# Generated snapshots (importer output)
snapshots/

# Generated reports (tool output)
reports/*
!reports/README.md
!reports/synthesis/
reports/synthesis/*
!reports/synthesis/wave_state.json

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/

# OS
.DS_Store

# Site-specific config (contains secrets/IPs — never commit)
/config.site.yaml

# Generated driver output (Makefile, default.nix, etc — regenerated from specs on demand)
output/

# Source distfiles — never committed; optionally cached to S3
distfiles/

# Working stubs (scratch area — use specs/ for committed canonical records)
stubs/

# Node.js — installed by npm install; not committed
node_modules/

# Build artifacts — regenerated by 'make compile-zsdl'; never committed
_build/
verify_all_specs_out.json
.claude/worktrees/

# MkDocs site output — regenerated by 'make docs'; never committed
site/
