{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theseus/schema/synthesis-result",
  "title": "Theseus Synthesis Audit Report",
  "description": "Output of synthesize_all_specs.py — per-spec synthesis results and aggregate statistics.",
  "type": "object",
  "required": ["generated_at", "model", "summary", "specs"],
  "additionalProperties": false,
  "properties": {
    "generated_at": {
      "type": "string",
      "description": "ISO-8601 UTC timestamp when the report was generated."
    },
    "model": {
      "type": "string",
      "description": "AI model or provider used for synthesis."
    },
    "summary": {
      "type": "object",
      "required": [
        "total_specs",
        "success_count",
        "partial_count",
        "failed_count",
        "build_failed_count",
        "infeasible_count",
        "total_invariants",
        "total_passing",
        "total_failing",
        "synthesizability_rate"
      ],
      "additionalProperties": false,
      "properties": {
        "total_specs":          { "type": "integer", "minimum": 0 },
        "success_count":        { "type": "integer", "minimum": 0 },
        "partial_count":        { "type": "integer", "minimum": 0 },
        "failed_count":         { "type": "integer", "minimum": 0 },
        "build_failed_count":   { "type": "integer", "minimum": 0 },
        "infeasible_count":     { "type": "integer", "minimum": 0 },
        "total_invariants":     { "type": "integer", "minimum": 0 },
        "total_passing":        { "type": "integer", "minimum": 0 },
        "total_failing":        { "type": "integer", "minimum": 0 },
        "synthesizability_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "success_count / total_specs (0.0–1.0)."
        }
      }
    },
    "specs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "canonical_name",
          "backend_lang",
          "status",
          "model",
          "attempted_at",
          "iterations",
          "pass_count",
          "fail_count",
          "total_invariants",
          "notes",
          "infeasible_reason",
          "failed_invariant_details"
        ],
        "additionalProperties": false,
        "properties": {
          "canonical_name":   { "type": "string" },
          "backend_lang":     { "type": "string", "enum": ["python", "c", "javascript"] },
          "status": {
            "type": "string",
            "enum": ["success", "partial", "failed", "build_failed", "infeasible"]
          },
          "model":            { "type": "string" },
          "attempted_at":     { "type": "string" },
          "iterations":       { "type": "integer", "minimum": 0 },
          "pass_count":       { "type": "integer", "minimum": 0 },
          "fail_count":       { "type": "integer", "minimum": 0 },
          "total_invariants": { "type": "integer", "minimum": 0 },
          "notes":            { "type": "string" },
          "infeasible_reason": { "type": ["string", "null"] },
          "failed_invariant_details": {
            "type": "object",
            "description": "Map of invariant ID to failure detail.",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "status": { "type": "string" },
                "reason": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
