{
  "$id": "https://example.org/schema/package-recipe.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "build": {
      "additionalProperties": true,
      "type": "object"
    },
    "dependencies": {
      "additionalProperties": true,
      "properties": {
        "build": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "host": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "runtime": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "test": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "build",
        "host",
        "runtime",
        "test"
      ],
      "type": "object"
    },
    "conflicts": {
      "description": "Package names that cannot be installed alongside this package.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "descriptive": {
      "additionalProperties": true,
      "properties": {
        "categories": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "deprecated": {
          "description": "True if the package is deprecated or marked broken by its ecosystem.",
          "type": "boolean"
        },
        "expiration_date": {
          "description": "ISO-8601 date on which the package will be removed (FreeBSD EXPIRATION_DATE).",
          "type": "string"
        },
        "homepage": {
          "type": "string"
        },
        "license": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "maintainers": {
          "description": "Maintainer identifiers: email addresses (FreeBSD) or GitHub handles (nixpkgs).",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "summary": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "extensions": {
      "additionalProperties": true,
      "type": "object"
    },
    "features": {
      "additionalProperties": true,
      "type": "object"
    },
    "identity": {
      "additionalProperties": true,
      "properties": {
        "canonical_id": {
          "type": "string"
        },
        "canonical_name": {
          "type": "string"
        },
        "ecosystem": {
          "type": "string"
        },
        "ecosystem_id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "canonical_name",
        "canonical_id",
        "version",
        "ecosystem",
        "ecosystem_id"
      ],
      "type": "object"
    },
    "patches": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "path": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "type": "array"
    },
    "platforms": {
      "additionalProperties": true,
      "properties": {
        "exclude": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "include": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "provenance": {
      "additionalProperties": true,
      "properties": {
        "confidence": {
          "type": "number"
        },
        "generated_by": {
          "type": "string"
        },
        "imported_at": {
          "type": "string"
        },
        "source_path": {
          "type": "string"
        },
        "source_repo_commit": {
          "type": [
            "string",
            "null"
          ]
        },
        "unmapped": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "schema_version": {
      "type": "string"
    },
    "stub": {
      "type": "boolean",
      "description": "True if this record is a generated stub awaiting verification."
    },
    "sources": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "type": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "description": "Checksum for distinfo/fetchurl."
          },
          "filename": {
            "type": "string",
            "description": "Override the downloaded filename."
          },
          "size": {
            "type": "integer",
            "description": "Distfile size in bytes for distinfo SIZE field."
          }
        },
        "required": [
          "type"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "tests": {
      "additionalProperties": true,
      "type": "object"
    },
    "behavioral_spec": {
      "type": "string",
      "description": "Relative path from the repo root to a Z-layer behavioral spec file (.zspec.json) that governs this library's behavior. When present, validate_record.py will run the spec and fail if any invariant fails."
    }
  },
  "required": [
    "schema_version",
    "identity",
    "descriptive",
    "sources",
    "dependencies",
    "build",
    "features",
    "platforms",
    "conflicts",
    "patches",
    "tests",
    "provenance",
    "extensions"
  ],
  "title": "Canonical Package Recipe",
  "type": "object"
}
