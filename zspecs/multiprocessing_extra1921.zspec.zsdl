spec: multiprocessing_extra1921
version: ">=3.9"
backend: python_module(multiprocessing)

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 575 (_extra1921): __slots__ inheritance checks, __abstractmethods__ set membership, __subclasshook__ dict presence, __init_subclass__ dict presence."
    - "multiprocessing.Process, queues.Queue, synchronize.Lock, synchronize.Event, synchronize.Semaphore, synchronize.Barrier, synchronize.BoundedSemaphore, synchronize.RLock do NOT define __slots__."
    - "multiprocessing.queues.SimpleQueue, queues.JoinableQueue do NOT define __slots__."
    - "multiprocessing.pool.Pool, managers.BaseManager do NOT define __slots__."
    - "None of the checked multiprocessing classes define __abstractmethods__, __subclasshook__, or __init_subclass__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table multiprocessing_extra1921.slots_protocol:
  description: "multiprocessing types __slots__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1921

  columns: [id, function, args, expected]
  rows:
    - ["mp1921001", "multiprocessing.Process.__dict__.__contains__", ["__slots__"], false]
    - ["mp1921002", "multiprocessing.queues.Queue.__dict__.__contains__", ["__slots__"], false]
    - ["mp1921003", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__slots__"], false]
    - ["mp1921004", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__slots__"], false]
    - ["mp1921005", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__slots__"], false]
    - ["mp1921006", "multiprocessing.synchronize.Barrier.__dict__.__contains__", ["__slots__"], false]
    - ["mp1921007", "multiprocessing.synchronize.BoundedSemaphore.__dict__.__contains__", ["__slots__"], false]
    - ["mp1921008", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__slots__"], false]
    - ["mp1921009", "multiprocessing.queues.SimpleQueue.__dict__.__contains__", ["__slots__"], false]
    - ["mp1921010", "multiprocessing.queues.JoinableQueue.__dict__.__contains__", ["__slots__"], false]
    - ["mp1921011", "multiprocessing.pool.Pool.__dict__.__contains__", ["__slots__"], false]
    - ["mp1921012", "multiprocessing.managers.BaseManager.__dict__.__contains__", ["__slots__"], false]

