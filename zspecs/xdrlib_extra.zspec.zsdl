spec: xdrlib_extra
version: ">=3.9,<3.13"
backend: python_module(xdrlib)

docs: https://docs.python.org/3/library/xdrlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xdrlib.html — Python xdrlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xdrlib.py"
  notes:
    - "This spec complements xdrlib.zspec.zsdl with additional invariants."
    - "Deprecated since Python 3.11; removed in Python 3.13. Version range is >=3.9,<3.13."
    - "xdrlib encodes and decodes data in XDR (External Data Representation) format per RFC 1014."
    - "Packer.__name__ == 'Packer' and Packer.__module__ == 'xdrlib'."
    - "Unpacker.__name__ == 'Unpacker' and Unpacker.__module__ == 'xdrlib'."
    - "Error.__name__ == 'Error' and Error.__bases__[0].__name__ == 'Exception'."
    - "ConversionError.__name__ == 'ConversionError' and ConversionError.__bases__[0].__name__ == 'Error'."
    - "All expected values verified by running Python 3.12 xdrlib module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Packer class — name and module affiliation
# ---------------------------------------------------------------------------

invariant xdrlib_extra.Packer.name:
  description: "xdrlib.Packer.__name__ == 'Packer'"
  category: classnames
  kind: python_call_eq
  function: Packer.__name__.__eq__
  args: ["Packer"]
  expected: true

invariant xdrlib_extra.Packer.module:
  description: "xdrlib.Packer.__module__ == 'xdrlib'"
  category: classnames
  kind: python_call_eq
  function: Packer.__module__.__eq__
  args: ["xdrlib"]
  expected: true

invariant xdrlib_extra.Packer.is_class:
  description: "xdrlib.Packer.__class__.__name__ == 'type' — Packer is a class object"
  category: classnames
  kind: python_call_eq
  function: Packer.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Unpacker class — name and module affiliation
# ---------------------------------------------------------------------------

invariant xdrlib_extra.Unpacker.name:
  description: "xdrlib.Unpacker.__name__ == 'Unpacker'"
  category: classnames
  kind: python_call_eq
  function: Unpacker.__name__.__eq__
  args: ["Unpacker"]
  expected: true

invariant xdrlib_extra.Unpacker.module:
  description: "xdrlib.Unpacker.__module__ == 'xdrlib'"
  category: classnames
  kind: python_call_eq
  function: Unpacker.__module__.__eq__
  args: ["xdrlib"]
  expected: true

invariant xdrlib_extra.Unpacker.is_class:
  description: "xdrlib.Unpacker.__class__.__name__ == 'type' — Unpacker is a class object"
  category: classnames
  kind: python_call_eq
  function: Unpacker.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Error class — name, hierarchy, and module
# ---------------------------------------------------------------------------

invariant xdrlib_extra.Error.name:
  description: "xdrlib.Error.__name__ == 'Error'"
  category: classnames
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant xdrlib_extra.Error.base_is_Exception:
  description: "xdrlib.Error.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

invariant xdrlib_extra.Error.is_class:
  description: "xdrlib.Error.__class__.__name__ == 'type' — Error is a class object"
  category: classnames
  kind: python_call_eq
  function: Error.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# ConversionError class — name and hierarchy
# ---------------------------------------------------------------------------

invariant xdrlib_extra.ConversionError.name:
  description: "xdrlib.ConversionError.__name__ == 'ConversionError'"
  category: classnames
  kind: python_call_eq
  function: ConversionError.__name__.__eq__
  args: ["ConversionError"]
  expected: true

invariant xdrlib_extra.ConversionError.base_is_Error:
  description: "xdrlib.ConversionError.__bases__[0].__name__ == 'Error'"
  category: hierarchy
  kind: python_call_eq
  function: ConversionError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Error"

invariant xdrlib_extra.ConversionError.is_class:
  description: "xdrlib.ConversionError.__class__.__name__ == 'type' — ConversionError is a class object"
  category: classnames
  kind: python_call_eq
  function: ConversionError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — Error and ConversionError are defined in xdrlib
# ---------------------------------------------------------------------------

invariant xdrlib_extra.Error.module:
  description: "xdrlib.Error.__module__ == 'xdrlib'"
  category: module
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["xdrlib"]
  expected: true

invariant xdrlib_extra.ConversionError.module:
  description: "xdrlib.ConversionError.__module__ == 'xdrlib'"
  category: module
  kind: python_call_eq
  function: ConversionError.__module__.__eq__
  args: ["xdrlib"]
  expected: true
