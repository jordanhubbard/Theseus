spec: th3256
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 664 (th3256): __rpow__, __rlshift__, __rrshift__ dict-presence checks for threading types."
    - "Theme: __rpow__/__rlshift__/__rrshift__ reflected power/shift dict-presence."
    - "Reflected operators are called when the left operand doesn't support the operation."
    - "All values False — callable/iterator/inspection/synchronization types have no reflected arithmetic."
    - "None of the threading types define __rpow__, __rlshift__, or __rrshift__ in their own __dict__."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier, and threading.local are Python-level classes."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3256.rpow:
  description: "threading types __rpow__ dict-presence checks; wave 664"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3256
  columns: [id, function, args, expected]
  rows:
    - ["th3256001", operator.contains, [threading.Thread.__dict__,           "__rpow__"], false]
    - ["th3256002", operator.contains, [threading.Event.__dict__,            "__rpow__"], false]
    - ["th3256003", operator.contains, [threading.Condition.__dict__,        "__rpow__"], false]
    - ["th3256004", operator.contains, [threading.Semaphore.__dict__,        "__rpow__"], false]
    - ["th3256005", operator.contains, [threading.BoundedSemaphore.__dict__, "__rpow__"], false]
    - ["th3256006", operator.contains, [threading.Timer.__dict__,            "__rpow__"], false]
    - ["th3256007", operator.contains, [threading.Barrier.__dict__,          "__rpow__"], false]
    - ["th3256008", operator.contains, [threading.local.__dict__,            "__rpow__"], false]
    - ["th3256009", operator.contains, [type(threading.Lock()).__dict__,     "__rpow__"], false]
    - ["th3256010", operator.contains, [type(threading.RLock()).__dict__,    "__rpow__"], false]

