spec: asyncio_extra2176
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Theme: iterator/sequence protocol dict-presence — checks for __iter__, __next__, __aiter__, __anext__, __await__, __length_hint__, __reversed__, __missing__ in class __dict__."
    - "asyncio.Task defines __iter__ and __await__ (awaitable/coroutine protocol) but no __next__, __aiter__, __anext__, __length_hint__, __reversed__, or __missing__."
    - "asyncio.Future defines __iter__ and __await__ (awaitable protocol) but no __next__, __aiter__, __anext__, __length_hint__, __reversed__, or __missing__."
    - "asyncio.Event does not define any iterator/sequence protocol methods in its own __dict__."
    - "asyncio.Lock does not define any iterator/sequence protocol methods in its own __dict__."
    - "asyncio.Queue does not define any iterator/sequence protocol methods in its own __dict__; it is not an async iterable despite its name."
    - "asyncio.Semaphore does not define any iterator/sequence protocol methods in its own __dict__."
    - "asyncio.Condition does not define any iterator/sequence protocol methods in its own __dict__."
    - "asyncio.StreamReader defines __aiter__ and __anext__ (async iterator protocol) for reading lines asynchronously, but no __iter__, __next__, __await__, __length_hint__, __reversed__, or __missing__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Task — iterator/sequence protocol dict-presence
# ---------------------------------------------------------------------------

table asyncio_extra2176.Task_iterator_presence:
  kind: python_call_eq
  category: iterator_presence
  columns: [id, function, args, expected]
  rows:
    - ["as2176001", "asyncio.Task.__dict__.__contains__", ["__iter__"], true]
    - ["as2176002", "asyncio.Task.__dict__.__contains__", ["__next__"], false]
    - ["as2176003", "asyncio.Task.__dict__.__contains__", ["__aiter__"], false]
    - ["as2176004", "asyncio.Task.__dict__.__contains__", ["__anext__"], false]
    - ["as2176005", "asyncio.Task.__dict__.__contains__", ["__await__"], true]
    - ["as2176006", "asyncio.Task.__dict__.__contains__", ["__length_hint__"], false]
    - ["as2176007", "asyncio.Task.__dict__.__contains__", ["__reversed__"], false]
    - ["as2176008", "asyncio.Task.__dict__.__contains__", ["__missing__"], false]

