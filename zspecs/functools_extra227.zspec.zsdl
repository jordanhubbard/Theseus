spec: functools_extra227
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools __qualname__ and __name__/__module__ identity contracts."
    - "functools.reduce.__qualname__ == 'reduce'. Verified with Python 3.14.3."
    - "functools.partial.__qualname__ == 'partial'. Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache'. Verified with Python 3.14.3."
    - "functools.singledispatch.__qualname__ == 'singledispatch'. Verified with Python 3.14.3."
    - "functools.cached_property.__qualname__ == 'cached_property'. Verified with Python 3.14.3."
    - "functools.total_ordering.__qualname__ == 'total_ordering'. Verified with Python 3.14.3."
    - "functools.wraps.__qualname__ == 'wraps'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__qualname__ == 'update_wrapper'. Verified with Python 3.14.3."
    - "functools.wraps.__name__ == 'wraps'. Verified with Python 3.14.3."
    - "functools.wraps.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__name__ == 'update_wrapper'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__module__ == 'functools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools __qualname__ identity checks
#
# Verified with Python 3.14.3:
#   functools.reduce.__qualname__ == 'reduce'
#   functools.partial.__qualname__ == 'partial'
#   functools.lru_cache.__qualname__ == 'lru_cache'
#   functools.singledispatch.__qualname__ == 'singledispatch'
#   functools.cached_property.__qualname__ == 'cached_property'
#   functools.total_ordering.__qualname__ == 'total_ordering'
#   functools.wraps.__qualname__ == 'wraps'
#   functools.update_wrapper.__qualname__ == 'update_wrapper'
# ---------------------------------------------------------------------------

table functools_extra227.qualnames:
  description: "functools function and class __qualname__ identity checks; new to extra227"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra227qualname

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_qualname_eq,
       reduce.__qualname__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — reduce is a C built-in at module scope in _functoolsmodule.c; __qualname__ is the simple name 'reduce' with no enclosing scope prefix; str.__eq__('reduce') returns True; new to extra227"]
    - [partial_qualname_eq,
       partial.__qualname__.__eq__,
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — partial is a C extension type defined at module scope; __qualname__ is 'partial'; str.__eq__('partial') returns True; new to extra227"]
    - [lru_cache_qualname_eq,
       lru_cache.__qualname__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — lru_cache is a Python function defined at module scope in Lib/functools.py; __qualname__ is 'lru_cache'; str.__eq__('lru_cache') returns True; new to extra227"]
    - [singledispatch_qualname_eq,
       singledispatch.__qualname__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__qualname__.__eq__('singledispatch') == True — singledispatch is defined at module scope; __qualname__ is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra227"]
    - [cached_property_qualname_eq,
       cached_property.__qualname__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__qualname__.__eq__('cached_property') == True — cached_property is a Python class defined at module scope; __qualname__ is 'cached_property'; str.__eq__('cached_property') returns True; new to extra227"]
    - [total_ordering_qualname_eq,
       total_ordering.__qualname__.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__.__eq__('total_ordering') == True — total_ordering is a Python function defined at module scope; __qualname__ is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra227"]
    - [wraps_qualname_eq,
       wraps.__qualname__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__qualname__.__eq__('wraps') == True — wraps is a Python function defined at module scope in Lib/functools.py; __qualname__ is 'wraps'; str.__eq__('wraps') returns True; new to extra227"]
    - [update_wrapper_qualname_eq,
       update_wrapper.__qualname__.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__qualname__.__eq__('update_wrapper') == True — update_wrapper is a Python function defined at module scope; __qualname__ is 'update_wrapper'; str.__eq__('update_wrapper') returns True; new to extra227"]

# ---------------------------------------------------------------------------
# Table 2: functools.wraps and update_wrapper __name__ and __module__
#
# Verified with Python 3.14.3:
#   functools.wraps.__name__ == 'wraps'
#   functools.wraps.__module__ == 'functools'
#   functools.update_wrapper.__name__ == 'update_wrapper'
#   functools.update_wrapper.__module__ == 'functools'
# ---------------------------------------------------------------------------

table functools_extra227.wraps_identity:
  description: "functools.wraps and update_wrapper __name__ and __module__ identity checks; new to extra227"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra227wrapsid

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_name_eq,
       wraps.__name__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__name__.__eq__('wraps') == True — wraps is a Python function in Lib/functools.py; __name__ is 'wraps'; str.__eq__('wraps') returns True; new to extra227"]
    - [wraps_module_eq,
       wraps.__module__.__eq__,
       ["functools"],
       true,
       "functools.wraps.__module__.__eq__('functools') == True — wraps is defined in the functools module; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra227"]
    - [update_wrapper_name_eq,
       update_wrapper.__name__.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__name__.__eq__('update_wrapper') == True — update_wrapper is a Python function in Lib/functools.py; __name__ is 'update_wrapper'; str.__eq__('update_wrapper') returns True; new to extra227"]
    - [update_wrapper_module_eq,
       update_wrapper.__module__.__eq__,
       ["functools"],
       true,
       "functools.update_wrapper.__module__.__eq__('functools') == True — update_wrapper is defined in the functools module; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra227"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra227
# ---------------------------------------------------------------------------

invariant functools_extra227.reduce_qualname:
  description: "functools.reduce.__qualname__.__eq__('reduce') == True — 'reduce' __qualname__ is 'reduce'; new to extra227"
  kind: python_call_eq
  function: reduce.__qualname__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra227.partial_qualname:
  description: "functools.partial.__qualname__.__eq__('partial') == True — 'partial' __qualname__ is 'partial'; new to extra227"
  kind: python_call_eq
  function: partial.__qualname__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra227.lru_cache_qualname:
  description: "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — 'lru_cache' __qualname__ is 'lru_cache'; new to extra227"
  kind: python_call_eq
  function: lru_cache.__qualname__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra227.singledispatch_qualname:
  description: "functools.singledispatch.__qualname__.__eq__('singledispatch') == True — 'singledispatch' __qualname__ is 'singledispatch'; new to extra227"
  kind: python_call_eq
  function: singledispatch.__qualname__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra227.cached_property_qualname:
  description: "functools.cached_property.__qualname__.__eq__('cached_property') == True — 'cached_property' __qualname__ is 'cached_property'; new to extra227"
  kind: python_call_eq
  function: cached_property.__qualname__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra227.total_ordering_qualname:
  description: "functools.total_ordering.__qualname__.__eq__('total_ordering') == True — 'total_ordering' __qualname__ is 'total_ordering'; new to extra227"
  kind: python_call_eq
  function: total_ordering.__qualname__.__eq__
  args: ["total_ordering"]
  expected: true

invariant functools_extra227.wraps_qualname:
  description: "functools.wraps.__qualname__.__eq__('wraps') == True — 'wraps' __qualname__ is 'wraps'; new to extra227"
  kind: python_call_eq
  function: wraps.__qualname__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra227.update_wrapper_qualname:
  description: "functools.update_wrapper.__qualname__.__eq__('update_wrapper') == True — 'update_wrapper' __qualname__ is 'update_wrapper'; new to extra227"
  kind: python_call_eq
  function: update_wrapper.__qualname__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra227.wraps_name:
  description: "functools.wraps.__name__.__eq__('wraps') == True — wraps __name__ is 'wraps'; new to extra227"
  kind: python_call_eq
  function: wraps.__name__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra227.wraps_module:
  description: "functools.wraps.__module__.__eq__('functools') == True — wraps __module__ is 'functools'; new to extra227"
  kind: python_call_eq
  function: wraps.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra227.update_wrapper_name:
  description: "functools.update_wrapper.__name__.__eq__('update_wrapper') == True — update_wrapper __name__ is 'update_wrapper'; new to extra227"
  kind: python_call_eq
  function: update_wrapper.__name__.__eq__
  args: ["update_wrapper"]
