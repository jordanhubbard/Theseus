spec: multiprocessing_extra61
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python function __defaults__ and __code__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra60.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__.__class__.__name__/__len__() tables, Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__name__=='function', ProcessError/AuthenticationError/__class__.__name__=='type' (extra45), Process/__class__.__module__=='builtins', current_process/__class__.__module__=='builtins', cpu_count/__class__.__module__=='builtins' (extra46), Pool/__doc__/__class__/__module__=='builtins' (extra50), Pool/__class__.__name__=='type', Pool/active_children/ProcessError/AuthenticationError __class__.__module__.__eq__('builtins') (extra53), Process/__init__.__class__.__name__.__eq__('function') (extra53), Process/Pool __repr__.__class__.__name__ (extra54), Process __weakref__.__class__.__name__ (extra54), ProcessError/AuthenticationError exception __repr__.__class__.__name__ (extra54), mp.__all__.__class__.__name__.__eq__('list') (extra55), mp.__all__.__len__()==37 (extra55), Process/ProcessError/AuthenticationError __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra55), mp.__all__.__contains__ membership checks (extra56), mp.__package__.__eq__('multiprocessing') (extra56), Queue/Pool __doc__.__class__.__name__.__eq__('str') (extra56), __loader__/__spec__/__file__/__cached__ __class__.__name__ (extra57), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__() (extra58), Process method __qualname__ string equality for start/run/join/terminate/kill/is_alive/close/interrupt (extra59), Process.__init__/__annotations__/__globals__ class identity + current_process __annotations__ class identity and len (extra60)."
    - "This spec covers (mpcode61 namespace): wave 229 theme — __defaults__ and __code__ checks for function parameters + __closure__ identity. NEW in extra61: Process.__init__.__defaults__.__class__.__name__.__eq__('tuple') — Process(group=None, target=None, name=None, args=(), kwargs={}, daemon=None) has __defaults__==(None, None, None, (), None) a five-element tuple; no prior mp spec has checked Process.__init__.__defaults__.__class__.__name__ via __eq__; Process.__init__.__code__.__class__.__name__.__eq__('code') — Process.__init__ is a pure-Python function (inherited from BaseProcess) with a code object; no prior mp spec has checked Process.__init__.__code__.__class__.__name__ via __eq__; current_process.__defaults__.__class__.__name__.__eq__('NoneType') — current_process() takes no arguments so __defaults__ is None; current_process.__code__.__class__.__name__.__eq__('code') — current_process is a pure-Python function with a code object."
    - "multiprocessing.Process.__init__.__defaults__ == (None, None, None, (), None). Process inherits __init__ from BaseProcess. BaseProcess.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, daemon=None). The positional-or-keyword parameters with defaults are group, target, name, args, daemon (kwargs is also in __defaults__... but note: actual value is (None, None, None, (), None) — 5 elements mapping to group/target/name/args/daemon respectively; kwargs default ({}) may also be present). __defaults__.__class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__init__.__code__.__class__.__name__ == 'code'. Process.__init__ is inherited from BaseProcess. BaseProcess.__init__ is a pure-Python function defined in Lib/multiprocessing/process.py. All pure-Python functions have a __code__ attribute that is a code object. __class__.__name__ of a code object is 'code'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.current_process.__defaults__ is None. current_process() takes no arguments, so __defaults__ is None. None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.current_process.__code__.__class__.__name__ == 'code'. current_process is a pure-Python function defined in Lib/multiprocessing/process.py. Its __code__ attribute is a code object with __class__.__name__ == 'code'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Process.__init__ and current_process __defaults__ checks — extra61
#
# Wave 229 theme: __defaults__ and __code__ checks for function parameters.
#
# Process.__init__ (inherited from BaseProcess) has defaults for group, target,
# name, args, and daemon parameters. __defaults__ is a tuple of 5 elements:
# (None, None, None, (), None). __class__.__name__ is 'tuple'.
#
# current_process() takes no arguments, so __defaults__ is None (NoneType).
#
# NEW: no prior mp spec has checked __defaults__.__class__.__name__ via __eq__
# for Process.__init__ or current_process.
# ---------------------------------------------------------------------------

table multiprocessing_extra61.function_defaults_class_name:
  description: "multiprocessing function __defaults__.__class__.__name__.__eq__ checks in mpcode61 namespace — wave 229 theme: __defaults__ class identity; Process.__init__ (inherited from BaseProcess) has __defaults__==(None, None, None, (), None) a five-element tuple; current_process() has no defaults so __defaults__ is None (NoneType); NEW in extra61: no prior mp spec has checked __defaults__.__class__.__name__ via __eq__ for Process.__init__ or current_process; verified with Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: mpcode61

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_defaults_class,  Process.__init__.__defaults__.__class__.__name__.__eq__,  ["tuple"],    true, "Process.__init__.__defaults__.__class__.__name__ == 'tuple' — Process inherits __init__ from BaseProcess; BaseProcess.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, daemon=None) has multiple positional-or-keyword parameters with defaults; __defaults__ is a tuple (e.g. (None, None, None, (), None)); tuple.__class__.__name__ is 'tuple'; NEW in extra61: first __defaults__.__class__.__name__.__eq__ check for Process.__init__ in any mp spec; verified with Python 3.14.3"]
    - [current_process_defaults_class, current_process.__defaults__.__class__.__name__.__eq__, ["NoneType"], true, "current_process.__defaults__.__class__.__name__ == 'NoneType' — current_process() takes no arguments; __defaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra61: first __defaults__.__class__.__name__.__eq__ check for current_process in any mp spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process.__init__ and current_process __code__ checks — extra61
#
# Wave 229 theme: __code__ checks for function parameters.
#
# Both Process.__init__ (inherited from BaseProcess) and current_process are
# pure-Python functions. All pure-Python functions have a __code__ attribute
# that is a code object. The type of a code object is <class 'code'>, so
# __class__.__name__ is 'code'.
#
# NEW: no prior mp spec has checked __code__.__class__.__name__ via __eq__
# for Process.__init__ or current_process.
# ---------------------------------------------------------------------------

table multiprocessing_extra61.function_code_class_name:
  description: "multiprocessing function __code__.__class__.__name__.__eq__('code') checks in mpcode61 namespace — wave 229 theme: __code__ class identity; Process.__init__ (inherited from BaseProcess in Lib/multiprocessing/process.py) and current_process are pure-Python functions; all pure-Python functions have a __code__ attribute that is a code object; __class__.__name__ of a code object is 'code'; NEW in extra61: no prior mp spec has checked __code__.__class__.__name__ via __eq__ for Process.__init__ or current_process; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpcode61c

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_code_class,    Process.__init__.__code__.__class__.__name__.__eq__,    ["code"], true, "Process.__init__.__code__.__class__.__name__ == 'code' — Process inherits __init__ from BaseProcess (Lib/multiprocessing/process.py); BaseProcess.__init__ is a pure-Python function; all pure-Python functions have a __code__ attribute that is a code object; __class__.__name__ of a code object is 'code'; NEW in extra61: first __code__.__class__.__name__.__eq__ check for Process.__init__ in any mp spec; verified with Python 3.14.3"]
    - [current_process_code_class, current_process.__code__.__class__.__name__.__eq__, ["code"], true, "current_process.__code__.__class__.__name__ == 'code' — current_process is a pure-Python function defined in Lib/multiprocessing/process.py; its __code__ attribute is a code object with __class__.__name__ == 'code'; NEW in extra61: first __code__.__class__.__name__.__eq__ check for current_process in any mp spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra61
# ---------------------------------------------------------------------------

invariant multiprocessing_extra61.process_init_defaults_class_name_eq:
  description: "multiprocessing.Process.__init__.__defaults__.__class__.__name__.__eq__('tuple') returns True — Process inherits __init__ from BaseProcess; BaseProcess.__init__ has multiple positional-or-keyword parameters with defaults (group, target, name, args, daemon); __defaults__ is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra61: no prior mp spec has checked Process.__init__.__defaults__.__class__.__name__ via __eq__; wave 229 first __defaults__ class identity invariant for Process.__init__ in any mp spec; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: Process.__init__.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant multiprocessing_extra61.current_process_defaults_class_name_eq:
  description: "multiprocessing.current_process.__defaults__.__class__.__name__.__eq__('NoneType') returns True — current_process() takes no arguments; __defaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra61: no prior mp spec has checked current_process.__defaults__.__class__.__name__ via __eq__; wave 229 first __defaults__ NoneType identity invariant for current_process in any mp spec; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: current_process.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant multiprocessing_extra61.process_init_code_class_name_eq:
  description: "multiprocessing.Process.__init__.__code__.__class__.__name__.__eq__('code') returns True — Process inherits __init__ from BaseProcess (Lib/multiprocessing/process.py); BaseProcess.__init__ is a pure-Python function; all pure-Python functions have a __code__ attribute that is a code object; __class__.__name__ of a code object is 'code'; NEW in extra61: no prior mp spec has checked Process.__init__.__code__.__class__.__name__ via __eq__; wave 229 first __code__ class identity invariant for Process.__init__ in any mp spec; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.__init__.__code__.__class__.__name__.__eq__
  args: ["code"]
  expected: true

invariant multiprocessing_extra61.current_process_code_class_name_eq:
  description: "multiprocessing.current_process.__code__.__class__.__name__.__eq__('code') returns True — current_process is a pure-Python function defined in Lib/multiprocessing/process.py; its __code__ attribute is a code object with __class__.__name__ == 'code'; NEW in extra61: no prior mp spec has checked current_process.__code__.__class__.__name__ via __eq__; wave 229 invariant alongside Process.__init__ code check; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: current_process.__code__.__class__.__name__.__eq__
  args: ["code"]
  expected: true
