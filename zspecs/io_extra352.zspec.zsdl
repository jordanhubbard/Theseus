spec: io_extra352
version: ">=3.7"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io._io C extension — module and class name attributes
# ---------------------------------------------------------------------------

invariant io._io.module_name:
  description: "io._io.__name__ == '_io' — the C extension sub-module name"
  category: module_metadata
  kind: python_call_eq
  function: _io.__name__.__eq__
  args: ["_io"]
  expected: true

invariant io._io.BytesIO.class_name:
  description: "io._io.BytesIO.__name__ == 'BytesIO'"
  category: class_metadata
  kind: python_call_eq
  function: _io.BytesIO.__name__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io._io.StringIO.class_name:
  description: "io._io.StringIO.__name__ == 'StringIO'"
  category: class_metadata
  kind: python_call_eq
  function: _io.StringIO.__name__.__eq__
  args: ["StringIO"]
  expected: true

invariant io._io.FileIO.class_name:
  description: "io._io.FileIO.__name__ == 'FileIO'"
  category: class_metadata
  kind: python_call_eq
  function: _io.FileIO.__name__.__eq__
  args: ["FileIO"]
  expected: true

invariant io._io.DEFAULT_BUFFER_SIZE:
  description: "io._io.DEFAULT_BUFFER_SIZE == 131072 — default I/O buffer size is 128 KiB"
  category: constants
  kind: python_call_eq
  function: _io.DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true

invariant io._io.UnsupportedOperation.class_name:
  description: "io._io.UnsupportedOperation.__name__ == 'UnsupportedOperation'"
  category: class_metadata
  kind: python_call_eq
  function: _io.UnsupportedOperation.__name__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

invariant io._io.open.func_name:
  description: "io._io.open.__name__ == 'open'"
  category: function_metadata
  kind: python_call_eq
  function: _io.open.__name__.__eq__
  args: ["open"]
  expected: true

invariant io._io.open_code.func_name:
  description: "io._io.open_code.__name__ == 'open_code'"
  category: function_metadata
  kind: python_call_eq
  function: _io.open_code.__name__.__eq__
  args: ["open_code"]
  expected: true
