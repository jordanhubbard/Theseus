spec: threading_extra856
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "Python standard library threading module"
    - "CPython source: Lib/threading.py"
  not_derived_from:
    - "Any third-party threading or concurrency library"
  notes:
    - "Covers __qualname__ and __module__ for threading utility functions"
    - "Includes threading.local class identity and TIMEOUT_MAX type verification"
  created_at: "2026-04-12"

table threading_extra856.utility_qualnames:
  description: "Verify qualnames, modules, and type identities for threading module-level utilities"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: th856uq
  columns: [id, function, args, expected]
  rows:
    - [th856uq001, "threading.local.__qualname__.__eq__", ["local"], true]
    - [th856uq002, "threading.local.__module__.__eq__", ["threading"], true]
    - [th856uq003, "threading.local.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [th856uq004, "threading.get_ident.__qualname__.__eq__", ["get_ident"], true]
    - [th856uq005, "threading.get_ident.__module__.__eq__", ["threading"], true]
    - [th856uq006, "threading.get_native_id.__qualname__.__eq__", ["get_native_id"], true]
    - [th856uq007, "threading.get_native_id.__module__.__eq__", ["threading"], true]
    - [th856uq008, "threading.stack_size.__qualname__.__eq__", ["stack_size"], true]
    - [th856uq009, "threading.stack_size.__module__.__eq__", ["threading"], true]
    - [th856uq010, "threading.excepthook.__qualname__.__eq__", ["excepthook"], true]
    - [th856uq011, "threading.excepthook.__module__.__eq__", ["threading"], true]
    - [th856uq012, "threading.TIMEOUT_MAX.__class__.__name__.__eq__", ["float"], true]
