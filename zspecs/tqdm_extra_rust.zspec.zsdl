spec: tqdm_extra_rust
version: ">=3.9"
backend: rust_module(tqdm_extra_rust)

docs: https://tqdm.github.io/

provenance:
  derived_from:
    - "https://tqdm.github.io/ — tqdm progress bar library"
  notes:
    - "tqdm provides fast, extensible progress bars."
    - "tqdm.tqdm is a class."
    - "list(tqdm.tqdm(range(3), disable=True)) == [0,1,2]."
    - "tqdm.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant tqdm_extra_rust.range_list:
  description: "list(tqdm(range(3), disable=True)) == [0,1,2]"
  category: iteration
  kind: python_call_eq
  function: tqdm_range_list
  args: [3]
  expected: [0, 1, 2]

invariant tqdm_extra_rust.has_tqdm_class:
  description: "tqdm.tqdm is a class"
  category: presence
  kind: python_call_eq
  function: tqdm_has_class
  args: []
  expected: true

invariant tqdm_extra_rust.version_nonempty:
  description: "tqdm.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: tqdm_version_nonempty
  args: []
  expected: true

