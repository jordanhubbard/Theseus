spec: concurrent_futures_extra136
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py, Lib/concurrent/futures/thread.py, Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers: concurrent.futures exception classes — InvalidStateError, BrokenExecutor, CancelledError, and Error — their __name__, __qualname__, and __module__ string attributes. Also BrokenThreadPool and BrokenProcessPool from the thread and process submodules. InvalidStateError.__name__=='InvalidStateError' (len=17); InvalidStateError.__module__=='concurrent.futures._base' (len=24); InvalidStateError.__bases__[0].__name__=='Error' (the local Error base, len=5). BrokenExecutor.__name__=='BrokenExecutor' (len=14); BrokenExecutor.__bases__[0].__name__=='RuntimeError'. CancelledError.__name__=='CancelledError' (len=14); CancelledError.__module__=='concurrent.futures._base' (len=24). Error.__name__=='Error' (len=5); Error.__bases__[0].__name__=='Exception'. BrokenThreadPool.__name__=='BrokenThreadPool' (len=16); BrokenProcessPool.__name__=='BrokenProcessPool' (len=17). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.InvalidStateError identity — extra136
#
# concurrent.futures.InvalidStateError.__name__              == 'InvalidStateError' (len=17)
# concurrent.futures.InvalidStateError.__qualname__          == 'InvalidStateError' (len=17)
# concurrent.futures.InvalidStateError.__module__            == 'concurrent.futures._base' (len=24)
# concurrent.futures.InvalidStateError.__bases__[0].__name__ == 'Error'             (len=5)
# ---------------------------------------------------------------------------

table concurrent_futures_extra136.invalid_state_error_identity:
  description: "concurrent.futures.InvalidStateError class identity checks — InvalidStateError.__name__.__eq__('InvalidStateError')==True (len=17: 'Invalid'=7+'State'=5+'Error'=5=17); InvalidStateError.__qualname__.__eq__('InvalidStateError')==True (len=17, same as __name__ — top-level class); InvalidStateError.__module__.__eq__('concurrent.futures._base')==True (len=24: same module as Future, len=24); InvalidStateError.__bases__[0].__name__.__eq__('Error')==True (len=5: local Error base class, itself a subclass of Exception); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfise136

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,    concurrent.futures.InvalidStateError.__name__.__eq__,              ["InvalidStateError"],       true, "InvalidStateError.__name__ == 'InvalidStateError' (len=17); verified with Python 3.14.3"]
    - [name_len,   concurrent.futures.InvalidStateError.__name__.__len__,              [],                         17,   "InvalidStateError.__name__.__len__() == 17; verified with Python 3.14.3"]
    - [qn_eq,      concurrent.futures.InvalidStateError.__qualname__.__eq__,          ["InvalidStateError"],       true, "InvalidStateError.__qualname__ == 'InvalidStateError' (len=17, same as __name__); verified with Python 3.14.3"]
    - [qn_len,     concurrent.futures.InvalidStateError.__qualname__.__len__,          [],                         17,   "InvalidStateError.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [mod_eq,     concurrent.futures.InvalidStateError.__module__.__eq__,            ["concurrent.futures._base"], true, "InvalidStateError.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [mod_len,    concurrent.futures.InvalidStateError.__module__.__len__,            [],                          24,   "InvalidStateError.__module__.__len__() == 24; verified with Python 3.14.3"]
    - ["base_name", "concurrent.futures.InvalidStateError.__bases__[0].__name__.__eq__", ["Error"],                  true, "InvalidStateError.__bases__[0].__name__ == 'Error' (len=5); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.BrokenExecutor identity — extra136
#
# concurrent.futures.BrokenExecutor.__name__              == 'BrokenExecutor' (len=14)
# concurrent.futures.BrokenExecutor.__qualname__          == 'BrokenExecutor' (len=14)
# concurrent.futures.BrokenExecutor.__module__            == 'concurrent.futures._base' (len=24)
# concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'
# ---------------------------------------------------------------------------

table concurrent_futures_extra136.broken_executor_identity:
  description: "concurrent.futures.BrokenExecutor class identity checks — BrokenExecutor.__name__.__eq__('BrokenExecutor')==True (len=14: 'Broken'=6+'Executor'=8=14); BrokenExecutor.__qualname__.__eq__('BrokenExecutor')==True (len=14, same as __name__ — top-level class); BrokenExecutor.__module__.__eq__('concurrent.futures._base')==True (len=24: same module as InvalidStateError); BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError')==True (inherits from RuntimeError, not Error — distinct hierarchy from InvalidStateError); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfbe136

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,   concurrent.futures.BrokenExecutor.__name__.__eq__,              ["BrokenExecutor"],          true, "BrokenExecutor.__name__ == 'BrokenExecutor' (len=14); verified with Python 3.14.3"]
    - [name_len,  concurrent.futures.BrokenExecutor.__name__.__len__,              [],                          14,   "BrokenExecutor.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [qn_eq,     concurrent.futures.BrokenExecutor.__qualname__.__eq__,          ["BrokenExecutor"],          true, "BrokenExecutor.__qualname__ == 'BrokenExecutor' (len=14, same as __name__); verified with Python 3.14.3"]
    - [mod_eq,    concurrent.futures.BrokenExecutor.__module__.__eq__,            ["concurrent.futures._base"], true, "BrokenExecutor.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [mod_len,   concurrent.futures.BrokenExecutor.__module__.__len__,            [],                          24,   "BrokenExecutor.__module__.__len__() == 24; verified with Python 3.14.3"]
    - ["base_name", "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__", ["RuntimeError"],            true, "BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures._base.Error identity — extra136
#
# concurrent.futures._base.Error.__name__              == 'Error' (len=5)
# concurrent.futures._base.Error.__qualname__          == 'Error' (len=5)
# concurrent.futures._base.Error.__module__            == 'concurrent.futures._base' (len=24)
# concurrent.futures._base.Error.__bases__[0].__name__ == 'Exception'
# ---------------------------------------------------------------------------

table concurrent_futures_extra136.error_identity:
  description: "concurrent.futures._base.Error class identity checks — Error.__name__.__eq__('Error')==True (len=5); Error.__qualname__.__eq__('Error')==True (len=5, same as __name__ — top-level class); Error.__module__.__eq__('concurrent.futures._base')==True (len=24); Error.__bases__[0].__name__.__eq__('Exception')==True (direct subclass of Exception — this is the root of the futures exception hierarchy: Error->CancelledError, Error->InvalidStateError); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cferr136

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,   concurrent.futures._base.Error.__name__.__eq__,              ["Error"],                    true, "Error.__name__ == 'Error' (len=5); verified with Python 3.14.3"]
    - [name_len,  concurrent.futures._base.Error.__name__.__len__,              [],                           5,    "Error.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [qn_eq,     concurrent.futures._base.Error.__qualname__.__eq__,          ["Error"],                    true, "Error.__qualname__ == 'Error' (len=5, same as __name__); verified with Python 3.14.3"]
    - [mod_eq,    concurrent.futures._base.Error.__module__.__eq__,            ["concurrent.futures._base"], true, "Error.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [mod_len,   concurrent.futures._base.Error.__module__.__len__,            [],                           24,   "Error.__module__.__len__() == 24; verified with Python 3.14.3"]
    - ["base_name", "concurrent.futures._base.Error.__bases__[0].__name__.__eq__", ["Exception"],              true, "Error.__bases__[0].__name__ == 'Exception'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# BrokenThreadPool and BrokenProcessPool identity — extra136
#
# concurrent.futures.thread.BrokenThreadPool.__name__   == 'BrokenThreadPool'  (len=16)
# concurrent.futures.thread.BrokenThreadPool.__module__ == 'concurrent.futures.thread' (len=25)
# concurrent.futures.process.BrokenProcessPool.__name__ == 'BrokenProcessPool' (len=17)
# concurrent.futures.process.BrokenProcessPool.__module__ == 'concurrent.futures.process' (len=26)
# ---------------------------------------------------------------------------

table concurrent_futures_extra136.broken_pool_identity:
  description: "BrokenThreadPool and BrokenProcessPool class identity checks — BrokenThreadPool.__name__.__eq__('BrokenThreadPool')==True (len=16: 'Broken'=6+'Thread'=6+'Pool'=4=16); BrokenThreadPool.__module__.__eq__('concurrent.futures.thread')==True (len=25); BrokenThreadPool.__bases__[0].__name__.__eq__('BrokenExecutor')==True (subclass of BrokenExecutor). BrokenProcessPool.__name__.__eq__('BrokenProcessPool')==True (len=17: 'Broken'=6+'Process'=7+'Pool'=4=17); BrokenProcessPool.__module__.__eq__('concurrent.futures.process')==True (len=26); BrokenProcessPool.__bases__[0].__name__.__eq__('BrokenExecutor')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfbpool136

  columns: [id, function, args, expected, description]
  rows:
    - [btp_name_eq,    concurrent.futures.thread.BrokenThreadPool.__name__.__eq__,              ["BrokenThreadPool"],         true, "BrokenThreadPool.__name__ == 'BrokenThreadPool' (len=16); verified with Python 3.14.3"]
    - [btp_name_len,   concurrent.futures.thread.BrokenThreadPool.__name__.__len__,              [],                           16,   "BrokenThreadPool.__name__.__len__() == 16; verified with Python 3.14.3"]
    - [btp_mod_eq,     concurrent.futures.thread.BrokenThreadPool.__module__.__eq__,            ["concurrent.futures.thread"], true, "BrokenThreadPool.__module__ == 'concurrent.futures.thread' (len=25); verified with Python 3.14.3"]
    - ["btp_base_name", "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__.__eq__", ["BrokenExecutor"],           true, "BrokenThreadPool.__bases__[0].__name__ == 'BrokenExecutor'; verified with Python 3.14.3"]
    - [bpp_name_eq,    concurrent.futures.process.BrokenProcessPool.__name__.__eq__,             ["BrokenProcessPool"],          true, "BrokenProcessPool.__name__ == 'BrokenProcessPool' (len=17); verified with Python 3.14.3"]
    - [bpp_name_len,   concurrent.futures.process.BrokenProcessPool.__name__.__len__,             [],                            17,   "BrokenProcessPool.__name__.__len__() == 17; verified with Python 3.14.3"]
    - [bpp_mod_eq,     concurrent.futures.process.BrokenProcessPool.__module__.__eq__,           ["concurrent.futures.process"], true, "BrokenProcessPool.__module__ == 'concurrent.futures.process' (len=26); verified with Python 3.14.3"]
    - ["bpp_base_name", "concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__.__eq__", ["BrokenExecutor"],           true, "BrokenProcessPool.__bases__[0].__name__ == 'BrokenExecutor'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra136
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra136.invalid_state_error_name_len_17:
  description: "concurrent.futures.InvalidStateError.__name__.__len__() == 17 — InvalidStateError.__name__ is 'InvalidStateError' (17 chars: 'Invalid'=7+'State'=5+'Error'=5=17); InvalidStateError.__module__=='concurrent.futures._base' (len=24); InvalidStateError.__bases__[0].__name__=='Error' (len=5); name len (17) is 3 more than BrokenExecutor name len (14); NEW in extra136: first standalone InvalidStateError name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.InvalidStateError.__name__.__len__
  args: []
  expected: 17

invariant concurrent_futures_extra136.broken_executor_name_len_14:
  description: "concurrent.futures.BrokenExecutor.__name__.__len__() == 14 — BrokenExecutor.__name__ is 'BrokenExecutor' (14 chars: 'Broken'=6+'Executor'=8=14); BrokenExecutor.__module__=='concurrent.futures._base' (len=24); BrokenExecutor.__bases__[0].__name__=='RuntimeError'; name len (14) same as CancelledError name len (14); NEW in extra136: first standalone BrokenExecutor name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.BrokenExecutor.__name__.__len__
  args: []
  expected: 14

invariant concurrent_futures_extra136.error_name_len_5:
  description: "concurrent.futures._base.Error.__name__.__len__() == 5 — Error.__name__ is 'Error' (5 chars); Error.__module__=='concurrent.futures._base' (len=24); Error.__bases__[0].__name__=='Exception' (root of the futures exception hierarchy); Error has the shortest name of all exception classes in this spec (compare: 'Error'=5, 'BrokenExecutor'=14, 'CancelledError'=14, 'InvalidStateError'=17); NEW in extra136: first standalone Error name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.Error.__name__.__len__
  args: []
  expected: 5

invariant concurrent_futures_extra136.broken_thread_pool_name_len_16:
  description: "concurrent.futures.thread.BrokenThreadPool.__name__.__len__() == 16 — BrokenThreadPool.__name__ is 'BrokenThreadPool' (16 chars: 'Broken'=6+'Thread'=6+'Pool'=4=16); BrokenThreadPool.__module__=='concurrent.futures.thread' (len=25); BrokenThreadPool.__bases__[0].__name__=='BrokenExecutor'; name len (16) is one less than BrokenProcessPool name len (17); NEW in extra136: first standalone BrokenThreadPool name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.thread.BrokenThreadPool.__name__.__len__
  args: []
  expected: 16

invariant concurrent_futures_extra136.broken_process_pool_name_len_17:
  description: "concurrent.futures.process.BrokenProcessPool.__name__.__len__() == 17 — BrokenProcessPool.__name__ is 'BrokenProcessPool' (17 chars: 'Broken'=6+'Process'=7+'Pool'=4=17); BrokenProcessPool.__module__=='concurrent.futures.process' (len=26); BrokenProcessPool.__bases__[0].__name__=='BrokenExecutor'; name len (17) is one more than BrokenThreadPool name len (16); NEW in extra136: first standalone BrokenProcessPool name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.process.BrokenProcessPool.__name__.__len__
  args: []
  expected: 17
