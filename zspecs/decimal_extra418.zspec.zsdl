spec: decimal_extra418
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "decimal.Subnormal, decimal.Clamped, decimal.FloatOperation are all in the 'decimal' module"
    - "decimal.Subnormal and decimal.Clamped each have DecimalException as their sole base class"
    - "decimal.FloatOperation has two bases: DecimalException and TypeError"
    - "decimal.ConversionSyntax has InvalidOperation as its sole base class"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal exception class __name__ identity
# ---------------------------------------------------------------------------

table decimal_extra418.exception_class_names:
  description: "decimal exception class __name__ identity — Subnormal, Clamped, FloatOperation, ConversionSyntax; each reports __name__ matching its class name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: decexcname418

  columns: [id, function, args, expected]
  rows:
    - [subnormal_name,        decimal.Subnormal.__name__.__eq__,        ["Subnormal"],        true]
    - [clamped_name,          decimal.Clamped.__name__.__eq__,          ["Clamped"],          true]
    - [floatop_name,          decimal.FloatOperation.__name__.__eq__,   ["FloatOperation"],   true]
    - [convsyntax_name,       decimal.ConversionSyntax.__name__.__eq__, ["ConversionSyntax"], true]

# ---------------------------------------------------------------------------
# decimal exception class __module__ identity
# ---------------------------------------------------------------------------

table decimal_extra418.exception_class_modules:
  description: "decimal exception class __module__ identity — Subnormal, Clamped, FloatOperation, ConversionSyntax all live in the 'decimal' module; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: decexcmod418

  columns: [id, function, args, expected]
  rows:
    - [subnormal_module,  decimal.Subnormal.__module__.__eq__,        ["decimal"], true]
    - [clamped_module,    decimal.Clamped.__module__.__eq__,          ["decimal"], true]
    - [floatop_module,    decimal.FloatOperation.__module__.__eq__,   ["decimal"], true]
    - [convsyntax_module, decimal.ConversionSyntax.__module__.__eq__, ["decimal"], true]

# ---------------------------------------------------------------------------
# decimal exception class primary base class __name__
# ---------------------------------------------------------------------------

table decimal_extra418.exception_primary_base:
  description: "decimal exception class primary base class — Subnormal and Clamped derive from DecimalException; FloatOperation derives from DecimalException (first base); ConversionSyntax derives from InvalidOperation; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: decexcbase418

  columns: [id, function, args, expected]
  rows:
    - [subnormal_base,  "decimal.Subnormal.__bases__[0].__name__.__eq__",        ["DecimalException"], true]
    - [clamped_base,    "decimal.Clamped.__bases__[0].__name__.__eq__",          ["DecimalException"], true]
    - [floatop_base,    "decimal.FloatOperation.__bases__[0].__name__.__eq__",   ["DecimalException"], true]
    - [convsyntax_base, "decimal.ConversionSyntax.__bases__[0].__name__.__eq__", ["InvalidOperation"], true]
