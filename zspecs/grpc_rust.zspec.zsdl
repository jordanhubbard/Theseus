spec: grpc_rust
version: ">=3.9"
backend: rust_module(grpc_rust)

docs: https://grpc.github.io/grpc/python/

provenance:
  derived_from:
    - "https://grpc.github.io/grpc/python/ — gRPC Python documentation"
  not_derived_from:
    - "grpc source: src/python/grpcio/grpc/__init__.py"
  notes:
    - "gRPC is a high-performance RPC framework."
    - "grpc.StatusCode is an enum with common status codes."
    - "grpc.StatusCode.OK.name == 'OK'."
    - "grpc.StatusCode.NOT_FOUND.name == 'NOT_FOUND'."
    - "grpc.Channel is available as a class."
    - "grpc.__version__ is a non-empty string."
    - "Expose grpc_status_ok_name() -> str: grpc.StatusCode.OK.name."
    - "Expose grpc_status_not_found_name() -> str: grpc.StatusCode.NOT_FOUND.name."
    - "Expose grpc_version_nonempty() -> bool: len(grpc.__version__) > 0."
    - "All test vectors verified against grpcio 1.71.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# grpc_status_ok_name — StatusCode.OK name
invariant grpc_rust.status.ok_name:
  description: "grpc.StatusCode.OK.name == 'OK'"
  category: status
  kind: python_call_eq
  function: grpc_status_ok_name
  args: []
  expected: "OK"

# grpc_status_not_found_name — StatusCode.NOT_FOUND name
invariant grpc_rust.status.not_found_name:
  description: "grpc.StatusCode.NOT_FOUND.name == 'NOT_FOUND'"
  category: status
  kind: python_call_eq
  function: grpc_status_not_found_name
  args: []
  expected: "NOT_FOUND"

# grpc_version_nonempty — version non-empty
invariant grpc_rust.version.nonempty:
  description: "grpc.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: grpc_version_nonempty
  args: []
  expected: true

