spec: lodash_tointeger
version: ">=4.0.0"
backend: node(lodash.tointeger)

docs: https://lodash.com/docs/#toInteger

provenance:
  derived_from:
    - "lodash.tointeger README — https://www.npmjs.com/package/lodash.tointeger"
    - "Test vectors verified with lodash.tointeger@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.tointeger exports the _.toInteger function directly as module.exports."
    - "toInteger converts value to an integer by truncating the decimal part."
    - "Coerces strings to numbers first."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an integer."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_tointeger.tointeger:
  kind: node_module_call_eq
  function: ~
  category: tointeger
  id_prefix: ltoi

  columns: [id, args, expected]
  rows:
    - [float,        [3.7],    3]
    - [str_num,      ["5"],    5]
    - [str_float,    ["3.9"],  3]
    - [negative,     [-2.5],  -2]
    - [already_int,  [7],      7]
