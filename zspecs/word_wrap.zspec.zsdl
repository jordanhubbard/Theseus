spec: word_wrap
version: ">=1.0.0"
backend: node(word-wrap)

docs: https://github.com/jonschlinkert/word-wrap#readme

provenance:
  derived_from:
    - "word-wrap README — https://github.com/jonschlinkert/word-wrap#readme"
    - "Test vectors verified with word-wrap@1.2.5 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "word-wrap source: index.js"
  notes:
    - "word-wrap exports the wrap function as the module default (CJS)."
    - "wrap(str, opts) wraps text at word boundaries."
    - "opts.width: max chars per line (default 80); opts.indent: leading indent (default '  ')."
    - "Output lines are joined with newline characters."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a wrapped string. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table word_wrap.wrap:
  kind: node_module_call_eq
  function: ~
  category: wrap
  id_prefix: ww

  columns: [id, args, expected]
  rows:
    - [basic,    ["hello world", {"width": 5, "indent": "", "trim": true}],  "hello\nworld"]
    - [no_wrap,  ["hi", {"width": 80, "indent": ""}],                        "hi"]
