spec: operator_extra7
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl through operator_extra6.zspec.zsdl."
    - "operator_extra6 covers: __module__ for iadd/isub/imul/itruediv/iand/ior/ixor/ifloordiv/imod/ilshift/irshift; __module__ for truth/is_/is_not/concat/length_hint/index/pos; __module__ for attrgetter/itemgetter/methodcaller; lshift(3,2)==12; rshift(32,3)==4; is_not(None,1)==True; is_not(1,1)==False; matmul __name__/__qualname__/__module__."
    - "NOT yet covered: imatmul/__module__, ipow/__module__, imatmul/__qualname__."
    - "NOT yet covered: call results for arithmetic operators (add/sub/mul/floordiv/mod/pow/neg/abs)."
    - "NOT yet covered: call results for bitwise operators (and_/or_/xor/not_)."
    - "NOT yet covered: call results for comparison operators (eq/ne/lt/le/gt/ge)."
    - "NOT yet covered: call results for item-access operators (getitem/contains/length_hint/index/concat)."
    - "NOT yet covered: attrgetter/itemgetter/methodcaller __bases__[0].__name__ == 'object'."
    - "operator.add(10, 3) == 13."
    - "operator.sub(10, 3) == 7."
    - "operator.mul(4, 5) == 20."
    - "operator.floordiv(10, 3) == 3."
    - "operator.mod(10, 3) == 1."
    - "operator.pow(2, 8) == 256."
    - "operator.neg(-5) == 5."
    - "operator.abs(-7) == 7."
    - "operator.and_(0b1100, 0b1010) == 8."
    - "operator.or_(0b1100, 0b1010) == 14."
    - "operator.xor(0b1100, 0b1010) == 6."
    - "operator.not_(0) == True."
    - "operator.truth([1]) == True; operator.truth([]) == False."
    - "operator.index(5) == 5."
    - "operator.getitem([10, 20, 30], 1) == 20."
    - "operator.contains([1, 2, 3], 2) == True."
    - "operator.length_hint([1, 2, 3]) == 3."
    - "operator.concat('foo', 'bar') == 'foobar'."
    - "operator.eq(5, 5) == True; operator.ne(5, 6) == True; operator.lt(3, 5) == True."
    - "operator.imatmul.__module__ == '_operator'; operator.ipow.__module__ == '_operator'."
    - "operator.attrgetter.__bases__[0].__name__ == 'object'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Arithmetic operator call results
#
# No prior spec tests actual return values of add/sub/mul/floordiv/mod/pow/
# neg/abs. operator.zspec.zsdl only confirms __name__; extras confirm
# __module__ and __qualname__. These are the first call-result vectors for
# the core arithmetic group.
# ---------------------------------------------------------------------------

table operator_extra7.arithmetic_results:
  kind: python_call_eq
  category: arithmetic
  id_prefix: arith

  columns: [id, function, args, expected]
  rows:
    - [add,      add,      [10, 3],  13]
    - [sub,      sub,      [10, 3],  7]
    - [mul,      mul,      [4, 5],   20]
    - [floordiv, floordiv, [10, 3],  3]
    - [mod,      mod,      [10, 3],  1]
    - [pow,      pow,      [2, 8],   256]
    - [neg,      neg,      [-5],     5]
    - [abs,      abs,      [-7],     7]

# ---------------------------------------------------------------------------
# Bitwise operator call results
#
# No prior spec tests call results for and_/or_/xor/not_. operator_extra5
# checks __qualname__; operator_extra3 checks __module__. These are the
# first behavioral (value) vectors for bitwise operators.
# ---------------------------------------------------------------------------

table operator_extra7.bitwise_results:
  kind: python_call_eq
  category: bitwise
  id_prefix: bitwise

  columns: [id, function, args, expected]
  rows:
    - [and_,  and_,  [12, 10], 8]
    - [or_,   or_,   [12, 10], 14]
    - [xor,   xor,   [12, 10], 6]
    - [not_,  not_,  [0],      true]

# ---------------------------------------------------------------------------
# Comparison operator call results
#
# No prior spec tests return values for eq/ne/lt/le/gt/ge. Prior extras
# only cover __name__, __qualname__, __module__ for these functions.
# ---------------------------------------------------------------------------

table operator_extra7.comparison_results:
  kind: python_call_eq
  category: comparison
  id_prefix: cmp

  columns: [id, function, args, expected]
  rows:
    - [eq_same,  eq, [5, 5], true]
    - [ne_diff,  ne, [5, 6], true]
    - [lt_less,  lt, [3, 5], true]
    - [gt_less,  gt, [3, 5], false]
    - [ge_eq,    ge, [5, 5], true]
    - [le_eq,    le, [5, 5], true]

# ---------------------------------------------------------------------------
# Item-access and sequence operator call results
#
# operator_extra5 checks __qualname__ for getitem/contains/concat/length_hint/
# index. No prior spec checks their actual return values.
# ---------------------------------------------------------------------------

invariant operator_extra7.getitem.list_mid:
  description: "operator.getitem([10, 20, 30], 1) == 20 — get element at index 1"
  category: item_access
  kind: python_call_eq
  function: getitem
  args: [[10, 20, 30], 1]
  expected: 20

invariant operator_extra7.contains.present:
  description: "operator.contains([1, 2, 3], 2) == True — 2 is in the list"
  category: item_access
  kind: python_call_eq
  function: contains
  args: [[1, 2, 3], 2]
  expected: true

invariant operator_extra7.contains.absent:
  description: "operator.contains([1, 2, 3], 9) == False — 9 is not in the list"
  category: item_access
  kind: python_call_eq
  function: contains
  args: [[1, 2, 3], 9]
  expected: false

invariant operator_extra7.length_hint.list:
  description: "operator.length_hint([1, 2, 3]) == 3 — length hint of a 3-element list"
  category: item_access
  kind: python_call_eq
  function: length_hint
  args: [[1, 2, 3]]
  expected: 3

invariant operator_extra7.index.int:
  description: "operator.index(5) == 5 — index of an integer returns the integer"
  category: item_access
  kind: python_call_eq
  function: index
  args: [5]
  expected: 5

invariant operator_extra7.concat.strings:
  description: "operator.concat('foo', 'bar') == 'foobar' — string concatenation"
  category: item_access
  kind: python_call_eq
  function: concat
  args: ["foo", "bar"]
  expected: "foobar"

# ---------------------------------------------------------------------------
# imatmul and ipow — __module__
#
# operator_extra6 covers __module__ for iadd/isub/imul/itruediv/iand/ior/
# ixor/ifloordiv/imod/ilshift/irshift. imatmul and ipow were omitted.
# Both are C builtins from _operator; their __module__ is '_operator'.
# ---------------------------------------------------------------------------

invariant operator_extra7.imatmul.module:
  description: "operator.imatmul.__module__ == '_operator' — imatmul is a C builtin"
  category: module_checks
  kind: python_call_eq
  function: imatmul.__module__.__eq__
  args: ["_operator"]
  expected: true

invariant operator_extra7.ipow.module:
  description: "operator.ipow.__module__ == '_operator' — ipow is a C builtin"
  category: module_checks
  kind: python_call_eq
  function: ipow.__module__.__eq__
  args: ["_operator"]
  expected: true

# ---------------------------------------------------------------------------
# attrgetter, itemgetter, methodcaller — base class
#
# operator_extra6 covers __module__ ('operator') for these factory classes.
# operator_extra5 covers __qualname__. No prior spec checks __bases__[0].__name__.
# All three are C-extension types whose sole base is object.
# ---------------------------------------------------------------------------

table operator_extra7.factory_class_bases:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base

  columns: [id, function, args, method, expected]
  rows:
    - [attrgetter,   attrgetter.__bases__.__getitem__,   [0], __name__, "object"]
    - [itemgetter,   itemgetter.__bases__.__getitem__,   [0], __name__, "object"]
    - [methodcaller, methodcaller.__bases__.__getitem__, [0], __name__, "object"]
