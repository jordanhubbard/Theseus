spec: uppercase_keys
version: ">=1.1.0"
backend: node(uppercase-keys)

docs: https://github.com/sindresorhus/uppercase-keys#readme

provenance:
  derived_from:
    - "uppercase-keys README — https://github.com/sindresorhus/uppercase-keys#readme"
    - "Test vectors verified with uppercase-keys via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "uppercase-keys source"
  notes:
    - "Returns a new object whose top-level keys are uppercased."
    - "Install: npm install uppercase-keys"
    - "v1 CJS; module export IS the function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; returns a new object."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant uppercase_keys.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant uppercase_keys.module_arity:
  description: "Module function takes 1 arg"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 1

invariant uppercase_keys.uppercases_lowercase_keys:
  description: "{a:1, b:2} → {A:1, B:2} — A key present"
  category: transform
  kind: node_chain_eq
  entry: module
  entry_args: [{"a": 1, "b": 2}]
  chain:
    - {get: A}
  expected: 1

invariant uppercase_keys.uppercases_lowercase_keys_b:
  description: "{a:1, b:2} → {A:1, B:2} — B key present"
  category: transform
  kind: node_chain_eq
  entry: module
  entry_args: [{"a": 1, "b": 2}]
  chain:
    - {get: B}
  expected: 2

invariant uppercase_keys.mixed_case_keys:
  description: "Mixed-case 'Hello' → 'HELLO'"
  category: transform
  kind: node_chain_eq
  entry: module
  entry_args: [{"Hello": 1, "world": 2}]
  chain:
    - {get: HELLO}
  expected: 1

invariant uppercase_keys.preserves_already_upper:
  description: "Already-uppercase keys are unchanged"
  category: transform
  kind: node_chain_eq
  entry: module
  entry_args: [{"FOO": "bar"}]
  chain:
    - {get: FOO}
  expected: "bar"

invariant uppercase_keys.empty_input:
  description: "Empty object passes through to empty object"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [{}]
  chain: []
  expected: {}

invariant uppercase_keys.values_preserved:
  description: "Values are unchanged when keys are uppercased"
  category: transform
  kind: node_chain_eq
  entry: module
  entry_args: [{"name": "Alice"}]
  chain:
    - {get: NAME}
  expected: "Alice"
