spec: hashlib_extra22
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "FIPS 180-2 — SHA-512 Test Vector"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), August 2015"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha512module.c"
    - "hashlib_extra21.zspec.zsdl — covers md5/sha1/sha256 empty hexdigest (extra21 namespace); sha256 hexdigest class name and length for b'hello'."
    - "hashlib_extra20.zspec.zsdl — covers md5/sha1/sha256/sha512/new __name__; algorithms_available/guaranteed class name; algorithms_guaranteed membership; pbkdf2_hmac __name__."
    - "hashlib_extra19.zspec.zsdl — covers algorithms_available/guaranteed is_set; algorithms_guaranteed membership table; algorithms_guaranteed min_count; hexdigest_len sha256/sha512/md5/sha1; sha256 digest_size."
    - "hashlib_extra17.zspec.zsdl — covers sha256/md5/sha1 empty-input hexdigest; sha256 block_size/name; algorithms_guaranteed contains md5/sha256."
  notes:
    - "This spec extends hashlib through hashlib_extra21; it does NOT duplicate invariants present in those files."
    - "Focus: sha512 empty-input hexdigest; sha256(b'abc') hexdigest value; md5 block_size; sha256/sha1 digest_size; md5 digest_size; sha256 digest() return type."
    - "hashlib.sha512(b'').hexdigest() == 'cf83e135...': FIPS 180-2 empty-string SHA-512 test vector. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha256(b'abc').hexdigest() == 'ba7816bf...': FIPS 180-4 SHA-256 test vector for 'abc'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.md5(b'').block_size == 64: MD5 operates on 512-bit (64-byte) blocks. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.md5(b'').digest_size == 16: MD5 produces a 128-bit (16-byte) digest. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha1(b'').digest_size == 20: SHA-1 produces a 160-bit (20-byte) digest. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha256(b'abc').digest().__class__.__name__ == 'bytes': digest() always returns bytes. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha256(b'abc').digest().__len__() == 32: SHA-256 produces a 256-bit (32-byte) digest. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sha512 empty-input hexdigest value (extra22 namespace)
#
# FIPS 180-2 defines the SHA-512 hash of the empty string.
# Verified: cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce
#           47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e
# (128 hex characters = 512 bits)
# ---------------------------------------------------------------------------

invariant hashlib_extra22.sha512.empty.hexdigest:
  description: "hashlib.sha512(b'').hexdigest() == 'cf83e135...' — FIPS 180-2 SHA-512 empty-string test vector"
  category: digests
  kind: python_call_eq
  function: sha512
  args: [!ascii ""]
  method: hexdigest
  method_args: []
  expected: "cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e"

# ---------------------------------------------------------------------------
# sha256(b'abc') hexdigest value (extra22 namespace)
#
# FIPS 180-4 defines the SHA-256 hash of the ASCII string 'abc'.
# Verified: ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad
# ---------------------------------------------------------------------------

invariant hashlib_extra22.sha256.abc.hexdigest:
  description: "hashlib.sha256(b'abc').hexdigest() == 'ba7816bf...' — FIPS 180-4 SHA-256 test vector for 'abc'"
  category: digests
  kind: python_call_eq
  function: sha256
  args: [!ascii "abc"]
  method: hexdigest
  method_args: []
  expected: "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"

# ---------------------------------------------------------------------------
# md5 block_size and digest_size (extra22 namespace)
#
# MD5 uses 512-bit (64-byte) blocks and produces a 128-bit (16-byte) digest.
# hashlib_extra19 covers sha256 digest_size from extra19.
# No prior spec covers md5 block_size or md5 digest_size as standalone
# invariants from the extra22 namespace.
# ---------------------------------------------------------------------------

invariant hashlib_extra22.md5.block_size:
  description: "hashlib.md5(b'').block_size == 64 — MD5 operates on 512-bit (64-byte) blocks"
  category: block_sizes
  kind: python_call_eq
  function: md5
  args: [!ascii ""]
  method: block_size
  method_args: []
  expected: 64

invariant hashlib_extra22.md5.digest_size:
  description: "hashlib.md5(b'').digest_size == 16 — MD5 produces a 128-bit (16-byte) digest"
  category: digest_sizes
  kind: python_call_eq
  function: md5
  args: [!ascii ""]
  method: digest_size
  method_args: []
  expected: 16

# ---------------------------------------------------------------------------
# sha1 digest_size (extra22 namespace)
#
# SHA-1 produces a 160-bit (20-byte) digest.
# No prior spec covers sha1 digest_size as a standalone invariant from extra22.
# ---------------------------------------------------------------------------

invariant hashlib_extra22.sha1.digest_size:
  description: "hashlib.sha1(b'').digest_size == 20 — SHA-1 produces a 160-bit (20-byte) digest"
  category: digest_sizes
  kind: python_call_eq
  function: sha1
  args: [!ascii ""]
  method: digest_size
  method_args: []
  expected: 20

# ---------------------------------------------------------------------------
# sha256(b'abc').digest() — return type and length (extra22 namespace)
#
# digest() always returns bytes. SHA-256 produces 32 bytes.
# hashlib_extra19 covers sha256 digest_size from extra19.
# No prior spec uses method_chain on the digest() output from extra22.
# ---------------------------------------------------------------------------

invariant hashlib_extra22.sha256.abc.digest.class_name:
  description: "hashlib.sha256(b'abc').digest().__class__.__name__ == 'bytes' — digest returns bytes"
  category: types
  kind: python_call_eq
  function: sha256
  args: [!ascii "abc"]
  method: digest
  method_args: []
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["bytes"]
  expected: true

invariant hashlib_extra22.sha256.abc.digest.len:
  description: "hashlib.sha256(b'abc').digest().__len__() == 32 — SHA-256 produces 32 bytes"
  category: digest_sizes
  kind: python_call_eq
  function: sha256
  args: [!ascii "abc"]
  method: digest
  method_args: []
  method_chain: __len__
  method_chain_args: []
  expected: 32
