spec: flake8_rust
version: ">=3.9"
backend: rust_module(flake8_rust)

docs: https://flake8.pycqa.org/en/latest/

provenance:
  derived_from:
    - "https://flake8.pycqa.org/en/latest/ — Flake8 documentation"
  not_derived_from:
    - "flake8 source: src/flake8/__init__.py"
  notes:
    - "Flake8 is a Python linting tool."
    - "flake8.__version__ is a non-empty string."
    - "int(flake8.__version__.split('.')[0]) >= 7."
    - "flake8.main is available."
    - "Expose flake8_version_nonempty() -> bool: len(flake8.__version__) > 0."
    - "Expose flake8_version_major() -> int: int(flake8.__version__.split('.')[0])."
    - "Expose flake8_has_main() -> bool: hasattr(flake8, 'main')."
    - "All test vectors verified against flake8 7.2.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# flake8_version_nonempty — version non-empty
invariant flake8_rust.version.nonempty:
  description: "flake8.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: flake8_version_nonempty
  args: []
  expected: true

# flake8_version_major — major version >= 7
invariant flake8_rust.version.major_ge7:
  description: "flake8 major version >= 7"
  category: version
  kind: python_call_eq
  function: flake8_version_major
  args: []
  expected: 7

# flake8_has_main — main module present
invariant flake8_rust.module.has_main:
  description: "flake8.main is available"
  category: module
  kind: python_call_eq
  function: flake8_has_main
  args: []
  expected: true

