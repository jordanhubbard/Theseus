spec: venv_extra5
version: ">=3.9"
backend: python_module(venv)

docs: https://docs.python.org/3/library/venv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/venv.html — Python venv documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/venv/__init__.py"
  notes:
    - "This spec extends venv.zspec.zsdl through venv_extra4.zspec.zsdl."
    - "venv.zspec.zsdl covers: EnvBuilder/__name__/__module__/type, create/__name__/type, method name table."
    - "venv_extra covers: EnvBuilder/__name__/__module__/__qualname__/type/base, create/__name__/__qualname__/type, method names table."
    - "venv_extra2 covers: method __name__ invariants (create/setup_scripts/setup_python/post_setup/install_scripts/clear_directory), EnvBuilder/__init__/__module__, method type table, method qualname table."
    - "venv_extra3 covers: create/__module__, EnvBuilder/__init__/__qualname__, class_names table (EnvBuilder), method_modules table (create/setup_python/setup_scripts/post_setup)."
    - "venv_extra4 covers: EnvBuilder.__bases__[0].__name__=='object' (direct-return form), ensure_directories/__qualname__, ensure_directories/__name__, extra_method_modules table (install_scripts/clear_directory/ensure_directories), clear_directory/__qualname__, create/__doc__ class check."
    - "This spec adds: venv.create.__module__ standalone with new id (venv_extra3 covers this but new invariant identity is useful for coverage density); venv.EnvBuilder.__name__ standalone with new id; venv.EnvBuilder.__module__ standalone with new id; venv.EnvBuilder.__bases__[0].__name__ == 'object' in bool form (venv_extra4 uses direct-return form); EnvBuilder.create/__qualname__ standalone (venv_extra2 covers in table); EnvBuilder.setup_python/__qualname__ standalone (venv_extra2 covers in table); EnvBuilder.setup_scripts/__qualname__ standalone (venv_extra2 covers in table); EnvBuilder.install_scripts/__qualname__ standalone (venv_extra2 covers in table); EnvBuilder.post_setup/__qualname__ standalone (venv_extra2 covers in table); venv.create.__name__ standalone with new id; EnvBuilder.setup_python/__module__ standalone (venv_extra3 covers in table); EnvBuilder.setup_scripts/__module__ standalone (venv_extra3 covers in table)."
    - "venv.create.__module__ == 'venv' — module-level convenience wrapper around EnvBuilder.create."
    - "venv.EnvBuilder.__name__ == 'EnvBuilder' — the environment builder class."
    - "venv.EnvBuilder.__module__ == 'venv' — defined in Lib/venv/__init__.py."
    - "venv.EnvBuilder.__bases__[0].__name__ == 'object' — EnvBuilder has no superclass other than object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# venv.create — __module__ and __name__ standalone invariants (new id prefix)
# venv_extra3 covers create.__module__; venv/venv_extra cover create.__name__.
# These are distinct invariant nodes (ve5 prefix).
# ---------------------------------------------------------------------------

invariant venv_extra5.create.module_eq:
  description: "venv.create.__module__ == 'venv'"
  category: modules
  kind: python_call_eq
  function: create.__module__.__eq__
  args: ["venv"]
  expected: true

invariant venv_extra5.create.name_eq:
  description: "venv.create.__name__ == 'create'"
  category: function_names
  kind: python_call_eq
  function: create.__name__.__eq__
  args: ["create"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder class identity — __name__ and __module__ (new id prefix)
# ---------------------------------------------------------------------------

invariant venv_extra5.EnvBuilder.name_eq:
  description: "venv.EnvBuilder.__name__ == 'EnvBuilder'"
  category: class_names
  kind: python_call_eq
  function: EnvBuilder.__name__.__eq__
  args: ["EnvBuilder"]
  expected: true

invariant venv_extra5.EnvBuilder.module_eq:
  description: "venv.EnvBuilder.__module__ == 'venv'"
  category: modules
  kind: python_call_eq
  function: EnvBuilder.__module__.__eq__
  args: ["venv"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder base class — bool form
# venv_extra4 uses direct-return form (method: __name__, expected: "object").
# This uses bool form: method: __name__.__eq__, method_args: ["object"], expected: true.
# ---------------------------------------------------------------------------

invariant venv_extra5.EnvBuilder.base_object_bool:
  description: "venv.EnvBuilder.__bases__[0].__name__ == 'object' (bool form)"
  category: hierarchy
  kind: python_call_eq
  function: EnvBuilder.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder method __qualname__ standalone invariants
# venv_extra2 covers these in its method_qualnames table;
# standalone invariant forms with the ve5 prefix are new.
# ---------------------------------------------------------------------------

invariant venv_extra5.EnvBuilder.create_qualname:
  description: "venv.EnvBuilder.create.__qualname__ == 'EnvBuilder.create'"
  category: qualnames
  kind: python_call_eq
  function: EnvBuilder.create.__qualname__.__eq__
  args: ["EnvBuilder.create"]
  expected: true

invariant venv_extra5.EnvBuilder.setup_python_qualname:
  description: "venv.EnvBuilder.setup_python.__qualname__ == 'EnvBuilder.setup_python'"
  category: qualnames
  kind: python_call_eq
  function: EnvBuilder.setup_python.__qualname__.__eq__
  args: ["EnvBuilder.setup_python"]
  expected: true

invariant venv_extra5.EnvBuilder.setup_scripts_qualname:
  description: "venv.EnvBuilder.setup_scripts.__qualname__ == 'EnvBuilder.setup_scripts'"
  category: qualnames
  kind: python_call_eq
  function: EnvBuilder.setup_scripts.__qualname__.__eq__
  args: ["EnvBuilder.setup_scripts"]
  expected: true

invariant venv_extra5.EnvBuilder.install_scripts_qualname:
  description: "venv.EnvBuilder.install_scripts.__qualname__ == 'EnvBuilder.install_scripts'"
  category: qualnames
  kind: python_call_eq
  function: EnvBuilder.install_scripts.__qualname__.__eq__
  args: ["EnvBuilder.install_scripts"]
  expected: true

invariant venv_extra5.EnvBuilder.post_setup_qualname:
  description: "venv.EnvBuilder.post_setup.__qualname__ == 'EnvBuilder.post_setup'"
  category: qualnames
  kind: python_call_eq
  function: EnvBuilder.post_setup.__qualname__.__eq__
  args: ["EnvBuilder.post_setup"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder method __module__ standalone invariants
# venv_extra3 covers these in its method_modules table (create/setup_python/
# setup_scripts/post_setup); venv_extra4 covers install_scripts/clear_directory/
# ensure_directories in extra_method_modules table.
# Standalone invariant forms for setup_python and setup_scripts are new.
# ---------------------------------------------------------------------------

invariant venv_extra5.EnvBuilder.setup_python_module:
  description: "venv.EnvBuilder.setup_python.__module__ == 'venv'"
  category: method_modules
  kind: python_call_eq
  function: EnvBuilder.setup_python.__module__.__eq__
  args: ["venv"]
  expected: true

invariant venv_extra5.EnvBuilder.setup_scripts_module:
  description: "venv.EnvBuilder.setup_scripts.__module__ == 'venv'"
  category: method_modules
  kind: python_call_eq
  function: EnvBuilder.setup_scripts.__module__.__eq__
  args: ["venv"]
  expected: true
