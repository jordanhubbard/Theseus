spec: hl3481
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 679 (hl3481): __enter__, __exit__, __call__ dict-presence checks for hashlib/uuid/struct/socket types."
    - "All values False."
    - "type(hashlib.md5()), type(hashlib.sha1()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "None of the hashlib types define __enter__, __exit__, or __call__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3481.enter:
  description: "hashlib types __enter__ dict-presence checks; wave 679"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: hl3481
  columns: [id, function, args, expected]
  rows:
    - ["hl3481001", operator.contains, [type(hashlib.md5()).__dict__,        "__enter__"], false]
    - ["hl3481002", operator.contains, [type(hashlib.sha1()).__dict__,       "__enter__"], false]
    - ["hl3481003", operator.contains, [type(hashlib.sha256()).__dict__,     "__enter__"], false]
    - ["hl3481004", operator.contains, [type(hashlib.sha512()).__dict__,     "__enter__"], false]
    - ["hl3481005", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__enter__"], false]

