spec: asyncio_extra452
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio-exceptions.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-exceptions.html — asyncio exception classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "asyncio.CancelledError is a subclass of BaseException since Python 3.8"
    - "asyncio.TimeoutError is an alias for the built-in TimeoutError since Python 3.11"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra452.exception_names:
  description: "asyncio exception class __name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: aioexcn

  columns: [id, function, args, expected]
  rows:
    - [aioexcn001, asyncio.CancelledError.__name__.__eq__, ["CancelledError"], true]
    - [aioexcn002, asyncio.TimeoutError.__name__.__eq__, ["TimeoutError"], true]
    - [aioexcn003, asyncio.InvalidStateError.__name__.__eq__, ["InvalidStateError"], true]
    - [aioexcn004, asyncio.SendfileNotAvailableError.__name__.__eq__, ["SendfileNotAvailableError"], true]
    - [aioexcn005, asyncio.IncompleteReadError.__name__.__eq__, ["IncompleteReadError"], true]
    - [aioexcn006, asyncio.LimitOverrunError.__name__.__eq__, ["LimitOverrunError"], true]

table asyncio_extra452.exception_modules:
  description: "asyncio exception class __module__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: aioexcm

  columns: [id, function, args, expected]
  rows:
    - [aioexcm001, asyncio.CancelledError.__module__.__eq__, ["asyncio"], true]
    - [aioexcm002, asyncio.TimeoutError.__module__.__eq__, ["asyncio"], true]
    - [aioexcm003, asyncio.InvalidStateError.__module__.__eq__, ["asyncio"], true]
    - [aioexcm004, asyncio.IncompleteReadError.__module__.__eq__, ["asyncio"], true]
    - [aioexcm005, asyncio.LimitOverrunError.__module__.__eq__, ["asyncio"], true]

table asyncio_extra452.exception_bases:
  description: "asyncio exception class __bases__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: aioexcb

  columns: [id, function, args, expected]
  rows:
    - [aioexcb001, "asyncio.CancelledError.__bases__[0].__name__.__eq__", ["BaseException"], true]
