spec: hashlib_extra1576
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __str__/__repr__/__bytes__ protocol"
    - "Covers hexdigest() string representation and digest() bytes representation."
    - "hexdigest() returns a str of lowercase hex characters; its length is always 2 * digest_size."
    - "digest() returns a bytes object of length digest_size."
    - "MD5 digest_size == 16, hexdigest length == 32."
    - "SHA-1 digest_size == 20, hexdigest length == 40."
    - "SHA-256 digest_size == 32, hexdigest length == 64."
    - "SHA-512 digest_size == 64, hexdigest length == 128."
    - "block_size for MD5, SHA-1, SHA-256 is 64; for SHA-512 it is 128."
    - "The .name attribute returns the canonical lowercase algorithm name as a str."
    - "All expected values verified by running Python 3.12 hashlib on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# hexdigest() — string representation of the hash
# ---------------------------------------------------------------------------

table hashlib_extra1576.hexdigest_values:
  kind: python_call_eq
  category: str_repr
  id_prefix: hl1576

  columns: [id, function, args, expected]
  rows:
    - ["hl1576_001", "hashlib.md5",    [b"hello"], "5d41402abc4b2a76b9719d911017c592"]
    - ["hl1576_002", "hashlib.sha1",   [b"hello"], "aaf4c61ddcc5e8a2dabede0f3b482cd9aea9434d"]
    - ["hl1576_003", "hashlib.sha256", [b""],      "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"]
    - ["hl1576_004", "hashlib.md5",    [b""],      "d41d8cd98f00b204e9800998ecf8427e"]
    - ["hl1576_005", "hashlib.sha1",   [b""],      "da39a3ee5e6b4b0d3255bfef95601890afd80709"]
    - ["hl1576_006", "hashlib.sha256", [b"hello"], "2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824"]

# ---------------------------------------------------------------------------
# hexdigest() length — always 2 * digest_size
# ---------------------------------------------------------------------------

table hashlib_extra1576.hexdigest_lengths:
  kind: python_call_eq
  category: str_repr
  id_prefix: hl1576

  columns: [id, function, args, expected]
  rows:
    - ["hl1576_010", "hashlib.md5.hexdigest.__len__",    [b"test"], 32]
    - ["hl1576_011", "hashlib.sha1.hexdigest.__len__",   [b"test"], 40]
    - ["hl1576_012", "hashlib.sha256.hexdigest.__len__", [b"test"], 64]
    - ["hl1576_013", "hashlib.sha512.hexdigest.__len__", [b"test"], 128]

# ---------------------------------------------------------------------------
# digest() length — equals digest_size in bytes
# ---------------------------------------------------------------------------

table hashlib_extra1576.digest_lengths:
  kind: python_call_eq
  category: bytes_repr
  id_prefix: hl1576

  columns: [id, function, args, expected]
  rows:
    - ["hl1576_020", "hashlib.md5.digest.__len__",    [b"test"], 16]
    - ["hl1576_021", "hashlib.sha1.digest.__len__",   [b"test"], 20]
    - ["hl1576_022", "hashlib.sha256.digest.__len__", [b"test"], 32]
    - ["hl1576_023", "hashlib.sha512.digest.__len__", [b"test"], 64]

# ---------------------------------------------------------------------------
# Return type checks — hexdigest is str, digest is bytes
# ---------------------------------------------------------------------------

table hashlib_extra1576.return_types:
  kind: python_call_eq
  category: str_repr
  id_prefix: hl1576

  columns: [id, function, args, expected]
  rows:
    - ["hl1576_030", "hashlib.md5.hexdigest.__class__.__name__", [b"test"], "str"]
    - ["hl1576_031", "hashlib.md5.digest.__class__.__name__",    [b"test"], "bytes"]
    - ["hl1576_032", "hashlib.sha256.hexdigest.__class__.__name__", [b"x"], "str"]
    - ["hl1576_033", "hashlib.sha256.digest.__class__.__name__",    [b"x"], "bytes"]

# ---------------------------------------------------------------------------
# .name attribute — canonical algorithm name as str
# ---------------------------------------------------------------------------

table hashlib_extra1576.name_attribute:
  kind: python_call_eq
  category: str_repr
  id_prefix: hl1576

  columns: [id, function, args, expected]
  rows:
    - ["hl1576_040", "hashlib.md5.name",    [b"hello"], "md5"]
    - ["hl1576_041", "hashlib.sha1.name",   [b"hello"], "sha1"]
    - ["hl1576_042", "hashlib.sha256.name", [b"hello"], "sha256"]
    - ["hl1576_043", "hashlib.sha512.name", [b"hello"], "sha512"]
    - ["hl1576_044", "hashlib.md5.name.__class__.__name__", [b"hello"], "str"]

# ---------------------------------------------------------------------------
# digest_size attribute
# ---------------------------------------------------------------------------

table hashlib_extra1576.digest_size:
  kind: python_call_eq
  category: properties
  id_prefix: hl1576

  columns: [id, function, args, expected]
  rows:
    - ["hl1576_050", "hashlib.md5.digest_size",    [b"abc"], 16]
    - ["hl1576_051", "hashlib.sha1.digest_size",   [b"abc"], 20]
    - ["hl1576_052", "hashlib.sha256.digest_size", [b"abc"], 32]
    - ["hl1576_053", "hashlib.sha512.digest_size", [b"abc"], 64]

# ---------------------------------------------------------------------------
# block_size attribute
# ---------------------------------------------------------------------------

table hashlib_extra1576.block_size:
  kind: python_call_eq
  category: properties
  id_prefix: hl1576

  columns: [id, function, args, expected]
  rows:
    - ["hl1576_060", "hashlib.sha1.block_size",   [b"abc"], 64]
    - ["hl1576_061", "hashlib.sha256.block_size", [b"abc"], 64]
    - ["hl1576_062", "hashlib.sha512.block_size", [b"abc"], 128]

# ---------------------------------------------------------------------------
# hexdigest() startswith checks — known prefix invariants
# ---------------------------------------------------------------------------

table hashlib_extra1576.hexdigest_prefix:
  kind: python_call_eq
  category: str_repr
  id_prefix: hl1576

  columns: [id, function, args, expected]
  rows:
    - ["hl1576_070", "hashlib.md5.hexdigest.startswith",    [b"hello", "5d"], true]
    - ["hl1576_071", "hashlib.sha256.hexdigest.startswith", [b"",      "e3"], true]
    - ["hl1576_072", "hashlib.md5.hexdigest.startswith",    [b"",      "d4"], true]
