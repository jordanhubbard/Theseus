spec: sk2881
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 639 (_extra2881): __iadd__, __isub__, __imul__ dict-presence checks for socket types."
    - "socket.socket is the main socket class (network I/O); it defines no in-place augmented assignment operators."
    - "socket.AddressFamily and socket.SocketKind are IntFlag subclasses; they do NOT define __iadd__/__isub__/__imul__ in their own __dict__."
    - "socket.AddressInfo and socket.MsgFlag are IntFlag subclasses; despite defining __rand__/__ror__/__rxor__ in wave 638, they do NOT define __iadd__, __isub__, or __imul__ in their own __dict__."
    - "socket.error, socket.herror, socket.gaierror, socket.timeout are exception subclasses with no arithmetic in-place operator definitions."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk2881.iadd:
  description: "socket types __iadd__ dict-presence checks; wave 639"
