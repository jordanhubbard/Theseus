spec: hashlib_extra71
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashlib.c"
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra70.zspec.zsdl — covers new/__kwdefaults__/__class__/__name__=='NoneType' / file_digest/__kwdefaults__/__class__/__name__=='NoneType' / md5/sha256/sha1/sha512 __doc__/__class__/__name__=='str' / new/__doc__/__class__/__name__=='str' / new/__doc__.__contains__('name') / file_digest/__doc__/__class__/__name__=='str' / file_digest/__doc__.__contains__('digest') (table + invariants)."
    - "hashlib_extra69.zspec.zsdl — covers new/__defaults__/__class__/__name__=='tuple' / new/__defaults__/__len__()==1 / new/__defaults__[0]/__class__/__name__=='bytes' / file_digest/__defaults__/__class__/__name__=='NoneType' / md5/sha256/sha512 __class__.__name__=='builtin_function_or_method' / md5/sha256 __module__.__contains__('hash') (table + invariants)."
    - "hashlib_extra68.zspec.zsdl — covers new/__code__.co_consts/__class__/__name__=='tuple' / file_digest/__code__.co_consts/__class__/__name__=='tuple' / co_nlocals/__class__/__name__=='int' / co_stacksize/__class__/__name__=='int' / algorithms_guaranteed.__contains__ sha3_256/sha3_512/sha224/sha384/blake2b/blake2s (table + invariants)."
    - "hashlib_extra67.zspec.zsdl — covers new/__code__.co_varnames/__class__/__name__=='tuple' / file_digest/__code__.co_varnames/__class__/__name__=='tuple' / new/__code__.co_varnames[0]=='name' / file_digest/__code__.co_varnames[0]=='fileobj' / algorithms_guaranteed.__contains__ sha256/md5/sha1/sha512 (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra70; it does NOT duplicate invariants present in those files."
    - "Wave 235 theme: pbkdf2_hmac C builtin identity + algorithms_guaranteed sha3_224/sha3_384/shake_128/shake_256 membership + hashlib.new and file_digest Python function class identity."
    - "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method' — pbkdf2_hmac is a C builtin function from the _hashlib C extension (not a Python wrapper). No prior hashlib spec checks pbkdf2_hmac.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__module__.__contains__('hashlib') == True — pbkdf2_hmac is exposed in the hashlib module namespace; __module__ contains 'hashlib'. No prior hashlib spec checks pbkdf2_hmac.__module__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha3_224') == True — sha3_224 is in algorithms_guaranteed per the Python docs (guaranteed since 3.6). hashlib_extra68 checks sha3_256/sha3_512 but not sha3_224. No prior hashlib spec checks sha3_224 membership. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha3_384') == True — sha3_384 is in algorithms_guaranteed. hashlib_extra68 checks sha3_256/sha3_512 but not sha3_384. No prior hashlib spec checks sha3_384 membership. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('shake_128') == True — shake_128 is in algorithms_guaranteed. No prior hashlib spec checks shake_128 membership. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('shake_256') == True — shake_256 is in algorithms_guaranteed. No prior hashlib spec checks shake_256 membership. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__class__.__name__ == 'function' — hashlib.new is a Python function defined in Lib/hashlib.py (the __hash_new wrapper); its class is 'function'. No prior hashlib spec checks new.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__class__.__name__ == 'function' — hashlib.file_digest is a Python function defined in Lib/hashlib.py; its class is 'function'. No prior hashlib spec checks file_digest.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__ == 'hashlib' — hashlib.new is defined in Lib/hashlib.py; __module__ is 'hashlib'. No prior hashlib spec checks new.__module__.__eq__('hashlib') in call form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__module__ == 'hashlib' — hashlib.file_digest is defined in Lib/hashlib.py; __module__ is 'hashlib'. No prior hashlib spec checks file_digest.__module__.__eq__('hashlib') in call form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac C builtin identity
#
# Wave 235 theme: pbkdf2_hmac is a C builtin from _hashlib; class and module.
#
# hashlib.pbkdf2_hmac is a C builtin function from the _hashlib C extension.
# Its __class__.__name__ is 'builtin_function_or_method'. Its __module__
# contains 'hashlib'. No prior hashlib spec checks any attribute of
# pbkdf2_hmac. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra71.pbkdf2_hmac_identity:
  description: "hashlib.pbkdf2_hmac/__class__/__name__=='builtin_function_or_method' / pbkdf2_hmac/__module__.__contains__('hashlib')==True — pbkdf2_hmac is a C builtin function from the _hashlib extension; __class__.__name__ is 'builtin_function_or_method'; __module__ contains 'hashlib'; no prior hashlib spec checks any attribute of pbkdf2_hmac; first identity anchor for hashlib.pbkdf2_hmac"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibmore71

  columns: [id, function, args, expected]
  rows:
    - [pbkdf2_hmac_class_builtin_function_or_method, pbkdf2_hmac.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [pbkdf2_hmac_module_contains_hashlib,          pbkdf2_hmac.__module__.__contains__,   ["hashlib"],                   true]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed sha3_224 / sha3_384 / shake_128 / shake_256
#
# Wave 235 theme: algorithms_guaranteed membership for sha3 and shake variants.
#
# hashlib_extra68 covers sha3_256/sha3_512/sha224/sha384/blake2b/blake2s.
# This spec adds sha3_224, sha3_384, shake_128, and shake_256 — all guaranteed
# per the Python docs since 3.6. No prior hashlib spec checks these four names.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra71.algorithms_guaranteed_sha3_shake:
  description: "hashlib.algorithms_guaranteed.__contains__('sha3_224')==True / __contains__('sha3_384')==True / __contains__('shake_128')==True / __contains__('shake_256')==True — sha3_224/sha3_384/shake_128/shake_256 are all in algorithms_guaranteed per the Python docs (guaranteed since 3.6); hashlib_extra68 covers sha3_256/sha3_512/sha224/sha384/blake2b/blake2s; this spec adds the remaining sha3 and shake variants; no prior hashlib spec checks these four names; first membership anchor for sha3_224/sha3_384/shake_128/shake_256"
  kind: python_call_eq
  category: algorithms_guaranteed
  id_prefix: hashlibmore71

  columns: [id, function, args, expected]
  rows:
    - [algorithms_guaranteed_contains_sha3_224,  algorithms_guaranteed.__contains__, ["sha3_224"],  true]
    - [algorithms_guaranteed_contains_sha3_384,  algorithms_guaranteed.__contains__, ["sha3_384"],  true]
    - [algorithms_guaranteed_contains_shake_128, algorithms_guaranteed.__contains__, ["shake_128"], true]
    - [algorithms_guaranteed_contains_shake_256, algorithms_guaranteed.__contains__, ["shake_256"], true]

# ---------------------------------------------------------------------------
# hashlib.new and file_digest __class__.__name__ == 'function'
#
# Wave 235 theme: new and file_digest are Python functions — class identity.
#
# hashlib.new and hashlib.file_digest are both pure-Python functions defined in
# Lib/hashlib.py. Their __class__.__name__ is 'function'. No prior hashlib spec
# checks __class__.__name__ for new or file_digest in any form. Prior specs
# establish co_name/co_argcount (extra66), co_varnames (extra67), etc., which
# imply Python code objects, but never directly assert __class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra71.hashlib_python_funcs_class:
  description: "hashlib.new/__class__/__name__=='function' / hashlib.file_digest/__class__/__name__=='function' — new and file_digest are pure-Python functions defined in Lib/hashlib.py; __class__.__name__ is 'function' for both; no prior hashlib spec checks __class__/__name__ for new or file_digest; first Python function class identity anchor for hashlib wrapper functions"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibmore71

  columns: [id, function, args, expected]
  rows:
    - [new_class_function,          new.__class__.__name__.__eq__,          ["function"], true]
    - [file_digest_class_function,  file_digest.__class__.__name__.__eq__,  ["function"], true]

# ---------------------------------------------------------------------------
# hashlib.new and file_digest __module__ == 'hashlib'
#
# Wave 235 theme: new and file_digest __module__ call-form equality.
#
# hashlib.new and hashlib.file_digest are defined in Lib/hashlib.py. Their
# __module__ is 'hashlib'. No prior hashlib spec checks new.__module__.__eq__
# or file_digest.__module__.__eq__ in call form. Verified Python 3.14.3 macOS.
# ---------------------------------------------------------------------------

table hashlib_extra71.hashlib_python_funcs_module:
  description: "hashlib.new/__module__.__eq__('hashlib')==True / hashlib.file_digest/__module__.__eq__('hashlib')==True — new and file_digest are defined in Lib/hashlib.py; __module__ is 'hashlib'; no prior hashlib spec checks new/__module__.__eq__ or file_digest/__module__.__eq__ in call form; first __module__ call-form equality anchor for hashlib wrapper functions"
  kind: python_call_eq
  category: module_identity
  id_prefix: hashlibmore71

  columns: [id, function, args, expected]
  rows:
    - [new_module_eq_hashlib,          new.__module__.__eq__,          ["hashlib"], true]
    - [file_digest_module_eq_hashlib,  file_digest.__module__.__eq__,  ["hashlib"], true]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.pbkdf2_hmac is a C builtin function from the _hashlib extension.
# Its __class__.__name__ is 'builtin_function_or_method'. No prior hashlib
# spec checks pbkdf2_hmac.__class__.__name__. First class identity anchor
# for hashlib.pbkdf2_hmac. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra71.pbkdf2_hmac_class_builtin:
  description: "hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method') == True — pbkdf2_hmac is a C builtin from the _hashlib extension; __class__.__name__ is 'builtin_function_or_method'; no prior hashlib spec checks pbkdf2_hmac.__class__.__name__; first class identity anchor for hashlib.pbkdf2_hmac"
  category: class_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha3_224') — standalone
#
# sha3_224 is in algorithms_guaranteed per the Python docs (guaranteed on all
# platforms since Python 3.6). hashlib_extra68 covers sha3_256/sha3_512 but
# not sha3_224. No prior hashlib spec checks sha3_224 membership. First
# sha3_224 membership anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra71.algorithms_guaranteed_sha3_224:
  description: "hashlib.algorithms_guaranteed.__contains__('sha3_224') == True — sha3_224 is guaranteed on all Python platforms since 3.6; hashlib_extra68 covers sha3_256/sha3_512 but not sha3_224; no prior hashlib spec checks sha3_224; first sha3_224 membership anchor for algorithms_guaranteed"
  category: algorithms_guaranteed
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha3_224"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('shake_128') — standalone
#
# shake_128 is in algorithms_guaranteed per the Python docs (guaranteed since
# Python 3.6). No prior hashlib spec checks shake_128 membership. First
# shake_128 membership anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra71.algorithms_guaranteed_shake_128:
  description: "hashlib.algorithms_guaranteed.__contains__('shake_128') == True — shake_128 is guaranteed on all Python platforms since 3.6; no prior hashlib spec checks shake_128 membership; first shake_128 membership anchor for algorithms_guaranteed"
  category: algorithms_guaranteed
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["shake_128"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__class__.__name__.__eq__('function') — standalone
#
# hashlib.new is a pure-Python function defined in Lib/hashlib.py. Its
# __class__.__name__ is 'function'. No prior hashlib spec checks
# new.__class__.__name__. First Python function class identity standalone
# for hashlib.new. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra71.new_class_function:
  description: "hashlib.new.__class__.__name__.__eq__('function') == True — new is a pure-Python function in Lib/hashlib.py; __class__.__name__ is 'function'; no prior hashlib spec checks new.__class__.__name__; first Python function class identity standalone for hashlib.new"
  category: class_identity
  kind: python_call_eq
  function: new.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__module__.__eq__('hashlib') — standalone
#
# hashlib.new is defined in Lib/hashlib.py. Its __module__ is 'hashlib'. No
# prior hashlib spec checks new.__module__.__eq__('hashlib') in call form.
# First __module__ call-form equality standalone for hashlib.new.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra71.new_module_hashlib:
  description: "hashlib.new.__module__.__eq__('hashlib') == True — new is defined in Lib/hashlib.py; __module__ is 'hashlib'; no prior hashlib spec checks new.__module__.__eq__ in call form; first __module__ call-form equality standalone for hashlib.new"
  category: module_identity
  kind: python_call_eq
  function: new.__module__.__eq__
  args: ["hashlib"]
  expected: true
