spec: pathlib_extra1966
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "any proprietary source"
  notes:
    - "Wave 578 (_extra1966): __enter__/__exit__, __aenter__/__aexit__, __del__ dict-presence checks."
    - "pathlib.Path is NOT a context manager; __enter__/__exit__ are absent from all pathlib class __dict__s."
    - "pathlib.PurePath.__mro__ == [PurePath, object]; pathlib.Path.__mro__ == [Path, PurePath, object]."
    - "pathlib.PurePosixPath.__mro__ == [PurePosixPath, PurePath, object]."
    - "pathlib.PureWindowsPath.__mro__ == [PureWindowsPath, PurePath, object]."
    - "None of the pathlib classes define __aenter__ or __aexit__ — no async context manager support."
    - "None of the pathlib classes define __del__ — no finalizer/resource cleanup protocol."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __enter__ dict-presence — pathlib classes
# pathlib.Path is not a context manager; prior to Python 3.10 it raised
# AttributeError; from 3.10+ it was removed from the public API.
# None of the Pure* variants ever defined __enter__.
# ---------------------------------------------------------------------------

table pathlib_extra1966.enter_protocol:
  description: "pathlib class __dict__.__contains__('__enter__') — all False (pathlib is not a context manager)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1966

  columns: [id, function, args, expected]
  rows:
    - ["pl1966001", "pathlib.PurePath.__dict__.__contains__",        ["__enter__"], false]
    - ["pl1966002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__enter__"], false]
    - ["pl1966003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__enter__"], false]
    - ["pl1966004", "pathlib.Path.__dict__.__contains__",            ["__enter__"], false]

# ---------------------------------------------------------------------------
# __exit__ dict-presence — pathlib classes
# ---------------------------------------------------------------------------

table pathlib_extra1966.exit_protocol:
  description: "pathlib class __dict__.__contains__('__exit__') — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1966

  columns: [id, function, args, expected]
  rows:
    - ["pl1966005", "pathlib.PurePath.__dict__.__contains__",        ["__exit__"], false]
    - ["pl1966006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__exit__"], false]
    - ["pl1966007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__exit__"], false]
    - ["pl1966008", "pathlib.Path.__dict__.__contains__",            ["__exit__"], false]

# ---------------------------------------------------------------------------
# __aenter__ dict-presence — pathlib classes
# No pathlib class supports async context manager protocol.
# ---------------------------------------------------------------------------

table pathlib_extra1966.aenter_protocol:
