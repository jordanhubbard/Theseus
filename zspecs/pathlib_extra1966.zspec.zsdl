  category: dict_contains
  id_prefix: pl1966

  columns: [id, function, args, expected]
  rows:
    - ["pl1966021", "pathlib.PurePath.__dict__.__contains__", ["__enter__"],  false]
    - ["pl1966022", "pathlib.PurePath.__dict__.__contains__", ["__exit__"],   false]
    - ["pl1966023", "pathlib.PurePath.__dict__.__contains__", ["__aenter__"], false]
    - ["pl1966024", "pathlib.PurePath.__dict__.__contains__", ["__aexit__"],  false]
    - ["pl1966025", "pathlib.PurePath.__dict__.__contains__", ["__del__"],    false]

