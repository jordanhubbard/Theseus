  columns: [id, function, args, expected]
  rows:
    - ["pl1966013", "pathlib.PurePath.__dict__.__contains__",        ["__aexit__"], false]
    - ["pl1966014", "pathlib.PurePosixPath.__dict__.__contains__",   ["__aexit__"], false]
    - ["pl1966015", "pathlib.PureWindowsPath.__dict__.__contains__", ["__aexit__"], false]
    - ["pl1966016", "pathlib.Path.__dict__.__contains__",            ["__aexit__"], false]

# ---------------------------------------------------------------------------
# __del__ dict-presence — pathlib classes
# pathlib classes hold no OS resources directly (file descriptors are managed
# by open()); no finalizer is defined on any pathlib class.
# ---------------------------------------------------------------------------

table pathlib_extra1966.del_finalizer:
  description: "pathlib class __dict__.__contains__('__del__') — all False (no resource finalizer)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1966

  columns: [id, function, args, expected]
  rows:
    - ["pl1966017", "pathlib.PurePath.__dict__.__contains__",        ["__del__"], false]
    - ["pl1966018", "pathlib.PurePosixPath.__dict__.__contains__",   ["__del__"], false]
    - ["pl1966019", "pathlib.PureWindowsPath.__dict__.__contains__", ["__del__"], false]
    - ["pl1966020", "pathlib.Path.__dict__.__contains__",            ["__del__"], false]

# ---------------------------------------------------------------------------
# Cross-protocol summary — PurePath: all five dunder protocol methods absent
# Combined spot-check invariants for the base class across all five methods.
# ---------------------------------------------------------------------------

table pathlib_extra1966.purepath_no_protocol:
  description: "pathlib.PurePath defines none of the five lifecycle protocol methods"
