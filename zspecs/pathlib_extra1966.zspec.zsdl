  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1966

  columns: [id, function, args, expected]
  rows:
    - ["pl1966009", "pathlib.PurePath.__dict__.__contains__",        ["__aenter__"], false]
    - ["pl1966010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__aenter__"], false]
    - ["pl1966011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__aenter__"], false]
    - ["pl1966012", "pathlib.Path.__dict__.__contains__",            ["__aenter__"], false]

