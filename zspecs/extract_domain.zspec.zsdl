spec: extract_domain
version: ">=5.0.2"
backend: node(extract-domain)

docs: https://www.npmjs.com/package/extract-domain

provenance:
  derived_from:
    - "extract-domain README — https://www.npmjs.com/package/extract-domain"
    - "Test vectors verified with extract-domain via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "extract-domain source"
  notes:
    - "extract-domain is an npm package. Install: npm install extract-domain"
    - "Extracts the domain from a URL string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the domain string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table extract_domain.extract:
  kind: node_module_call_eq
  function: "default"
  category: url
  id_prefix: extdom

  columns: [id, args, expected]
  rows:
    - [with_path,   ["https://example.com/path"],   "example.com"]
    - [subdomain,   ["http://sub.domain.com"],       "domain.com"]
    - [simple,      ["https://foo.io"],              "foo.io"]

