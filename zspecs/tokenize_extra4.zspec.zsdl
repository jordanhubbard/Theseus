spec: tokenize_extra4
version: ">=3.9"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tokenize.html — Python tokenize module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
  notes:
    - "This spec extends tokenize.zspec.zsdl, tokenize_extra.zspec.zsdl, tokenize_extra2.zspec.zsdl, and tokenize_extra3.zspec.zsdl."
    - "tokenize (base) covers: NAME/NUMBER/STRING/NEWLINE/INDENT/DEDENT/OP int checks (core_token_types), COMMENT/ENCODING/NL int checks (extended_token_types), tokenize/__name__, generate_tokens/__name__, detect_encoding/__name__."
    - "tokenize_extra covers: TokenInfo/__name__/__module__, TokenError/__name__ and bases, tokenize/generate_tokens/detect_encoding/open/untokenize __name__, ENCODING/COMMENT/NAME/NUMBER/STRING/NEWLINE/OP/ENDMARKER int type checks."
    - "tokenize_extra2 covers: TokenInfo/__name__, TokenInfo/_fields/__len__()==5, TokenInfo/_fields membership (all 5 fields via __contains__), TokenInfo/_fields[0]=='type', TokenInfo/_fields[1]=='string', tokenize/generate_tokens/detect_encoding/open __name__ (table), COMMENT is_int."
    - "tokenize_extra3 covers: tokenize/generate_tokens/untokenize/detect_encoding __module__ (table), TokenError/__name__/__module__/bases, TokenInfo/__name__/__module__/bases, COMMENT/STRING/NUMBER/NAME/ENCODING int checks (table), untokenize/__name__, TokenInfo/bases_len."
    - "This spec adds: TokenInfo/_fields[2]=='start', _fields[3]=='end', _fields[4]=='line' (extra2 only covers [0] and [1]), open/__module__=='tokenize' (not covered anywhere), TokenError/__bases__/__len__()==1, TokenInfo/__qualname__, TokenError/__qualname__, function __qualname__ checks for generate_tokens/tokenize/detect_encoding/untokenize."
    - "TokenInfo._fields[2] == 'start', [3] == 'end', [4] == 'line' — completes the positional field-order coverage."
    - "tokenize.open.__module__ == 'tokenize' — open.__name__ is covered in extra and extra2; __module__ is new."
    - "TokenError.__bases__.__len__() == 1 — exactly one base class (Exception)."
    - "TokenInfo.__qualname__ == 'TokenInfo' — top-level named tuple class; qualname equals name."
    - "TokenError.__qualname__ == 'TokenError' — top-level exception class; qualname equals name."
    - "generate_tokens.__qualname__ == 'generate_tokens' — module-level function; qualname equals name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TokenInfo._fields positional access — indices 2, 3, 4
# tokenize_extra2 covers [0] ('type') and [1] ('string'); this adds the rest.
# ---------------------------------------------------------------------------

invariant tokenize_extra4.TokenInfo.fields_start_at_two:
  description: "tokenize.TokenInfo._fields[2] == 'start'"
  category: token_info
  kind: python_call_eq
  function: TokenInfo._fields.__getitem__
  args: [2]
  expected: "start"

invariant tokenize_extra4.TokenInfo.fields_end_at_three:
  description: "tokenize.TokenInfo._fields[3] == 'end'"
  category: token_info
  kind: python_call_eq
  function: TokenInfo._fields.__getitem__
  args: [3]
  expected: "end"

invariant tokenize_extra4.TokenInfo.fields_line_at_four:
  description: "tokenize.TokenInfo._fields[4] == 'line'"
  category: token_info
  kind: python_call_eq
  function: TokenInfo._fields.__getitem__
  args: [4]
  expected: "line"

# ---------------------------------------------------------------------------
# open.__module__ — not covered in any prior tokenize spec
# (tokenize_extra and tokenize_extra2 cover open.__name__ == 'open')
# ---------------------------------------------------------------------------

invariant tokenize_extra4.open.module:
  description: "tokenize.open.__module__ == 'tokenize'"
  category: function_modules
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["tokenize"]
  expected: true

# ---------------------------------------------------------------------------
# TokenError.__bases__.__len__() == 1 — exactly one base class
# tokenize_extra and tokenize_extra3 check which class it is; this adds the count.
# ---------------------------------------------------------------------------

invariant tokenize_extra4.TokenError.bases_len:
  description: "len(tokenize.TokenError.__bases__) == 1 — TokenError has exactly one base class"
  category: token_error
  kind: python_call_eq
  function: TokenError.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# TokenInfo.__qualname__ and TokenError.__qualname__ — not covered in any prior spec
# ---------------------------------------------------------------------------

invariant tokenize_extra4.TokenInfo.qualname:
  description: "tokenize.TokenInfo.__qualname__ == 'TokenInfo'"
  category: token_info
  kind: python_call_eq
  function: TokenInfo.__qualname__.__eq__
  args: ["TokenInfo"]
  expected: true

invariant tokenize_extra4.TokenError.qualname:
  description: "tokenize.TokenError.__qualname__ == 'TokenError'"
  category: token_error
  kind: python_call_eq
  function: TokenError.__qualname__.__eq__
  args: ["TokenError"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__ checks — not covered in any prior tokenize spec.
# All four are module-level functions so qualname == name.
# ---------------------------------------------------------------------------

table tokenize_extra4.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [generate_tokens, generate_tokens.__qualname__.__eq__, ["generate_tokens"], true]
    - [tokenize,        tokenize.__qualname__.__eq__,        ["tokenize"],        true]
    - [detect_encoding, detect_encoding.__qualname__.__eq__, ["detect_encoding"], true]
    - [untokenize,      untokenize.__qualname__.__eq__,      ["untokenize"],      true]
