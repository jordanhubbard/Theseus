spec: decimal_extra33
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra32.zspec.zsdl — covers Context.to_integral_value(25)/to_integral_exact(25) __qualname__.__len__(); Context.is_nan/is_zero/is_finite/is_signed/is_normal/is_infinite/is_subnormal __qualname__.__len__(); MAX_PREC/MAX_EMAX/MIN_EMIN __class__.__name__.__len__()==3."
    - "decimal_extra22.zspec.zsdl — covers Decimal.__abs__.__qualname__.__len__()==15."
    - "decimal_extra20.zspec.zsdl — covers ROUND_* string constant __len__() for all eight rounding modes."
    - "decimal_extra28.zspec.zsdl — covers Decimal.__add__/__mul__/__sub__/quantize/to_eng_string/__repr__/__str__/__neg__ __qualname__.__len__()."
  notes:
    - "This spec extends decimal_extra32.zspec.zsdl."
    - "Prior specs collectively covered: Decimal/Context/__module__/__name__/__qualname__ and all lengths; exception class __name__/__qualname__/__module__/__mro__.__len__(); getcontext/setcontext/localcontext __name__/__qualname__/__module__ and lengths; Decimal arithmetic method __qualname__.__len__() for __add__/__mul__/__sub__/quantize/to_eng_string/__repr__/__str__/__neg__/compare/sqrt/ln/log10/normalize/fma/exp/remainder_near/to_integral_value/as_integer_ratio/as_tuple/is_nan/is_zero/is_finite/is_signed/is_normal/is_subnormal/is_infinite; Decimal.__abs__.__qualname__.__len__()==15; all Context method __qualname__.__len__(); ROUND_* string __len__(); exception __name__.__len__(); MAX_PREC/MAX_EMAX/MIN_EMIN __class__.__name__.__len__()==3; Context.is_* predicate __qualname__.__len__()."
    - "This spec covers: Decimal.__pos__/__qualname__.__len__()==15 (NOVEL — no prior decimal spec checks __pos__.__qualname__.__len__()); Decimal.__int__/__qualname__.__len__()==15 (NOVEL — decimal_extra7 covers __int__ behavioral tests; no prior spec checks __int__.__qualname__.__len__()); Decimal.__ceil__/__qualname__.__len__()==16 (NOVEL); Decimal.__bool__/__qualname__.__len__()==16 (NOVEL); Decimal.__copy__/__qualname__.__len__()==16 (NOVEL); Decimal.__float__/__qualname__.__len__()==17 (NOVEL — decimal_extra8 covers __float__ behavioral test; no prior spec checks __float__.__qualname__.__len__()); Decimal.__round__/__qualname__.__len__()==17 (NOVEL — decimal_extra8 covers __round__(ndigits) behavioral test; no prior spec checks __round__.__qualname__.__len__()); Decimal.__floor__/__qualname__.__len__()==17 (NOVEL); Decimal.__trunc__/__qualname__.__len__()==17 (NOVEL); Decimal.__format__/__qualname__.__len__()==18 (NOVEL); Decimal.__deepcopy__/__qualname__.__len__()==20 (NOVEL — longest Decimal dunder qualname covered in this spec); Context.is_snan/__qualname__.__len__()==15 (NOVEL — decimal_extra32 covers Context.is_nan/is_zero/is_finite/is_signed/is_normal/is_infinite/is_subnormal but NOT is_snan/is_qnan); Context.is_qnan/__qualname__.__len__()==15 (NOVEL); decimal.HAVE_THREADS.__class__.__name__.__len__()==4 (NOVEL — HAVE_THREADS is a bool; 'bool' has 4 chars; no prior decimal spec checks HAVE_THREADS type name length); decimal.HAVE_CONTEXTVAR.__class__.__name__.__len__()==4 (NOVEL)."
    - "Decimal.__pos__.__qualname__ == 'Decimal.__pos__' — len 15. Equals Decimal.__abs__(15) from decimal_extra22. No prior decimal spec checks __pos__.__qualname__.__len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.__int__.__qualname__ == 'Decimal.__int__' — len 15. decimal_extra7 covers __int__ behavioral test; no prior spec checks __int__.__qualname__.__len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.__ceil__.__qualname__ == 'Decimal.__ceil__' — len 16. No prior decimal spec checks __ceil__.__qualname__.__len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.__bool__.__qualname__ == 'Decimal.__bool__' — len 16. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.__copy__.__qualname__ == 'Decimal.__copy__' — len 16. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.__float__.__qualname__ == 'Decimal.__float__' — len 17. decimal_extra8 covers __float__() behavioral test but not __qualname__.__len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.__round__.__qualname__ == 'Decimal.__round__' — len 17. decimal_extra8 covers __round__(ndigits) behavioral test but not __qualname__.__len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.__floor__.__qualname__ == 'Decimal.__floor__' — len 17. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.__trunc__.__qualname__ == 'Decimal.__trunc__' — len 17. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.__format__.__qualname__ == 'Decimal.__format__' — len 18. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.__deepcopy__.__qualname__ == 'Decimal.__deepcopy__' — len 20. Longest Decimal dunder qualname in this spec. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.is_snan.__qualname__ == 'Context.is_snan' — len 15. decimal_extra32 covers Context.is_nan(14)/is_zero(15)/is_finite/is_signed/is_normal/is_infinite/is_subnormal but NOT is_snan or is_qnan. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.is_qnan.__qualname__ == 'Context.is_qnan' — len 15. Tied with Context.is_snan (15). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "decimal.HAVE_THREADS.__class__.__name__ == 'bool' — len 4. HAVE_THREADS is True on CPython 3.12. The type name 'bool' has 4 characters. No prior decimal spec checks HAVE_THREADS type or its name length. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "decimal.HAVE_CONTEXTVAR.__class__.__name__ == 'bool' — len 4. HAVE_CONTEXTVAR is True; same type as HAVE_THREADS. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal conversion/coercion dunder __qualname__.__len__(): len-15 cluster
#
# decimal_extra22 covers Decimal.__abs__.__qualname__.__len__()==15.
# No prior decimal spec checks __pos__ or __int__ qualname lengths.
#
# Both carry the 'Decimal.' prefix (8 chars) plus the dunder name:
#   __pos__ -> 'Decimal.__pos__' -> 8+7 = 15
#   __int__ -> 'Decimal.__int__' -> 8+7 = 15
#
# Both novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra33.Decimal_len15_dunder_qualname_lens:
  description: "decimal.Decimal.__pos__/__int__ __qualname__.__len__() == 15 — both novel; decimal_extra22 covers __abs__(15) but not __pos__ or __int__; 'Decimal.' prefix (8) + 7-char dunder = 15"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: ddq15_33

  columns: [id, function, args, expected]
  rows:
    - [dunder_pos, Decimal.__pos__.__qualname__.__len__, [], 15]
    - [dunder_int, Decimal.__int__.__qualname__.__len__, [], 15]

# ---------------------------------------------------------------------------
# Decimal dunder __qualname__.__len__(): len-16 cluster
#
# No prior decimal spec checks __ceil__, __bool__, or __copy__ qualname lengths.
# All three carry the 'Decimal.' prefix (8 chars) plus an 8-char dunder name:
#
#   __ceil__  -> 'Decimal.__ceil__'  -> 8+8 = 16
#   __bool__  -> 'Decimal.__bool__'  -> 8+8 = 16
#   __copy__  -> 'Decimal.__copy__'  -> 8+8 = 16
#
# All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra33.Decimal_len16_dunder_qualname_lens:
  description: "decimal.Decimal.__ceil__/__bool__/__copy__ __qualname__.__len__() == 16 — all novel; 'Decimal.' prefix (8) + 8-char dunder = 16"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: ddq16_33

  columns: [id, function, args, expected]
  rows:
    - [dunder_ceil, Decimal.__ceil__.__qualname__.__len__, [], 16]
    - [dunder_bool, Decimal.__bool__.__qualname__.__len__, [], 16]
    - [dunder_copy, Decimal.__copy__.__qualname__.__len__, [], 16]

# ---------------------------------------------------------------------------
# Decimal dunder __qualname__.__len__(): len-17 cluster
#
# No prior decimal spec checks __float__, __round__, __floor__, or __trunc__
# qualname lengths. All four carry the 'Decimal.' prefix (8 chars) plus a
# 9-char dunder name:
#
#   __float__ -> 'Decimal.__float__' -> 8+9 = 17
#   __round__ -> 'Decimal.__round__' -> 8+9 = 17
#   __floor__ -> 'Decimal.__floor__' -> 8+9 = 17
#   __trunc__ -> 'Decimal.__trunc__' -> 8+9 = 17
#
# decimal_extra8 covers __float__ and __round__ behavioral tests but not
# __qualname__.__len__(). All four are novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra33.Decimal_len17_dunder_qualname_lens:
  description: "decimal.Decimal.__float__/__round__/__floor__/__trunc__ __qualname__.__len__() == 17 — all novel; decimal_extra8 covers __float__/__round__ behavioral tests but not qualname lengths; 'Decimal.' prefix (8) + 9-char dunder = 17"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: ddq17_33

  columns: [id, function, args, expected]
  rows:
    - [dunder_float, Decimal.__float__.__qualname__.__len__, [], 17]
    - [dunder_round, Decimal.__round__.__qualname__.__len__, [], 17]
    - [dunder_floor, Decimal.__floor__.__qualname__.__len__, [], 17]
    - [dunder_trunc, Decimal.__trunc__.__qualname__.__len__, [], 17]

# ---------------------------------------------------------------------------
# Decimal.__format__ and __deepcopy__ __qualname__.__len__()
#
# Two longer Decimal dunders not covered by any prior decimal spec:
#
#   __format__   -> 'Decimal.__format__'   -> 8+10 = 18
#   __deepcopy__ -> 'Decimal.__deepcopy__' -> 8+12 = 20
#
# __deepcopy__ (len 20) is the longest Decimal dunder qualname checked in
# this spec, tied with Decimal.to_eng_string (21) only in a different category.
# Both novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant decimal_extra33.Decimal_format_qualname_len:
  description: "len(decimal.Decimal.__format__.__qualname__) == 18 — 'Decimal.__format__' has 18 characters; novel (no prior decimal spec checks __format__.__qualname__.__len__())"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Decimal.__format__.__qualname__.__len__
  args: []
  expected: 18

invariant decimal_extra33.Decimal_deepcopy_qualname_len:
  description: "len(decimal.Decimal.__deepcopy__.__qualname__) == 20 — 'Decimal.__deepcopy__' has 20 characters; longest Decimal dunder qualname in this spec; novel"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Decimal.__deepcopy__.__qualname__.__len__
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# Context.is_snan and Context.is_qnan __qualname__.__len__()
#
# decimal_extra32 covers Context.is_nan(14)/is_zero(15)/is_finite(17)/
# is_signed(17)/is_normal(17)/is_infinite(19)/is_subnormal(20) but does NOT
# cover Context.is_snan or Context.is_qnan. These two predicates test for
# signaling NaN and quiet NaN respectively. Both have qualnames of length 15:
#
#   Context.is_snan -> 'Context.is_snan' -> 8+7 = 15  (= Context.is_zero)
#   Context.is_qnan -> 'Context.is_qnan' -> 8+7 = 15  (= Context.is_zero)
#
# Both novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra33.Context_is_snan_qnan_qualname_lens:
  description: "decimal.Context.is_snan/__qualname__.__len__()==15 and is_qnan/__qualname__.__len__()==15 — both novel; decimal_extra32 covers Context.is_nan through is_subnormal but not is_snan or is_qnan"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: dcsnq33

  columns: [id, function, args, expected]
  rows:
    - [is_snan, Context.is_snan.__qualname__.__len__, [], 15]
    - [is_qnan, Context.is_qnan.__qualname__.__len__, [], 15]

# ---------------------------------------------------------------------------
# decimal.HAVE_THREADS and HAVE_CONTEXTVAR __class__.__name__.__len__()
#
# decimal.HAVE_THREADS and HAVE_CONTEXTVAR are module-level boolean constants
# indicating build-time capabilities. On CPython 3.12 both are True. No prior
# decimal spec checks either constant or its type. Their type is bool, so
# __class__.__name__ == 'bool' and __class__.__name__.__len__() == 4.
#
# decimal_extra32 covers MAX_PREC/MAX_EMAX/MIN_EMIN __class__.__name__.__len__()==3
# ('int'). HAVE_THREADS/HAVE_CONTEXTVAR have the same pattern but yield 4 ('bool').
# Both novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra33.have_constants_class_name_lens:
  description: "decimal.HAVE_THREADS/HAVE_CONTEXTVAR __class__.__name__.__len__() == 4 — both are bool instances; 'bool' has 4 chars; novel (decimal_extra32 covers int constants at len 3 but not bool constants at len 4)"
  kind: python_call_eq
  category: module_constants
  id_prefix: dhccnl33

  columns: [id, function, args, expected]
  rows:
    - [HAVE_THREADS,    HAVE_THREADS.__class__.__name__.__len__,    [], 4]
    - [HAVE_CONTEXTVAR, HAVE_CONTEXTVAR.__class__.__name__.__len__, [], 4]
