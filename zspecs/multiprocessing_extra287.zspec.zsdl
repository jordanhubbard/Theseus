spec: multiprocessing_extra287
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "multiprocessing.cpu_count and current_process resolve to the platform context's bound methods on macOS."
    - "multiprocessing.cpu_count.__module__ == 'multiprocessing.context' (not 'multiprocessing')."
    - "multiprocessing.current_process.__module__ == 'multiprocessing.process'."
    - "multiprocessing.active_children.__module__ == 'multiprocessing.process'."
    - "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess' (the abstract base in multiprocessing.process)."
    - "multiprocessing.Pool is a bound method on the context object; its __module__ == 'multiprocessing.context'."
    - "multiprocessing.Manager is a bound method on the context object; its __module__ == 'multiprocessing.context'."
    - "multiprocessing.SUBDEBUG == 5, multiprocessing.SUBWARNING == 25 (int constants)."
    - "All expected values verified by running Python 3.14.3 multiprocessing module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# cpu_count — function identity
# ---------------------------------------------------------------------------

invariant multiprocessing.cpu_count.name:
  description: "multiprocessing.cpu_count.__name__ == 'cpu_count'"
  category: cpu_count
  kind: python_call_eq
  function: cpu_count.__name__.__eq__
  args: ["cpu_count"]
  expected: true

invariant multiprocessing.cpu_count.module:
  description: "multiprocessing.cpu_count.__module__ == 'multiprocessing.context'"
  category: cpu_count
  kind: python_call_eq
  function: cpu_count.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

# ---------------------------------------------------------------------------
# current_process — function identity
# ---------------------------------------------------------------------------

invariant multiprocessing.current_process.name:
  description: "multiprocessing.current_process.__name__ == 'current_process'"
  category: current_process
  kind: python_call_eq
  function: current_process.__name__.__eq__
  args: ["current_process"]
  expected: true

invariant multiprocessing.current_process.module:
  description: "multiprocessing.current_process.__module__ == 'multiprocessing.process'"
  category: current_process
  kind: python_call_eq
  function: current_process.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

# ---------------------------------------------------------------------------
# active_children — function identity
# ---------------------------------------------------------------------------

invariant multiprocessing.active_children.name:
  description: "multiprocessing.active_children.__name__ == 'active_children'"
  category: active_children
  kind: python_call_eq
  function: active_children.__name__.__eq__
  args: ["active_children"]
  expected: true

invariant multiprocessing.active_children.module:
  description: "multiprocessing.active_children.__module__ == 'multiprocessing.process'"
  category: active_children
  kind: python_call_eq
  function: active_children.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

# ---------------------------------------------------------------------------
# Process — class identity (inherits from BaseProcess)
# ---------------------------------------------------------------------------

invariant multiprocessing.process.name:
  description: "multiprocessing.Process.__name__ == 'Process'"
  category: process
  kind: python_call_eq
  function: Process.__name__.__eq__
  args: ["Process"]
  expected: true

invariant multiprocessing.process.module:
  description: "multiprocessing.Process.__module__ == 'multiprocessing.context'"
  category: process
  kind: python_call_eq
  function: Process.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing.process.base_name:
  description: "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess'"
  category: process
  kind: python_call_eq
  function: Process.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseProcess"

# ---------------------------------------------------------------------------
# Pool — bound method identity on the platform context
# ---------------------------------------------------------------------------

invariant multiprocessing.pool.name:
  description: "multiprocessing.Pool.__name__ == 'Pool'"
  category: pool
  kind: python_call_eq
  function: Pool.__name__.__eq__
  args: ["Pool"]
  expected: true

invariant multiprocessing.pool.module:
  description: "multiprocessing.Pool.__module__ == 'multiprocessing.context'"
  category: pool
  kind: python_call_eq
  function: Pool.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

# ---------------------------------------------------------------------------
# Manager — bound method identity on the platform context
# ---------------------------------------------------------------------------

invariant multiprocessing.manager.name:
  description: "multiprocessing.Manager.__name__ == 'Manager'"
  category: manager
  kind: python_call_eq
  function: Manager.__name__.__eq__
  args: ["Manager"]
  expected: true

invariant multiprocessing.manager.module:
  description: "multiprocessing.Manager.__module__ == 'multiprocessing.context'"
  category: manager
  kind: python_call_eq
  function: Manager.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

# ---------------------------------------------------------------------------
# SUBDEBUG and SUBWARNING — integer logging level constants
#
# SUBDEBUG == 5, SUBWARNING == 25
# ---------------------------------------------------------------------------

invariant multiprocessing.subdebug.class_name:
  description: "multiprocessing.SUBDEBUG.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: SUBDEBUG.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant multiprocessing.subdebug.value:
  description: "multiprocessing.SUBDEBUG == 5"
  category: constants
  kind: python_call_eq
  function: SUBDEBUG.__eq__
  args: [5]
  expected: true

invariant multiprocessing.subwarning.class_name:
  description: "multiprocessing.SUBWARNING.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: SUBWARNING.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant multiprocessing.subwarning.value:
  description: "multiprocessing.SUBWARNING == 25"
  category: constants
  kind: python_call_eq
  function: SUBWARNING.__eq__
  args: [25]
  expected: true
