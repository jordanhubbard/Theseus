spec: io_extra23
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE type/value; StringIO/BytesIO basic class checks"
    - "io_extra22.zspec.zsdl — covers DEFAULT_BUFFER_SIZE.__class__.__name__/ge_4096; UnsupportedOperation qualname/module/base0; BlockingIOError qualname; StringIO/BytesIO/BufferedReader qualname; class __module__ table"
  notes:
    - "This spec extends io.zspec.zsdl and prior extras through io_extra22.zspec.zsdl."
    - "io.StringIO('hello').getvalue() == 'hello' — getvalue returns all written content from construction."
    - "io.StringIO().__class__.__name__ == 'StringIO' — the instance class name is 'StringIO'."
    - "io.BytesIO(b'hello').getvalue() == b'hello' — getvalue returns the bytes buffer; b'hello' expressed as !ascii."
    - "io.BytesIO().__class__.__name__ == 'BytesIO' — the instance class name is 'BytesIO'."
    - "io.StringIO('hello').read() == 'hello' — read() with no args returns the full string content."
    - "io.BytesIO(b'hi').read() == b'hi' — read() with no args returns the full bytes content; b'hi' expressed as !ascii."
    - "io.StringIO().writable() == True — StringIO objects are writable."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.StringIO('hello').getvalue() == 'hello'
#
# StringIO initialized with a string returns that string from getvalue().
# No prior io spec checks getvalue() on a StringIO with constructor arg.
# ---------------------------------------------------------------------------

invariant io_extra23.StringIO.getvalue_hello:
  description: "io.StringIO('hello').getvalue() == 'hello' — getvalue returns constructor-provided content"
  category: StringIO
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: getvalue
  method_args: []
  expected: "hello"

# ---------------------------------------------------------------------------
# io.StringIO().__class__.__name__ == 'StringIO'
#
# The class name of a StringIO instance is 'StringIO'. Tests instance-level
# __class__.__name__ (not the class attribute __name__).
# ---------------------------------------------------------------------------

invariant io_extra23.StringIO.instance_class_name:
  description: "io.StringIO().__class__.__name__ == 'StringIO' — instance class name"
  category: StringIO
  kind: python_call_eq
  function: StringIO
  args: []
  method: __class__.__name__.__eq__
  method_args: ["StringIO"]
  expected: true

# ---------------------------------------------------------------------------
# io.BytesIO(b'hello').getvalue() == b'hello'
#
# BytesIO initialized with bytes returns those bytes from getvalue().
# No prior io spec checks getvalue() on a BytesIO with constructor arg.
# b'hello' expressed as !ascii "hello" per ZSDL convention.
# ---------------------------------------------------------------------------

invariant io_extra23.BytesIO.getvalue_hello:
  description: "io.BytesIO(b'hello').getvalue() == b'hello' — getvalue returns constructor-provided bytes"
  category: BytesIO
  kind: python_call_eq
  function: BytesIO
  args: [!ascii "hello"]
  method: getvalue
  method_args: []
  expected: !ascii "hello"

# ---------------------------------------------------------------------------
# io.BytesIO().__class__.__name__ == 'BytesIO'
#
# The class name of a BytesIO instance is 'BytesIO'. Tests instance-level
# __class__.__name__ (not the class attribute __name__).
# ---------------------------------------------------------------------------

invariant io_extra23.BytesIO.instance_class_name:
  description: "io.BytesIO().__class__.__name__ == 'BytesIO' — instance class name"
  category: BytesIO
  kind: python_call_eq
  function: BytesIO
  args: []
  method: __class__.__name__.__eq__
  method_args: ["BytesIO"]
  expected: true

# ---------------------------------------------------------------------------
# io.StringIO('hello').read() == 'hello'
#
# read() with no arguments returns all content of the StringIO stream.
# No prior io spec covers read() on a constructor-initialized StringIO.
# ---------------------------------------------------------------------------

invariant io_extra23.StringIO.read_hello:
  description: "io.StringIO('hello').read() == 'hello' — read() returns full string content"
  category: StringIO
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: read
  method_args: []
  expected: "hello"

# ---------------------------------------------------------------------------
# io.BytesIO(b'hi').read() == b'hi'
#
# read() with no arguments returns all bytes content of the BytesIO stream.
# No prior io spec covers read() on a constructor-initialized BytesIO.
# b'hi' expressed as !ascii "hi" per ZSDL convention.
# ---------------------------------------------------------------------------

invariant io_extra23.BytesIO.read_hi:
  description: "io.BytesIO(b'hi').read() == b'hi' — read() returns full bytes content"
  category: BytesIO
  kind: python_call_eq
  function: BytesIO
  args: [!ascii "hi"]
  method: read
  method_args: []
  expected: !ascii "hi"

# ---------------------------------------------------------------------------
# io.StringIO().writable() == True
#
# StringIO streams are writable. No prior io spec checks writable() on
# a default-constructed StringIO instance.
# ---------------------------------------------------------------------------

invariant io_extra23.StringIO.writable:
  description: "io.StringIO().writable() == True — StringIO is writable"
  category: StringIO
  kind: python_call_eq
  function: StringIO
  args: []
  method: writable
  method_args: []
  expected: true
