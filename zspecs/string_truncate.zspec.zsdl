spec: string_truncate
version: ">=1.0.0"
backend: node(string-truncate)

docs: https://www.npmjs.com/package/string-truncate

provenance:
  derived_from:
    - "string-truncate README — https://www.npmjs.com/package/string-truncate"
    - "Test vectors verified with string-truncate via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "string-truncate source"
  notes:
    - "string-truncate is an npm package. Install: npm install string-truncate"
    - "truncate(str, maxLength) truncates at end, appending the ellipsis character (…)."
    - "truncateMiddle(str, maxLength) truncates in the middle."
    - "The maxLength includes the ellipsis character in the count."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table string_truncate.truncate:
  kind: node_module_call_eq
  function: truncate
  category: strings
  id_prefix: strtrunc

  columns: [id, args, expected]
  rows:
    - [truncated,  ["hello world", 7], "hello …"]
    - [short,      ["hi", 10],         "hi"]
    - [tight,      ["short", 3],       "sh…"]

table string_truncate.truncate_middle:
  kind: node_module_call_eq
  function: truncateMiddle
  category: strings
  id_prefix: strtruncm

  columns: [id, args, expected]
  rows:
    - [middle,  ["hello world", 7], "hel…rld"]
    - [short,   ["abcdefgh", 5],    "ab…gh"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:22:07Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
