spec: is_empty
version: ">=1.2.0"
backend: node(is-empty)

docs: https://www.npmjs.com/package/is-empty

provenance:
  derived_from:
    - "is-empty README — https://www.npmjs.com/package/is-empty"
    - "Test vectors verified with is-empty via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-empty source"
  notes:
    - "is-empty is an npm package. Install: npm install is-empty"
    - "Returns true if the value is empty (empty array, empty object, null, undefined, empty string)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_empty.check:
  kind: node_module_call_eq
  function: ~
  category: validation
  id_prefix: isempty

  columns: [id, args, expected]
  rows:
    - [empty_arr,   [[]],     true]
    - [nonempty,    [[1]],    false]
    - [empty_obj,  [{}],      true]

