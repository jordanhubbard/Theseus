spec: cgi_extra
version: ">=3.0,<3.13"
backend: python_module(cgi)

docs: https://docs.python.org/3/library/cgi.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cgi.html — Python cgi module documentation"
    - "Test vectors derived from public documentation; cgi removed in Python 3.13"
  not_derived_from:
    - "CPython source: Lib/cgi.py"
  notes:
    - "The cgi module was deprecated in Python 3.11 and removed in Python 3.13."
    - "This spec covers aspects not present in cgi.zspec.zsdl."
    - "FieldStorage.__module__ == 'cgi' — the class is defined in the cgi module."
    - "MiniFieldStorage.__module__ == 'cgi' — the class is defined in the cgi module."
    - "print_exception is a module-level function in cgi for printing CGI tracebacks."
    - "escape was deprecated in Python 3.2 in favour of html.escape and is not covered here."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# class __module__ checks
# ---------------------------------------------------------------------------

invariant cgi_extra.FieldStorage.module:
  description: "cgi.FieldStorage.__module__ == 'cgi'"
  category: classes
  kind: python_call_eq
  function: FieldStorage.__module__.__eq__
  args: ["cgi"]
  expected: true

invariant cgi_extra.MiniFieldStorage.module:
  description: "cgi.MiniFieldStorage.__module__ == 'cgi'"
  category: classes
  kind: python_call_eq
  function: MiniFieldStorage.__module__.__eq__
  args: ["cgi"]
  expected: true

# ---------------------------------------------------------------------------
# function __name__ checks (not in cgi.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant cgi_extra.print_exception.name:
  description: "cgi.print_exception.__name__ == 'print_exception'"
  category: functions
  kind: python_call_eq
  function: print_exception.__name__.__eq__
  args: ["print_exception"]
  expected: true
