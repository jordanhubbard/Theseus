spec: beautifulsoup4_rust
version: ">=3.9"
backend: rust_module(beautifulsoup4_rust)

docs: https://www.crummy.com/software/BeautifulSoup/bs4/doc/

provenance:
  derived_from:
    - "https://www.crummy.com/software/BeautifulSoup/bs4/doc/ — BeautifulSoup documentation"
  not_derived_from:
    - "bs4 source: bs4/__init__.py"
  notes:
    - "BeautifulSoup provides HTML/XML parsing."
    - "BeautifulSoup('<p>hello</p>', 'html.parser').find('p').text == 'hello'."
    - "BeautifulSoup('<b>bold</b>', 'html.parser').find('b').text == 'bold'."
    - "BeautifulSoup('<p class=\"x\">hi</p>', 'html.parser').find('p')['class'] == ['x']."
    - "Expose bs4_tag_text(html, tag) -> str: BeautifulSoup(html, 'html.parser').find(tag).text."
    - "Expose bs4_tag_count(html, tag) -> int: len(BeautifulSoup(html, 'html.parser').find_all(tag))."
    - "All test vectors verified against beautifulsoup4 4.13.3."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# bs4_tag_text — text content of first matching tag
table beautifulsoup4_rust.parse.tag_text:
  kind: python_call_eq
  category: tag_text
  id_prefix: bs4_tt
  function: bs4_tag_text

  columns: [id, args, expected]
  rows:
    - [p_hello,  ["<p>hello</p>", "p"],   "hello"]
    - [b_bold,   ["<b>bold</b>", "b"],    "bold"]
    - [h1_title, ["<h1>Title</h1>", "h1"], "Title"]

# bs4_tag_count — count matching tags
table beautifulsoup4_rust.parse.tag_count:
  kind: python_call_eq
  category: tag_count
  id_prefix: bs4_tc
  function: bs4_tag_count

  columns: [id, args, expected]
  rows:
    - [two_p,   ["<p>a</p><p>b</p>", "p"],        2]
    - [three_li, ["<ul><li>a</li><li>b</li><li>c</li></ul>", "li"], 3]
    - [one_b,   ["<b>x</b>", "b"],                1]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:31:48Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
