spec: struct_extra91
version: ">=3.9"
backend: python_module(struct)
extends: struct_extra90

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra90.zspec.zsdl — covers struct module-level function __qualname__ values / Struct method __qualname__ values / Struct.__doc__ and struct.error.__doc__ class names / Struct method class name cross-checks (table + invariants)."
    - "struct_extra89.zspec.zsdl — covers Struct.__dict__ membership for core methods and dunder attrs / module-level function __module__ cross-checks (table + invariants)."
    - "struct_extra88.zspec.zsdl — covers Struct.pack/pack_into/unpack/unpack_from/iter_unpack method_descriptor class names / Struct dunder and size class names (table + invariants)."
    - "struct_extra87.zspec.zsdl — covers struct module identity cross-checks / module-level function class names / struct.Struct class identity (table + invariants)."
    - "struct_extra86.zspec.zsdl — covers struct.Struct dunder method class names / struct.error MRO chain (table + invariants)."
    - "struct_extra85.zspec.zsdl — covers struct.Struct/__class__.__name__=='type' / module-level pack/unpack/calcsize builtin_function_or_method (table + invariants)."
    - "struct_extra83.zspec.zsdl — covers module-level function __qualname__.__eq__ / Struct.__dict__.__contains__ (table + invariants)."
    - "struct_extra82.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from __qualname__.__eq__ / Struct.__name__/__qualname__/__bases__/__mro__ (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra90; it does NOT duplicate invariants present in those files."
    - "Wave 258 theme: struct.calcsize return values for common format strings — behavioral pack/unpack size invariants using python_call_eq."
    - "struct.calcsize('b') == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('c') == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('H') == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('h') == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('i') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('I') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('q') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('Q') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('f') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('d') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('?') == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('x') == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('e') == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__ == 'calcsize'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__qualname__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__qualname__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.calcsize('b') == 1
# struct.calcsize('c') == 1
# struct.calcsize('H') == 2
# struct.calcsize('h') == 2
# struct.calcsize('i') == 4
# struct.calcsize('I') == 4
# struct.calcsize('q') == 8
# struct.calcsize('Q') == 8
# struct.calcsize('f') == 4
# struct.calcsize('d') == 8
#
# Wave 258 theme: struct.calcsize return values for integer and float format codes.
#
# struct.calcsize returns the byte size described by a native-byte-order format
# string. b/c (signed char/char) == 1; h/H (short) == 2; i/I (int) == 4;
# q/Q (long long) == 8; f (float) == 4; d (double) == 8. These are stable
# across platforms in native format (no byte-order prefix). No prior struct
# spec anchors these ten calcsize return values together under structcalcsize91.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra91.struct_calcsize_integer_float_formats:
  description: "struct.calcsize('b')==1 / calcsize('c')==1 / calcsize('H')==2 / calcsize('h')==2 / calcsize('i')==4 / calcsize('I')==4 / calcsize('q')==8 / calcsize('Q')==8 / calcsize('f')==4 / calcsize('d')==8 — b/c (char) are 1 byte; h/H (short) are 2 bytes; i/I (int) are 4 bytes; q/Q (long long) are 8 bytes; f (float) is 4 bytes; d (double) is 8 bytes; no prior struct spec anchors these ten calcsize return values together; first structcalcsize91 anchor for integer and float format calcsize values"
  kind: python_call_eq
  category: behavior
  id_prefix: structcalcsize91

  columns: [id, function, args, expected]
  rows:
    - [calcsize_b, calcsize, ["b"], 1]
    - [calcsize_c, calcsize, ["c"], 1]
    - [calcsize_H, calcsize, ["H"], 2]
    - [calcsize_h, calcsize, ["h"], 2]
    - [calcsize_i, calcsize, ["i"], 4]
    - [calcsize_I, calcsize, ["I"], 4]
    - [calcsize_q, calcsize, ["q"], 8]
    - [calcsize_Q, calcsize, ["Q"], 8]
    - [calcsize_f, calcsize, ["f"], 4]
    - [calcsize_d, calcsize, ["d"], 8]

# ---------------------------------------------------------------------------
# struct.calcsize('?') == 1
# struct.calcsize('x') == 1
# struct.calcsize('e') == 2
#
# Wave 258 theme: struct.calcsize return values for bool, pad, and half-float.
#
# '?' (bool) is 1 byte; 'x' (pad byte) is 1 byte; 'e' (half-precision float,
# added in Python 3.6) is 2 bytes. These three are less common format codes.
# 'x' writes a null byte and has no corresponding value in pack/unpack. 'e' is
# the IEEE 754 binary16 format. No prior struct spec anchors these three together
# under structcalcsize91. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra91.struct_calcsize_bool_pad_half:
  description: "struct.calcsize('?')==1 / calcsize('x')==1 / calcsize('e')==2 — '?' (bool) is 1 byte; 'x' (pad byte, no value) is 1 byte; 'e' (IEEE 754 binary16 half-float, Python 3.6+) is 2 bytes; no prior struct spec anchors these three together; first structcalcsize91 anchor for bool/pad/half-float calcsize values"
  kind: python_call_eq
  category: behavior
  id_prefix: structcalcsize91

  columns: [id, function, args, expected]
  rows:
    - [calcsize_bool, calcsize, ["?"], 1]
    - [calcsize_pad,  calcsize, ["x"], 1]
    - [calcsize_half, calcsize, ["e"], 2]

# ---------------------------------------------------------------------------
# struct.pack.__qualname__.__eq__('pack')
# struct.calcsize.__qualname__.__eq__('calcsize')
# struct.unpack.__qualname__.__eq__('unpack')
#
# Wave 258 theme: struct module function __qualname__ cross-check.
#
# pack, calcsize, and unpack are three of the six module-level C-extension
# functions in struct. Their __qualname__ equals their own name (no enclosing
# scope). struct_extra83 and struct_extra90 first anchor these; this table
# cross-checks the three most behaviorally central functions together under
# structcalcsize91. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra91.struct_core_fn_qualname_xchk:
  description: "struct.pack/__qualname__.__eq__('pack')==True / calcsize/__qualname__.__eq__('calcsize')==True / unpack/__qualname__.__eq__('unpack')==True — pack, calcsize, and unpack are the three most central struct module functions; all have __qualname__ equal to their own name (C-extension, no enclosing scope); struct_extra83/struct_extra90 first anchor these; this table cross-checks the three together under structcalcsize91; first structcalcsize91 anchor for core function __qualname__ cross-check"
  kind: python_call_eq
  category: type_identity
  id_prefix: structcalcsize91

  columns: [id, function, args, expected]
  rows:
    - [pack_qualname,     pack.__qualname__.__eq__,     ["pack"],     true]
    - [calcsize_qualname, calcsize.__qualname__.__eq__,  ["calcsize"], true]
    - [unpack_qualname,   unpack.__qualname__.__eq__,   ["unpack"],   true]

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__class__.__name__.__eq__('str')
# struct.error.__class__.__name__.__eq__('type')
#
# Wave 258 theme: Struct.__doc__ class name and struct.error class name.
#
# struct.Struct.__doc__ is a str (the Struct class has a docstring). struct_extra90
# first anchors Struct.__doc__.__class__.__name__=='str'. struct.error is a
# subclass of Exception defined at C level; its __class__.__name__ is 'type'
# (struct.error is itself a class, and the class of a class is 'type').
# No prior struct spec anchors these two together as a cross-check under
# structcalcsize91. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra91.struct_doc_and_error_class_names:
  description: "struct.Struct/__doc__/__class__/__name__.__eq__('str')==True / struct.error/__class__/__name__.__eq__('type')==True — Struct.__doc__ is a str (Struct has a class docstring); struct.error is a C-level exception class; its __class__.__name__ is 'type' (the metaclass of any class); struct_extra90 first anchors Struct.__doc__ class name; this table cross-checks both together under structcalcsize91; first structcalcsize91 anchor for Struct.__doc__ and error class name cross-check"
  kind: python_call_eq
  category: type_identity
  id_prefix: structcalcsize91

  columns: [id, function, args, expected]
  rows:
    - [struct_doc_str,    "Struct.__doc__.__class__.__name__.__eq__", ["str"],  true]
    - [error_class_type,  "error.__class__.__name__.__eq__",          ["type"], true]

# ---------------------------------------------------------------------------
# struct.calcsize('b') == 1 — standalone
#
# struct.calcsize('b') returns 1. 'b' is the format code for a signed char
# (int8_t), which is 1 byte wide. This is the smallest integer type supported
# by struct. No prior struct spec anchors calcsize('b')==1 as a standalone
# under structcalcsize91. First standalone for calcsize 'b' under structcalcsize91.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra91.calcsize_b_is_1:
  description: "struct.calcsize('b') == 1 — 'b' is the format code for a signed char (int8_t); calcsize returns 1, the byte size of a single char; no prior struct spec anchors this as a standalone; first standalone for calcsize('b') under structcalcsize91"
  category: behavior
  kind: python_call_eq
  function: calcsize
  args: ["b"]
  expected: 1

# ---------------------------------------------------------------------------
# struct.calcsize('Q') == 8 — standalone
#
# struct.calcsize('Q') returns 8. 'Q' is the format code for an unsigned long
# long (uint64_t), which is 8 bytes wide. It is the largest standard integer
# type supported by struct. No prior struct spec anchors calcsize('Q')==8 as
# a standalone under structcalcsize91. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra91.calcsize_Q_is_8:
  description: "struct.calcsize('Q') == 8 — 'Q' is the format code for an unsigned long long (uint64_t); calcsize returns 8, the byte size of an unsigned 64-bit integer; no prior struct spec anchors this as a standalone; first standalone for calcsize('Q') under structcalcsize91"
  category: behavior
  kind: python_call_eq
  function: calcsize
  args: ["Q"]
  expected: 8

# ---------------------------------------------------------------------------
# struct.calcsize('d') == 8 — standalone
#
# struct.calcsize('d') returns 8. 'd' is the format code for a double-precision
# float (IEEE 754 binary64), which is 8 bytes wide. This is the default
# floating-point type used by Python's float. No prior struct spec anchors
# calcsize('d')==8 as a standalone under structcalcsize91.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra91.calcsize_d_is_8:
  description: "struct.calcsize('d') == 8 — 'd' is the format code for a double-precision float (IEEE 754 binary64); calcsize returns 8; this is Python's native float type width; no prior struct spec anchors this as a standalone; first standalone for calcsize('d') under structcalcsize91"
  category: behavior
  kind: python_call_eq
  function: calcsize
  args: ["d"]
  expected: 8

# ---------------------------------------------------------------------------
# struct.calcsize('e') == 2 — standalone
#
# struct.calcsize('e') returns 2. 'e' is the format code for a half-precision
# float (IEEE 754 binary16), added in Python 3.6. It is 2 bytes wide. Half-
# precision floats are commonly used in GPU computing and ML frameworks where
# memory bandwidth is a constraint. No prior struct spec anchors calcsize('e')==2
# as a standalone under structcalcsize91. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra91.calcsize_e_is_2:
  description: "struct.calcsize('e') == 2 — 'e' is the format code for a half-precision float (IEEE 754 binary16, Python 3.6+); calcsize returns 2; half-floats are used in GPU/ML workloads where memory bandwidth matters; no prior struct spec anchors this as a standalone; first standalone for calcsize('e') under structcalcsize91"
  category: behavior
  kind: python_call_eq
  function: calcsize
  args: ["e"]
  expected: 2

# ---------------------------------------------------------------------------
# struct.calcsize('f') == 4 — standalone
#
# struct.calcsize('f') returns 4. 'f' is the format code for a single-precision
# float (IEEE 754 binary32), which is 4 bytes wide. This is half the size of a
# double ('d'==8). No prior struct spec anchors calcsize('f')==4 as a standalone
# under structcalcsize91. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra91.calcsize_f_is_4:
  description: "struct.calcsize('f') == 4 — 'f' is the format code for a single-precision float (IEEE 754 binary32); calcsize returns 4 (half the size of double); no prior struct spec anchors this as a standalone; first standalone for calcsize('f') under structcalcsize91"
  category: behavior
  kind: python_call_eq
  function: calcsize
  args: ["f"]
  expected: 4
