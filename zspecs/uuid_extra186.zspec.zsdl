spec: uuid_extra186
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "uuid.__name__ == 'uuid' and uuid.__package__ == '' — the uuid module is a top-level stdlib module with no package prefix."
    - "uuid.__spec__.name == 'uuid' — the ModuleSpec name attribute matches the module's __name__."
    - "uuid.UUID.__name__.__len__() == 4 ('UUID' has 4 characters); uuid.uuid4.__name__.__len__() == 5 ('uuid4' has 5 characters)."
    - "uuid.SafeUUID.__name__ == 'SafeUUID' and uuid.SafeUUID.__module__ == 'uuid' — SafeUUID is an Enum subclass defined in the uuid module."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' — SafeUUID directly subclasses enum.Enum."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid module identity — __name__, __package__, __spec__.name
# ---------------------------------------------------------------------------

table uuidmodule186.module_identity:
  kind: python_call_eq
  category: module_identity
  id_prefix: uuidmodule186

  columns: [id, function, args, expected, description]
  rows:
    - [module_name,    __name__.__eq__,         ["uuid"], true, "uuid.__name__ == 'uuid' (top-level stdlib module name)"]
    - [module_package, __package__.__eq__,       [""],    true, "uuid.__package__ == '' (empty string — uuid is a top-level module, no package prefix)"]
    - [spec_name,      __spec__.name.__eq__,     ["uuid"], true, "uuid.__spec__.name == 'uuid' (ModuleSpec.name matches the module's __name__)"]

# ---------------------------------------------------------------------------
# UUID and uuid4 name length checks
# ---------------------------------------------------------------------------

table uuidmodule186.name_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: uuidmodule186

  columns: [id, function, args, expected, description]
  rows:
    - [uuid_class_name_len,  UUID.__name__.__len__,   [], 4, "len(uuid.UUID.__name__) == 4 ('UUID' has 4 characters)"]
    - [uuid4_name_len,       uuid4.__name__.__len__,  [], 5, "len(uuid.uuid4.__name__) == 5 ('uuid4' has 5 characters)"]

# ---------------------------------------------------------------------------
# SafeUUID class identity — name, module, base class
# SafeUUID.__bases__[0].__name__ contains '[' so the function is double-quoted.
# ---------------------------------------------------------------------------

table uuidmodule186.SafeUUID_identity:
  kind: python_call_eq
  category: class_identity
  id_prefix: uuidmodule186

  columns: [id, function, args, expected, description]
  rows:
    - [safeuuid_name,   SafeUUID.__name__.__eq__,           ["SafeUUID"], true, "uuid.SafeUUID.__name__ == 'SafeUUID'"]
    - [safeuuid_module, SafeUUID.__module__.__eq__,          ["uuid"],     true, "uuid.SafeUUID.__module__ == 'uuid' (SafeUUID is defined in the uuid module)"]
    - [safeuuid_base,   "SafeUUID.__bases__[0].__name__.__eq__", ["Enum"], true, "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' (SafeUUID directly subclasses enum.Enum)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuidmodule186.module.name:
  description: "uuid.__name__ == 'uuid' (top-level stdlib module name)"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["uuid"]
  expected: true

invariant uuidmodule186.module.package:
  description: "uuid.__package__ == '' (top-level stdlib module, no package prefix)"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant uuidmodule186.module.spec_name:
  description: "uuid.__spec__.name == 'uuid' (ModuleSpec.name matches uuid.__name__)"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["uuid"]
  expected: true

invariant uuidmodule186.UUID.name_len:
  description: "len(uuid.UUID.__name__) == 4 ('UUID' has 4 characters)"
  category: name_lengths
  kind: python_call_eq
  function: UUID.__name__.__len__
  args: []
  expected: 4

invariant uuidmodule186.uuid4.name_len:
  description: "len(uuid.uuid4.__name__) == 5 ('uuid4' has 5 characters)"
  category: name_lengths
  kind: python_call_eq
  function: uuid4.__name__.__len__
  args: []
  expected: 5

invariant uuidmodule186.SafeUUID.name:
  description: "uuid.SafeUUID.__name__ == 'SafeUUID'"
  category: class_identity
  kind: python_call_eq
  function: SafeUUID.__name__.__eq__
  args: ["SafeUUID"]
  expected: true

invariant uuidmodule186.SafeUUID.module:
  description: "uuid.SafeUUID.__module__ == 'uuid' (SafeUUID is defined in the uuid module)"
  category: class_identity
  kind: python_call_eq
  function: SafeUUID.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuidmodule186.SafeUUID.base_class:
  description: "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' (SafeUUID directly subclasses enum.Enum)"
  category: class_identity
  kind: python_call_eq
  function: "SafeUUID.__bases__[0].__name__.__eq__"
  args: ["Enum"]
  expected: true
