spec: threading_extra1081
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading.Lock __module__ and __qualname__, RLock method qualnames (acquire, release), BoundedSemaphore qualnames, and threading module-level function qualnames not covered in _extra976/_extra991"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1081.lock_rlock_qualnames:
  description: "threading.Lock and RLock class-level and method __qualname__ identity"
  kind: python_call_eq
  category: lock_rlock_qualnames
  id_prefix: th1081lr
  columns: [id, function, args, expected]
  rows:
    - [th1081lr001, threading.RLock.__qualname__.__eq__,                     ["RLock"],                        true]
    - [th1081lr002, threading.RLock.__module__.__eq__,                       ["threading"],                    true]
    - [th1081lr003, threading.RLock.__doc__.__class__.__name__.__eq__,       ["str"],                          true]
    - [th1081lr004, threading.Lock.__qualname__.__eq__,                      ["Lock"],                         true]
    - [th1081lr005, threading.Lock.__module__.__eq__,                        ["threading"],                    true]
    - [th1081lr006, threading.Lock.__doc__.__class__.__name__.__eq__,        ["str"],                          true]
    - [th1081lr007, threading.Lock.__class__.__name__.__eq__,                ["builtin_function_or_method"],   true]
    - [th1081lr008, threading.RLock.__class__.__name__.__eq__,               ["function"],                     true]

table threading_extra1081.bounded_semaphore_qualnames:
  description: "threading.BoundedSemaphore method __qualname__ identity"
  kind: python_call_eq
  category: bounded_semaphore_qualnames
  id_prefix: th1081bs
  columns: [id, function, args, expected]
  rows:
    - [th1081bs001, threading.BoundedSemaphore.__qualname__.__eq__,          ["BoundedSemaphore"],             true]
    - [th1081bs002, threading.BoundedSemaphore.__module__.__eq__,            ["threading"],                    true]
    - [th1081bs003, threading.BoundedSemaphore.__class__.__name__.__eq__,    ["type"],                         true]
    - [th1081bs004, threading.BoundedSemaphore.__init__.__qualname__.__eq__,  ["BoundedSemaphore.__init__"],   true]
    - [th1081bs005, threading.BoundedSemaphore.acquire.__qualname__.__eq__,  ["BoundedSemaphore.acquire"],     true]
    - [th1081bs006, threading.BoundedSemaphore.release.__qualname__.__eq__,  ["BoundedSemaphore.release"],     true]
    - [th1081bs007, threading.BoundedSemaphore.__doc__.__class__.__name__.__eq__, ["str"],                     true]

table threading_extra1081.module_function_qualnames:
  description: "threading module-level function __qualname__ and __module__ identity"
  kind: python_call_eq
  category: module_function_qualnames
  id_prefix: th1081mf
  columns: [id, function, args, expected]
  rows:
    - [th1081mf001, threading.current_thread.__qualname__.__eq__,            ["current_thread"],               true]
    - [th1081mf002, threading.current_thread.__module__.__eq__,              ["threading"],                    true]
    - [th1081mf003, threading.main_thread.__qualname__.__eq__,               ["main_thread"],                  true]
    - [th1081mf004, threading.main_thread.__module__.__eq__,                 ["threading"],                    true]
    - [th1081mf005, threading.active_count.__qualname__.__eq__,              ["active_count"],                 true]
    - [th1081mf006, threading.active_count.__module__.__eq__,                ["threading"],                    true]
    - [th1081mf007, threading.enumerate.__qualname__.__eq__,                 ["enumerate"],                    true]
    - [th1081mf008, threading.enumerate.__module__.__eq__,                   ["threading"],                    true]
