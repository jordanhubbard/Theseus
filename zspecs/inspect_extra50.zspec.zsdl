spec: inspect_extra50
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra49.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/iscode/isframe/istraceback __name__/__qualname__.__len__(); iscoroutinefunction/isgeneratorfunction/isasyncgenfunction __name__/__qualname__.__len__(); getmembers/getfile/getsource/getmodule/signature/stack/currentframe/getfullargspec __qualname__.__len__(); Parameter/__mro__.__len__()==2; Signature/__mro__.__len__()==2; BoundArguments/__mro__.__len__()==2; FullArgSpec/__mro__.__len__()==3; FrameInfo/__mro__.__len__()==4; Parameter.empty/kind constants; inspect.__all__.__len__()==107; CO_OPTIMIZED==1; cleandoc/formatannotation/getattr_static/classify_class_attrs __name__ lengths; Signature/Parameter/BoundArguments method qualnames; getmembers/__module__.__len__(7); parameter kind integer values; Parameter/__name__/__module__/__qualname__; Signature/__name__/__module__/__qualname__; BoundArguments/__name__/__qualname__/__module__; FullArgSpec/__name__/__qualname__/__module__; FrameInfo/__name__/__qualname__; class __bases__[0].__name__ for Parameter/Signature/BoundArguments; FullArgSpec/__bases__[0].__name__=='tuple'; FrameInfo/__bases__[0].__name__=='_FrameInfo'; all __bases__[0].__qualname__ for Parameter/Signature/BoundArguments/FullArgSpec/FrameInfo; getouterframes/__name__/__module__; getinnerframes/__name__/__module__; formatargvalues/__name__/__module__; walktree/__name__/__module__; classify_class_attrs/__name__/__module__; getattr_static/__name__/__module__; isfunction/__class__.__name__=='function'; isbuiltin/__class__.__name__=='function'; isclass/__class__.__name__=='function'; ismodule/__class__.__name__=='function'; signature/__class__.__name__=='function'; getdoc/__class__.__name__=='function'; getsource/__class__.__name__=='function'; Parameter/__class__.__name__=='type'; Signature/__class__.__name__=='type'; isfunction/__class__.__qualname__=='function'; isbuiltin/__class__.__qualname__=='function'; isclass/__class__.__qualname__=='function'; ismodule/__class__.__qualname__=='function'; signature/__class__.__qualname__=='function'; Parameter/__class__.__qualname__=='type'; Signature/__class__.__qualname__=='type'; BoundArguments/__class__.__qualname__=='type'; FullArgSpec/__class__.__qualname__=='type'; CO_* constants __class__.__name__=='int' for all seven; Parameter kind constants __class__.__name__=='_ParameterKind' for all five."
    - "This spec covers: inspect.CO_OPTIMIZED.__eq__(1)==true; inspect.CO_NEWLOCALS.__eq__(2)==true; inspect.CO_VARARGS.__eq__(4)==true; inspect.CO_VARKEYWORDS.__eq__(8)==true; inspect.CO_NESTED.__eq__(16)==true; inspect.CO_GENERATOR.__eq__(32)==true; inspect.CO_NOFREE.__eq__(64)==true; inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__(1)==true; inspect.Parameter.VAR_POSITIONAL.__eq__(2)==true; inspect.Parameter.KEYWORD_ONLY.__eq__(3)==true; inspect.Parameter.VAR_KEYWORD.__eq__(4)==true; inspect.Parameter.POSITIONAL_ONLY.__eq__(0)==true."
    - "Key findings: The inspect.CO_* constants are plain int objects whose values are fixed bitmask positions in the code object co_flags field. The canonical CPython values are: CO_OPTIMIZED=1 (0x01), CO_NEWLOCALS=2 (0x02), CO_VARARGS=4 (0x04), CO_VARKEYWORDS=8 (0x08), CO_NESTED=16 (0x10), CO_GENERATOR=32 (0x20), CO_NOFREE=64 (0x40). These values are stable across CPython 3.x releases and are tested via int.__eq__ which returns True when the values match. The inspect.Parameter kind constants are _ParameterKind enum members. Enum members support equality comparison with their underlying integer values via __eq__ because Python's IntEnum (which _ParameterKind inherits from) delegates __eq__ to int. The CPython values are: POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1, VAR_POSITIONAL=2, KEYWORD_ONLY=3, VAR_KEYWORD=4. These are defined in Lib/inspect.py and are stable across Python 3.x. Note: extra47 recorded CO_OPTIMIZED==1 as a separate invariant; the present spec extends that to all seven CO_* constants and all five Parameter kind constants. All twelve invariants are new to extra50 (the CO_OPTIMIZED value check in extra47 used a different id_prefix and table namespace)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect CO_* constant integer values — extra50 namespace
#
# inspect.CO_OPTIMIZED, CO_NEWLOCALS, CO_VARARGS, CO_VARKEYWORDS, CO_NESTED,
# CO_GENERATOR, and CO_NOFREE are plain int objects whose values are fixed
# bitmask positions in the code object co_flags field. The values are:
#   CO_OPTIMIZED    =  1  (0x01)
#   CO_NEWLOCALS    =  2  (0x02)
#   CO_VARARGS      =  4  (0x04)
#   CO_VARKEYWORDS  =  8  (0x08)
#   CO_NESTED       = 16  (0x10)
#   CO_GENERATOR    = 32  (0x20)
#   CO_NOFREE       = 64  (0x40)
# Each flag is a power of two because these are bitmask positions. They are
# tested via int.__eq__ which returns True for matching integer values.
# extra47 recorded CO_OPTIMIZED == 1 in a different namespace. All seven
# entries in this table use the inspconstval50 prefix and are new to extra50.
# ---------------------------------------------------------------------------

table inspect_extra50.co_flag_constant_values:
  description: "inspect CO_* constant integer values — CO_OPTIMIZED=1, CO_NEWLOCALS=2, CO_VARARGS=4, CO_VARKEYWORDS=8, CO_NESTED=16, CO_GENERATOR=32, CO_NOFREE=64; bitmask powers-of-two for code object co_flags field; tested via int.__eq__"
  kind: python_call_eq
  category: identity
  id_prefix: inspconstval50

  columns: [id, function, args, expected, description]
  rows:
    - [CO_OPTIMIZED_value,
       CO_OPTIMIZED.__eq__,
       [1],
       true,
       "inspect.CO_OPTIMIZED.__eq__(1) == True — CO_OPTIMIZED is 1 (0x01); the first and lowest bit of co_flags; set when a function uses fast locals (LOAD_FAST/STORE_FAST) instead of a dictionary; all regular Python functions set this flag; int.__eq__ returns True when both operands are equal integers"]
    - [CO_NEWLOCALS_value,
       CO_NEWLOCALS.__eq__,
       [2],
       true,
       "inspect.CO_NEWLOCALS.__eq__(2) == True — CO_NEWLOCALS is 2 (0x02); set when a new dict is created for the locals namespace on function entry; all regular Python functions also set this flag; always set together with CO_OPTIMIZED for normal functions"]
    - [CO_VARARGS_value,
       CO_VARARGS.__eq__,
       [4],
       true,
       "inspect.CO_VARARGS.__eq__(4) == True — CO_VARARGS is 4 (0x04); set when the function accepts a *args variable-length positional argument tuple; the *args parameter collects all extra positional arguments into a tuple"]
    - [CO_VARKEYWORDS_value,
       CO_VARKEYWORDS.__eq__,
       [8],
       true,
       "inspect.CO_VARKEYWORDS.__eq__(8) == True — CO_VARKEYWORDS is 8 (0x08); set when the function accepts a **kwargs variable-length keyword argument dict; the **kwargs parameter collects all extra keyword arguments into a dict"]
    - [CO_NESTED_value,
       CO_NESTED.__eq__,
       [16],
       true,
       "inspect.CO_NESTED.__eq__(16) == True — CO_NESTED is 16 (0x10); set when the code object is a nested function (defined inside another function scope); nested functions can form closures over free variables from enclosing scopes"]
    - [CO_GENERATOR_value,
       CO_GENERATOR.__eq__,
       [32],
       true,
       "inspect.CO_GENERATOR.__eq__(32) == True — CO_GENERATOR is 32 (0x20); set when the function body contains a yield or yield from statement making it a generator function; calling a generator function returns a generator iterator rather than executing the body immediately"]
    - [CO_NOFREE_value,
       CO_NOFREE.__eq__,
       [64],
       true,
       "inspect.CO_NOFREE.__eq__(64) == True — CO_NOFREE is 64 (0x40); set when the function has no free variables (no cell variables and no free variables in co_freevars); a function with CO_NOFREE cannot be a closure; CO_NOFREE and CO_NESTED are mutually exclusive in practice for closures"]

# ---------------------------------------------------------------------------
# inspect.Parameter kind constant integer values — extra50 namespace
#
# inspect.Parameter.POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL,
# KEYWORD_ONLY, and VAR_KEYWORD are members of the _ParameterKind enum.
# _ParameterKind inherits from enum.IntEnum, so enum members compare equal
# to their underlying integer values via __eq__. The values are:
#   POSITIONAL_ONLY         = 0
#   POSITIONAL_OR_KEYWORD   = 1
#   VAR_POSITIONAL          = 2
#   KEYWORD_ONLY            = 3
#   VAR_KEYWORD             = 4
# These values are defined in Lib/inspect.py and are stable across CPython 3.x.
# extra47 recorded integer values for some Parameter kind constants in a
# different namespace; all five entries here use inspconstval50 and are new to extra50.
# ---------------------------------------------------------------------------

table inspect_extra50.parameter_kind_constant_values:
  description: "inspect.Parameter kind constant integer values — POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1, VAR_POSITIONAL=2, KEYWORD_ONLY=3, VAR_KEYWORD=4; _ParameterKind enum inherits from IntEnum so members compare equal to their int values via __eq__"
  kind: python_call_eq
  category: identity
  id_prefix: inspconstval50

  columns: [id, function, args, expected, description]
  rows:
    - [POSITIONAL_ONLY_value,
       Parameter.POSITIONAL_ONLY.__eq__,
       [0],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__eq__(0) == True — _ParameterKind enum member with integer value 0; represents a parameter that can only be passed positionally (appears before a / separator in the function signature); introduced in Python 3.8 when PEP 570 added positional-only parameters; value 0 is the lowest ordinal in the enum"]
    - [POSITIONAL_OR_KEYWORD_value,
       Parameter.POSITIONAL_OR_KEYWORD.__eq__,
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__(1) == True — _ParameterKind enum member with integer value 1; represents a parameter that can be passed either positionally or as a keyword argument; the most common parameter kind in Python functions; value 1 follows POSITIONAL_ONLY in the enum definition order"]
    - [VAR_POSITIONAL_value,
       Parameter.VAR_POSITIONAL.__eq__,
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__eq__(2) == True — _ParameterKind enum member with integer value 2; represents a *args variable-length positional parameter that collects extra positional arguments into a tuple; at most one VAR_POSITIONAL parameter is allowed per signature"]
    - [KEYWORD_ONLY_value,
       Parameter.KEYWORD_ONLY.__eq__,
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__eq__(3) == True — _ParameterKind enum member with integer value 3; represents a parameter that must be passed as a keyword argument; keyword-only parameters appear after a * or *args in the signature (PEP 3102); cannot be passed positionally"]
    - [VAR_KEYWORD_value,
       Parameter.VAR_KEYWORD.__eq__,
       [4],
       true,
       "inspect.Parameter.VAR_KEYWORD.__eq__(4) == True — _ParameterKind enum member with integer value 4; represents a **kwargs variable-length keyword parameter that collects extra keyword arguments into a dict; at most one VAR_KEYWORD parameter is allowed per signature; value 4 is the highest ordinal in the _ParameterKind enum"]
