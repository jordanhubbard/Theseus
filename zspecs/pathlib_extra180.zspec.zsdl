spec: pathlib_extra180
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib class MRO analysis for PurePath, PurePosixPath, PureWindowsPath, and Path."
    - "pathlib.PurePath.__mro__.__len__() == 2 — MRO is [PurePath, object]; PurePath inherits directly from object as the abstract root of all pathlib classes."
    - "pathlib.PurePosixPath.__mro__.__len__() == 3 — MRO is [PurePosixPath, PurePath, object]."
    - "pathlib.PureWindowsPath.__mro__.__len__() == 3 — MRO is [PureWindowsPath, PurePath, object]; same 3-step pattern as PurePosixPath."
    - "pathlib.Path.__mro__.__len__() == 3 — MRO is [Path, PurePath, object]; Path also has MRO length 3 on Python 3.12+."
    - "PurePosixPath, PureWindowsPath, and Path all tie at MRO length 3."
    - "pathlib.PurePath.__name__ == 'PurePath' (len=8: 'Pure' (4) + 'Path' (4) = 8)."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath' (len=13: 'Pure' (4) + 'Posix' (5) + 'Path' (4) = 13)."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' (len=15: 'Pure' (4) + 'Windows' (7) + 'Path' (4) = 15)."
    - "pathlib.Path.__name__ == 'Path' (len=4)."
    - "PureWindowsPath (15) > PurePosixPath (13) > PurePath (8) > Path (4) in class name length."
    - "All pathlib classes share __module__ == 'pathlib' (len=7)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib MRO lengths — PurePath, PurePosixPath, PureWindowsPath, Path
# PurePath.__mro__.__len__() == 2 (PurePath > object)
# PurePosixPath.__mro__.__len__() == 3 (PurePosixPath > PurePath > object)
# PureWindowsPath.__mro__.__len__() == 3 (PureWindowsPath > PurePath > object)
# Path.__mro__.__len__() == 3 (Path > PurePath > object)
# ---------------------------------------------------------------------------

table pathlib_extra180.mro_lengths:
  description: "MRO lengths: PurePath (len=2), PurePosixPath=PureWindowsPath=Path (len=3); PurePath (2) is the minimum; the three subclasses tie at 3; PureWindowsPath.__name__ (len=15) is the longest pathlib class name"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmro180

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_mro_len,      PurePath.__mro__.__len__,        [], 2, "pathlib.PurePath.__mro__.__len__() == 2 — MRO is [PurePath, object]; PurePath inherits directly from object with no intermediate base classes; PurePath (2) is the minimum MRO length among all pathlib classes in this spec: PurePath (2) < PurePosixPath=PureWindowsPath=Path (3); the 2-step MRO is the minimum possible for any user-defined class (class and object); PurePath is the root of the pathlib hierarchy — it provides all pure-path string manipulation without filesystem I/O; PurePosixPath, PureWindowsPath, and Path all have PurePath as a direct base, contributing the last 2 steps of their 3-step MROs; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_mro_len, PurePosixPath.__mro__.__len__,   [], 3, "pathlib.PurePosixPath.__mro__.__len__() == 3 — MRO is [PurePosixPath, PurePath, object]; PurePosixPath is the POSIX-flavored pure path class providing case-sensitive path semantics and forward-slash separators; PurePosixPath (3) == PureWindowsPath (3) == Path (3): a three-way tie at 3 for the direct PurePath subclasses; PurePosixPath (3) > PurePath (2) by 1: PurePosixPath adds exactly one step to the PurePath root; 'PurePosixPath' has 13 characters: 'Pure' (4) + 'Posix' (5) + 'Path' (4) = 13; PurePosixPath.__module__ == 'pathlib' (7 chars); confirmed Python 3.14.3 macOS"]
    - [purewinpath_mro_len,   PureWindowsPath.__mro__.__len__, [], 3, "pathlib.PureWindowsPath.__mro__.__len__() == 3 — MRO is [PureWindowsPath, PurePath, object]; PureWindowsPath provides Windows-flavored pure path semantics with backslash separators and case-insensitive comparisons; PureWindowsPath (3) == PurePosixPath (3) == Path (3): all three direct PurePath subclasses tie at MRO length 3; 'PureWindowsPath' has 15 characters: 'Pure' (4) + 'Windows' (7) + 'Path' (4) = 15; PureWindowsPath (15 chars) is the longest pathlib class name in this spec; PureWindowsPath (15) > PurePosixPath (13) by 2 — 'Windows' (7) is 2 chars longer than 'Posix' (5); confirmed Python 3.14.3 macOS"]
    - [path_mro_len,          Path.__mro__.__len__,            [], 3, "pathlib.Path.__mro__.__len__() == 3 — MRO is [Path, PurePath, object]; on Python 3.12+, Path inherits directly from PurePath with no intermediate OS-specific pure path class; Path (3) == PurePosixPath (3) == PureWindowsPath (3): a three-way tie at 3; 'Path' has 4 characters — the shortest pathlib class name in this spec: Path (4) < PurePath (8) < PurePosixPath (13) < PureWindowsPath (15); despite being the shortest name (4 chars), Path has the same MRO length (3) as the much longer-named PureWindowsPath (15 chars); Path adds filesystem I/O methods on top of PurePath's pure-path API; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib class name lengths
# Path (4) < PurePath (8) < PurePosixPath (13) < PureWindowsPath (15)
# All share __module__ == 'pathlib' (len=7)
# ---------------------------------------------------------------------------

table pathlib_extra180.class_name_lengths:
  description: "Class name lengths: Path (4), PurePath (8), PurePosixPath (13), PureWindowsPath (15); strict ascending sequence; all have __module__=='pathlib' (len=7); PureWindowsPath (15) is the maximum, Path (4) is the minimum"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmro180

  columns: [id, function, args, expected, description]
  rows:
    - [path_name_len,    Path.__name__.__len__,            [], 4,  "pathlib.Path.__name__.__len__() == 4 — 'Path' has 4 characters; Path (4) is the shortest class name among the four pathlib classes in this spec: Path (4) < PurePath (8) < PurePosixPath (13) < PureWindowsPath (15); the 4-character name 'Path' is simple and direct; Path.__module__ == 'pathlib' (7 chars): the module name 'pathlib' (7) is nearly twice the class name 'Path' (4); despite being the shortest name, Path is the most commonly used class for concrete filesystem path operations; 'Path' (4 chars) is the suffix shared by all four class names in this spec: PurePath ends in 'Path', PurePosixPath ends in 'Path', PureWindowsPath ends in 'Path'; confirmed Python 3.14.3 macOS"]
    - [purepath_name_len, PurePath.__name__.__len__,       [], 8,  "pathlib.PurePath.__name__.__len__() == 8 — 'PurePath' has 8 characters: 'Pure' (4) + 'Path' (4) = 8; PurePath (8) is the second-shortest in the ascending name-length sequence: Path (4) < PurePath (8) < PurePosixPath (13) < PureWindowsPath (15); PurePath (8) - Path (4) == 4 == len('Pure'): the 'Pure' prefix (4 chars) is exactly what distinguishes PurePath from Path; PurePath.__module__ == 'pathlib' (7 chars) < PurePath.__name__ (8 chars) by 1: the module name is 1 character shorter than the class name; 'PurePath' (8 chars) == len('suffixes') == 8: a coincidental tie with the longest PurePath property name; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_name_len, PurePosixPath.__name__.__len__, [], 13, "pathlib.PurePosixPath.__name__.__len__() == 13 — 'PurePosixPath' has 13 characters: 'Pure' (4) + 'Posix' (5) + 'Path' (4) = 13; PurePosixPath (13) is the second-longest in the ascending name-length sequence: Path (4) < PurePath (8) < PurePosixPath (13) < PureWindowsPath (15); PurePosixPath (13) - PurePath (8) == 5 == len('Posix'): the 'Posix' infix (5 chars) is the sole difference between PurePosixPath and PurePath; PurePosixPath (13) < PureWindowsPath (15) by 2 because 'Windows' (7) > 'Posix' (5) by 2; PurePosixPath.__module__ == 'pathlib' (7 chars) < PurePosixPath.__name__ (13 chars) by 6; confirmed Python 3.14.3 macOS"]
    - [purewinpath_name_len,   PureWindowsPath.__name__.__len__, [], 15, "pathlib.PureWindowsPath.__name__.__len__() == 15 — 'PureWindowsPath' has 15 characters: 'Pure' (4) + 'Windows' (7) + 'Path' (4) = 15; PureWindowsPath (15) is the maximum class name length among the four pathlib classes in this spec; PureWindowsPath (15) - PurePosixPath (13) == 2 because 'Windows' (7) > 'Posix' (5) by 2; PureWindowsPath (15) > PurePath (8) by 7 == len('Windows'): the 'Windows' infix is the sole length difference relative to PurePath; PureWindowsPath.__module__ == 'pathlib' (7 chars) < PureWindowsPath.__name__ (15 chars) by 8; the name 'PureWindowsPath' (15) is the longest of all class names tested across any pathlib spec; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib class __module__ and mro[1].__name__ entries
# All four classes have __module__ == 'pathlib' (len=7)
# PurePath mro[1] = object, PurePosixPath mro[1] = PurePath, Path mro[1] = PurePath
# ---------------------------------------------------------------------------

table pathlib_extra180.module_and_mro1_names:
  description: "pathlib classes all have __module__=='pathlib' (len=7); mro[1].__name__: PurePath->'object' (len=6), PurePosixPath->'PurePath' (len=8), Path->'PurePath' (len=8)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmro180

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_module,         PurePath.__module__.__eq__,                     ["pathlib"],  true, "pathlib.PurePath.__module__ == 'pathlib' — 'pathlib' has 7 characters; PurePath.__module__ == 'pathlib' (7) is shared by all four pathlib classes in this spec: Path, PurePath, PurePosixPath, PureWindowsPath all have __module__ == 'pathlib'; the uniform 7-character module name 'pathlib' is longer than Path.__name__ (4 chars) but shorter than PurePath.__name__ (8 chars); PurePath is defined in the public 'pathlib' module; confirmed Python 3.14.3 macOS"]
    - [purepath_mro1_name,      "PurePath.__mro__[1].__name__.__eq__",          ["object"],   true, "pathlib.PurePath.__mro__[1].__name__ == 'object' — PurePath inherits directly from object; PurePath.__mro__ == [PurePath, object], so mro[1] is object; 'object' has 6 characters; PurePath.__mro__[1] being object confirms PurePath has no intermediate base class: it is the root of the pathlib hierarchy and inherits directly from the Python root object; this is consistent with PurePath.__mro__.__len__() == 2 — a 2-entry MRO always has object at index 1; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_mro1_name, "PurePosixPath.__mro__[1].__name__.__eq__",     ["PurePath"],  true, "pathlib.PurePosixPath.__mro__[1].__name__ == 'PurePath' — PurePosixPath inherits directly from PurePath; PurePosixPath.__mro__ == [PurePosixPath, PurePath, object], so mro[1] is PurePath; 'PurePath' has 8 characters; PurePosixPath.__mro__[1] being PurePath confirms the single-level inheritance: PurePosixPath extends PurePath with POSIX-specific path semantics; confirmed Python 3.14.3 macOS"]
    - [path_mro1_name,          "Path.__mro__[1].__name__.__eq__",              ["PurePath"],  true, "pathlib.Path.__mro__[1].__name__ == 'PurePath' — Path inherits directly from PurePath; Path.__mro__ == [Path, PurePath, object], so mro[1] is PurePath; 'PurePath' has 8 characters; Path.__mro__[1] being PurePath confirms that on Python 3.12+, Path directly subclasses PurePath without an OS-specific intermediate class; Path (4 chars) and PurePosixPath (13 chars) both have mro[1].__name__ == 'PurePath' (8 chars): a two-way tie in the mro[1] name length even though the two classes themselves differ in name length; confirmed Python 3.14.3 macOS"]

