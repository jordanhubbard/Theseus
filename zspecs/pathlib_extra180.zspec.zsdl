# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra180.PurePath_mro_len_2:
  description: "pathlib.PurePath.__mro__.__len__() == 2 — MRO is [PurePath, object]; PurePath (2) is the minimum MRO length among the four pathlib classes in this spec; PurePath inherits directly from object with no intermediate base; PurePath (2) < PurePosixPath=PureWindowsPath=Path (3) by 1; the minimum-possible MRO length (2) for any class that doesn't explicitly inherit from another custom class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PurePath.__mro__.__len__
  args: []
  expected: 2

invariant pathlib_extra180.PurePosixPath_mro_len_3:
  description: "pathlib.PurePosixPath.__mro__.__len__() == 3 — MRO is [PurePosixPath, PurePath, object]; PurePosixPath (3) joins PureWindowsPath and Path in the three-way tie at 3; PurePosixPath (3) > PurePath (2) by 1: adding one direct base increases the MRO length by exactly 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PurePosixPath.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra180.PureWindowsPath_mro_len_3:
  description: "pathlib.PureWindowsPath.__mro__.__len__() == 3 — MRO is [PureWindowsPath, PurePath, object]; PureWindowsPath (3) == PurePosixPath (3) == Path (3): the three direct PurePath subclasses tie at MRO length 3; despite 'PureWindowsPath' (15 chars) being the longest name and PurePosixPath (13) being shorter and Path (4) being the shortest, all three have identical MRO length 3; name length and MRO length are independent properties; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PureWindowsPath.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra180.Path_mro_len_3:
  description: "pathlib.Path.__mro__.__len__() == 3 — MRO is [Path, PurePath, object]; Path (3) == PurePosixPath (3) == PureWindowsPath (3): a three-way tie at MRO length 3; Path has the shortest name (4 chars) but the same MRO depth (3) as the much longer-named PureWindowsPath (15 chars); Path inherits from PurePath and adds concrete filesystem I/O methods; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra180.PureWindowsPath_name_len_15:
  description: "pathlib.PureWindowsPath.__name__.__len__() == 15 — 'PureWindowsPath' is the longest class name among the four pathlib classes in this spec: Path (4) < PurePath (8) < PurePosixPath (13) < PureWindowsPath (15); PureWindowsPath (15) > PurePosixPath (13) by 2 because 'Windows' (7) > 'Posix' (5) by 2; the strict ascending name-length sequence Path (4) < PurePath (8) < PurePosixPath (13) < PureWindowsPath (15) has gaps of 4, 5, and 2 respectively; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PureWindowsPath.__name__.__len__
  args: []
  expected: 15

invariant pathlib_extra180.Path_name_len_4:
  description: "pathlib.Path.__name__.__len__() == 4 — 'Path' is the shortest class name among the four pathlib classes in this spec: Path (4) < PurePath (8) < PurePosixPath (13) < PureWindowsPath (15); 'Path' (4 chars) is the shared suffix of all four class names in this spec; Path.__module__ == 'pathlib' (7 chars) > Path.__name__ (4 chars) by 3 — the module name is longer than the class name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.__name__.__len__
  args: []
  expected: 4

