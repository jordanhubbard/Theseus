spec: shelve_extra7
version: ">=3.0"
backend: python_module(shelve)

docs: https://docs.python.org/3/library/shelve.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shelve.html — Python shelve module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shelve.py"
  notes:
    - "This spec extends shelve.zspec.zsdl through shelve_extra6.zspec.zsdl with new, non-duplicate invariants."
    - "shelve.zspec.zsdl covers: open/__name__; class names table; class modules table; Shelf/__bases__[0]/__name__; DbfilenameShelf/__bases__[0]/__name__."
    - "shelve_extra covers: Shelf/__name__/__module__; BsdDbShelf/__name__; DbfilenameShelf/__name__; open/__name__."
    - "shelve_extra2 covers: Shelf/__name__; BsdDbShelf/__name__; DbfilenameShelf/__name__; Shelf/__module__; Shelf.__bases__[0]; open/__name__/__module__."
    - "shelve_extra3 covers: BsdDbShelf/__module__; DbfilenameShelf/__module__; Shelf/__bases__/__len__; DbfilenameShelf/__bases__/__len__; open/__class__/__name__; class metatype table; BsdDbShelf/__bases__[0]/__name__."
    - "shelve_extra4 covers: __qualname__ for open, Shelf, BsdDbShelf, DbfilenameShelf."
    - "shelve_extra5 covers: Shelf method names (keys, values, items, sync, close); Shelf.__dict__.__class__.__name__."
    - "shelve_extra6 covers: Shelf.__mro__.__len__ >= 4; BsdDbShelf.__bases__.__len__ == 1; open.__doc__.__class__.__name__; Shelf.get.__name__."
    - "No prior spec covers: shelve.Shelf.__mro__[0].__name__ == 'Shelf' — MRO index 0."
    - "No prior spec covers: shelve.Shelf.__mro__[1].__name__ == 'MutableMapping' — MRO index 1."
    - "No prior spec covers: shelve.Shelf.__mro__[2].__name__ == 'Mapping' — MRO index 2."
    - "No prior spec covers: shelve.BsdDbShelf.__mro__[0].__name__ == 'BsdDbShelf' — BsdDbShelf MRO index 0."
    - "No prior spec covers: shelve.BsdDbShelf.__mro__[1].__name__ == 'Shelf' — BsdDbShelf MRO index 1."
    - "No prior spec covers: shelve.Shelf.update.__name__ == 'update' — inherited MutableMapping method."
    - "No prior spec covers: shelve.Shelf.setdefault.__name__ == 'setdefault' — inherited MutableMapping method."
    - "shelve.Shelf.__mro__[0..2]: [Shelf, MutableMapping, Mapping, ...] — confirmed on Python 3.12."
    - "shelve.BsdDbShelf.__mro__[0..1]: [BsdDbShelf, Shelf, ...] — BsdDbShelf inherits from Shelf directly."
    - "shelve.Shelf.update and setdefault are inherited from MutableMapping; distinct from keys/values/items/sync/close checked in extra5."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Shelf.__mro__ index checks — depth 0, 1, and 2
# shelve_extra6 checks Shelf.__mro__.__len__ >= 4 but does NOT check any
# individual index. All three depth checks are new invariants.
# Shelf.__mro__: [Shelf, MutableMapping, Mapping, Collection, Sized, Iterable, Container, object]
# ---------------------------------------------------------------------------

table shelve_extra7.Shelf_mro_indices:
  description: "Shelf.__mro__ depth checks: index 0=Shelf, 1=MutableMapping, 2=Mapping"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: smro7

  columns: [id, function, args, method, expected]
  rows:
    - [idx0, Shelf.__mro__.__getitem__, [0], __name__, "Shelf"]
    - [idx1, Shelf.__mro__.__getitem__, [1], __name__, "MutableMapping"]
    - [idx2, Shelf.__mro__.__getitem__, [2], __name__, "Mapping"]

# ---------------------------------------------------------------------------
# BsdDbShelf.__mro__ index checks — depth 0 and 1
# No prior shelve spec checks BsdDbShelf.__mro__[N] for any N.
# BsdDbShelf.__mro__: [BsdDbShelf, Shelf, MutableMapping, ...]
# Depth 0 and 1 are the most informative (class identity and direct parent).
# ---------------------------------------------------------------------------

table shelve_extra7.BsdDbShelf_mro_indices:
  description: "BsdDbShelf.__mro__ depth checks: index 0=BsdDbShelf, 1=Shelf"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: bmro7

  columns: [id, function, args, method, expected]
  rows:
    - [idx0, BsdDbShelf.__mro__.__getitem__, [0], __name__, "BsdDbShelf"]
    - [idx1, BsdDbShelf.__mro__.__getitem__, [1], __name__, "Shelf"]

# ---------------------------------------------------------------------------
# Shelf.update and Shelf.setdefault method names
# shelve_extra5 checks keys/values/items/sync/close.
# shelve_extra6 checks Shelf.get.__name__.
# update() and setdefault() are the remaining core MutableMapping methods
# inherited by Shelf that have not appeared in any prior shelve spec.
# ---------------------------------------------------------------------------

invariant shelve_extra7.Shelf.update_name:
  description: "shelve.Shelf.update.__name__ == 'update' — inherited MutableMapping batch-update method"
  category: method_names
  kind: python_call_eq
  function: Shelf.update.__name__.__eq__
  args: ["update"]
  expected: true

invariant shelve_extra7.Shelf.setdefault_name:
  description: "shelve.Shelf.setdefault.__name__ == 'setdefault' — inherited MutableMapping default-insert method"
  category: method_names
  kind: python_call_eq
  function: Shelf.setdefault.__name__.__eq__
  args: ["setdefault"]
  expected: true
