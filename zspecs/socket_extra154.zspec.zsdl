    - [timeout_name_TimeoutError,       "timeout.__name__.__eq__",                     ["TimeoutError"], true, "socket.timeout.__name__ == 'TimeoutError' (12 chars; socket.timeout IS TimeoutError alias; NOT 'timeout')"]
    - [timeout_module_builtins,         "timeout.__module__.__eq__",                   ["builtins"],     true, "socket.timeout.__module__ == 'builtins' (8 chars; TimeoutError is a built-in; NOT 'socket' unlike herror/gaierror)"]
    - [timeout_bases_OSError,           "timeout.__bases__[0].__name__.__eq__",        ["OSError"],      true, "socket.timeout.__bases__[0].__name__ == 'OSError' (TimeoutError inherits from OSError; PEP 3151 exception hierarchy)"]

