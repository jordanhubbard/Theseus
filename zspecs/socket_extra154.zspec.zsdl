table socket_extra154.exception_name_lengths_and_gaierror_confirmation:
  description: "socket.gaierror.__name__.__eq__('gaierror')==True / gaierror.__module__.__eq__('socket')==True / herror.__name__.__len__()==6 / timeout.__name__.__len__()==12 — gaierror.__name__ is 'gaierror' (8 chars; extra152 anchors this; confirmed alongside new invariants); gaierror.__module__ is 'socket' (6 chars; extra152 anchors); herror.__name__ 'herror' is 6 chars (shorter than gaierror by 2); timeout.__name__ 'TimeoutError' is 12 chars (longest exception name in socket module; 'TimeoutError' reflects the builtin alias); name length ordering: herror(6) < gaierror(8) < TimeoutError(12)"
  kind: python_call_eq
  category: identity
  id_prefix: sockexc154

  columns: [id, function, args, expected, description]
  rows:
    - [gaierror_name_gaierror,          "gaierror.__name__.__eq__",                    ["gaierror"], true, "socket.gaierror.__name__ == 'gaierror' (8 chars; lowercase; GetAddrInfo error; extra152 anchors; confirmed here)"]
    - [gaierror_module_socket,          "gaierror.__module__.__eq__",                  ["socket"],   true, "socket.gaierror.__module__ == 'socket' (6 chars; extra152 anchors; confirmed here alongside herror/timeout context)"]
