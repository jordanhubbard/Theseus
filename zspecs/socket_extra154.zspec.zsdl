table socket_extra154.socket_exception_bases_and_herror:
  description: "socket.error.__name__.__eq__('OSError')==True / gaierror.__bases__[0].__name__.__eq__('OSError')==True / herror.__name__.__eq__('herror')==True / herror.__module__.__eq__('socket')==True — socket.error IS OSError alias (__name__=='OSError', 7 chars; extra152 anchors this); gaierror.__bases__[0] is OSError (gaierror subclasses OSError; confirmed by __bases__[0].__name__=='OSError'); herror is proper subclass with __name__=='herror' (6 chars, lowercase) and __module__=='socket' (6 chars); first sockexc154 anchor for gaierror.__bases__ and herror identity"
  kind: python_call_eq
  category: identity
  id_prefix: sockexc154

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_OSError,              "error.__name__.__eq__",                       ["OSError"], true, "socket.error.__name__ == 'OSError' (7 chars; socket.error IS OSError alias; extra152 anchors this; confirmed here)"]
    - [gaierror_bases_OSError,          "gaierror.__bases__[0].__name__.__eq__",       ["OSError"], true, "socket.gaierror.__bases__[0].__name__ == 'OSError' (gaierror subclasses OSError; first __bases__ anchor for gaierror)"]
    - [herror_name_herror,              "herror.__name__.__eq__",                      ["herror"],  true, "socket.herror.__name__ == 'herror' (6 chars; lowercase; legacy gethostbyname() host errors; proper subclass of OSError)"]
    - [herror_module_socket,            "herror.__module__.__eq__",                    ["socket"],  true, "socket.herror.__module__ == 'socket' (6 chars; defined in socket module; contrasts with socket.timeout.__module__=='builtins')"]

