    - [timeout_name_len_12,             "timeout.__name__.__len__",                    [],           12,   "socket.timeout.__name__.__len__() is 12 ('TimeoutError' = 12 chars; reflects built-in class name, not 'timeout')"]

# ---------------------------------------------------------------------------
# socket.gaierror.__bases__[0].__name__.__eq__('OSError') — standalone
#
# socket.gaierror.__bases__[0].__name__ is 'OSError'. socket.gaierror is a proper
# subclass of OSError. Its MRO includes gaierror -> OSError -> Exception -> BaseException.
# This means code catching OSError will also catch socket.gaierror. 'gaierror' stands for
# GetAddrInfo error — it is raised by getaddrinfo() and related name resolution functions.
# The name 'gaierror' (8 chars, lowercase) follows the same naming convention as
# socket.herror (6 chars, lowercase). Both are proper subclasses of OSError, unlike
# socket.error which is a direct alias for OSError. extra152 anchors gaierror.__name__
# and gaierror.__module__; no prior socket spec anchors gaierror.__bases__[0].__name__
# as a standalone under sockexc154. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra154.gaierror_bases_OSError:
  description: "socket.gaierror.__bases__[0].__name__.__eq__('OSError') == True — gaierror is a proper subclass of OSError (not an alias like socket.error); MRO: gaierror->OSError->Exception->BaseException; catching OSError also catches gaierror; 'gaierror' name from POSIX getaddrinfo() (GAI=GetAddrInfo); extra152 anchors gaierror.__name__=='gaierror' and __module__=='socket'; no prior socket spec anchors gaierror.__bases__[0].__name__ as a standalone; first standalone under sockexc154"
  category: identity
  kind: python_call_eq
  function: "gaierror.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.herror.__bases__[0].__name__.__eq__('OSError') — standalone
#
# socket.herror.__bases__[0].__name__ is 'OSError'. socket.herror is the exception class
# for host resolution errors from legacy functions like gethostbyname() and
# gethostbyaddr(). Like gaierror, herror is a proper subclass of OSError. 'herror' (6
# chars, lowercase) stands for host error. It carries an h_errno value from the C library
# host resolution functions. herror is less commonly seen in modern Python code because
# getaddrinfo() (which raises gaierror) is preferred over gethostbyname() (which raises
# herror). herror.__bases__[0].__name__ == 'OSError' confirms that herror is in the OSError
# hierarchy. No prior socket spec anchors herror.__bases__[0].__name__ as a standalone.
# First standalone under sockexc154. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra154.herror_bases_OSError:
  description: "socket.herror.__bases__[0].__name__.__eq__('OSError') == True — herror is a proper subclass of OSError (MRO: herror->OSError->Exception->BaseException); 'herror' (6 chars) = host error from legacy gethostbyname()/gethostbyaddr(); carries h_errno value; parallel to gaierror (also a proper OSError subclass); both herror and gaierror have __module__=='socket' (contrast with socket.error/__module__=='builtins'); no prior socket spec anchors this as a standalone; first standalone under sockexc154"
  category: identity
  kind: python_call_eq
  function: "herror.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.timeout.__name__.__eq__('TimeoutError') — standalone
#
# socket.timeout.__name__ is 'TimeoutError' (12 chars). socket.timeout is an alias for
# the built-in TimeoutError (introduced with PEP 3151 in Python 3.3, which unified the
# OS exception hierarchy). socket.timeout IS TimeoutError — they are the same object.
# Therefore socket.timeout.__name__ returns 'TimeoutError' (the built-in class name),
# NOT 'timeout' (the attribute name on the socket module). This is analogous to
# socket.error IS OSError (extra152 anchors socket.error.__name__=='OSError'). socket.timeout
# is kept as an alias for backward compatibility with Python 2 code that caught
# socket.timeout for timeout-related socket errors. socket.timeout.__module__ == 'builtins'
# (8 chars) because TimeoutError is a built-in class. No prior socket spec anchors
# socket.timeout.__name__ as a standalone. First standalone under sockexc154.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra154.timeout_name_TimeoutError:
  description: "socket.timeout.__name__.__eq__('TimeoutError') == True — 12 chars; socket.timeout IS TimeoutError alias (same object, not subclass; parallel to socket.error IS OSError); __name__ returns 'TimeoutError' not 'timeout'; __module__=='builtins' (8 chars); PEP 3151 Python 3.3 unification; backward compat alias for Python 2 socket.timeout; extra152 anchors socket.error.__name__=='OSError' (parallel pattern); no prior socket spec anchors this as a standalone; first standalone under sockexc154"
  category: identity
  kind: python_call_eq
  function: timeout.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

