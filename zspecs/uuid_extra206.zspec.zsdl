spec: uuid_extra206
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 9562 — Universally Unique IDentifiers (UUID)"
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "verified with Python 3.14.3."
    - "uuid.UUID('not-a-valid-uuid') raises ValueError: badly formed hexadecimal UUID string."
    - "uuid.UUID(hex='abc123') raises ValueError: badly formed hexadecimal UUID string (too short)."
    - "uuid.UUID('12345678-1234-1234-1234-123456789abc', version=0) raises ValueError: illegal version number."
    - "uuid.UUID(hex='12345678123412341234123456789abc', bytes=b'a'*16) raises TypeError: one of the hex, bytes, bytes_le, fields, or int arguments must be given."
    - "uuid.uuid3('not a uuid', 'name') raises AttributeError: 'str' object has no attribute 'bytes'."
    - "All exception types verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID — raises ValueError for malformed positional string argument
#
# uuid.UUID('not-a-valid-uuid') raises ValueError
# ---------------------------------------------------------------------------

table uuid_extra206.UUID_bad_string_raises:
  description: "uuid.UUID raises ValueError for malformed UUID strings in uuiderr206 namespace — wave 206 theme: uuid.UUID('not-a-valid-uuid') raises ValueError; uuid.UUID constructor validates the canonical 8-4-4-4-12 format and all-hex content; any non-conforming string raises ValueError with 'badly formed hexadecimal UUID string'; verified with Python 3.14.3"
  kind: python_call_raises
  category: errors
  id_prefix: uuiderr206

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_invalid_string,  uuid.UUID, ["not-a-valid-uuid"],  ValueError, "uuid.UUID('not-a-valid-uuid') raises ValueError — badly formed hexadecimal UUID string"]
    - [UUID_empty_string,    uuid.UUID, [""],                  ValueError, "uuid.UUID('') raises ValueError — empty string is not a valid UUID"]

# ---------------------------------------------------------------------------
# uuid.UUID — raises ValueError for short hex kwarg and illegal version
# uuid.UUID — raises TypeError for conflicting constructor arguments
# uuid.uuid3 — raises AttributeError for non-UUID namespace
# ---------------------------------------------------------------------------

invariant uuid_extra206.UUID_short_hex_raises:
  description: "uuid.UUID(hex='abc123') raises ValueError — the hex argument must be exactly 32 hexadecimal characters (representing 128 bits); 'abc123' is only 6 characters; the uuid module reports 'badly formed hexadecimal UUID string'; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: uuid.UUID
  args: []
  kwargs:
    hex: "abc123"
  expected_exception: ValueError

invariant uuid_extra206.UUID_illegal_version_zero_raises:
  description: "uuid.UUID('12345678-1234-1234-1234-123456789abc', version=0) raises ValueError — UUID versions are defined as 1 through 5 by RFC 4122 and RFC 9562; version 0 is not a valid UUID version; the uuid module enforces this with 'illegal version number'; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: uuid.UUID
  args: ["12345678-1234-1234-1234-123456789abc"]
  kwargs:
    version: 0
  expected_exception: ValueError

invariant uuid_extra206.UUID_hex_and_bytes_raises:
  description: "uuid.UUID(hex='12345678123412341234123456789abc', bytes=b'aaaaaaaaaaaaaaaa') raises TypeError — only one of hex, bytes, bytes_le, fields, or int may be given; providing two mutually exclusive constructor arguments is rejected immediately; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: uuid.UUID
  args: []
  kwargs:
    hex: "12345678123412341234123456789abc"
    bytes: {type: bytes_hex, value: "61616161616161616161616161616161"}
  expected_exception: TypeError

invariant uuid_extra206.uuid3_non_uuid_namespace_raises:
  description: "uuid.uuid3('not a uuid', 'name') raises AttributeError — the namespace argument must be a uuid.UUID instance; uuid.uuid3 accesses namespace.bytes to extract the binary form of the namespace for MD5 hashing; passing a plain string causes AttributeError because str objects do not have a .bytes attribute; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: uuid.uuid3
  args: ["not a uuid", "name"]
  expected_exception: AttributeError

# ---------------------------------------------------------------------------
# uuid.UUID and uuid.uuid3 class/function identity checks
# ---------------------------------------------------------------------------

table uuid_extra206.uuid_class_identity:
  description: "uuid.UUID class name identity and uuid.uuid3 function name identity in uuiderr206a namespace — wave 206 theme: UUID.__name__ == 'UUID'; uuid3.__name__ == 'uuid3'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuiderr206a

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_class_name,   uuid.UUID.__name__.__eq__,   ["UUID"],   true, "uuid.UUID.__name__ == 'UUID' — class identity check"]
    - [uuid3_func_name,   uuid.uuid3.__name__.__eq__,  ["uuid3"],  true, "uuid.uuid3.__name__ == 'uuid3' — function identity check"]

