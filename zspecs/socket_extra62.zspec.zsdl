spec: socket_extra62
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra61.zspec.zsdl — covers socket.socket.accept/close/detach/makefile __annotations__.__class__.__name__.__eq__('dict') / __annotations__.__len__()==0 / getfqdn.__annotations__.__class__.__name__.__eq__('dict') / socket module __doc__.__class__.__name__.__eq__('str') / __doc__.__len__()==2021 / socket.socket.__doc__.__contains__('socket') / __contains__('makefile') (table + invariants)."
    - "socket_extra60.zspec.zsdl — covers socket.socket recv_into/recvfrom_into/getblocking/get_inheritable/set_inheritable __qualname__.__eq__ string values (table + invariants)."
    - "socket_extra59.zspec.zsdl — covers socket.__spec__.origin.__class__.__name__.__eq__('str') / submodule_search_locations.__class__.__name__.__eq__('NoneType') / has_location==True / __loader__.__class__.__name__.__len__()==16 (table + invariants)."
    - "socket_extra58.zspec.zsdl — covers socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "socket_extra50.zspec.zsdl — covers socket.socket.connect/bind/listen/accept/send/recv/close __qualname__.__eq__ string values."
    - "socket_extra49.zspec.zsdl — covers socket.gethostname/__doc__.__class__.__name__.__eq__('str') (type identity axis for gethostname docstring); no prior socket spec checks gethostname.__doc__.__contains__ for any keyword."
    - "socket_extra42.zspec.zsdl — covers socket.socket shutdown/sendall/recvfrom/sendto/connect_ex/dup/makefile/detach __qualname__.__eq__ string values."
    - "socket_extra22.zspec.zsdl — covers socket.socket connect/bind/listen/accept/close/recv/send __qualname__.__eq__ string values."
    - "socket_extra8.zspec.zsdl — covers gethostname/gethostbyname/getaddrinfo/getfqdn/create_connection __qualname__.__eq__ string values (module-level functions)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra61; it does NOT duplicate invariants present in those files."
    - "Wave 229 theme: __defaults__ and __code__ checks for Python functions + __doc__ content checks."
    - "socket.socket.accept is a Python function in Lib/socket.py with no default arguments — accept() takes only self. accept.__defaults__ is None (NoneType). socket_extra61 checks accept.__annotations__.__class__.__name__.__eq__('dict') (annotations axis); no prior socket spec checks accept.__defaults__.__class__.__name__.__eq__('NoneType'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile(mode='r', buffering=None, ...) has positional defaults — makefile.__defaults__ is ('r', None), a tuple. makefile.__defaults__.__class__.__name__ == 'tuple'. socket_extra61 checks makefile.__annotations__.__class__.__name__.__eq__('dict') (annotations axis); no prior socket spec checks makefile.__defaults__.__class__.__name__.__eq__('tuple'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__code__ and socket.socket.makefile.__code__ are Python code objects (type name 'code'). Both are pure Python functions in Lib/socket.py. socket_extra61 checks __annotations__ axes; no prior socket spec checks __code__.__class__.__name__.__eq__('code') for any socket.socket method. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__doc__ == 'gethostname() -> string\n\nReturn the current host name.' The word 'host' appears as part of 'hostname' in the signature line and 'host name' in the body. socket_extra49 checks gethostname.__doc__.__class__.__name__.__eq__('str') (type identity axis); no prior socket spec checks gethostname.__doc__.__contains__ for any keyword. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.accept and makefile __defaults__ class identity
#
# Wave 229 theme: __defaults__ checks for Python functions.
#
# socket.socket.accept() has no default arguments — __defaults__ is None
# (NoneType). socket.socket.makefile(mode='r', buffering=None, ...) has
# positional defaults — __defaults__ is a tuple.
#
# socket_extra61 checks the __annotations__ axis for both methods. No prior
# socket spec checks __defaults__.__class__.__name__ for any socket.socket
# method. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra62.socket_method_defaults_class_name:
  description: "socket.socket.accept.__defaults__.__class__.__name__.__eq__('NoneType') and makefile.__defaults__.__class__.__name__.__eq__('tuple') — accept has no default args so __defaults__ is None (NoneType); makefile(mode='r', buffering=None) has positional defaults so __defaults__ is a tuple; socket_extra61 checks __annotations__ axes; no prior socket spec checks __defaults__.__class__.__name__ for any socket.socket method; first __defaults__ class identity anchor for socket.socket"
  kind: python_call_eq
  category: defaults
  id_prefix: socketcode62

  columns: [id, function, args, expected]
  rows:
    - [accept_defaults_class_name_eq,   socket.accept.__defaults__.__class__.__name__.__eq__,   ["NoneType"], true]
    - [makefile_defaults_class_name_eq, socket.makefile.__defaults__.__class__.__name__.__eq__, ["tuple"],    true]

# ---------------------------------------------------------------------------
# socket.socket.accept and makefile __code__ class identity
#
# Wave 229 theme: __code__ checks for Python functions.
#
# socket.socket.accept and socket.socket.makefile are pure Python functions
# in Lib/socket.py. Both have a __code__ attribute that is a Python code
# object (type name 'code'). No prior socket spec checks
# __code__.__class__.__name__.__eq__('code') for any socket.socket method.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra62.socket_method_code_class_name:
  description: "socket.socket.accept.__code__.__class__.__name__.__eq__('code') and makefile.__code__.__class__.__name__.__eq__('code') — both are pure Python functions in Lib/socket.py with code objects; socket_extra61 checks __annotations__ axes; no prior socket spec checks __code__.__class__.__name__.__eq__('code') for any socket.socket method; first __code__ class identity anchor for socket.socket"
  kind: python_call_eq
  category: code_objects
  id_prefix: socketcode62

  columns: [id, function, args, expected]
  rows:
    - [accept_code_class_name_eq,   socket.accept.__code__.__class__.__name__.__eq__,   ["code"], true]
    - [makefile_code_class_name_eq, socket.makefile.__code__.__class__.__name__.__eq__, ["code"], true]

# ---------------------------------------------------------------------------
# socket.gethostname __doc__ content check
#
# Wave 229 theme: __doc__ content checks.
#
# socket.gethostname.__doc__ == 'gethostname() -> string\n\nReturn the current
# host name.' The word 'host' appears as part of 'hostname' in the signature
# line and as 'host name' in the description. socket_extra49 checks
# gethostname.__doc__.__class__.__name__.__eq__('str') (type identity axis);
# no prior socket spec checks gethostname.__doc__.__contains__ for any keyword.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra62.gethostname_doc_contains:
  description: "socket.gethostname.__doc__.__contains__('host') — C function docstring is 'gethostname() -> string\n\nReturn the current host name.'; 'host' appears in 'hostname' (signature) and 'host name' (body); socket_extra49 checks gethostname.__doc__.__class__.__name__.__eq__('str') (type identity axis); no prior socket spec checks gethostname.__doc__.__contains__ for any keyword; first doc content check for gethostname"
  kind: python_call_eq
  category: docstrings
  id_prefix: socketcode62

  columns: [id, function, args, expected]
  rows:
    - [gethostname_doc_contains_host, gethostname.__doc__.__contains__, ["host"], true]

# ---------------------------------------------------------------------------
# socket.socket.accept.__defaults__.__class__.__name__.__eq__('NoneType') — standalone
#
# socket.socket.accept() takes only self — no default arguments. Its
# __defaults__ is None (NoneType). The chain
# __defaults__.__class__.__name__.__eq__('NoneType') confirms the None type
# identity of the defaults object. socket_extra22/50 cover accept.__qualname__
# (qualname axis); socket_extra61 covers accept.__annotations__ (annotations
# axis). No prior socket spec checks accept.__defaults__ in any form. First
# __defaults__ class identity anchor for any socket.socket method. Verified
# Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra62.accept_defaults_class_name_nonetype:
  description: "socket.socket.accept.__defaults__.__class__.__name__.__eq__('NoneType') == True — accept() takes only self with no default arguments; __defaults__ is None so __class__.__name__ is 'NoneType'; socket_extra22/50 cover __qualname__ axis; socket_extra61 covers __annotations__ axis; no prior socket spec checks accept.__defaults__.__class__.__name__; first __defaults__ class identity anchor for any socket.socket method"
  category: defaults
  kind: python_call_eq
  function: socket.accept.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gethostname.__doc__.__contains__('host') — standalone
#
# socket.gethostname is a C function from socketmodule.c. Its docstring is
# 'gethostname() -> string\n\nReturn the current host name.' The word 'host'
# appears twice: in 'gethostname' (signature) and 'host name' (description).
# socket_extra49 checks gethostname.__doc__.__class__.__name__.__eq__('str')
# (type identity axis). No prior socket spec checks
# gethostname.__doc__.__contains__ for any keyword. First doc content anchor
# for gethostname. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra62.gethostname_doc_contains_host:
  description: "socket.gethostname.__doc__.__contains__('host') == True — C function docstring is 'gethostname() -> string\n\nReturn the current host name.'; 'host' appears in both the signature and description; socket_extra49 checks __doc__.__class__.__name__.__eq__('str') (type identity axis only); no prior socket spec checks gethostname.__doc__.__contains__ for any keyword; first doc content anchor for gethostname"
  category: docstrings
  kind: python_call_eq
  function: gethostname.__doc__.__contains__
  args: ["host"]
  expected: true
