spec: threading_extra118
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra117.zspec.zsdl."
    - "This spec covers: threading.RLock function and threading._RLock class attributes not yet covered — RLock.__name__ ('RLock', len 5), RLock.__module__ ('threading', len 9), RLock.__qualname__ ('RLock'), RLock.__class__.__name__ ('function'); _RLock.__name__ ('_RLock', len 6), _RLock.__module__ ('threading', len 9), _RLock.__bases__[0].__name__ ('object'), _RLock.__mro__.__len__ (2); threading._CRLock.__module__ ('_thread'); wave 268."
    - "threading.RLock is a Python function, not a class. threading.RLock().__class__.__name__ == 'RLock' (the C type _CRLock). Verified with Python 3.14.3."
    - "threading.RLock.__name__ == 'RLock'. Verified with Python 3.14.3."
    - "threading.RLock.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.RLock.__qualname__ == 'RLock'. Verified with Python 3.14.3."
    - "threading.RLock.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading._RLock.__name__ == '_RLock'. Verified with Python 3.14.3."
    - "threading._RLock.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading._RLock.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "threading._RLock.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "threading._CRLock.__module__ == '_thread'. Verified with Python 3.14.3."
    - "threading._CRLock.__name__ == 'RLock'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.RLock function attributes
#
# Wave 268 theme: threading.RLock is unusual — it is a Python *function*, not
# a class. The function checks if the C-accelerated _thread.RLock is available
# and returns either a _CRLock (C type) or a _RLock (pure-Python fallback)
# instance. RLock.__class__.__name__ is 'function'. RLock.__name__ is 'RLock'
# (5 chars). RLock.__module__ is 'threading' (9 chars). RLock.__qualname__ is
# 'RLock' (same as __name__ for a top-level function). Previously covered:
# none for RLock specifically. New here: __name__, __module__, __qualname__,
# __class__.__name__, __name__.__len__.
#
# RLock.__name__ == 'RLock'         (len 5)
# RLock.__module__ == 'threading'   (len 9)
# RLock.__class__.__name__ == 'function'
#
# New to extra118.
# ---------------------------------------------------------------------------

table threading_extra118.rlock_function_attrs:
  description: "threading.RLock is a Python function (not a class): __name__='RLock'(5), __module__='threading'(9), __qualname__='RLock', __class__.__name__='function'; factory that returns _CRLock or _RLock; wave 268; new to extra118"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingrlfa118

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_name,
       "RLock.__name__.__eq__",
       ["RLock"],
       true,
       "threading.RLock.__name__.__eq__('RLock') == True — threading.RLock is a Python function whose __name__ is 'RLock' (5 chars); it is a factory function, not a class; str.__eq__('RLock') returns True; new to extra118"]
    - [rlock_name_len,
       "RLock.__name__.__len__",
       [],
       5,
       "threading.RLock.__name__.__len__() == 5 — 'RLock' has 5 chars: R-L-o-c-k; the capital R distinguishes it from _RLock; str.__len__() returns 5; new to extra118"]
    - [rlock_module,
       "RLock.__module__.__eq__",
       ["threading"],
       true,
       "threading.RLock.__module__.__eq__('threading') == True — RLock is defined in Lib/threading.py; __module__ is 'threading' (9 chars); str.__eq__('threading') returns True; new to extra118"]
    - [rlock_qualname,
       "RLock.__qualname__.__eq__",
       ["RLock"],
       true,
       "threading.RLock.__qualname__.__eq__('RLock') == True — RLock is a top-level function; __qualname__ equals __name__ ('RLock', 5 chars); str.__eq__('RLock') returns True; new to extra118"]
    - [rlock_class_name,
       "RLock.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.RLock.__class__.__name__.__eq__('function') == True — RLock is a plain Python function, not a class or builtin; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra118"]

# ---------------------------------------------------------------------------
# Table 2: threading._RLock class attributes
#
# Wave 268 theme: threading._RLock is the pure-Python fallback implementation
# of a reentrant lock, used when the C-accelerated _thread.RLock is not
# available. Its __name__ is '_RLock' (6 chars, with leading underscore), its
# __module__ is 'threading' (9 chars), and it inherits directly from object.
# __mro__ has 2 entries: [_RLock, object]. This parallels threading.local
# (already covered: __name__ == '_local', mro len 2) but for the pure-Python
# lock class. Previously covered: none for _RLock specifically. New here:
# __name__, __module__, __bases__[0].__name__, __mro__.__len__, __name__.__len__.
#
# _RLock.__name__ == '_RLock'         (len 6)
# _RLock.__module__ == 'threading'    (len 9)
# _RLock.__bases__[0].__name__ == 'object'
# _RLock.__mro__.__len__() == 2
#
# New to extra118.
# ---------------------------------------------------------------------------

table threading_extra118.private_rlock_class_attrs:
  description: "threading._RLock (pure-Python fallback): __name__='_RLock'(6), __module__='threading'(9), __bases__[0]='object', __mro__ len=2; leading underscore marks private impl; wave 268; new to extra118"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingprlca118

  columns: [id, function, args, expected, description]
  rows:
    - [private_rlock_name,
       "_RLock.__name__.__eq__",
       ["_RLock"],
       true,
       "threading._RLock.__name__.__eq__('_RLock') == True — the pure-Python reentrant lock class has __name__ '_RLock' with a leading underscore indicating it is a private implementation detail; str.__eq__('_RLock') returns True; new to extra118"]
    - [private_rlock_name_len,
       "_RLock.__name__.__len__",
       [],
       6,
       "threading._RLock.__name__.__len__() == 6 — '_RLock' has 6 chars: _(1)+R-L-o-c-k(5); one char longer than RLock (5) due to the leading underscore; str.__len__() returns 6; new to extra118"]
    - [private_rlock_module,
       "_RLock.__module__.__eq__",
       ["threading"],
       true,
       "threading._RLock.__module__.__eq__('threading') == True — _RLock is defined in Lib/threading.py; __module__ is 'threading'; same as RLock.__module__; str.__eq__('threading') returns True; new to extra118"]
    - [private_rlock_bases0,
       "_RLock.__bases__.__getitem__",
       [0],
       "object",
       "threading._RLock.__bases__[0].__name__ == 'object' — _RLock inherits directly from object; no intermediate base class; tuple.__getitem__(0).__name__ returns 'object'; new to extra118"]
    - [private_rlock_mro_len,
       "_RLock.__mro__.__len__",
       [],
       2,
       "threading._RLock.__mro__.__len__() == 2 — the MRO is [_RLock, object]; direct single-inheritance from object; same MRO length as threading.local; tuple.__len__() returns 2; new to extra118"]

# ---------------------------------------------------------------------------
# Table 3: threading._CRLock (C-accelerated RLock) class attributes
#
# Wave 268 theme: threading._CRLock is the C-accelerated reentrant lock type
# from the _thread module. Its __name__ is 'RLock' (5 chars — same as the
# factory function name, without the underscore prefix). Its __module__ is
# '_thread' (7 chars). Its __qualname__ is 'RLock'. When threading.RLock()
# is called on a standard CPython installation, it returns an instance of
# _CRLock. The instance __class__.__name__ is 'RLock' and __class__.__module__
# is '_thread'. Previously covered: none for _CRLock specifically. New here:
# _CRLock.__name__, _CRLock.__module__, _CRLock.__qualname__, and the instance
# class attributes.
#
# _CRLock.__name__ == 'RLock'        (len 5)
# _CRLock.__module__ == '_thread'    (len 7)
# _CRLock.__qualname__ == 'RLock'
#
# New to extra118.
# ---------------------------------------------------------------------------

table threading_extra118.c_rlock_class_attrs:
  description: "threading._CRLock (C-accelerated _thread.RLock): __name__='RLock'(5), __module__='_thread'(7), __qualname__='RLock'; C type returned by threading.RLock() on CPython; wave 268; new to extra118"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingcrlca118

  columns: [id, function, args, expected, description]
  rows:
    - [c_rlock_name,
       "_CRLock.__name__.__eq__",
       ["RLock"],
       true,
       "threading._CRLock.__name__.__eq__('RLock') == True — the C-accelerated lock's __name__ is 'RLock' (5 chars); no leading underscore unlike _RLock; it is _thread.RLock re-exported; str.__eq__('RLock') returns True; new to extra118"]
    - [c_rlock_module,
       "_CRLock.__module__.__eq__",
       ["_thread"],
       true,
       "threading._CRLock.__module__.__eq__('_thread') == True — _CRLock is the _thread.RLock C extension type; __module__ is '_thread' (7 chars); different from _RLock.__module__ ('threading'); str.__eq__('_thread') returns True; new to extra118"]
    - [c_rlock_qualname,
       "_CRLock.__qualname__.__eq__",
       ["RLock"],
       true,
       "threading._CRLock.__qualname__.__eq__('RLock') == True — for a top-level C type __qualname__ equals __name__; both are 'RLock' (5 chars); str.__eq__('RLock') returns True; new to extra118"]
    - [c_rlock_module_len,
       "_CRLock.__module__.__len__",
       [],
       7,
       "threading._CRLock.__module__.__len__() == 7 — '_thread' has 7 chars: _(1)+t-h-r-e-a-d(6); same as threading.excepthook.__module__.__len__() (7); str.__len__() returns 7; new to extra118"]
    - [c_rlock_name_len,
       "_CRLock.__name__.__len__",
       [],
       5,
       "threading._CRLock.__name__.__len__() == 5 — 'RLock' has 5 chars: R-L-o-c-k; same as threading.RLock.__name__.__len__(); both refer to the same conceptual name; str.__len__() returns 5; new to extra118"]
    - [rlock_module_len,
       "RLock.__module__.__len__",
       [],
       9,
       "threading.RLock.__module__.__len__() == 9 — 'threading' has 9 chars: t-h-r-e-a-d-i-n-g; longer than _CRLock.__module__ '_thread' (7) and _RLock.__module__ 'threading' (9); str.__len__() returns 9; new to extra118"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra118
# ---------------------------------------------------------------------------

invariant threading_extra118.rlock_class_name:
  description: "threading.RLock.__class__.__name__ == 'function' — RLock is a Python factory function, not a class; wave 268; new to extra118"
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra118.rlock_module:
  description: "threading.RLock.__module__ == 'threading' — the factory function is defined in Lib/threading.py; length 9; wave 268; new to extra118"
  kind: python_call_eq
  function: RLock.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra118.private_rlock_name:
  description: "threading._RLock.__name__ == '_RLock' — pure-Python fallback reentrant lock; leading underscore; length 6; wave 268; new to extra118"
  kind: python_call_eq
  function: _RLock.__name__.__eq__
  args: ["_RLock"]
  expected: true

invariant threading_extra118.private_rlock_mro_len:
  description: "threading._RLock.__mro__.__len__() == 2 — direct inheritance from object; MRO is [_RLock, object]; same as local.__mro__.__len__(); wave 268; new to extra118"
  kind: python_call_eq
  function: _RLock.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra118.c_rlock_module:
  description: "threading._CRLock.__module__ == '_thread' — C-accelerated RLock is from the _thread extension; different module from _RLock ('threading'); wave 268; new to extra118"
  kind: python_call_eq
  function: _CRLock.__module__.__eq__
  args: ["_thread"]
  expected: true

