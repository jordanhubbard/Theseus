spec: docutils
version: ">=0.18"
backend: python_module(docutils)

docs: https://docutils.sourceforge.io/docs/

provenance:
  derived_from:
    - "docutils documentation — https://docutils.sourceforge.io/docs/"
    - "docutils API reference — https://docutils.sourceforge.io/docs/api/publisher.html"
    - "Test vectors verified with docutils 0.22.4 on Python 3.14 / macOS Darwin 25.4.0, 2026-04-05"
  not_derived_from:
    - "docutils source: docutils/__init__.py"
    - "docutils source: docutils/core.py"
    - "docutils source: docutils/nodes.py"
  notes:
    - "docutils.core and docutils.nodes are submodules; they are preloaded in verify_behavior.py."
    - "__version_info__ is a VersionInfo named tuple (subclass of tuple) with 6 fields."
    - "publish_string() returns bytes; function name is tested via the __name__ attribute."
    - "writer_name='pseudoxml' is a lightweight built-in writer, but kwargs not supported by harness."
    - "Invariants use dotted attribute paths resolved via iterative getattr in the harness."
  created_at: "2026-04-05T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version (category: version)
# ---------------------------------------------------------------------------

invariant docutils.version.contains_dot:
  description: "__version__ contains a dot (dotted version string such as '0.22.4')"
  category: version
  kind: python_call_eq
  function: "__version__.__contains__"
  args: ["."]
  expected: true

invariant docutils.version.major_ge_0:
  description: "__version_info__[0] is an integer >= 0: first element of version tuple"
  category: version
  kind: python_call_eq
  function: "__version_info__.__getitem__"
  args: [0]
  method: "__ge__"
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# version_info (category: version_info)
# ---------------------------------------------------------------------------

invariant docutils.version_info.length_is_6:
  description: "__version_info__ is a named tuple with 6 fields (major, minor, micro, releaselevel, serial, release)"
  category: version_info
  kind: python_call_eq
  function: "__version_info__.__len__"
  args: []
  expected: 6

invariant docutils.version_info.major_field_ge_0:
  description: "__version_info__.major >= 0"
  category: version_info
  kind: python_call_eq
  function: "__version_info__.major.__ge__"
  args: [0]
  expected: true

invariant docutils.version_info.minor_field_ge_0:
  description: "__version_info__.minor >= 0"
  category: version_info
  kind: python_call_eq
  function: "__version_info__.minor.__ge__"
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# core (category: core)
# docutils.core is preloaded in verify_behavior.py _SUBMODULE_PRELOADS.
# publish_string() is tested via its __name__ attribute (returns bytes so
# direct output comparison is not straightforward in the harness).
# ---------------------------------------------------------------------------

invariant docutils.core.publish_string_name:
  description: "core.publish_string.__name__ == 'publish_string'"
  category: core
  kind: python_call_eq
  function: "core.publish_string.__name__.__eq__"
  args: ["publish_string"]
  expected: true

# ---------------------------------------------------------------------------
# nodes (category: nodes)
# docutils.nodes is preloaded in verify_behavior.py _SUBMODULE_PRELOADS.
# Class __name__ attributes are accessed via dotted paths.
# ---------------------------------------------------------------------------

invariant docutils.nodes.text_classname:
  description: "nodes.Text.__name__ == 'Text'"
  category: nodes
  kind: python_call_eq
  function: "nodes.Text.__name__.__eq__"
  args: ["Text"]
  expected: true

invariant docutils.nodes.paragraph_classname:
  description: "nodes.paragraph.__name__ == 'paragraph'"
  category: nodes
  kind: python_call_eq
  function: "nodes.paragraph.__name__.__eq__"
  args: ["paragraph"]
  expected: true

invariant docutils.nodes.section_classname:
  description: "nodes.section.__name__ == 'section'"
  category: nodes
  kind: python_call_eq
  function: "nodes.section.__name__.__eq__"
  args: ["section"]
  expected: true

invariant docutils.nodes.title_classname:
  description: "nodes.title.__name__ == 'title'"
  category: nodes
  kind: python_call_eq
  function: "nodes.title.__name__.__eq__"
  args: ["title"]
  expected: true

invariant docutils.nodes.node_base_classname:
  description: "nodes.Node.__name__ == 'Node' — the base node class"
  category: nodes
  kind: python_call_eq
  function: "nodes.Node.__name__.__eq__"
  args: ["Node"]
  expected: true

invariant docutils.nodes.element_classname:
  description: "nodes.Element.__name__ == 'Element'"
  category: nodes
  kind: python_call_eq
  function: "nodes.Element.__name__.__eq__"
  args: ["Element"]
  expected: true

