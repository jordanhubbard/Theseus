spec: filecmp_extra6
version: ">=3.9"
backend: python_module(filecmp)

docs: https://docs.python.org/3/library/filecmp.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/filecmp.html — Python filecmp module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/filecmp.py"
  notes:
    - "This spec extends filecmp.zspec.zsdl and all prior filecmp_extra specs."
    - "filecmp_extra5 covers: __name__ length checks, __name__ is-str checks, __name__ first-character checks for cmp/cmpfiles/dircmp/clear_cache."
    - "This spec adds genuinely new axes: __name__ last-character checks for cmp/cmpfiles/dircmp/clear_cache; filecmp module __name__ attribute; BUFSIZE value and class; dircmp method __name__ lengths."
    - "filecmp.cmp.__name__ last char == 'p' ('cmp'[-1])."
    - "filecmp.cmpfiles.__name__ last char == 's' ('cmpfiles'[-1])."
    - "filecmp.dircmp.__name__ last char == 'p' ('dircmp'[-1])."
    - "filecmp.clear_cache.__name__ last char == 'e' ('clear_cache'[-1])."
    - "filecmp.__name__ == 'filecmp' — module's own __name__; not covered in any prior filecmp spec."
    - "filecmp.BUFSIZE == 8192 — the I/O buffer size constant; no prior spec verifies this exact value (extra3 covers DEFAULT_BUFSIZE minimum and class name; BUFSIZE is different from DEFAULT_BUFSIZE in some CPython versions)."
    - "filecmp.BUFSIZE.__class__.__name__ == 'int' — BUFSIZE is an integer constant."
    - "dircmp.report.__name__ len == 6 ('report'); dircmp.report_full_closure.__name__ len == 19; dircmp.report_partial_closure.__name__ len == 22."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# filecmp.__name__ — module-level attribute
# No prior filecmp spec verifies the module's own __name__ attribute.
# ---------------------------------------------------------------------------

invariant filecmp_extra6.module_name:
  description: "filecmp.__name__ == 'filecmp' — module's own __name__ attribute"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["filecmp"]
  expected: true

# ---------------------------------------------------------------------------
# __name__ last-character checks — cmp, cmpfiles, dircmp, clear_cache
# extra5 covers first-character; last-character is a distinct new axis.
# cmp -> 'p', cmpfiles -> 's', dircmp -> 'p', clear_cache -> 'e'.
# ---------------------------------------------------------------------------

table filecmp_extra6.name_last_char:
  description: "Last character of __name__ for cmp, cmpfiles, dircmp, and clear_cache"
  kind: python_call_eq
  category: name_suffix
  id_prefix: namelast

  columns: [id, function, args, expected]
  rows:
    - [cmp,         cmp.__name__.__getitem__(-1),         [], "p"]
    - [cmpfiles,    cmpfiles.__name__.__getitem__(-1),    [], "s"]
    - [dircmp,      dircmp.__name__.__getitem__(-1),      [], "p"]
    - [clear_cache, clear_cache.__name__.__getitem__(-1), [], "e"]

# ---------------------------------------------------------------------------
# BUFSIZE — value and class
# filecmp.BUFSIZE is the internal I/O buffer size (8192 bytes).
# No prior filecmp spec verifies BUFSIZE (extra3 covers DEFAULT_BUFSIZE,
# which is a different symbol that may or may not exist; BUFSIZE is always present).
# ---------------------------------------------------------------------------

invariant filecmp_extra6.BUFSIZE.value:
  description: "filecmp.BUFSIZE == 8192 — default I/O buffer size"
  category: constants
  kind: python_call_eq
  function: BUFSIZE.__eq__
  args: [8192]
  expected: true

invariant filecmp_extra6.BUFSIZE.class_is_int:
  description: "filecmp.BUFSIZE.__class__.__name__ == 'int' — BUFSIZE is an integer"
  category: constants
  kind: python_call_eq
  function: BUFSIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# DEFAULT_IGNORES exact length
# filecmp_extra verifies DEFAULT_IGNORES membership for individual VCS entries.
# filecmp_extra4 verifies minimum length >= 4.
# This spec verifies the exact length == 8 (the actual count in CPython 3.9+).
# DEFAULT_IGNORES = ['RCS', 'CVS', 'tags', '.git', '.hg', '.bzr', '_darcs', '__pycache__']
# ---------------------------------------------------------------------------

invariant filecmp_extra6.DEFAULT_IGNORES.exact_length:
  description: "filecmp.DEFAULT_IGNORES.__len__() == 8"
  category: constants
  kind: python_call_eq
  function: DEFAULT_IGNORES.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# dircmp method __name__ length checks
# filecmp.zspec.zsdl covers dircmp method __name__ via a table (equality).
# extra4 covers dircmp method __qualname__. No spec measures __name__ lengths.
# ---------------------------------------------------------------------------

table filecmp_extra6.dircmp_method_name_lengths:
  description: "dircmp method __name__ lengths"
  kind: python_call_eq
  category: dircmp_method_names
  id_prefix: dmethlen

  columns: [id, function, args, expected]
  rows:
    - [report,                dircmp.report.__name__.__len__,                [], 6]
    - [report_full_closure,   dircmp.report_full_closure.__name__.__len__,   [], 19]
    - [report_partial_closure, dircmp.report_partial_closure.__name__.__len__, [], 22]

# ---------------------------------------------------------------------------
# filecmp.__name__ length
# filecmp.__name__ == 'filecmp' (7 chars). The module-level attribute length
# is not covered in any prior filecmp spec.
# ---------------------------------------------------------------------------

invariant filecmp_extra6.module_name_length:
  description: "filecmp.__name__.__len__() == 7"
  category: module
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 7
