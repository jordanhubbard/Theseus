spec: hashlib_extra1396
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
  notes:
    - "Wave 540 (_extra1396): focuses on __class_getitem__ and __init_subclass__ method checks."
    - "hashlib.new('md5').__class__ is _hashlib.HASH — a C extension type. It does not define __class_getitem__ in its own __dict__ (Python 3.9+ generic alias support was not added to _hashlib.HASH), so HASH.__dict__.__contains__('__class_getitem__') returns False."
    - "object.__dict__ does NOT contain '__class_getitem__' on Python 3.14 — the generic alias protocol is opt-in and not present on object itself. Therefore no __class_getitem__ is inherited by HASH."
    - "HASH.__dict__.__contains__('__init_subclass__') returns False — HASH does not own __init_subclass__; it inherits it from object."
    - "When accessed as an attribute HASH.__init_subclass__, the classmethod_descriptor in object.__dict__ is bound through the descriptor protocol, yielding a 'builtin_function_or_method'."
    - "object.__dict__.__contains__('__init_subclass__') returns True — object is the owner of __init_subclass__."
    - "object.__dict__['__init_subclass__'].__class__.__name__ == 'classmethod_descriptor' — this is the raw unbound descriptor."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table hashlib_extra1396.hash_class_getitem_absent:
  description: "hashlib HASH class dict does not contain __class_getitem__ — _hashlib.HASH is a C extension type without generic-alias support; __dict__.__contains__ returns False for multiple hash algorithm instances"
  kind: python_call_eq
  category: class_getitem_checks
  id_prefix: hl1396cg
  columns: [id, function, args, expected]
  rows:
    - [hl1396cg001, hashlib.new("md5").__class__.__dict__.__contains__,     ["__class_getitem__"], false]
    - [hl1396cg002, hashlib.new("sha256").__class__.__dict__.__contains__,  ["__class_getitem__"], false]
    - [hl1396cg003, hashlib.new("sha512").__class__.__dict__.__contains__,  ["__class_getitem__"], false]
    - [hl1396cg004, hashlib.new("sha1").__class__.__dict__.__contains__,    ["__class_getitem__"], false]
    - [hl1396cg005, hashlib.new("sha3_256").__class__.__dict__.__contains__, ["__class_getitem__"], false]
    - [hl1396cg006, hashlib.new("blake2b").__class__.__dict__.__contains__, ["__class_getitem__"], false]

table hashlib_extra1396.hash_init_subclass_checks:
  description: "hashlib HASH class dict does not own __init_subclass__ (inherited from object); when accessed as an attribute the descriptor binds to a builtin_function_or_method; object itself owns __init_subclass__ as a classmethod_descriptor"
  kind: python_call_eq
  category: init_subclass_checks
  id_prefix: hl1396is
  columns: [id, function, args, expected]
  rows:
    - [hl1396is001, hashlib.new("md5").__class__.__dict__.__contains__,      ["__init_subclass__"], false]
    - [hl1396is002, hashlib.new("sha256").__class__.__dict__.__contains__,   ["__init_subclass__"], false]
    - [hl1396is003, hashlib.new("sha512").__class__.__dict__.__contains__,   ["__init_subclass__"], false]
    - [hl1396is004, hashlib.new("md5").__class__.__init_subclass__.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [hl1396is005, hashlib.new("sha256").__class__.__init_subclass__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl1396is006, object.__dict__.__contains__,                             ["__init_subclass__"], true]

table hashlib_extra1396.object_classmethod_descriptor_checks:
  description: "object.__dict__['__init_subclass__'] is a classmethod_descriptor; object does not contain __class_getitem__ in its __dict__; HASH class name and module confirm it is a C extension type"
  kind: python_call_eq
  category: class_getitem_checks
  id_prefix: hl1396od
  columns: [id, function, args, expected]
  rows:
    - [hl1396od001, object.__dict__.__contains__,                                            ["__class_getitem__"], false]
    - [hl1396od002, object.__dict__.__contains__,                                            ["__init_subclass__"], true]
    - [hl1396od003, hashlib.new("md5").__class__.__name__.__eq__,                           ["HASH"],              true]
    - [hl1396od004, hashlib.new("md5").__class__.__module__.__eq__,                         ["_hashlib"],          true]
    - [hl1396od005, hashlib.new("sha256").__class__.__dict__.__class__.__name__.__eq__,     ["mappingproxy"],      true]
    - [hl1396od006, hashlib.new("blake2b").__class__.__dict__.__class__.__name__.__eq__,    ["mappingproxy"],      true]
