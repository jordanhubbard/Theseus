spec: asyncio_extra706
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers Task, Future, Handle, TimerHandle, and BaseEventLoop class identity attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra706.task_and_future_identity:
  description: "Identity checks for asyncio Task and Future class qualnames and modules"
  kind: python_call_eq
  category: class_identity
  id_prefix: as706tf
  columns: [id, function, args, expected]
  rows:
    - [as706tf001, asyncio.Task.__qualname__.__eq__, ["Task"], true]
    - [as706tf002, asyncio.Task.__module__.__eq__, ["asyncio.tasks"], true]
    - [as706tf003, asyncio.Task.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [as706tf004, asyncio.Future.__qualname__.__eq__, ["Future"], true]
    - [as706tf005, asyncio.Future.__module__.__eq__, ["asyncio.futures"], true]
    - [as706tf006, asyncio.Future.__doc__.__class__.__name__.__eq__, ["str"], true]

