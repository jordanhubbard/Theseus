spec: cgitb
version: ">=3.9,<3.13"
backend: python_module(cgitb)

docs: https://docs.python.org/3/library/cgitb.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cgitb.html — Python cgitb module documentation"
    - "Test vectors verified by running Python 3.12.9 cgitb module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/cgitb.py"
  notes:
    - "The cgitb module was deprecated in Python 3.11 and removed in Python 3.13."
    - "This spec applies to Python >=3.9,<3.13 only."
    - "cgitb installs a custom exception handler that formats tracebacks as HTML or plain text for CGI scripts."
    - "cgitb.enable() replaces sys.excepthook with the Hook class handler."
    - "cgitb.reset() and cgitb.handler() are module-level utility functions."
    - "cgitb.text() and cgitb.html() format a (type, value, traceback) tuple as plain text or HTML."
    - "cgitb.lookup() extracts local variable information from a traceback frame."
    - "cgitb does not define a public 'disable' function; sys.excepthook must be restored manually."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# class names
# ---------------------------------------------------------------------------

invariant cgitb.Hook.name:
  description: "Hook.__name__ == 'Hook'"
  category: classes
  kind: python_call_eq
  function: Hook.__name__.__eq__
  args: ["Hook"]
  expected: true

invariant cgitb.Hook.module:
  description: "Hook.__module__ == 'cgitb'"
  category: classes
  kind: python_call_eq
  function: Hook.__module__.__eq__
  args: ["cgitb"]
  expected: true

# ---------------------------------------------------------------------------
# function names
# ---------------------------------------------------------------------------

invariant cgitb.enable.name:
  description: "cgitb.enable.__name__ == 'enable'"
  category: functions
  kind: python_call_eq
  function: enable.__name__.__eq__
  args: ["enable"]
  expected: true

invariant cgitb.reset.name:
  description: "cgitb.reset.__name__ == 'reset'"
  category: functions
  kind: python_call_eq
  function: reset.__name__.__eq__
  args: ["reset"]
  expected: true

invariant cgitb.handler.name:
  description: "cgitb.handler.__name__ == 'handler'"
  category: functions
  kind: python_call_eq
  function: handler.__name__.__eq__
  args: ["handler"]
  expected: true

invariant cgitb.text.name:
  description: "cgitb.text.__name__ == 'text'"
  category: functions
  kind: python_call_eq
  function: text.__name__.__eq__
  args: ["text"]
  expected: true

invariant cgitb.html.name:
  description: "cgitb.html.__name__ == 'html'"
  category: functions
  kind: python_call_eq
  function: html.__name__.__eq__
  args: ["html"]
  expected: true

invariant cgitb.lookup.name:
  description: "cgitb.lookup.__name__ == 'lookup'"
  category: functions
  kind: python_call_eq
  function: lookup.__name__.__eq__
  args: ["lookup"]
  expected: true

# ---------------------------------------------------------------------------
# Hook instantiation — keyword arguments only; display defaults
# ---------------------------------------------------------------------------

invariant cgitb.Hook.file_attr:
  description: "Hook(display=0).file is None — file defaults to None when display=0"
  category: hook_instance
  kind: python_call_eq
  function: Hook
  kwargs: {display: 0}
  method: file
  expected: ~

invariant cgitb.Hook.format_attr_html:
  description: "Hook(format='html').format == 'html' — format attribute reflects constructor arg"
  category: hook_instance
  kind: python_call_eq
  function: Hook
  kwargs: {format: "html"}
  method: format
  expected: "html"

invariant cgitb.Hook.format_attr_text:
  description: "Hook(format='text').format == 'text' — text format is also supported"
  category: hook_instance
  kind: python_call_eq
  function: Hook
  kwargs: {format: "text"}
  method: format
  expected: "text"
