    - ["cf3541002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__format__"], false]
    - ["cf3541003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__format__"], false]

