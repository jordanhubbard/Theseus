spec: pathlib_extra294
version: ">=3.9"
backend: python_module(pathlib)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Path method identity for I/O and filesystem operations"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib.py, Lib/pathlib/_local.py"
  notes:
    - "All qualnames verified against live Python 3.14 runtime"
    - "hardlink_to and readlink added in Python 3.10"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table pathlib_extra294.path_io_qualnames:
  description: "Path I/O and filesystem operation method __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: plio294

  columns: [id, function, args, expected, description]
  rows:
    - [plio294_001, pathlib.Path.read_bytes.__qualname__.__eq__, ["Path.read_bytes"], true, "Path.read_bytes qualname"]
    - [plio294_002, pathlib.Path.write_bytes.__qualname__.__eq__, ["Path.write_bytes"], true, "Path.write_bytes qualname"]
    - [plio294_003, pathlib.Path.touch.__qualname__.__eq__, ["Path.touch"], true, "Path.touch qualname"]
    - [plio294_004, pathlib.Path.rmdir.__qualname__.__eq__, ["Path.rmdir"], true, "Path.rmdir qualname"]
    - [plio294_005, pathlib.Path.lstat.__qualname__.__eq__, ["Path.lstat"], true, "Path.lstat qualname"]
    - [plio294_006, pathlib.Path.stat.__qualname__.__eq__, ["Path.stat"], true, "Path.stat qualname"]
    - [plio294_007, pathlib.Path.resolve.__qualname__.__eq__, ["Path.resolve"], true, "Path.resolve qualname"]
    - [plio294_008, pathlib.Path.absolute.__qualname__.__eq__, ["Path.absolute"], true, "Path.absolute qualname"]
    - [plio294_009, pathlib.Path.expanduser.__qualname__.__eq__, ["Path.expanduser"], true, "Path.expanduser qualname"]

table pathlib_extra294.path_link_check_qualnames:
  description: "Path link and predicate method __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: pllk294

  columns: [id, function, args, expected, description]
  rows:
    - [pllk294_001, pathlib.Path.hardlink_to.__qualname__.__eq__, ["Path.hardlink_to"], true, "Path.hardlink_to qualname"]
    - [pllk294_002, pathlib.Path.readlink.__qualname__.__eq__, ["Path.readlink"], true, "Path.readlink qualname"]
    - [pllk294_003, pathlib.Path.samefile.__qualname__.__eq__, ["Path.samefile"], true, "Path.samefile qualname"]
    - [pllk294_004, pathlib.Path.is_symlink.__qualname__.__eq__, ["Path.is_symlink"], true, "Path.is_symlink qualname"]
    - [pllk294_005, pathlib.Path.is_mount.__qualname__.__eq__, ["Path.is_mount"], true, "Path.is_mount qualname"]
    - [pllk294_006, pathlib.Path.is_block_device.__qualname__.__eq__, ["Path.is_block_device"], true, "Path.is_block_device qualname"]
    - [pllk294_007, pathlib.Path.is_char_device.__qualname__.__eq__, ["Path.is_char_device"], true, "Path.is_char_device qualname"]
    - [pllk294_008, pathlib.Path.is_fifo.__qualname__.__eq__, ["Path.is_fifo"], true, "Path.is_fifo qualname"]
    - [pllk294_009, pathlib.Path.is_socket.__qualname__.__eq__, ["Path.is_socket"], true, "Path.is_socket qualname"]

invariant pathlib_extra294.read_bytes_qualname_confirmed:
  description: "Path.read_bytes qualname confirmed as standalone invariant"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.read_bytes.__qualname__.__eq__
  args: ["Path.read_bytes"]
  expected: true

invariant pathlib_extra294.is_symlink_qualname_confirmed:
  description: "Path.is_symlink qualname confirmed as standalone invariant"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.is_symlink.__qualname__.__eq__
  args: ["Path.is_symlink"]
  expected: true
