spec: decimal_extra2551
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2551 (_extra2551): __reduce__, __reduce_ex__, __getnewargs__ dict-presence checks for decimal classes."
    - "decimal.Decimal defines __reduce__ and __copy__/__deepcopy__ in its class dict, but NOT __reduce_ex__ or __getnewargs__."
    - "decimal.Context defines __reduce__ and __copy__ in its class dict, but NOT __reduce_ex__, __getnewargs__, or __deepcopy__."
    - "decimal exception subclasses (DecimalException, InvalidOperation, Overflow, etc.) define none of these methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

table decimal_extra2551.reduce_protocol:
  description: "decimal.Decimal and decimal.Context __reduce__ dict-presence — both True; exception classes False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2551

  columns: [id, function, args, expected]
  rows:
    - ["dc2551001", "decimal.Decimal.__dict__.__contains__",          ["__reduce__"], true]
    - ["dc2551002", "decimal.Context.__dict__.__contains__",          ["__reduce__"], true]
    - ["dc2551003", "decimal.DecimalException.__dict__.__contains__", ["__reduce__"], false]
    - ["dc2551004", "decimal.InvalidOperation.__dict__.__contains__", ["__reduce__"], false]
    - ["dc2551005", "decimal.Overflow.__dict__.__contains__",         ["__reduce__"], false]
    - ["dc2551006", "decimal.Underflow.__dict__.__contains__",        ["__reduce__"], false]
    - ["dc2551007", "decimal.DivisionByZero.__dict__.__contains__",   ["__reduce__"], false]
    - ["dc2551008", "decimal.Inexact.__dict__.__contains__",          ["__reduce__"], false]

table decimal_extra2551.reduce_ex_protocol:
  description: "decimal classes __reduce_ex__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2551x

  columns: [id, function, args, expected]
  rows:
    - ["dc2551x001", "decimal.Decimal.__dict__.__contains__",          ["__reduce_ex__"], false]
    - ["dc2551x002", "decimal.Context.__dict__.__contains__",          ["__reduce_ex__"], false]
    - ["dc2551x003", "decimal.DecimalException.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["dc2551x004", "decimal.InvalidOperation.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["dc2551x005", "decimal.Overflow.__dict__.__contains__",         ["__reduce_ex__"], false]

table decimal_extra2551.getnewargs_protocol:
  description: "decimal classes __getnewargs__ and __getnewargs_ex__ dict-presence — all False; __copy__/__deepcopy__ on Decimal and Context"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2551g

  columns: [id, function, args, expected]
  rows:
    - ["dc2551g001", "decimal.Decimal.__dict__.__contains__",          ["__getnewargs__"],    false]
    - ["dc2551g002", "decimal.Context.__dict__.__contains__",          ["__getnewargs__"],    false]
    - ["dc2551g003", "decimal.DecimalException.__dict__.__contains__", ["__getnewargs__"],    false]
    - ["dc2551g004", "decimal.Decimal.__dict__.__contains__",          ["__getnewargs_ex__"], false]
    - ["dc2551g005", "decimal.Context.__dict__.__contains__",          ["__getnewargs_ex__"], false]
    - ["dc2551g006", "decimal.Decimal.__dict__.__contains__",          ["__copy__"],          true]
    - ["dc2551g007", "decimal.Decimal.__dict__.__contains__",          ["__deepcopy__"],      true]
    - ["dc2551g008", "decimal.Context.__dict__.__contains__",          ["__copy__"],          true]
    - ["dc2551g009", "decimal.Context.__dict__.__contains__",          ["__deepcopy__"],      false]
    - ["dc2551g010", "decimal.DecimalException.__dict__.__contains__", ["__copy__"],          false]
    - ["dc2551g011", "decimal.InvalidOperation.__dict__.__contains__", ["__copy__"],          false]
    - ["dc2551g012", "decimal.Decimal.__dict__.__contains__",          ["__getstate__"],      false]
    - ["dc2551g013", "decimal.Context.__dict__.__contains__",          ["__getstate__"],      false]
    - ["dc2551g014", "decimal.Decimal.__dict__.__contains__",          ["__setstate__"],      false]
    - ["dc2551g015", "decimal.Context.__dict__.__contains__",          ["__setstate__"],      false]
