spec: asyncio_extra233
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "asyncio.Semaphore.acquire.__name__ == 'acquire' — 7 characters; qualname is 'Semaphore.acquire'; verified with Python 3.14.3."
    - "asyncio.Semaphore.release.__name__ == 'release' — 7 characters; qualname is 'Semaphore.release'; verified with Python 3.14.3."
    - "asyncio.Semaphore.locked.__name__ == 'locked' — 6 characters; qualname is 'Semaphore.locked'; verified with Python 3.14.3."
    - "asyncio.BoundedSemaphore.release.__name__ == 'release'; qualname is 'BoundedSemaphore.release' — BoundedSemaphore overrides release; verified with Python 3.14.3."
    - "asyncio.BoundedSemaphore.acquire.__qualname__ == 'Semaphore.acquire' — acquire is inherited from Semaphore; verified with Python 3.14.3."
    - "asyncio.BoundedSemaphore.locked.__qualname__ == 'Semaphore.locked' — locked is inherited from Semaphore; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Semaphore method name and qualname contracts — extra233 namespace
#
# Semaphore.acquire, release, locked all have qualnames with 'Semaphore.' prefix.
# acquire and release are both 7 characters; locked is 6 characters.
# ---------------------------------------------------------------------------

table asyncio_extra233.semaphore_method_names:
  description: "asyncio.Semaphore method __name__ and __qualname__ contracts in aio233smn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio233smn

  columns: [id, function, args, expected, description]
  rows:
    - [sem_acquire_name_eq,      Semaphore.acquire.__name__.__eq__,          ["acquire"],             true, "asyncio.Semaphore.acquire.__name__ == 'acquire'; verified with Python 3.14.3"]
    - [sem_acquire_name_len_7,   Semaphore.acquire.__name__.__len__,         [],                      7,    "asyncio.Semaphore.acquire.__name__.__len__() == 7 — 'acquire' has 7 characters; verified with Python 3.14.3"]
    - [sem_acquire_qualname_eq,  Semaphore.acquire.__qualname__.__eq__,      ["Semaphore.acquire"],   true, "asyncio.Semaphore.acquire.__qualname__ == 'Semaphore.acquire'; verified with Python 3.14.3"]
    - [sem_release_name_eq,      Semaphore.release.__name__.__eq__,          ["release"],             true, "asyncio.Semaphore.release.__name__ == 'release'; verified with Python 3.14.3"]
    - [sem_release_name_len_7,   Semaphore.release.__name__.__len__,         [],                      7,    "asyncio.Semaphore.release.__name__.__len__() == 7 — 'release' has 7 characters; verified with Python 3.14.3"]
    - [sem_release_qualname_eq,  Semaphore.release.__qualname__.__eq__,      ["Semaphore.release"],   true, "asyncio.Semaphore.release.__qualname__ == 'Semaphore.release'; verified with Python 3.14.3"]
    - [sem_locked_name_eq,       Semaphore.locked.__name__.__eq__,           ["locked"],              true, "asyncio.Semaphore.locked.__name__ == 'locked'; verified with Python 3.14.3"]
    - [sem_locked_name_len_6,    Semaphore.locked.__name__.__len__,          [],                      6,    "asyncio.Semaphore.locked.__name__.__len__() == 6 — 'locked' has 6 characters; verified with Python 3.14.3"]
    - [sem_locked_qualname_eq,   Semaphore.locked.__qualname__.__eq__,       ["Semaphore.locked"],    true, "asyncio.Semaphore.locked.__qualname__ == 'Semaphore.locked'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.BoundedSemaphore method name and qualname contracts — extra233 namespace
#
# BoundedSemaphore overrides release (qualname 'BoundedSemaphore.release').
# BoundedSemaphore inherits acquire from Semaphore (qualname 'Semaphore.acquire').
# BoundedSemaphore inherits locked from Semaphore (qualname 'Semaphore.locked').
# ---------------------------------------------------------------------------

table asyncio_extra233.boundedsemaphore_method_names:
  description: "asyncio.BoundedSemaphore method __name__ and __qualname__ contracts in aio233bsmn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio233bsmn

  columns: [id, function, args, expected, description]
  rows:
    - [bsem_release_name_eq,     BoundedSemaphore.release.__name__.__eq__,      ["release"],                   true, "asyncio.BoundedSemaphore.release.__name__ == 'release'; verified with Python 3.14.3"]
    - [bsem_release_qualname_eq, BoundedSemaphore.release.__qualname__.__eq__,  ["BoundedSemaphore.release"],  true, "asyncio.BoundedSemaphore.release.__qualname__ == 'BoundedSemaphore.release' — overrides Semaphore; verified with Python 3.14.3"]
    - [bsem_acquire_name_eq,     BoundedSemaphore.acquire.__name__.__eq__,      ["acquire"],                   true, "asyncio.BoundedSemaphore.acquire.__name__ == 'acquire' — inherited from Semaphore; verified with Python 3.14.3"]
    - [bsem_acquire_qualname_eq, BoundedSemaphore.acquire.__qualname__.__eq__,  ["Semaphore.acquire"],         true, "asyncio.BoundedSemaphore.acquire.__qualname__ == 'Semaphore.acquire' — inherited, not overridden; verified with Python 3.14.3"]
    - [bsem_locked_name_eq,      BoundedSemaphore.locked.__name__.__eq__,       ["locked"],                    true, "asyncio.BoundedSemaphore.locked.__name__ == 'locked' — inherited from Semaphore; verified with Python 3.14.3"]
    - [bsem_locked_qualname_eq,  BoundedSemaphore.locked.__qualname__.__eq__,   ["Semaphore.locked"],          true, "asyncio.BoundedSemaphore.locked.__qualname__ == 'Semaphore.locked' — inherited, not overridden; verified with Python 3.14.3"]
