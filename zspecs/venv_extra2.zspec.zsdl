spec: venv_extra2
version: ">=3.9"
backend: python_module(venv)

docs: https://docs.python.org/3/library/venv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/venv.html — Python venv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/venv/__init__.py"
  notes:
    - "This spec covers invariants not in venv.zspec.zsdl or venv_extra.zspec.zsdl."
    - "EnvBuilder.create.__name__ == 'create' — method identity confirmed by __name__."
    - "EnvBuilder.setup_scripts.__name__ == 'setup_scripts' — copies activation scripts."
    - "EnvBuilder.setup_python.__name__ == 'setup_python' — installs the Python binary into the venv."
    - "EnvBuilder.post_setup.__name__ == 'post_setup' — hook for subclasses; default is a no-op."
    - "EnvBuilder.install_scripts.__name__ == 'install_scripts' — installs shell activation scripts."
    - "EnvBuilder.clear_directory.__name__ == 'clear_directory' — removes all content from a directory."
    - "EnvBuilder.__init__.__module__ == 'venv' — __init__ is defined in the venv module."
    - "All method objects are plain Python functions: __class__.__name__ == 'function'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# EnvBuilder.create — method __name__
# ---------------------------------------------------------------------------

invariant venv_extra2.EnvBuilder.create_name:
  description: "EnvBuilder.create.__name__ == 'create'"
  category: methods
  kind: python_call_eq
  function: EnvBuilder.create.__name__.__eq__
  args: ["create"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder.setup_scripts — method __name__
# ---------------------------------------------------------------------------

invariant venv_extra2.EnvBuilder.setup_scripts_name:
  description: "EnvBuilder.setup_scripts.__name__ == 'setup_scripts'"
  category: methods
  kind: python_call_eq
  function: EnvBuilder.setup_scripts.__name__.__eq__
  args: ["setup_scripts"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder.setup_python — method __name__
# ---------------------------------------------------------------------------

invariant venv_extra2.EnvBuilder.setup_python_name:
  description: "EnvBuilder.setup_python.__name__ == 'setup_python'"
  category: methods
  kind: python_call_eq
  function: EnvBuilder.setup_python.__name__.__eq__
  args: ["setup_python"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder.post_setup — method __name__
# ---------------------------------------------------------------------------

invariant venv_extra2.EnvBuilder.post_setup_name:
  description: "EnvBuilder.post_setup.__name__ == 'post_setup'"
  category: methods
  kind: python_call_eq
  function: EnvBuilder.post_setup.__name__.__eq__
  args: ["post_setup"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder.install_scripts — method __name__
# ---------------------------------------------------------------------------

invariant venv_extra2.EnvBuilder.install_scripts_name:
  description: "EnvBuilder.install_scripts.__name__ == 'install_scripts'"
  category: methods
  kind: python_call_eq
  function: EnvBuilder.install_scripts.__name__.__eq__
  args: ["install_scripts"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder.clear_directory — method __name__
# ---------------------------------------------------------------------------

invariant venv_extra2.EnvBuilder.clear_directory_name:
  description: "EnvBuilder.clear_directory.__name__ == 'clear_directory'"
  category: methods
  kind: python_call_eq
  function: EnvBuilder.clear_directory.__name__.__eq__
  args: ["clear_directory"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder.__init__ — module affiliation
# ---------------------------------------------------------------------------

invariant venv_extra2.EnvBuilder.init_module:
  description: "EnvBuilder.__init__.__module__ == 'venv'"
  category: module
  kind: python_call_eq
  function: EnvBuilder.__init__.__module__.__eq__
  args: ["venv"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder methods — type check: all are plain Python functions
# ---------------------------------------------------------------------------

table venv_extra2.EnvBuilder.method_types:
  kind: python_call_eq
  category: method_types
  id_prefix: type

  columns: [id, function, args, expected]
  rows:
    - [create_type,          EnvBuilder.create.__class__.__name__.__eq__,          ["function"], true]
    - [setup_scripts_type,   EnvBuilder.setup_scripts.__class__.__name__.__eq__,   ["function"], true]
    - [setup_python_type,    EnvBuilder.setup_python.__class__.__name__.__eq__,    ["function"], true]
    - [post_setup_type,      EnvBuilder.post_setup.__class__.__name__.__eq__,      ["function"], true]
    - [install_scripts_type, EnvBuilder.install_scripts.__class__.__name__.__eq__, ["function"], true]
    - [clear_directory_type, EnvBuilder.clear_directory.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# EnvBuilder methods — __qualname__ checks (dotted: ClassName.method_name)
# ---------------------------------------------------------------------------

table venv_extra2.EnvBuilder.method_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [create,          EnvBuilder.create.__qualname__.__eq__,          ["EnvBuilder.create"],          true]
    - [setup_scripts,   EnvBuilder.setup_scripts.__qualname__.__eq__,   ["EnvBuilder.setup_scripts"],   true]
    - [setup_python,    EnvBuilder.setup_python.__qualname__.__eq__,    ["EnvBuilder.setup_python"],    true]
    - [post_setup,      EnvBuilder.post_setup.__qualname__.__eq__,      ["EnvBuilder.post_setup"],      true]
    - [install_scripts, EnvBuilder.install_scripts.__qualname__.__eq__, ["EnvBuilder.install_scripts"], true]
