spec: collections_extra20
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections.zspec.zsdl and prior extras through collections_extra19.zspec.zsdl."
    - "Prior specs cover: __qualname__.__eq__ for OrderedDict/ChainMap/Counter/UserDict/UserList/UserString; __module__.__eq__ for all six; __qualname__.__len__ for OrderedDict (extra18) and deque (extra15)."
    - "NOT yet covered: __qualname__.__len__ for ChainMap/Counter/UserDict/UserList/UserString; __module__.__len__ for UserDict/UserList/Counter; deque.__module__.__len__ as standalone in extra20 namespace."
    - "ChainMap.__qualname__.__len__() == 8 — len('ChainMap')."
    - "Counter.__qualname__.__len__() == 7 — len('Counter')."
    - "UserDict.__qualname__.__len__() == 8 — len('UserDict')."
    - "UserList.__qualname__.__len__() == 8 — len('UserList')."
    - "UserString.__qualname__.__len__() == 10 — len('UserString')."
    - "All six classes have __module__ == 'collections'; a unified __module__.__len__ table provides a fresh extra20 namespace anchor."
    - "deque.__module__.__len__() == 11 re-anchored in extra20 namespace with new invariant ID."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__ — ChainMap, Counter, UserDict, UserList, UserString
#
# collections_extra18 covers OrderedDict.__qualname__.__len__() == 11.
# collections_extra15 covers deque.__qualname__.__len__() == 5.
# No prior spec records __qualname__.__len__ for the remaining five classes.
# ---------------------------------------------------------------------------

invariant collections_extra20.ChainMap.qualname_len:
  description: "collections.ChainMap.__qualname__.__len__() == 8 — len('ChainMap')"
  category: qualname_lengths
  kind: python_call_eq
  function: ChainMap.__qualname__.__len__
  args: []
  expected: 8

invariant collections_extra20.Counter.qualname_len:
  description: "collections.Counter.__qualname__.__len__() == 7 — len('Counter')"
  category: qualname_lengths
  kind: python_call_eq
  function: Counter.__qualname__.__len__
  args: []
  expected: 7

invariant collections_extra20.UserDict.qualname_len:
  description: "collections.UserDict.__qualname__.__len__() == 8 — len('UserDict')"
  category: qualname_lengths
  kind: python_call_eq
  function: UserDict.__qualname__.__len__
  args: []
  expected: 8

invariant collections_extra20.UserList.qualname_len:
  description: "collections.UserList.__qualname__.__len__() == 8 — len('UserList')"
  category: qualname_lengths
  kind: python_call_eq
  function: UserList.__qualname__.__len__
  args: []
  expected: 8

invariant collections_extra20.UserString.qualname_len:
  description: "collections.UserString.__qualname__.__len__() == 10 — len('UserString')"
  category: qualname_lengths
  kind: python_call_eq
  function: UserString.__qualname__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# __module__.__len__ table — six classes, fresh extra20 namespace anchor
#
# Prior specs cover __module__.__eq__('collections') for all six classes and
# __module__.__len__() == 11 for OrderedDict (extra18) and ChainMap (extra19).
# This table covers __module__.__len__ for the remaining four (Counter,
# UserDict, UserList, UserString) and re-anchors OrderedDict/ChainMap under
# the fresh id_prefix cmod20 for structural completeness.
# All six have __module__ == 'collections'; len('collections') == 11.
# ---------------------------------------------------------------------------

table collections_extra20.module_len_all:
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: cmod20

  columns: [id, function, args, expected]
  rows:
    - [OrderedDict, OrderedDict.__module__.__len__, [], 11]
    - [ChainMap,    ChainMap.__module__.__len__,    [], 11]
    - [Counter,     Counter.__module__.__len__,     [], 11]
    - [UserDict,    UserDict.__module__.__len__,    [], 11]
    - [UserList,    UserList.__module__.__len__,    [], 11]
    - [UserString,  UserString.__module__.__len__,  [], 11]

# ---------------------------------------------------------------------------
# deque.__module__.__len__ — extra20 namespace anchor
#
# collections_extra19 covers deque.__module__.__len__() == 11 as a standalone
# invariant. This re-anchors the same check in the extra20 namespace with a
# distinct invariant ID, providing continuity across the module-length series.
# ---------------------------------------------------------------------------

invariant collections_extra20.deque.module_len:
  description: "collections.deque.__module__.__len__() == 11 — len('collections'), extra20 namespace"
  category: module_attr_lengths
  kind: python_call_eq
  function: deque.__module__.__len__
  args: []
  expected: 11
