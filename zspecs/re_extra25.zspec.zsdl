spec: re_extra25
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and prior extras through re_extra24.zspec.zsdl."
    - "re_extra8 covers: compile/match/search/fullmatch/sub/split/findall/finditer __qualname__ via .__eq__ table."
    - "re_extra10 covers: purge/escape/subn __qualname__ via .__eq__ table."
    - "re_extra24 covers: Pattern/Match/error __qualname__.__len__() and function qualname lengths table."
    - "This spec provides a consolidated standalone invariant block for all ten re function __qualname__ values — compile, match, search, findall, finditer, sub, subn, split, fullmatch, escape — as named invariants for independent cross-spec anchoring."
    - "re.compile.__qualname__ == 'compile' — top-level function qualname equals its simple name. Verified at runtime."
    - "re.match.__qualname__ == 'match' — top-level function qualname equals its simple name. Verified at runtime."
    - "re.search.__qualname__ == 'search' — top-level function qualname equals its simple name. Verified at runtime."
    - "re.findall.__qualname__ == 'findall' — top-level function qualname equals its simple name. Verified at runtime."
    - "re.finditer.__qualname__ == 'finditer' — top-level function qualname equals its simple name. Verified at runtime."
    - "re.sub.__qualname__ == 'sub' — top-level function qualname equals its simple name. Verified at runtime."
    - "re.subn.__qualname__ == 'subn' — top-level function qualname equals its simple name. Verified at runtime."
    - "re.split.__qualname__ == 'split' — top-level function qualname equals its simple name. Verified at runtime."
    - "re.fullmatch.__qualname__ == 'fullmatch' — top-level function qualname equals its simple name. Verified at runtime."
    - "re.escape.__qualname__ == 'escape' — top-level function qualname equals its simple name. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile — __qualname__
#
# re_extra8 covers compile.__qualname__ via a table with .__eq__. This spec
# provides a named standalone invariant from the re_extra25 namespace.
# For a module-level function, __qualname__ equals the simple function name.
# Verified at runtime: re.compile.__qualname__ == 'compile'.
# ---------------------------------------------------------------------------

invariant re_extra25.compile.qualname:
  description: "re.compile.__qualname__ == 'compile' — top-level function qualname equals its simple name"
  category: function_identity
  kind: python_call_eq
  function: compile.__qualname__.__eq__
  args: ["compile"]
  expected: true

# ---------------------------------------------------------------------------
# re.match — __qualname__
#
# re_extra8 covers match.__qualname__ via table. Named standalone anchor.
