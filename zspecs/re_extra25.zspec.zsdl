# ---------------------------------------------------------------------------
# Table: consolidated re function __qualname__ values
#
# Groups all ten function __qualname__ equality checks from this spec into a
# single table for compact cross-reference. Each row corresponds to a named
# standalone invariant above.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table re_extra25.function_qualnames:
  description: "re module function __qualname__ values — all ten public callables consolidated"
  kind: python_call_eq
  category: function_identity
  id_prefix: qn25

  columns: [id, function, args, expected]
  rows:
    - [compile,   compile.__qualname__.__eq__,   ["compile"],   true]
    - [match,     match.__qualname__.__eq__,     ["match"],     true]
    - [search,    search.__qualname__.__eq__,    ["search"],    true]
    - [findall,   findall.__qualname__.__eq__,   ["findall"],   true]
    - [finditer,  finditer.__qualname__.__eq__,  ["finditer"],  true]
    - [sub,       sub.__qualname__.__eq__,       ["sub"],       true]
    - [subn,      subn.__qualname__.__eq__,      ["subn"],      true]
    - [split,     split.__qualname__.__eq__,     ["split"],     true]
    - [fullmatch, fullmatch.__qualname__.__eq__, ["fullmatch"], true]
    - [escape,    escape.__qualname__.__eq__,    ["escape"],    true]
