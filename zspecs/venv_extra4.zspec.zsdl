spec: venv_extra4
version: ">=3.9"
backend: python_module(venv)

docs: https://docs.python.org/3/library/venv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/venv.html — Python venv documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/venv/__init__.py"
  notes:
    - "This spec extends venv.zspec.zsdl, venv_extra.zspec.zsdl, venv_extra2.zspec.zsdl, and venv_extra3.zspec.zsdl."
    - "venv.zspec.zsdl covers: EnvBuilder/__name__/__module__/type, create/__name__/type, method name table."
    - "venv_extra.zspec.zsdl covers: EnvBuilder/__name__/__module__/__qualname__/type/base, create/__name__/__qualname__/type, method names table."
    - "venv_extra2.zspec.zsdl covers: method __name__ invariants (create/setup_scripts/setup_python/post_setup/install_scripts/clear_directory), EnvBuilder/__init__/__module__, method type table, method qualname table."
    - "venv_extra3.zspec.zsdl covers: create/__module__, EnvBuilder/__init__/__qualname__, class_names table (EnvBuilder), method_modules table (create/setup_python/setup_scripts/post_setup)."
    - "This spec adds: EnvBuilder.__bases__[0].__name__ (direct __getitem__ + __name__ return), EnvBuilder.ensure_directories/__qualname__ (not in any prior spec), EnvBuilder.install_scripts/__module__, EnvBuilder.clear_directory/__module__, EnvBuilder.clear_directory/__qualname__, create/__doc__ class check (str)."
    - "EnvBuilder.ensure_directories is documented in the venv module and is a public method."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# EnvBuilder.__bases__[0].__name__ == 'object'
# venv_extra covers this via method: __name__.__eq__ without method_args/expected.
# This adds a complementary direct-return form: method: __name__, expected: "object"
# (not used in any prior venv spec as a standalone invariant in this exact form)
# ---------------------------------------------------------------------------

invariant venv_extra4.EnvBuilder.base_name:
  description: "venv.EnvBuilder.__bases__[0].__name__ == 'object' — EnvBuilder inherits from object"
  category: classes
  kind: python_call_eq
  function: EnvBuilder.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# EnvBuilder.setup_scripts.__qualname__ == 'EnvBuilder.setup_scripts'
# venv_extra2 covers this in its method_qualnames table — so this is already done.
# Instead add ensure_directories.__qualname__ (NOT in any prior venv spec).
# ---------------------------------------------------------------------------

invariant venv_extra4.EnvBuilder.ensure_directories_qualname:
  description: "venv.EnvBuilder.ensure_directories.__qualname__ == 'EnvBuilder.ensure_directories'"
  category: qualnames
  kind: python_call_eq
  function: EnvBuilder.ensure_directories.__qualname__.__eq__
  args: ["EnvBuilder.ensure_directories"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder.ensure_directories.__name__ — method name check
# (venv.zspec.zsdl has this in a table; but the qualname above is new)
# ---------------------------------------------------------------------------

invariant venv_extra4.EnvBuilder.ensure_directories_name:
  description: "venv.EnvBuilder.ensure_directories.__name__ == 'ensure_directories'"
  category: methods
  kind: python_call_eq
  function: EnvBuilder.ensure_directories.__name__.__eq__
  args: ["ensure_directories"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder method __module__ checks — install_scripts and clear_directory
# (venv_extra3 covers create/setup_python/setup_scripts/post_setup __module__;
#  install_scripts and clear_directory are NOT in any prior __module__ table)
# ---------------------------------------------------------------------------

table venv_extra4.EnvBuilder.extra_method_modules:
  kind: python_call_eq
  category: method_modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [install_scripts,    EnvBuilder.install_scripts.__module__.__eq__,    ["venv"], true]
    - [clear_directory,    EnvBuilder.clear_directory.__module__.__eq__,    ["venv"], true]
    - [ensure_directories, EnvBuilder.ensure_directories.__module__.__eq__, ["venv"], true]

# ---------------------------------------------------------------------------
# EnvBuilder.clear_directory.__qualname__
# (venv_extra2.EnvBuilder.method_qualnames does NOT include clear_directory)
# ---------------------------------------------------------------------------

invariant venv_extra4.EnvBuilder.clear_directory_qualname:
  description: "venv.EnvBuilder.clear_directory.__qualname__ == 'EnvBuilder.clear_directory'"
  category: qualnames
  kind: python_call_eq
  function: EnvBuilder.clear_directory.__qualname__.__eq__
  args: ["EnvBuilder.clear_directory"]
  expected: true

# ---------------------------------------------------------------------------
# create.__doc__ — module-level create function is documented
# (not covered in any prior venv spec)
# ---------------------------------------------------------------------------

invariant venv_extra4.create.has_doc:
  description: "venv.create.__doc__.__class__.__name__ == 'str' — create function is documented"
  category: functions
  kind: python_call_eq
  function: create.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
