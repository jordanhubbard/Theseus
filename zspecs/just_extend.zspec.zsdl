spec: just_extend
version: ">=6.2.0"
backend: node(just-extend)

docs: https://www.npmjs.com/package/just-extend

provenance:
  derived_from:
    - "just-extend README — https://www.npmjs.com/package/just-extend"
    - "Test vectors verified with just-extend via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-extend source"
  notes:
    - "just-extend is an npm package. Install: npm install just-extend"
    - "The module exports a single function: extend(target, ...sources) merges sources into target."
    - "Later sources overwrite earlier ones. Returns the mutated target."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the target object with sources merged in."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_extend.extend:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: jext

  columns: [id, args, expected]
  rows:
    - [two_sources,   [{}, {"a": 1}, {"b": 2}],    {"a": 1, "b": 2}]
    - [overwrite,     [{}, {"a": 1}, {"a": 99}],   {"a": 99}]
