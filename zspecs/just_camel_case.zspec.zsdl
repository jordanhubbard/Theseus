spec: just_camel_case
version: ">=6.2.0"
backend: node(just-camel-case)

docs: https://www.npmjs.com/package/just-camel-case

provenance:
  derived_from:
    - "just-camel-case README — https://www.npmjs.com/package/just-camel-case"
    - "Test vectors verified with just-camel-case via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "just-camel-case source"
  notes:
    - "just-camel-case is an npm package. Install: npm install just-camel-case"
    - "Converts a string to camelCase."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_camel_case.convert:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: jcc

  columns: [id, args, expected]
  rows:
    - [from_kebab,  ["foo-bar"],  "fooBar"]
    - [from_snake,  ["foo_bar"],  "fooBar"]
    - [from_space,  ["foo bar"],  "fooBar"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:07:00Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
