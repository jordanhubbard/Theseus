spec: theseus_readline_cr
version: ">=3.0"
backend: python_cleanroom(theseus_readline_cr)
blocks: readline

docs: https://docs.python.org/3/library/readline.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/readline.html"
  not_derived_from:
    - "CPython source: Modules/readline.c"
  notes:
    - "Clean-room readline module. Do NOT import readline."

error_model: python_exceptions

invariant theseus_readline_cr.readline2_history_length:
  description: "get_history_length() returns an int"
  category: behavior
  kind: python_call_eq
  function: readline2_history_length
  args: []
  expected: true

invariant theseus_readline_cr.readline2_add_history:
  description: "add_history() and get_current_history_length() work"
  category: behavior
  kind: python_call_eq
  function: readline2_add_history
  args: []
  expected: true

invariant theseus_readline_cr.readline2_parse_and_bind:
  description: "parse_and_bind() is callable"
  category: behavior
  kind: python_call_eq
  function: readline2_parse_and_bind
  args: []
  expected: true
