spec: threading_extra402
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.Thread.ident.__class__.__name__ == 'property' — ident is a Python property descriptor on Thread; __class__.__name__ is 'property'. Verified with Python 3.14.4."
    - "threading.Thread.name.__class__.__name__ == 'property' — name is a Python property descriptor on Thread; __class__.__name__ is 'property'. Verified with Python 3.14.4."
    - "threading.Thread.daemon.__class__.__name__ == 'property' — daemon is a Python property descriptor on Thread; __class__.__name__ is 'property'. Verified with Python 3.14.4."
    - "threading.Thread.native_id.__class__.__name__ == 'property' — native_id is a Python property descriptor added in Python 3.8; __class__.__name__ is 'property'. Verified with Python 3.14.4."
    - "threading.Thread.__init__.__name__ == '__init__' — __init__ is a Python method on Thread; __name__ is '__init__'. Verified with Python 3.14.4."
    - "threading.Thread.__repr__.__name__ == '__repr__' — __repr__ is a Python method on Thread; __name__ is '__repr__'. Verified with Python 3.14.4."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread instance attribute descriptor __class__.__name__
#
# threading.Thread defines ident, name, daemon, and native_id as Python
# property descriptors in Lib/threading.py. When accessed on the class
# object (not an instance), each descriptor's __class__.__name__ is
# 'property'. native_id was added in Python 3.8.
# ---------------------------------------------------------------------------

table threading_extra402.thread_attr_descriptor_class_name:
  description: "threading.Thread property descriptor __class__.__name__ — ident, name, daemon, native_id are all Python properties; new to extra402"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingta402

  columns: [id, function, args, expected, description]
  rows:
    - [thread_ident_class_name_eq,
       "Thread.ident.__class__.__name__.__eq__",
       ["property"],
       true,
       "threading.Thread.ident.__class__.__name__.__eq__('property') == True — ident is a Python property descriptor on Thread; accessed on the class it is a property object; __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra402"]
    - [thread_name_class_name_eq,
       "Thread.name.__class__.__name__.__eq__",
       ["property"],
       true,
       "threading.Thread.name.__class__.__name__.__eq__('property') == True — name is a Python property descriptor on Thread; accessed on the class it is a property object; __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra402"]
    - [thread_daemon_class_name_eq,
       "Thread.daemon.__class__.__name__.__eq__",
       ["property"],
       true,
       "threading.Thread.daemon.__class__.__name__.__eq__('property') == True — daemon is a Python property descriptor on Thread; accessed on the class it is a property object; __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra402"]
    - [thread_native_id_class_name_eq,
       "Thread.native_id.__class__.__name__.__eq__",
       ["property"],
       true,
       "threading.Thread.native_id.__class__.__name__.__eq__('property') == True — native_id is a Python property descriptor added in Python 3.8; accessed on the class it is a property object; __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra402"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread special method __name__ values
#
# threading.Thread.__init__ and threading.Thread.__repr__ are Python
# methods defined in Lib/threading.py. Their __name__ attribute equals
# the bare method name string.
# ---------------------------------------------------------------------------

table threading_extra402.thread_special_method_name:
  description: "threading.Thread.__init__ and __repr__ __name__ values — Python methods on Thread; new to extra402"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtm402

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_name_eq,
       "Thread.__init__.__name__.__eq__",
       ["__init__"],
       true,
       "threading.Thread.__init__.__name__.__eq__('__init__') == True — __init__ is a Python method on Thread defined in Lib/threading.py; __name__ is '__init__'; str.__eq__('__init__') returns True; new to extra402"]
    - [thread_repr_name_eq,
       "Thread.__repr__.__name__.__eq__",
       ["__repr__"],
       true,
       "threading.Thread.__repr__.__name__.__eq__('__repr__') == True — __repr__ is a Python method on Thread defined in Lib/threading.py; __name__ is '__repr__'; str.__eq__('__repr__') returns True; new to extra402"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra402
# ---------------------------------------------------------------------------

invariant threading_extra402.thread_ident_class_name:
  description: "threading.Thread.ident.__class__.__name__ == 'property' — Python property descriptor on Thread class; new to extra402"
  kind: python_call_eq
  function: Thread.ident.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra402.thread_name_class_name:
  description: "threading.Thread.name.__class__.__name__ == 'property' — Python property descriptor on Thread class; new to extra402"
  kind: python_call_eq
  function: Thread.name.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra402.thread_daemon_class_name:
  description: "threading.Thread.daemon.__class__.__name__ == 'property' — Python property descriptor on Thread class; new to extra402"
  kind: python_call_eq
  function: Thread.daemon.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra402.thread_native_id_class_name:
  description: "threading.Thread.native_id.__class__.__name__ == 'property' — Python property descriptor added in 3.8; new to extra402"
  kind: python_call_eq
  function: Thread.native_id.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra402.thread_init_name:
  description: "threading.Thread.__init__.__name__ == '__init__' — Python method on Thread; new to extra402"
  kind: python_call_eq
  function: Thread.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant threading_extra402.thread_repr_name:
  description: "threading.Thread.__repr__.__name__ == '__repr__' — Python method on Thread; new to extra402"
  kind: python_call_eq
  function: Thread.__repr__.__name__.__eq__
  args: ["__repr__"]
  expected: true
