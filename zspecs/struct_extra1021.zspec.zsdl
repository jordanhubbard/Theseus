spec: struct_extra1021
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct module metadata types, class __weakref__ descriptors, and builtin function __self__ identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1021.module_metadata_types:
  description: "struct module top-level attribute class name checks"
  kind: python_call_eq
  category: module_metadata
  id_prefix: st1021x
  columns: [id, function, args, expected]
  rows:
    - [st1021x001, struct.__cached__.__class__.__name__.__eq__, ["str"],  true]
    - [st1021x002, struct.__file__.__class__.__name__.__eq__,   ["str"],  true]
    - [st1021x003, struct.__name__.__class__.__name__.__eq__,   ["str"],  true]
    - [st1021x004, struct.__doc__.__class__.__name__.__eq__,    ["str"],  true]
    - [st1021x005, struct.__name__.__eq__,                      ["struct"], true]

table struct_extra1021.class_weakref_descriptors:
  description: "struct class __weakref__ getset_descriptor checks"
  kind: python_call_eq
  category: weakref_descriptors
  id_prefix: st1021w
  columns: [id, function, args, expected]
  rows:
    - [st1021w001, struct.Struct.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [st1021w002, struct.error.__weakref__.__class__.__name__.__eq__,  ["getset_descriptor"], true]
    - [st1021w003, struct.Struct.__class__.__name__.__eq__,             ["type"],              true]
    - [st1021w004, struct.error.__class__.__name__.__eq__,              ["type"],              true]
    - [st1021w005, struct.Struct.__module__.__eq__,                     ["struct"],            true]
    - [st1021w006, struct.error.__module__.__eq__,                      ["struct"],            true]

table struct_extra1021.builtin_function_self_identity:
  description: "struct builtin functions __self__ class name checks"
  kind: python_call_eq
  category: builtin_self_identity
  id_prefix: st1021s
  columns: [id, function, args, expected]
  rows:
    - [st1021s001, struct.pack.__self__.__class__.__name__.__eq__,     ["module"], true]
    - [st1021s002, struct.unpack.__self__.__class__.__name__.__eq__,   ["module"], true]
    - [st1021s003, struct.calcsize.__self__.__class__.__name__.__eq__, ["module"], true]
    - [st1021s004, struct.pack_into.__self__.__class__.__name__.__eq__, ["module"], true]
    - [st1021s005, struct.unpack_from.__self__.__class__.__name__.__eq__, ["module"], true]
