spec: uuid_extra149
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra148.zspec.zsdl — covers uuid.NAMESPACE_DNS/__class__.__name__.__eq__('UUID') / NAMESPACE_URL/__class__.__name__.__eq__('UUID') / NAMESPACE_OID/__class__.__name__.__eq__('UUID') / NAMESPACE_X500/__class__.__name__.__eq__('UUID') / NAMESPACE_DNS.__str__.__qualname__.__eq__('UUID.__str__') / SafeUUID.__name__.__eq__('SafeUUID') / SafeUUID.__module__.__eq__('uuid') (table + invariants)."
    - "uuid_extra147.zspec.zsdl — covers uuid.UUID.__slots__.__class__.__name__.__eq__('tuple') / UUID.__slots__.__contains__('int'/'is_safe'/'__weakref__') / UUID.__slots__.__len__()==3 / UUID.__hash__/__str__/__repr__/__eq__ qualname lengths (table + invariants)."
    - "uuid_extra146.zspec.zsdl — covers uuid.uuid1/uuid3/uuid4/uuid5 __module__/__code__.co_name/__code__.co_argcount (table + invariants)."
    - "uuid_extra144.zspec.zsdl — covers uuid.UUID.__str__/__repr__/__hash__/__eq__/__int__ qualnames and qualname lengths (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra148."
    - "Wave 339 theme: uuid.UUID.__init__ and dunder method code attributes — UUID.__init__.__qualname__.__eq__('UUID.__init__') / UUID.__init__.__code__.co_argcount==7 / UUID.__init__.__code__.co_name.__eq__('__init__') / UUID.__str__.__code__.co_name.__eq__('__str__') / UUID.__repr__.__code__.co_name.__eq__('__repr__') / UUID.__hash__.__code__.co_name.__eq__('__hash__') / UUID.__eq__.__code__.co_name.__eq__('__eq__') / UUID.__eq__.__code__.co_argcount.__eq__(2)."
    - "uuid.UUID.__init__.__qualname__ == 'UUID.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_argcount == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_name == '__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__code__.co_name == '__str__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__code__.co_name == '__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__code__.co_name == '__hash__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__code__.co_name == '__eq__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.__init__.__code__.co_argcount == 7. UUID.__init__ takes 7 arguments: self, hex, bytes, bytes_le, fields, int, version (plus keyword-only is_safe=SafeUUID.unknown). co_argcount counts positional+keyword arguments but not keyword-only arguments; thus co_argcount is 7 (self + hex + bytes + bytes_le + fields + int + version). The UUID class accepts exactly one non-None constructor argument (other than self and is_safe)."
    - "Note: uuid.UUID.__eq__.__code__.co_argcount == 2. __eq__(self, other) takes exactly 2 positional arguments: self and other. This is the minimum for a binary comparison operator. UUID.__eq__ compares UUIDs by their int attribute (the underlying 128-bit integer). Returns NotImplemented if other is not a UUID instance."
    - "Note: uuid.UUID.__init__.__qualname__ == 'UUID.__init__' (13 chars = 'UUID.'=5 + '__init__'=8). This matches the pattern for dunder methods. co_name == '__init__' (8 chars) matches the function name in the def statement. co_argcount == 7 distinguishes UUID.__init__ from simpler dunder methods (__eq__ with co_argcount==2, __hash__ and __str__ with co_argcount==1)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__')
# uuid.UUID.__init__.__code__.co_argcount==7
# uuid.UUID.__init__.__code__.co_name.__eq__('__init__')
# uuid.UUID.__str__.__code__.co_name.__eq__('__str__')
#
# Wave 339 theme: UUID.__init__ qualname and code attributes for dunder methods.
#
# UUID.__init__.__qualname__ == 'UUID.__init__' (13 chars = 'UUID.'=5 + '__init__'=8).
# UUID.__init__.__code__.co_argcount == 7 (self + hex + bytes + bytes_le + fields + int + version).
# UUID.__init__.__code__.co_name == '__init__' (8 chars; matches def-statement name).
# UUID.__str__.__code__.co_name == '__str__' (7 chars; matches def-statement name).
# No prior uuid spec anchors UUID.__init__ qualname or code attributes as a table under
# uuidco149. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra149.UUID_init_qualname_and_code_attrs:
  description: "uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__')==True / UUID.__init__.__code__.co_argcount==7 / UUID.__init__.__code__.co_name.__eq__('__init__')==True / UUID.__str__.__code__.co_name.__eq__('__str__')==True — __init__.__qualname__ is 'UUID.__init__' (13 chars = 'UUID.'=5 + '__init__'=8); co_argcount is 7 (self/hex/bytes/bytes_le/fields/int/version; UUID accepts exactly one non-None of these); co_name is '__init__' (8 chars; matches def-statement name; confirms code object belongs to __init__); __str__.co_name is '__str__' (7 chars); first uuidco149 anchor for UUID.__init__ qualname and co_argcount"
  kind: python_call_eq
  category: identity
  id_prefix: uuidco149

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname_UUID_init,   "__init__.__qualname__.__eq__",          ["UUID.__init__"], true, "uuid.UUID.__init__.__qualname__ == 'UUID.__init__' (13 chars = 'UUID.'=5 + '__init__'=8; follows dunder qualname pattern)"]
    - [init_co_argcount_7,        "__init__.__code__.co_argcount.__eq__",  [7],               true, "uuid.UUID.__init__.__code__.co_argcount == 7 (self/hex/bytes/bytes_le/fields/int/version; most args of any UUID dunder)"]
    - [init_co_name_init,         "__init__.__code__.co_name.__eq__",      ["__init__"],      true, "uuid.UUID.__init__.__code__.co_name == '__init__' (8 chars; code object name matches def-statement function name)"]
    - [str_co_name_str,           "__str__.__code__.co_name.__eq__",       ["__str__"],       true, "uuid.UUID.__str__.__code__.co_name == '__str__' (7 chars; code object name matches def-statement; confirms pure Python impl)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__.__code__.co_name.__eq__('__repr__')
# uuid.UUID.__hash__.__code__.co_name.__eq__('__hash__')
# uuid.UUID.__eq__.__code__.co_name.__eq__('__eq__')
# uuid.UUID.__eq__.__code__.co_argcount.__eq__(2)
#
# Wave 339 theme: more dunder method co_name values and __eq__ co_argcount.
#
# UUID.__repr__.__code__.co_name == '__repr__' (8 chars; same length as '__init__' and '__hash__').
# UUID.__hash__.__code__.co_name == '__hash__' (8 chars; same length as '__repr__').
# UUID.__eq__.__code__.co_name == '__eq__' (6 chars; shortest dunder co_name here).
# UUID.__eq__.__code__.co_argcount == 2 (self, other; minimum for binary comparison).
# No prior uuid spec anchors these co_name values or __eq__ co_argcount as a table under
# uuidco149. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra149.UUID_dunder_co_names_and_eq_argcount:
  description: "uuid.UUID.__repr__.__code__.co_name.__eq__('__repr__')==True / UUID.__hash__.__code__.co_name.__eq__('__hash__')==True / UUID.__eq__.__code__.co_name.__eq__('__eq__')==True / UUID.__eq__.__code__.co_argcount.__eq__(2)==True — __repr__.co_name is '__repr__' (8 chars; same length as '__init__' and '__hash__'); __hash__.co_name is '__hash__' (8 chars); __eq__.co_name is '__eq__' (6 chars; shortest; 2 fewer than '__hash__'/'__repr__'); __eq__.co_argcount is 2 (self + other; minimum for binary comparison; compares UUID.int attributes); first uuidco149 anchor for dunder co_name values and __eq__ co_argcount"
  kind: python_call_eq
  category: identity
  id_prefix: uuidco149

  columns: [id, function, args, expected, description]
  rows:
    - [repr_co_name_repr,   "__repr__.__code__.co_name.__eq__",         ["__repr__"], true, "uuid.UUID.__repr__.__code__.co_name == '__repr__' (8 chars; code object name; same length as '__init__' and '__hash__')"]
    - [hash_co_name_hash,   "__hash__.__code__.co_name.__eq__",         ["__hash__"], true, "uuid.UUID.__hash__.__code__.co_name == '__hash__' (8 chars; code object name; UUID.__hash__ returns hash of self.int)"]
    - [eq_co_name_eq,       "__eq__.__code__.co_name.__eq__",           ["__eq__"],   true, "uuid.UUID.__eq__.__code__.co_name == '__eq__' (6 chars; shortest co_name here; 2 fewer chars than '__repr__'/'__hash__')"]
    - [eq_co_argcount_2,    "__eq__.__code__.co_argcount.__eq__",       [2],          true, "uuid.UUID.__eq__.__code__.co_argcount == 2 (self + other; minimum for binary comparison operator; returns NotImplemented if not UUID)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__ co_argcount length ordering table
#
# Wave 339 theme: co_argcount ordering across UUID dunder methods.
#
# UUID.__eq__.__code__.co_argcount == 2 (binary operator: self + other).
# UUID.__init__.__code__.co_argcount == 7 (7 positional params including self).
# Length ordering: __eq__(2) < __str__/__repr__/__hash__(1 each) ... wait:
# __str__/__repr__/__hash__ all take only self, so co_argcount == 1.
# Ordering: __str__/repr/hash(1) < __eq__(2) < __init__(7).
# No prior uuid spec anchors these co_argcount values as a combined table under uuidco149.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra149.UUID_dunder_co_argcount_ordering:
  description: "uuid.UUID.__str__.__code__.co_argcount==1 / UUID.__hash__.__code__.co_argcount==1 / UUID.__eq__.__code__.co_argcount==2 / UUID.__init__.__code__.co_argcount==7 — co_argcount ordering: __str__/__repr__/__hash__(1; unary, only self) < __eq__(2; binary, self+other) < __init__(7; self+hex+bytes+bytes_le+fields+int+version); __init__ has the most positional args (7) of any UUID dunder method; __str__/__hash__ take only self (unary operations); __eq__ takes self and other (binary comparison); first uuidco149 anchor for this co_argcount ordering"
  kind: python_call_eq
  category: identity
  id_prefix: uuidco149

  columns: [id, function, args, expected, description]
  rows:
    - [str_co_argcount_1,    "__str__.__code__.co_argcount.__eq__",   [1], true, "uuid.UUID.__str__.__code__.co_argcount == 1 (only self; unary string conversion; no additional arguments)"]
    - [hash_co_argcount_1,   "__hash__.__code__.co_argcount.__eq__",  [1], true, "uuid.UUID.__hash__.__code__.co_argcount == 1 (only self; returns hash(self.int); unary operation)"]
    - [eq_co_argcount_2b,    "__eq__.__code__.co_argcount.__eq__",    [2], true, "uuid.UUID.__eq__.__code__.co_argcount == 2 (self + other; binary comparison; returns NotImplemented for non-UUID other)"]
    - [init_co_argcount_7b,  "__init__.__code__.co_argcount.__eq__",  [7], true, "uuid.UUID.__init__.__code__.co_argcount == 7 (self/hex/bytes/bytes_le/fields/int/version; accepts exactly one non-None of the 6 data params)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__') — standalone
#
# uuid.UUID.__init__.__qualname__ is 'UUID.__init__' (13 chars). UUID.__init__
# is the constructor for UUID instances. Its qualname follows the standard pattern
# for class methods: 'ClassName.' + 'method_name'. 'UUID.__init__' = 'UUID.'=5 chars +
# '__init__'=8 chars = 13 chars. The __init__ method implements UUID construction
# from one of several alternative representations: hex string, bytes, bytes_le,
# fields tuple, or integer. It accepts exactly one non-None data argument (plus
# optional version and is_safe keyword-only arguments). extra147 anchors UUID dunder
# qualname lengths; no prior uuid spec anchors UUID.__init__.__qualname__ string
# value as a standalone under uuidco149.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra149.UUID_init_qualname_eq:
  description: "uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__') == True — 13 chars = 'UUID.'=5 + '__init__'=8; UUID constructor accepting hex/bytes/bytes_le/fields/int (exactly one non-None); co_argcount==7 (self/hex/bytes/bytes_le/fields/int/version); co_name=='__init__' (8 chars); extra147 anchors dunder qualname lengths but not __init__ qualname string; qualname length ordering: __eq__(11) < __str__(12) < __hash__==__repr__==__init__(13); no prior uuid spec anchors this as a standalone; first standalone under uuidco149"
  category: identity
  kind: python_call_eq
  function: __init__.__qualname__.__eq__
  args: ["UUID.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_argcount == 7 — standalone
#
# uuid.UUID.__init__.__code__.co_argcount is 7. The UUID.__init__ method signature is:
# def __init__(self, hex=None, bytes=None, bytes_le=None, fields=None, int=None, version=None, *, is_safe=SafeUUID.unknown).
# co_argcount counts positional/keyword parameters (not keyword-only parameters that come
# after '*'). The 7 parameters counted are: self, hex, bytes, bytes_le, fields, int, version.
# The keyword-only 'is_safe' parameter is NOT counted in co_argcount (it is in co_kwonlyargcount).
# co_argcount == 7 makes UUID.__init__ the most parameter-rich dunder method in UUID.
# No prior uuid spec anchors UUID.__init__.__code__.co_argcount as a standalone under
# uuidco149. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra149.UUID_init_co_argcount_7:
  description: "uuid.UUID.__init__.__code__.co_argcount == 7 — self + hex + bytes + bytes_le + fields + int + version = 7 positional/keyword params; is_safe is keyword-only (after '*') so NOT counted in co_argcount; UUID accepts exactly one non-None data param (hex/bytes/bytes_le/fields/int); version is optional (1-5 for RFC 4122 types); co_argcount(7) >> co_argcount of __str__/__repr__/__hash__(1) and __eq__(2); no prior uuid spec anchors this as a standalone; first standalone under uuidco149"
  category: identity
  kind: python_call_eq
  function: __init__.__code__.co_argcount.__eq__
  args: [7]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__eq__.__code__.co_argcount == 2 — standalone
#
# uuid.UUID.__eq__.__code__.co_argcount is 2. UUID.__eq__ implements equality
# comparison between UUID instances. Its signature is: def __eq__(self, other).
# co_argcount == 2 because there are exactly 2 positional arguments: self and other.
# This is the minimum co_argcount for a binary comparison operator. UUID.__eq__ compares
# two UUIDs by comparing their .int attributes (the underlying 128-bit integers). If
# 'other' is not a UUID instance, __eq__ returns NotImplemented (allowing Python to try
# the reflected operation other.__eq__(self)). co_argcount == 2 contrasts with unary
# dunders (__str__, __repr__, __hash__) which have co_argcount == 1.
# No prior uuid spec anchors UUID.__eq__.__code__.co_argcount as a standalone under
# uuidco149. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra149.UUID_eq_co_argcount_2:
  description: "uuid.UUID.__eq__.__code__.co_argcount == 2 — self + other = 2; minimum co_argcount for binary comparison operator; UUID.__eq__ compares self.int == other.int; returns NotImplemented if other is not UUID (allows reflected ops); co_argcount ordering: __str__/__repr__/__hash__(1; unary) < __eq__(2; binary) < __init__(7; constructor); extra147 anchors __eq__.__qualname__.__len__()==11; no prior uuid spec anchors __eq__.co_argcount as a standalone; first standalone under uuidco149"
  category: identity
  kind: python_call_eq
  function: __eq__.__code__.co_argcount.__eq__
  args: [2]
  expected: true

