spec: ssl_extra30
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "ssl_extra29.zspec.zsdl — covers SSLCertVerificationError __module__/__name__/__qualname__ __len__(); SSLContext.load_cert_chain/load_verify_locations/set_ciphers __qualname__/__name__ __len__(); SSLSocket.read/write __qualname__/__name__ __len__(); create_default_context.__qualname__.__len__()."
    - "ssl_extra28.zspec.zsdl — covers SSLContext/SSLError/SSLSocket/SSLObject __module__.__len__() and __name__.__len__(); create_default_context/__qualname__/__module__.__len__(); SSLContext.wrap_socket/__qualname__/__module__.__len__()."
    - "ssl_extra27.zspec.zsdl — covers SSLContext/__init__.__name__; SSLError/__init__.__name__; SSLSocket/__module__/__bases__[0].__name__; SSLObject/__module__/__bases__[0].__name__; SSLCertVerificationError/__name__/__module__/__bases__[0].__name__; CertificateError/__name__/__bases__[0].__name__."
    - "ssl_extra23.zspec.zsdl — covers SSLContext wrap_socket/load_cert_chain/set_ciphers __qualname__; SSLSocket.read.__qualname__."
    - "ssl_extra21.zspec.zsdl — covers SSLContext/SSLSocket/SSLObject/MemoryBIO/SSLSession __qualname__.__len__; create_default_context __qualname__.__len__."
  notes:
    - "This spec extends ssl through ssl_extra29; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: SSLContext/__name__/__module__/__qualname__/__module__.__len__()/__name__.__len__(); SSLError/__name__/__module__/__module__.__len__()/__name__.__len__(); SSLSocket/__name__/__module__/__module__.__len__()/__name__.__len__(); SSLObject/__name__/__module__/__module__.__len__()/__name__.__len__(); SSLCertVerificationError/__name__/__module__/__qualname__ all __len__(); CertificateError/__name__; create_default_context/__qualname__/__module__.__len__()/__qualname__.__len__(); SSLContext.wrap_socket/__qualname__/__module__.__len__(); SSLContext.load_cert_chain/load_verify_locations/set_ciphers __qualname__/__name__ __len__(); SSLSocket.read/write __qualname__/__name__ __len__()."
    - "This spec covers: ssl.SSLContext.__mro__.__len__(); ssl.SSLError.__mro__.__len__(); ssl.SSLSocket.__mro__.__len__(); ssl.SSLObject.__mro__.__len__(); ssl.SSLContext.__bases__[0].__name__ (== '_SSLContext'); ssl.SSLError.__bases__[0].__name__ (== 'OSError'); ssl.SSLSocket.__bases__[0].__name__ (== 'socket'); ssl.SSLContext.set_alpn_protocols/__qualname__/__qualname__.__len__()/__name__.__len__(); ssl.SSLContext.set_npn_protocols/__qualname__/__qualname__.__len__()/__name__.__len__(); ssl.SSLSocket.getpeercert/__qualname__/__qualname__.__len__()/__name__.__len__()."
    - "ssl.SSLContext.__mro__.__len__() == 3 — (SSLContext, _ssl._SSLContext, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLError.__mro__.__len__() == 5 — (SSLError, OSError, Exception, BaseException, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.__mro__.__len__() == 4 — (SSLSocket, socket.socket, _socket.socket, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLObject.__mro__.__len__() == 2 — (SSLObject, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.__bases__[0].__name__ == '_SSLContext' — the C-level base class. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLError.__bases__[0].__name__ == 'OSError'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.__bases__[0].__name__ == 'socket'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.set_alpn_protocols.__qualname__ == 'SSLContext.set_alpn_protocols' — len 29. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.set_npn_protocols.__qualname__ == 'SSLContext.set_npn_protocols' — len 28. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.set_alpn_protocols.__name__ == 'set_alpn_protocols' — len 18. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.set_npn_protocols.__name__ == 'set_npn_protocols' — len 17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.getpeercert.__qualname__ == 'SSLSocket.getpeercert' — len 21. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.getpeercert.__name__ == 'getpeercert' — len 11. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ssl class __mro__.__len__()
#
# No prior spec checks __mro__.__len__() for any ssl class.
# SSLContext: 3 (SSLContext, _ssl._SSLContext, object)
# SSLError:   5 (SSLError, OSError, Exception, BaseException, object)
# SSLSocket:  4 (SSLSocket, socket.socket, _socket.socket, object)
# SSLObject:  2 (SSLObject, object)
# ---------------------------------------------------------------------------

invariant ssl_extra30.SSLContext.mro_len:
  description: "len(ssl.SSLContext.__mro__) == 3 — (SSLContext, _ssl._SSLContext, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLContext.__mro__.__len__
  args: []
  expected: 3

invariant ssl_extra30.SSLError.mro_len:
  description: "len(ssl.SSLError.__mro__) == 5 — (SSLError, OSError, Exception, BaseException, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLError.__mro__.__len__
  args: []
  expected: 5

table ssl_extra30.class_mro_lengths:
  description: "ssl class __mro__.__len__() — SSLSocket (4) and SSLObject (2)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: scml30

  columns: [id, function, args, expected, description]
  rows:
    - [SSLSocket,
       SSLSocket.__mro__.__len__,
       [],
       4,
       "len(ssl.SSLSocket.__mro__) == 4 — SSLSocket inherits from socket"]
    - [SSLObject,
       SSLObject.__mro__.__len__,
       [],
       2,
       "len(ssl.SSLObject.__mro__) == 2 — SSLObject inherits only from object"]

# ---------------------------------------------------------------------------
# ssl class __bases__[0].__name__ for SSLContext, SSLError, SSLSocket
#
# No prior spec checks __bases__[0].__name__ for SSLContext or SSLError from
# the extra30 namespace. SSLSocket.__bases__[0].__name__ == 'socket' was noted
# in ssl_extra27 for the module attribute; this anchors it from extra30.
# ---------------------------------------------------------------------------

table ssl_extra30.class_base_names:
  description: "ssl class __bases__[0].__name__ — SSLContext/'_SSLContext', SSLError/'OSError', SSLSocket/'socket'"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: scbn30

  columns: [id, function, args, expected, description]
  rows:
    - [SSLContext,
       "SSLContext.__bases__[0].__name__.__eq__",
       ["_SSLContext"],
       true,
       "ssl.SSLContext.__bases__[0].__name__ == '_SSLContext' (C-level base)"]
    - [SSLError,
       "SSLError.__bases__[0].__name__.__eq__",
       ["OSError"],
       true,
       "ssl.SSLError.__bases__[0].__name__ == 'OSError'"]
    - [SSLSocket,
       "SSLSocket.__bases__[0].__name__.__eq__",
       ["socket"],
       true,
       "ssl.SSLSocket.__bases__[0].__name__ == 'socket' (inherits from socket.socket)"]

# ---------------------------------------------------------------------------
# ssl.SSLContext.set_alpn_protocols and set_npn_protocols __qualname__ and lengths
#
# No prior spec checks __qualname__ or __len__() for set_alpn_protocols or
# set_npn_protocols. These are Python-level methods on SSLContext.
# set_alpn_protocols.__qualname__ == 'SSLContext.set_alpn_protocols' (len 29).
# set_npn_protocols.__qualname__ == 'SSLContext.set_npn_protocols' (len 28).
# ---------------------------------------------------------------------------

invariant ssl_extra30.SSLContext.set_alpn_protocols_qualname_len:
  description: "len(ssl.SSLContext.set_alpn_protocols.__qualname__) == 29 — len('SSLContext.set_alpn_protocols') == 29"
  category: function_qualnames
  kind: python_call_eq
  function: SSLContext.set_alpn_protocols.__qualname__.__len__
  args: []
  expected: 29

invariant ssl_extra30.SSLContext.set_npn_protocols_qualname_len:
  description: "len(ssl.SSLContext.set_npn_protocols.__qualname__) == 28 — len('SSLContext.set_npn_protocols') == 28"
  category: function_qualnames
  kind: python_call_eq
  function: SSLContext.set_npn_protocols.__qualname__.__len__
  args: []
  expected: 28

table ssl_extra30.SSLContext_protocol_method_qualnames:
  description: "ssl.SSLContext.set_alpn_protocols/set_npn_protocols __qualname__.__eq__ and __name__.__len__()"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: scpmq30

  columns: [id, function, args, expected, description]
  rows:
    - [alpn_qualname,
       SSLContext.set_alpn_protocols.__qualname__.__eq__,
       ["SSLContext.set_alpn_protocols"],
       true,
       "SSLContext.set_alpn_protocols.__qualname__ == 'SSLContext.set_alpn_protocols'"]
    - [npn_qualname,
       SSLContext.set_npn_protocols.__qualname__.__eq__,
       ["SSLContext.set_npn_protocols"],
       true,
       "SSLContext.set_npn_protocols.__qualname__ == 'SSLContext.set_npn_protocols'"]
    - [alpn_name_len,
       SSLContext.set_alpn_protocols.__name__.__len__,
       [],
       18,
       "len('set_alpn_protocols') == 18"]
    - [npn_name_len,
       SSLContext.set_npn_protocols.__name__.__len__,
       [],
       17,
       "len('set_npn_protocols') == 17"]

# ---------------------------------------------------------------------------
# ssl.SSLSocket.getpeercert __qualname__ and __name__ lengths
#
# No prior spec checks __qualname__ or __name__ for SSLSocket.getpeercert.
# getpeercert.__qualname__ == 'SSLSocket.getpeercert' (len 21).
# getpeercert.__name__ == 'getpeercert' (len 11).
# ---------------------------------------------------------------------------

invariant ssl_extra30.SSLSocket.getpeercert_qualname_len:
  description: "len(ssl.SSLSocket.getpeercert.__qualname__) == 21 — len('SSLSocket.getpeercert') == 21"
  category: function_qualnames
  kind: python_call_eq
  function: SSLSocket.getpeercert.__qualname__.__len__
  args: []
  expected: 21

invariant ssl_extra30.SSLSocket.getpeercert_name_len:
  description: "len(ssl.SSLSocket.getpeercert.__name__) == 11 — len('getpeercert') == 11"
  category: function_names
  kind: python_call_eq
  function: SSLSocket.getpeercert.__name__.__len__
  args: []
  expected: 11
