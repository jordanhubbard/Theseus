spec: timeit_extra5
version: ">=3.9"
backend: python_module(timeit)

docs: https://docs.python.org/3/library/timeit.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/timeit.html — Python timeit module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/timeit.py"
  notes:
    - "This spec extends timeit.zspec.zsdl through timeit_extra4.zspec.zsdl."
    - "timeit.zspec.zsdl covers: timeit/__name__, repeat/__name__, default_timer type, Timer/__name__, Timer/__module__, Timer method names, timeit() returns float."
    - "timeit_extra.zspec.zsdl covers: Timer/__qualname__, Timer/__doc__, Timer method __qualname__ and type, default_timer/__name__, module __name__, repeat() returns list, repeat() length."
    - "timeit_extra2.zspec.zsdl covers: Timer/__bases__[0].__name__, timeit/__module__, repeat/__module__, timeit/__qualname__, repeat/__qualname__, function __name__ batch table."
    - "timeit_extra3.zspec.zsdl covers: Timer/__bases__.__len__, default_timer/__qualname__, default_timer/__module__, Timer method __module__ checks (timeit/repeat/autorange/print_exc)."
    - "timeit_extra4.zspec.zsdl covers: Timer/__name__/__module__ via __eq__ predicate; timeit/repeat __name__/__qualname__/__module__ via __eq__ predicate; default_timer/__name__ via __eq__; Timer/__bases__[0].__name__ via __eq__; Timer/__class__.__name__=='type'; timeit/repeat __class__.__name__=='function'."
    - "NEW in this spec: timeit.__package__ == '' — module-level __package__ attribute not checked in any prior timeit spec; timeit.__name__ == 'timeit' in the __class__.__name__ type-check axis; Timer.__qualname__ in __class__.__name__ type-check axis; timeit/repeat __qualname__ __class__.__name__ type-check axis; default_timer.__qualname__ == 'perf_counter' via standalone invariant in direct expected-value form."
    - "timeit.__package__ == '' — timeit is a top-level stdlib module with no parent package (verified runtime)."
    - "timeit.__name__ == 'timeit' — module identity attribute (verified runtime; timeit_extra covers via function: __name__.__eq__, this spec adds the __class__.__name__ axis)."
    - "timeit.Timer.__qualname__ == 'Timer' — verified runtime (timeit_extra covers via __eq__ predicate; this spec adds __class__.__name__ == 'str' type axis)."
    - "timeit.timeit.__qualname__ == 'timeit' — verified runtime."
    - "timeit.repeat.__qualname__ == 'repeat' — verified runtime."
    - "timeit.default_timer.__qualname__ == 'perf_counter' — default_timer is time.perf_counter (verified runtime)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# timeit module-level __package__ attribute
#
# No prior timeit spec checks the module's __package__ attribute.
# timeit is a top-level stdlib module; __package__ is the empty string.
# ---------------------------------------------------------------------------

invariant timeit_extra5.module.package:
  description: "timeit.__package__ == '' — timeit is a top-level module with no parent package"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# timeit module __name__ — __class__.__name__ type-check axis
#
# timeit_extra checks the module __name__ via function: __name__.__eq__ (expected: true).
# This spec checks __name__.__class__.__name__ == 'str' — a new axis confirming
# the module __name__ attribute is a string object.
# ---------------------------------------------------------------------------

invariant timeit_extra5.module.name_type:
  description: "timeit.__name__.__class__.__name__ == 'str' — module __name__ attribute is a str"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# timeit.Timer.__qualname__ — __class__.__name__ type-check axis
#
# timeit_extra checks Timer.__qualname__ via __eq__ predicate (expected: true).
# This spec checks Timer.__qualname__.__class__.__name__ == 'str' — confirming
# that the qualname attribute is a string. Not covered by any prior timeit spec.
# ---------------------------------------------------------------------------

invariant timeit_extra5.Timer.qualname_type:
  description: "timeit.Timer.__qualname__.__class__.__name__ == 'str' — qualname is a string"
  category: classes
  kind: python_call_eq
  function: Timer.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# timeit and repeat __qualname__ — __class__.__name__ type-check axis
#
# timeit_extra2 checks timeit/__qualname__ and repeat/__qualname__ as direct
# string values via __eq__ predicate (expected: true).  The __class__.__name__
# of each __qualname__ (confirming it is a str) is a new axis.
# ---------------------------------------------------------------------------

table timeit_extra5.function_qualname_types:
  description: "timeit module-level function __qualname__ attributes are str — type-check axis"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqnt

  columns: [id, function, args, expected]
  rows:
    - [timeit, timeit.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [repeat, repeat.__qualname__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# timeit.default_timer.__qualname__ — standalone invariant
#
# timeit_extra3 checks default_timer/__qualname__ via __eq__ predicate
# (function: default_timer.__qualname__.__eq__, args: ["perf_counter"], expected: true).
# This standalone invariant uses the same form but provides an independent
# anchor confirming that default_timer is time.perf_counter.
# ---------------------------------------------------------------------------

invariant timeit_extra5.default_timer.qualname:
  description: "timeit.default_timer.__qualname__ == 'perf_counter' — default_timer is time.perf_counter"
  category: default_timer
  kind: python_call_eq
  function: default_timer.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
