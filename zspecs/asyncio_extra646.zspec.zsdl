spec: asyncio_extra646
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio.Condition synchronization primitive"
    - "https://docs.python.org/3/library/asyncio-stream.html — asyncio.StreamReader and asyncio.StreamWriter"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers identity checks for asyncio.Condition and asyncio.StreamReader/Writer class and method qualnames"
  created_at: "2026-04-12T00:00:00Z"

table asyncio_extra646.condition_identity:
  description: "Identity checks for asyncio.Condition class and its methods"
  kind: python_call_eq
  category: class_identity
  id_prefix: as646cn
  columns: [id, function, args, expected]
  rows:
    - [as646cn001, asyncio.Condition.__qualname__.__eq__, ["Condition"], true]
    - [as646cn002, asyncio.Condition.__module__.__eq__, ["asyncio.locks"], true]
    - [as646cn003, asyncio.Condition.__init__.__qualname__.__eq__, ["Condition.__init__"], true]
    - [as646cn004, asyncio.Condition.acquire.__qualname__.__eq__, ["Condition.acquire"], true]
    - [as646cn005, asyncio.Condition.release.__qualname__.__eq__, ["Condition.release"], true]
    - [as646cn006, asyncio.Condition.wait.__qualname__.__eq__, ["Condition.wait"], true]
    - [as646cn007, asyncio.Condition.notify.__qualname__.__eq__, ["Condition.notify"], true]
    - [as646cn008, asyncio.Condition.notify_all.__qualname__.__eq__, ["Condition.notify_all"], true]

table asyncio_extra646.stream_identity:
  description: "Identity checks for asyncio.StreamReader and asyncio.StreamWriter"
  kind: python_call_eq
  category: class_identity
  id_prefix: as646tp
  columns: [id, function, args, expected]
  rows:
    - [as646tp001, asyncio.StreamReader.__qualname__.__eq__, ["StreamReader"], true]
    - [as646tp002, asyncio.StreamReader.__module__.__eq__, ["asyncio.streams"], true]
    - [as646tp003, asyncio.StreamWriter.__qualname__.__eq__, ["StreamWriter"], true]
    - [as646tp004, asyncio.StreamWriter.__module__.__eq__, ["asyncio.streams"], true]
    - [as646tp005, asyncio.StreamReader.read.__qualname__.__eq__, ["StreamReader.read"], true]
    - [as646tp006, asyncio.StreamReader.readline.__qualname__.__eq__, ["StreamReader.readline"], true]
