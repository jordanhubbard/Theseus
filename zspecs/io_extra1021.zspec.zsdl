spec: io_extra1021
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __weakref__.__class__.__name__ for io classes and module-level __all__ type"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1021.iobase_weakref:
  description: "io.IOBase and core stream classes __weakref__ descriptor identity"
  kind: python_call_eq
  category: weakref_descriptor
  id_prefix: io1021x
  columns: [id, function, args, expected]
  rows:
    - [io1021x001, io.IOBase.__weakref__.__class__.__name__.__eq__,       ["getset_descriptor"], true]
    - [io1021x002, io.FileIO.__weakref__.__class__.__name__.__eq__,       ["getset_descriptor"], true]
    - [io1021x003, io.BytesIO.__weakref__.__class__.__name__.__eq__,      ["getset_descriptor"], true]
    - [io1021x004, io.StringIO.__weakref__.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [io1021x005, io.BufferedReader.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [io1021x006, io.TextIOWrapper.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]

table io_extra1021.buffered_classes_weakref:
  description: "Buffered IO classes __weakref__ descriptor identity"
  kind: python_call_eq
  category: weakref_descriptor
  id_prefix: io1021b
  columns: [id, function, args, expected]
  rows:
    - [io1021b001, io.BufferedWriter.__weakref__.__class__.__name__.__eq__,   ["getset_descriptor"], true]
    - [io1021b002, io.BufferedRandom.__weakref__.__class__.__name__.__eq__,   ["getset_descriptor"], true]
    - [io1021b003, io.BufferedRWPair.__weakref__.__class__.__name__.__eq__,   ["getset_descriptor"], true]
    - [io1021b004, io.RawIOBase.__weakref__.__class__.__name__.__eq__,        ["getset_descriptor"], true]
    - [io1021b005, io.BufferedIOBase.__weakref__.__class__.__name__.__eq__,   ["getset_descriptor"], true]
    - [io1021b006, io.TextIOBase.__weakref__.__class__.__name__.__eq__,       ["getset_descriptor"], true]

table io_extra1021.module_meta:
  description: "io module-level metadata type checks"
  kind: python_call_eq
  category: module_meta
  id_prefix: io1021m
  columns: [id, function, args, expected]
  rows:
    - [io1021m001, io.__all__.__class__.__name__.__eq__,         ["list"], true]
    - [io1021m002, io.__name__.__class__.__name__.__eq__,        ["str"],  true]
    - [io1021m003, io.__package__.__class__.__name__.__eq__,     ["str"],  true]
    - [io1021m004, io.IOBase.__module__.__eq__,                  ["io"],   true]
    - [io1021m005, io.BytesIO.__module__.__eq__,                 ["io"],   true]
    - [io1021m006, io.StringIO.__module__.__eq__,                ["io"],   true]
