spec: array_extra20
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
    - "array.zspec.zsdl — baseline typecode, itemsize, and instance vectors."
    - "array_extra.zspec.zsdl through array_extra19.zspec.zsdl — prior extras."
  notes:
    - "This spec extends array.zspec.zsdl through array_extra19.zspec.zsdl."
    - "Focus: typecode attribute on empty-array instances for all 12 safe typecodes."
    - "Prior typecode_attr coverage (all specs combined): b, B, h, H, i, I, l, L, d, f, q, Q — but always with non-empty initializers ([1,2,3], [0], [1.0,2.0], etc.)."
    - "No prior spec checks typecode via .typecode attribute on array instances constructed with an empty list []."
    - "array_extra8 uses [1,2,3]; array_extra4 uses [0]; array_extra3 uses [1.0] — none use []."
    - "This spec uses empty-list initializers exclusively, providing a distinct execution axis."
    - "array.array('b', []).typecode == 'b' — Verified Python 3.12 macOS."
    - "array.array('B', []).typecode == 'B' — Verified."
    - "array.array('i', []).typecode == 'i' — Verified."
    - "array.array('I', []).typecode == 'I' — Verified."
    - "array.array('l', []).typecode == 'l' — Verified."
    - "array.array('L', []).typecode == 'L' — Verified."
    - "array.array('d', []).typecode == 'd' — Verified."
    - "array.array('f', []).typecode == 'f' — Verified."
    - "array.array('h', []).typecode == 'h' — Verified."
    - "array.array('H', []).typecode == 'H' — Verified."
    - "array.array('q', []).typecode == 'q' — Verified."
    - "array.array('Q', []).typecode == 'Q' — Verified."
    - "The 'u' typecode is deprecated in Python 3.12 (DeprecationWarning) and is excluded from this spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# typecode attribute on empty-array instances — all 12 safe typecodes
#
# Prior specs verify the .typecode attribute using non-empty initializers.
# This table uses empty-list [] initializers as a distinct construction axis.
# An empty array still has a valid typecode (set at construction time).
# id_prefix tc20 does not conflict with any prior array spec.
# ---------------------------------------------------------------------------

table array_extra20.typecode_empty_init:
  description: "typecode attribute on empty-list-initialized array instances for all 12 safe typecodes"
  kind: python_call_eq
  category: typecode_attrs
  id_prefix: tc20

  columns: [id, function, args, method, expected]
  rows:
    - [b, array, ["b", []], typecode, "b"]
    - [B, array, ["B", []], typecode, "B"]
    - [h, array, ["h", []], typecode, "h"]
    - [H, array, ["H", []], typecode, "H"]
    - [i, array, ["i", []], typecode, "i"]
    - [I, array, ["I", []], typecode, "I"]
    - [l, array, ["l", []], typecode, "l"]
    - [L, array, ["L", []], typecode, "L"]
    - [q, array, ["q", []], typecode, "q"]
    - [Q, array, ["Q", []], typecode, "Q"]
    - [f, array, ["f", []], typecode, "f"]
    - [d, array, ["d", []], typecode, "d"]
