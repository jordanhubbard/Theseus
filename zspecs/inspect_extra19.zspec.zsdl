spec: inspect_extra19
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra18.zspec.zsdl — covers __name__ table for isfunction/ismethod/isclass/ismodule/isbuiltin/isgenerator/iscoroutine; __module__ table for same; isclass(int)/ismodule(inspect)/isbuiltin(len) predicate-on-value checks"
    - "inspect_extra17.zspec.zsdl — covers __name__ for isgenerator/iscoroutine/isasyncgen/isroutine/isbuiltin; __module__ for isroutine/isbuiltin; predicate-on-value checks"
    - "inspect_extra15.zspec.zsdl — covers __name__ and __qualname__ table for isfunction/isbuiltin/isclass/ismodule/ismethod/ismethoddescriptor; Signature/BoundArguments/Parameter __module__"
    - "inspect_extra16.zspec.zsdl — covers __qualname__ for isgenerator/iscoroutine/isasyncgen/isabstract; __module__ for isclass/ismodule/isfunction/ismethod/isgenerator/iscoroutine/isasyncgen/isabstract"
  notes:
    - "This spec extends inspect.zspec.zsdl and prior extras through inspect_extra18.zspec.zsdl."
    - "inspect.getmembers.__name__ == 'getmembers' — no prior spec checks getmembers.__name__ in any namespace."
    - "inspect.signature.__name__ == 'signature' — no prior spec checks signature.__name__ in any namespace."
    - "inspect.getmembers.__module__ == 'inspect' — no prior spec checks getmembers.__module__."
    - "inspect.signature.__module__ == 'inspect' — no prior spec checks signature.__module__."
    - "inspect.ismodule.__qualname__ == 'ismodule' — __qualname__ for the is* predicates not yet covered in extra19 namespace."
    - "inspect.isclass.__qualname__ == 'isclass' — __qualname__ for the is* predicates."
    - "inspect.isfunction.__qualname__ == 'isfunction' — __qualname__ for the is* predicates."
    - "inspect.ismethod.__qualname__ == 'ismethod' — __qualname__ for the is* predicates."
    - "inspect.isbuiltin.__qualname__ == 'isbuiltin' — __qualname__ for the is* predicates."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.getmembers and inspect.signature — __name__ and __module__
#
# No prior inspect spec checks getmembers.__name__, getmembers.__module__,
# signature.__name__, or signature.__module__. These are core utility functions
# in the inspect module distinct from the is* predicate group.
# ---------------------------------------------------------------------------

invariant inspect_extra19.getmembers.name:
  description: "inspect.getmembers.__name__ == 'getmembers'"
  category: function_names
  kind: python_call_eq
  function: getmembers.__name__.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra19.getmembers.module:
  description: "inspect.getmembers.__module__ == 'inspect'"
  category: module_attrs
  kind: python_call_eq
  function: getmembers.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra19.signature.name:
  description: "inspect.signature.__name__ == 'signature'"
  category: function_names
  kind: python_call_eq
  function: signature.__name__.__eq__
  args: ["signature"]
  expected: true

invariant inspect_extra19.signature.module:
  description: "inspect.signature.__module__ == 'inspect'"
  category: module_attrs
  kind: python_call_eq
  function: signature.__module__.__eq__
  args: ["inspect"]
  expected: true

# ---------------------------------------------------------------------------
# inspect predicate functions — __qualname__ (inspect_extra19 namespace)
#
# inspect_extra15 covers __qualname__ for isfunction/isbuiltin/isclass/ismodule/
# ismethod/ismethoddescriptor in a table. No prior spec covers __qualname__ for
# these predicates as standalone invariants in the extra19 namespace.
# For top-level module functions, __qualname__ == __name__.
# ---------------------------------------------------------------------------

table inspect_extra19.predicate_qualnames:
  description: "__qualname__ for inspect is* predicate functions (extra19 namespace)"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [ismodule,   ismodule.__qualname__.__eq__,   ["ismodule"],   true]
    - [isclass,    isclass.__qualname__.__eq__,     ["isclass"],    true]
    - [isfunction, isfunction.__qualname__.__eq__,  ["isfunction"], true]
    - [ismethod,   ismethod.__qualname__.__eq__,    ["ismethod"],   true]
    - [isbuiltin,  isbuiltin.__qualname__.__eq__,   ["isbuiltin"],  true]

# ---------------------------------------------------------------------------
# inspect.getmembers and inspect.signature — __qualname__
#
# No prior inspect spec checks getmembers.__qualname__ or signature.__qualname__.
# For top-level module functions, __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant inspect_extra19.getmembers.qualname:
  description: "inspect.getmembers.__qualname__ == 'getmembers'"
  category: function_qualnames
  kind: python_call_eq
  function: getmembers.__qualname__.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra19.signature.qualname:
  description: "inspect.signature.__qualname__ == 'signature'"
  category: function_qualnames
  kind: python_call_eq
  function: signature.__qualname__.__eq__
  args: ["signature"]
  expected: true
