spec: orator_rust
version: ">=3.9"
backend: rust_module(orator_rust)

docs: https://orator-orm.com/

provenance:
  derived_from:
    - "https://orator-orm.com/ — Orator ORM"
  notes:
    - "Orator is an ActiveRecord ORM for Python."
    - "orator.DatabaseManager is a class."
    - "orator.Model is a class."
    - "orator.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant orator_rust.has_database_manager:
  description: "orator.DatabaseManager is a class"
  category: presence
  kind: python_call_eq
  function: orator_has_database_manager
  args: []
  expected: true

invariant orator_rust.has_model:
  description: "orator.Model is a class"
  category: presence
  kind: python_call_eq
  function: orator_has_model
  args: []
  expected: true

invariant orator_rust.version_nonempty:
  description: "orator.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: orator_version_nonempty
  args: []
  expected: true

