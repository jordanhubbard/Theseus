spec: xml_etree_extra4
version: ">=3.9"
backend: python_module(xml.etree.ElementTree)

docs: https://docs.python.org/3/library/xml.etree.elementtree.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xml.etree.elementtree.html — Python xml.etree.ElementTree documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xml/etree/ElementTree.py"
    - "elementtree.zspec.zsdl — covers fromstring tag/text/attrib/get/findtext, Element constructor, tostring, SubElement, ParseError raise behavior"
    - "xml_parse.zspec.zsdl — covers ElementTree/XMLParser/ParseError __module__, ParseError base, XMLParser feed/close, ElementTree.__bases__[0].__name__, XMLParser __name__/module, ElementTree __name__"
    - "xml_extra.zspec.zsdl — covers Element/ElementTree/SubElement/ParseError/parse/fromstring/tostring __name__ in a table; ParseError base; fromstring result class"
    - "xml_extra2.zspec.zsdl — covers fromstring('<root/>').tag, Element tag/attrib, tostring result class, ParseError class_name, VERSION/XML_VERSION class_name, SubElement __name__"
    - "xml_extra3.zspec.zsdl — covers Element/ElementTree/XMLParser/ParseError __qualname__; function __qualname__ (tostring/indent/iterparse/parse); Element/XMLParser base == 'object'; function type checks (indent/iterparse/parse/tostring); ParseError/Element is_type; Element.__module__; XMLParser.__module__"
    - "xml_extra4.zspec.zsdl — covers Element text/tail default None; fromstring text; VERSION/XML_VERSION values"
    - "xml_etree_extra.zspec.zsdl — covers Element/__name__, SubElement/__name__, parse/fromstring/tostring/indent/iterparse/register_namespace __name__, Comment/ProcessingInstruction __name__, ParseError name/base, fromstring result class, Element.__module__ is str"
    - "xml_etree_extra2.zspec.zsdl — covers SubElement/__qualname__, fromstring/__qualname__, SubElement/fromstring/tostring/parse/indent/iterparse __module__, ParseError.__module__, SubElement callable check"
    - "xml_etree_extra3.zspec.zsdl — covers register_namespace/__qualname__/__module__, Comment/__qualname__/__module__, ProcessingInstruction/__qualname__/__module__, fromstring text/tag with text, ElementTree is_type, fromstring class_name, register_namespace class_name"
  notes:
    - "This spec extends all prior xml.etree.ElementTree specs."
    - "Focus: Element instance method __name__ checks — these verify that the standard Element API methods exist with correct names."
    - "No prior spec checks the __name__ of instance methods on the Element class (get, set, find, findall, append, remove, iter, keys, items)."
    - "Element.get.__name__ == 'get' — retrieves attribute value with optional default."
    - "Element.set.__name__ == 'set' — sets an attribute key/value pair."
    - "Element.find.__name__ == 'find' — finds first subelement matching a path."
    - "Element.findall.__name__ == 'findall' — finds all subelements matching a path."
    - "Element.append.__name__ == 'append' — appends a child Element."
    - "Element.remove.__name__ == 'remove' — removes a child Element."
    - "Element.iter.__name__ == 'iter' — creates a tree iterator (added in Python 3.2)."
    - "Element.keys.__name__ == 'keys' — returns list of attribute key names."
    - "Element.items.__name__ == 'items' — returns list of (name, value) attribute pairs."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Element instance method __name__ checks
#
# No prior xml.etree spec verifies __name__ for Element's instance methods.
# xml_etree_extra.zspec.zsdl checks module-level function __name__ values
# (parse, fromstring, tostring, indent, iterparse, register_namespace) but
# does not touch any Element class method names.
# ---------------------------------------------------------------------------

table xml_etree_extra4.element_method_names:
  kind: python_call_eq
  category: function_names
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [get,     Element.get.__name__.__eq__,     ["get"],     true]
    - [set,     Element.set.__name__.__eq__,     ["set"],     true]
    - [find,    Element.find.__name__.__eq__,    ["find"],    true]
    - [findall, Element.findall.__name__.__eq__, ["findall"], true]
    - [append,  Element.append.__name__.__eq__,  ["append"],  true]
    - [remove,  Element.remove.__name__.__eq__,  ["remove"],  true]
    - [iter,    Element.iter.__name__.__eq__,    ["iter"],    true]
    - [keys,    Element.keys.__name__.__eq__,    ["keys"],    true]
    - [items,   Element.items.__name__.__eq__,   ["items"],   true]

# ---------------------------------------------------------------------------
# Element instance method __qualname__ checks
#
# xml_extra3 checks qualnames for module-level functions and top-level classes.
# No prior spec checks the __qualname__ for Element's instance methods.
# Instance methods of a class have __qualname__ == 'ClassName.method_name'.
# ---------------------------------------------------------------------------

table xml_etree_extra4.element_method_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: mqname

  columns: [id, function, args, expected]
  rows:
    - [get,     Element.get.__qualname__.__eq__,     ["Element.get"],     true]
    - [set,     Element.set.__qualname__.__eq__,     ["Element.set"],     true]
    - [find,    Element.find.__qualname__.__eq__,    ["Element.find"],    true]
    - [findall, Element.findall.__qualname__.__eq__, ["Element.findall"], true]
    - [append,  Element.append.__qualname__.__eq__,  ["Element.append"],  true]
    - [remove,  Element.remove.__qualname__.__eq__,  ["Element.remove"],  true]
    - [iter,    Element.iter.__qualname__.__eq__,    ["Element.iter"],    true]
    - [keys,    Element.keys.__qualname__.__eq__,    ["Element.keys"],    true]
    - [items,   Element.items.__qualname__.__eq__,   ["Element.items"],   true]
