spec: pathlib_extra118
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra117.zspec.zsdl."
    - "This spec covers: pathlib.Path.__truediv__, __rtruediv__, __str__, __fspath__, __repr__, __hash__, __eq__, __lt__ method qualnames."
    - "All these methods are defined on PurePath so qualnames use the 'PurePath.' prefix."
    - "pathlib.Path.__truediv__.__qualname__ == 'PurePath.__truediv__' (len 20); type 'function'."
    - "pathlib.Path.__rtruediv__.__qualname__ == 'PurePath.__rtruediv__' (len 21); type 'function'."
    - "pathlib.Path.__str__.__qualname__ == 'PurePath.__str__' (len 16); type 'function'."
    - "pathlib.Path.__fspath__.__qualname__ == 'PurePath.__fspath__' (len 19); type 'function'."
    - "pathlib.Path.__repr__.__qualname__ == 'PurePath.__repr__' (len 17); type 'function'."
    - "pathlib.Path.__hash__.__qualname__ == 'PurePath.__hash__' (len 17); type 'function'."
    - "pathlib.Path.__eq__.__qualname__ == 'PurePath.__eq__' (len 15); type 'function'."
    - "pathlib.Path.__lt__.__qualname__ == 'PurePath.__lt__' (len 15); type 'function'."
    - "__repr__ and __hash__ share qualname length 17; __eq__ and __lt__ share qualname length 15."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.__truediv__ and __rtruediv__ qualnames and types
# Both defined on PurePath; qualnames use 'PurePath.' prefix; type 'function'.
# __truediv__: 'PurePath.__truediv__' (20 chars); implements path / other.
# __rtruediv__: 'PurePath.__rtruediv__' (21 chars); implements other / path.
# ---------------------------------------------------------------------------

table pathlib_extra118.Path_truediv_rtruediv_qualnames:
  description: "pathlib.Path.__truediv__ qualname='PurePath.__truediv__'(20), __rtruediv__ qualname='PurePath.__rtruediv__'(21); both type 'function'; defined on PurePath"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn118a

  columns: [id, function, args, expected, description]
  rows:
    - [truediv_type,        "Path.__truediv__.__class__.__name__.__eq__",    ["function"],              true,  "type(pathlib.Path.__truediv__).__name__ == 'function' (pure Python method defined on PurePath)"]
    - [truediv_qn_eq,       "Path.__truediv__.__qualname__.__eq__",          ["PurePath.__truediv__"],  true,  "pathlib.Path.__truediv__.__qualname__ == 'PurePath.__truediv__' (implements path / other; defined on PurePath)"]
    - [truediv_qn_len,      "Path.__truediv__.__qualname__.__len__",         [],                        20,    "pathlib.Path.__truediv__.__qualname__.__len__() == 20 ('PurePath.__truediv__' has 20 chars)"]
    - [rtruediv_type,       "Path.__rtruediv__.__class__.__name__.__eq__",   ["function"],              true,  "type(pathlib.Path.__rtruediv__).__name__ == 'function' (pure Python method defined on PurePath)"]
    - [rtruediv_qn_eq,      "Path.__rtruediv__.__qualname__.__eq__",         ["PurePath.__rtruediv__"], true,  "pathlib.Path.__rtruediv__.__qualname__ == 'PurePath.__rtruediv__' (implements other / path; r-prefix means reflected)"]
    - [rtruediv_qn_len,     "Path.__rtruediv__.__qualname__.__len__",        [],                        21,    "pathlib.Path.__rtruediv__.__qualname__.__len__() == 21 ('PurePath.__rtruediv__' has 21 chars; longest in group a)"]
    - [rtruediv_gt_truediv, "Path.__rtruediv__.__qualname__.__len__.__gt__", [20],                      true,  "len('PurePath.__rtruediv__') > len('PurePath.__truediv__') (21 > 20; rtruediv is one char longer due to 'r' prefix)"]
    - [truediv_ne_rtruediv, "Path.__truediv__.__qualname__.__eq__",          ["PurePath.__rtruediv__"], false, "pathlib.Path.__truediv__.__qualname__ != 'PurePath.__rtruediv__' (distinct qualname strings though both implement the / path-joining operator)"]

# ---------------------------------------------------------------------------
# pathlib.Path.__str__ and __fspath__ qualnames and types
# Both defined on PurePath; qualnames use 'PurePath.' prefix; type 'function'.
# __str__: 'PurePath.__str__' (16 chars); returns string representation of the path.
# __fspath__: 'PurePath.__fspath__' (19 chars); returns the file system path string.
# ---------------------------------------------------------------------------

table pathlib_extra118.Path_str_fspath_qualnames:
  description: "pathlib.Path.__str__ qualname='PurePath.__str__'(16), __fspath__ qualname='PurePath.__fspath__'(19); both type 'function'; defined on PurePath"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn118b

  columns: [id, function, args, expected, description]
  rows:
    - [str_type,           "Path.__str__.__class__.__name__.__eq__",      ["function"],            true,  "type(pathlib.Path.__str__).__name__ == 'function' (pure Python method defined on PurePath)"]
    - [str_qn_eq,          "Path.__str__.__qualname__.__eq__",             ["PurePath.__str__"],    true,  "pathlib.Path.__str__.__qualname__ == 'PurePath.__str__' (returns the path as a string; defined on PurePath)"]
    - [str_qn_len,         "Path.__str__.__qualname__.__len__",            [],                      16,    "pathlib.Path.__str__.__qualname__.__len__() == 16 ('PurePath.__str__' has 16 chars)"]
    - [fspath_type,        "Path.__fspath__.__class__.__name__.__eq__",    ["function"],            true,  "type(pathlib.Path.__fspath__).__name__ == 'function' (pure Python method; makes Path work with os.fspath())"]
    - [fspath_qn_eq,       "Path.__fspath__.__qualname__.__eq__",          ["PurePath.__fspath__"], true,  "pathlib.Path.__fspath__.__qualname__ == 'PurePath.__fspath__' (returns os.fspath()-compatible string; defined on PurePath)"]
    - [fspath_qn_len,      "Path.__fspath__.__qualname__.__len__",         [],                      19,    "pathlib.Path.__fspath__.__qualname__.__len__() == 19 ('PurePath.__fspath__' has 19 chars)"]
    - [fspath_gt_str_len,  "Path.__fspath__.__qualname__.__len__.__gt__",  [16],                    true,  "len('PurePath.__fspath__') > len('PurePath.__str__') (19 > 16; fspath is three chars longer)"]
    - [str_ne_fspath,      "Path.__str__.__qualname__.__eq__",             ["PurePath.__fspath__"], false, "pathlib.Path.__str__.__qualname__ != 'PurePath.__fspath__' (distinct qualname strings; str returns path text, fspath satisfies os.fspath protocol)"]

# ---------------------------------------------------------------------------
# pathlib.Path.__repr__, __hash__, __eq__, __lt__ qualnames and types
# All defined on PurePath; qualnames use 'PurePath.' prefix; type 'function'.
# __repr__: 'PurePath.__repr__' (17 chars).
# __hash__: 'PurePath.__hash__' (17 chars; same length as __repr__).
# __eq__: 'PurePath.__eq__' (15 chars).
# __lt__: 'PurePath.__lt__' (15 chars; same length as __eq__).
# ---------------------------------------------------------------------------

table pathlib_extra118.Path_repr_hash_eq_lt_qualnames:
  description: "pathlib.Path __repr__='PurePath.__repr__'(17), __hash__='PurePath.__hash__'(17), __eq__='PurePath.__eq__'(15), __lt__='PurePath.__lt__'(15); all type 'function'; repr and hash share len 17; eq and lt share len 15"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn118c

  columns: [id, function, args, expected, description]
  rows:
    - [repr_qn_eq,          "Path.__repr__.__qualname__.__eq__",            ["PurePath.__repr__"],  true,  "pathlib.Path.__repr__.__qualname__ == 'PurePath.__repr__' (returns repr string like PosixPath('/usr/local'))"]
    - [repr_qn_len,         "Path.__repr__.__qualname__.__len__",           [],                     17,    "pathlib.Path.__repr__.__qualname__.__len__() == 17 ('PurePath.__repr__' has 17 chars)"]
    - [hash_qn_eq,          "Path.__hash__.__qualname__.__eq__",            ["PurePath.__hash__"],  true,  "pathlib.Path.__hash__.__qualname__ == 'PurePath.__hash__' (makes Path objects hashable and usable in sets/dicts)"]
    - [hash_qn_len,         "Path.__hash__.__qualname__.__len__",           [],                     17,    "pathlib.Path.__hash__.__qualname__.__len__() == 17 ('PurePath.__hash__' has 17 chars; same length as __repr__)"]
    - [eq_qn_eq,            "Path.__eq__.__qualname__.__eq__",              ["PurePath.__eq__"],    true,  "pathlib.Path.__eq__.__qualname__ == 'PurePath.__eq__' (implements == comparison; case-sensitive on POSIX)"]
    - [eq_qn_len,           "Path.__eq__.__qualname__.__len__",             [],                     15,    "pathlib.Path.__eq__.__qualname__.__len__() == 15 ('PurePath.__eq__' has 15 chars)"]
    - [lt_qn_eq,            "Path.__lt__.__qualname__.__eq__",              ["PurePath.__lt__"],    true,  "pathlib.Path.__lt__.__qualname__ == 'PurePath.__lt__' (implements < comparison; enables sorting of paths)"]
    - [lt_qn_len,           "Path.__lt__.__qualname__.__len__",             [],                     15,    "pathlib.Path.__lt__.__qualname__.__len__() == 15 ('PurePath.__lt__' has 15 chars; same length as __eq__)"]
    - [repr_eq_hash_len,    "Path.__repr__.__qualname__.__len__.__eq__",    [17],                   true,  "len('PurePath.__repr__') == len('PurePath.__hash__') == 17 (repr and hash share identical qualname length)"]
    - [eq_eq_lt_len,        "Path.__eq__.__qualname__.__len__.__eq__",      [15],                   true,  "len('PurePath.__eq__') == len('PurePath.__lt__') == 15 (eq and lt share identical qualname length)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra118.Path.truediv_qualname:
  description: "pathlib.Path.__truediv__.__qualname__ == 'PurePath.__truediv__' (length 20; type is 'function'; __truediv__ is defined on PurePath and inherited by Path; it implements the / operator for path joining, e.g. Path('/usr') / 'local' == Path('/usr/local'); 'PurePath.' (9) + '__truediv__' (11) == 20)"
  category: qualnames
  kind: python_call_eq
  function: "Path.__truediv__.__qualname__.__eq__"
  args: ["PurePath.__truediv__"]
  expected: true

invariant pathlib_extra118.Path.rtruediv_qualname_len:
  description: "pathlib.Path.__rtruediv__.__qualname__.__len__() == 21 ('PurePath.__rtruediv__' has 21 characters; 'PurePath.' (9) + '__rtruediv__' (12) == 21; __rtruediv__ is the reflected division operator implementing other / path, e.g. '/usr' / Path('local'); it is one char longer than __truediv__ at 20)"
  category: qualnames
  kind: python_call_eq
  function: "Path.__rtruediv__.__qualname__.__len__"
  args: []
  expected: 21

invariant pathlib_extra118.Path.str_qualname_len:
  description: "pathlib.Path.__str__.__qualname__.__len__() == 16 ('PurePath.__str__' has 16 characters; 'PurePath.' (9) + '__str__' (7) == 16; type is 'function'; __str__ returns the file system path string and is used when str() is called on a Path object)"
  category: qualnames
  kind: python_call_eq
  function: "Path.__str__.__qualname__.__len__"
  args: []
  expected: 16

invariant pathlib_extra118.Path.fspath_qualname_len:
  description: "pathlib.Path.__fspath__.__qualname__.__len__() == 19 ('PurePath.__fspath__' has 19 characters; 'PurePath.' (9) + '__fspath__' (10) == 19; type is 'function'; __fspath__ implements the os.PathLike protocol enabling Path objects to be used anywhere os.fspath() is accepted)"
  category: qualnames
  kind: python_call_eq
  function: "Path.__fspath__.__qualname__.__len__"
  args: []
  expected: 19

invariant pathlib_extra118.Path.repr_hash_share_qualname_len:
  description: "pathlib.Path.__repr__.__qualname__.__len__() == 17 and pathlib.Path.__hash__.__qualname__.__len__() == 17 ('PurePath.__repr__' and 'PurePath.__hash__' both have 17 characters; 'PurePath.' (9) + '__repr__' (8) == 17 and 'PurePath.' (9) + '__hash__' (8) == 17; repr and hash share the same qualname length; both are pure Python functions defined on PurePath)"
  category: qualnames
  kind: python_call_eq
  function: "Path.__repr__.__qualname__.__len__"
  args: []
  expected: 17
