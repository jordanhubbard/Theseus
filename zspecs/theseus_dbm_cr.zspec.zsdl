spec: theseus_dbm_cr
version: ">=3.0"
backend: python_cleanroom(theseus_dbm_cr)
blocks: dbm

docs: https://docs.python.org/3/library/dbm.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/dbm.html"
  not_derived_from:
    - "CPython source: Lib/dbm/__init__.py"
  notes:
    - "Clean-room dbm module. Do NOT import dbm."

error_model: python_exceptions

invariant theseus_dbm_cr.dbm2_open:
  description: "open() creates a dbm database and supports key-value store"
  category: behavior
  kind: python_call_eq
  function: dbm2_open
  args: []
  expected: true

invariant theseus_dbm_cr.dbm2_error:
  description: "dbm.error exception class exists"
  category: behavior
  kind: python_call_eq
  function: dbm2_error
  args: []
  expected: true

invariant theseus_dbm_cr.dbm2_whichdb:
  description: "whichdb() is callable"
  category: behavior
  kind: python_call_eq
  function: dbm2_whichdb
  args: []
  expected: true
