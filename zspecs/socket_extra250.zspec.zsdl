spec: socket_extra250
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra249.zspec.zsdl — covers socket module convenience function identity — gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout/__module__=='_socket' and getfqdn/getaddrinfo/create_connection/socketpair/__module__=='socket' (table + invariants)."
    - "socket_extra248.zspec.zsdl — covers socket error class identity / AF_UNIX and SHUT_* constants / SOL_SOCKET and SOMAXCONN constants (table + invariants)."
  notes:
    - "Wave 295 theme: socket.socket instance method identity — connect, bind, listen, accept, send, recv, close, setsockopt, getsockopt, settimeout, gettimeout."
    - "socket.socket.connect.__name__ == 'connect'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__qualname__ == 'socket.connect'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__name__ == 'bind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__name__ == 'listen'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__name__ == 'accept'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.send.__name__ == 'send'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.send.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__name__ == 'recv'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__name__ == 'close'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__name__ == 'setsockopt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockopt.__name__ == 'getsockopt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockopt.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__name__ == 'settimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.gettimeout.__name__ == 'gettimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.gettimeout.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket is the Python wrapper class defined in Lib/socket.py. Most of its methods (connect, bind, listen, send, recv, setsockopt, getsockopt, settimeout, gettimeout) are method_descriptors from the underlying _socket.socket C type in Modules/socketmodule.c. However, accept and close are Python functions (__class__.__name__=='function') defined in Lib/socket.py — they wrap the underlying C methods to add Python-level logic (e.g., close() calls self._real_close() and sets self.fd=-1)."
    - "Note: socket.socket.__qualname__ for method_descriptors follows the pattern 'socket.<method>' — the class name in __qualname__ is 'socket' (referring to the underlying _socket.socket type), not 'socket.socket' (the Python wrapper class)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket C-backed method identity: connect, bind, listen, send, recv,
# setsockopt, getsockopt, settimeout, gettimeout
#
# Wave 295 theme: socket.socket C-backed methods (__class__.__name__=='method_descriptor').
#
# The majority of socket.socket instance methods are C-backed method_descriptors
# from Modules/socketmodule.c, exposed through the _socket.socket type.
# connect() establishes a connection; bind() assigns a local address; listen()
# marks the socket as passive; send() and recv() transfer data; setsockopt() and
# getsockopt() control socket options; settimeout() and gettimeout() manage the
# blocking/timeout mode. No prior spec anchors __name__ and __class__.__name__
# for these nine methods together in a grouped table under sockmethod295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra250.socket_c_method_identity:
  description: "socket.connect.__name__.__eq__('connect')==True / socket.connect.__class__.__name__.__eq__('method_descriptor')==True / socket.bind.__name__.__eq__('bind')==True / socket.listen.__name__.__eq__('listen')==True / socket.send.__name__.__eq__('send')==True / socket.recv.__name__.__eq__('recv')==True / socket.setsockopt.__name__.__eq__('setsockopt')==True / socket.getsockopt.__name__.__eq__('getsockopt')==True / socket.settimeout.__name__.__eq__('settimeout')==True / socket.gettimeout.__name__.__eq__('gettimeout')==True — all nine are method_descriptors from _socket.socket (C); contrasts with accept/close which are pure Python functions; first sockmethod295 anchor for socket C-backed method identity"
  kind: python_call_eq
  category: method_identity
  id_prefix: sockmethod295

  columns: [id, function, args, expected, description]
  rows:
    - [connect_name_eq,      "socket.connect.__name__.__eq__",        ["connect"],           true, "socket.socket.connect.__name__ is 'connect' (C method; establishes connection to address)"]
    - [connect_class_eq,     "socket.connect.__class__.__name__.__eq__", ["method_descriptor"], true, "socket.socket.connect is a method_descriptor (C-backed from _socket.socket)"]
    - [bind_name_eq,         "socket.bind.__name__.__eq__",           ["bind"],              true, "socket.socket.bind.__name__ is 'bind' (C method; assigns local address to socket)"]
    - [bind_class_eq,        "socket.bind.__class__.__name__.__eq__", ["method_descriptor"], true, "socket.socket.bind is a method_descriptor"]
    - [listen_name_eq,       "socket.listen.__name__.__eq__",         ["listen"],            true, "socket.socket.listen.__name__ is 'listen' (C method; marks socket as passive/server)"]
    - [listen_class_eq,      "socket.listen.__class__.__name__.__eq__", ["method_descriptor"], true, "socket.socket.listen is a method_descriptor"]
    - [send_name_eq,         "socket.send.__name__.__eq__",           ["send"],              true, "socket.socket.send.__name__ is 'send' (C method; sends data to connected socket)"]
    - [send_class_eq,        "socket.send.__class__.__name__.__eq__", ["method_descriptor"], true, "socket.socket.send is a method_descriptor"]
    - [recv_name_eq,         "socket.recv.__name__.__eq__",           ["recv"],              true, "socket.socket.recv.__name__ is 'recv' (C method; receives data from connected socket)"]
    - [recv_class_eq,        "socket.recv.__class__.__name__.__eq__", ["method_descriptor"], true, "socket.socket.recv is a method_descriptor"]
    - [setsockopt_name_eq,   "socket.setsockopt.__name__.__eq__",     ["setsockopt"],        true, "socket.socket.setsockopt.__name__ is 'setsockopt' (C method; sets socket option)"]
    - [setsockopt_class_eq,  "socket.setsockopt.__class__.__name__.__eq__", ["method_descriptor"], true, "socket.socket.setsockopt is a method_descriptor"]
    - [getsockopt_name_eq,   "socket.getsockopt.__name__.__eq__",     ["getsockopt"],        true, "socket.socket.getsockopt.__name__ is 'getsockopt' (C method; retrieves socket option)"]
    - [settimeout_name_eq,   "socket.settimeout.__name__.__eq__",     ["settimeout"],        true, "socket.socket.settimeout.__name__ is 'settimeout' (C method; sets blocking/timeout mode)"]
    - [settimeout_class_eq,  "socket.settimeout.__class__.__name__.__eq__", ["method_descriptor"], true, "socket.socket.settimeout is a method_descriptor"]
    - [gettimeout_name_eq,   "socket.gettimeout.__name__.__eq__",     ["gettimeout"],        true, "socket.socket.gettimeout.__name__ is 'gettimeout' (C method; returns current timeout)"]
    - [gettimeout_class_eq,  "socket.gettimeout.__class__.__name__.__eq__", ["method_descriptor"], true, "socket.socket.gettimeout is a method_descriptor"]

# ---------------------------------------------------------------------------
# socket.socket Python-function method identity: accept and close
#
# Wave 295 theme: socket.socket.accept and socket.socket.close are pure
# Python functions (__class__.__name__=='function'), not method_descriptors.
#
# accept() and close() are defined in Lib/socket.py as Python methods on the
# socket.socket wrapper class. accept() wraps the underlying C accept to return
# a (socket, address) pair where the new socket is wrapped in a Python socket
# object. close() manages the file descriptor lifecycle (calls self._real_close()
# and updates internal state). Their __class__.__name__ is 'function', not
# 'method_descriptor'. This is a notable distinction from the other socket
# methods. No prior spec anchors accept and close __class__.__name__ together
# in a grouped table under sockmethod295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra250.socket_python_method_identity:
  description: "socket.accept.__name__.__eq__('accept')==True / socket.accept.__class__.__name__.__eq__('function')==True / socket.close.__name__.__eq__('close')==True / socket.close.__class__.__name__.__eq__('function')==True — accept and close are pure Python functions defined in Lib/socket.py (not C method_descriptors); accept wraps C accept to return (socket, address) with Python socket wrapper; close manages fd lifecycle; __class__.__name__=='function' contrasts with method_descriptor for connect/bind/send/recv; first sockmethod295 anchor for Python-function method identity"
  kind: python_call_eq
  category: method_identity
  id_prefix: sockmethod295

  columns: [id, function, args, expected, description]
  rows:
    - [accept_name_eq,    "socket.accept.__name__.__eq__",             ["accept"],   true, "socket.socket.accept.__name__ is 'accept' (Python wrapper in Lib/socket.py)"]
    - [accept_class_eq,   "socket.accept.__class__.__name__.__eq__",   ["function"], true, "socket.socket.accept.__class__.__name__ is 'function' (pure Python, not method_descriptor)"]
    - [close_name_eq,     "socket.close.__name__.__eq__",              ["close"],    true, "socket.socket.close.__name__ is 'close' (Python function managing fd lifecycle)"]
    - [close_class_eq,    "socket.close.__class__.__name__.__eq__",    ["function"], true, "socket.socket.close.__class__.__name__ is 'function' (pure Python, not method_descriptor)"]

# ---------------------------------------------------------------------------
# socket.socket.__qualname__ pattern: method_descriptor methods use
# 'socket.<method>' (underlying C type) not 'socket.socket.<method>'
#
# Wave 295 theme: socket.socket C-method __qualname__ uses 'socket.' prefix
# (the underlying _socket.socket type name, not the Python wrapper).
#
# For method_descriptor methods on socket.socket, the __qualname__ is
# 'socket.connect', 'socket.bind', etc. — where 'socket' refers to the name
# of the _socket.socket C type (whose __name__ is 'socket'), not the Python
# module or wrapper class. This means socket.socket.connect.__qualname__ is
# 'socket.connect' (5 characters in the prefix) rather than
# 'socket.socket.connect'. No prior spec anchors connect and recv __qualname__
# as standalones under sockmethod295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra250.socket_connect_qualname_eq:
  description: "socket.socket.connect.__qualname__.__eq__('socket.connect') == True — __qualname__ for method_descriptor on socket.socket uses 'socket.' (the _socket.socket C type __name__) not 'socket.socket.'; connect.__qualname__=='socket.connect'; accept.__qualname__=='socket.accept' (Python function qualname also uses single 'socket.' prefix); first standalone anchor for connect.__qualname__ under sockmethod295"
  category: method_identity
  kind: python_call_eq
  function: "socket.connect.__qualname__.__eq__"
  args: ["socket.connect"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.recv.__qualname__.__eq__('socket.recv') — standalone
#
# socket.socket.recv.__qualname__ is 'socket.recv'. recv is the primary data
# reception method for connected sockets. It is a C method_descriptor from
# Modules/socketmodule.c. recv(bufsize[, flags]) blocks until data arrives (in
# blocking mode) or raises BlockingIOError (in non-blocking mode). The maximum
# number of bytes received is bufsize. Like all socket.socket method_descriptors,
# its __qualname__ uses the 'socket.' prefix (the C type name) not 'socket.socket.'.
# No prior spec anchors recv.__qualname__ as a standalone under sockmethod295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra250.socket_recv_qualname_eq:
  description: "socket.socket.recv.__qualname__.__eq__('socket.recv') == True — recv is a C method_descriptor from socketmodule.c; __qualname__=='socket.recv' (not 'socket.socket.recv'); recv(bufsize[, flags]) blocks until data arrives in blocking mode; first standalone anchor for recv.__qualname__ under sockmethod295"
  category: method_identity
  kind: python_call_eq
  function: "socket.recv.__qualname__.__eq__"
  args: ["socket.recv"]
  expected: true
