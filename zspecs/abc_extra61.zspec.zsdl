spec: abc_extra61
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python code object co_consts, co_nlocals, and co_stacksize documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra60.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all abc exports, abstractproperty/abstractclassmethod/abstractstaticmethod lengths/qualnames/bases, ABCMeta.register qualname lengths/equality, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2)/abstractproperty(3)/abstractclassmethod(3)/abstractstaticmethod(3), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() tables, ABCMeta/__dict__.__class__.__name__.__eq__('mappingproxy') (extra9), ABC/__dict__.__class__.__name__.__eq__('mappingproxy') (extra8), ABCMeta/__dict__.__class__.__qualname__ and ABC/__dict__.__class__.__qualname__ (extra49), abstractproperty/abstractclassmethod/abstractstaticmethod __dict__.__class__.__name__.__eq__('mappingproxy') (extra49), abc module __dict__.__class__.__name__/__qualname__ (extra49), abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta' (extra40), __class__.__qualname__ string equality for all abc exports (extra41-extra43), abstractmethod/__class__.__module__=='builtins', abstractproperty/__class__.__module__=='builtins', ABC/__class__.__module__=='abc', ABCMeta/__class__.__module__=='builtins', abstractclassmethod/__class__.__module__=='builtins', abstractstaticmethod/__class__.__module__=='builtins' (extra42), abstractproperty/__init__.__class__.__name__=='wrapper_descriptor', abstractmethod/__init__.__class__.__name__=='method-wrapper' (extra50), __class__.__module__.__len__() cross-checks (extra50), __repr__.__class__.__name__ for all abc objects (extra51), __weakref__.__class__.__name__ for abstractproperty/abstractclassmethod/abstractstaticmethod (extra51), ABCMeta.__instancecheck__/__subclasscheck__.__class__.__name__.__eq__('function') (extra52), ABC/ABCMeta __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra52), abc.__package__.__eq__('') (extra53), ABC/ABCMeta/abstractmethod/get_cache_token __doc__.__class__.__name__.__eq__('str') (extra53), ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') (extra53), __loader__.__class__.__name__.__eq__('type') (extra54), __loader__.__name__.__eq__('FrozenImporter') (extra54), __spec__.__class__.__name__.__eq__('ModuleSpec') (extra54), __file__.__class__.__name__.__eq__('str') (extra54), ABCMeta.__instancecheck__.__qualname__.__len__()==25 (extra54), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__name__.__len__() (extra55), ABCMeta.register/__instancecheck__/__subclasscheck__/update_abstractmethods __qualname__.__eq__ (extra56), abstractproperty.__init__.__qualname__.__eq__('property.__init__') (extra56), abstractmethod/__annotations__/__globals__ class identity, ABCMeta/__doc__.__contains__('Abstract'), get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') (extra57), abstractmethod/__defaults__/__code__/__closure__/__class__.__name__ checks, update_abstractmethods/__defaults__/__code__/__class__.__name__ checks (extra58), abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ __code__.co_name equality and co_argcount values (extra59), abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ co_varnames/co_filename/co_flags attribute chains (extra60)."
    - "This spec covers (abccode4_61 namespace): wave 232 theme — __code__.co_consts, co_nlocals, co_stacksize attribute chains, plus ABC/ABCMeta class __doc__ content checks. NEW in extra61: abstractmethod.__code__.co_consts.__class__.__name__=='tuple' — co_consts is always a tuple; update_abstractmethods.__code__.co_consts.__class__.__name__=='tuple'; ABCMeta.__instancecheck__.__code__.co_consts.__class__.__name__=='tuple'; all three functions co_nlocals.__class__.__name__=='int'; all three functions co_stacksize.__class__.__name__=='int'; ABCMeta.__doc__.__class__.__name__=='str'; ABCMeta.__doc__.__contains__('Abstract')==True; ABC.__doc__.__class__.__name__=='str'; ABC.__doc__.__contains__('ABC')==True."
    - "abc.abstractmethod.__code__.co_consts.__class__.__name__ == 'tuple'. co_consts is a tuple of constants (literals, nested code objects, None, etc.) used by the code object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_nlocals.__class__.__name__ == 'int'. co_nlocals is the number of local variables (including parameters) used by the function, stored as a plain Python int. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_stacksize.__class__.__name__ == 'int'. co_stacksize is the required stack size (the maximum number of stack entries needed during execution), stored as a plain Python int. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__doc__.__contains__('Abstract') == True. ABCMeta.__doc__ is a non-empty string; the docstring contains 'Abstract' (from the class description of the Abstract Base Class metaclass). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__doc__.__contains__('ABC') == True. ABC is defined with 'Helper class that provides a standard way to create an ABC using inheritance, if desired.' — the docstring contains 'ABC'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc __code__.co_consts.__class__.__name__ checks — extra61
#
# Wave 232 theme: co_consts type identity.
#
# co_consts is always a tuple of constants (literals, nested code objects,
# None, etc.) used by the code object.
# tuple.__class__.__name__ == 'tuple'.
# ---------------------------------------------------------------------------

table abc_extra61.co_consts_class_name:
  description: "abc __code__.co_consts.__class__.__name__.__eq__('tuple') checks in abccode4_61 namespace — wave 232 theme: co_consts type identity; co_consts is always a tuple on all code objects; abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ all have co_consts.__class__.__name__=='tuple'; NEW in extra61: no prior abc spec has checked __code__.co_consts.__class__.__name__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abccode4_61

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_co_consts_class,  abstractmethod.__code__.co_consts.__class__.__name__.__eq__,            ["tuple"], true, "abstractmethod.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is a tuple of constants (literals, nested code objects, None, etc.) used by the code object; abstractmethod.__code__.co_consts is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra61: first co_consts.__class__.__name__ check for abstractmethod in any abc spec; verified with Python 3.14.3"]
    - [uam_co_consts_class,             update_abstractmethods.__code__.co_consts.__class__.__name__.__eq__,    ["tuple"], true, "update_abstractmethods.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is always a tuple; update_abstractmethods.__code__.co_consts is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra61: first co_consts.__class__.__name__ check for update_abstractmethods in any abc spec; verified with Python 3.14.3"]
    - [instancecheck_co_consts_class,   ABCMeta.__instancecheck__.__code__.co_consts.__class__.__name__.__eq__, ["tuple"], true, "ABCMeta.__instancecheck__.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is always a tuple; ABCMeta.__instancecheck__.__code__.co_consts is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra61: first co_consts.__class__.__name__ check for ABCMeta.__instancecheck__ in any abc spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc __code__.co_nlocals.__class__.__name__ checks — extra61
#
# Wave 232 theme: co_nlocals type identity.
#
# co_nlocals is the count of local variables (including parameters) used by
# the function. It is always a plain Python int.
# int.__class__.__name__ == 'int'.
# ---------------------------------------------------------------------------

table abc_extra61.co_nlocals_class_name:
  description: "abc __code__.co_nlocals.__class__.__name__.__eq__('int') checks in abccode4_61 namespace — wave 232 theme: co_nlocals type identity; co_nlocals is the count of local variables (including parameters); abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ all have co_nlocals.__class__.__name__=='int'; NEW in extra61: no prior abc spec has checked __code__.co_nlocals.__class__.__name__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abccode4_61a

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_co_nlocals_class,  abstractmethod.__code__.co_nlocals.__class__.__name__.__eq__,            ["int"], true, "abstractmethod.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals is the number of local variables (including parameters) used by the function, stored as a plain Python int; abstractmethod.__code__.co_nlocals is an int; int.__class__.__name__ is 'int'; NEW in extra61: first co_nlocals.__class__.__name__ check for abstractmethod in any abc spec; verified with Python 3.14.3"]
    - [uam_co_nlocals_class,             update_abstractmethods.__code__.co_nlocals.__class__.__name__.__eq__,    ["int"], true, "update_abstractmethods.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals is always an int; update_abstractmethods.__code__.co_nlocals is an int; int.__class__.__name__ is 'int'; NEW in extra61: first co_nlocals.__class__.__name__ check for update_abstractmethods in any abc spec; verified with Python 3.14.3"]
    - [instancecheck_co_nlocals_class,   ABCMeta.__instancecheck__.__code__.co_nlocals.__class__.__name__.__eq__, ["int"], true, "ABCMeta.__instancecheck__.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals is always an int; ABCMeta.__instancecheck__.__code__.co_nlocals is an int; int.__class__.__name__ is 'int'; NEW in extra61: first co_nlocals.__class__.__name__ check for ABCMeta.__instancecheck__ in any abc spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc __code__.co_stacksize.__class__.__name__ checks — extra61
#
# Wave 232 theme: co_stacksize type identity.
#
# co_stacksize is the required stack size (the maximum number of stack
# entries needed during execution). It is always a plain Python int.
# int.__class__.__name__ == 'int'.
# ---------------------------------------------------------------------------

table abc_extra61.co_stacksize_class_name:
  description: "abc __code__.co_stacksize.__class__.__name__.__eq__('int') checks in abccode4_61 namespace — wave 232 theme: co_stacksize type identity; co_stacksize is the required stack size for code execution; abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ all have co_stacksize.__class__.__name__=='int'; NEW in extra61: no prior abc spec has checked __code__.co_stacksize.__class__.__name__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abccode4_61b

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_co_stacksize_class,  abstractmethod.__code__.co_stacksize.__class__.__name__.__eq__,            ["int"], true, "abstractmethod.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is the required stack size (maximum number of stack entries needed during execution), stored as a plain Python int; abstractmethod.__code__.co_stacksize is an int; int.__class__.__name__ is 'int'; NEW in extra61: first co_stacksize.__class__.__name__ check for abstractmethod in any abc spec; verified with Python 3.14.3"]
    - [uam_co_stacksize_class,             update_abstractmethods.__code__.co_stacksize.__class__.__name__.__eq__,    ["int"], true, "update_abstractmethods.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is always an int; update_abstractmethods.__code__.co_stacksize is an int; int.__class__.__name__ is 'int'; NEW in extra61: first co_stacksize.__class__.__name__ check for update_abstractmethods in any abc spec; verified with Python 3.14.3"]
    - [instancecheck_co_stacksize_class,   ABCMeta.__instancecheck__.__code__.co_stacksize.__class__.__name__.__eq__, ["int"], true, "ABCMeta.__instancecheck__.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is always an int; ABCMeta.__instancecheck__.__code__.co_stacksize is an int; int.__class__.__name__ is 'int'; NEW in extra61: first co_stacksize.__class__.__name__ check for ABCMeta.__instancecheck__ in any abc spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABC/ABCMeta class __doc__ content checks — extra61
#
# Wave 232 theme: class docstring type and content.
#
# ABCMeta has a docstring containing 'Abstract' (from the ABCMeta description
# of Abstract Base Class metaclass behavior).
# ABC has a docstring: "Helper class that provides a standard way to create an
# ABC using inheritance, if desired." — the text contains 'ABC'.
# ---------------------------------------------------------------------------

table abc_extra61.abc_class_doc_contains:
  description: "abc ABC/ABCMeta __doc__.__class__.__name__ and __doc__.__contains__ checks in abccode4_61 namespace — wave 232 theme: class docstring type and content; ABCMeta.__doc__ is a str containing 'Abstract'; ABC.__doc__ is a str containing 'ABC'; NEW in extra61: these specific __doc__.__contains__ checks (for ABCMeta with 'Abstract' and ABC with 'ABC') have not appeared in prior abc code-attribute specs under the abccode4_61 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abccode4_61c

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_doc_class,    ABCMeta.__doc__.__class__.__name__.__eq__, ["str"],      true, "ABCMeta.__doc__.__class__.__name__ == 'str' — ABCMeta has a docstring; the docstring is a plain Python str; str.__class__.__name__ is 'str'; NEW in extra61: first __doc__.__class__.__name__ check for ABCMeta in abccode4_61 namespace; verified with Python 3.14.3"]
    - [abcmeta_doc_contains, ABCMeta.__doc__.__contains__,              ["Abstract"], true, "ABCMeta.__doc__.__contains__('Abstract') == True — ABCMeta.__doc__ is a non-empty string describing the Abstract Base Class metaclass; the docstring contains 'Abstract'; __contains__('Abstract') returns True; NEW in extra61: first __doc__.__contains__('Abstract') check for ABCMeta in abccode4_61 namespace; verified with Python 3.14.3"]
    - [abc_doc_class,        ABC.__doc__.__class__.__name__.__eq__,     ["str"],      true, "ABC.__doc__.__class__.__name__ == 'str' — ABC is defined with 'Helper class that provides a standard way to create an ABC using inheritance, if desired.' — the docstring is a plain Python str; str.__class__.__name__ is 'str'; NEW in extra61: first __doc__.__class__.__name__ check for ABC in abccode4_61 namespace; verified with Python 3.14.3"]
    - [abc_doc_contains,     ABC.__doc__.__contains__,                  ["ABC"],      true, "ABC.__doc__.__contains__('ABC') == True — ABC.__doc__ is 'Helper class that provides a standard way to create an ABC using inheritance, if desired.'; the docstring mentions 'ABC' by name; __contains__('ABC') returns True; NEW in extra61: first __doc__.__contains__('ABC') check for ABC in abccode4_61 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra61
# ---------------------------------------------------------------------------

invariant abc_extra61.abstractmethod_co_consts_tuple:
  description: "abc.abstractmethod.__code__.co_consts.__class__.__name__.__eq__('tuple') returns True — co_consts is a tuple of constants (literals, nested code objects, None, etc.) used by the code object; abstractmethod.__code__.co_consts is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra61: no prior abc spec has checked abstractmethod.__code__.co_consts.__class__.__name__ via __eq__; wave 232 first co_consts type identity invariant for abstractmethod; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: abstractmethod.__code__.co_consts.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant abc_extra61.abstractmethod_co_nlocals_int:
  description: "abc.abstractmethod.__code__.co_nlocals.__class__.__name__.__eq__('int') returns True — co_nlocals is the number of local variables (including parameters) used by the function, stored as a plain Python int; abstractmethod.__code__.co_nlocals is an int; int.__class__.__name__ is 'int'; NEW in extra61: no prior abc spec has checked abstractmethod.__code__.co_nlocals.__class__.__name__ via __eq__; wave 232 first co_nlocals type identity invariant for abstractmethod; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: abstractmethod.__code__.co_nlocals.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant abc_extra61.abstractmethod_co_stacksize_int:
  description: "abc.abstractmethod.__code__.co_stacksize.__class__.__name__.__eq__('int') returns True — co_stacksize is the required stack size (maximum number of stack entries needed during execution), stored as a plain Python int; abstractmethod.__code__.co_stacksize is an int; int.__class__.__name__ is 'int'; NEW in extra61: no prior abc spec has checked abstractmethod.__code__.co_stacksize.__class__.__name__ via __eq__; wave 232 first co_stacksize type identity invariant for abstractmethod; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: abstractmethod.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant abc_extra61.ABCMeta_doc_Abstract:
  description: "abc.ABCMeta.__doc__.__contains__('Abstract') returns True — ABCMeta.__doc__ is a non-empty string describing the Abstract Base Class metaclass; the docstring text contains 'Abstract'; __contains__('Abstract') returns True; NEW in extra61: no prior abc spec has checked ABCMeta.__doc__.__contains__('Abstract') as a standalone invariant in the abccode4_61 namespace; wave 232 first __doc__ content invariant for ABCMeta; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ABCMeta.__doc__.__contains__
  args: ["Abstract"]
  expected: true

invariant abc_extra61.ABC_doc_ABC:
  description: "abc.ABC.__doc__.__contains__('ABC') returns True — ABC.__doc__ is 'Helper class that provides a standard way to create an ABC using inheritance, if desired.'; the docstring text mentions 'ABC' by name; __contains__('ABC') returns True; NEW in extra61: no prior abc spec has checked ABC.__doc__.__contains__('ABC') as a standalone invariant in the abccode4_61 namespace; wave 232 first __doc__ content invariant for ABC; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ABC.__doc__.__contains__
  args: ["ABC"]
  expected: true
