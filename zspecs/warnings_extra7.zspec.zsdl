spec: warnings_extra7
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Python/_warnings.c"
  notes:
    - "This spec extends warnings.zspec.zsdl through warnings_extra6.zspec.zsdl."
    - "Prior specs cover: __name__ for all public functions and classes (warnings + warnings_extra + warnings_extra4); __module__ for warn/warn_explicit/showwarning/formatwarning/filterwarnings/simplefilter/resetwarnings (warnings_extra2 + warnings_extra6); __qualname__ for all public functions/classes (warnings_extra5 + warnings_extra6); warning category __qualname__ (warnings_extra6); __class__.__name__ for warning categories (warnings_extra5); __bases__ for catch_warnings/DeprecationWarning (warnings_extra + warnings_extra2); defaultaction/filters/onceregistry type checks (warnings + warnings_extra); internal __name__ for _filters_mutated/_formatwarnmsg_impl (warnings_extra2)."
    - "This spec adds new axes: warn.__class__.__name__ (builtin_function_or_method — warn is C-implemented); warn_explicit.__class__.__name__ (builtin_function_or_method); _formatwarnmsg_impl.__module__ ('_py_warnings'); _formatwarnmsg_impl.__qualname__ ('_formatwarnmsg_impl'); _filters_mutated.__module__ ('_py_warnings'); warnings.__spec__.name ('warnings'); warnings.__file__.__class__.__name__ ('str')."
    - "warnings.warn.__class__.__name__ == 'builtin_function_or_method' — warn is implemented in the C extension _warnings."
    - "warnings.warn_explicit.__class__.__name__ == 'builtin_function_or_method' — also C-implemented."
    - "warnings._formatwarnmsg_impl.__module__ == '_py_warnings' — defined in the Python-layer of warnings, reported as _py_warnings internally."
    - "warnings._filters_mutated.__module__ == '_py_warnings' — the Python-layer C-bridge function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# warn and warn_explicit — __class__.__name__
#
# Both warn and warn_explicit are implemented in the C extension _warnings;
# they are C builtins, not Python functions. Their __class__.__name__ is
# 'builtin_function_or_method', not 'function'.
# Prior specs checked __name__ and __module__ for these; this adds type check.
# ---------------------------------------------------------------------------

invariant warnings_extra7.warn.class_name:
  description: "warnings.warn.__class__.__name__ == 'builtin_function_or_method'"
  category: function_types
  kind: python_call_eq
  function: warn.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant warnings_extra7.warn_explicit.class_name:
  description: "warnings.warn_explicit.__class__.__name__ == 'builtin_function_or_method'"
  category: function_types
  kind: python_call_eq
  function: warn_explicit.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# _formatwarnmsg_impl — __module__ and __qualname__
#
# _formatwarnmsg_impl is the internal Python-layer implementation of warning
# message formatting. Its __module__ is '_py_warnings' (the internal name for
# the Python-layer of the warnings module). Its __qualname__ is the simple
# function name with no enclosing scope.
# Prior spec (warnings_extra2) checked __name__ only.
# ---------------------------------------------------------------------------

invariant warnings_extra7._formatwarnmsg_impl.module:
  description: "warnings._formatwarnmsg_impl.__module__ == '_py_warnings'"
  category: internal_modules
  kind: python_call_eq
  function: _formatwarnmsg_impl.__module__.__eq__
  args: ["_py_warnings"]
  expected: true

invariant warnings_extra7._formatwarnmsg_impl.qualname:
  description: "warnings._formatwarnmsg_impl.__qualname__ == '_formatwarnmsg_impl'"
  category: internal_qualnames
  kind: python_call_eq
  function: _formatwarnmsg_impl.__qualname__.__eq__
  args: ["_formatwarnmsg_impl"]
  expected: true

# ---------------------------------------------------------------------------
# _filters_mutated — __module__
#
# _filters_mutated is an internal C-bridge function that signals filter list
# changes. Its __module__ is '_py_warnings'.
# Prior spec (warnings_extra2) checked __name__ only.
# ---------------------------------------------------------------------------

invariant warnings_extra7._filters_mutated.module:
  description: "warnings._filters_mutated.__module__ == '_py_warnings'"
  category: internal_modules
  kind: python_call_eq
  function: _filters_mutated.__module__.__eq__
  args: ["_py_warnings"]
  expected: true

# ---------------------------------------------------------------------------
# warnings module-level metadata
# warnings.__spec__.name records the canonical import name.
# warnings.__file__ is a str path (warnings is a source module).
# ---------------------------------------------------------------------------

invariant warnings_extra7.spec_name:
  description: "warnings.__spec__.name == 'warnings'"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["warnings"]
  expected: true

invariant warnings_extra7.file_is_str:
  description: "warnings.__file__.__class__.__name__ == 'str'"
  category: module_attrs
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# onceregistry — dict type (additional type axis not previously verified)
#
# warnings.onceregistry is a dict tracking already-shown warnings for
# 'once' filters. The warnings.zspec.zsdl already checks __class__.__name__
# for onceregistry; this spec verifies the dict method __len__ is >=0.
# ---------------------------------------------------------------------------

invariant warnings_extra7.onceregistry.len_nonneg:
  description: "len(warnings.onceregistry) >= 0 — onceregistry is an empty or small dict"
  category: constants
  kind: python_call_eq
  function: onceregistry.__len__().__ge__
  args: [0]
  expected: true
