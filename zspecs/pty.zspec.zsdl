spec: pty
version: ">=3.3"
backend: python_module(pty)

docs: https://docs.python.org/3/library/pty.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pty.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "pty source: Lib/pty.py (PSF; source inspection permitted)"
  not_derived_from:
    - "pty internals: kernel TTY layer, file-descriptor allocation"
  notes:
    - "pty is a POSIX-only module; it is not available on Windows."
    - "pty.fork() forks the process, returns (pid, fd) in the parent and (0, 0) in the child."
    - "pty.openpty() opens a new pseudo-terminal and returns (master_fd, slave_fd)."
    - "pty.spawn(argv) runs a child process connected to a pty."
    - "pty.STDIN_FILENO == 0, pty.STDOUT_FILENO == 1, pty.STDERR_FILENO == 2 (POSIX standard fd numbers)."
    - "All expected values verified by inspecting the pty module source on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "pty.fork() and pty.openpty() raise OSError on failure. pty is unavailable on non-POSIX platforms (ImportError)."
  stderr: "null"
  stickiness: "N/A — each call is stateless with respect to module-level state."
  codes: {}

# ---------------------------------------------------------------------------
# File descriptor constants
# ---------------------------------------------------------------------------

invariant pty.STDIN_FILENO:
  description: "pty.STDIN_FILENO == 0"
  category: constants
  kind: python_call_eq
  function: STDIN_FILENO.__eq__
  args: [0]
  expected: true

invariant pty.STDOUT_FILENO:
  description: "pty.STDOUT_FILENO == 1"
  category: constants
  kind: python_call_eq
  function: STDOUT_FILENO.__eq__
  args: [1]
  expected: true

invariant pty.STDERR_FILENO:
  description: "pty.STDERR_FILENO == 2"
  category: constants
  kind: python_call_eq
  function: STDERR_FILENO.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant pty.fork_name:
  description: "pty.fork.__name__ == 'fork'"
  category: functions
  kind: python_call_eq
  function: fork.__name__.__eq__
  args: ["fork"]
  expected: true

invariant pty.fork_module:
  description: "pty.fork.__module__ == 'pty'"
  category: functions
  kind: python_call_eq
  function: fork.__module__.__eq__
  args: ["pty"]
  expected: true

invariant pty.openpty_name:
  description: "pty.openpty.__name__ == 'openpty'"
  category: functions
  kind: python_call_eq
  function: openpty.__name__.__eq__
  args: ["openpty"]
  expected: true

invariant pty.openpty_module:
  description: "pty.openpty.__module__ == 'pty'"
  category: functions
  kind: python_call_eq
  function: openpty.__module__.__eq__
  args: ["pty"]
  expected: true

invariant pty.spawn_name:
  description: "pty.spawn.__name__ == 'spawn'"
  category: functions
  kind: python_call_eq
  function: spawn.__name__.__eq__
  args: ["spawn"]
  expected: true

invariant pty.spawn_module:
  description: "pty.spawn.__module__ == 'pty'"
  category: functions
  kind: python_call_eq
  function: spawn.__module__.__eq__
  args: ["pty"]
  expected: true

# ---------------------------------------------------------------------------
# Constant type checks
# ---------------------------------------------------------------------------

invariant pty.STDIN_FILENO_type:
  description: "pty.STDIN_FILENO is an int"
  category: constants
  kind: python_call_eq
  function: STDIN_FILENO.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant pty.STDOUT_FILENO_type:
  description: "pty.STDOUT_FILENO is an int"
  category: constants
  kind: python_call_eq
  function: STDOUT_FILENO.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant pty.STDERR_FILENO_type:
  description: "pty.STDERR_FILENO is an int"
  category: constants
  kind: python_call_eq
  function: STDERR_FILENO.__class__.__name__.__eq__
  args: ["int"]
  expected: true

