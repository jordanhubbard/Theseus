spec: doctest_extra6
version: ">=3.9"
backend: python_module(doctest)

docs: https://docs.python.org/3/library/doctest.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/doctest.html — Python doctest module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/doctest.py"
  notes:
    - "Extends doctest.zspec.zsdl through doctest_extra5.zspec.zsdl."
    - "doctest (base) covers: testmod/testfile/run_docstring_examples/register_optionflag/__name__, DocTest/DocTestFinder/DocTestRunner/DocTestParser/OutputChecker/Example/DocTestFailure/UnexpectedException/DebugRunner/TestResults.__name__, DocTest.__module__, ELLIPSIS/NORMALIZE_WHITESPACE/IGNORE_EXCEPTION_DETAIL/SKIP/FAIL_FAST is_int."
    - "doctest_extra covers: DocTest/DocTestFinder/DocTestRunner/DocTestSuite/DocTestCase/DocTestParser/Example __name__, testmod/testfile/run_docstring_examples __name__, ELLIPSIS/NORMALIZE_WHITESPACE/IGNORE_EXCEPTION_DETAIL/FAIL_FAST is_int."
    - "doctest_extra2 covers: DocTestFinder/DocTestRunner/DocTestParser __name__/__module__, testmod/testfile/run_docstring_examples __name__/__module__, ELLIPSIS==8, NORMALIZE_WHITESPACE==2, SKIP==16."
    - "doctest_extra3 covers: DocTestFailure/UnexpectedException __name__/__module__/__bases__[0]/__name__, IGNORE_EXCEPTION_DETAIL==32, FAIL_FAST==64, class_names table, flag_types table."
    - "doctest_extra4 covers: class_qualnames table, function_qualnames table, flag_class_names table, DocTest.__module__."
    - "doctest_extra5 covers: OutputChecker/__name__/__module__/__qualname__/__bases__[0].__name__, DebugRunner/__name__/__module__/__qualname__/__bases__[0].__name__, DocTestCase/__name__/__module__/__qualname__/__bases__[0], register_optionflag/__module__/__qualname__, BLANKLINE_MARKER/ELLIPSIS_MARKER str type and value."
    - "NEW in this spec: flag constant __class__.__name__ == 'int' checks (ELLIPSIS, NORMALIZE_WHITESPACE, IGNORE_EXCEPTION_DETAIL, DONT_ACCEPT_TRUE_FOR_1, SKIP, FAIL_FAST) using __eq__ predicate form; class __name__ identity checks via __eq__ for DocTest, DocTestFinder, DocTestRunner, DocTestParser, DocTestSuite, DocFileSuite, DocTestFailure."
    - "doctest.DONT_ACCEPT_TRUE_FOR_1 is an integer option flag; its __class__.__name__ == 'int'."
    - "doctest.DocTestSuite.__name__ == 'DocTestSuite' — confirmed identity via __eq__ predicate."
    - "doctest.DocFileSuite.__name__ == 'DocFileSuite' — confirmed identity via __eq__ predicate."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Flag constant class name checks — __class__.__name__ == 'int' via __eq__
#
# Prior specs verify these flags are integers via direct comparison (is_int)
# or by checking their numeric values.  This set uses __class__.__name__.__eq__
# with expected: true — a distinct structural form not previously used for
# this predicate on these six constants.
# ---------------------------------------------------------------------------

invariant doctest_extra6.ELLIPSIS.class_name_eq:
  description: "doctest.ELLIPSIS.__class__.__name__.__eq__('int') == True"
  category: flag_constants
  kind: python_call_eq
  function: ELLIPSIS.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant doctest_extra6.NORMALIZE_WHITESPACE.class_name_eq:
  description: "doctest.NORMALIZE_WHITESPACE.__class__.__name__.__eq__('int') == True"
  category: flag_constants
  kind: python_call_eq
  function: NORMALIZE_WHITESPACE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant doctest_extra6.IGNORE_EXCEPTION_DETAIL.class_name_eq:
  description: "doctest.IGNORE_EXCEPTION_DETAIL.__class__.__name__.__eq__('int') == True"
  category: flag_constants
  kind: python_call_eq
  function: IGNORE_EXCEPTION_DETAIL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant doctest_extra6.DONT_ACCEPT_TRUE_FOR_1.class_name_eq:
  description: "doctest.DONT_ACCEPT_TRUE_FOR_1.__class__.__name__.__eq__('int') == True"
  category: flag_constants
  kind: python_call_eq
  function: DONT_ACCEPT_TRUE_FOR_1.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant doctest_extra6.SKIP.class_name_eq:
  description: "doctest.SKIP.__class__.__name__.__eq__('int') == True"
  category: flag_constants
  kind: python_call_eq
  function: SKIP.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant doctest_extra6.FAIL_FAST.class_name_eq:
  description: "doctest.FAIL_FAST.__class__.__name__.__eq__('int') == True"
  category: flag_constants
  kind: python_call_eq
  function: FAIL_FAST.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Class __name__ identity checks — __eq__ predicate form
#
# Prior specs confirm __name__ values via direct-value expected fields or
# table rows.  These invariants use __eq__ with expected: true — a new
# structural form for this set of class identity assertions.
# ---------------------------------------------------------------------------

invariant doctest_extra6.DocTest.name_eq:
  description: "doctest.DocTest.__name__.__eq__('DocTest') == True"
  category: class_names
  kind: python_call_eq
  function: DocTest.__name__.__eq__
  args: ["DocTest"]
  expected: true

invariant doctest_extra6.DocTestFinder.name_eq:
  description: "doctest.DocTestFinder.__name__.__eq__('DocTestFinder') == True"
  category: class_names
  kind: python_call_eq
  function: DocTestFinder.__name__.__eq__
  args: ["DocTestFinder"]
  expected: true

invariant doctest_extra6.DocTestRunner.name_eq:
  description: "doctest.DocTestRunner.__name__.__eq__('DocTestRunner') == True"
  category: class_names
  kind: python_call_eq
  function: DocTestRunner.__name__.__eq__
  args: ["DocTestRunner"]
  expected: true

invariant doctest_extra6.DocTestParser.name_eq:
  description: "doctest.DocTestParser.__name__.__eq__('DocTestParser') == True"
  category: class_names
  kind: python_call_eq
  function: DocTestParser.__name__.__eq__
  args: ["DocTestParser"]
  expected: true

invariant doctest_extra6.DocTestSuite.name_eq:
  description: "doctest.DocTestSuite.__name__.__eq__('DocTestSuite') == True"
