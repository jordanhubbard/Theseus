spec: multiprocessing_extra170
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec covers: multiprocessing.__name__=='multiprocessing'; multiprocessing.__package__=='multiprocessing'; multiprocessing.__spec__.__class__.__name__=='ModuleSpec'; multiprocessing.pool.Pool.__dict__.__contains__('apply')==True; multiprocessing.pool.Pool.__dict__.__contains__('map')==True; multiprocessing.pool.Pool.__dict__.__contains__('starmap')==True; multiprocessing.pool.Pool.__dict__.__contains__('close')==True; multiprocessing.pool.Pool.__dict__.__len__()==42. KEY FINDINGS: multiprocessing.__name__=='multiprocessing' (len=15); multiprocessing.__package__=='multiprocessing' (len=15; equal to __name__); Pool.__dict__.__len__()==42 (42 entries verified with Python 3.14.3 — the largest class dict in this spec series); all four Pool public methods (apply, map, starmap, close) are in Pool.__dict__. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.__name__=='multiprocessing' (len=15: 'multiprocessing'=15); __package__=='multiprocessing' (len=15; __name__==__package__ for a package module). Verified with Python 3.14.3."
    - "multiprocessing.pool.Pool.__dict__.__len__()==42 (42 entries: 'Process', '__del__', '__dict__', '__doc__', '__enter__', '__exit__', '__firstlineno__', '__init__', '__module__', '__reduce__', '__repr__', '__static_attributes__', '__weakref__', '_check_running', '_get_sentinels', '_get_tasks', '_get_worker_sentinels', '_guarded_task_generation', '_handle_results', '_handle_tasks', '_handle_workers', '_help_stuff_finish', '_join_exited_workers', '_maintain_pool', '_map_async', '_repopulate_pool', '_repopulate_pool_static', '_setup_queues', '_terminate_pool', '_wait_for_updates', '_wrap_exception', 'apply', 'apply_async', 'close', 'imap', 'imap_unordered', 'join', 'map', 'map_async', 'starmap', 'starmap_async', 'terminate'). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.__name__ and __package__ module identity — extra170
#
# multiprocessing.__name__.__eq__('multiprocessing')     == True
# multiprocessing.__name__.__len__()                     == 15
# multiprocessing.__package__.__eq__('multiprocessing')  == True
# multiprocessing.__package__.__len__()                  == 15
# ---------------------------------------------------------------------------

table multiprocessing_extra170.mp_module_name_and_package:
  description: "multiprocessing.__name__ and __package__ module identity checks in mpmodname170 namespace — multiprocessing.__name__.__eq__('multiprocessing')==True (multiprocessing.__name__=='multiprocessing' (len=15: 'multiprocessing'=15); the __name__ of the top-level multiprocessing package; for a package module (__init__.py), __name__ equals the package's dotted path); multiprocessing.__name__.__len__()==15 ('multiprocessing'=15; compare: 'concurrent.futures'=18 from extra169 is 3 longer; 'asyncio'=7 is 8 shorter; 'abc'=3 is 12 shorter; 'multiprocessing'=15 is the longest single-component package name in this spec series — 15 chars vs 'asyncio'=7 vs 'abc'=3); multiprocessing.__package__.__eq__('multiprocessing')==True (multiprocessing.__package__=='multiprocessing' (len=15; equal to __name__); for a package module, __name__==__package__; CONTRAST: multiprocessing.process.__package__=='multiprocessing' (submodule's __package__ is the parent package, not the submodule itself)); multiprocessing.__package__.__len__()==15 ('multiprocessing'=15; same as __name__.__len__); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmodname170

  columns: [id, function, args, expected, description]
  rows:
    - [mp_name_eq,   multiprocessing.__name__.__eq__,      ["multiprocessing"],  true,  "multiprocessing.__name__ == 'multiprocessing' (len=15; the package's dotted name); verified with Python 3.14.3"]
    - [mp_name_len,  multiprocessing.__name__.__len__,     [],                   15,    "multiprocessing.__name__.__len__() == 15 ('multiprocessing'=15; longest single-component package name in spec); verified with Python 3.14.3"]
    - [mp_pkg_eq,    multiprocessing.__package__.__eq__,   ["multiprocessing"],  true,  "multiprocessing.__package__ == 'multiprocessing' (len=15; __name__==__package__ for package modules); verified with Python 3.14.3"]
    - [mp_pkg_len,   multiprocessing.__package__.__len__,  [],                   15,    "multiprocessing.__package__.__len__() == 15 ('multiprocessing'=15; equal to __name__ len=15); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
