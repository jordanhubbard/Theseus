table multiprocessing_extra170.mp_spec_class_name:
  description: "multiprocessing.__spec__.__class__.__name__ checks in mpspecname170 namespace — multiprocessing.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (multiprocessing.__spec__.__class__.__name__=='ModuleSpec' (len=10: 'Module'=6+'Spec'=4=10); same as concurrent.futures.__spec__.__class__.__name__ (extra169): all standard-library modules use importlib.machinery.ModuleSpec as their spec type; the ModuleSpec holds: the module name, loader, submodule_search_locations (non-None for packages like multiprocessing), and origin); multiprocessing.__spec__.__class__.__name__.__len__()==10 ('ModuleSpec'=10: same as in extra169 — invariant across modules); multiprocessing.__name__.__eq__('multiprocessing')==True (cross-check; len=15); multiprocessing.__package__.__eq__('multiprocessing')==True (cross-check; len=15; equal to __name__); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpspecname170

  columns: [id, function, args, expected, description]
  rows:
    - [mp_spec_cls_eq,   multiprocessing.__spec__.__class__.__name__.__eq__,  ["ModuleSpec"],       true,  "multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec' (len=10; importlib.machinery.ModuleSpec); verified with Python 3.14.3"]
    - [mp_spec_cls_len,  multiprocessing.__spec__.__class__.__name__.__len__, [],                   10,    "multiprocessing.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec'=10; same as concurrent.futures spec); verified with Python 3.14.3"]
    - [mp_name_xchk,     multiprocessing.__name__.__eq__,                     ["multiprocessing"],  true,  "multiprocessing.__name__ == 'multiprocessing' (cross-check; len=15); verified with Python 3.14.3"]
    - [mp_pkg_xchk,      multiprocessing.__package__.__eq__,                  ["multiprocessing"],  true,  "multiprocessing.__package__ == 'multiprocessing' (cross-check; len=15); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool.__dict__.__contains__ — apply, map, starmap — extra170
#
# multiprocessing.pool.Pool.__dict__.__contains__('apply')    == True
# multiprocessing.pool.Pool.__dict__.__contains__('map')      == True
# multiprocessing.pool.Pool.__dict__.__contains__('starmap')  == True
# ---------------------------------------------------------------------------

table multiprocessing_extra170.mp_pool_dict_apply_map_starmap:
  description: "multiprocessing.pool.Pool.__dict__.__contains__ checks for 'apply', 'map', and 'starmap' in mppoolapply170 namespace — multiprocessing.pool.Pool.__dict__.__contains__('apply')==True ('apply' IS in Pool.__dict__; Pool.apply(func, args=(), kwds={}) calls func with the given args in a worker process and blocks until the result is ready — the synchronous single-item parallel call; equivalent to func(*args, **kwds) but in a worker process; Pool.apply_async() is the non-blocking version); multiprocessing.pool.Pool.__dict__.__contains__('map')==True ('map' IS in Pool.__dict__; Pool.map(func, iterable, chunksize=None) applies func to every item in iterable in parallel and returns a list of results in order; blocks until all results are ready; equivalent to list(map(func, iterable)) but in parallel across worker processes); multiprocessing.pool.Pool.__dict__.__contains__('starmap')==True ('starmap' IS in Pool.__dict__; Pool.starmap(func, iterable, chunksize=None) is like map but unpacks each element as arguments — equivalent to list(itertools.starmap(func, iterable)) but in parallel; added in Python 3.3); Pool.__dict__.__len__()==42 (cross-check; 42 total entries; apply, map, starmap are 3 of 42); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppoolapply170

  columns: [id, function, args, expected, description]
  rows:
    - [pool_has_apply,    multiprocessing.pool.Pool.__dict__.__contains__,  ["apply"],    true,  "Pool.__dict__.__contains__('apply') == True (synchronous single-item parallel call); verified with Python 3.14.3"]
    - [pool_has_map,      multiprocessing.pool.Pool.__dict__.__contains__,  ["map"],      true,  "Pool.__dict__.__contains__('map') == True (parallel map over iterable with result ordering); verified with Python 3.14.3"]
    - [pool_has_starmap,  multiprocessing.pool.Pool.__dict__.__contains__,  ["starmap"],  true,  "Pool.__dict__.__contains__('starmap') == True (like map but unpacks args per element; added Python 3.3); verified with Python 3.14.3"]
    - [pool_dict_len,     multiprocessing.pool.Pool.__dict__.__len__,       [],           42,    "Pool.__dict__.__len__() == 42 (42 total entries; apply, map, starmap are 3 of 42); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool.__dict__.__contains__('close') and __len__ — extra170
#
# multiprocessing.pool.Pool.__dict__.__contains__('close') == True
# multiprocessing.pool.Pool.__dict__.__len__()             == 42
# ---------------------------------------------------------------------------

table multiprocessing_extra170.mp_pool_dict_close_and_len:
  description: "multiprocessing.pool.Pool.__dict__.__contains__('close') and __len__ checks in mppoolclose170 namespace — multiprocessing.pool.Pool.__dict__.__contains__('close')==True ('close' IS in Pool.__dict__; Pool.close() prevents any more tasks from being submitted to the pool; after close() is called, the pool will finish executing all pending tasks but will not accept new ones; close() is followed by join() to wait for all worker processes to complete; the standard shutdown idiom is: pool.close(); pool.join()); multiprocessing.pool.Pool.__dict__.__len__()==42 (Pool's class dict has exactly 42 entries in Python 3.14.3; the 42 entries include: public API methods: apply, apply_async, map, map_async, starmap, starmap_async, imap, imap_unordered, close, terminate, join; internal methods: _map_async, _guarded_task_generation, _get_tasks, _handle_tasks, _handle_results, _handle_workers, _maintain_pool, _repopulate_pool, _repopulate_pool_static, _join_exited_workers, _wait_for_updates, _get_sentinels, _get_worker_sentinels, _setup_queues, _terminate_pool, _help_stuff_finish, _check_running, _wrap_exception; plus dunder entries and other attributes); multiprocessing.pool.Pool.__dict__.__contains__('apply')==True (cross-check; apply is 1 of 42); multiprocessing.pool.Pool.__dict__.__contains__('starmap')==True (cross-check; starmap is 1 of 42); ORDERING: BaseProcess.__dict__.__len__()==27 < Pool.__dict__.__len__()==42 — Pool is the largest class dict in this spec series at 42 entries; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppoolclose170

  columns: [id, function, args, expected, description]
  rows:
    - [pool_has_close,    multiprocessing.pool.Pool.__dict__.__contains__,  ["close"],    true,  "Pool.__dict__.__contains__('close') == True (close() prevents new tasks; followed by join() for cleanup); verified with Python 3.14.3"]
    - [pool_dict_len2,    multiprocessing.pool.Pool.__dict__.__len__,       [],           42,    "Pool.__dict__.__len__() == 42 (42 entries; largest class dict in spec series: BaseProcess=27 < Pool=42); verified with Python 3.14.3"]
    - [pool_has_apply2,   multiprocessing.pool.Pool.__dict__.__contains__,  ["apply"],    true,  "Pool.__dict__.__contains__('apply') == True (cross-check; apply is 1 of 42 entries); verified with Python 3.14.3"]
    - [pool_has_starmap2, multiprocessing.pool.Pool.__dict__.__contains__,  ["starmap"],  true,  "Pool.__dict__.__contains__('starmap') == True (cross-check; starmap is 1 of 42 entries); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra170
# ---------------------------------------------------------------------------

invariant multiprocessing_extra170.mp_module_name_eq:
  description: "multiprocessing.__name__.__eq__('multiprocessing') returns True — multiprocessing.__name__=='multiprocessing' (len=15: 'multiprocessing'=15); the multiprocessing package's __name__ is its fully qualified dotted path; as a top-level package, 'multiprocessing' IS the dotted path (no dot — single component); 'multiprocessing'=15 is the longest single-component package name in this spec series: 'abc'=3 < 'asyncio'=7 < 'multiprocessing'=15; compare: 'concurrent.futures'=18 is longer but is a two-component dotted path ('concurrent'=10+'.'=1+'futures'=7=18); for single components, 'multiprocessing'=15 is the longest; the multiprocessing package provides process-based parallelism (contrast: threading provides thread-based); NEW in extra170: first standalone multiprocessing.__name__ identity invariant in mpmodname170 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.__name__.__eq__
  args: ["multiprocessing"]
  expected: true

invariant multiprocessing_extra170.mp_module_package_eq:
  description: "multiprocessing.__package__.__eq__('multiprocessing') returns True — multiprocessing.__package__=='multiprocessing' (len=15; equal to __name__='multiprocessing'=15); for a package module (the __init__.py), __package__ and __name__ are equal; COMPARISON of __package__ values across spec series: abc.__package__=='' (empty string — abc is a top-level module, not a package; frozen modules may have empty __package__); multiprocessing.__package__=='multiprocessing' (non-empty; multiprocessing IS a package); concurrent.futures.__package__=='concurrent.futures' (non-empty; a package); asyncio.__package__=='asyncio' (non-empty; a package); CONTRAST: submodules like multiprocessing.process have __package__=='multiprocessing' (the parent) while the package itself has __package__=='multiprocessing' (itself — same value coincidentally because the package name equals the parent name); NEW in extra170: first standalone multiprocessing.__package__ identity invariant in mpmodname170 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.__package__.__eq__
  args: ["multiprocessing"]
  expected: true

invariant multiprocessing_extra170.mp_spec_class_is_ModuleSpec:
  description: "multiprocessing.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — multiprocessing.__spec__.__class__.__name__=='ModuleSpec' (len=10: 'Module'=6+'Spec'=4=10); ModuleSpec is importlib.machinery.ModuleSpec — the metadata container for any importlib-loaded module; the __spec__ attribute is set by the import system on every module; for the multiprocessing package, __spec__.submodule_search_locations is not None (it is a list of directories containing multiprocessing's submodules); COMPARISON: concurrent.futures.__spec__.__class__.__name__=='ModuleSpec' (from extra169: same type — universal invariant); abc.__spec__.__class__.__name__=='ModuleSpec' (from abc_extra167: also ModuleSpec — even frozen modules get ModuleSpec); 'ModuleSpec'=10: 'Module'=6+'Spec'=4=10; NEW in extra170: first standalone multiprocessing.__spec__.__class__.__name__ invariant in mpspecname170 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant multiprocessing_extra170.mp_Pool_dict_has_apply:
  description: "multiprocessing.pool.Pool.__dict__.__contains__('apply') returns True — multiprocessing.pool.Pool.__dict__.__contains__('apply')==True; Pool.apply(func, args=(), kwds={}) blocks until the result is ready — it is the synchronous pool dispatch method; apply() sends func to one worker process and waits for the result; unlike map which dispatches to multiple workers, apply dispatches a single call; Pool.apply_async() is the non-blocking variant that returns an AsyncResult immediately; 'apply' is 1 of 42 entries in Pool.__dict__; compare: concurrent.futures.Executor.__dict__.__contains__('submit')==True (from extra168: submit is the concurrent.futures equivalent of apply — both dispatch a single callable to a worker); Pool.apply=5chars vs Executor.submit=6chars; NEW in extra170: first standalone Pool.__dict__.__contains__('apply') invariant in mppoolapply170 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__dict__.__contains__
  args: ["apply"]
  expected: true

invariant multiprocessing_extra170.mp_Pool_dict_has_starmap:
  description: "multiprocessing.pool.Pool.__dict__.__contains__('starmap') returns True — multiprocessing.pool.Pool.__dict__.__contains__('starmap')==True; Pool.starmap(func, iterable, chunksize=None) is the argument-unpacking variant of map: each element of iterable is unpacked as *args for func, equivalent to list(itertools.starmap(func, iterable)) but in parallel; starmap was added in Python 3.3 to match itertools.starmap; example: Pool.starmap(pow, [(2,3),(3,2)]) returns [8, 9]; 'starmap' is 1 of 42 entries in Pool.__dict__; COMPARISON: map(3), apply(5), starmap(7) — starmap is the longest of the three main Pool dispatch method names; Pool.starmap_async() (also in Pool.__dict__) is the non-blocking variant; NEW in extra170: first standalone Pool.__dict__.__contains__('starmap') invariant in mppoolapply170 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__dict__.__contains__
  args: ["starmap"]
  expected: true

invariant multiprocessing_extra170.mp_Pool_dict_has_close:
  description: "multiprocessing.pool.Pool.__dict__.__contains__('close') returns True — multiprocessing.pool.Pool.__dict__.__contains__('close')==True; Pool.close() signals the pool that no more work will be submitted; after close(), the pool's worker processes will complete all pending tasks in their queues and then exit; close() is non-blocking — call join() after close() to wait for all workers to exit; the standard safe pool shutdown pattern is: try: pool.close() finally: pool.join(); CONTRAST: Pool.terminate() immediately stops worker processes without waiting for pending tasks; Pool.close() is the graceful shutdown (finishes pending work) while terminate() is the forceful shutdown (discards pending work); 'close' is 1 of 42 entries in Pool.__dict__; COMPARE: BaseProcess.__dict__.__contains__('terminate')==True (from extra169: BaseProcess defines terminate for individual process control); Pool.__dict__.__contains__('close') and Pool.__dict__.__contains__('terminate') are both True — Pool has both graceful and forceful shutdown methods; NEW in extra170: first standalone Pool.__dict__.__contains__('close') invariant in mppoolclose170 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__dict__.__contains__
  args: ["close"]
  expected: true

invariant multiprocessing_extra170.mp_Pool_dict_len:
  description: "multiprocessing.pool.Pool.__dict__.__len__() returns 42 — multiprocessing.pool.Pool.__dict__.__len__()==42 (42 entries in Pool's class dict as of Python 3.14.3 on macOS/Darwin 25.4.0); the 42 entries include public API methods: apply, apply_async, map, map_async, starmap, starmap_async, imap, imap_unordered, close, terminate, join (11 public methods); internal worker management: _handle_tasks, _handle_results, _handle_workers, _maintain_pool, _repopulate_pool, _repopulate_pool_static, _join_exited_workers, _wait_for_updates, _get_sentinels, _get_worker_sentinels, _setup_queues, _terminate_pool, _help_stuff_finish, _check_running, _wrap_exception, _guarded_task_generation, _get_tasks, _map_async, _adjust_process_count (private helpers); plus dunder entries: __init__, __module__, __doc__, __dict__, __weakref__, __repr__, __reduce__, __del__, __enter__, __exit__, __firstlineno__, __static_attributes__; and Process (a class reference); SIZE ORDERING: abc.ABC(7) < abc.ABCMeta(11) < ThreadPoolExecutor(12) < concurrent.futures.Executor(11) < concurrent.futures.Future(21) < multiprocessing.process.BaseProcess(27) < multiprocessing.pool.Pool(42) — Pool is the LARGEST class dict in this entire spec series at 42 entries; NEW in extra170: first standalone Pool.__dict__.__len__ invariant in mppoolclose170 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__dict__.__len__
  args: []
  expected: 42

