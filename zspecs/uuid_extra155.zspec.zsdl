spec: uuid_extra155
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra154.zspec.zsdl — covers uuid.UUID.__lt__/__le__/__gt__/__ge__/__eq__ qualname strings and lengths / all five are 'function' type (table + invariants)."
    - "uuid_extra153.zspec.zsdl — covers uuid.UUID.__slots__ attribute details — __slots__.__class__.__name__.__eq__('tuple') / __slots__.__len__()==3 / __slots__.__contains__('int'/'is_safe'/'__weakref__') / slot element lengths (table + invariants)."
    - "uuid_extra149.zspec.zsdl — covers uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__') / __init__.__code__.co_argcount==7 / __init__.__code__.co_name / __str__/__repr__/__hash__/__eq__ co_name and co_argcount ordering (table + invariants)."
    - "uuid_extra147.zspec.zsdl — covers uuid.UUID.__slots__.__class__.__name__.__eq__('tuple') / UUID.__slots__.__len__()==3 / UUID.__hash__/__str__/__repr__/__eq__ qualname lengths (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra154."
    - "Wave 345 theme: uuid.UUID.__init__ code object attributes — UUID.__init__.__code__.co_argcount==7 / UUID.__init__.__code__.co_name.__eq__('__init__') / UUID.__init__.__qualname__.__eq__('UUID.__init__') / UUID.__init__.__code__.co_varnames.__len__()==15. uuid_extra149 anchors UUID.__init__.__code__.co_argcount==7 as a table row and UUID.__init__.__qualname__ as a row; this spec anchors the co_varnames length (15), the co_name string, and the qualname as novel standalone invariants with a deeper code-object focus."
    - "uuid.UUID.__init__.__code__.co_argcount == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_name == '__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__qualname__ == 'UUID.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_varnames.__len__() == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__qualname__.__len__() == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.__init__.__code__.co_argcount == 7. The 7 positional parameters are: self, hex, bytes, bytes_le, fields, int, version. All 6 non-self parameters default to None in the signature. co_argcount counts all positional params including self (for methods). uuid_extra149 anchors co_argcount==7 as a table row; this spec anchors it as a standalone and pairs it with co_name and co_varnames.__len__()."
    - "Note: uuid.UUID.__init__.__code__.co_varnames.__len__() == 15. co_varnames contains all local variables: the 7 positional parameters (self, hex, bytes, bytes_le, fields, int, version) plus 1 keyword-only argument (is_safe) plus additional local variables used inside the function body (time_low, time_mid, time_hi_version, clock_seq_hi_variant, clock_seq_low, node, clock_seq). 7 params + 1 kw-only + 7 local vars = 15 total. This is more than co_argcount (7) because co_varnames includes all locals, not just positional params."
    - "Note: uuid.UUID.__init__.__qualname__ == 'UUID.__init__' (13 chars = 'UUID.'=5 + '__init__'=8). The qualname uses the class name prefix 'UUID.' because __init__ is a method defined inside the UUID class. '__init__' (8 chars) = '__'=2 + 'init'=4 + '__'=2. 'UUID.__init__' (13 chars) is longer than 'UUID.__eq__' (11 chars) by 2 chars because '__init__'=8 > '__eq__'=6."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_argcount==7
# uuid.UUID.__init__.__code__.co_name.__eq__('__init__')
# uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__')
# uuid.UUID.__init__.__class__.__name__.__eq__('function')
#
# Wave 345 theme: UUID.__init__ code object identity.
#
# UUID.__init__.__code__.co_argcount == 7 (self + hex + bytes + bytes_le + fields + int + version).
# UUID.__init__.__code__.co_name == '__init__' (8 chars).
# UUID.__init__.__qualname__ == 'UUID.__init__' (13 chars = 'UUID.'=5 + '__init__'=8).
# UUID.__init__.__class__.__name__ == 'function' (8 chars; pure Python method).
# uuid_extra149 anchors co_argcount==7 and qualname as table rows;
# no prior uuid spec anchors co_name as a table under uuidinit155.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra155.UUID_init_code_identity:
  description: "uuid.UUID.__init__.__code__.co_argcount==7 / UUID.__init__.__code__.co_name.__eq__('__init__')==True / UUID.__init__.__qualname__.__eq__('UUID.__init__')==True / UUID.__init__.__class__.__name__.__eq__('function')==True — __init__.__code__.co_argcount is 7 (self/hex/bytes/bytes_le/fields/int/version are the 7 positional params; all 6 non-self params default to None; uuid_extra149 anchors this as a table row; confirmed); __init__.__code__.co_name is '__init__' (8 chars = '__'=2 + 'init'=4 + '__'=2; code object's internal name; same as the method name; first uuidinit155 anchor for co_name); __init__.__qualname__ is 'UUID.__init__' (13 chars = 'UUID.'=5 + '__init__'=8; uuid_extra149 anchors this as a row; confirmed; 2 chars longer than 'UUID.__eq__'=11 because '__init__'=8 vs '__eq__'=6); __init__.__class__.__name__ is 'function' (8 chars; pure Python method defined in Lib/uuid.py; same type as UUID.__eq__ and comparison methods); first uuidinit155 anchor for co_name string"
  kind: python_call_eq
  category: identity
  id_prefix: uuidinit155

  columns: [id, function, args, expected, description]
  rows:
    - [init_co_argcount_7,      "__init__.__code__.co_argcount.__eq__",      [7],           true, "uuid.UUID.__init__.__code__.co_argcount == 7 (self/hex/bytes/bytes_le/fields/int/version; uuid_extra149 anchors; confirmed)"]
    - [init_co_name_init,       "__init__.__code__.co_name.__eq__",          ["__init__"],  true, "uuid.UUID.__init__.__code__.co_name == '__init__' (8 chars = '__'=2 + 'init'=4 + '__'=2; first uuidinit155 anchor for co_name)"]
    - [init_qualname_uuid_init, "__init__.__qualname__.__eq__",              ["UUID.__init__"], true, "uuid.UUID.__init__.__qualname__ == 'UUID.__init__' (13 chars = 'UUID.'=5 + '__init__'=8; uuid_extra149 anchors; confirmed)"]
    - [init_class_function,     "__init__.__class__.__name__.__eq__",        ["function"],  true, "uuid.UUID.__init__.__class__.__name__ == 'function' (8 chars; pure Python method in Lib/uuid.py; same type as comparison dunders)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_varnames.__len__()==15
# uuid.UUID.__init__.__code__.co_varnames.__class__.__name__.__eq__('tuple')
# uuid.UUID.__init__.__code__.co_argcount.__eq__(7)
# uuid.UUID.__init__.__qualname__.__len__()==13
#
# Wave 345 theme: UUID.__init__ code object varnames count and qualname length.
#
# UUID.__init__.__code__.co_varnames.__len__() == 15 (7 positional + 1 kw-only + 7 locals).
# UUID.__init__.__code__.co_varnames.__class__.__name__ == 'tuple'.
# UUID.__init__.__code__.co_argcount == 7 (confirmed).
# UUID.__init__.__qualname__.__len__() == 13 ('UUID.__init__' = 13 chars).
# No prior uuid spec anchors co_varnames.__len__() or qualname.__len__() as a table under
# uuidinit155. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra155.UUID_init_co_varnames_and_lengths:
  description: "uuid.UUID.__init__.__code__.co_varnames.__len__()==15 / co_varnames.__class__.__name__.__eq__('tuple')==True / co_argcount.__eq__(7)==True / __qualname__.__len__()==13 — co_varnames.__len__() is 15 (7 positional args: self/hex/bytes/bytes_le/fields/int/version + 1 keyword-only arg: is_safe + 7 body locals: time_low/time_mid/time_hi_version/clock_seq_hi_variant/clock_seq_low/node/clock_seq; total = 15; co_varnames > co_argcount because it includes all local variables); co_varnames.__class__.__name__ is 'tuple' (5 chars; code object varnames is always a tuple of strings); co_argcount is 7 (confirmed; co_argcount(7) < co_varnames.__len__()(15); the difference is 8 non-positional locals including is_safe and 7 body variables); __qualname__.__len__() is 13 ('UUID.__init__' = 'UUID.'=5 + '__init__'=8 = 13 chars; 2 chars longer than 'UUID.__eq__'=11 because '__init__'=8 vs '__eq__'=6); first uuidinit155 anchor for co_varnames.__len__()==15 and __qualname__.__len__()==13"
  kind: python_call_eq
  category: identity
  id_prefix: uuidinit155

  columns: [id, function, args, expected, description]
  rows:
    - [init_co_varnames_len_15,     "__init__.__code__.co_varnames.__len__",               [], 15,      "uuid.UUID.__init__.__code__.co_varnames.__len__() is 15 (7 positional + 1 kw-only(is_safe) + 7 body locals; co_argcount=7 < co_varnames=15)"]
    - [init_co_varnames_cls_tuple,  "__init__.__code__.co_varnames.__class__.__name__.__eq__", ["tuple"], true, "uuid.UUID.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' (5 chars; code object varnames always a tuple)"]
    - [init_co_argcount_7_b,        "__init__.__code__.co_argcount.__eq__",                [7], true,   "uuid.UUID.__init__.__code__.co_argcount == 7 (confirmed; self/hex/bytes/bytes_le/fields/int/version; positional params only)"]
    - [init_qualname_len_13,        "__init__.__qualname__.__len__",                       [], 13,      "uuid.UUID.__init__.__qualname__.__len__() is 13 ('UUID.__init__' = 'UUID.'=5 + '__init__'=8 = 13; 2 chars longer than 'UUID.__eq__'=11)"]

# ---------------------------------------------------------------------------
# UUID.__init__ code attribute comparisons
#
# Wave 345 theme: co_argcount vs co_varnames length comparison for UUID.__init__.
#
# UUID.__init__.__code__.co_argcount == 7.
# UUID.__init__.__code__.co_varnames.__len__() == 15.
# UUID.__init__.__code__.co_name.__eq__('__init__') == True (confirmed).
# UUID.__init__.__qualname__.__len__() == 13.
# No prior uuid spec anchors the relationship between co_argcount and co_varnames as a
# table under uuidinit155. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra155.UUID_init_code_comparison:
  description: "uuid.UUID.__init__.__code__.co_argcount==7 / co_varnames.__len__()==15 / co_name.__eq__('__init__')==True / __qualname__.__len__()==13 — the relationship between co_argcount(7) and co_varnames.__len__()(15): co_argcount counts only positional params; co_varnames contains all locals (params + keyword-only + body locals); co_varnames.__len__()(15) > co_argcount(7) by 8 (1 keyword-only is_safe + 7 body locals: time_low/time_mid/time_hi_version/clock_seq_hi_variant/clock_seq_low/node/clock_seq); co_name is '__init__' (8 chars; confirmed; code object name agrees with method name); __qualname__.__len__() is 13 ('UUID.'=5 + '__init__'=8 = 13; longer than '__init__'=8 alone by 5 chars for the class prefix); length ordering: co_argcount(7) < '__init__'(8) < __qualname__(13) < co_varnames(15); first uuidinit155 anchor for this code comparison table"
  kind: python_call_eq
  category: identity
  id_prefix: uuidinit155

  columns: [id, function, args, expected, description]
  rows:
    - [init_co_argc_eq_7,       "__init__.__code__.co_argcount.__eq__",      [7],          true, "uuid.UUID.__init__.__code__.co_argcount == 7 (self/hex/bytes/bytes_le/fields/int/version; confirmed 7 positional params)"]
    - [init_co_varnames_eq_15,  "__init__.__code__.co_varnames.__len__",     [], 15,              "uuid.UUID.__init__.__code__.co_varnames.__len__() == 15 (7 positional + is_safe + 7 body locals; 15 > 7 by 8)"]
    - [init_co_name_init_b,     "__init__.__code__.co_name.__eq__",          ["__init__"], true, "uuid.UUID.__init__.__code__.co_name == '__init__' (8 chars; confirmed; code object name agrees with method name)"]
    - [init_qualname_len_13_b,  "__init__.__qualname__.__len__",             [], 13,              "uuid.UUID.__init__.__qualname__.__len__() == 13 ('UUID.'=5 + '__init__'=8 = 13; qualname adds 5-char class prefix to 8-char method name)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_argcount == 7 — standalone
#
# uuid.UUID.__init__.__code__.co_argcount is 7. The 7 positional parameters of UUID.__init__
# are: self, hex, bytes, bytes_le, fields, int, version. All 6 non-self parameters default
# to None. UUID can be constructed by passing exactly one of hex, bytes, bytes_le, fields,
# or int (exactly one must be non-None unless version is specified). co_argcount == 7 counts
# all positional parameters including self (because it is a method). uuid_extra149 anchors
# UUID.__init__.__code__.co_argcount==7 as a table row; this standalone provides a dedicated
# invariant under uuidinit155 focused on the code object attribute.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra155.UUID_init_co_argcount_7:
  description: "uuid.UUID.__init__.__code__.co_argcount.__eq__(7) == True — 7 positional params: self/hex/bytes/bytes_le/fields/int/version; all 6 non-self params default to None; co_argcount includes self for methods; co_varnames.__len__()==15 (15 > 7; includes is_safe + 7 body locals); uuid_extra149 anchors co_argcount==7 as table row; this standalone provides dedicated invariant under uuidinit155; UUID can be constructed with exactly one of hex/bytes/bytes_le/fields/int (UUID construction rules); first uuidinit155 standalone for co_argcount"
  category: identity
  kind: python_call_eq
  function: __init__.__code__.co_argcount.__eq__
  args: [7]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_name.__eq__('__init__') — standalone
#
# uuid.UUID.__init__.__code__.co_name is '__init__' (8 chars). The code object's co_name
# stores the name of the function as defined in source. For UUID.__init__, co_name is
# '__init__' (the dunder initializer name). co_name is an immutable attribute of the code
# object stored at compile time. For methods, co_name is just the bare method name without
# the class prefix (unlike __qualname__ which includes 'UUID.'). co_name == '__init__'
# (8 chars) vs __qualname__ == 'UUID.__init__' (13 chars): the qualname adds the 5-char
# class prefix 'UUID.'. No prior uuid spec anchors UUID.__init__.__code__.co_name as a
# standalone under uuidinit155. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra155.UUID_init_co_name_init:
  description: "uuid.UUID.__init__.__code__.co_name.__eq__('__init__') == True — 8 chars = '__'=2 + 'init'=4 + '__'=2; code object's internal name; immutable attribute stored at compile time; co_name=='__init__' is the bare method name without class prefix; contrasts with __qualname__=='UUID.__init__' (13 chars; includes 'UUID.' prefix adding 5 chars); co_name(8) < __qualname__(13) by 5 chars (the 'UUID.' prefix); first uuidinit155 standalone for co_name"
  category: identity
  kind: python_call_eq
  function: __init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__') — standalone
#
# uuid.UUID.__init__.__qualname__ is 'UUID.__init__' (13 chars = 'UUID.'=5 + '__init__'=8).
# The qualname includes the class name prefix 'UUID.' because __init__ is a method of the
# UUID class. This contrasts with the code object's co_name which is '__init__' (8 chars,
# without class prefix). 'UUID.__init__' (13 chars) is 2 chars longer than 'UUID.__eq__'
# (11 chars) because '__init__' (8 chars) > '__eq__' (6 chars). uuid_extra149 anchors
# UUID.__init__.__qualname__ as a table row; this standalone confirms it under uuidinit155
# with focus on the code object context. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra155.UUID_init_qualname_eq:
  description: "uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__') == True — 13 chars = 'UUID.'=5 + '__init__'=8; class prefix 'UUID.' marks __init__ as a method of UUID class; contrasts with co_name=='__init__' (8 chars; bare name without class prefix); 'UUID.__init__'(13) vs 'UUID.__eq__'(11): 2 chars longer because '__init__'=8 > '__eq__'=6; uuid_extra149 anchors as table row; this standalone provides dedicated invariant under uuidinit155; first uuidinit155 standalone for qualname string"
  category: identity
  kind: python_call_eq
  function: __init__.__qualname__.__eq__
  args: ["UUID.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_varnames.__len__() == 15 — standalone
#
# uuid.UUID.__init__.__code__.co_varnames.__len__() is 15. co_varnames contains all local
# variable names for the function: the 7 positional parameters (self, hex, bytes, bytes_le,
# fields, int, version), 1 keyword-only parameter (is_safe), and 7 local variables used
# in the function body (time_low, time_mid, time_hi_version, clock_seq_hi_variant,
# clock_seq_low, node, clock_seq). Total: 7 + 1 + 7 = 15. This is greater than co_argcount
# (7) by 8 because co_varnames includes all locals, not just positional params. The 7 body
# local variables are used when parsing the 'fields' argument (which is a tuple of 6 UUID
# component fields used to construct the UUID from individual components).
# No prior uuid spec anchors UUID.__init__.__code__.co_varnames.__len__() as a standalone
# under uuidinit155. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra155.UUID_init_co_varnames_len_15:
  description: "uuid.UUID.__init__.__code__.co_varnames.__len__() == 15 — 15 total locals: 7 positional(self/hex/bytes/bytes_le/fields/int/version) + 1 keyword-only(is_safe) + 7 body locals(time_low/time_mid/time_hi_version/clock_seq_hi_variant/clock_seq_low/node/clock_seq); 7+1+7=15; co_varnames(15) > co_argcount(7) by 8; the 7 body locals are used when parsing the 'fields' tuple argument (6 UUID component fields); co_varnames.__class__.__name__=='tuple'; first uuidinit155 standalone for co_varnames.__len__()"
  category: identity
  kind: python_call_eq
  function: __init__.__code__.co_varnames.__len__
  args: []
  expected: 15
