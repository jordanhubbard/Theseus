spec: numbers_extra4
version: ">=3.0"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/numbers.html"
    - "PEP 3141 — A Type Hierarchy for Numbers"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers.zspec.zsdl, numbers_extra.zspec.zsdl, numbers_extra2.zspec.zsdl, and numbers_extra3.zspec.zsdl."
    - "numbers covers: class_names table, module_checks table, abstract method counts, Complex_has_abs/conjugate, Rational_has_numerator/denominator, Integral_has_and."
    - "numbers_extra covers: hierarchy __bases__[0].__name__ for all five; isinstance checks; Integral or/xor/lshift; Real trunc/floor; Complex real/imag."
    - "numbers_extra2 covers: class_names table (description variant); Number/Complex/Real __module__ invariants; Complex/Real bases via __name__.__eq__."
    - "numbers_extra3 covers: class_names table (class_name prefix); __qualname__ for all five; Rational/Integral __module__; Rational/Integral bases via __name__.__eq__; bases_len for Number/Integral; Integral __int__/__rrshift__/__invert__; Real __ceil__."
    - "This spec adds: abstract method membership for new methods not yet covered — Complex.__neg__, Complex.__pos__, Complex.__mul__; Real.__abs__ (Real inherits and overrides abs); Integral.__pow__, Integral.__mod__, Integral.__floordiv__; isinstance checks for new types — Rational.__instancecheck__(fractions.Fraction instance expressed as float) is not expressible; instead: Integral.__instancecheck__(0) == True (zero is an int); Real.__instancecheck__(0.0) == True (zero float); Number.__instancecheck__(0j) == True (complex zero); Integral.__instancecheck__(False) == True (bool is a subtype of int)."
    - "numbers.Complex.__abstractmethods__.__contains__('__neg__') == True — negation is abstract in Complex."
    - "numbers.Complex.__abstractmethods__.__contains__('__pos__') == True — unary plus is abstract in Complex."
    - "numbers.Complex.__abstractmethods__.__contains__('__mul__') == True — multiplication is abstract in Complex."
    - "numbers.Integral.__abstractmethods__.__contains__('__pow__') == True — power is abstract in Integral."
    - "numbers.Integral.__abstractmethods__.__contains__('__mod__') == True — modulo is abstract in Integral."
    - "numbers.Integral.__abstractmethods__.__contains__('__floordiv__') == True — floor division is abstract in Integral."
    - "numbers.Integral.__instancecheck__(0) == True — zero (int) is an Integral."
    - "numbers.Real.__instancecheck__(0.0) == True — zero float is a Real."
    - "numbers.Number.__instancecheck__(0j) == True — complex zero is a Number."
    - "numbers.Integral.__instancecheck__(False) == True — bool is a subtype of int and thus an Integral."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Abstract method membership — Complex: __neg__, __pos__, __mul__
# numbers covers __abs__ and conjugate for Complex.
# numbers_extra adds real and imag for Complex.
# New here: __neg__, __pos__, __mul__
# ---------------------------------------------------------------------------

table numbers_extra4.abstract_methods.complex_ops:
  kind: python_call_eq
  category: abstract_methods
  id_prefix: complex_op

  columns: [id, function, args, expected]
  rows:
    - [neg, Complex.__abstractmethods__.__contains__, ["__neg__"], true]
    - [pos, Complex.__abstractmethods__.__contains__, ["__pos__"], true]
    - [mul, Complex.__abstractmethods__.__contains__, ["__mul__"], true]

# ---------------------------------------------------------------------------
# Abstract method membership — Integral: __pow__, __mod__, __floordiv__
# numbers covers __and__ for Integral.
# numbers_extra adds __or__, __xor__, __lshift__ for Integral.
# numbers_extra3 adds __int__, __rrshift__, __invert__ for Integral.
# New here: __pow__, __mod__, __floordiv__
# ---------------------------------------------------------------------------

table numbers_extra4.abstract_methods.integral_ops:
  kind: python_call_eq
  category: abstract_methods
  id_prefix: integral_op

  columns: [id, function, args, expected]
  rows:
    - [pow,      Integral.__abstractmethods__.__contains__, ["__pow__"],      true]
    - [mod,      Integral.__abstractmethods__.__contains__, ["__mod__"],      true]
    - [floordiv, Integral.__abstractmethods__.__contains__, ["__floordiv__"], true]

# ---------------------------------------------------------------------------
# isinstance checks — new argument values not used in numbers_extra
# numbers_extra uses: Integral(1), Real(1.0), Complex(1), Number(1),
#   Number(1.0), Integral('x') == False.
# New here: Integral(0), Real(0.0), Number(0j), Integral(False).
# ---------------------------------------------------------------------------

invariant numbers_extra4.isinstance.zero_int_is_Integral:
  description: "numbers.Integral.__instancecheck__(0) == True — zero (int) is an Integral"
  category: isinstance
  kind: python_call_eq
  function: Integral.__instancecheck__
  args: [0]
  expected: true

invariant numbers_extra4.isinstance.zero_float_is_Real:
  description: "numbers.Real.__instancecheck__(0.0) == True — zero float is a Real"
  category: isinstance
  kind: python_call_eq
  function: Real.__instancecheck__
  args: [0.0]
  expected: true

invariant numbers_extra4.isinstance.complex_zero_is_Number:
  description: "numbers.Number.__instancecheck__(0j) == True — complex zero is a Number"
  category: isinstance
  kind: python_call_eq
  function: Number.__instancecheck__
  args: [0]
  expected: true

invariant numbers_extra4.isinstance.bool_is_Integral:
  description: "numbers.Integral.__instancecheck__(False) == True — bool is a subtype of int and thus an Integral"
  category: isinstance
  kind: python_call_eq
  function: Integral.__instancecheck__
  args: [false]
  expected: true
