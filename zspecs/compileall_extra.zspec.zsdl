spec: compileall_extra
version: ">=3.2"
backend: python_module(compileall)

docs: https://docs.python.org/3/library/compileall.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/compileall.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "compileall source: Lib/compileall.py (internal implementation details)"
    - "compileall.zspec.zsdl — covers function name checks, module checks, type checks, docstring checks, and qualname checks"
  notes:
    - "This spec extends compileall.zspec.zsdl with focused function name and module membership invariants."
    - "compile_file.__name__ == 'compile_file' — module-level function for compiling a single .py file."
    - "compile_file.__module__ == 'compileall' — function is defined in the compileall module."
    - "compile_dir.__name__ == 'compile_dir' — module-level function for compiling a directory tree."
    - "compile_path.__name__ == 'compile_path' — module-level function for compiling files on sys.path."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "compile_file and compile_dir return True on success, False if any file failed to compile. They do not raise on individual file compile errors by default."
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# Function name checks — compile_file, compile_dir, compile_path
# ---------------------------------------------------------------------------

invariant compileall_extra.compile_file.name:
  description: "compileall.compile_file.__name__ == 'compile_file'"
  category: names
  kind: python_call_eq
  function: compile_file.__name__.__eq__
  args: ["compile_file"]
  expected: true

invariant compileall_extra.compile_dir.name:
  description: "compileall.compile_dir.__name__ == 'compile_dir'"
  category: names
  kind: python_call_eq
  function: compile_dir.__name__.__eq__
  args: ["compile_dir"]
  expected: true

invariant compileall_extra.compile_path.name:
  description: "compileall.compile_path.__name__ == 'compile_path'"
  category: names
  kind: python_call_eq
  function: compile_path.__name__.__eq__
  args: ["compile_path"]
  expected: true

# ---------------------------------------------------------------------------
# Module membership — compile_file lives in the compileall module
# ---------------------------------------------------------------------------

invariant compileall_extra.compile_file.module:
  description: "compileall.compile_file.__module__ == 'compileall'"
  category: modules
  kind: python_call_eq
  function: compile_file.__module__.__eq__
  args: ["compileall"]
  expected: true
