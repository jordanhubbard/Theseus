spec: asyncio_extra1921
version: ">=3.9"
backend: python_module(asyncio)

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 575 (_extra1921): __slots__ inheritance checks, __abstractmethods__ set membership, __subclasshook__ dict presence, __init_subclass__ dict presence."
    - "asyncio.Task, asyncio.Future, asyncio.Event, asyncio.Lock, asyncio.Queue, asyncio.Semaphore, asyncio.Condition, asyncio.Barrier, asyncio.BoundedSemaphore do NOT define __slots__."
    - "asyncio.Handle and asyncio.TimerHandle DO define __slots__ (tuple of attribute names)."
    - "asyncio.BaseProtocol, asyncio.Protocol, asyncio.DatagramProtocol, asyncio.SubprocessProtocol define __slots__ as empty tuples."
    - "None of the checked asyncio classes define __abstractmethods__, __subclasshook__, or __init_subclass__ in their own __dict__."
    - "asyncio.AbstractEventLoop, asyncio.BaseEventLoop, asyncio.StreamReader, asyncio.StreamWriter, asyncio.Runner, asyncio.TaskGroup, asyncio.Timeout, asyncio.Server do not use __slots__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table asyncio_extra1921.slots_protocol:
  description: "asyncio types __slots__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1921

  columns: [id, function, args, expected]
  rows:
    - ["as1921001", "asyncio.Task.__dict__.__contains__", ["__slots__"], false]
    - ["as1921002", "asyncio.Future.__dict__.__contains__", ["__slots__"], false]
    - ["as1921003", "asyncio.Event.__dict__.__contains__", ["__slots__"], false]
    - ["as1921004", "asyncio.Lock.__dict__.__contains__", ["__slots__"], false]
    - ["as1921005", "asyncio.Queue.__dict__.__contains__", ["__slots__"], false]
    - ["as1921006", "asyncio.Semaphore.__dict__.__contains__", ["__slots__"], false]
    - ["as1921007", "asyncio.Condition.__dict__.__contains__", ["__slots__"], false]
    - ["as1921008", "asyncio.Barrier.__dict__.__contains__", ["__slots__"], false]
    - ["as1921009", "asyncio.BoundedSemaphore.__dict__.__contains__", ["__slots__"], false]
    - ["as1921010", "asyncio.Handle.__dict__.__contains__", ["__slots__"], true]
    - ["as1921011", "asyncio.TimerHandle.__dict__.__contains__", ["__slots__"], true]
    - ["as1921012", "asyncio.BaseProtocol.__dict__.__contains__", ["__slots__"], true]
    - ["as1921013", "asyncio.Protocol.__dict__.__contains__", ["__slots__"], true]
    - ["as1921014", "asyncio.DatagramProtocol.__dict__.__contains__", ["__slots__"], true]
    - ["as1921015", "asyncio.SubprocessProtocol.__dict__.__contains__", ["__slots__"], true]
    - ["as1921016", "asyncio.AbstractEventLoop.__dict__.__contains__", ["__slots__"], false]
    - ["as1921017", "asyncio.BaseEventLoop.__dict__.__contains__", ["__slots__"], false]
    - ["as1921018", "asyncio.StreamReader.__dict__.__contains__", ["__slots__"], false]
    - ["as1921019", "asyncio.StreamWriter.__dict__.__contains__", ["__slots__"], false]
    - ["as1921020", "asyncio.Server.__dict__.__contains__", ["__slots__"], false]

