spec: hashlib_extra173
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra172.zspec.zsdl — covers hashlib constructor __name__.__len__() integer values for all eight OpenSSL/BLAKE2 constructors (blake2b/blake2s=7, sha1=12, sha256/sha512/sha224/sha384=14, sha3_256=16) (table + invariants)."
    - "hashlib_extra171.zspec.zsdl — covers hashlib.new/__pbkdf2_hmac/__scrypt/__file_digest .__name__/__module__/__class__.__name__ and name lengths (table + invariants)."
    - "hashlib_extra170.zspec.zsdl — covers hashlib.sha1/__sha224/__sha384/__blake2b/__blake2s/__sha3_256 .__name__ and .__module__ (table + invariants)."
    - "hashlib_extra169.zspec.zsdl — covers hashlib.algorithms_guaranteed/__available membership and lengths (table + invariants)."
    - "hashlib_extra168.zspec.zsdl — covers hashlib.sha256/__md5/__sha512 .__name__ and .__module__; algorithms_available/__guaranteed .__class__.__name__=='set' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra172."
    - "Wave 352 theme: hashlib constructor __qualname__ attributes and algorithms set class names. For C builtin constructors (sha256, md5), __qualname__ == __name__ (same string). sha256.__qualname__ == 'openssl_sha256' (14 chars); md5.__qualname__ == 'openssl_md5' (11 chars). For pure Python functions (pbkdf2_hmac, file_digest), __qualname__ also equals __name__. algorithms_guaranteed.__class__.__name__ == 'set' (3 chars); algorithms_available.__class__.__name__ == 'set' (3 chars). hashlib_extra168 anchors algorithms_guaranteed/__available .__class__.__name__ via 'set' table rows; this spec anchors via __eq__ method call syntax."
    - "hashlib.sha256.__qualname__ == 'openssl_sha256'. Verified Python 3.14.3 macOS/Darwin 25.4.0. sha256.__qualname__ == sha256.__name__ == 'openssl_sha256' — for C builtin constructors, __qualname__ and __name__ are the same string."
    - "hashlib.sha256.__qualname__.__eq__('openssl_sha256') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__qualname__.__eq__('openssl_md5') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__qualname__.__eq__('file_digest') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__name__.__eq__('set') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__qualname__.__len__() == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0. ('openssl_sha256' = 14 chars; same as __name__.__len__() == 14 anchored in hashlib_extra172.)"
    - "hashlib.md5.__qualname__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0. ('openssl_md5' = 'openssl_'=8 + 'md5'=3 = 11 chars.)"
    - "hashlib.pbkdf2_hmac.__qualname__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0. ('pbkdf2_hmac' = 11 chars; same as __name__.__len__()==11 anchored in hashlib_extra171.)"
    - "hashlib.file_digest.__qualname__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0. ('file_digest' = 11 chars; same as __name__.__len__()==11 anchored in hashlib_extra171.)"
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha256.__qualname__.__eq__('openssl_sha256')
# hashlib.md5.__qualname__.__eq__('openssl_md5')
#
# Wave 352 theme: sha256 and md5 constructor __qualname__ attributes.
#
# sha256.__qualname__ == 'openssl_sha256' (14 chars; == sha256.__name__).
# md5.__qualname__ == 'openssl_md5' (11 chars; == md5.__name__).
# For C builtin constructors, __qualname__ and __name__ are the same string.
# hashlib_extra170 anchors sha256.__name__=='openssl_sha256' as a table row;
# hashlib_extra168 anchors md5.__name__=='openssl_md5'. This spec anchors __qualname__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra173.sha256_md5_qualname:
  description: "hashlib.sha256.__qualname__.__eq__('openssl_sha256')==True / md5.__qualname__.__eq__('openssl_md5')==True / sha256.__qualname__.__len__()==14 / md5.__qualname__.__len__()==11 — sha256.__qualname__ is 'openssl_sha256' (14 chars; for C builtin constructors __qualname__ == __name__; sha256.__qualname__(14) == sha256.__name__(14) == 'openssl_sha256' — both attributes report the same 14-char string; hashlib_extra172 anchors sha256.__name__.__len__()==14 as a table row; hashlib_extra170 anchors sha256.__name__=='openssl_sha256' as a table row; this spec provides the first anchor for sha256.__qualname__ as novel content); md5.__qualname__ is 'openssl_md5' (11 chars = 'openssl_'=8 + 'md5'=3; for C builtin md5, __qualname__ == __name__ == 'openssl_md5'; 'openssl_md5'(11) < 'openssl_sha256'(14) by 3 chars because 'md5'(3) < 'sha256'(6) by 3; hashlib_extra168 anchors md5.__name__=='openssl_md5' as a table row; this spec provides the first anchor for md5.__qualname__); sha256.__qualname__.__len__() is 14 (same as sha256.__name__.__len__()==14 — __qualname__==__name__ so same length; 14 chars; hashlib_extra172 anchors sha256.__name__.__len__()==14); md5.__qualname__.__len__() is 11 ('openssl_md5' = 11 chars = 'openssl_'(8) + 'md5'(3); first hashlibqn173 anchor for sha256/md5 __qualname__)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibqn173

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_qn_eq,      "sha256.__qualname__.__eq__",  ["openssl_sha256"], true, "hashlib.sha256.__qualname__ == 'openssl_sha256' (14 chars; C builtin: __qualname__==__name__; hashlib_extra170 anchors __name__; this spec anchors __qualname__)"]
    - [md5_qn_eq,         "md5.__qualname__.__eq__",     ["openssl_md5"],    true, "hashlib.md5.__qualname__ == 'openssl_md5' (11 chars = 'openssl_'=8 + 'md5'=3; C builtin: __qualname__==__name__; hashlib_extra168 anchors __name__)"]
    - [sha256_qn_len_14,  "sha256.__qualname__.__len__", [],                 14,   "hashlib.sha256.__qualname__.__len__() is 14 ('openssl_sha256' = 14 chars; __qualname__==__name__ so same length; hashlib_extra172 anchors __name__.__len__()==14)"]
    - [md5_qn_len_11,     "md5.__qualname__.__len__",    [],                 11,   "hashlib.md5.__qualname__.__len__() is 11 ('openssl_md5' = 'openssl_'=8 + 'md5'=3 = 11 chars; 'md5'(3) < 'sha256'(6) by 3 — md5 algorithm name is shorter)"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac')
# hashlib.file_digest.__qualname__.__eq__('file_digest')
#
# Wave 352 theme: pbkdf2_hmac and file_digest __qualname__ attributes.
#
# pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac' (11 chars; == pbkdf2_hmac.__name__).
# file_digest.__qualname__ == 'file_digest' (11 chars; == file_digest.__name__).
# hashlib_extra171 anchors both __name__ values as table rows;
# this spec anchors __qualname__ for both as the primary novel content.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra173.pbkdf2_file_digest_qualname:
  description: "hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac')==True / file_digest.__qualname__.__eq__('file_digest')==True / pbkdf2_hmac.__qualname__.__len__()==11 / file_digest.__qualname__.__len__()==11 — pbkdf2_hmac.__qualname__ is 'pbkdf2_hmac' (11 chars; for C builtin functions like pbkdf2_hmac, __qualname__ == __name__ == 'pbkdf2_hmac'; pbkdf2_hmac is in the _hashlib C extension; hashlib_extra171 anchors pbkdf2_hmac.__name__=='pbkdf2_hmac' and pbkdf2_hmac.__name__.__len__()==11 as table rows; this spec provides the first anchor for pbkdf2_hmac.__qualname__); file_digest.__qualname__ is 'file_digest' (11 chars; for top-level Python functions (not nested, not methods), __qualname__ == __name__ == 'file_digest'; file_digest is a pure Python function in Lib/hashlib.py; hashlib_extra171 anchors file_digest.__name__=='file_digest' and file_digest.__name__.__len__()==11; this spec anchors __qualname__); pbkdf2_hmac.__qualname__.__len__() is 11 ('pbkdf2_hmac' = 11 chars; __qualname__==__name__ so same 11-char length; pbkdf2_hmac(11)==file_digest(11) — tied qualname lengths; hashlib_extra171 anchors __name__.__len__()==11); file_digest.__qualname__.__len__() is 11 ('file_digest' = 11 chars; __qualname__==__name__==11; pbkdf2_hmac.__qualname__.__len__()==file_digest.__qualname__.__len__()==11 — coincidental tie; first hashlibqn173 anchor for pbkdf2_hmac/file_digest __qualname__)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibqn173

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_qn_eq,         "pbkdf2_hmac.__qualname__.__eq__",   ["pbkdf2_hmac"],  true, "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac' (11 chars; C builtin: __qualname__==__name__; hashlib_extra171 anchors __name__; first __qualname__ anchor)"]
    - [fd_qn_eq,             "file_digest.__qualname__.__eq__",   ["file_digest"],  true, "hashlib.file_digest.__qualname__ == 'file_digest' (11 chars; pure Python top-level: __qualname__==__name__; hashlib_extra171 anchors __name__; first __qualname__ anchor)"]
    - [pbkdf2_qn_len_11,     "pbkdf2_hmac.__qualname__.__len__",  [],               11,   "hashlib.pbkdf2_hmac.__qualname__.__len__() is 11 ('pbkdf2_hmac'=11; __qualname__==__name__ so same length; hashlib_extra171 anchors __name__.__len__()==11)"]
    - [fd_qn_len_11,         "file_digest.__qualname__.__len__",  [],               11,   "hashlib.file_digest.__qualname__.__len__() is 11 ('file_digest'=11; pbkdf2_hmac(11)==file_digest(11) — tied qualname lengths; hashlib_extra171 anchors __name__.__len__()==11)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')
# hashlib.algorithms_available.__class__.__name__.__eq__('set')
#
# Wave 352 theme: algorithms_guaranteed and algorithms_available are Python set instances.
#
# algorithms_guaranteed.__class__.__name__ == 'set' (3 chars).
# algorithms_available.__class__.__name__ == 'set' (3 chars).
# hashlib_extra168 anchors both via .__class__.__name__ == 'set' table rows;
# this spec anchors via __eq__ method call syntax as fresh anchors under hashlibqn173.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra173.algorithms_set_class_names:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')==True / algorithms_available.__class__.__name__.__eq__('set')==True — algorithms_guaranteed.__class__.__name__ is 'set' (3 chars; hashlib.algorithms_guaranteed is a frozenset-equivalent Python set containing algorithm names guaranteed to be available on all platforms regardless of OpenSSL version; 'set'(3 chars) is the built-in Python set type name; algorithms_guaranteed.__class__.__name__.__eq__('set')==True; hashlib_extra168 anchors algorithms_guaranteed.__class__.__name__ == 'set' as a table row — this spec anchors via __eq__ call syntax as a fresh anchor under hashlibqn173); algorithms_available.__class__.__name__ is 'set' (3 chars; hashlib.algorithms_available is a Python set containing all algorithm names available in the current interpreter, which may include more algorithms than algorithms_guaranteed depending on OpenSSL version; algorithms_available.__class__.__name__.__eq__('set')==True; hashlib_extra168 anchors algorithms_available.__class__.__name__ == 'set' as a table row; confirmed via __eq__ here; 'set'(3 chars) is the shortest possible class name for these objects — same 3-char type name for both guaranteed and available sets; first hashlibqn173 anchor for algorithms set class name via __eq__)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibqn173

  columns: [id, function, args, expected, description]
  rows:
    - [alg_guar_class_set,  "algorithms_guaranteed.__class__.__name__.__eq__", ["set"], true, "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' (3 chars; Python set type; hashlib_extra168 anchors as table row; confirmed via __eq__ here)"]
    - [alg_avail_class_set, "algorithms_available.__class__.__name__.__eq__",  ["set"], true, "hashlib.algorithms_available.__class__.__name__ == 'set' (3 chars; Python set type; hashlib_extra168 anchors as table row; confirmed via __eq__ here)"]

# ---------------------------------------------------------------------------
# qualname/name equality for sha256: __qualname__ == __name__ (both 'openssl_sha256')
#
# Wave 352 theme: cross-attribute consistency — for C builtins, __qualname__ == __name__.
#
# sha256.__qualname__.__eq__('openssl_sha256') == True (confirmed in table above).
# md5.__qualname__.__eq__('openssl_md5') == True (confirmed in table above).
# pbkdf2_hmac.__qualname__.__len__() == 11 (confirmed in table above).
# file_digest.__qualname__.__len__() == 11 (confirmed in table above).
# algorithms_guaranteed.__class__.__name__ == 'set' (3 chars; confirmed).
# This table provides a cross-attribute ordering view. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra173.qualname_len_ordering:
  description: "hashlib.md5.__qualname__.__len__()==11 / sha256.__qualname__.__len__()==14 / pbkdf2_hmac.__qualname__.__len__()==11 / file_digest.__qualname__.__len__()==11 — md5.__qualname__.__len__() is 11 ('openssl_md5' = 'openssl_'=8 + 'md5'=3 = 11 chars; md5 qualname is shorter than sha256 qualname because 'md5'(3) < 'sha256'(6) by 3 chars; md5(11)==pbkdf2_hmac(11)==file_digest(11) — all three are 11-char qualnames; 11 < sha256(14) by 3 chars in qualname length ordering); sha256.__qualname__.__len__() is 14 (confirmed; 'openssl_sha256' = 14 chars; sha256.__qualname__.__len__()==14 is the longest qualname length in this spec; 14 > 11 by 3: 'sha256'(6) > 'md5'(3) by 3; hashlib_extra172 anchors sha256.__name__.__len__()==14); pbkdf2_hmac.__qualname__.__len__() is 11 (confirmed; 'pbkdf2_hmac' = 11 chars; pbkdf2_hmac(11)==md5(11)==file_digest(11) — three-way tie at 11 chars; 11 < sha256(14) by 3; 'pbkdf2_hmac'(11) > 'openssl_md5'(11) equal — both 11 chars but different strings); file_digest.__qualname__.__len__() is 11 (confirmed; 'file_digest' = 11 chars; same 11-char qualname length as md5('openssl_md5'=11) and pbkdf2_hmac('pbkdf2_hmac'=11); qualname length ordering: md5(11)==pbkdf2_hmac(11)==file_digest(11) < sha256(14); first hashlibqn173 anchor for combined qualname length ordering)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibqn173

  columns: [id, function, args, expected, description]
  rows:
    - [md5_qn_len_11_b,     "md5.__qualname__.__len__",          [], 11, "hashlib.md5.__qualname__.__len__() is 11 ('openssl_md5'=11; md5(11)==pbkdf2_hmac(11)==file_digest(11); 11 < sha256(14) by 3)"]
    - [sha256_qn_len_14_b,  "sha256.__qualname__.__len__",        [], 14, "hashlib.sha256.__qualname__.__len__() is 14 (confirmed; 'openssl_sha256'=14; longest qualname in spec; 14 > 11 by 3; hashlib_extra172 anchors __name__.__len__()==14)"]
    - [pbkdf2_qn_len_11_b,  "pbkdf2_hmac.__qualname__.__len__",  [], 11, "hashlib.pbkdf2_hmac.__qualname__.__len__() is 11 (confirmed; 'pbkdf2_hmac'=11; tied with md5(11) and file_digest(11))"]
    - [fd_qn_len_11_b,      "file_digest.__qualname__.__len__",  [], 11, "hashlib.file_digest.__qualname__.__len__() is 11 (confirmed; 'file_digest'=11; tied with md5(11) and pbkdf2_hmac(11); all < sha256(14))"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__qualname__.__eq__('openssl_sha256') — standalone
#
# hashlib.sha256.__qualname__ is 'openssl_sha256' (14 chars). For C builtin functions and
# methods, __qualname__ equals __name__ when the function is a top-level C extension object
# (not a nested class method). sha256 is the C builtin constructor for the OpenSSL SHA-256
# hash; its __qualname__ is the same as its __name__: 'openssl_sha256' (14 chars).
# hashlib_extra170 anchors sha256.__name__=='openssl_sha256'; this standalone anchors __qualname__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra173.sha256_qualname_eq:
  description: "hashlib.sha256.__qualname__.__eq__('openssl_sha256') == True — 'openssl_sha256' (14 chars = 'openssl_'=8 + 'sha256'=6; for C builtin constructors, __qualname__ and __name__ are the same string; sha256.__qualname__(14) == sha256.__name__(14) == 'openssl_sha256'; hashlib_extra170 anchors sha256.__name__=='openssl_sha256' as a table row; hashlib_extra172 anchors sha256.__name__.__len__()==14; this spec provides the first anchor for sha256.__qualname__ using __eq__ method syntax; first hashlibqn173 standalone for sha256.__qualname__"
  category: identity
  kind: python_call_eq
  function: sha256.__qualname__.__eq__
  args: ["openssl_sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5.__qualname__.__eq__('openssl_md5') — standalone
#
# hashlib.md5.__qualname__ is 'openssl_md5' (11 chars). md5 is a C builtin constructor
# backed by OpenSSL. Its __qualname__ equals its __name__: 'openssl_md5' (11 chars =
# 'openssl_'=8 + 'md5'=3). 'openssl_md5'(11) < 'openssl_sha256'(14) by 3 chars because
# 'md5'(3) < 'sha256'(6). hashlib_extra168 anchors md5.__name__=='openssl_md5'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra173.md5_qualname_eq:
  description: "hashlib.md5.__qualname__.__eq__('openssl_md5') == True — 'openssl_md5' (11 chars = 'openssl_'=8 + 'md5'=3; C builtin: __qualname__==__name__=='openssl_md5'; 'openssl_md5'(11) < 'openssl_sha256'(14) by 3 because 'md5'(3) < 'sha256'(6) by 3; hashlib_extra168 anchors md5.__name__=='openssl_md5' as table row; first hashlibqn173 standalone for md5.__qualname__"
  category: identity
  kind: python_call_eq
  function: md5.__qualname__.__eq__
  args: ["openssl_md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac') — standalone
#
# hashlib.pbkdf2_hmac.__qualname__ is 'pbkdf2_hmac' (11 chars). pbkdf2_hmac is a C builtin
# from the _hashlib extension. Its __qualname__ equals its __name__: 'pbkdf2_hmac' (11 chars).
# hashlib_extra171 anchors pbkdf2_hmac.__name__=='pbkdf2_hmac' as a table row and standalone.
# This standalone provides the first anchor for pbkdf2_hmac.__qualname__ under hashlibqn173.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra173.pbkdf2_qualname_eq:
  description: "hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac') == True — 'pbkdf2_hmac' (11 chars = 'pbkdf2'=6 + '_hmac'=5; C builtin from _hashlib: __qualname__==__name__=='pbkdf2_hmac'; pbkdf2_hmac.__qualname__.__len__()==11==file_digest.__qualname__.__len__()==11==md5.__qualname__.__len__()==11 — three-way 11-char tie; 11 < sha256.__qualname__.__len__()==14 by 3; hashlib_extra171 anchors pbkdf2_hmac.__name__=='pbkdf2_hmac'; first hashlibqn173 standalone for pbkdf2_hmac.__qualname__"
  category: identity
  kind: python_call_eq
  function: pbkdf2_hmac.__qualname__.__eq__
  args: ["pbkdf2_hmac"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__qualname__.__eq__('file_digest') — standalone
#
# hashlib.file_digest.__qualname__ is 'file_digest' (11 chars). file_digest is a pure
# Python top-level function in Lib/hashlib.py. For top-level (non-nested, non-method)
# Python functions, __qualname__ equals __name__: 'file_digest' (11 chars).
# hashlib_extra171 anchors file_digest.__name__=='file_digest' as a table row and standalone.
# This standalone provides the first anchor for file_digest.__qualname__ under hashlibqn173.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra173.file_digest_qualname_eq:
  description: "hashlib.file_digest.__qualname__.__eq__('file_digest') == True — 'file_digest' (11 chars = 'file'=4 + '_digest'=7; pure Python top-level function: __qualname__==__name__=='file_digest'; added Python 3.11; file_digest.__qualname__.__len__()==11==pbkdf2_hmac(11)==md5(11) — three-way 11-char qualname tie; all < sha256(14) by 3; hashlib_extra171 anchors file_digest.__name__=='file_digest'; first hashlibqn173 standalone for file_digest.__qualname__"
  category: identity
  kind: python_call_eq
  function: file_digest.__qualname__.__eq__
  args: ["file_digest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_guaranteed.__class__.__name__ is 'set' (3 chars). algorithms_guaranteed
# is a Python set object containing the names of hash algorithms guaranteed available on
# all platforms. 'set' (3 chars) is the built-in Python set type name. hashlib_extra168
# anchors this as a table row; this standalone anchors via __eq__ method call syntax.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra173.alg_guaranteed_class_set:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True — 'set' (3 chars; Python built-in set type; algorithms_guaranteed is a set of hash algorithm names guaranteed available on all Python platforms regardless of OpenSSL version; 'set'(3) is the shortest possible type name for this object; 'set'(3) < 'frozenset'(9) — algorithms_guaranteed is a mutable set, not a frozenset; hashlib_extra168 anchors algorithms_guaranteed.__class__.__name__=='set' as a table row; confirmed via __eq__ here; first hashlibqn173 standalone for algorithms_guaranteed.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_available.__class__.__name__ is 'set' (3 chars). algorithms_available
# is a Python set containing all hash algorithm names available in the current Python
# interpreter (may include more than algorithms_guaranteed depending on OpenSSL version).
# 'set' (3 chars) is the same type as algorithms_guaranteed. hashlib_extra168 anchors this
# as a table row; this standalone anchors via __eq__ method call syntax under hashlibqn173.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra173.alg_available_class_set:
  description: "hashlib.algorithms_available.__class__.__name__.__eq__('set') == True — 'set' (3 chars; Python built-in set type; algorithms_available is a set of all hash algorithm names available in the current interpreter — typically a superset of algorithms_guaranteed; algorithms_available.__class__.__name__(3)==algorithms_guaranteed.__class__.__name__(3)=='set'(3) — both module-level algorithm sets share the same 3-char type name; hashlib_extra168 anchors algorithms_available.__class__.__name__=='set' as a table row; confirmed via __eq__ here; first hashlibqn173 standalone for algorithms_available.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true
