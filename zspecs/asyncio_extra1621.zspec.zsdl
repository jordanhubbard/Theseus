spec: asyncio_extra1621
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __weakref__ and weak reference protocol"
    - "asyncio.Future and asyncio.Task are C extension types (from _asyncio); they do not expose __weakref__ in their class __dict__ because C types implement weakref support via tp_weaklistoffset without adding a Python getset_descriptor"
    - "asyncio sync primitives (Lock, Event, Queue, Semaphore, BoundedSemaphore, Condition, LifoQueue, PriorityQueue) are pure Python classes that inherit from object indirectly; they do NOT own __weakref__ in their own __dict__ because a parent class in their MRO already supplies it"
    - "asyncio.TimerHandle inherits from asyncio.Handle; Handle owns __weakref__, so TimerHandle does not re-define it"
    - "asyncio.BaseEventLoop does not own __weakref__ because a parent already defines it"
    - "asyncio.DefaultEventLoopPolicy inherits from AbstractEventLoopPolicy which owns __weakref__; DefaultEventLoopPolicy does not re-define it"
    - "Exception subclasses inherit through BaseException; only the first pure-Python subclass in a chain that adds no __slots__ owns __weakref__ in its own dict"
    - "asyncio.TimeoutError and asyncio.InvalidStateError differ: TimeoutError inherits from builtins.TimeoutError (C type), so __weakref__ is NOT in TimeoutError.__dict__; InvalidStateError is a direct subclass of Exception (pure Python) so __weakref__ IS in its __dict__"
    - "asyncio.CancelledError is a pure Python subclass of BaseException; __weakref__ is in its own __dict__"
    - "asyncio.QueueEmpty and asyncio.QueueFull are pure Python subclasses of Exception; __weakref__ is in their own __dict__"
    - "asyncio.StreamReader and asyncio.StreamWriter are pure Python classes (no slots); __weakref__ is in their own __dict__"
    - "asyncio.Handle is a pure Python class with no __slots__; __weakref__ is in its own __dict__"
    - "asyncio.AbstractEventLoop is an abstract base class defined in pure Python; __weakref__ is in its own __dict__"
    - "asyncio.AbstractEventLoopPolicy is a pure Python abstract class; __weakref__ is in its own __dict__"
    - "asyncio.AbstractServer is a pure Python abstract class; __weakref__ is in its own __dict__"
    - "asyncio.Runner and asyncio.Timeout are pure Python classes (no slots); __weakref__ is in their own __dict__"
    - "Transport hierarchy classes (BaseTransport, ReadTransport, WriteTransport, DatagramTransport, Transport) and Protocol classes do not own __weakref__ because a parent in the MRO already defines it"
  created_at: "2026-04-12"
error_model: python_exceptions

table asyncio_extra1621.future_task_no_weakref:
  description: "asyncio.Future and asyncio.Task are C extension types from _asyncio; C types do not expose __weakref__ as a getset_descriptor in their class __dict__ even when instances support weak references"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1621ft

  columns: [id, function, args, expected]
  rows:
    - ["as1621ft001", "asyncio.Future.__dict__.__contains__",                  ["__weakref__"], false]
    - ["as1621ft002", "asyncio.Task.__dict__.__contains__",                    ["__weakref__"], false]
    - ["as1621ft003", "asyncio.Future.__dict__.__contains__",                  ["__dict__"],    false]
    - ["as1621ft004", "asyncio.Task.__dict__.__contains__",                    ["__dict__"],    false]
    - ["as1621ft005", "asyncio.Future.__dict__.__contains__",                  ["__slots__"],   false]
    - ["as1621ft006", "asyncio.Task.__dict__.__contains__",                    ["__slots__"],   false]
    - ["as1621ft007", "asyncio.Future.__dict__.__class__.__name__.__eq__",     ["mappingproxy"], true]
    - ["as1621ft008", "asyncio.Task.__dict__.__class__.__name__.__eq__",       ["mappingproxy"], true]
    - ["as1621ft009", "asyncio.Future.__name__.__eq__",                        ["Future"],      true]
    - ["as1621ft010", "asyncio.Task.__name__.__eq__",                          ["Task"],        true]
    - ["as1621ft011", "asyncio.Future.__module__.__eq__",                      ["asyncio.futures"], true]
    - ["as1621ft012", "asyncio.Task.__module__.__eq__",                        ["asyncio.tasks"], true]

table asyncio_extra1621.sync_primitives_no_weakref:
  description: "asyncio synchronization primitives are pure Python classes that do not own __weakref__ in their own __dict__; they inherit weak reference support from object through a parent class that already defined __weakref__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1621sp

  columns: [id, function, args, expected]
  rows:
    - ["as1621sp001", "asyncio.Lock.__dict__.__contains__",                    ["__weakref__"], false]
    - ["as1621sp002", "asyncio.Event.__dict__.__contains__",                   ["__weakref__"], false]
    - ["as1621sp003", "asyncio.Queue.__dict__.__contains__",                   ["__weakref__"], false]
    - ["as1621sp004", "asyncio.Semaphore.__dict__.__contains__",               ["__weakref__"], false]
    - ["as1621sp005", "asyncio.BoundedSemaphore.__dict__.__contains__",        ["__weakref__"], false]
    - ["as1621sp006", "asyncio.Condition.__dict__.__contains__",               ["__weakref__"], false]
    - ["as1621sp007", "asyncio.LifoQueue.__dict__.__contains__",               ["__weakref__"], false]
    - ["as1621sp008", "asyncio.PriorityQueue.__dict__.__contains__",           ["__weakref__"], false]
    - ["as1621sp009", "asyncio.Handle.__dict__.__contains__",                  ["__weakref__"], true]
    - ["as1621sp010", "asyncio.TimerHandle.__dict__.__contains__",             ["__weakref__"], false]
    - ["as1621sp011", "asyncio.StreamReader.__dict__.__contains__",            ["__weakref__"], true]
    - ["as1621sp012", "asyncio.StreamWriter.__dict__.__contains__",            ["__weakref__"], true]
    - ["as1621sp013", "asyncio.Runner.__dict__.__contains__",                  ["__weakref__"], true]
    - ["as1621sp014", "asyncio.Timeout.__dict__.__contains__",                 ["__weakref__"], true]
    - ["as1621sp015", "asyncio.BaseEventLoop.__dict__.__contains__",           ["__weakref__"], false]
    - ["as1621sp016", "asyncio.AbstractEventLoop.__dict__.__contains__",       ["__weakref__"], true]
    - ["as1621sp017", "asyncio.AbstractServer.__dict__.__contains__",          ["__weakref__"], true]
    - ["as1621sp018", "asyncio.BaseTransport.__dict__.__contains__",           ["__weakref__"], false]
    - ["as1621sp019", "asyncio.ReadTransport.__dict__.__contains__",           ["__weakref__"], false]
    - ["as1621sp020", "asyncio.WriteTransport.__dict__.__contains__",          ["__weakref__"], false]
    - ["as1621sp021", "asyncio.DatagramTransport.__dict__.__contains__",       ["__weakref__"], false]
    - ["as1621sp022", "asyncio.Transport.__dict__.__contains__",               ["__weakref__"], false]
    - ["as1621sp023", "asyncio.BaseProtocol.__dict__.__contains__",            ["__weakref__"], false]
    - ["as1621sp024", "asyncio.Protocol.__dict__.__contains__",                ["__weakref__"], false]
    - ["as1621sp025", "asyncio.DatagramProtocol.__dict__.__contains__",        ["__weakref__"], false]
    - ["as1621sp026", "asyncio.SubprocessProtocol.__dict__.__contains__",      ["__weakref__"], false]
    - ["as1621sp027", "asyncio.BufferedProtocol.__dict__.__contains__",        ["__weakref__"], false]

table asyncio_extra1621.exceptions_no_weakref:
  description: "asyncio exception classes: CancelledError and some queue exceptions are pure Python and own __weakref__; TimeoutError inherits from the C builtin TimeoutError and does not own __weakref__; InvalidStateError is a direct pure-Python subclass of Exception and does own __weakref__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1621ex

  columns: [id, function, args, expected]
  rows:
    - ["as1621ex001", "asyncio.CancelledError.__dict__.__contains__",          ["__weakref__"], true]
    - ["as1621ex002", "asyncio.TimeoutError.__dict__.__contains__",            ["__weakref__"], false]
    - ["as1621ex003", "asyncio.InvalidStateError.__dict__.__contains__",       ["__weakref__"], true]
    - ["as1621ex004", "asyncio.QueueEmpty.__dict__.__contains__",              ["__weakref__"], true]
    - ["as1621ex005", "asyncio.QueueFull.__dict__.__contains__",               ["__weakref__"], true]
    - ["as1621ex006", "asyncio.CancelledError.__dict__.__contains__",          ["__dict__"],    false]
    - ["as1621ex007", "asyncio.TimeoutError.__dict__.__contains__",            ["__dict__"],    false]
    - ["as1621ex008", "asyncio.InvalidStateError.__dict__.__contains__",       ["__dict__"],    false]
    - ["as1621ex009", "asyncio.QueueEmpty.__dict__.__contains__",              ["__dict__"],    false]
    - ["as1621ex010", "asyncio.QueueFull.__dict__.__contains__",               ["__dict__"],    false]
    - ["as1621ex011", "asyncio.CancelledError.__name__.__eq__",                ["CancelledError"], true]
    - ["as1621ex012", "asyncio.TimeoutError.__name__.__eq__",                  ["TimeoutError"], true]
    - ["as1621ex013", "asyncio.InvalidStateError.__name__.__eq__",             ["InvalidStateError"], true]
    - ["as1621ex014", "asyncio.QueueEmpty.__name__.__eq__",                    ["QueueEmpty"], true]
    - ["as1621ex015", "asyncio.QueueFull.__name__.__eq__",                     ["QueueFull"], true]
