spec: decimal_extra1246
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal __doc__ class checks for module, Decimal, Context, getcontext, setcontext, localcontext, DecimalException, InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["decimal.Decimal, Context, getcontext, setcontext, localcontext all have str __doc__; decimal.DecimalException, InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded all have NoneType __doc__ (no docstrings defined on those exception subclasses); none of these __doc__ class checks were covered in prior decimal_extra specs (_extra1201, _extra1216, _extra1231)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1246.module_and_core_classes_doc_class:
  description: "decimal module, Decimal, and Context classes have str __doc__"
  kind: python_call_eq
  category: doc_class
  id_prefix: dc1246mc
  columns: [id, function, args, expected]
  rows:
    - [dc1246mc001, decimal.__doc__.__class__.__name__.__eq__,          ["str"],     true]
    - [dc1246mc002, decimal.__doc__.__class__.__name__.__eq__,          ["NoneType"], false]
    - [dc1246mc003, decimal.Decimal.__doc__.__class__.__name__.__eq__,  ["str"],     true]
    - [dc1246mc004, decimal.Decimal.__doc__.__class__.__name__.__eq__,  ["NoneType"], false]
    - [dc1246mc005, decimal.Context.__doc__.__class__.__name__.__eq__,  ["str"],     true]
    - [dc1246mc006, decimal.Context.__doc__.__class__.__name__.__eq__,  ["NoneType"], false]
    - [dc1246mc007, decimal.getcontext.__doc__.__class__.__name__.__eq__, ["str"],   true]
    - [dc1246mc008, decimal.getcontext.__doc__.__class__.__name__.__eq__, ["NoneType"], false]
    - [dc1246mc009, decimal.setcontext.__doc__.__class__.__name__.__eq__, ["str"],   true]
    - [dc1246mc010, decimal.setcontext.__doc__.__class__.__name__.__eq__, ["NoneType"], false]

