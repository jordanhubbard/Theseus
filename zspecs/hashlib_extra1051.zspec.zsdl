spec: hashlib_extra1051
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib.md5, sha256, sha512, new, and pbkdf2_hmac __reduce_ex__ and __sizeof__ qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1051.reduce_ex_qualnames:
  description: "hashlib function __reduce_ex__.__qualname__ identity"
  kind: python_call_eq
  category: reduce_ex_qualnames
  id_prefix: hl1051x
  columns: [id, function, args, expected]
  rows:
    - [hl1051x001, hashlib.md5.__reduce_ex__.__qualname__.__eq__,         ["builtin_function_or_method.__reduce_ex__"], true]
    - [hl1051x002, hashlib.sha256.__reduce_ex__.__qualname__.__eq__,      ["builtin_function_or_method.__reduce_ex__"], true]
    - [hl1051x003, hashlib.new.__reduce_ex__.__qualname__.__eq__,         ["builtin_function_or_method.__reduce_ex__"], true]
    - [hl1051x004, hashlib.pbkdf2_hmac.__reduce_ex__.__qualname__.__eq__, ["builtin_function_or_method.__reduce_ex__"], true]
    - [hl1051x005, hashlib.md5.__reduce_ex__.__qualname__.__class__.__name__.__eq__,    ["str"], true]
    - [hl1051x006, hashlib.sha256.__reduce_ex__.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [hl1051x007, hashlib.new.__reduce_ex__.__qualname__.__class__.__name__.__eq__,    ["str"], true]

table hashlib_extra1051.sizeof_qualnames:
  description: "hashlib function __sizeof__.__qualname__ identity"
  kind: python_call_eq
  category: sizeof_qualnames
  id_prefix: hl1051s
  columns: [id, function, args, expected]
  rows:
    - [hl1051s001, hashlib.md5.__sizeof__.__qualname__.__eq__,    ["builtin_function_or_method.__sizeof__"], true]
    - [hl1051s002, hashlib.sha256.__sizeof__.__qualname__.__eq__, ["builtin_function_or_method.__sizeof__"], true]
    - [hl1051s003, hashlib.sha512.__sizeof__.__qualname__.__eq__, ["builtin_function_or_method.__sizeof__"], true]
    - [hl1051s004, hashlib.new.__sizeof__.__qualname__.__eq__,    ["builtin_function_or_method.__sizeof__"], true]
    - [hl1051s005, hashlib.md5.__sizeof__.__qualname__.__class__.__name__.__eq__,    ["str"], true]
    - [hl1051s006, hashlib.sha256.__sizeof__.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [hl1051s007, hashlib.sha512.__sizeof__.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [hl1051s008, hashlib.new.__sizeof__.__qualname__.__class__.__name__.__eq__,    ["str"], true]

table hashlib_extra1051.class_identity:
  description: "hashlib function __class__.__name__ and module identity checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: hl1051c
  columns: [id, function, args, expected]
  rows:
    - [hl1051c001, hashlib.md5.__class__.__name__.__eq__,         ["builtin_function_or_method"], true]
    - [hl1051c002, hashlib.sha256.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [hl1051c003, hashlib.sha512.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [hl1051c004, hashlib.new.__class__.__name__.__eq__,         ["builtin_function_or_method"], true]
    - [hl1051c005, hashlib.pbkdf2_hmac.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl1051c006, hashlib.md5.__module__.__eq__,                 ["_hashlib"],                  true]
    - [hl1051c007, hashlib.sha256.__module__.__eq__,              ["_hashlib"],                  true]
