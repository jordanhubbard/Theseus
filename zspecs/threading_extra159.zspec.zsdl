spec: threading_extra159
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Condition method qualnames — Condition.wait.__qualname__ 'Condition.wait', Condition.notify.__qualname__ 'Condition.notify', Condition.notify_all.__qualname__ 'Condition.notify_all'; Condition does not define acquire/release (they are delegated to the underlying lock); threading.Semaphore.acquire.__qualname__ 'Semaphore.acquire'; threading.Semaphore.release.__qualname__ 'Semaphore.release'; threading.Event.set.__qualname__ 'Event.set' (Wave 287)."
    - "threading.Condition.wait.__qualname__ == 'Condition.wait' — Condition defines wait() in Lib/threading.py to release the lock, sleep until notified, then re-acquire; __qualname__ is 'Condition.wait'. Verified with Python 3.14.3."
    - "threading.Condition.notify.__qualname__ == 'Condition.notify' — Condition defines notify() in Lib/threading.py to wake one waiting thread; __qualname__ is 'Condition.notify'. Verified with Python 3.14.3."
    - "threading.Condition.notify_all.__qualname__ == 'Condition.notify_all' — Condition defines notify_all() in Lib/threading.py to wake all waiting threads; __qualname__ is 'Condition.notify_all'. Verified with Python 3.14.3."
    - "threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' — Semaphore defines acquire() in Lib/threading.py to decrement the counter, blocking if zero; __qualname__ is 'Semaphore.acquire'. Verified with Python 3.14.3."
    - "threading.Semaphore.release.__qualname__ == 'Semaphore.release' — Semaphore defines release() in Lib/threading.py to increment the counter; __qualname__ is 'Semaphore.release'. Verified with Python 3.14.3."
    - "threading.Event.set.__qualname__ == 'Event.set' — Event defines set() in Lib/threading.py to set the internal flag and wake all waiting threads; __qualname__ is 'Event.set'. Verified with Python 3.14.3."
    - "threading.Condition does not define acquire or release in its __dict__ — those operations are delegated to the underlying lock object passed to the constructor; Condition.acquire and Condition.release are not in Condition.__dict__. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Condition method qualnames (wait, notify, notify_all)
#
# Wave 287 theme: threading.Condition method __qualname__ attributes.
#
# threading.Condition.wait.__qualname__ == 'Condition.wait'
# threading.Condition.notify.__qualname__ == 'Condition.notify'
# threading.Condition.notify_all.__qualname__ == 'Condition.notify_all'
# threading.Condition.__init__.__qualname__ == 'Condition.__init__'
#
# threading.Condition is a Python class in Lib/threading.py implementing the
# monitor pattern for thread synchronization. It wraps an underlying lock
# (RLock by default). Condition does NOT define acquire or release in its
# own class dict — those are delegated to the underlying lock. The methods
# it does define (wait, notify, notify_all, wait_for, __init__) all have
# __qualnames__ following the 'Condition.<method_name>' pattern.
# New to extra159.
# ---------------------------------------------------------------------------

table threading_extra159.condition_method_qualnames:
  description: "threading.Condition method qualnames: wait 'Condition.wait', notify 'Condition.notify', notify_all 'Condition.notify_all', __init__ 'Condition.__init__'; Condition does not define acquire/release; wave 287; new to extra159"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingcondmq159

  columns: [id, function, args, expected, description]
  rows:
    - [condition_wait_qualname_eq,
       "Condition.wait.__qualname__.__eq__",
       ["Condition.wait"],
       true,
       "threading.Condition.wait.__qualname__.__eq__('Condition.wait') == True — Condition.wait is defined in Lib/threading.py to release the underlying lock, wait until notified by another thread, then re-acquire the lock before returning; its __qualname__ is 'Condition.wait'; str.__eq__('Condition.wait') returns True; new to extra159"]
    - [condition_notify_qualname_eq,
       "Condition.notify.__qualname__.__eq__",
       ["Condition.notify"],
       true,
       "threading.Condition.notify.__qualname__.__eq__('Condition.notify') == True — Condition.notify is defined in Lib/threading.py to wake up one of the threads waiting on the condition variable; by default it wakes one thread; its __qualname__ is 'Condition.notify'; str.__eq__('Condition.notify') returns True; new to extra159"]
    - [condition_notify_all_qualname_eq,
       "Condition.notify_all.__qualname__.__eq__",
       ["Condition.notify_all"],
       true,
       "threading.Condition.notify_all.__qualname__.__eq__('Condition.notify_all') == True — Condition.notify_all is defined in Lib/threading.py to wake all threads waiting on the condition variable; its __qualname__ is 'Condition.notify_all'; str.__eq__('Condition.notify_all') returns True; new to extra159"]
    - [condition_init_qualname_eq,
       "Condition.__init__.__qualname__.__eq__",
       ["Condition.__init__"],
       true,
       "threading.Condition.__init__.__qualname__.__eq__('Condition.__init__') == True — Condition.__init__ is defined in Lib/threading.py to initialize the condition variable with an optional underlying lock (defaults to RLock); its __qualname__ is 'Condition.__init__'; str.__eq__('Condition.__init__') returns True; new to extra159"]

# ---------------------------------------------------------------------------
# Table 2: threading.Semaphore and threading.Event method qualnames
#
# Wave 287 theme: threading.Semaphore and threading.Event method __qualname__
# attributes.
#
# threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire'
# threading.Semaphore.release.__qualname__ == 'Semaphore.release'
# threading.Event.set.__qualname__ == 'Event.set'
#
# Semaphore is a Python class in Lib/threading.py implementing the classic
# counting semaphore. acquire() decrements the counter (blocking if zero);
# release() increments the counter. Event is a Python class implementing a
# simple flag-based signaling primitive. Event.set() sets the flag to True
# and wakes all threads waiting on Event.wait(). All methods are Python
# functions defined in the class body. New to extra159.
# ---------------------------------------------------------------------------

table threading_extra159.semaphore_and_event_method_qualnames:
  description: "threading.Semaphore: acquire qualname 'Semaphore.acquire', release qualname 'Semaphore.release'; threading.Event: set qualname 'Event.set'; wave 287; new to extra159"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingsemevmq159

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_acquire_qualname_eq,
       "Semaphore.acquire.__qualname__.__eq__",
       ["Semaphore.acquire"],
       true,
       "threading.Semaphore.acquire.__qualname__.__eq__('Semaphore.acquire') == True — Semaphore.acquire is defined in Lib/threading.py to decrement the semaphore counter, blocking if the counter is zero until another thread calls release; its __qualname__ is 'Semaphore.acquire'; str.__eq__('Semaphore.acquire') returns True; new to extra159"]
    - [semaphore_release_qualname_eq,
       "Semaphore.release.__qualname__.__eq__",
       ["Semaphore.release"],
       true,
       "threading.Semaphore.release.__qualname__.__eq__('Semaphore.release') == True — Semaphore.release is defined in Lib/threading.py to increment the semaphore counter and wake one waiting thread if any; its __qualname__ is 'Semaphore.release'; str.__eq__('Semaphore.release') returns True; new to extra159"]
    - [event_set_qualname_eq,
       "Event.set.__qualname__.__eq__",
       ["Event.set"],
       true,
       "threading.Event.set.__qualname__.__eq__('Event.set') == True — Event.set is defined in Lib/threading.py to set the internal flag to True and wake all threads blocked in Event.wait; its __qualname__ is 'Event.set'; str.__eq__('Event.set') returns True; new to extra159"]
    - [semaphore_acquire_qualname_class_eq_str,
       "Semaphore.acquire.__qualname__.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.Semaphore.acquire.__qualname__.__class__.__name__.__eq__('str') == True — the __qualname__ of a Python function is always a str; Semaphore.acquire.__qualname__ is a str object; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra159"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra159
# ---------------------------------------------------------------------------

invariant threading_extra159.condition_wait_qualname_eq:
  description: "threading.Condition.wait.__qualname__ == 'Condition.wait' — wait releases lock and sleeps until notified; wave 287; new to extra159"
  kind: python_call_eq
  function: Condition.wait.__qualname__.__eq__
  args: ["Condition.wait"]
  expected: true

invariant threading_extra159.condition_notify_qualname_eq:
  description: "threading.Condition.notify.__qualname__ == 'Condition.notify' — notify wakes one waiting thread; wave 287; new to extra159"
  kind: python_call_eq
  function: Condition.notify.__qualname__.__eq__
  args: ["Condition.notify"]
  expected: true

invariant threading_extra159.condition_notify_all_qualname_eq:
  description: "threading.Condition.notify_all.__qualname__ == 'Condition.notify_all' — notify_all wakes all waiting threads; wave 287; new to extra159"
  kind: python_call_eq
  function: Condition.notify_all.__qualname__.__eq__
  args: ["Condition.notify_all"]
  expected: true

invariant threading_extra159.semaphore_acquire_qualname_eq:
  description: "threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' — acquire decrements counter or blocks; wave 287; new to extra159"
  kind: python_call_eq
  function: Semaphore.acquire.__qualname__.__eq__
  args: ["Semaphore.acquire"]
  expected: true

invariant threading_extra159.semaphore_release_qualname_eq:
  description: "threading.Semaphore.release.__qualname__ == 'Semaphore.release' — release increments counter and wakes waiters; wave 287; new to extra159"
  kind: python_call_eq
  function: Semaphore.release.__qualname__.__eq__
  args: ["Semaphore.release"]
  expected: true

invariant threading_extra159.event_set_qualname_eq:
  description: "threading.Event.set.__qualname__ == 'Event.set' — set sets the flag True and wakes all Event.wait waiters; wave 287; new to extra159"
  kind: python_call_eq
  function: Event.set.__qualname__.__eq__
  args: ["Event.set"]
  expected: true

