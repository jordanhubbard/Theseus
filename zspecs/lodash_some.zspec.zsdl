spec: lodash_some
version: ">=4.0.0"
backend: node(lodash.some)

docs: https://lodash.com/docs/#some

provenance:
  derived_from:
    - "lodash.some README — https://www.npmjs.com/package/lodash.some"
    - "Test vectors verified with lodash.some@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.some exports the _.some function directly as module.exports."
    - "some(collection) with no iteratee checks direct truthiness."
    - "some(collection, key) uses property key as the iteratee."
    - "Returns false for empty collection."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_some.some:
  kind: node_module_call_eq
  function: ~
  category: some
  id_prefix: lsome

  columns: [id, args, expected]
  rows:
    - [all_false,    [[false, false, false]],            false]
    - [one_true,     [[false, true, false]],             true]
    - [empty,        [[]],                               false]
    - [prop_one,     [[{"v": false}, {"v": true}], "v"], true]
    - [prop_none,    [[{"v": false}, {"v": false}], "v"], false]
