spec: hashlib_extra172
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra171.zspec.zsdl — covers hashlib.new/__pbkdf2_hmac/__scrypt/__file_digest .__name__/__module__/__class__.__name__ and name lengths (table + invariants)."
    - "hashlib_extra170.zspec.zsdl — covers hashlib.sha1/__sha224/__sha384/__blake2b/__blake2s/__sha3_256 .__name__ (openssl_ prefix or bare) and .__module__ ('_hashlib' or '_blake2') and name lengths (table + invariants)."
    - "hashlib_extra169.zspec.zsdl — covers hashlib.algorithms_guaranteed/__available membership and lengths (table + invariants)."
    - "hashlib_extra168.zspec.zsdl — covers hashlib.sha256/__md5/__sha512 .__name__ and .__module__ (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra171."
    - "Wave 351 theme: hashlib constructor __name__.__len__() integer values for all eight OpenSSL/BLAKE2 constructors. hashlib_extra170 anchors the __name__ strings themselves (e.g. openssl_sha256 == 'openssl_sha256'); this spec anchors the __len__() integer values as the primary novel content. Name length ordering: blake2b(7)==blake2s(7) < openssl_sha1(12) < openssl_sha256(14)==openssl_sha512(14)==openssl_sha224(14)==openssl_sha384(14) < openssl_sha3_256(16). Note: openssl_sha256.__name__.__len__()==14 (NOT 13 as might be naively expected — 'openssl_sha256'=14 chars: 'openssl_'=8 + 'sha256'=6 = 14)."
    - "hashlib.sha256.__name__.__len__() == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0. ('openssl_sha256' = 'openssl_'=8 + 'sha256'=6 = 14 chars)"
    - "hashlib.sha512.__name__.__len__() == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0. ('openssl_sha512' = 14 chars)"
    - "hashlib.sha1.__name__.__len__() == 12. Verified Python 3.14.3 macOS/Darwin 25.4.0. ('openssl_sha1' = 'openssl_'=8 + 'sha1'=4 = 12 chars)"
    - "hashlib.sha224.__name__.__len__() == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0. ('openssl_sha224' = 14 chars)"
    - "hashlib.sha384.__name__.__len__() == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0. ('openssl_sha384' = 14 chars)"
    - "hashlib.sha3_256.__name__.__len__() == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0. ('openssl_sha3_256' = 'openssl_'=8 + 'sha3_256'=8 = 16 chars)"
    - "hashlib.blake2b.__name__.__len__() == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0. ('blake2b' = 7 chars; no 'openssl_' prefix)"
    - "hashlib.blake2s.__name__.__len__() == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0. ('blake2s' = 7 chars; no 'openssl_' prefix)"
    - "Note: Length ordering: blake2b(7)==blake2s(7) < openssl_sha1(12) < openssl_sha256(14)==openssl_sha512(14)==openssl_sha224(14)==openssl_sha384(14) < openssl_sha3_256(16). The blake2 constructors lack the 'openssl_' prefix (they come from _blake2, not _hashlib OpenSSL), so their names are 7 chars. The SHA-1 name (12 chars) is shorter than the SHA-2/SHA-3 names because 'sha1'=4 chars while 'sha256'/'sha512'/'sha224'/'sha384' are all 6 chars. SHA-3 is longest (16) because 'sha3_256'=8 chars (includes the '3_' infix)."
    - "Note: hashlib.sha256.__name__.__len__() == 14 (NOT 13). 'openssl_sha256' has 14 characters: o(1)p(2)e(3)n(4)s(5)s(6)l(7)_(8)s(9)h(10)a(11)2(12)5(13)6(14). 'openssl_'=8 chars + 'sha256'=6 chars = 14 total. Similarly sha512/sha224/sha384 all produce 14-char __name__ values."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b.__name__.__len__()==7
# hashlib.blake2s.__name__.__len__()==7
# hashlib.sha1.__name__.__len__()==12
#
# Wave 351 theme: blake2 and sha1 constructor name lengths — shortest three.
#
# blake2b.__name__.__len__() == 7 ('blake2b' = 7 chars; no openssl_ prefix; from _blake2).
# blake2s.__name__.__len__() == 7 ('blake2s' = 7 chars; same as blake2b; no prefix).
# sha1.__name__.__len__() == 12 ('openssl_sha1' = 'openssl_'=8 + 'sha1'=4 = 12 chars).
# Length ordering so far: blake2b(7)==blake2s(7) < sha1(12).
# hashlib_extra170 anchors blake2b.__name__=='blake2b' (7) and sha1.__name__=='openssl_sha1' (12).
# This spec anchors the integer __len__() values. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra172.blake2_sha1_name_lengths:
  description: "hashlib.blake2b.__name__.__len__()==7 / blake2s.__name__.__len__()==7 / sha1.__name__.__len__()==12 — blake2b.__name__.__len__() is 7 ('blake2b' = 'blake'=5 + '2'=1 + 'b'=1 = 7 chars; blake2b is the 512-bit-output variant of BLAKE2; it lacks the 'openssl_' prefix because it is implemented in the _blake2 C extension, not through OpenSSL in _hashlib; 'blake2b'(7) is the shortest constructor __name__ in this spec; hashlib_extra170 anchors blake2b.__name__=='blake2b'(7) as a table row); blake2s.__name__.__len__() is 7 ('blake2s' = 'blake'=5 + '2'=1 + 's'=1 = 7 chars; blake2s is the 256-bit-output variant of BLAKE2; also lacks 'openssl_' prefix; 'blake2s'(7)==blake2b.__name__.__len__()==7 — both blake2 variants share the same 7-char length; hashlib_extra170 anchors blake2s.__name__=='blake2s'(7)); sha1.__name__.__len__() is 12 ('openssl_sha1' = 'openssl_'=8 + 'sha1'=4 = 12 chars; SHA-1 is the shortest-named OpenSSL-backed constructor because 'sha1'=4 chars while sha256/sha512/sha224/sha384 are all 6 chars; openssl_sha1(12) > blake2b(7) by 5 chars; hashlib_extra170 anchors sha1.__name__=='openssl_sha1'(12); first hashnamelen172 anchor for blake2b/blake2s/sha1 name lengths)"
  kind: python_call_eq
  category: identity
  id_prefix: hashnamelen172

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_name_len_7,  "blake2b.__name__.__len__",  [], 7,  "hashlib.blake2b.__name__.__len__() is 7 ('blake2b' = 7 chars; no openssl_ prefix; _blake2 extension; hashlib_extra170 anchors __name__=='blake2b')"]
    - [blake2s_name_len_7,  "blake2s.__name__.__len__",  [], 7,  "hashlib.blake2s.__name__.__len__() is 7 ('blake2s' = 7 chars; same as blake2b=7; no openssl_ prefix; hashlib_extra170 anchors __name__=='blake2s')"]
    - [sha1_name_len_12,    "sha1.__name__.__len__",     [], 12, "hashlib.sha1.__name__.__len__() is 12 ('openssl_sha1' = 'openssl_'=8 + 'sha1'=4 = 12; shortest OpenSSL constructor name; sha1(12) > blake2b(7) by 5; hashlib_extra170 anchors __name__=='openssl_sha1')"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__name__.__len__()==14
# hashlib.sha512.__name__.__len__()==14
# hashlib.sha224.__name__.__len__()==14
# hashlib.sha384.__name__.__len__()==14
#
# Wave 351 theme: the four 14-char OpenSSL SHA-2 constructor names.
#
# sha256.__name__.__len__() == 14 ('openssl_sha256' = 14 chars).
# sha512.__name__.__len__() == 14 ('openssl_sha512' = 14 chars).
# sha224.__name__.__len__() == 14 ('openssl_sha224' = 14 chars).
# sha384.__name__.__len__() == 14 ('openssl_sha384' = 14 chars).
# All four tied at 14 chars. 14 > sha1(12) > blake2b/blake2s(7).
# hashlib_extra170 anchors sha256.__name__=='openssl_sha256' and sha512.__name__=='openssl_sha512'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra172.sha2_name_lengths_tied_14:
  description: "hashlib.sha256.__name__.__len__()==14 / sha512.__name__.__len__()==14 / sha224.__name__.__len__()==14 / sha384.__name__.__len__()==14 — sha256.__name__.__len__() is 14 ('openssl_sha256' = 'openssl_'=8 + 'sha256'=6 = 14 chars; SHA-256 is the most widely used SHA-2 hash; the 'openssl_' prefix=8 chars is the same for all four SHA-2 constructors; all four SHA-2 names consist of 'openssl_'(8) + algorithm_name(6) = 14 chars; 14 > 12 (sha1) > 7 (blake2b); hashlib_extra170 anchors sha256.__name__=='openssl_sha256' as a table row; this spec anchors the integer length 14); sha512.__name__.__len__() is 14 ('openssl_sha512' = 'openssl_'=8 + 'sha512'=6 = 14 chars; SHA-512 produces a 512-bit (64-byte) digest; 'sha512'(6)==sha256(6) in algorithm name length — both are 6-char algorithm names differing only in the final digits; hashlib_extra170 anchors sha512.__name__=='openssl_sha512'); sha224.__name__.__len__() is 14 ('openssl_sha224' = 'openssl_'=8 + 'sha224'=6 = 14 chars; SHA-224 is a truncated variant of SHA-256; 'sha224'(6)==sha256(6)==sha512(6)==sha384(6) — all four SHA-2 algorithm names are 6 chars; sha224(14)==sha256(14) in total __name__ length; hashlib_extra170 anchors sha224.__name__=='openssl_sha224'); sha384.__name__.__len__() is 14 ('openssl_sha384' = 'openssl_'=8 + 'sha384'=6 = 14 chars; SHA-384 is a truncated variant of SHA-512; 'sha384'(6) shares the 6-char length with sha256/sha512/sha224; all four SHA-2 names are 14 chars total; first hashnamelen172 anchor for the four-way tie at 14 chars)"
  kind: python_call_eq
  category: identity
  id_prefix: hashnamelen172

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_name_len_14,  "sha256.__name__.__len__",  [], 14, "hashlib.sha256.__name__.__len__() is 14 ('openssl_sha256' = 'openssl_'=8 + 'sha256'=6 = 14; hashlib_extra170 anchors __name__=='openssl_sha256')"]
    - [sha512_name_len_14,  "sha512.__name__.__len__",  [], 14, "hashlib.sha512.__name__.__len__() is 14 ('openssl_sha512' = 'openssl_'=8 + 'sha512'=6 = 14; hashlib_extra170 anchors __name__=='openssl_sha512')"]
    - [sha224_name_len_14,  "sha224.__name__.__len__",  [], 14, "hashlib.sha224.__name__.__len__() is 14 ('openssl_sha224' = 'openssl_'=8 + 'sha224'=6 = 14; hashlib_extra170 anchors __name__=='openssl_sha224')"]
    - [sha384_name_len_14,  "sha384.__name__.__len__",  [], 14, "hashlib.sha384.__name__.__len__() is 14 ('openssl_sha384' = 'openssl_'=8 + 'sha384'=6 = 14; hashlib_extra170 anchors __name__=='openssl_sha384')"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__name__.__len__()==16
#
# Wave 351 theme: sha3_256 is the longest constructor __name__ (16 chars).
#
# sha3_256.__name__.__len__() == 16 ('openssl_sha3_256' = 'openssl_'=8 + 'sha3_256'=8 = 16).
# sha3_256 is longest because 'sha3_256'=8 chars while 'sha256'=6, 'sha1'=4, etc.
# The '3_' infix adds 2 extra chars relative to 'sha256'.
# hashlib_extra170 anchors sha3_256.__name__=='openssl_sha3_256' (16 chars).
# This spec anchors the integer length 16. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra172.sha3_256_name_len_and_ordering:
  description: "hashlib.sha3_256.__name__.__len__()==16 / blake2b.__name__.__len__()==7 / sha1.__name__.__len__()==12 / sha256.__name__.__len__()==14 — sha3_256.__name__.__len__() is 16 ('openssl_sha3_256' = 'openssl_'=8 + 'sha3_256'=8 = 16 chars; SHA3-256 is the longest constructor __name__ among the eight anchored in this spec; 'sha3_256'=8 chars because it includes '3_' (2 extra chars) relative to 'sha256'(6 chars); 16 > 14 (sha256/sha512/sha224/sha384) > 12 (sha1) > 7 (blake2b/blake2s); hashlib_extra170 anchors sha3_256.__name__=='openssl_sha3_256'(16) as a table row; this spec anchors the integer length 16 as the primary novel value); blake2b.__name__.__len__() is 7 (confirmed; shortest constructor __name__; 7 < 12 < 14 < 16); sha1.__name__.__len__() is 12 (confirmed; 'openssl_sha1'=12; second tier in the ordering; 12 < 14 < 16); sha256.__name__.__len__() is 14 (confirmed; 'openssl_sha256'=14; third tier tied with sha512/sha224/sha384; 14 < 16; complete length ordering: 7(blake2b=blake2s) < 12(sha1) < 14(sha256=sha512=sha224=sha384) < 16(sha3_256); first hashnamelen172 anchor for sha3_256 length and the complete ordering)"
  kind: python_call_eq
  category: identity
  id_prefix: hashnamelen172

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_name_len_16,   "sha3_256.__name__.__len__",  [], 16, "hashlib.sha3_256.__name__.__len__() is 16 ('openssl_sha3_256' = 'openssl_'=8 + 'sha3_256'=8 = 16; longest; 'sha3_256'(8) > 'sha256'(6) by 2 due to '3_' infix; hashlib_extra170 anchors)"]
    - [blake2b_name_len_7_b,   "blake2b.__name__.__len__",   [], 7,  "hashlib.blake2b.__name__.__len__() is 7 (confirmed; shortest; 7 < 12 < 14 < 16)"]
    - [sha1_name_len_12_b,     "sha1.__name__.__len__",      [], 12, "hashlib.sha1.__name__.__len__() is 12 (confirmed; 'openssl_sha1'=12; 12 < 14 < 16)"]
    - [sha256_name_len_14_b,   "sha256.__name__.__len__",    [], 14, "hashlib.sha256.__name__.__len__() is 14 (confirmed; 'openssl_sha256'=14; 14 < 16; ordering: 7 < 12 < 14 < 16)"]

# ---------------------------------------------------------------------------
# Module name lengths: _hashlib(8) vs _blake2(7)
#
# Wave 351 theme: the two C extension modules underlying hashlib constructors.
#
# sha256.__module__.__len__() == 8 ('_hashlib' = 8 chars; OpenSSL-backed constructors).
# blake2b.__module__.__len__() == 7 ('_blake2' = 7 chars; BLAKE2-specific extension).
# blake2s.__module__.__len__() == 7 ('_blake2' = 7 chars; same as blake2b).
# sha3_256.__module__.__len__() == 8 ('_hashlib' = 8 chars; sha3 is OpenSSL-backed).
# hashlib_extra170 anchors these __module__ strings; this spec anchors their lengths.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra172.constructor_module_lengths:
  description: "hashlib.sha256.__module__.__len__()==8 / sha3_256.__module__.__len__()==8 / blake2b.__module__.__len__()==7 / blake2s.__module__.__len__()==7 — sha256.__module__.__len__() is 8 ('_hashlib' = '_'=1 + 'hashlib'=7 = 8 chars; the private C extension module for OpenSSL-backed hashlib constructors; all OpenSSL-backed constructors (sha256/sha512/sha1/sha224/sha384/sha3_256) share __module__=='_hashlib'(8 chars); '_hashlib'(8) > '_blake2'(7) by 1 char — the hashlib C extension name is 1 char longer than the blake2 extension; hashlib_extra168 anchors sha256.__module__=='_hashlib'); sha3_256.__module__.__len__() is 8 ('_hashlib' = 8 chars; sha3_256 is OpenSSL-backed like sha256/sha512; __module__=='_hashlib'(8) — the '3_' infix in the __name__ does not affect __module__; sha3_256.__module__.__len__()==sha256.__module__.__len__()==8 — both OpenSSL); blake2b.__module__.__len__() is 7 ('_blake2' = '_'=1 + 'blake2'=6 = 7 chars; blake2b comes from the _blake2 C extension (not OpenSSL's _hashlib); '_blake2'(7) < '_hashlib'(8) by 1 char; hashlib_extra170 anchors blake2b.__module__=='_blake2'); blake2s.__module__.__len__() is 7 ('_blake2' = 7 chars; same extension as blake2b; blake2b.__module__.__len__()==blake2s.__module__.__len__()==7; '_blake2'(7)==blake2b.__name__.__len__()==7 — coincidental same length as the constructor __name__; first hashnamelen172 anchor for module name length comparison)"
  kind: python_call_eq
  category: identity
  id_prefix: hashnamelen172

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_module_len_8,   "sha256.__module__.__len__",   [], 8, "hashlib.sha256.__module__.__len__() is 8 ('_hashlib' = '_'=1 + 'hashlib'=7 = 8; OpenSSL-backed; hashlib_extra168 anchors __module__=='_hashlib')"]
    - [sha3_256_module_len_8, "sha3_256.__module__.__len__", [], 8, "hashlib.sha3_256.__module__.__len__() is 8 ('_hashlib' = 8 chars; sha3 is OpenSSL-backed; same as sha256.__module__.__len__()==8)"]
    - [blake2b_module_len_7,  "blake2b.__module__.__len__",  [], 7, "hashlib.blake2b.__module__.__len__() is 7 ('_blake2' = '_'=1 + 'blake2'=6 = 7; '_blake2'(7) < '_hashlib'(8) by 1; hashlib_extra170 anchors __module__=='_blake2')"]
    - [blake2s_module_len_7,  "blake2s.__module__.__len__",  [], 7, "hashlib.blake2s.__module__.__len__() is 7 ('_blake2' = 7 chars; same as blake2b; '_blake2'(7)==blake2b.__name__.__len__()==7 — coincidental)"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__name__.__len__()==7 — standalone
#
# hashlib.blake2b.__name__.__len__() is 7. 'blake2b' (7 chars) = 'blake'=5 + '2'=1 + 'b'=1.
# blake2b is the 512-bit-output variant of BLAKE2 (the 'b' suffix stands for 'big').
# It lacks the 'openssl_' prefix because it is backed by the _blake2 C extension, not OpenSSL.
# blake2b(7) is the shortest constructor __name__ in the complete length ordering:
# blake2b(7)==blake2s(7) < sha1(12) < sha256(14)==sha512(14)==sha224(14)==sha384(14) < sha3_256(16).
# hashlib_extra170 anchors blake2b.__name__=='blake2b' as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra172.blake2b_name_len_7:
  description: "hashlib.blake2b.__name__.__len__() == 7 — 'blake2b' (7 chars = 'blake'=5 + '2'=1 + 'b'=1; BLAKE2b is the 512-bit variant; 'b' suffix = 'big'; lacks 'openssl_' prefix because it comes from _blake2, not _hashlib; blake2b(7)==blake2s(7) — both blake2 variants have 7-char __name__; 7 is the shortest __name__ length among all eight constructors; complete ordering: 7(blake2b=blake2s) < 12(sha1) < 14(sha256=sha512=sha224=sha384) < 16(sha3_256); hashlib_extra170 anchors __name__=='blake2b'; first hashnamelen172 standalone for blake2b.__name__.__len__()==7"
  category: identity
  kind: python_call_eq
  function: blake2b.__name__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# hashlib.blake2s.__name__.__len__()==7 — standalone
#
# hashlib.blake2s.__name__.__len__() is 7. 'blake2s' (7 chars) = 'blake'=5 + '2'=1 + 's'=1.
# blake2s is the 256-bit-output variant of BLAKE2 (the 's' suffix stands for 'small').
# blake2s.__name__.__len__()==7 == blake2b.__name__.__len__()==7 — both BLAKE2 variants have
# 7-char constructor __name__ values (the only difference is the final 'b' vs 's').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra172.blake2s_name_len_7:
  description: "hashlib.blake2s.__name__.__len__() == 7 — 'blake2s' (7 chars = 'blake'=5 + '2'=1 + 's'=1; BLAKE2s is the 256-bit variant; 's' suffix = 'small'; lacks 'openssl_' prefix like blake2b; blake2s(7)==blake2b(7) — tied shortest __name__ length; both BLAKE2 constructor __name__ values are exactly 7 chars differing only in the final letter ('b' vs 's'); hashlib_extra170 anchors __name__=='blake2s'; first hashnamelen172 standalone for blake2s.__name__.__len__()==7"
  category: identity
  kind: python_call_eq
  function: blake2s.__name__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# hashlib.sha1.__name__.__len__()==12 — standalone
#
# hashlib.sha1.__name__.__len__() is 12. 'openssl_sha1' (12 chars) = 'openssl_'=8 + 'sha1'=4.
# sha1 has the shortest OpenSSL-backed constructor __name__ because 'sha1' (4 chars) is
# shorter than 'sha256'/'sha512'/'sha224'/'sha384' (all 6 chars) and 'sha3_256' (8 chars).
# openssl_sha1(12) sits between blake2b/blake2s(7) and the 14-char SHA-2 names.
# hashlib_extra170 anchors sha1.__name__=='openssl_sha1' as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra172.sha1_name_len_12:
  description: "hashlib.sha1.__name__.__len__() == 12 — 'openssl_sha1' (12 chars = 'openssl_'=8 + 'sha1'=4; SHA-1 is the shortest-named OpenSSL constructor because 'sha1'=4 chars < 'sha256'/'sha512'/'sha224'/'sha384'=6 chars each; 12 > 7(blake2b/blake2s) by 5; 12 < 14(sha256/sha512/sha224/sha384) by 2; 12 < 16(sha3_256) by 4; complete ordering: 7 < 12 < 14 < 16; hashlib_extra170 anchors sha1.__name__=='openssl_sha1'; first hashnamelen172 standalone for sha1.__name__.__len__()==12"
  category: identity
  kind: python_call_eq
  function: sha1.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# hashlib.sha256.__name__.__len__()==14 — standalone
#
# hashlib.sha256.__name__.__len__() is 14. 'openssl_sha256' (14 chars) = 'openssl_'=8 + 'sha256'=6.
# This is the primary 14-char tier: sha256/sha512/sha224/sha384 all have 14-char __name__ values
# because they all share the 'openssl_'(8) prefix and a 6-char algorithm name.
# hashlib_extra170 anchors sha256.__name__=='openssl_sha256' as a table row.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra172.sha256_name_len_14:
  description: "hashlib.sha256.__name__.__len__() == 14 — 'openssl_sha256' (14 chars = 'openssl_'=8 + 'sha256'=6; SHA-256 produces a 256-bit (32-byte) digest; 'openssl_sha256'(14) is shared with sha512/sha224/sha384 — all four SHA-2 names are 14 chars; 14 > 12(sha1) by 2; 14 < 16(sha3_256) by 2; 14 = 2 * 7 = exactly double the blake2b/blake2s __name__ length; hashlib_extra170 anchors sha256.__name__=='openssl_sha256'; first hashnamelen172 standalone for sha256.__name__.__len__()==14"
  category: identity
  kind: python_call_eq
  function: sha256.__name__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__name__.__len__()==16 — standalone
#
# hashlib.sha3_256.__name__.__len__() is 16. 'openssl_sha3_256' (16 chars) = 'openssl_'=8 + 'sha3_256'=8.
# sha3_256 has the longest constructor __name__ because 'sha3_256' (8 chars) is 2 chars longer
# than 'sha256' (6 chars) — the '3_' infix adds 2 extra characters. This makes sha3_256
# the unique longest name at 16 chars. hashlib_extra170 anchors sha3_256.__name__=='openssl_sha3_256'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra172.sha3_256_name_len_16:
  description: "hashlib.sha3_256.__name__.__len__() == 16 — 'openssl_sha3_256' (16 chars = 'openssl_'=8 + 'sha3_256'=8; 'sha3_256'=8 chars because of the '3_' infix: 'sha'=3 + '3_'=2 + '256'=3 = 8; SHA3-256 is a Keccak-based hash (FIPS 202) distinct from SHA2-256; 16 > 14(sha256/sha512/sha224/sha384) by 2; 16 > 12(sha1) by 4; 16 > 7(blake2b/blake2s) by 9; 16 is the unique longest __name__ in this spec; 16 = 2 * 8 = twice the sha3_256 algorithm name length 'sha3_256'=8; hashlib_extra170 anchors sha3_256.__name__=='openssl_sha3_256'; first hashnamelen172 standalone for sha3_256.__name__.__len__()==16"
