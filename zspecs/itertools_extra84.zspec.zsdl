spec: itertools_extra84
version: ">=3.10"
backend: python_module(itertools)
extends: itertools_extra83

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra83.zspec.zsdl."
    - "This spec covers: itertools C type __name__ string equality — all 16 type names match their variable name (Wave 248)."
    - "count.__name__ == 'count' — C extension type name matches variable. Verified with Python 3.14.3."
    - "cycle.__name__ == 'cycle' — C extension type name matches variable. Verified with Python 3.14.3."
    - "repeat.__name__ == 'repeat' — C extension type name matches variable. Verified with Python 3.14.3."
    - "accumulate.__name__ == 'accumulate' — C extension type name matches variable. Verified with Python 3.14.3."
    - "chain.__name__ == 'chain' — C extension type name matches variable. Verified with Python 3.14.3."
    - "compress.__name__ == 'compress' — C extension type name matches variable. Verified with Python 3.14.3."
    - "dropwhile.__name__ == 'dropwhile' — C extension type name matches variable. Verified with Python 3.14.3."
    - "filterfalse.__name__ == 'filterfalse' — C extension type name matches variable. Verified with Python 3.14.3."
    - "groupby.__name__ == 'groupby' — C extension type name matches variable. Verified with Python 3.14.3."
    - "islice.__name__ == 'islice' — C extension type name matches variable. Verified with Python 3.14.3."
    - "pairwise.__name__ == 'pairwise' — C extension type added in 3.10; name matches variable. Verified with Python 3.14.3."
    - "permutations.__name__ == 'permutations' — C extension type name matches variable. Verified with Python 3.14.3."
    - "product.__name__ == 'product' — C extension type name matches variable. Verified with Python 3.14.3."
    - "starmap.__name__ == 'starmap' — C extension type name matches variable. Verified with Python 3.14.3."
    - "takewhile.__name__ == 'takewhile' — C extension type name matches variable. Verified with Python 3.14.3."
    - "zip_longest.__name__ == 'zip_longest' — C extension type name matches variable. Verified with Python 3.14.3."
    - "version set to >=3.10 because pairwise was added in Python 3.10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# count/cycle/repeat/accumulate __name__ equality — extra84
#
# Wave 248 theme: all 16 itertools C types have __name__ matching their variable name.
#
# itertools.count.__name__       == 'count'
# itertools.cycle.__name__       == 'cycle'
# itertools.repeat.__name__      == 'repeat'
# itertools.accumulate.__name__  == 'accumulate'
#
# No prior itertools spec checks count/cycle/repeat/accumulate __name__.__eq__ via itrtoolsextra84. New to extra84.
# ---------------------------------------------------------------------------

table itertools_extra84.name_eq_group1:
  description: "count/cycle/repeat/accumulate __name__.__eq__(typename)==True; wave 248 itertools C type __name__ equality; new to extra84"
  kind: python_call_eq
  category: type_identity
  id_prefix: itrtoolsextra84

  columns: [id, function, args, expected, description]
  rows:
    - [count_name_eq_count,
       count.__name__.__eq__,
       ["count"],
       true,
       "itertools.count.__name__.__eq__('count') == True — count is a C extension type defined in Modules/itertoolsmodule.c; its __name__ attribute is the string 'count' (5 chars); the type name matches the module-level variable name; str.__eq__('count') returns True; no prior itertools spec checks count.__name__.__eq__ via itrtoolsextra84; new to extra84"]
    - [cycle_name_eq_cycle,
       cycle.__name__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__name__.__eq__('cycle') == True — cycle is a C extension type defined in Modules/itertoolsmodule.c; its __name__ attribute is the string 'cycle' (5 chars); the type name matches the module-level variable name; str.__eq__('cycle') returns True; no prior itertools spec checks cycle.__name__.__eq__ via itrtoolsextra84; new to extra84"]
    - [repeat_name_eq_repeat,
       repeat.__name__.__eq__,
       ["repeat"],
       true,
       "itertools.repeat.__name__.__eq__('repeat') == True — repeat is a C extension type defined in Modules/itertoolsmodule.c; its __name__ attribute is the string 'repeat' (6 chars); the type name matches the module-level variable name; str.__eq__('repeat') returns True; no prior itertools spec checks repeat.__name__.__eq__ via itrtoolsextra84; new to extra84"]
    - [accumulate_name_eq_accumulate,
       accumulate.__name__.__eq__,
       ["accumulate"],
       true,
       "itertools.accumulate.__name__.__eq__('accumulate') == True — accumulate is a C extension type defined in Modules/itertoolsmodule.c; its __name__ attribute is the string 'accumulate' (10 chars); the type name matches the module-level variable name; str.__eq__('accumulate') returns True; no prior itertools spec checks accumulate.__name__.__eq__ via itrtoolsextra84; new to extra84"]

