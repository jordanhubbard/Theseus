spec: functools_extra282
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.cache is a pure-Python function: __class__.__name__ == 'function', __module__ == 'functools'."
    - "cache.__name__ == 'cache' (5 chars); cache.__qualname__ == 'cache' (top-level function, no enclosing class)."
    - "functools.cached_property is a type (class): __class__.__name__ == 'type', __module__ == 'functools'."
    - "cached_property.__name__ == 'cached_property' (15 chars); cached_property.__qualname__ == 'cached_property'."
    - "cached_property.__set_name__ is a pure-Python method: __qualname__ == 'cached_property.__set_name__' (28 chars)."
    - "cached_property.__get__ is a pure-Python method: __qualname__ == 'cached_property.__get__' (23 chars)."
    - "functools.reduce.__doc__ is not None — the C builtin ships with a docstring."
    - "reduce.__module__ == '_functools' (C extension), not 'functools'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.cache — pure-Python function identity
#
# cache is a pure-Python decorator function: __class__.__name__ == 'function'.
# cache.__name__ == 'cache' (5 chars); cache.__module__ == 'functools'.
# cache.__qualname__ == 'cache' (top-level, no enclosing scope).
# ---------------------------------------------------------------------------

table functools_extra282.cache_identity:
  description: "functools.cache function identity — __name__, __module__, __qualname__, __class__.__name__; name length; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex282ci

  columns: [id, function, args, expected, description]
  rows:
    - [ca_name_eq,  cache.__name__.__eq__,            ["cache"],     true, "functools.cache.__name__ == 'cache'; verified with Python 3.14.3"]
    - [ca_name_len, cache.__name__.__len__,            [],            5,    "functools.cache.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [ca_mod_eq,   cache.__module__.__eq__,           ["functools"], true, "functools.cache.__module__ == 'functools'; verified with Python 3.14.3"]
    - [ca_qn_eq,    cache.__qualname__.__eq__,         ["cache"],     true, "functools.cache.__qualname__ == 'cache' (top-level function); verified with Python 3.14.3"]
    - [ca_cls_eq,   cache.__class__.__name__.__eq__,   ["function"],  true, "functools.cache.__class__.__name__ == 'function' (pure-Python function); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools.cached_property — type identity and method qualnames
#
# cached_property is a class (type): __class__.__name__ == 'type'.
# cached_property.__name__ == 'cached_property' (15 chars).
# cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__' (28 chars).
# cached_property.__get__.__qualname__ == 'cached_property.__get__' (23 chars).
# Both __set_name__ and __get__ are pure-Python functions in the functools module.
# ---------------------------------------------------------------------------

table functools_extra282.cached_property_identity:
  description: "functools.cached_property type and method identity — __name__, __module__, __class__.__name__; __set_name__ and __get__ qualnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex282cpi

  columns: [id, function, args, expected, description]
  rows:
    - [cp_name_eq,    cached_property.__name__.__eq__,                       ["cached_property"],              true, "functools.cached_property.__name__ == 'cached_property'; verified with Python 3.14.3"]
    - [cp_name_len,   cached_property.__name__.__len__,                       [],                              15,   "functools.cached_property.__name__.__len__() == 15; verified with Python 3.14.3"]
    - [cp_mod_eq,     cached_property.__module__.__eq__,                      ["functools"],                   true, "functools.cached_property.__module__ == 'functools'; verified with Python 3.14.3"]
    - [cp_cls_eq,     cached_property.__class__.__name__.__eq__,              ["type"],                        true, "functools.cached_property.__class__.__name__ == 'type' (class object); verified with Python 3.14.3"]
    - [sn_qn_eq,      cached_property.__set_name__.__qualname__.__eq__,       ["cached_property.__set_name__"], true, "functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__'; verified with Python 3.14.3"]
    - [sn_qn_len,     cached_property.__set_name__.__qualname__.__len__,       [],                              28,   "functools.cached_property.__set_name__.__qualname__.__len__() == 28; verified with Python 3.14.3"]
    - [get_qn_eq,     cached_property.__get__.__qualname__.__eq__,            ["cached_property.__get__"],     true, "functools.cached_property.__get__.__qualname__ == 'cached_property.__get__'; verified with Python 3.14.3"]
    - [get_qn_len,    cached_property.__get__.__qualname__.__len__,            [],                              23,   "functools.cached_property.__get__.__qualname__.__len__() == 23; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra282
# ---------------------------------------------------------------------------

invariant functools_extra282.cache_is_function:
  description: "functools.cache.__class__.__name__ == 'function' — cache is a pure-Python function, not a C builtin or class"
  category: identity
  kind: python_call_eq
  function: cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra282.cache_module_is_functools:
  description: "functools.cache.__module__ == 'functools' — cache is defined directly in the functools module"
  category: identity
  kind: python_call_eq
  function: cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra282.cache_qualname_equals_name:
  description: "functools.cache.__qualname__ == 'cache' — qualname matches __name__ for a top-level function with no enclosing class"
  category: identity
  kind: python_call_eq
  function: cache.__qualname__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra282.cached_property_is_type:
  description: "functools.cached_property.__class__.__name__ == 'type' — cached_property is a class object, not a plain function"
  category: identity
  kind: python_call_eq
  function: cached_property.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra282.cached_property_set_name_qualname:
  description: "functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__' — method qualified name encodes the enclosing class"
  category: identity
  kind: python_call_eq
  function: cached_property.__set_name__.__qualname__.__eq__
  args: ["cached_property.__set_name__"]
  expected: true

invariant functools_extra282.cached_property_get_qualname:
  description: "functools.cached_property.__get__.__qualname__ == 'cached_property.__get__' — __get__ qualified name encodes the enclosing class"
  category: identity
  kind: python_call_eq
  function: cached_property.__get__.__qualname__.__eq__
  args: ["cached_property.__get__"]
  expected: true

invariant functools_extra282.reduce_doc_is_not_none:
  description: "functools.reduce.__doc__.__eq__(None) == False — reduce ships with a non-None docstring despite being a C builtin"
  category: behavior
  kind: python_call_eq
  function: reduce.__doc__.__eq__
  args: [null]
  expected: false
