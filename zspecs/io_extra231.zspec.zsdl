spec: io_extra231
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bufferedio.c"
  notes:
    - "This spec covers: io class and module-level __doc__ string contains checks, and DEFAULT_BUFFER_SIZE type and value."
    - "io.BytesIO.__doc__.__contains__('bytes') == True — BytesIO doc is 'Buffered I/O implementation using an in-memory bytes buffer.'; verified with Python 3.14.3."
    - "io.StringIO.__doc__.__contains__('str') == True — StringIO doc starts 'Text I/O implementation using an in-memory buffer.'; 'string' is NOT present but 'str' appears in context; verified with Python 3.14.3."
    - "io.FileIO.__doc__.__contains__('file') == True — FileIO doc starts 'Open a file.'; verified with Python 3.14.3."
    - "io.BufferedReader.__doc__.__contains__('buffer') == True — BufferedReader doc is 'Create a new buffered reader using the given readable raw IO object.'; verified with Python 3.14.3."
    - "io.BufferedWriter.__doc__.__contains__('buffer') == True — BufferedWriter doc starts 'A buffer for a writeable sequential RawIO object.'; verified with Python 3.14.3."
    - "io.TextIOWrapper.__doc__.__contains__('buffer') == True — TextIOWrapper doc starts 'Character and line based layer over a BufferedIOBase object, buffer.'; 'text' is NOT present but 'buffer' is; verified with Python 3.14.3."
    - "io.IOBase.__doc__.__contains__('abstract') == True — IOBase doc starts 'The abstract base class for all I/O classes.'; verified with Python 3.14.3."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — DEFAULT_BUFFER_SIZE is a plain Python int; verified with Python 3.14.3."
    - "io.DEFAULT_BUFFER_SIZE == 131072 — the default buffer size is 128 KiB (131072 bytes); verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io class __doc__ contains checks
# Verified with Python 3.14.3.
# BytesIO.__doc__ contains 'bytes'; StringIO.__doc__ contains 'str' (not 'string');
# FileIO.__doc__ contains 'file'; BufferedReader.__doc__ contains 'buffer';
# BufferedWriter.__doc__ contains 'buffer'; TextIOWrapper.__doc__ contains 'buffer';
# IOBase.__doc__ contains 'abstract'.
# ---------------------------------------------------------------------------

table io_extra231.class_doc_contains:
  description: "io class __doc__ string contains checks for BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, TextIOWrapper, IOBase; verified with Python 3.14.3"
  kind: python_call_eq
  category: docstring
  id_prefix: iodoccontains231

  columns: [id, function, args, expected]
  rows:
    - [bytesio_doc_bytes,          "BytesIO.__doc__.__contains__",          ["bytes"],    true]
    - [stringio_doc_str,           "StringIO.__doc__.__contains__",         ["str"],      true]
    - [fileio_doc_file,            "FileIO.__doc__.__contains__",           ["file"],     true]
    - [bufferedreader_doc_buffer,  "BufferedReader.__doc__.__contains__",   ["buffer"],   true]
    - [bufferedwriter_doc_buffer,  "BufferedWriter.__doc__.__contains__",   ["buffer"],   true]
    - [textiowrapper_doc_buffer,   "TextIOWrapper.__doc__.__contains__",    ["buffer"],   true]
    - [iobase_doc_abstract,        "IOBase.__doc__.__contains__",           ["abstract"], true]

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE type and value
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table io_extra231.default_buffer_size:
  description: "io.DEFAULT_BUFFER_SIZE type is 'int' and value is 131072 (128 KiB); verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: iobufsize231

  columns: [id, function, args, expected]
  rows:
    - [default_buffer_size_classname, DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"], true]
    - [default_buffer_size_value,     DEFAULT_BUFFER_SIZE.__eq__,                    [131072], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

invariant io_extra231.BytesIO.doc_contains_bytes:
  description: "io.BytesIO.__doc__.__contains__('bytes') == True — BytesIO docstring is 'Buffered I/O implementation using an in-memory bytes buffer.'; 'bytes' appears at the end; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: BytesIO.__doc__.__contains__
  args: ["bytes"]
  expected: true

invariant io_extra231.StringIO.doc_contains_str:
  description: "io.StringIO.__doc__.__contains__('str') == True — StringIO docstring starts 'Text I/O implementation using an in-memory buffer.'; 'str' appears in 'string' context elsewhere in doc; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: StringIO.__doc__.__contains__
  args: ["str"]
  expected: true

invariant io_extra231.FileIO.doc_contains_file:
  description: "io.FileIO.__doc__.__contains__('file') == True — FileIO docstring starts 'Open a file.'; 'file' appears immediately; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: FileIO.__doc__.__contains__
  args: ["file"]
  expected: true

invariant io_extra231.BufferedReader.doc_contains_buffer:
  description: "io.BufferedReader.__doc__.__contains__('buffer') == True — BufferedReader docstring is 'Create a new buffered reader using the given readable raw IO object.'; 'buffer' appears in 'buffered'; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: BufferedReader.__doc__.__contains__
  args: ["buffer"]
  expected: true

invariant io_extra231.BufferedWriter.doc_contains_buffer:
  description: "io.BufferedWriter.__doc__.__contains__('buffer') == True — BufferedWriter docstring starts 'A buffer for a writeable sequential RawIO object.'; 'buffer' is the first word; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: BufferedWriter.__doc__.__contains__
  args: ["buffer"]
  expected: true

invariant io_extra231.TextIOWrapper.doc_contains_buffer:
  description: "io.TextIOWrapper.__doc__.__contains__('buffer') == True — TextIOWrapper docstring starts 'Character and line based layer over a BufferedIOBase object, buffer.'; 'buffer' appears at end of first sentence; 'text' is NOT present; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: TextIOWrapper.__doc__.__contains__
  args: ["buffer"]
  expected: true

invariant io_extra231.IOBase.doc_contains_abstract:
  description: "io.IOBase.__doc__.__contains__('abstract') == True — IOBase docstring starts 'The abstract base class for all I/O classes.'; 'abstract' is the second word; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: IOBase.__doc__.__contains__
  args: ["abstract"]
  expected: true

invariant io_extra231.DEFAULT_BUFFER_SIZE.class_name:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — DEFAULT_BUFFER_SIZE is a plain Python int constant; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra231.DEFAULT_BUFFER_SIZE.value:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 — the default buffer size is 128 KiB (131072 bytes = 2^17); verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true
