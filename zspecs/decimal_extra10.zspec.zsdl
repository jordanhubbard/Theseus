spec: decimal_extra10
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic specification"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal.zspec.zsdl and prior extras (decimal_extra through decimal_extra9)."
    - "decimal_extra9 covers: as_tuple().exponent for '1.23'; as_tuple().digits.__len__ for '3.14'; to_integral_value; sqrt; __mod__; __floordiv__; compare; max; min."
    - "No prior spec covers Decimal.radix() — returns the radix of decimal arithmetic (always 10)."
    - "No prior spec covers Decimal.logb() — returns the adjusted exponent (base-10 logarithm of the absolute value, truncated to integer Decimal)."
    - "No prior spec covers Decimal.number_class() — returns a string describing the class of the number."
    - "No prior spec covers Decimal.fma() — fused multiply-add: d.fma(other, third) == d * other + third with no intermediate rounding."
    - "Decimal.radix() returns Decimal('10') — the radix is 10 for all decimal arithmetic."
    - "Decimal('10').logb().__str__() == '1' — log base 10 of 10 is 1 (integer result)."
    - "Decimal('100').logb().__str__() == '2' — log base 10 of 100 is 2."
    - "Decimal('1').logb().__str__() == '0' — log base 10 of 1 is 0."
    - "Decimal('1').number_class() == '+Normal' — positive finite nonzero number."
    - "Decimal('-1').number_class() == '-Normal' — negative finite nonzero number."
    - "Decimal('0').number_class() == '+Zero' — positive zero."
    - "Decimal('Infinity').number_class() == '+Infinity' — positive infinity."
    - "Decimal('2').fma(3, 1).__str__() == '7' — 2*3+1 == 7."
    - "Decimal('3').fma(4, 5).__str__() == '17' — 3*4+5 == 17."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal.radix() — the radix of decimal arithmetic
#
# radix() is a method on any Decimal instance that returns the base of the
# arithmetic system. For decimal, this is always 10. No prior spec covers this
# method. It is equivalent to Decimal(10) and is used by the GDA specification.
# ---------------------------------------------------------------------------

invariant decimal_extra10.Decimal.radix_is_ten:
  description: "Decimal('1').radix().__str__() == '10' — radix of decimal arithmetic is always 10"
  category: class_info
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: radix
  method_chain: __str__
  expected: "10"

invariant decimal_extra10.Decimal.radix_same_for_any_value:
  description: "Decimal('999').radix().__str__() == '10' — radix is 10 regardless of the Decimal value"
  category: class_info
  kind: python_call_eq
  function: Decimal
  args: ["999"]
  method: radix
  method_chain: __str__
  expected: "10"

# ---------------------------------------------------------------------------
# Decimal.logb() — adjusted exponent (integer base-10 log of absolute value)
#
# logb() returns the adjusted exponent of the operand: for a non-zero finite
# number it is floor(log10(abs(d))). The result is a Decimal with exponent 0.
# Decimal('10').logb() == Decimal('1') because floor(log10(10)) == 1.
# Decimal('100').logb() == Decimal('2') because floor(log10(100)) == 2.
# Decimal('1').logb() == Decimal('0') because floor(log10(1)) == 0.
# No prior spec covers logb().
# ---------------------------------------------------------------------------

invariant decimal_extra10.Decimal.logb_ten:
  description: "Decimal('10').logb().__str__() == '1' — adjusted exponent of 10 is 1"
  category: logarithm
  kind: python_call_eq
  function: Decimal
  args: ["10"]
  method: logb
  method_chain: __str__
  expected: "1"

invariant decimal_extra10.Decimal.logb_hundred:
  description: "Decimal('100').logb().__str__() == '2' — adjusted exponent of 100 is 2"
  category: logarithm
  kind: python_call_eq
  function: Decimal
  args: ["100"]
  method: logb
  method_chain: __str__
  expected: "2"

invariant decimal_extra10.Decimal.logb_one:
  description: "Decimal('1').logb().__str__() == '0' — adjusted exponent of 1 is 0"
  category: logarithm
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: logb
  method_chain: __str__
  expected: "0"

# ---------------------------------------------------------------------------
# Decimal.number_class() — returns a string describing the class of the number
#
# number_class() returns one of these strings per GDA:
#   '+Infinity', '+Normal', '+Subnormal', '+Zero',
#   '-Zero', '-Subnormal', '-Normal', '-Infinity', 'NaN', 'sNaN'
# No prior spec covers number_class().
# ---------------------------------------------------------------------------

invariant decimal_extra10.Decimal.number_class_positive_normal:
  description: "Decimal('1').number_class() == '+Normal' — positive finite nonzero number"
  category: number_class
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: number_class
  expected: "+Normal"

invariant decimal_extra10.Decimal.number_class_negative_normal:
  description: "Decimal('-1').number_class() == '-Normal' — negative finite nonzero number"
  category: number_class
  kind: python_call_eq
  function: Decimal
  args: ["-1"]
  method: number_class
  expected: "-Normal"

invariant decimal_extra10.Decimal.number_class_positive_zero:
  description: "Decimal('0').number_class() == '+Zero' — positive zero"
  category: number_class
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: number_class
  expected: "+Zero"

invariant decimal_extra10.Decimal.number_class_positive_infinity:
  description: "Decimal('Infinity').number_class() == '+Infinity' — positive infinity"
  category: number_class
  kind: python_call_eq
  function: Decimal
  args: ["Infinity"]
  method: number_class
  expected: "+Infinity"

# ---------------------------------------------------------------------------
# Decimal.fma() — fused multiply-add
#
# fma(other, third) computes self * other + third with a single rounding step.
# This is useful for dot-product and Horner polynomial evaluation. No prior
# spec covers fma(). Decimal('2').fma(3, 1) == Decimal('7') (2*3+1).
# Decimal('3').fma(4, 5) == Decimal('17') (3*4+5).
# ---------------------------------------------------------------------------

invariant decimal_extra10.Decimal.fma_two_three_one:
  description: "Decimal('2').fma(3, 1).__str__() == '7' — 2*3+1 == 7, fused multiply-add"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["2"]
  method: fma
  method_args: [3, 1]
  method_chain: __str__
  expected: "7"

invariant decimal_extra10.Decimal.fma_three_four_five:
  description: "Decimal('3').fma(4, 5).__str__() == '17' — 3*4+5 == 17, fused multiply-add"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["3"]
  method: fma
  method_args: [4, 5]
  method_chain: __str__
  expected: "17"

invariant decimal_extra10.Decimal.fma_with_zero_addend:
  description: "Decimal('5').fma(2, 0).__str__() == '10' — fma with zero addend is equivalent to multiplication"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["5"]
  method: fma
  method_args: [2, 0]
  method_chain: __str__
  expected: "10"
