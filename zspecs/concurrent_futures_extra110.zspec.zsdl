# Standalone invariants — extra110
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra110.Future_mro_len_2:
  description: "concurrent.futures.Future.__mro__.__len__() == 2 — Future MRO is [Future, object] (length=2); the simplest possible MRO — Future inherits directly from object with no intermediate base classes; concurrent.futures.Future.__bases__[0].__name__=='object'; concurrent.futures.Future.__name__=='Future' (len=6); concurrent.futures.Future.__module__=='concurrent.futures._base' (len=24); concurrent.futures.Future.__qualname__=='Future' (len=6); compare MRO lengths: Future=Executor=2 (minimal, base classes inheriting from object) < ThreadPoolExecutor=ProcessPoolExecutor=3 (executor subclasses add one level via Executor); Future is a concrete class (not abstract) that represents an async operation result; a Future can be in states: PENDING, RUNNING, CANCELLED, FINISHED; concurrent.futures.Future.__mro__.__len__()==2 is shorter than most Python stdlib classes (most have at least 3 levels via mixins or exception hierarchies); NEW in extra110: first standalone Future MRO length invariant in cfcls110 namespace; wave 255; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: concurrent.futures.Future.__mro__.__len__
  args: []
  expected: 2

invariant concurrent_futures_extra110.ProcessPoolExecutor_name_len_19:
  description: "concurrent.futures.ProcessPoolExecutor.__name__.__len__() == 19 — 'ProcessPoolExecutor'=19 chars; this is the longest __name__ in this spec; compare class name lengths: Future=6 (shortest) < Executor=8 < ThreadPoolExecutor=18 < ProcessPoolExecutor=19 (longest, 1 char longer than ThreadPoolExecutor — 'Process'=7 vs 'Thread'=6); concurrent.futures.ProcessPoolExecutor.__qualname__=='ProcessPoolExecutor' (len=19, qualname equals name); concurrent.futures.ProcessPoolExecutor.__module__=='concurrent.futures.process' (len=26, longest module name in spec); concurrent.futures.ProcessPoolExecutor.__mro__.__len__()==3 ([ProcessPoolExecutor, Executor, object]); concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__=='Executor'; ProcessPoolExecutor distributes work across separate OS processes (bypasses the GIL, suitable for CPU-bound tasks); compare: ThreadPoolExecutor distributes work across threads (lighter weight, shares memory, limited by GIL); NEW in extra110: first standalone ProcessPoolExecutor name length invariant in cfcls110 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__name__.__len__
  args: []
  expected: 19

invariant concurrent_futures_extra110.ProcessPoolExecutor_module_len_26:
  description: "concurrent.futures.ProcessPoolExecutor.__module__.__len__() == 26 — 'concurrent.futures.process'=26 chars; this is the longest module name in this spec; compare module name lengths: Future=Executor=24 ('concurrent.futures._base'=24, same) < ThreadPoolExecutor=25 ('concurrent.futures.thread'=25) < ProcessPoolExecutor=26 ('concurrent.futures.process'=26, longest — 'process'=7 > 'thread'=6 by 1 char); concurrent.futures.ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process')==True; the private submodule 'concurrent.futures.process' contains the ProcessPoolExecutor implementation; concurrent.futures.ProcessPoolExecutor.__name__=='ProcessPoolExecutor' (len=19); concurrent.futures.ProcessPoolExecutor.__mro__.__len__()==3; concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__=='Executor'; NEW in extra110: first standalone ProcessPoolExecutor module length invariant in cfcls110 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__module__.__len__
  args: []
  expected: 26

invariant concurrent_futures_extra110.Executor_submit_qualname_len_15:
  description: "concurrent.futures.Executor.submit.__qualname__.__len__() == 15 — 'Executor.submit' = 'Executor.'=9 + 'submit'=6 = 15; concurrent.futures.Executor.submit.__qualname__.__eq__('Executor.submit')==True; concurrent.futures.Executor.submit.__code__.co_argcount==2 (self and fn — fn is the callable to run asynchronously; additional positional and keyword arguments can be passed as *args/**kwargs but those are keyword-only in the signature); type(concurrent.futures.Executor.submit).__name__=='function' (Python-defined); compare Executor method qualname lengths: Executor.map=12 (shortest) < Executor.submit=15 < Executor.shutdown=17 (longest); concurrent.futures.Executor.__module__=='concurrent.futures._base' (len=24); concurrent.futures.Executor.__mro__.__len__()==2; concurrent.futures.Executor.__name__.__len__()==8; NEW in extra110: first standalone Executor.submit qualname length invariant in cfcls110 namespace; wave 255; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.Executor.submit.__qualname__.__len__
  args: []
  expected: 15

invariant concurrent_futures_extra110.ThreadPoolExecutor_mro_len_3:
  description: "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3 — ThreadPoolExecutor MRO is [ThreadPoolExecutor, Executor, object] (length=3); concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__=='Executor'; concurrent.futures.ThreadPoolExecutor.__name__=='ThreadPoolExecutor' (len=18); concurrent.futures.ThreadPoolExecutor.__module__=='concurrent.futures.thread' (len=25); compare: Future.__mro__.__len__()==Executor.__mro__.__len__()==2 (both base classes with minimal hierarchy) < ThreadPoolExecutor.__mro__.__len__()==ProcessPoolExecutor.__mro__.__len__()==3 (both add one level via Executor); ThreadPoolExecutor.__mro__.__len__()==ProcessPoolExecutor.__mro__.__len__()==3 (tied — both concrete executors have the same MRO depth); ThreadPoolExecutor manages a pool of worker threads (suitable for I/O-bound tasks); its MRO of length 3 reflects the single level of inheritance from Executor; NEW in extra110: first standalone ThreadPoolExecutor MRO length invariant in cfcls110 namespace; wave 255; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__mro__.__len__
  args: []
  expected: 3

