spec: concurrent_futures_extra110
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra109.zspec.zsdl."
    - "This spec covers: wave 255 theme — concurrent.futures.Future, Executor, ThreadPoolExecutor, and ProcessPoolExecutor class identity attributes (__name__, __qualname__, __module__, __mro__.__len__, __bases__[0].__name__). NEW in extra110: concurrent.futures.Future.__name__=='Future' (len=6); concurrent.futures.Future.__module__=='concurrent.futures._base' (len=24); concurrent.futures.Future.__mro__.__len__()==2 (only [Future, object]); concurrent.futures.Executor.__name__=='Executor' (len=8); concurrent.futures.Executor.__module__=='concurrent.futures._base' (len=24); concurrent.futures.Executor.__mro__.__len__()==2; concurrent.futures.ThreadPoolExecutor.__name__=='ThreadPoolExecutor' (len=18); concurrent.futures.ThreadPoolExecutor.__module__=='concurrent.futures.thread' (len=25); concurrent.futures.ThreadPoolExecutor.__mro__.__len__()==3; concurrent.futures.ProcessPoolExecutor.__name__=='ProcessPoolExecutor' (len=19, longest in spec); concurrent.futures.ProcessPoolExecutor.__module__=='concurrent.futures.process' (len=26, longest module name in spec); concurrent.futures.ProcessPoolExecutor.__mro__.__len__()==3. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.__mro__.__len__() == 2 ([Future, object]) — Future inherits directly from object (no intermediate base). concurrent.futures.Executor.__mro__.__len__() == 2 ([Executor, object]) — same minimal hierarchy. ThreadPoolExecutor and ProcessPoolExecutor both have __mro__.__len__()==3 ([XxxExecutor, Executor, object]). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (len=25). concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (len=26, one char longer than thread — 'process'=7 vs 'thread'=6). Both Executor subclasses inherit directly from Executor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future and Executor class identity — extra110
#
# Wave 255 theme: Future and Executor __name__, __module__, __mro__ attrs.
#
# concurrent.futures.Future.__name__            == 'Future'   (len=6)
# concurrent.futures.Future.__module__          == 'concurrent.futures._base' (len=24)
# concurrent.futures.Future.__mro__.__len__()   == 2
# concurrent.futures.Executor.__name__          == 'Executor' (len=8)
# concurrent.futures.Executor.__module__        == 'concurrent.futures._base' (len=24)
# concurrent.futures.Executor.__mro__.__len__() == 2
# ---------------------------------------------------------------------------

table concurrent_futures_extra110.cf_future_executor_identity:
  description: "concurrent.futures.Future and Executor class identity checks in cfcls110 namespace — wave 255 theme: concurrent.futures.Future.__name__.__eq__('Future')==True (len=6: 'Future'=6; Future represents the result of an asynchronous computation); concurrent.futures.Future.__name__.__len__()==6; concurrent.futures.Future.__qualname__.__eq__('Future')==True (len=6; qualname equals name, top-level class); concurrent.futures.Future.__module__.__eq__('concurrent.futures._base')==True (len=24: same module as CancelledError, InvalidStateError from extra109); concurrent.futures.Future.__module__.__len__()==24; concurrent.futures.Future.__mro__.__len__()==2 (MRO=[Future, object]; minimal 2-level chain — Future inherits directly from object with no intermediate base); concurrent.futures.Future.__bases__[0].__name__.__eq__('object')==True; concurrent.futures.Executor.__name__.__eq__('Executor')==True (len=8: 'Executor'=8; abstract base class for all executor types); concurrent.futures.Executor.__name__.__len__()==8; concurrent.futures.Executor.__qualname__.__eq__('Executor')==True (len=8; qualname equals name); concurrent.futures.Executor.__module__.__eq__('concurrent.futures._base')==True (len=24; same as Future — both in _base); concurrent.futures.Executor.__module__.__len__()==24; concurrent.futures.Executor.__mro__.__len__()==2 (MRO=[Executor, object]; also minimal 2-level chain — Executor is the direct abstract base); concurrent.futures.Executor.__bases__[0].__name__.__eq__('object')==True; compare: Future.__name__ len=6 < Executor.__name__ len=8 (Executor name is 2 chars longer); both have __mro__.__len__()==2 and __module__=='concurrent.futures._base'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfcls110

  columns: [id, function, args, expected, description]
  rows:
    - [fut_name_eq,         concurrent.futures.Future.__name__.__eq__,                    ["Future"],             true, "Future.__name__ == 'Future' (len=6); verified with Python 3.14.3"]
    - [fut_name_len,        concurrent.futures.Future.__name__.__len__,                   [],                     6,    "Future.__name__.__len__() == 6 ('Future'=6); verified with Python 3.14.3"]
    - [fut_qn_eq,           concurrent.futures.Future.__qualname__.__eq__,                ["Future"],             true, "Future.__qualname__ == 'Future' (len=6, qualname equals name); verified with Python 3.14.3"]
    - [fut_module_eq,       concurrent.futures.Future.__module__.__eq__,                  ["concurrent.futures._base"], true, "Future.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [fut_module_len,      concurrent.futures.Future.__module__.__len__,                 [],                     24,   "Future.__module__.__len__() == 24 ('concurrent.futures._base'=24); verified with Python 3.14.3"]
    - [fut_mro_len,         concurrent.futures.Future.__mro__.__len__,                    [],                     2,    "Future.__mro__.__len__() == 2 ([Future, object]); verified with Python 3.14.3"]
    - [fut_base_eq,         "concurrent.futures.Future.__bases__[0].__name__.__eq__",     ["object"],             true, "Future.__bases__[0].__name__ == 'object' (inherits directly from object); verified with Python 3.14.3"]
    - [exc_name_eq,         concurrent.futures.Executor.__name__.__eq__,                  ["Executor"],           true, "Executor.__name__ == 'Executor' (len=8); verified with Python 3.14.3"]
    - [exc_name_len,        concurrent.futures.Executor.__name__.__len__,                 [],                     8,    "Executor.__name__.__len__() == 8 ('Executor'=8); verified with Python 3.14.3"]
    - [exc_qn_eq,           concurrent.futures.Executor.__qualname__.__eq__,              ["Executor"],           true, "Executor.__qualname__ == 'Executor' (len=8, qualname equals name); verified with Python 3.14.3"]
    - [exc_module_eq,       concurrent.futures.Executor.__module__.__eq__,                ["concurrent.futures._base"], true, "Executor.__module__ == 'concurrent.futures._base' (len=24, same as Future); verified with Python 3.14.3"]
    - [exc_mro_len,         concurrent.futures.Executor.__mro__.__len__,                  [],                     2,    "Executor.__mro__.__len__() == 2 ([Executor, object]); verified with Python 3.14.3"]
    - [exc_base_eq,         "concurrent.futures.Executor.__bases__[0].__name__.__eq__",   ["object"],             true, "Executor.__bases__[0].__name__ == 'object' (abstract base inherits from object); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor and ProcessPoolExecutor identity — extra110
#
# Wave 255 theme: executor subclass __name__, __module__, __mro__ attrs.
#
# concurrent.futures.ThreadPoolExecutor.__name__          == 'ThreadPoolExecutor' (len=18)
# concurrent.futures.ThreadPoolExecutor.__module__        == 'concurrent.futures.thread' (len=25)
# concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3
# concurrent.futures.ProcessPoolExecutor.__name__         == 'ProcessPoolExecutor' (len=19, longest)
# concurrent.futures.ProcessPoolExecutor.__module__       == 'concurrent.futures.process' (len=26, longest)
# concurrent.futures.ProcessPoolExecutor.__mro__.__len__() == 3
# ---------------------------------------------------------------------------

table concurrent_futures_extra110.cf_pool_executor_identity:
  description: "concurrent.futures.ThreadPoolExecutor and ProcessPoolExecutor identity checks in cfcls110 namespace — wave 255 theme: concurrent.futures.ThreadPoolExecutor.__name__.__eq__('ThreadPoolExecutor')==True (len=18: 'ThreadPoolExecutor'=18); concurrent.futures.ThreadPoolExecutor.__name__.__len__()==18; concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__('ThreadPoolExecutor')==True (len=18); concurrent.futures.ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread')==True (len=25: 'concurrent.futures.thread'=25; ThreadPoolExecutor is defined in the private thread submodule); concurrent.futures.ThreadPoolExecutor.__module__.__len__()==25; concurrent.futures.ThreadPoolExecutor.__mro__.__len__()==3 (MRO=[ThreadPoolExecutor, Executor, object]; 3-level chain: ThreadPoolExecutor -> Executor -> object); concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True (inherits from Executor); concurrent.futures.ProcessPoolExecutor.__name__.__eq__('ProcessPoolExecutor')==True (len=19: 'ProcessPoolExecutor'=19; longest __name__ in this spec — 1 char longer than ThreadPoolExecutor=18); concurrent.futures.ProcessPoolExecutor.__name__.__len__()==19; concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__('ProcessPoolExecutor')==True (len=19); concurrent.futures.ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process')==True (len=26: 'concurrent.futures.process'=26; longest module name in spec — 1 char longer than thread=25 because 'process'=7 > 'thread'=6); concurrent.futures.ProcessPoolExecutor.__module__.__len__()==26; concurrent.futures.ProcessPoolExecutor.__mro__.__len__()==3 (same as ThreadPoolExecutor — both have 3-level MRO); concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True; compare: ThreadPoolExecutor.__name__ len=18 < ProcessPoolExecutor.__name__ len=19; compare modules: thread len=25 < process len=26; both executor subclasses have MRO len=3; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfcls110a

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_name_eq,         concurrent.futures.ThreadPoolExecutor.__name__.__eq__,         ["ThreadPoolExecutor"], true, "ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' (len=18); verified with Python 3.14.3"]
    - [tpe_name_len,        concurrent.futures.ThreadPoolExecutor.__name__.__len__,        [],                     18,   "ThreadPoolExecutor.__name__.__len__() == 18 ('ThreadPoolExecutor'=18); verified with Python 3.14.3"]
    - [tpe_module_eq,       concurrent.futures.ThreadPoolExecutor.__module__.__eq__,       ["concurrent.futures.thread"], true, "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (len=25); verified with Python 3.14.3"]
    - [tpe_module_len,      concurrent.futures.ThreadPoolExecutor.__module__.__len__,      [],                     25,   "ThreadPoolExecutor.__module__.__len__() == 25 ('concurrent.futures.thread'=25); verified with Python 3.14.3"]
    - [tpe_mro_len,         concurrent.futures.ThreadPoolExecutor.__mro__.__len__,         [],                     3,    "ThreadPoolExecutor.__mro__.__len__() == 3 ([ThreadPoolExecutor, Executor, object]); verified with Python 3.14.3"]
    - [tpe_base_eq,         "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],    true, "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' (inherits from Executor); verified with Python 3.14.3"]
    - [ppe_name_eq,         concurrent.futures.ProcessPoolExecutor.__name__.__eq__,        ["ProcessPoolExecutor"], true, "ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' (len=19, longest in spec); verified with Python 3.14.3"]
    - [ppe_name_len,        concurrent.futures.ProcessPoolExecutor.__name__.__len__,       [],                     19,   "ProcessPoolExecutor.__name__.__len__() == 19 ('ProcessPoolExecutor'=19, longest __name__ in spec); verified with Python 3.14.3"]
    - [ppe_module_eq,       concurrent.futures.ProcessPoolExecutor.__module__.__eq__,      ["concurrent.futures.process"], true, "ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (len=26, longest module in spec); verified with Python 3.14.3"]
    - [ppe_module_len,      concurrent.futures.ProcessPoolExecutor.__module__.__len__,     [],                     26,   "ProcessPoolExecutor.__module__.__len__() == 26 ('concurrent.futures.process'=26); verified with Python 3.14.3"]
    - [ppe_mro_len,         concurrent.futures.ProcessPoolExecutor.__mro__.__len__,        [],                     3,    "ProcessPoolExecutor.__mro__.__len__() == 3 (same as ThreadPoolExecutor=3); verified with Python 3.14.3"]
    - [ppe_base_eq,         "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],   true, "ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' (inherits from Executor); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Executor method qualnames — extra110
#
# Wave 255 theme: Executor.submit, map, shutdown qualname lengths and co_argcounts.
#
# concurrent.futures.Executor.submit.__qualname__    == 'Executor.submit'   (len=15, co_argcount=2)
# concurrent.futures.Executor.map.__qualname__       == 'Executor.map'      (len=12, shortest)
# concurrent.futures.Executor.shutdown.__qualname__  == 'Executor.shutdown' (len=17, longest)
# ---------------------------------------------------------------------------

table concurrent_futures_extra110.cf_executor_method_qualnames:
  description: "concurrent.futures.Executor method qualname and co_argcount checks in cfcls110 namespace — wave 255 theme: concurrent.futures.Executor.submit.__qualname__.__eq__('Executor.submit')==True (len=15: 'Executor.'=9+'submit'=6=15; co_argcount=2: self and fn — fn is the callable to execute, additional args are keyword-only); concurrent.futures.Executor.submit.__qualname__.__len__()==15; concurrent.futures.Executor.submit.__code__.co_argcount.__eq__(2)==True; type(concurrent.futures.Executor.submit).__name__.__eq__('function')==True; concurrent.futures.Executor.map.__qualname__.__eq__('Executor.map')==True (len=12: 'Executor.'=9+'map'=3=12; shortest method qualname in spec; co_argcount=2: self and fn); concurrent.futures.Executor.map.__qualname__.__len__()==12; concurrent.futures.Executor.map.__code__.co_argcount.__eq__(2)==True; concurrent.futures.Executor.shutdown.__qualname__.__eq__('Executor.shutdown')==True (len=17: 'Executor.'=9+'shutdown'=8=17; longest method qualname in spec; co_argcount=2: self and wait); concurrent.futures.Executor.shutdown.__qualname__.__len__()==17; concurrent.futures.Executor.shutdown.__code__.co_argcount.__eq__(2)==True; compare qualname lengths: Executor.map=12 (shortest) < Executor.submit=15 < Executor.shutdown=17 (longest); all three methods have co_argcount=2 (self + one positional arg each); Executor.__module__=='concurrent.futures._base' (len=24); Executor.__mro__.__len__()==2; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfcls110b

  columns: [id, function, args, expected, description]
  rows:
    - [submit_qn_eq,        concurrent.futures.Executor.submit.__qualname__.__eq__,        ["Executor.submit"],    true, "Executor.submit.__qualname__ == 'Executor.submit' (len=15); verified with Python 3.14.3"]
    - [submit_qn_len,       concurrent.futures.Executor.submit.__qualname__.__len__,       [],                     15,   "Executor.submit.__qualname__.__len__() == 15 ('Executor.submit'=15); verified with Python 3.14.3"]
    - [submit_argc,         concurrent.futures.Executor.submit.__code__.co_argcount.__eq__, [2],                   true, "Executor.submit.__code__.co_argcount == 2 (self and fn); verified with Python 3.14.3"]
    - [submit_type_eq,      type(concurrent.futures.Executor.submit).__name__.__eq__,      ["function"],           true, "type(Executor.submit).__name__ == 'function' (Python-defined); verified with Python 3.14.3"]
    - [map_qn_eq,           concurrent.futures.Executor.map.__qualname__.__eq__,           ["Executor.map"],       true, "Executor.map.__qualname__ == 'Executor.map' (len=12, shortest method qualname in spec); verified with Python 3.14.3"]
    - [map_qn_len,          concurrent.futures.Executor.map.__qualname__.__len__,          [],                     12,   "Executor.map.__qualname__.__len__() == 12 ('Executor.map'=12, shortest); verified with Python 3.14.3"]
    - [map_argc,            concurrent.futures.Executor.map.__code__.co_argcount.__eq__,   [2],                    true, "Executor.map.__code__.co_argcount == 2 (self and fn); verified with Python 3.14.3"]
    - [shutdown_qn_eq,      concurrent.futures.Executor.shutdown.__qualname__.__eq__,      ["Executor.shutdown"],  true, "Executor.shutdown.__qualname__ == 'Executor.shutdown' (len=17, longest method qualname in spec); verified with Python 3.14.3"]
    - [shutdown_qn_len,     concurrent.futures.Executor.shutdown.__qualname__.__len__,     [],                     17,   "Executor.shutdown.__qualname__.__len__() == 17 ('Executor.shutdown'=17, longest); verified with Python 3.14.3"]
    - [shutdown_argc,       concurrent.futures.Executor.shutdown.__code__.co_argcount.__eq__, [2],                 true, "Executor.shutdown.__code__.co_argcount == 2 (self and wait); verified with Python 3.14.3"]

