spec: struct_extra378
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "struct.Struct.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__name__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__name__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__name__ == 'pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__name__ == 'unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct is a C type defined in Modules/_struct.c. Its __module__ is '_struct' because the type object originates in the C extension, even though struct.py re-exports it."
    - "Note: struct.Struct.size and struct.Struct.format are getset_descriptor objects — C-level descriptors defined via PyGetSetDef in the C extension. They are not Python properties."
    - "Note: struct.Struct('i').size == 4 on all standard platforms (int is 4 bytes in C struct layout)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct class identity: __name__, __module__, __bases__
# struct.Struct method __name__ values: pack, unpack, pack_into, unpack_from
# struct.Struct descriptor types: size, format (getset_descriptor)
#
# Wave 378 theme: struct.Struct class identity and method/descriptor introspection.
#
# struct.Struct is a C type implemented in Modules/_struct.c. It is exposed
# into the Python struct namespace by Lib/struct.py. Because the type object
# originates in the _struct C extension, struct.Struct.__module__ is '_struct'
# (not 'struct').
#
# struct.Struct directly inherits from object (no intermediate base classes).
# Its __bases__ tuple contains exactly one element: the built-in object type.
#
# struct.Struct.size and struct.Struct.format are getset_descriptor objects —
# C-level descriptors defined via PyGetSetDef in Modules/_struct.c. They are
# not Python property objects. A getset_descriptor provides read-only (or
# read-write) access to C struct fields from Python.
#
# The instance methods pack, unpack, pack_into, unpack_from, iter_unpack are
# slot wrappers whose __name__ matches the method name.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra378.struct_class_identity:
  description: "struct.Struct class identity — __name__ is 'Struct', __module__ is '_struct' (C extension origin), base class is 'object'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: structclsid378

  columns: [id, function, args, expected]
  rows:
    - [struct_name,    Struct.__name__.__eq__,             ["Struct"],  true]
    - [struct_module,  Struct.__module__.__eq__,           ["_struct"], true]
    - [struct_base,    Struct.__bases__[0].__name__.__eq__, ["object"],  true]

table struct_extra378.struct_method_names:
  description: "struct.Struct instance method __name__ values — pack/unpack/pack_into/unpack_from are C slot wrapper methods; __name__ matches the method name exactly; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: structmeth378

  columns: [id, function, args, expected]
  rows:
    - [pack_name,        Struct.pack.__name__.__eq__,        ["pack"],        true]
    - [unpack_name,      Struct.unpack.__name__.__eq__,      ["unpack"],      true]
    - [pack_into_name,   Struct.pack_into.__name__.__eq__,   ["pack_into"],   true]
    - [unpack_from_name, Struct.unpack_from.__name__.__eq__, ["unpack_from"], true]

# ---------------------------------------------------------------------------
# struct.Struct.size and struct.Struct.format are getset_descriptor objects
#
# In CPython's C API, a getset_descriptor is created when a C type defines
# read/write accessors via PyGetSetDef. These are distinct from Python property
# objects (type 'property') — they are C-level descriptors. Accessing
# Struct.size or Struct.format on the class (not an instance) returns the
# descriptor object itself, whose __class__.__name__ is 'getset_descriptor'.
#
# On an instance (e.g., struct.Struct('i')), accessing .size returns the
# integer 4 (for the 'i' format, which corresponds to a C int of 4 bytes).
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra378.size_descriptor_class:
  description: "struct.Struct.size.__class__.__name__.__eq__('getset_descriptor') == True — Struct.size is a C-level getset_descriptor (PyGetSetDef), not a Python property; accessed on the class returns the descriptor; on an instance returns the compiled struct size in bytes; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: type_identity
  kind: python_call_eq
  function: Struct.size.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant struct_extra378.format_descriptor_class:
  description: "struct.Struct.format.__class__.__name__.__eq__('getset_descriptor') == True — Struct.format is a C-level getset_descriptor (PyGetSetDef); accessed on the class returns the descriptor; on an instance returns the format string used to compile the struct; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: type_identity
  kind: python_call_eq
  function: Struct.format.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true
