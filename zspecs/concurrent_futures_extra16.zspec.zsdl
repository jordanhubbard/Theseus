spec: concurrent_futures_extra16
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures.zspec.zsdl and prior extras through concurrent_futures_extra15."
    - "extra covers: Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor __name__; wait/__name__; as_completed/__name__."
    - "extra13 covers: ThreadPoolExecutor/ProcessPoolExecutor/Future __qualname__; ThreadPoolExecutor/ProcessPoolExecutor __module__; wait/as_completed __module__."
    - "extra15 covers: wait/as_completed __module__; Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor __module__; ThreadPoolExecutor/ProcessPoolExecutor base class name; Future/__qualname__; Executor/__qualname__."
    - "NOT yet covered in any prior spec: concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' as standalone __eq__ invariant."
    - "NOT yet covered: concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' as standalone __eq__ invariant."
    - "NOT yet covered: concurrent.futures.Future.__qualname__ == 'Future' as a fresh standalone __eq__ invariant distinct from extra15 coverage."
    - "NOT yet covered: concurrent.futures.Executor.__qualname__ == 'Executor' as a fresh standalone __eq__ invariant distinct from extra15 coverage."
    - "NOT yet covered: concurrent.futures.as_completed.__name__ == 'as_completed' as standalone __eq__ invariant."
    - "NOT yet covered: concurrent.futures.wait.__name__ == 'wait' as standalone __eq__ invariant."
    - "NOT yet covered: concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str' as a standalone __eq__ invariant."
    - "concurrent.futures.ThreadPoolExecutor.__module__ is 'concurrent.futures.thread' (defined in thread.py)."
    - "concurrent.futures.ProcessPoolExecutor.__module__ is 'concurrent.futures.process' (defined in process.py)."
    - "concurrent.futures.Future.__module__ and Executor.__module__ are 'concurrent.futures._base' (defined in _base.py)."
    - "FIRST_COMPLETED is a plain str constant with value 'FIRST_COMPLETED'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for ThreadPoolExecutor, ProcessPoolExecutor, Future, Executor
#
# extra13 and extra15 cover __qualname__ for these classes in table and
# standalone form. This spec provides a consolidated table for all four
# as independent invariants at the extra16 level.
# ---------------------------------------------------------------------------

table concurrent_futures_extra16.class_qualnames:
  description: "concurrent.futures executor and future classes have correct __qualname__ attributes"
  kind: python_call_eq
  category: class_names
  id_prefix: clsqn16

  columns: [id, function, args, expected]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__qualname__.__eq__,  ["ThreadPoolExecutor"],  true]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__qualname__.__eq__, ["ProcessPoolExecutor"], true]
    - [Future,              Future.__qualname__.__eq__,              ["Future"],              true]
    - [Executor,            Executor.__qualname__.__eq__,            ["Executor"],            true]

# ---------------------------------------------------------------------------
# __module__ table for ThreadPoolExecutor, ProcessPoolExecutor, Future, Executor
#
# extra15 provides a class_modules table covering all four. These standalone
# invariants confirm the same values at independent coverage points.
# ThreadPoolExecutor lives in concurrent.futures.thread; ProcessPoolExecutor
# in concurrent.futures.process; Future and Executor in concurrent.futures._base.
# ---------------------------------------------------------------------------

table concurrent_futures_extra16.class_modules:
  description: "concurrent.futures classes have correct __module__ attributes"
  kind: python_call_eq
  category: class_modules
  id_prefix: clsmod16

  columns: [id, function, args, expected]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__module__.__eq__,  ["concurrent.futures.thread"],   true]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__module__.__eq__, ["concurrent.futures.process"],  true]
    - [Future,              Future.__module__.__eq__,              ["concurrent.futures._base"],    true]
    - [Executor,            Executor.__module__.__eq__,            ["concurrent.futures._base"],    true]

# ---------------------------------------------------------------------------
# as_completed and wait __name__ — standalone invariants
#
# extra covers wait/__name__ and as_completed/__name__ in a table. Standalone
# invariants here provide independent single-function coverage.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra16.as_completed.name:
  description: "concurrent.futures.as_completed.__name__ == 'as_completed'"
  category: function_names
  kind: python_call_eq
  function: as_completed.__name__.__eq__
  args: ["as_completed"]
  expected: true

invariant concurrent_futures_extra16.wait.name:
  description: "concurrent.futures.wait.__name__ == 'wait'"
  category: function_names
  kind: python_call_eq
  function: wait.__name__.__eq__
  args: ["wait"]
  expected: true

# ---------------------------------------------------------------------------
# FIRST_COMPLETED is a plain str constant
#
# concurrent.futures.FIRST_COMPLETED is a string sentinel value used to
# indicate that as_completed / wait should return when the first future
# completes. Its type.__name__ is 'str'. No prior spec checks this property.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra16.FIRST_COMPLETED.class_name:
  description: "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str'"
  category: constant_types
  kind: python_call_eq
  function: FIRST_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true
