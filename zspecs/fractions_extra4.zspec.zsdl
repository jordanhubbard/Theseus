spec: fractions_extra4
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions.zspec.zsdl, fractions_extra.zspec.zsdl, fractions_extra2.zspec.zsdl, and fractions_extra3.zspec.zsdl."
    - "Focus: Fraction class identity attributes, auto-reduction of numerator/denominator, and zero/negative fraction properties."
    - "Fraction(2, 4) auto-reduces to 1/2 — GCD is applied at construction time."
    - "Fraction(-1, 3) has numerator == -1 and denominator == 3 — denominator is always positive."
    - "Fraction(0, 5) has numerator == 0 and denominator == 1 after reduction."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Fraction class identity
# ---------------------------------------------------------------------------

invariant fractions_extra4.Fraction.class_name:
  description: "fractions.Fraction.__name__ == 'Fraction'"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__name__.__eq__
  args: ["Fraction"]
  expected: true

invariant fractions_extra4.Fraction.module:
  description: "fractions.Fraction.__module__ == 'fractions'"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__module__.__eq__
  args: ["fractions"]
  expected: true

invariant fractions_extra4.Fraction.qualname:
  description: "fractions.Fraction.__qualname__ == 'Fraction'"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__qualname__.__eq__
  args: ["Fraction"]
  expected: true

# ---------------------------------------------------------------------------
# Fraction(1, 3) — instance class name and attributes
# ---------------------------------------------------------------------------

invariant fractions_extra4.Fraction_1_3.class_name:
  description: "fractions.Fraction(1, 3).__class__.__name__ == 'Fraction'"
  category: instance
  kind: python_call_eq
  function: Fraction
  args: [1, 3]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Fraction"]
  expected: true

invariant fractions_extra4.Fraction_1_3.numerator:
  description: "fractions.Fraction(1, 3).numerator == 1"
  category: instance
  kind: python_call_eq
  function: Fraction
  args: [1, 3]
  method: numerator.__eq__
  method_args: [1]
  expected: true

invariant fractions_extra4.Fraction_1_3.denominator:
  description: "fractions.Fraction(1, 3).denominator == 3"
  category: instance
  kind: python_call_eq
  function: Fraction
  args: [1, 3]
  method: denominator.__eq__
  method_args: [3]
  expected: true

# ---------------------------------------------------------------------------
# Fraction(2, 4) — auto-reduction to 1/2
# ---------------------------------------------------------------------------

invariant fractions_extra4.Fraction_2_4.numerator:
  description: "fractions.Fraction(2, 4).numerator == 1 — auto-reduces via GCD"
  category: reduction
  kind: python_call_eq
  function: Fraction
  args: [2, 4]
  method: numerator.__eq__
  method_args: [1]
  expected: true

invariant fractions_extra4.Fraction_2_4.denominator:
  description: "fractions.Fraction(2, 4).denominator == 2 — auto-reduces via GCD"
  category: reduction
  kind: python_call_eq
  function: Fraction
  args: [2, 4]
  method: denominator.__eq__
  method_args: [2]
  expected: true

# ---------------------------------------------------------------------------
# Fraction(0, 5) — zero fraction
# ---------------------------------------------------------------------------

invariant fractions_extra4.Fraction_0_5.numerator:
  description: "fractions.Fraction(0, 5).numerator == 0"
  category: zero
  kind: python_call_eq
  function: Fraction
  args: [0, 5]
  method: numerator.__eq__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# Fraction(-1, 3) — negative numerator, positive denominator
# ---------------------------------------------------------------------------

invariant fractions_extra4.Fraction_neg1_3.numerator:
  description: "fractions.Fraction(-1, 3).numerator == -1"
  category: negative
  kind: python_call_eq
  function: Fraction
  args: [-1, 3]
  method: numerator.__eq__
  method_args: [-1]
  expected: true

invariant fractions_extra4.Fraction_neg1_3.denominator:
  description: "fractions.Fraction(-1, 3).denominator == 3 — denominator is always positive"
  category: negative
  kind: python_call_eq
  function: Fraction
  args: [-1, 3]
  method: denominator.__eq__
  method_args: [3]
  expected: true

# ---------------------------------------------------------------------------
# class_names table — Fraction
# ---------------------------------------------------------------------------

table fractions_extra4.class_names:
  kind: python_call_eq
  category: classes
  id_prefix: class_name

  columns: [id, function, args, expected]
  rows:
    - [Fraction, Fraction.__name__.__eq__, ["Fraction"], true]
