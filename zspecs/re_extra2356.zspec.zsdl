spec: re_extra2356
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers Pattern/Match class names, flag constants"
    - "re_extra1771.zspec.zsdl — covers async protocol, function class names, error.__dict__"
  notes:
    - "Wave 2356, theme: __init__ and __new__ implementation type classification."
    - "re.Pattern and re.Match are C extension types; __init__ is 'wrapper_descriptor'."
    - "re.error is a Python exception class with a custom __init__; __init__ is 'function'."
    - "re.RegexFlag is an IntFlag subclass; __init__ is 'wrapper_descriptor' (enum machinery), __new__ is 'function'."
    - "re.Pattern.__init__.__class__.__name__ == 'wrapper_descriptor' (verified Python 3.13, macOS)."
    - "re.Match.__init__.__class__.__name__ == 'wrapper_descriptor' (verified Python 3.13, macOS)."
    - "re.error.__init__.__class__.__name__ == 'function' — error defines a custom Python __init__."
    - "re.RegexFlag.__init__.__class__.__name__ == 'wrapper_descriptor' — enum base handles __init__ in C."
    - "re.RegexFlag.__new__.__class__.__name__ == 'function' — IntFlag.__new__ is a Python function."
    - "re.Pattern.__new__.__class__.__name__ == 'builtin_function_or_method' — C-level tp_new."
    - "re.Match.__new__.__class__.__name__ == 'builtin_function_or_method' — C-level tp_new."
    - "re.error.__new__.__class__.__name__ == 'builtin_function_or_method' — inherits object.__new__."
    - "All expected values verified by running Python 3.13 re module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __init__.__class__.__name__ — re types (C extension vs Python)
# ---------------------------------------------------------------------------

table re_extra2356.init_class_name:
  kind: python_call_eq
  category: impl_type
  id_prefix: re2356

  columns: [id, function, args, expected]
  rows:
    - ["re2356001", Pattern.__init__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - ["re2356002", Match.__init__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true]
    - ["re2356003", error.__init__.__class__.__name__.__eq__,    ["function"],           true]
    - ["re2356004", RegexFlag.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# __new__.__class__.__name__ — re types
# ---------------------------------------------------------------------------

table re_extra2356.new_class_name:
  kind: python_call_eq
  category: impl_type
  id_prefix: re2356

  columns: [id, function, args, expected]
  rows:
    - ["re2356005", Pattern.__new__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - ["re2356006", Match.__new__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - ["re2356007", error.__new__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - ["re2356008", RegexFlag.__new__.__class__.__name__.__eq__, ["function"],                   true]

# ---------------------------------------------------------------------------
# Contrast: re.error.__init__ is NOT wrapper_descriptor (it is a Python function)
# ---------------------------------------------------------------------------

table re_extra2356.error_init_not_wrapper:
  kind: python_call_eq
  category: impl_type
  id_prefix: re2356

  columns: [id, function, args, expected]
  rows:
    - ["re2356009", error.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"],        false]
    - ["re2356010", error.__init__.__class__.__name__.__eq__, ["builtin_function_or_method"], false]
    - ["re2356011", error.__init__.__class__.__name__.__eq__, ["slot_wrapper"],               false]

# ---------------------------------------------------------------------------
# Contrast: re.Pattern.__init__ is NOT function (it is wrapper_descriptor)
# ---------------------------------------------------------------------------

table re_extra2356.pattern_init_not_function:
  kind: python_call_eq
  category: impl_type
  id_prefix: re2356

  columns: [id, function, args, expected]
  rows:
    - ["re2356012", Pattern.__init__.__class__.__name__.__eq__, ["function"], false]
    - ["re2356013", Match.__init__.__class__.__name__.__eq__,   ["function"], false]

# ---------------------------------------------------------------------------
# RegexFlag.__new__ is a Python function — IntFlag machinery
# ---------------------------------------------------------------------------

table re_extra2356.regexflag_new_is_function:
  kind: python_call_eq
  category: impl_type
  id_prefix: re2356

  columns: [id, function, args, expected]
  rows:
    - ["re2356014", RegexFlag.__new__.__class__.__name__.__eq__, ["function"],                   true]
    - ["re2356015", RegexFlag.__new__.__class__.__name__.__eq__, ["builtin_function_or_method"], false]
    - ["re2356016", RegexFlag.__new__.__class__.__name__.__eq__, ["wrapper_descriptor"],         false]

# ---------------------------------------------------------------------------
# Additional coverage: error.__init__ is callable and in error.__dict__
# ---------------------------------------------------------------------------

table re_extra2356.error_init_in_dict:
  kind: python_call_eq
  category: impl_type
  id_prefix: re2356

  columns: [id, function, args, expected]
  rows:
    - ["re2356017", error.__dict__.__contains__, ["__init__"], true]
    - ["re2356018", Pattern.__dict__.__contains__, ["__init__"], true]
    - ["re2356019", Match.__dict__.__contains__, ["__init__"], true]
    - ["re2356020", RegexFlag.__dict__.__contains__, ["__init__"], true]
