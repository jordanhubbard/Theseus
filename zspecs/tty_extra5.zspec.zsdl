spec: tty_extra5
version: ">=3.12"
backend: python_module(tty)

docs: https://docs.python.org/3/library/tty.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tty.html — Python tty module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tty.py"
  notes:
    - "This spec extends tty.zspec.zsdl through tty_extra4.zspec.zsdl with new, non-duplicate invariants."
    - "tty covers: setraw/setcbreak __name__ and __module__, IFLAG/OFLAG/CFLAG/LFLAG/ISPEED/OSPEED/CC values."
    - "tty_extra covers: function __name__/__module__ (invariants), index constant class and value checks."
    - "tty_extra2 covers: ISPEED/OSPEED class checks; setraw/setcbreak __qualname__/type; constant class table; IFLAG<OFLAG and CC>OSPEED ordering."
    - "tty_extra3 covers: module __name__/__package__; cfmakeraw/cfmakecbreak __name__/__module__/__qualname__/type; CFLAG+1==LFLAG; LFLAG<ISPEED."
    - "tty_extra4 covers: TCSANOW/TCSADRAIN/TCSAFLUSH values; ECHO/ICANON/ISIG/OPOST values; OFLAG+1==CFLAG; ISPEED+1==OSPEED; CC-OSPEED==1."
    - "New here: TCSANOW/TCSADRAIN/TCSAFLUSH class checks (int); IFLAG+1==OFLAG arithmetic; LFLAG+1==ISPEED arithmetic; setraw/setcbreak __doc__ type; cfmakeraw/cfmakecbreak __doc__ type."
    - "tty.TCSANOW/TCSADRAIN/TCSAFLUSH are re-exported from termios — they are plain ints."
    - "setraw and setcbreak are pure Python functions; __doc__.__class__.__name__ == 'str'."
    - "cfmakeraw and cfmakecbreak are Python 3.12+ pure Python functions with string docstrings."
    - "IFLAG(0)+1 == OFLAG(1) — adjacent index arithmetic not checked in prior specs."
    - "LFLAG(3)+1 == ISPEED(4) — adjacent index arithmetic not checked in prior specs."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TCSANOW / TCSADRAIN / TCSAFLUSH — class checks
# tty_extra4 pins their values; their class (int) is NOT checked in any tty spec.
# (termios_extra covers the class check for the termios module, not tty.)
# ---------------------------------------------------------------------------

table tty_extra5.tcsa_constants.class_checks:
  kind: python_call_eq
  category: constants
  id_prefix: tcsa_class

  columns: [id, function, args, expected]
  rows:
    - [TCSANOW,   TCSANOW.__class__.__name__.__eq__,   ["int"], true]
    - [TCSADRAIN, TCSADRAIN.__class__.__name__.__eq__, ["int"], true]
    - [TCSAFLUSH, TCSAFLUSH.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# Adjacent index arithmetic — IFLAG+1==OFLAG and LFLAG+1==ISPEED
# tty_extra2 covers IFLAG < OFLAG (strict less-than) but not IFLAG+1==OFLAG.
# tty_extra3 covers LFLAG < ISPEED but not LFLAG+1==ISPEED.
# ---------------------------------------------------------------------------

invariant tty_extra5.IFLAG.plus_one_is_OFLAG:
  description: "tty.IFLAG + 1 == tty.OFLAG — IFLAG(0) and OFLAG(1) are adjacent indices"
  category: constants
  kind: python_call_eq
  function: IFLAG.__add__
  args: [1]
  method: __eq__
  method_args: [1]
  expected: true

invariant tty_extra5.LFLAG.plus_one_is_ISPEED:
  description: "tty.LFLAG + 1 == tty.ISPEED — LFLAG(3) and ISPEED(4) are adjacent indices"
  category: constants
  kind: python_call_eq
  function: LFLAG.__add__
  args: [1]
  method: __eq__
  method_args: [4]
  expected: true

# ---------------------------------------------------------------------------
# Function __doc__ type checks — setraw and setcbreak
# No prior tty spec covers __doc__ for any function.
# setraw and setcbreak are pure Python functions with string docstrings.
# ---------------------------------------------------------------------------

table tty_extra5.function_doc_types:
  kind: python_call_eq
  category: function_docs
  id_prefix: doc_type

  columns: [id, function, args, expected]
  rows:
    - [setraw,    setraw.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [setcbreak, setcbreak.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# cfmakeraw / cfmakecbreak __doc__ type checks (Python 3.12+)
# tty_extra3 covers __name__/__module__/__qualname__/type for these functions
# but does NOT cover __doc__. New here.
# ---------------------------------------------------------------------------

table tty_extra5.cfmake_doc_types:
  kind: python_call_eq
  category: function_docs
  id_prefix: cfmake_doc

  columns: [id, function, args, expected]
  rows:
    - [cfmakeraw,    cfmakeraw.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [cfmakecbreak, cfmakecbreak.__doc__.__class__.__name__.__eq__, ["str"], true]
