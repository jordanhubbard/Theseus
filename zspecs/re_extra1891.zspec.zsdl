spec: re_extra1891
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
  notes:
    - "Tests unary arithmetic protocol, async iteration protocol, __fspath__, and regex flag constants in re module types"
    - "None of the re types implement unary arithmetic, async iteration, or __fspath__ dunder methods"
    - "re.A, re.I, re.L, re.M, re.S, re.U, re.X are short aliases for regex flag constants"
    - "re.T (TEMPLATE) was removed in Python 3.13"
    - "re.error and re.RegexFlag are public names in re.__dict__"
  created_at: "2026-04-12"

table re_extra1891.unary_arithmetic:
  columns: [id, function, args, expected]
  rows:
    - ["re1891-ua-001", "re.Pattern.__dict__.__contains__", ["__abs__"], false]
    - ["re1891-ua-002", "re.Pattern.__dict__.__contains__", ["__neg__"], false]
    - ["re1891-ua-003", "re.Match.__dict__.__contains__", ["__abs__"], false]
    - ["re1891-ua-004", "re.Match.__dict__.__contains__", ["__neg__"], false]
    - ["re1891-ua-005", "re.error.__dict__.__contains__", ["__abs__"], false]
    - ["re1891-ua-006", "re.RegexFlag.__dict__.__contains__", ["__abs__"], false]
    - ["re1891-ua-007", "re.Pattern.__dict__.__contains__", ["__round__"], false]
    - ["re1891-ua-008", "re.Match.__dict__.__contains__", ["__round__"], false]

table re_extra1891.fspath_aiter_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["re1891-fa-001", "re.Pattern.__dict__.__contains__", ["__fspath__"], false]
    - ["re1891-fa-002", "re.Pattern.__dict__.__contains__", ["__aiter__"], false]
    - ["re1891-fa-003", "re.Pattern.__dict__.__contains__", ["__anext__"], false]
    - ["re1891-fa-004", "re.Match.__dict__.__contains__", ["__fspath__"], false]
    - ["re1891-fa-005", "re.Match.__dict__.__contains__", ["__aiter__"], false]
    - ["re1891-fa-006", "re.Match.__dict__.__contains__", ["__anext__"], false]
    - ["re1891-fa-007", "re.error.__dict__.__contains__", ["__fspath__"], false]
    - ["re1891-fa-008", "re.RegexFlag.__dict__.__contains__", ["__fspath__"], false]

table re_extra1891.regex_flag_constants:
  columns: [id, function, args, expected]
  rows:
    - ["re1891-fc-001", "re.__dict__.__contains__", ["A"], true]
    - ["re1891-fc-002", "re.__dict__.__contains__", ["I"], true]
    - ["re1891-fc-003", "re.__dict__.__contains__", ["L"], true]
    - ["re1891-fc-004", "re.__dict__.__contains__", ["M"], true]
    - ["re1891-fc-005", "re.__dict__.__contains__", ["S"], true]
    - ["re1891-fc-006", "re.__dict__.__contains__", ["U"], true]
    - ["re1891-fc-007", "re.__dict__.__contains__", ["X"], true]
    - ["re1891-fc-008", "re.__dict__.__contains__", ["T"], false]
    - ["re1891-fc-009", "re.__dict__.__contains__", ["error"], true]
    - ["re1891-fc-010", "re.__dict__.__contains__", ["RegexFlag"], true]
