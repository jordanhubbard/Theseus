spec: functools_extra1606
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __slots__ and slot descriptor protocol"
    - "functools.partial is a C extension type: no __slots__ key in its __dict__, but exposes func/args/keywords as member_descriptors"
    - "functools.partialmethod is a pure Python class that does NOT define __slots__ (it uses __dict__ per instance)"
    - "functools.cached_property is a pure Python class with no __slots__"
    - "functools._lru_cache_wrapper is a C extension type wrapping lru_cache-decorated functions"
  created_at: "2026-04-12"
error_model: python_exceptions

table functools_extra1606.partial_slot_attrs:
  description: "functools.partial is a C extension type exposing func/args/keywords as C-level member_descriptors; no Python __slots__ key"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1606pa

  columns: [id, function, args, expected]
  rows:
    - ["fu1606pa001", "functools.partial.__dict__.__contains__", ["__slots__"],    false]
    - ["fu1606pa002", "functools.partial.__dict__.__contains__", ["func"],         true]
    - ["fu1606pa003", "functools.partial.__dict__.__contains__", ["args"],         true]
    - ["fu1606pa004", "functools.partial.__dict__.__contains__", ["keywords"],     true]
    - ["fu1606pa005", "functools.partial.__dict__.__contains__", ["__dict__"],     true]
    - ["fu1606pa006", "functools.partial.__dict__.__contains__", ["__weakref__"],  false]
    - ["fu1606pa007", "functools.partial.__dict__.__contains__", ["__call__"],     true]
    - ["fu1606pa008", "functools.partial.__dict__.__contains__", ["__get__"],      true]
    - ["fu1606pa009", "functools.partial.__dict__.__contains__", ["__new__"],      true]
    - ["fu1606pa010", "functools.partial.__dict__.__contains__", ["__reduce__"],   true]
    - ["fu1606pa011", "functools.partial.__dict__.__contains__", ["__setstate__"], true]
    - ["fu1606pa012", "functools.partial.__dict__.__contains__", ["__repr__"],     true]
    - ["fu1606pa013", "functools.partial.__dict__.__contains__", ["__vectorcalloffset__"], true]
    - ["fu1606pa014", "functools.partial.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["fu1606pa015", "functools.partial.__name__.__eq__",   ["partial"],      true]
    - ["fu1606pa016", "functools.partial.__module__.__eq__", ["functools"],    true]
    - ["fu1606pa017", "functools.partial.__dict__.__contains__", ["__class_getitem__"], true]
    - ["fu1606pa018", "functools.partial.__dict__.__contains__", ["__delattr__"],  true]
    - ["fu1606pa019", "functools.partial.__dict__.__contains__", ["__setattr__"],  true]
    - ["fu1606pa020", "functools.partial.__dict__.__contains__", ["__getattribute__"], true]
    - ["fu1606pa021", "functools.partial.__class__.__name__.__eq__", ["type"],     true]
    - ["fu1606pa022", "functools.partial.__bases__.__len__", [], 1]
    - ["fu1606pa023", "functools.partial.__dict__.__contains__", ["cache_clear"],  false]
    - ["fu1606pa024", "functools.partial.__dict__.__contains__", ["cache_info"],   false]
    - ["fu1606pa025", "functools.partial.__dict__.__contains__", ["__iter__"],     false]

