spec: google_auth_rust
version: ">=3.9"
backend: rust_module(google_auth_rust)

docs: https://google-auth.readthedocs.io/

provenance:
  derived_from:
    - "https://google-auth.readthedocs.io/ — google-auth library"
  notes:
    - "google-auth provides Google authentication."
    - "google.auth.credentials.Credentials is a class."
    - "google.oauth2.credentials.Credentials is a class."
    - "google.auth.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant google_auth_rust.has_credentials_class:
  description: "google.auth.credentials.Credentials is a class"
  category: presence
  kind: python_call_eq
  function: google_auth_has_credentials
  args: []
  expected: true

invariant google_auth_rust.has_oauth2_credentials:
  description: "google.oauth2.credentials.Credentials is a class"
  category: presence
  kind: python_call_eq
  function: google_auth_has_oauth2_credentials
  args: []
  expected: true

invariant google_auth_rust.version_nonempty:
  description: "google.auth.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: google_auth_version_nonempty
  args: []
  expected: true

