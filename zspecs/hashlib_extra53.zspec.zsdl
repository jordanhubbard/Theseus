spec: hashlib_extra53
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra52.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __doc__.__class__.__name__/__qualname__.__eq__('str') (the __doc__.__class__ type axis)."
    - "hashlib_extra51.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __name__.__class__.__name__.__eq__('str') (the __name__ type axis)."
    - "hashlib_extra6.zspec.zsdl — covers sha256/md5/sha1/sha384/sha512/pbkdf2_hmac/sha3_256/blake2b/blake2s/scrypt __module__.__eq__ string values (the __module__ value axis)."
    - "hashlib_extra4.zspec.zsdl — covers new.__module__.__eq__('hashlib') and new.__name__.__eq__('new')."
    - "hashlib_extra18.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/new __name__/__qualname__ string values."
    - "hashlib_extra50.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __class__.__qualname__/__module__ equality."
  notes:
    - "This spec extends hashlib through hashlib_extra52; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: No prior hashlib spec checks __module__.__class__.__name__.__eq__('str') for any hashlib callable. hashlib_extra6 covers the __module__ string VALUE for sha256/md5/sha1/sha3_256/blake2b/blake2s/pbkdf2_hmac (e.g., sha256.__module__.__eq__('_hashlib')). hashlib_extra51 covers __name__.__class__.__name__.__eq__('str') (the __name__ type axis). But no prior spec checks the TYPE of the __module__ attribute itself — i.e., __module__.__class__.__name__. For all hashlib callables, __module__ is a Python str, so __module__.__class__.__name__ == 'str'. This axis is entirely novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__module__.__class__.__name__ == 'str'. sha256.__module__ is '_hashlib' (a str); its __class__.__name__ is 'str'. No prior spec checks sha256.__module__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.md5.__module__.__class__.__name__ == 'str'. md5.__module__ is '_hashlib' (a str). No prior spec checks md5.__module__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__module__.__class__.__name__ == 'str'. sha1.__module__ is '_hashlib' (a str). No prior spec checks sha1.__module__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__module__.__class__.__name__ == 'str'. sha3_256.__module__ is '_sha3' (a str). No prior spec checks sha3_256.__module__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__.__class__.__name__ == 'str'. blake2b.__module__ is '_blake2' (a str). No prior spec checks blake2b.__module__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__.__class__.__name__ == 'str'. new.__module__ is 'hashlib' (a str). No prior spec checks new.__module__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__module__.__class__.__name__ == 'str'. pbkdf2_hmac.__module__ is '_hashlib' (a str). No prior spec checks pbkdf2_hmac.__module__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior hashlib spec checks __module__.__class__.__qualname__.__eq__('str') for any hashlib callable. hashlib_extra6 checks the __module__ string value; hashlib_extra52 checks __doc__.__class__.__qualname__. But __module__.__class__.__qualname__ is a distinct chain (module attribute, not doc attribute). For any str object, __class__.__qualname__ == 'str'. Three representative objects (sha256, blake2b, new) confirm this pattern provides an independent regression vector. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__module__.__class__.__qualname__ == 'str'. sha256.__module__ is a str; str.__qualname__ is 'str'. No prior spec checks sha256.__module__.__class__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__.__class__.__qualname__ == 'str'. blake2b.__module__ is a str; str.__qualname__ is 'str'. No prior spec checks blake2b.__module__.__class__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__.__class__.__qualname__ == 'str'. new.__module__ is 'hashlib' (a str); str.__qualname__ is 'str'. No prior spec checks new.__module__.__class__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior hashlib spec checks __module__.__len__() for any hashlib callable. hashlib_extra6 covers the __module__ string value but not its length. The length of the __module__ string provides an independent regression vector: if a function is moved to a differently-named module, the length changes. '_hashlib' has 8 chars, 'hashlib' has 7 chars, '_sha3' has 5 chars, '_blake2' has 7 chars. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__module__.__len__() == 8. '_hashlib' has 8 characters. No prior spec checks sha256.__module__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__.__len__() == 7. 'hashlib' has 7 characters. No prior spec checks new.__module__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__module__.__len__() == 5. '_sha3' has 5 characters. No prior spec checks sha3_256.__module__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__.__len__() == 7. '_blake2' has 7 characters. No prior spec checks blake2b.__module__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib callable __module__.__class__.__name__.__eq__('str')
#
# hashlib_extra6 covers the __module__ string VALUE for sha256/md5/sha1/
# sha3_256/blake2b/blake2s/pbkdf2_hmac. hashlib_extra51 covers the type of
# the __name__ attribute. But no prior spec checks the TYPE of __module__
# itself via __module__.__class__.__name__. For every hashlib callable,
# __module__ is a Python str, so __module__.__class__.__name__ == 'str'.
# This axis provides an independent structural regression vector.
# ---------------------------------------------------------------------------

table hashlib_extra53.module_class_names:
  description: "hashlib sha256/md5/sha1/sha3_256/blake2b/new/pbkdf2_hmac __module__.__class__.__name__.__eq__('str') — verifies that each hashlib callable's __module__ attribute is a Python str; novel __module__.__class__.__name__ axis; hashlib_extra6 covers __module__ string values (different axis); no prior spec checks __module__.__class__.__name__ for any hashlib callable"
  kind: python_call_eq
  category: type_structure
  id_prefix: hashlibmod53

  columns: [id, function, args, expected]
  rows:
    - [sha256_module_class_name_eq,    sha256.__module__.__class__.__name__.__eq__,    ["str"], true]
    - [md5_module_class_name_eq,       md5.__module__.__class__.__name__.__eq__,       ["str"], true]
    - [sha1_module_class_name_eq,      sha1.__module__.__class__.__name__.__eq__,      ["str"], true]
    - [sha3_256_module_class_name_eq,  sha3_256.__module__.__class__.__name__.__eq__,  ["str"], true]
    - [blake2b_module_class_name_eq,   blake2b.__module__.__class__.__name__.__eq__,   ["str"], true]
    - [new_module_class_name_eq,       new.__module__.__class__.__name__.__eq__,       ["str"], true]
    - [pbkdf2_hmac_module_class_name_eq, pbkdf2_hmac.__module__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# hashlib callable __module__.__class__.__qualname__.__eq__('str')
#
# A distinct attribute chain from __module__.__class__.__name__. For built-in
# str, __qualname__ == __name__ == 'str', but the .__qualname__ access path
# is independent. Three representative objects confirm the pattern.
# ---------------------------------------------------------------------------

table hashlib_extra53.module_class_qualnames:
  description: "hashlib sha256/blake2b/new __module__.__class__.__qualname__.__eq__('str') — str.__qualname__ == 'str'; novel __module__.__class__.__qualname__ axis distinct from __module__.__class__.__name__; hashlib_extra52 covers __doc__.__class__.__qualname__ (different attribute); no prior spec checks __module__.__class__.__qualname__ for any hashlib callable"
  kind: python_call_eq
  category: type_structure
  id_prefix: hashlibmodqual53

  columns: [id, function, args, expected]
  rows:
    - [sha256_module_class_qualname_eq, sha256.__module__.__class__.__qualname__.__eq__, ["str"], true]
    - [blake2b_module_class_qualname_eq, blake2b.__module__.__class__.__qualname__.__eq__, ["str"], true]
    - [new_module_class_qualname_eq,    new.__module__.__class__.__qualname__.__eq__,    ["str"], true]

# ---------------------------------------------------------------------------
# hashlib callable __module__.__len__()
#
# hashlib_extra6 checks __module__ string values ('_hashlib', '_sha3', etc.)
# but no prior spec checks their lengths. The length of the __module__ string
# is an independent regression vector: if a function moves to a differently-
# named module, the length changes. '_hashlib'=8, 'hashlib'=7, '_sha3'=5,
# '_blake2'=7. These four cases cover three distinct module strings.
# ---------------------------------------------------------------------------

table hashlib_extra53.module_lengths:
  description: "hashlib sha256/new/sha3_256/blake2b __module__.__len__() — '_hashlib'=8 chars, 'hashlib'=7 chars, '_sha3'=5 chars, '_blake2'=7 chars; independent length regression vector; hashlib_extra6 covers __module__ string values but no prior spec checks __module__.__len__() for any hashlib callable"
  kind: python_call_eq
  category: type_structure
  id_prefix: hashlibmodlen53

  columns: [id, function, args, expected]
  rows:
    - [sha256_module_len,   sha256.__module__.__len__,   [], 8]
    - [new_module_len,      new.__module__.__len__,      [], 7]
    - [sha3_256_module_len, sha3_256.__module__.__len__, [], 5]
    - [blake2b_module_len,  blake2b.__module__.__len__,  [], 7]
