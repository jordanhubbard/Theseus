spec: csv_extra4
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html
rfcs:
  - "RFC 4180 — Common Format and MIME Type for Comma-Separated Values (CSV) Files"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "RFC 4180 — Common Format and MIME Type for Comma-Separated Values"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
  notes:
    - "This spec extends prior csv specs."
    - "Focus: Dialect class attributes; csv constants; DictReader/DictWriter class names."
    - "csv.excel.__name__ == 'excel' (default dialect)."
    - "csv.excel_tab.__name__ == 'excel-tab'."
    - "csv.excel.delimiter == ','."
    - "csv.excel.quotechar == '\"'."
    - "csv.excel.doublequote == True."
    - "csv.excel.skipinitialspace == False."
    - "csv.excel.lineterminator == '\\r\\n'."
    - "csv.QUOTE_ALL == 1; csv.QUOTE_MINIMAL == 0; csv.QUOTE_NONNUMERIC == 2; csv.QUOTE_NONE == 3."
    - "csv.DictReader.__name__ == 'DictReader'."
    - "csv.DictWriter.__name__ == 'DictWriter'."
    - "csv.Dialect.__name__ == 'Dialect'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table csv_extra4.quote_constants:
  kind: python_call_eq
  category: constants
  id_prefix: quote

  columns: [id, function, args, expected]
  rows:
    - [QUOTE_MINIMAL,    QUOTE_MINIMAL.__eq__,    [0], true]
    - [QUOTE_ALL,        QUOTE_ALL.__eq__,        [1], true]
    - [QUOTE_NONNUMERIC, QUOTE_NONNUMERIC.__eq__, [2], true]
    - [QUOTE_NONE,       QUOTE_NONE.__eq__,       [3], true]

table csv_extra4.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [DictReader, DictReader.__name__.__eq__, ["DictReader"], true]
    - [DictWriter, DictWriter.__name__.__eq__, ["DictWriter"], true]
    - [Dialect,    Dialect.__name__.__eq__,    ["Dialect"],    true]

invariant csv_extra4.excel.delimiter:
  description: "csv.excel.delimiter == ','"
  category: excel_dialect
  kind: python_call_eq
  function: excel.delimiter.__eq__
  args: [","]
  expected: true

invariant csv_extra4.excel.quotechar:
  description: "csv.excel.quotechar == '\"'"
  category: excel_dialect
  kind: python_call_eq
  function: excel.quotechar.__eq__
  args: ["\""]
  expected: true

invariant csv_extra4.excel.doublequote:
  description: "csv.excel.doublequote == True"
  category: excel_dialect
  kind: python_call_eq
  function: excel.doublequote.__eq__
  args: [true]
  expected: true

invariant csv_extra4.excel.skipinitialspace:
  description: "csv.excel.skipinitialspace == False"
  category: excel_dialect
  kind: python_call_eq
  function: excel.skipinitialspace.__eq__
  args: [false]
  expected: true

invariant csv_extra4.excel.lineterminator:
  description: "csv.excel.lineterminator == '\\r\\n'"
  category: excel_dialect
  kind: python_call_eq
  function: excel.lineterminator.__eq__
  args: ["\r\n"]
  expected: true

invariant csv_extra4.Error.class_name:
  description: "csv.Error.__name__ == 'Error'"
  category: exceptions
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant csv_extra4.field_size_limit.returns_int:
  description: "csv.field_size_limit().__class__.__name__ == 'int'"
  category: field_size_limit
  kind: python_call_eq
  function: field_size_limit
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["int"]
  expected: true
