spec: decimal_extra1861
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from: []
  not_derived_from: []
  notes:
    - "Wave 571: bitwise and in-place operators for decimal module classes"
    - "Decimal is immutable; no in-place arithmetic operators defined in class dict"
  created_at: "2026-04-12"

