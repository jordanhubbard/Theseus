    - "cassandra.cluster.Cluster is a class."
    - "cassandra.auth.PlainTextAuthProvider is a class."
    - "cassandra.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant cassandra_driver_rust.has_cluster:
  description: "cassandra.cluster.Cluster is a class"
  category: presence
  kind: python_call_eq
  function: cassandra_driver_has_cluster
  args: []
  expected: true

invariant cassandra_driver_rust.has_auth_provider:
  description: "cassandra.auth.PlainTextAuthProvider is a class"
  category: presence
  kind: python_call_eq
  function: cassandra_driver_has_auth_provider
  args: []
  expected: true

invariant cassandra_driver_rust.version_nonempty:
  description: "cassandra.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: cassandra_driver_version_nonempty
  args: []
  expected: true

