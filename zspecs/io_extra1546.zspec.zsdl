spec: io_extra1546
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl — covers basic io class presence and read/write methods"
  notes:
    - "Wave 550 (_extra1546): bitwise operator __dict__ presence checks for io module classes."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase are all abstract base classes; their own __dict__ is minimal: __abstractmethods__, __doc__, __firstlineno__, __module__, __static_attributes__, _abc_impl. No bitwise operators are defined in any of these ABCs."
    - "io.BytesIO and io.StringIO are concrete in-memory stream classes. Neither defines any bitwise operators (__and__, __or__, __xor__, __invert__, __lshift__, __rshift__, __rand__, __ror__, __rxor__). BytesIO.__dict__ contains I/O methods: read, write, getvalue, seek, tell, read1, readinto, __init__. StringIO.__dict__ contains: read, write, getvalue, seek, tell, __init__."
    - "Bitwise operators are absent from all io module classes because stream objects are not integer-like values; bitwise operations have no meaningful semantics for file or buffer objects."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1546.iobase_bitwise_ops_absent:
  description: "io.IOBase bitwise operator absence — __and__, __or__, __xor__, __invert__, __lshift__, __rshift__ and reflected variants are all absent from io.IOBase.__dict__; IOBase is an abstract base class providing the core I/O interface; its own __dict__ contains only ABC infrastructure attributes (__abstractmethods__, _abc_impl) and metadata (__doc__, __module__); no bitwise operators are present; wave 550"
  kind: python_call_eq
  category: bitwise_ops
  id_prefix: io1546ib
  columns: [id, function, args, expected, description]
  rows:
    - [io1546ib001,
       io.IOBase.__dict__.__contains__,
       ["__and__"],
       false,
       "io.IOBase.__dict__.__contains__('__and__') == False — io.IOBase is an abstract base class for all I/O objects; stream objects are not integer-like values; __and__ (bitwise AND) is absent from IOBase.__dict__; verified with Python 3.14.3"]
    - [io1546ib002,
       io.IOBase.__dict__.__contains__,
       ["__or__"],
       false,
       "io.IOBase.__dict__.__contains__('__or__') == False — io.IOBase does not define __or__ (bitwise OR) in its own __dict__; bitwise operations have no meaningful semantics for file objects; verified with Python 3.14.3"]
    - [io1546ib003,
       io.IOBase.__dict__.__contains__,
       ["__xor__"],
       false,
       "io.IOBase.__dict__.__contains__('__xor__') == False — io.IOBase does not define __xor__ (bitwise XOR) in its own __dict__; verified with Python 3.14.3"]
    - [io1546ib004,
       io.IOBase.__dict__.__contains__,
       ["__invert__"],
       false,
       "io.IOBase.__dict__.__contains__('__invert__') == False — io.IOBase does not define __invert__ (bitwise NOT, unary ~) in its own __dict__; verified with Python 3.14.3"]
    - [io1546ib005,
       io.IOBase.__dict__.__contains__,
       ["__lshift__"],
       false,
       "io.IOBase.__dict__.__contains__('__lshift__') == False — io.IOBase does not define __lshift__ (left bitshift <<) in its own __dict__; verified with Python 3.14.3"]
    - [io1546ib006,
       io.IOBase.__dict__.__contains__,
       ["__rshift__"],
       false,
       "io.IOBase.__dict__.__contains__('__rshift__') == False — io.IOBase does not define __rshift__ (right bitshift >>) in its own __dict__; verified with Python 3.14.3"]
    - [io1546ib007,
       io.IOBase.__dict__.__contains__,
       ["__rand__"],
       false,
       "io.IOBase.__dict__.__contains__('__rand__') == False — io.IOBase does not define __rand__ (reflected bitwise AND) in its own __dict__; verified with Python 3.14.3"]
    - [io1546ib008,
       io.IOBase.__dict__.__contains__,
       ["__ror__"],
       false,
       "io.IOBase.__dict__.__contains__('__ror__') == False — io.IOBase does not define __ror__ (reflected bitwise OR) in its own __dict__; verified with Python 3.14.3"]
    - [io1546ib009,
       io.IOBase.__dict__.__contains__,
       ["__rxor__"],
       false,
       "io.IOBase.__dict__.__contains__('__rxor__') == False — io.IOBase does not define __rxor__ (reflected bitwise XOR) in its own __dict__; IOBase's own __dict__ contains only ABC infrastructure: __abstractmethods__, _abc_impl, __doc__, __module__, __firstlineno__, __static_attributes__; verified with Python 3.14.3"]
    - [io1546ib010,
       io.IOBase.__dict__.__contains__,
       ["__doc__"],
       true,
       "io.IOBase.__dict__.__contains__('__doc__') == True — positive anchor: io.IOBase does define __doc__ in its own __dict__; IOBase is documented; the __dict__ contains metadata and ABC infrastructure but no bitwise operators; verified with Python 3.14.3"]

table io_extra1546.bytesio_bitwise_ops_absent:
  description: "io.BytesIO bitwise operator absence — all bitwise operators absent from io.BytesIO.__dict__; BytesIO is a concrete in-memory binary stream backed by a bytes buffer; its __dict__ contains I/O methods (read, write, getvalue, seek, tell, read1, readinto, __init__) but no bitwise operators; wave 550"
  kind: python_call_eq
  category: bitwise_ops
  id_prefix: io1546by
  columns: [id, function, args, expected, description]
  rows:
    - [io1546by001,
       io.BytesIO.__dict__.__contains__,
       ["__and__"],
       false,
       "io.BytesIO.__dict__.__contains__('__and__') == False — io.BytesIO is an in-memory binary stream; it provides a bytes-compatible buffer interface but not integer bitwise operations; __and__ is absent from BytesIO.__dict__; verified with Python 3.14.3"]
    - [io1546by002,
       io.BytesIO.__dict__.__contains__,
       ["__or__"],
       false,
       "io.BytesIO.__dict__.__contains__('__or__') == False — io.BytesIO does not define __or__ in its own __dict__; the bytes buffer contents cannot be OR-ed as an integer; verified with Python 3.14.3"]
    - [io1546by003,
       io.BytesIO.__dict__.__contains__,
       ["__xor__"],
       false,
       "io.BytesIO.__dict__.__contains__('__xor__') == False — io.BytesIO does not define __xor__ in its own __dict__; verified with Python 3.14.3"]
    - [io1546by004,
       io.BytesIO.__dict__.__contains__,
       ["__invert__"],
       false,
       "io.BytesIO.__dict__.__contains__('__invert__') == False — io.BytesIO does not define __invert__ in its own __dict__; verified with Python 3.14.3"]
    - [io1546by005,
       io.BytesIO.__dict__.__contains__,
       ["__lshift__"],
       false,
       "io.BytesIO.__dict__.__contains__('__lshift__') == False — io.BytesIO does not define __lshift__ in its own __dict__; verified with Python 3.14.3"]
    - [io1546by006,
       io.BytesIO.__dict__.__contains__,
       ["__rshift__"],
       false,
       "io.BytesIO.__dict__.__contains__('__rshift__') == False — io.BytesIO does not define __rshift__ in its own __dict__; verified with Python 3.14.3"]
    - [io1546by007,
       io.BytesIO.__dict__.__contains__,
       ["__rand__"],
       false,
       "io.BytesIO.__dict__.__contains__('__rand__') == False — io.BytesIO does not define __rand__ in its own __dict__; verified with Python 3.14.3"]
    - [io1546by008,
       io.BytesIO.__dict__.__contains__,
       ["__ror__"],
       false,
       "io.BytesIO.__dict__.__contains__('__ror__') == False — io.BytesIO does not define __ror__ in its own __dict__; verified with Python 3.14.3"]
    - [io1546by009,
       io.BytesIO.__dict__.__contains__,
       ["__rxor__"],
       false,
       "io.BytesIO.__dict__.__contains__('__rxor__') == False — io.BytesIO does not define __rxor__ in its own __dict__; verified with Python 3.14.3"]
    - [io1546by010,
       io.BytesIO.__dict__.__contains__,
       ["read"],
       true,
       "io.BytesIO.__dict__.__contains__('read') == True — positive anchor: io.BytesIO defines 'read' in its own __dict__; BytesIO.read() reads and returns up to size bytes from the buffer; the class dict contains I/O methods but no bitwise operators; verified with Python 3.14.3"]
    - [io1546by011,
       io.BytesIO.__dict__.__contains__,
       ["write"],
       true,
       "io.BytesIO.__dict__.__contains__('write') == True — positive anchor: io.BytesIO defines 'write' in its own __dict__; BytesIO.write() appends bytes to the buffer; confirmed no bitwise operators alongside write in BytesIO.__dict__; verified with Python 3.14.3"]
    - [io1546by012,
       io.BytesIO.__dict__.__contains__,
       ["getvalue"],
       true,
       "io.BytesIO.__dict__.__contains__('getvalue') == True — positive anchor: io.BytesIO defines 'getvalue' in its own __dict__; getvalue() returns the entire contents of the buffer as a bytes object; no bitwise operators present alongside getvalue; verified with Python 3.14.3"]

