spec: itertools_extra252
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.groupby, itertools.zip_longest, itertools.takewhile, itertools.dropwhile, itertools.filterfalse, and itertools.starmap type identity behavioral contracts."
    - "itertools.groupby.__class__.__name__ == 'type' — groupby is a C-level iterator type; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.groupby.__module__ == 'itertools' — groupby is defined in the itertools C extension; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.groupby.__name__ == 'groupby' — groupby type name is 'groupby'. Verified with Python 3.14.3."
    - "itertools.zip_longest.__class__.__name__ == 'type' — zip_longest is a C-level iterator type; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.zip_longest.__module__ == 'itertools' — zip_longest is defined in the itertools C extension; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.zip_longest.__name__ == 'zip_longest' — zip_longest type name is 'zip_longest'. Verified with Python 3.14.3."
    - "itertools.takewhile.__class__.__name__ == 'type' — takewhile is a C-level iterator type; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.takewhile.__module__ == 'itertools' — takewhile is defined in the itertools C extension; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.dropwhile.__class__.__name__ == 'type' — dropwhile is a C-level iterator type; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.filterfalse.__class__.__name__ == 'type' — filterfalse is a C-level iterator type; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.starmap.__class__.__name__ == 'type' — starmap is a C-level iterator type; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.groupby type identity
#
# itertools.groupby.__class__.__name__ == 'type'
# itertools.groupby.__module__ == 'itertools'
# itertools.groupby.__name__ == 'groupby'
#
# groupby is a C-level lazy iterator type that groups consecutive elements
# with the same key. It is not a function. New to extra252.
# ---------------------------------------------------------------------------

table itertools_extra252.groupby_identity:
  description: "itertools.groupby __name__, __module__, __class__.__name__ identity contracts; new to extra252"
  kind: python_call_eq
  category: identity
  id_prefix: itergroupby252

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_name_eq,
       groupby.__name__.__eq__,
       ["groupby"],
       true,
       "itertools.groupby.__name__.__eq__('groupby') == True — groupby is a C-level iterator type; __name__ is 'groupby'; new to extra252"]
    - [groupby_module_eq,
       groupby.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.groupby.__module__.__eq__('itertools') == True — groupby is defined in the itertools C extension; __module__ is 'itertools'; new to extra252"]
    - [groupby_class_name_eq,
       groupby.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.groupby.__class__.__name__.__eq__('type') == True — groupby is a C-level type (not a function); __class__.__name__ is 'type'; new to extra252"]
    - [groupby_name_len_7,
       groupby.__name__.__len__,
       [],
       7,
       "itertools.groupby.__name__.__len__() == 7 — 'groupby' has 7 characters; new to extra252"]
    - [groupby_module_len_9,
       groupby.__module__.__len__,
       [],
       9,
       "itertools.groupby.__module__.__len__() == 9 — 'itertools' has 9 characters; new to extra252"]

# ---------------------------------------------------------------------------
# Table 2: itertools.zip_longest type identity
#
# itertools.zip_longest.__class__.__name__ == 'type'
# itertools.zip_longest.__module__ == 'itertools'
# itertools.zip_longest.__name__ == 'zip_longest'
#
# zip_longest is a C-level iterator type that zips iterables filling missing
# values with a fillvalue. New to extra252.
# ---------------------------------------------------------------------------

table itertools_extra252.zip_longest_identity:
  description: "itertools.zip_longest __name__, __module__, __class__.__name__ identity contracts; new to extra252"
  kind: python_call_eq
  category: identity
  id_prefix: iterziplong252

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_name_eq,
       zip_longest.__name__.__eq__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__name__.__eq__('zip_longest') == True — zip_longest is a C-level iterator type; __name__ is 'zip_longest'; new to extra252"]
    - [zip_longest_module_eq,
       zip_longest.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.zip_longest.__module__.__eq__('itertools') == True — zip_longest is defined in the itertools C extension; __module__ is 'itertools'; new to extra252"]
    - [zip_longest_class_name_eq,
       zip_longest.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.zip_longest.__class__.__name__.__eq__('type') == True — zip_longest is a C-level type; __class__.__name__ is 'type'; new to extra252"]
    - [zip_longest_name_len_11,
       zip_longest.__name__.__len__,
       [],
       11,
       "itertools.zip_longest.__name__.__len__() == 11 — 'zip_longest' has 11 characters; new to extra252"]
    - [zip_longest_module_len_9,
       zip_longest.__module__.__len__,
       [],
       9,
       "itertools.zip_longest.__module__.__len__() == 9 — 'itertools' has 9 characters; new to extra252"]

# ---------------------------------------------------------------------------
# Table 3: itertools.takewhile, dropwhile, filterfalse, starmap type identity
#
# itertools.takewhile.__class__.__name__ == 'type'
# itertools.takewhile.__module__ == 'itertools'
# itertools.dropwhile.__name__ == 'dropwhile'
# itertools.filterfalse.__name__ == 'filterfalse'
# itertools.starmap.__name__ == 'starmap'
#
# All four are C-level iterator types in the itertools module.
# New to extra252.
# ---------------------------------------------------------------------------

table itertools_extra252.takewhile_dropwhile_filterfalse_starmap_identity:
  description: "itertools.takewhile, dropwhile, filterfalse, starmap __name__, __module__, __class__.__name__ identity contracts; new to extra252"
  kind: python_call_eq
  category: identity
  id_prefix: itertakefilt252

  columns: [id, function, args, expected, description]
  rows:
    - [takewhile_name_eq,
       takewhile.__name__.__eq__,
       ["takewhile"],
       true,
       "itertools.takewhile.__name__.__eq__('takewhile') == True — takewhile is a C-level iterator type yielding elements while predicate is true; __name__ is 'takewhile'; new to extra252"]
    - [takewhile_module_eq,
       takewhile.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.takewhile.__module__.__eq__('itertools') == True — takewhile is defined in the itertools C extension; __module__ is 'itertools'; new to extra252"]
    - [dropwhile_name_eq,
       dropwhile.__name__.__eq__,
       ["dropwhile"],
       true,
       "itertools.dropwhile.__name__.__eq__('dropwhile') == True — dropwhile is a C-level iterator type dropping elements while predicate is true; __name__ is 'dropwhile'; new to extra252"]
    - [filterfalse_name_eq,
       filterfalse.__name__.__eq__,
       ["filterfalse"],
       true,
       "itertools.filterfalse.__name__.__eq__('filterfalse') == True — filterfalse is a C-level iterator type yielding elements for which predicate is false; __name__ is 'filterfalse'; new to extra252"]
    - [starmap_name_eq,
       starmap.__name__.__eq__,
       ["starmap"],
       true,
       "itertools.starmap.__name__.__eq__('starmap') == True — starmap is a C-level iterator type applying a function using arguments from an iterable of tuples; __name__ is 'starmap'; new to extra252"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra252
# ---------------------------------------------------------------------------

invariant itertools_extra252.groupby.name_eq:
  description: "itertools.groupby.__name__ == 'groupby' — C-level iterator type grouping consecutive elements by key; new to extra252"
  category: identity
  kind: python_call_eq
  function: groupby.__name__.__eq__
  args: ["groupby"]
  expected: true

invariant itertools_extra252.groupby.module_eq:
  description: "itertools.groupby.__module__ == 'itertools' — defined in the itertools C extension; new to extra252"
  category: identity
  kind: python_call_eq
  function: groupby.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra252.groupby.class_is_type:
  description: "itertools.groupby.__class__.__name__ == 'type' — groupby is a C-level type, not a function; new to extra252"
  category: identity
  kind: python_call_eq
  function: groupby.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra252.groupby.name_len_7:
  description: "itertools.groupby.__name__.__len__() == 7 — 'groupby' has 7 characters; new to extra252"
  category: identity
  kind: python_call_eq
  function: groupby.__name__.__len__
  args: []
  expected: 7

invariant itertools_extra252.zip_longest.name_eq:
  description: "itertools.zip_longest.__name__ == 'zip_longest' — C-level iterator type zipping iterables with fillvalue for short ones; new to extra252"
  category: identity
  kind: python_call_eq
  function: zip_longest.__name__.__eq__
  args: ["zip_longest"]
  expected: true

invariant itertools_extra252.zip_longest.module_eq:
  description: "itertools.zip_longest.__module__ == 'itertools' — defined in the itertools C extension; new to extra252"
  category: identity
  kind: python_call_eq
  function: zip_longest.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra252.zip_longest.class_is_type:
  description: "itertools.zip_longest.__class__.__name__ == 'type' — zip_longest is a C-level type, not a function; new to extra252"
  category: identity
  kind: python_call_eq
  function: zip_longest.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra252.zip_longest.name_len_11:
  description: "itertools.zip_longest.__name__.__len__() == 11 — 'zip_longest' has 11 characters; new to extra252"
  category: identity
  kind: python_call_eq
  function: zip_longest.__name__.__len__
  args: []
  expected: 11

invariant itertools_extra252.takewhile.name_eq:
  description: "itertools.takewhile.__name__ == 'takewhile' — C-level iterator type yielding elements while predicate is true; new to extra252"
  category: identity
  kind: python_call_eq
  function: takewhile.__name__.__eq__
  args: ["takewhile"]
  expected: true

invariant itertools_extra252.takewhile.module_eq:
  description: "itertools.takewhile.__module__ == 'itertools' — defined in the itertools C extension; new to extra252"
  category: identity
  kind: python_call_eq
  function: takewhile.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra252.takewhile.class_is_type:
  description: "itertools.takewhile.__class__.__name__ == 'type' — takewhile is a C-level type; new to extra252"
  category: identity
  kind: python_call_eq
  function: takewhile.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra252.dropwhile.name_eq:
  description: "itertools.dropwhile.__name__ == 'dropwhile' — C-level iterator type dropping elements while predicate is true; new to extra252"
  category: identity
  kind: python_call_eq
  function: dropwhile.__name__.__eq__
  args: ["dropwhile"]
  expected: true

invariant itertools_extra252.dropwhile.module_eq:
  description: "itertools.dropwhile.__module__ == 'itertools' — defined in the itertools C extension; new to extra252"
  category: identity
  kind: python_call_eq
  function: dropwhile.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra252.filterfalse.name_eq:
  description: "itertools.filterfalse.__name__ == 'filterfalse' — C-level iterator type yielding elements where predicate is false; new to extra252"
  category: identity
  kind: python_call_eq
  function: filterfalse.__name__.__eq__
  args: ["filterfalse"]
  expected: true

invariant itertools_extra252.filterfalse.module_eq:
  description: "itertools.filterfalse.__module__ == 'itertools' — defined in the itertools C extension; new to extra252"
  category: identity
  kind: python_call_eq
  function: filterfalse.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra252.starmap.name_eq:
  description: "itertools.starmap.__name__ == 'starmap' — C-level iterator type applying a function using tuple arguments from an iterable; new to extra252"
  category: identity
  kind: python_call_eq
  function: starmap.__name__.__eq__
  args: ["starmap"]
  expected: true

invariant itertools_extra252.starmap.module_eq:
  description: "itertools.starmap.__module__ == 'itertools' — defined in the itertools C extension; new to extra252"
  category: identity
  kind: python_call_eq
  function: starmap.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra252.starmap.class_is_type:
  description: "itertools.starmap.__class__.__name__ == 'type' — starmap is a C-level type; new to extra252"
  category: identity
  kind: python_call_eq
  function: starmap.__class__.__name__.__eq__
  args: ["type"]
  expected: true
