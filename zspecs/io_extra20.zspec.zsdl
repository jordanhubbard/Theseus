spec: io_extra20
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
    - "io_extra18.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__; DEFAULT_BUFFER_SIZE type/sign; SEEK_* constants"
    - "io_extra19.zspec.zsdl — covers __qualname__ for StringIO/BytesIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper/UnsupportedOperation; UnsupportedOperation base classes"
  notes:
    - "This spec extends io.zspec.zsdl through io_extra19.zspec.zsdl."
    - "io_extra18 covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__ and DEFAULT_BUFFER_SIZE type and sign."
    - "No prior io spec covers __name__ for FileIO, BytesIO, StringIO, BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper, IncrementalNewlineDecoder via table."
    - "No prior io spec checks DEFAULT_BUFFER_SIZE.__eq__(8192) directly."
    - "No prior io spec covers io.BytesIO.__bases__[0].__name__ == 'BufferedIOBase' or io.StringIO.__bases__[0].__name__ == 'TextIOBase'."
    - "io.IOBase.__name__ == 'IOBase', io.RawIOBase.__name__ == 'RawIOBase', etc. — class names match the Python-level attribute names."
    - "io.DEFAULT_BUFFER_SIZE == 8192 — the default buffer size for buffered I/O operations."
    - "io.BytesIO.__bases__[0].__name__ == 'BufferedIOBase' — BytesIO directly subclasses BufferedIOBase."
    - "io.StringIO.__bases__[0].__name__ == 'TextIOBase' — StringIO directly subclasses TextIOBase."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io class __name__ attributes
#
# io_extra18 covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__.
# No prior io spec covers __name__ for FileIO, BytesIO, StringIO,
# BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper, or
# IncrementalNewlineDecoder in a single table. This table provides
# comprehensive __name__ coverage for all major io classes.
# ---------------------------------------------------------------------------

table io_extra20.class_names:
  description: "__name__ attribute for major io module classes"
  kind: python_call_eq
  category: class_names

  columns: [id, function, args, expected]
  rows:
    - [IOBase,                  IOBase.__name__.__eq__,                  ["IOBase"],                  true]
    - [RawIOBase,               RawIOBase.__name__.__eq__,               ["RawIOBase"],               true]
    - [BufferedIOBase,          BufferedIOBase.__name__.__eq__,          ["BufferedIOBase"],          true]
    - [TextIOBase,              TextIOBase.__name__.__eq__,              ["TextIOBase"],              true]
    - [FileIO,                  FileIO.__name__.__eq__,                  ["FileIO"],                  true]
    - [BytesIO,                 BytesIO.__name__.__eq__,                 ["BytesIO"],                 true]
    - [StringIO,                StringIO.__name__.__eq__,                ["StringIO"],                true]
    - [BufferedReader,          BufferedReader.__name__.__eq__,          ["BufferedReader"],          true]
    - [BufferedWriter,          BufferedWriter.__name__.__eq__,          ["BufferedWriter"],          true]
    - [BufferedRandom,          BufferedRandom.__name__.__eq__,          ["BufferedRandom"],          true]
    - [TextIOWrapper,           TextIOWrapper.__name__.__eq__,           ["TextIOWrapper"],           true]
    - [IncrementalNewlineDecoder, IncrementalNewlineDecoder.__name__.__eq__, ["IncrementalNewlineDecoder"], true]

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE == 8192
#
# io_extra18 covers DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' and
# DEFAULT_BUFFER_SIZE.__gt__(0). No prior spec checks the exact value.
# The default buffer size for buffered I/O is 8192 bytes (8 KiB).
# ---------------------------------------------------------------------------

invariant io_extra20.DEFAULT_BUFFER_SIZE.value:
  description: "io.DEFAULT_BUFFER_SIZE == 8192 — the standard 8 KiB default buffer size"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [8192]
  expected: true

# ---------------------------------------------------------------------------
# io.BytesIO.__bases__[0].__name__ and io.StringIO.__bases__[0].__name__
#
# No prior io spec covers the primary base class of BytesIO or StringIO by name.
# BytesIO directly subclasses BufferedIOBase; StringIO directly subclasses TextIOBase.
# The __bases__[0].__name__ check uses __getitem__ on __bases__ with index 0,
# then chains __name__.__eq__ as an invariant method chain.
# ---------------------------------------------------------------------------

invariant io_extra20.BytesIO.base0_name:
  description: "io.BytesIO.__bases__[0].__name__ == 'BufferedIOBase' — BytesIO directly subclasses BufferedIOBase"
  category: class_hierarchy
  kind: python_call_eq
  function: BytesIO.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["BufferedIOBase"]
  expected: true

invariant io_extra20.StringIO.base0_name:
  description: "io.StringIO.__bases__[0].__name__ == 'TextIOBase' — StringIO directly subclasses TextIOBase"
  category: class_hierarchy
  kind: python_call_eq
  function: StringIO.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["TextIOBase"]
  expected: true
