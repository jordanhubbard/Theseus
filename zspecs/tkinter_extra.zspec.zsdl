spec: tkinter_extra
version: ">=3.9"
backend: python_module(tkinter)

docs: https://docs.python.org/3/library/tkinter.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tkinter.html — Python tkinter module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tkinter/__init__.py"
  notes:
    - "Extends tkinter.zspec.zsdl with class name, module, and hierarchy invariants for core widget classes."
    - "tkinter.Tk is the top-level window class; its __name__ == 'Tk' and __module__ == 'tkinter'."
    - "tkinter.TclError.__bases__[0].__name__ == 'Exception' — TclError inherits directly from Exception."
    - "tkinter.Misc is the base mixin class for all widget and wm classes."
    - "tkinter.Variable is the base class for StringVar, IntVar, DoubleVar, BooleanVar."
    - "tkinter.StringVar.__bases__[0].__name__ == 'Variable' — StringVar inherits from Variable."
    - "tkinter.Frame is a widget class used for grouping other widgets."
    - "tkinter.Widget is the base class for all Tk widgets; it inherits from BaseWidget and Misc."
    - "These class name and hierarchy checks are safe without a running Tk display."
    - "All expected values verified with Python 3.12 tkinter on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Tk — class name and module
# ---------------------------------------------------------------------------

invariant tkinter_extra.Tk.name:
  description: "tkinter.Tk.__name__ == 'Tk'"
  category: class_names
  kind: python_call_eq
  function: Tk.__name__.__eq__
  args: ["Tk"]
  expected: true

invariant tkinter_extra.Tk.module:
  description: "tkinter.Tk.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: Tk.__module__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# TclError — class name and hierarchy
# ---------------------------------------------------------------------------

invariant tkinter_extra.TclError.name:
  description: "tkinter.TclError.__name__ == 'TclError'"
  category: class_names
  kind: python_call_eq
  function: TclError.__name__.__eq__
  args: ["TclError"]
  expected: true

invariant tkinter_extra.TclError.base_is_Exception:
  description: "tkinter.TclError.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: TclError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# Misc — base mixin class name and module
# ---------------------------------------------------------------------------

invariant tkinter_extra.Misc.name:
  description: "tkinter.Misc.__name__ == 'Misc'"
  category: class_names
  kind: python_call_eq
  function: Misc.__name__.__eq__
  args: ["Misc"]
  expected: true

invariant tkinter_extra.Misc.module:
  description: "tkinter.Misc.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: Misc.__module__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# Variable — base class for traced variable types
# ---------------------------------------------------------------------------

invariant tkinter_extra.Variable.name:
  description: "tkinter.Variable.__name__ == 'Variable'"
  category: class_names
  kind: python_call_eq
  function: Variable.__name__.__eq__
  args: ["Variable"]
  expected: true

invariant tkinter_extra.Variable.module:
  description: "tkinter.Variable.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: Variable.__module__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# StringVar — name and parent class
# ---------------------------------------------------------------------------

invariant tkinter_extra.StringVar.name:
  description: "tkinter.StringVar.__name__ == 'StringVar'"
  category: class_names
  kind: python_call_eq
  function: StringVar.__name__.__eq__
  args: ["StringVar"]
  expected: true

invariant tkinter_extra.StringVar.base_is_Variable:
  description: "tkinter.StringVar.__bases__[0].__name__ == 'Variable'"
  category: class_hierarchy
  kind: python_call_eq
  function: StringVar.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Variable"

# ---------------------------------------------------------------------------
# Frame — widget class name and module
# ---------------------------------------------------------------------------

invariant tkinter_extra.Frame.name:
  description: "tkinter.Frame.__name__ == 'Frame'"
  category: class_names
  kind: python_call_eq
  function: Frame.__name__.__eq__
  args: ["Frame"]
  expected: true

invariant tkinter_extra.Frame.module:
  description: "tkinter.Frame.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: Frame.__module__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# Widget — base widget class name and module
# ---------------------------------------------------------------------------

invariant tkinter_extra.Widget.name:
  description: "tkinter.Widget.__name__ == 'Widget'"
  category: class_names
  kind: python_call_eq
  function: Widget.__name__.__eq__
  args: ["Widget"]
  expected: true

invariant tkinter_extra.Widget.module:
  description: "tkinter.Widget.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: Widget.__module__.__eq__
  args: ["tkinter"]
  expected: true
