spec: quopri_extra
version: ">=3.9"
backend: python_module(quopri)

docs: https://docs.python.org/3/library/quopri.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/quopri.html — Python quopri module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/quopri.py"
  notes:
    - "This spec extends quopri.zspec.zsdl with function name, module affiliation, and MAXLINESIZE invariants."
    - "quopri.encode(input, output, quotetabs, header=False) encodes a stream in quoted-printable format."
    - "quopri.decode(input, output, header=False) decodes a quoted-printable stream."
    - "quopri.encodestring(s, quotetabs=False, header=False) encodes bytes to quoted-printable bytes."
    - "quopri.decodestring(s, header=False) decodes quoted-printable bytes to plain bytes."
    - "quopri.MAXLINESIZE == 76 — the default maximum line length for QP-encoded output per RFC 2045."
    - "All four public functions are defined in the quopri module (__module__ == 'quopri')."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant quopri_extra.names.encode:
  description: "quopri.encode.__name__ == 'encode'"
  category: names
  kind: python_call_eq
  function: encode.__name__.__eq__
  args: ["encode"]
  expected: true

invariant quopri_extra.names.decode:
  description: "quopri.decode.__name__ == 'decode'"
  category: names
  kind: python_call_eq
  function: decode.__name__.__eq__
  args: ["decode"]
  expected: true

invariant quopri_extra.names.encodestring:
  description: "quopri.encodestring.__name__ == 'encodestring'"
  category: names
  kind: python_call_eq
  function: encodestring.__name__.__eq__
  args: ["encodestring"]
  expected: true

invariant quopri_extra.names.decodestring:
  description: "quopri.decodestring.__name__ == 'decodestring'"
  category: names
  kind: python_call_eq
  function: decodestring.__name__.__eq__
  args: ["decodestring"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — all four public functions belong to quopri
# ---------------------------------------------------------------------------

invariant quopri_extra.module.encode:
  description: "quopri.encode.__module__ == 'quopri'"
  category: module
  kind: python_call_eq
  function: encode.__module__.__eq__
  args: ["quopri"]
  expected: true

invariant quopri_extra.module.decode:
  description: "quopri.decode.__module__ == 'quopri'"
  category: module
  kind: python_call_eq
  function: decode.__module__.__eq__
  args: ["quopri"]
  expected: true

invariant quopri_extra.module.encodestring:
  description: "quopri.encodestring.__module__ == 'quopri'"
  category: module
  kind: python_call_eq
  function: encodestring.__module__.__eq__
  args: ["quopri"]
  expected: true

invariant quopri_extra.module.decodestring:
  description: "quopri.decodestring.__module__ == 'quopri'"
  category: module
  kind: python_call_eq
  function: decodestring.__module__.__eq__
  args: ["quopri"]
  expected: true

# ---------------------------------------------------------------------------
# Callable type checks — all four exports are plain Python functions
# ---------------------------------------------------------------------------

invariant quopri_extra.callable_type.encode:
  description: "quopri.encode.__class__.__name__ == 'function' — encode is a plain Python function"
  category: callable_type
  kind: python_call_eq
  function: encode.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant quopri_extra.callable_type.decode:
  description: "quopri.decode.__class__.__name__ == 'function' — decode is a plain Python function"
  category: callable_type
  kind: python_call_eq
  function: decode.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant quopri_extra.callable_type.encodestring:
  description: "quopri.encodestring.__class__.__name__ == 'function' — encodestring is a plain Python function"
  category: callable_type
  kind: python_call_eq
  function: encodestring.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant quopri_extra.callable_type.decodestring:
  description: "quopri.decodestring.__class__.__name__ == 'function' — decodestring is a plain Python function"
  category: callable_type
  kind: python_call_eq
  function: decodestring.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# MAXLINESIZE — the default maximum line size for QP encoding (RFC 2045 §6.7)
#
# RFC 2045 specifies that encoded lines must be no more than 76 characters
# long (not counting the trailing CRLF). quopri.MAXLINESIZE is the module
# constant that enforces this limit; it equals 76 in all CPython versions.
# ---------------------------------------------------------------------------

invariant quopri_extra.MAXLINESIZE.value:
  description: "quopri.MAXLINESIZE == 76 — the default maximum QP-encoded line length per RFC 2045"
  category: constants
  kind: python_call_eq
  function: MAXLINESIZE.__eq__
  args: [76]
  expected: true

invariant quopri_extra.MAXLINESIZE.is_int:
  description: "quopri.MAXLINESIZE.__class__.__name__ == 'int' — MAXLINESIZE is an integer constant"
  category: constants
  kind: python_call_eq
  function: MAXLINESIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true
