spec: is_integer
version: ">=1.0.7"
backend: node(is-integer)

docs: https://www.npmjs.com/package/is-integer

provenance:
  derived_from:
    - "is-integer README — https://www.npmjs.com/package/is-integer"
    - "Test vectors verified with is-integer via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-integer source"
  notes:
    - "is-integer is an npm package. Install: npm install is-integer"
    - "Returns true if the number has no fractional component."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_integer.check:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: isint

  columns: [id, args, expected]
  rows:
    - [integer,  [5],    true]
    - [float,    [5.5],  false]
    - [zero,     [0],    true]
