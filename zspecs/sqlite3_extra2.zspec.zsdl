spec: sqlite3_extra2
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified by running Python 3.12 sqlite3 module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_sqlite/"
    - "SQLite source: sqlite3.c"
  notes:
    - "This spec provides additional class, hierarchy, and constant invariants for sqlite3."
    - "sqlite3.Connection.__name__ == 'Connection' — class returned by sqlite3.connect()."
    - "sqlite3.Cursor.__name__ == 'Cursor' — class returned by Connection.cursor()."
    - "sqlite3.Row.__name__ == 'Row' — row factory supporting column access by name."
    - "sqlite3.Error.__name__ == 'Error' — base exception for all sqlite3 exceptions."
    - "sqlite3.DatabaseError.__name__ == 'DatabaseError' — subclass of sqlite3.Error."
    - "sqlite3.OperationalError.__name__ == 'OperationalError' — subclass of sqlite3.DatabaseError."
    - "sqlite3.Error.__bases__[0].__name__ == 'Exception' — Error directly subclasses Exception."
    - "sqlite3.sqlite_version.__class__.__name__ == 'str' — library version string."
    - "sqlite3.threadsafety.__class__.__name__ == 'int' — DB-API 2.0 thread safety level."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant sqlite3_extra2.classes.Connection_name:
  description: "sqlite3.Connection.__name__ == 'Connection'"
  category: class_names
  kind: python_call_eq
  function: Connection.__name__.__eq__
  args: ["Connection"]
  expected: true

invariant sqlite3_extra2.classes.Cursor_name:
  description: "sqlite3.Cursor.__name__ == 'Cursor'"
  category: class_names
  kind: python_call_eq
  function: Cursor.__name__.__eq__
  args: ["Cursor"]
  expected: true

invariant sqlite3_extra2.classes.Row_name:
  description: "sqlite3.Row.__name__ == 'Row'"
  category: class_names
  kind: python_call_eq
  function: Row.__name__.__eq__
  args: ["Row"]
  expected: true

invariant sqlite3_extra2.classes.Error_name:
  description: "sqlite3.Error.__name__ == 'Error'"
  category: class_names
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant sqlite3_extra2.classes.DatabaseError_name:
  description: "sqlite3.DatabaseError.__name__ == 'DatabaseError'"
  category: class_names
  kind: python_call_eq
  function: DatabaseError.__name__.__eq__
  args: ["DatabaseError"]
  expected: true

invariant sqlite3_extra2.classes.OperationalError_name:
  description: "sqlite3.OperationalError.__name__ == 'OperationalError'"
  category: class_names
  kind: python_call_eq
  function: OperationalError.__name__.__eq__
  args: ["OperationalError"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy
# sqlite3.Error -> Exception
# ---------------------------------------------------------------------------

invariant sqlite3_extra2.hierarchy.Error_base:
  description: "sqlite3.Error.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Module-level constants — type checks
# ---------------------------------------------------------------------------

invariant sqlite3_extra2.constants.sqlite_version_type:
  description: "sqlite3.sqlite_version.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: sqlite_version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sqlite3_extra2.constants.threadsafety_type:
  description: "sqlite3.threadsafety.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: threadsafety.__class__.__name__.__eq__
  args: ["int"]
  expected: true
