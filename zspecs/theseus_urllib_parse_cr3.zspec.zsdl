spec: theseus_urllib_parse_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_urllib_parse_cr3)
blocks: urllib

docs: https://docs.python.org/3/library/urllib.parse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html"
  notes:
    - "Clean-room extended urllib.parse utilities. Do NOT import urllib."
    - "quote_plus(string): percent-encode with '+' for spaces."
    - "unquote_plus(string): decode percent-encoded string with '+' as space."
    - "urlencode(query): encode dict/list of pairs as application/x-www-form-urlencoded."
    - "urldefrag(url): return (url_without_fragment, fragment) tuple."
    - "urlparse3_quote_plus(): quote_plus('hello world') == 'hello+world'."
    - "urlparse3_unquote_plus(): unquote_plus('hello+world') == 'hello world'."
    - "urlparse3_urlencode(): urlencode({'a':'1','b':'2'}) contains 'a=1'."
    - "Export: quote_plus, unquote_plus, urlencode, urldefrag."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_urllib_parse_cr3.quote_plus:
  description: "quote_plus('hello world') == 'hello+world'"
  category: quote
  kind: python_call_eq
  function: urlparse3_quote_plus
  args: []
  expected: "hello+world"

invariant theseus_urllib_parse_cr3.unquote_plus:
  description: "unquote_plus('hello+world') == 'hello world'"
  category: unquote
  kind: python_call_eq
  function: urlparse3_unquote_plus
  args: []
  expected: "hello world"

invariant theseus_urllib_parse_cr3.urlencode:
  description: "urlencode({'a':'1'}) == 'a=1'"
  category: encode
  kind: python_call_eq
  function: urlparse3_urlencode
  args: []
  expected: "a=1"
