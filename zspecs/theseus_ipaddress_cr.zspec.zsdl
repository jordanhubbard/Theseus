spec: theseus_ipaddress_cr
version: ">=3.8"
backend: python_cleanroom(theseus_ipaddress_cr)
blocks: ipaddress

docs: https://docs.python.org/3/library/ipaddress.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ipaddress.html"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
  notes:
    - "Clean-room ipaddress module. Do NOT import ipaddress."
    - "IPv4Address, IPv6Address, IPv4Network, IPv6Network."

error_model: python_exceptions

invariant theseus_ipaddress_cr.ipaddress2_ipv4:
  description: "IPv4Address parses dotted notation and returns integer"
  category: parsing
  kind: python_call_eq
  function: ipaddress2_ipv4
  args: []
  expected: true

invariant theseus_ipaddress_cr.ipaddress2_ipv6:
  description: "IPv6Address parses colon notation"
  category: parsing
  kind: python_call_eq
  function: ipaddress2_ipv6
  args: []
  expected: true

invariant theseus_ipaddress_cr.ipaddress2_network:
  description: "IPv4Network parses CIDR notation and checks membership"
  category: behavior
  kind: python_call_eq
  function: ipaddress2_network
  args: []
  expected: true
