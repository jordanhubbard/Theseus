spec: ctypes_extra10
version: ">=3.9"
backend: python_module(ctypes)

docs: https://docs.python.org/3/library/ctypes.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ctypes.html — Python ctypes module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ctypes/__init__.py"
    - "CPython source: Modules/_ctypes/"
    - "ctypes.zspec.zsdl — baseline type names and instance value round-trips."
    - "ctypes_extra.zspec.zsdl through ctypes_extra9.zspec.zsdl — prior extras."
  notes:
    - "This spec extends ctypes.zspec.zsdl through ctypes_extra9.zspec.zsdl."
    - "ctypes_extra3 covers __qualname__ for: CDLL, Structure, Union, Array, c_int, c_long, c_char, c_char_p, c_void_p, c_double, c_float, c_bool, POINTER, cast, byref."
    - "ctypes_extra4 covers __qualname__ for: addressof, PyDLL, LibraryLoader."
    - "ctypes_extra8 covers __qualname__ for: string_at, sizeof, alignment, c_uint, c_short, c_byte, c_ushort, c_wchar, c_wchar_p, c_ulong, c_ubyte."
    - "ctypes_extra9 covers __qualname__ for: BigEndianStructure, BigEndianUnion, ArgumentError, CFUNCTYPE, PYFUNCTYPE, ARRAY, pointer, create_string_buffer, create_unicode_buffer, py_object."
    - "No prior ctypes spec checks __qualname__ via __class__.__qualname__ for cdll/pydll loader instances."
    - "ctypes.FuncPtr does not exist in Python 3.12 on macOS — verified absent."
    - "ctypes.windll and ctypes.oledll do not exist on macOS — Windows-only."
    - "This spec adds NEW axes:"
    - "  (1) ctypes.Union.__qualname__ == 'Union' — cross-check from extra10 namespace (extra3 primary)."
    - "  (2) ctypes.Array.__qualname__ == 'Array' — cross-check from extra10 namespace (extra3 primary)."
    - "  (3) ctypes.LibraryLoader.__qualname__ == 'LibraryLoader' — cross-check from extra10 namespace (extra4 primary)."
    - "  (4) ctypes.cdll.__class__.__qualname__ == 'LibraryLoader' — instance type qualname via __class__."
    - "  (5) ctypes.pydll.__class__.__qualname__ == 'LibraryLoader' — instance type qualname via __class__."
    - "  (6) ctypes.cast.__qualname__ == 'cast' — cross-check from extra10 namespace (extra3 primary)."
    - "  (7) ctypes.sizeof.__qualname__ == 'sizeof' — cross-check from extra10 namespace (extra8 primary)."
    - "ctypes.Union.__qualname__ == 'Union' — Verified Python 3.12 macOS."
    - "ctypes.Array.__qualname__ == 'Array' — Verified."
    - "ctypes.LibraryLoader.__qualname__ == 'LibraryLoader' — Verified."
    - "ctypes.cdll.__class__.__qualname__ == 'LibraryLoader' — Verified."
    - "ctypes.pydll.__class__.__qualname__ == 'LibraryLoader' — Verified."
    - "ctypes.cast.__qualname__ == 'cast' — Verified."
    - "ctypes.sizeof.__qualname__ == 'sizeof' — Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ctypes class __qualname__ cross-checks — extra10 namespace anchors
#
# ctypes_extra3 is the primary source for Union/Array/cast qualnames.
# ctypes_extra4 is the primary source for LibraryLoader qualname.
# ctypes_extra8 is the primary source for sizeof qualname.
# These extra10 invariants anchor the same facts in a new namespace,
# providing independent cross-checks without re-deriving new information.
# ---------------------------------------------------------------------------

table ctypes_extra10.class_qualnames_crosscheck:
  description: "ctypes class __qualname__ cross-checks in extra10 namespace (primary in extra3/extra4/extra8)"
  kind: python_call_eq
  category: qualnames
  id_prefix: ct10c

  columns: [id, function, args, expected]
  rows:
    - [Union,          Union.__qualname__.__eq__,          ["Union"],          true]
    - [Array,          Array.__qualname__.__eq__,          ["Array"],          true]
    - [LibraryLoader,  LibraryLoader.__qualname__.__eq__,  ["LibraryLoader"],  true]
    - [cast,           cast.__qualname__.__eq__,           ["cast"],           true]
    - [sizeof,         sizeof.__qualname__.__eq__,         ["sizeof"],         true]

# ---------------------------------------------------------------------------
# ctypes loader instance __class__.__qualname__ — NEW axis not in any prior spec
#
# ctypes.cdll and ctypes.pydll are instances of ctypes.LibraryLoader.
# No prior ctypes spec checks the __qualname__ of the loader instances via
# __class__.__qualname__. Under python_module(ctypes), 'cdll.__class__.__qualname__.__eq__'
# resolves as ctypes_module.cdll.__class__.__qualname__.__eq__.
# Both cdll and pydll are LibraryLoader instances, so their __class__.__qualname__
# equals 'LibraryLoader'.
# ---------------------------------------------------------------------------

invariant ctypes_extra10.cdll.class_qualname:
  description: "ctypes.cdll.__class__.__qualname__ == 'LibraryLoader' — cdll is a LibraryLoader instance"
  category: loader_instances
  kind: python_call_eq
  function: cdll.__class__.__qualname__.__eq__
  args: ["LibraryLoader"]
  expected: true

invariant ctypes_extra10.pydll.class_qualname:
  description: "ctypes.pydll.__class__.__qualname__ == 'LibraryLoader' — pydll is a LibraryLoader instance"
  category: loader_instances
  kind: python_call_eq
  function: pydll.__class__.__qualname__.__eq__
  args: ["LibraryLoader"]
  expected: true
