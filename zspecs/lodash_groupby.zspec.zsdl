spec: lodash_groupby
version: ">=4.0.0"
backend: node(lodash.groupby)

docs: https://lodash.com/docs/#groupBy

provenance:
  derived_from:
    - "lodash.groupby README — https://www.npmjs.com/package/lodash.groupby"
    - "Test vectors verified with lodash.groupby@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.groupby exports the _.groupBy function directly as module.exports."
    - "groupBy(collection, iteratee) creates an object grouping elements by iteratee result."
    - "String iteratee plucks a property to use as the group key."
    - "Keys are always strings in the resulting object."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns object mapping group keys to arrays of elements."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_groupby.groupby:
  kind: node_module_call_eq
  function: ~
  category: groupby
  id_prefix: lgby

  columns: [id, args, expected]
  rows:
    - [by_type,
       [[{"type": "a", "n": 1}, {"type": "b", "n": 2}, {"type": "a", "n": 3}], "type"],
       {"a": [{"type": "a", "n": 1}, {"type": "a", "n": 3}], "b": [{"type": "b", "n": 2}]}]
    - [by_len,
       [["one", "two", "four", "six"], "length"],
       {"3": ["one", "two", "six"], "4": ["four"]}]
