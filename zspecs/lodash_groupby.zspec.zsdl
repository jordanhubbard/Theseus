spec: lodash_groupby
version: ">=4.0.0"
backend: node(lodash.groupby)

docs: https://lodash.com/docs/#groupBy

provenance:
  derived_from:
    - "lodash.groupby README — https://www.npmjs.com/package/lodash.groupby"
    - "Test vectors verified with lodash.groupby@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.groupby exports the _.groupBy function directly as module.exports."
    - "groupBy(collection, key) creates an object with keys being the grouped values."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns grouped object. No errors for array inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_groupby.group:
  kind: node_module_call_eq
  function: ~
  category: group
  id_prefix: lgroupby

  columns: [id, args, expected]
  rows:
    - [by_key,  [[{"t": 1, "n": "a"}, {"t": 2, "n": "b"}, {"t": 1, "n": "c"}], "t"],
       {"1": [{"t": 1, "n": "a"}, {"t": 1, "n": "c"}], "2": [{"t": 2, "n": "b"}]}]
