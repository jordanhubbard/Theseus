spec: th2926
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 642 (th2926): __iand__, __ior__, __ixor__ dict-presence checks for threading types."
    - "threading types are synchronization primitives and thread management classes — none define in-place bitwise AND, OR, or XOR operators."
    - "Verified types: threading.Thread, threading.Lock (type), threading.RLock (type), threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Event, threading.Timer, threading.Barrier, threading.local."
    - "threading.Lock and threading.RLock are factory functions; their types are accessed via type(threading.Lock()) and type(threading.RLock())."
    - "threading.Timer is a Thread subclass used for delayed execution."
    - "threading.local is the thread-local storage class."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th2926.iand:
  description: "threading types __iand__ dict-presence checks; wave 642"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2926
  columns: [id, function, args, expected]
  rows:
    - ["th2926001", operator.contains, [threading.Thread.__dict__,           "__iand__"], false]
    - ["th2926002", operator.contains, [threading.Condition.__dict__,        "__iand__"], false]
    - ["th2926003", operator.contains, [threading.Semaphore.__dict__,        "__iand__"], false]
    - ["th2926004", operator.contains, [threading.BoundedSemaphore.__dict__, "__iand__"], false]
    - ["th2926005", operator.contains, [threading.Event.__dict__,            "__iand__"], false]
    - ["th2926006", operator.contains, [threading.Barrier.__dict__,          "__iand__"], false]

