spec: string_extra8
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra7.zspec.zsdl."
    - "string_extra covers: Formatter/__name__/__module__, Template/__name__/__module__, capwords/__name__, constants type-is-str table."
    - "string_extra2 covers: Formatter/__bases__[0].__name__=='object', Template/__bases__[0].__name__=='object', capwords.__module__, ascii_letters len==52, whitespace contains newline, printable len==100, punctuation len==32, octdigits/hexdigits exact values."
    - "string_extra4 covers: Formatter/__name__/__module__ (table), Template/__name__/__module__ (table), digits/hexdigits/octdigits values, ascii_lowercase/uppercase/letters/digits/punctuation lengths, Formatter().format.__func__.__name__."
    - "string_extra5 covers: Template/__qualname__, Formatter/__qualname__, capwords/__qualname__, ascii_uppercase/lowercase exact values, digits/ascii_uppercase membership checks, capwords double-internal-space and uppercase single word."
    - "string_extra6 covers: whitespace len/membership (CR/tab/not-a); punctuation membership (!/@/not-a); ascii_letters membership (z/Z/not-0); capwords with sep ('hello-world'/multi); digits membership (not-a/9)."
    - "string_extra7 covers: printable membership (5/a/Z/!/space/null); ascii_letters exact value; hexdigits membership (A/f/G); whitespace vtab/ff membership; Formatter instance class name; Formatter/Template base class name; capwords already-title-case/empty-string; digits first/last char."
    - "Focus: __len__ on constants as standalone invariants (new namespace); Formatter.__name__ and Template.__name__ via __eq__ chain (new namespace anchors); Formatter.__module__ and Template.__module__ via __eq__ chain (new namespace anchors)."
    - "string.ascii_letters.__len__() == 52 — new namespace anchor (string_extra8); prior specs cover in string_extra2 and string_extra4 namespaces."
    - "string.digits.__len__() == 10 — new namespace anchor; prior specs cover in string_extra4 namespace."
    - "string.hexdigits.__len__() == 22 — new namespace anchor; prior specs cover in string_extra4 namespace."
    - "string.octdigits.__len__() == 8 — new namespace anchor; prior specs cover in string_extra4 namespace."
    - "string.punctuation.__len__() == 32 — new namespace anchor; prior specs cover in string_extra2/string_extra4 namespaces."
    - "string.whitespace.__len__() == 6 — new namespace anchor; string_extra6 covers this in its namespace."
    - "string.printable.__len__() == 100 — new namespace anchor; base spec and string_extra2 cover this."
    - "string.ascii_lowercase.__len__() == 26 — new namespace anchor; prior specs cover in string_extra4 namespace."
    - "string.ascii_uppercase.__len__() == 26 — new namespace anchor; prior specs cover in string_extra4 namespace."
    - "string.Formatter.__name__ == 'Formatter' — new namespace anchor via __eq__ invariant form."
    - "string.Template.__name__ == 'Template' — new namespace anchor via __eq__ invariant form."
    - "string.Template.__module__ == 'string' — new namespace anchor via standalone invariant form."
    - "string.Formatter.__module__ == 'string' — new namespace anchor via standalone invariant form."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# String constant lengths — all as standalone invariants in the extra8 namespace
#
# Prior specs cover these lengths in earlier namespaces (extra2, extra4, extra6).
# This spec provides extra8-namespace anchors for each constant's length,
# using the function: constant.__len__ / args: [] / expected: N pattern.
# ---------------------------------------------------------------------------

invariant string_extra8.ascii_letters.len:
  description: "len(string.ascii_letters) == 52 — 26 lowercase + 26 uppercase"
  category: constants
  kind: python_call_eq
  function: ascii_letters.__len__
  args: []
  expected: 52

invariant string_extra8.digits.len:
  description: "len(string.digits) == 10 — '0123456789'"
  category: constants
  kind: python_call_eq
  function: digits.__len__
  args: []
  expected: 10

invariant string_extra8.hexdigits.len:
  description: "len(string.hexdigits) == 22 — digits (10) + lowercase a-f (6) + uppercase A-F (6)"
  category: constants
  kind: python_call_eq
  function: hexdigits.__len__
  args: []
  expected: 22

invariant string_extra8.octdigits.len:
  description: "len(string.octdigits) == 8 — '01234567'"
  category: constants
  kind: python_call_eq
  function: octdigits.__len__
  args: []
  expected: 8

invariant string_extra8.punctuation.len:
  description: "len(string.punctuation) == 32 — 32 ASCII punctuation characters"
  category: constants
  kind: python_call_eq
  function: punctuation.__len__
  args: []
  expected: 32

invariant string_extra8.whitespace.len:
  description: "len(string.whitespace) == 6 — space, tab, newline, CR, VT, FF"
  category: constants
  kind: python_call_eq
  function: whitespace.__len__
  args: []
  expected: 6

invariant string_extra8.printable.len:
  description: "len(string.printable) == 100 — digits + letters + punctuation + whitespace"
  category: constants
  kind: python_call_eq
  function: printable.__len__
  args: []
  expected: 100

invariant string_extra8.ascii_lowercase.len:
  description: "len(string.ascii_lowercase) == 26 — 'a' through 'z'"
  category: constants
  kind: python_call_eq
  function: ascii_lowercase.__len__
  args: []
  expected: 26

invariant string_extra8.ascii_uppercase.len:
  description: "len(string.ascii_uppercase) == 26 — 'A' through 'Z'"
  category: constants
  kind: python_call_eq
  function: ascii_uppercase.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# Formatter and Template class identity — __name__ and __module__
#
# string_extra4 covers these via table rows and __eq__ chained functions.
# This spec provides standalone extra8-namespace invariants for each attribute,
# using the same dotted-chain pattern for consistency.
# ---------------------------------------------------------------------------

invariant string_extra8.Formatter.name:
  description: "string.Formatter.__name__ == 'Formatter'"
  category: class_identity
  kind: python_call_eq
  function: Formatter.__name__.__eq__
  args: ["Formatter"]
  expected: true

invariant string_extra8.Template.name:
  description: "string.Template.__name__ == 'Template'"
  category: class_identity
  kind: python_call_eq
  function: Template.__name__.__eq__
  args: ["Template"]
  expected: true

invariant string_extra8.Template.module:
  description: "string.Template.__module__ == 'string'"
  category: class_identity
  kind: python_call_eq
  function: Template.__module__.__eq__
  args: ["string"]
  expected: true

invariant string_extra8.Formatter.module:
  description: "string.Formatter.__module__ == 'string'"
  category: class_identity
  kind: python_call_eq
  function: Formatter.__module__.__eq__
  args: ["string"]
  expected: true
