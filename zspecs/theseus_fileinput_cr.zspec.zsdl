spec: theseus_fileinput_cr
version: ">=3.8"
backend: python_cleanroom(theseus_fileinput_cr)
blocks: fileinput

docs: https://docs.python.org/3/library/fileinput.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/fileinput.html"
  not_derived_from:
    - "CPython source: Lib/fileinput.py"
  notes:
    - "Clean-room fileinput module. Do NOT import fileinput."

error_model: python_exceptions

invariant theseus_fileinput_cr.fileinput2_lines:
  description: "FileInput iterates lines from a temp file"
  category: behavior
  kind: python_call_eq
  function: fileinput2_lines
  args: []
  expected: true

invariant theseus_fileinput_cr.fileinput2_lineno:
  description: "lineno() returns the cumulative line number"
  category: behavior
  kind: python_call_eq
  function: fileinput2_lineno
  args: []
  expected: true

invariant theseus_fileinput_cr.fileinput2_filename:
  description: "filename() returns the current file name"
  category: behavior
  kind: python_call_eq
  function: fileinput2_filename
  args: []
  expected: true
