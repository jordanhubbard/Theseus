spec: itertools_extra93
version: ">=3.9"
backend: python_module(itertools)
extends: itertools_extra92

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra92.zspec.zsdl."
    - "This spec covers: itertools C-type __qualname__ equality — all itertools types have __qualname__ equal to their class name (Wave 253)."
    - "itertools.chain.__qualname__ == 'chain' (len 5). Verified with Python 3.14.3."
    - "itertools.product.__qualname__ == 'product' (len 7). Verified with Python 3.14.3."
    - "itertools.combinations.__qualname__ == 'combinations' (len 12). Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement' (len 29). Verified with Python 3.14.3."
    - "itertools.permutations.__qualname__ == 'permutations' (len 12). Verified with Python 3.14.3."
    - "itertools.accumulate.__qualname__ == 'accumulate' (len 10). Verified with Python 3.14.3."
    - "itertools.groupby.__qualname__ == 'groupby' (len 7). Verified with Python 3.14.3."
    - "itertools.islice.__qualname__ == 'islice' (len 6). Verified with Python 3.14.3."
    - "itertools.starmap.__qualname__ == 'starmap' (len 7). Verified with Python 3.14.3."
    - "itertools.filterfalse.__qualname__ == 'filterfalse' (len 11). Verified with Python 3.14.3."
    - "itertools.takewhile.__qualname__ == 'takewhile' (len 9). Verified with Python 3.14.3."
    - "itertools.dropwhile.__qualname__ == 'dropwhile' (len 9). Verified with Python 3.14.3."
    - "itertools.count.__qualname__ == 'count' (len 5). Verified with Python 3.14.3."
    - "itertools.repeat.__qualname__ == 'repeat' (len 6). Verified with Python 3.14.3."
    - "itertools.cycle.__qualname__ == 'cycle' (len 5). Verified with Python 3.14.3."
    - "itertools.compress.__qualname__ == 'compress' (len 8). Verified with Python 3.14.3."
    - "itertools.pairwise.__qualname__ == 'pairwise' (len 8). Verified with Python 3.14.3."
    - "itertools.zip_longest.__qualname__ == 'zip_longest' (len 11). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: chain/product/combinations/combinations_with_replacement/permutations
#
# Wave 253 theme: itertools C-type __qualname__ equals class name — group 1.
#
# itertools.chain.__qualname__.__eq__('chain') == True
# itertools.product.__qualname__.__eq__('product') == True
# itertools.combinations.__qualname__.__eq__('combinations') == True
# itertools.combinations_with_replacement.__qualname__.__eq__('combinations_with_replacement') == True
# itertools.permutations.__qualname__.__eq__('permutations') == True
#
# C extension types defined at module scope have __qualname__ equal to their simple class name.
# Prior spec extra92 checked __module__; this spec (extra93) checks __qualname__. New to extra93.
# ---------------------------------------------------------------------------

table itertools_extra93.qualname_eq_group1:
  description: "chain/product/combinations/combinations_with_replacement/permutations __qualname__ equals class name; C types in itertoolsmodule.c; wave 253; new to extra93"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsqualname93

  columns: [id, function, args, expected, description]
  rows:
    - [chain_qualname_eq_chain,
       "chain.__qualname__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__qualname__.__eq__('chain') == True — chain is a C extension type defined at module scope in Modules/itertoolsmodule.c; C types defined at module scope have __qualname__ equal to their simple name; __qualname__ is 'chain'; str.__eq__('chain') returns True; prior spec extra92 checked __module__; this spec (extra93) checks __qualname__; new to extra93"]
    - [product_qualname_eq_product,
       "product.__qualname__.__eq__",
       ["product"],
       true,
       "itertools.product.__qualname__.__eq__('product') == True — product is a C extension type; __qualname__ is 'product'; str.__eq__('product') returns True; new to extra93"]
    - [combinations_qualname_eq_combinations,
       "combinations.__qualname__.__eq__",
       ["combinations"],
       true,
       "itertools.combinations.__qualname__.__eq__('combinations') == True — combinations is a C extension type; __qualname__ is 'combinations'; str.__eq__('combinations') returns True; new to extra93"]
    - ["combinations_with_replacement_qualname_eq",
       "combinations_with_replacement.__qualname__.__eq__",
       ["combinations_with_replacement"],
       true,
       "itertools.combinations_with_replacement.__qualname__.__eq__('combinations_with_replacement') == True — combinations_with_replacement is a C extension type; __qualname__ is 'combinations_with_replacement' (len 29); str.__eq__('combinations_with_replacement') returns True; new to extra93"]
    - [permutations_qualname_eq_permutations,
       "permutations.__qualname__.__eq__",
       ["permutations"],
       true,
       "itertools.permutations.__qualname__.__eq__('permutations') == True — permutations is a C extension type; __qualname__ is 'permutations'; str.__eq__('permutations') returns True; new to extra93"]

