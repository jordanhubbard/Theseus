spec: itertools_extra2176
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
    - "itertools_extra2161.zspec.zsdl — covers fget/fset/fdel and __objclass__/__func__ dict-presence, class name checks"
  notes:
    - "Wave 2176 (_extra2176): iterator/sequence protocol dict-presence theme — __iter__, __next__, __aiter__, __anext__, __await__, __length_hint__, __reversed__, __missing__."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All itertools C-extension iterator types define both __iter__ and __next__ in their own __dict__ — they are proper Python iterators (self-iterating)."
    - "None of the itertools C types define __aiter__ or __anext__ — they are synchronous-only iterators with no async support."
    - "None of the itertools C types define __await__ — they are not awaitable."
    - "Only itertools.repeat defines __length_hint__ in its own __dict__ — it is the sole itertools type with a size hint. All others return False."
    - "None of the itertools C types define __reversed__ in their own __dict__ — they are forward-only iterators."
    - "None of the itertools C types define __missing__ in their own __dict__ — they are not dict subclasses."
    - "itertools.chain.__iter__ and itertools.chain.__next__ are slot_wrapper objects (C-level slot wrappers)."
    - "itertools.repeat.__length_hint__ is a method_descriptor that returns the count of remaining repetitions when the repeat count is finite."
  created_at: "2026-04-12"
error_model: python_exceptions

table itertools_extra2176.iter_next_core:
  description: "itertools core C-types __iter__ and __next__ dict-presence — both true for all iterator types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2176
  columns: [id, function, args, expected]
  rows:
    - ["it2176001", "itertools.chain.__dict__.__contains__",        ["__iter__"],  true]
    - ["it2176002", "itertools.chain.__dict__.__contains__",        ["__next__"],  true]
    - ["it2176003", "itertools.cycle.__dict__.__contains__",        ["__iter__"],  true]
    - ["it2176004", "itertools.cycle.__dict__.__contains__",        ["__next__"],  true]
    - ["it2176005", "itertools.count.__dict__.__contains__",        ["__iter__"],  true]
    - ["it2176006", "itertools.count.__dict__.__contains__",        ["__next__"],  true]
    - ["it2176007", "itertools.islice.__dict__.__contains__",       ["__iter__"],  true]
    - ["it2176008", "itertools.islice.__dict__.__contains__",       ["__next__"],  true]
    - ["it2176009", "itertools.repeat.__dict__.__contains__",       ["__iter__"],  true]
    - ["it2176010", "itertools.repeat.__dict__.__contains__",       ["__next__"],  true]

