spec: struct_extra1651
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic (for float/double format strings)"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
    - "CPython source: Modules/_struct.c"
  notes:
    - "behavioral invariants for __init_subclass__, __set_name__, and __class_getitem__ class creation and parameterization protocol"
    - "struct.Struct is a C extension type; it does not define __init_subclass__ in its own __dict__ — inherited from object."
    - "struct.error is a Python exception class (subclass of Exception); it also lacks __init_subclass__ in its own __dict__."
    - "Neither struct.Struct nor struct.error defines __set_name__ — they are not descriptors."
    - "struct.Struct does not define __class_getitem__ — it is not a generic container type."
    - "struct.error does not define __class_getitem__ — exception classes do not support generic parameterization."
    - "object.__init_subclass__ is always present as the universal no-op fallback hook."
    - "calcsize format characters are platform-independent when an explicit byte-order prefix is given (>, <, !, =)."
    - "Without a prefix, native size and alignment apply; this table uses bare format chars for native-size results (c=1, b=1, B=1, h=2, H=2, i=4, I=4, q=8, Q=8, f=4, d=8 — guaranteed on all supported platforms)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: struct.Struct and struct.error do not define __init_subclass__,
# __set_name__, or __class_getitem__ in their own __dict__.
#
# struct.Struct is a C extension type; struct.error is a Python class that
# inherits from Exception. Neither defines these class-creation hooks because
# neither is intended to be subclassed in the ABC/generic sense. The default
# __init_subclass__ lives on object and is inherited via the MRO.
# ---------------------------------------------------------------------------

table struct_extra1651.no_init_subclass:
  description: "struct.Struct and struct.error do not define __init_subclass__, __set_name__, or __class_getitem__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1651

  columns: [id, function, args, expected]
  rows:
    - ["st1651001", "Struct.__dict__.__contains__", ["__init_subclass__"], false]
    - ["st1651002", "error.__dict__.__contains__",  ["__init_subclass__"], false]
    - ["st1651003", "Struct.__dict__.__contains__", ["__class_getitem__"], false]
    - ["st1651004", "error.__dict__.__contains__",  ["__class_getitem__"], false]
    - ["st1651005", "Struct.__dict__.__contains__", ["__set_name__"],      false]
    - ["st1651006", "error.__dict__.__contains__",  ["__set_name__"],      false]
    - ["st1651007", "object.__dict__.__contains__", ["__init_subclass__"], true]
    - ["st1651008", "object.__dict__.__contains__", ["__class_getitem__"], false]
    - ["st1651009", "object.__dict__.__contains__", ["__set_name__"],      false]
    - ["st1651010", "Struct.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["st1651011", "error.__dict__.__contains__",  ["__subclasshook__"],  false]
    - ["st1651012", "Struct.__dict__.__contains__", ["pack"],              true]
    - ["st1651013", "Struct.__dict__.__contains__", ["unpack"],            true]
    - ["st1651014", "Struct.__dict__.__contains__", ["pack_into"],         true]
    - ["st1651015", "Struct.__dict__.__contains__", ["unpack_from"],       true]
    - ["st1651016", "Struct.__dict__.__contains__", ["iter_unpack"],       true]
    - ["st1651017", "Struct.__dict__.__contains__", ["format"],            true]
    - ["st1651018", "Struct.__dict__.__contains__", ["size"],              true]
    - ["st1651019", "Struct.__name__.__eq__",        ["Struct"],           true]
    - ["st1651020", "error.__name__.__eq__",         ["error"],            true]
    - ["st1651021", "Struct.__bases__.__getitem__",  [0],                  "object"]
    - ["st1651022", "error.__bases__.__getitem__",   [0],                  "Exception"]
    - ["st1651023", "Struct.__dict__.__contains__", ["__doc__"],           true]
    - ["st1651024", "error.__dict__.__contains__",  ["__doc__"],           false]
    - ["st1651025", "Struct.__module__.__eq__",      ["_struct"],          true]

# ---------------------------------------------------------------------------
# Table 2: struct module-level attribute presence
#
# The struct module exports pack, unpack, pack_into, unpack_from, iter_unpack,
# calcsize, Struct, and error as top-level module attributes. We verify their
# presence and absence of class-creation protocol hooks at module level.
# ---------------------------------------------------------------------------

table struct_extra1651.module_attr_presence:
  description: "struct module-level attributes are present in struct.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1651

  columns: [id, function, args, expected]
  rows:
    - ["st1651026", "__dict__.__contains__", ["pack"],             true]
    - ["st1651027", "__dict__.__contains__", ["unpack"],           true]
    - ["st1651028", "__dict__.__contains__", ["pack_into"],        true]
    - ["st1651029", "__dict__.__contains__", ["unpack_from"],      true]
    - ["st1651030", "__dict__.__contains__", ["iter_unpack"],      true]
    - ["st1651031", "__dict__.__contains__", ["calcsize"],         true]
    - ["st1651032", "__dict__.__contains__", ["Struct"],           true]
    - ["st1651033", "__dict__.__contains__", ["error"],            true]
    - ["st1651034", "__dict__.__contains__", ["__name__"],         true]
    - ["st1651035", "__dict__.__contains__", ["__doc__"],          true]
    - ["st1651036", "__dict__.__contains__", ["__init_subclass__"], false]
    - ["st1651037", "__dict__.__contains__", ["__set_name__"],     false]
    - ["st1651038", "__dict__.__contains__", ["__class_getitem__"], false]
    - ["st1651039", "__dict__.__contains__", ["pack_into"],        true]
    - ["st1651040", "__dict__.__contains__", ["iter_unpack"],      true]
    - ["st1651041", "__dict__.__contains__", ["calcsize"],         true]
    - ["st1651042", "__dict__.__contains__", ["Struct"],           true]
    - ["st1651043", "__dict__.__contains__", ["error"],            true]
    - ["st1651044", "__dict__.__contains__", ["unpack_from"],      true]
    - ["st1651045", "__dict__.__contains__", ["pack"],             true]
    - ["st1651046", "__dict__.__contains__", ["__spec__"],         true]
    - ["st1651047", "__dict__.__contains__", ["__loader__"],       true]
    - ["st1651048", "__dict__.__contains__", ["_clearcache"],      false]
    - ["st1651049", "__dict__.__contains__", ["__all__"],          false]
    - ["st1651050", "__dict__.__contains__", ["__file__"],         false]

# ---------------------------------------------------------------------------
# Table 3: struct.calcsize for standard format characters
#
# calcsize returns the size in bytes that struct.pack would produce for the
# given format string. Using bare (no prefix) format characters gives the
# native size, which is standardized for these types on all CPython platforms:
# c=1, b=1, B=1, h=2, H=2, i=4, I=4, q=8, Q=8, f=4, d=8.
# Using '>' prefix forces big-endian standard sizes (same as bare for these).
# ---------------------------------------------------------------------------

table struct_extra1651.calcsize_format_chars:
  description: "struct.calcsize returns correct byte sizes for standard primitive format characters"
  kind: python_call_eq
  category: calcsize
  id_prefix: st1651

  columns: [id, function, args, expected]
  rows:
    - ["st1651051", "calcsize", [">c"],  1]
    - ["st1651052", "calcsize", [">b"],  1]
    - ["st1651053", "calcsize", [">B"],  1]
    - ["st1651054", "calcsize", [">h"],  2]
    - ["st1651055", "calcsize", [">H"],  2]
    - ["st1651056", "calcsize", [">i"],  4]
    - ["st1651057", "calcsize", [">I"],  4]
    - ["st1651058", "calcsize", [">q"],  8]
    - ["st1651059", "calcsize", [">Q"],  8]
    - ["st1651060", "calcsize", [">f"],  4]
    - ["st1651061", "calcsize", [">d"],  8]
    - ["st1651062", "calcsize", [">?"],  1]
    - ["st1651063", "calcsize", [">e"],  2]
    - ["st1651064", "calcsize", [">s"],  1]
    - ["st1651065", "calcsize", [">2s"], 2]
    - ["st1651066", "calcsize", [">4s"], 4]
    - ["st1651067", "calcsize", [">BH"], 3]
    - ["st1651068", "calcsize", [">HI"], 6]
    - ["st1651069", "calcsize", [">BHI"], 7]
    - ["st1651070", "calcsize", [">HIQ"], 14]
    - ["st1651071", "calcsize", [">bB"], 2]
    - ["st1651072", "calcsize", [">hH"], 4]
    - ["st1651073", "calcsize", [">iI"], 8]
    - ["st1651074", "calcsize", [">qQ"], 16]
    - ["st1651075", "calcsize", [">fd"], 12]
