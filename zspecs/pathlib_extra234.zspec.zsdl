spec: pathlib_extra234
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec covers: pathlib.PurePosixPath and PureWindowsPath additional contracts — parts length/indexing, truediv join, with_name, with_suffix."
    - "PurePosixPath('/a/b/c').parts has length 4: ('/', 'a', 'b', 'c') — root '/' is the first element; verified Python 3.14.3 macOS."
    - "PurePosixPath('/a/b/c').parts[0] == '/' — first element is the root; verified Python 3.14.3 macOS."
    - "PurePosixPath('a/b.txt').parts has length 2: ('a', 'b.txt') — relative path has no root element; verified Python 3.14.3 macOS."
    - "str(PurePosixPath('/a') / 'b') == '/a/b' — / operator joins path components; verified Python 3.14.3 macOS."
    - "PurePosixPath('/a/b').with_name('c.txt').__str__() == '/a/c.txt' — replaces final component; verified Python 3.14.3 macOS."
    - "PurePosixPath('/a/b.txt').with_suffix('.py').__str__() == '/a/b.py' — replaces suffix; verified Python 3.14.3 macOS."
    - "PureWindowsPath('C:/a/b').parts has length 3: ('C:\\\\', 'a', 'b') — root includes drive+backslash; verified Python 3.14.3 macOS."
    - "PureWindowsPath('C:/a/b').drive == 'C:' — drive letter without separator; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath parts behavioral contracts
# PurePosixPath('/a/b/c').parts == ('/', 'a', 'b', 'c') — length 4, [0] == '/'.
# PurePosixPath('a/b.txt').parts == ('a', 'b.txt') — length 2, no root element.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra234.PurePosixPath.parts_abc_len:
  description: "pathlib.PurePosixPath('/a/b/c').parts.__len__() == 4 — absolute path parts include root '/' as first element giving ('/', 'a', 'b', 'c'); verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: parts.__len__
  expected: 4

invariant pathlib_extra234.PurePosixPath.parts_abc_first:
  description: "pathlib.PurePosixPath('/a/b/c').parts[0] == '/' — first element of an absolute path's parts tuple is the root '/'; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: "parts.__getitem__"
  method_args: [0]
  expected: "/"

invariant pathlib_extra234.PurePosixPath.parts_relative_len:
  description: "pathlib.PurePosixPath('a/b.txt').parts.__len__() == 2 — relative path has no root component so parts is ('a', 'b.txt'), length 2; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["a/b.txt"]
  method: parts.__len__
  expected: 2

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath / (truediv) join behavioral contracts
# PurePosixPath('/a') / 'b' produces PurePosixPath('/a/b').
# str() of result == '/a/b'.
# Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra234.PurePosixPath.truediv_join:
  description: "str(pathlib.PurePosixPath('/a') / 'b') == '/a/b' — truediv operator joins path segments; result is PurePosixPath('/a/b'); verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a"]
  method: __truediv__
  method_args: ["b"]
  method_chain: __str__
  expected: "/a/b"

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath with_name and with_suffix behavioral contracts
# with_name replaces the final path component entirely.
# with_suffix replaces only the suffix (extension) of the final component.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra234.PurePosixPath.with_name_ctxt:
  description: "pathlib.PurePosixPath('/a/b').with_name('c.txt').__str__() == '/a/c.txt' — with_name replaces the final component 'b' with 'c.txt'; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b"]
  method: with_name
  method_args: ["c.txt"]
  method_chain: __str__
  expected: "/a/c.txt"

invariant pathlib_extra234.PurePosixPath.with_suffix_py:
  description: "pathlib.PurePosixPath('/a/b.txt').with_suffix('.py').__str__() == '/a/b.py' — with_suffix replaces .txt with .py in the final component; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b.txt"]
  method: with_suffix
  method_args: [".py"]
  method_chain: __str__
  expected: "/a/b.py"

invariant pathlib_extra234.PurePosixPath.with_suffix_empty:
  description: "pathlib.PurePosixPath('/a/b.txt').with_suffix('').__str__() == '/a/b' — with_suffix('') removes the extension entirely; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b.txt"]
  method: with_suffix
  method_args: [""]
  method_chain: __str__
  expected: "/a/b"

# ---------------------------------------------------------------------------
# pathlib.PureWindowsPath parts and drive behavioral contracts
# PureWindowsPath('C:/a/b').parts has 3 elements: ('C:\\', 'a', 'b').
# drive property returns 'C:' (drive letter without separator).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra234.PureWindowsPath.parts_len:
  description: "pathlib.PureWindowsPath('C:/a/b').parts.__len__() == 3 — Windows path parts are ('C:\\\\', 'a', 'b') where drive+root is one element; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PureWindowsPath
  args: ["C:/a/b"]
  method: parts.__len__
  expected: 3

invariant pathlib_extra234.PureWindowsPath.drive:
  description: "pathlib.PureWindowsPath('C:/a/b').drive == 'C:' — drive property returns the drive letter with colon, no separator; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PureWindowsPath
  args: ["C:/a/b"]
  method: drive.__eq__
  method_args: ["C:"]
  expected: true

invariant pathlib_extra234.PureWindowsPath.parts_second:
  description: "pathlib.PureWindowsPath('C:/a/b').parts[1] == 'a' — second element of Windows path parts is first directory component after root; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: PureWindowsPath
  args: ["C:/a/b"]
  method: "parts.__getitem__"
  method_args: [1]
  expected: "a"
