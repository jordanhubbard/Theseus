spec: lodash_compact
version: ">=4.0.0"
backend: node(lodash.compact)

docs: https://lodash.com/docs/#compact

provenance:
  derived_from:
    - "lodash.compact README — https://www.npmjs.com/package/lodash.compact"
    - "Test vectors verified with lodash.compact@3.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.compact exports the _.compact function directly as module.exports."
    - "compact(array) removes all falsy values: false, null, 0, '', undefined, NaN."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array with falsy values removed. No errors for array inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_compact.compact:
  kind: node_module_call_eq
  function: ~
  category: compact
  id_prefix: lcompact

  columns: [id, args, expected]
  rows:
    - [falsy,   [[0, 1, false, 2, null, 3, ""]],  [1, 2, 3]]
    - [strings, [["", "a", "", "b"]],              ["a", "b"]]
    - [clean,   [[1, 2, 3]],                       [1, 2, 3]]
