spec: mime
version: ">=1.0.0"
backend: node(mime)

docs: https://github.com/broofa/mime#readme

provenance:
  derived_from:
    - "mime README — https://github.com/broofa/mime#readme"
    - "Test vectors verified with mime@1.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "mime source: mime.js"
  notes:
    - "mime@1.x exports an object with lookup() and extension() methods."
    - "mime.lookup(ext) returns the MIME type for a file extension."
    - "mime.extension(mimeType) returns the primary file extension for a MIME type."
    - "The pre-installed version in the theseus repo is mime@1.x."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "lookup returns string or false; extension returns string. No errors."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table mime.lookup:
  kind: node_module_call_eq
  function: lookup
  category: lookup
  id_prefix: mime_lk

  columns: [id, args, expected]
  rows:
    - [html,  ["html"],  "text/html"]
    - [txt,   ["txt"],   "text/plain"]
    - [json,  ["json"],  "application/json"]

table mime.extension:
  kind: node_module_call_eq
  function: extension
  category: extension
  id_prefix: mime_ext

  columns: [id, args, expected]
  rows:
    - [text_html,  ["text/html"],         "html"]
    - [app_json,   ["application/json"],  "json"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:17:04Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
