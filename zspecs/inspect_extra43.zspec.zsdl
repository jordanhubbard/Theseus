spec: inspect_extra43
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra42.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/iscode/isframe/istraceback __name__/__qualname__.__len__(); iscoroutinefunction/isgeneratorfunction/isasyncgenfunction __name__/__qualname__.__len__(); getmembers/getfile/getsource/getmodule/signature/stack/currentframe/getfullargspec __qualname__.__len__(); Parameter/__mro__.__len__()==2; Signature/__mro__.__len__()==2; BoundArguments/__mro__.__len__()==2; Parameter.empty/kind constants; inspect.__all__.__len__()==107; CO_OPTIMIZED==1; cleandoc/formatannotation/getattr_static/classify_class_attrs __name__ lengths; Signature/Parameter/BoundArguments method qualnames; getmembers/__module__.__len__(7); parameter kind integer values; Parameter/__name__/__module__; Signature/__name__/__module__; isfunction/__name__/__module__; isbuiltin/__name__/__module__; isclass/__name__/__module__; ismodule/__name__/__module__; ismethod/__name__/__module__; getcallargs/__name__/__module__; getfile/__name__/__module__; getdoc/__name__/__module__; getsource/__name__/__module__; getmembers/__name__/__module__; signature/__name__/__module__; cleandoc/__name__/__module__; iscoroutinefunction/__name__/__module__; isasyncgenfunction/__name__; isgeneratorfunction/__name__; isgenerator/__name__; isawaitable/__name__; stack/__name__/__module__; currentframe/__name__/__module__."
    - "This spec covers: inspect.Parameter.empty.__class__.__name__ == 'type' (Parameter.empty is inspect._empty which is itself a class, so its __class__ is type); inspect.Parameter.empty.__class__.__module__ == 'builtins'; inspect.Signature.empty.__class__.__name__ == 'type' (Signature.empty is the same object as Parameter.empty — inspect._empty); inspect.BoundArguments.__name__ == 'BoundArguments'; inspect.BoundArguments.__module__ == 'inspect'; inspect.BoundArguments.__qualname__ == 'BoundArguments'; inspect.FullArgSpec.__name__ == 'FullArgSpec'; inspect.FullArgSpec.__module__ == 'inspect'; inspect.FrameInfo.__name__ == 'FrameInfo'."
    - "Key findings: inspect.Parameter.empty is the sentinel class inspect._empty — it is a class object (not an instance), so its __class__ is type (the metaclass) and __class__.__module__ is 'builtins'. inspect.Signature.empty is the same object as inspect.Parameter.empty (verified: Signature.empty is Parameter.empty returns True); both sentinels are the same inspect._empty class, so both __class__.__name__ == 'type' and __class__.__module__ == 'builtins'. inspect.BoundArguments.__name__ is 'BoundArguments' (14 chars), __qualname__ is 'BoundArguments' (top-level class so __qualname__==__name__), and __module__ is 'inspect'. inspect.FullArgSpec is a named tuple defined in Lib/inspect.py; __name__ is 'FullArgSpec' (11 chars) and __module__ is 'inspect'. inspect.ArgSpec does not exist in Python 3.9+ (removed). inspect.FrameInfo.__name__ is 'FrameInfo' (9 chars) — a named tuple (or dataclass in newer Python) defined in Lib/inspect.py."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.Parameter.empty and Signature.empty __class__ metadata — extra43 namespace
#
# inspect.Parameter.empty is the sentinel class inspect._empty. As a class
# object its __class__ is type (the metaclass for all classes) with
# __module__ == 'builtins'. inspect.Signature.empty is the same object
# (Signature.empty is Parameter.empty evaluates to True). Prior specs
# recorded Parameter.empty integer kind constants and the sentinel's existence,
# but not __class__.__name__ or __class__.__module__. These invariants are new.
# ---------------------------------------------------------------------------

table inspect_extra43.empty_sentinel_class:
  description: "inspect.Parameter.empty and Signature.empty __class__ metadata — both are inspect._empty (a class), so __class__ is type with module builtins"
  kind: python_call_eq
  category: identity
  id_prefix: emptyclass43

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_empty_class_name,
       Parameter.empty.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is inspect._empty, a class object; its metaclass is type; __class__.__name__ is the metaclass name 'type'"]
    - [parameter_empty_class_module,
       Parameter.empty.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "inspect.Parameter.empty.__class__.__module__ == 'builtins' — type is a built-in metaclass; its __module__ is 'builtins'; 8 chars"]
    - [signature_empty_class_name,
       Signature.empty.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Signature.empty.__class__.__name__ == 'type' — Signature.empty is the same object as Parameter.empty (inspect._empty); same metaclass; same result"]

# ---------------------------------------------------------------------------
# inspect.BoundArguments identity metadata — extra43 namespace
#
# inspect.BoundArguments.__name__ is 'BoundArguments' (14 chars),
# inspect.BoundArguments.__qualname__ is 'BoundArguments' (14 chars), and
# inspect.BoundArguments.__module__ is 'inspect' (7 chars). BoundArguments
# is a pure-Python class defined at module level in Lib/inspect.py that holds
# the result of binding arguments to a Signature. As a top-level class,
# __qualname__ == __name__. Prior specs recorded BoundArguments/__mro__.__len__()
# and method __qualname__ lengths but not __name__, __qualname__, or __module__
# string equality invariants. These three are new to extra43.
# ---------------------------------------------------------------------------

table inspect_extra43.boundarguments_identity:
  description: "inspect.BoundArguments __name__, __qualname__, and __module__ string equality — pure-Python class; top-level; inherits from object"
  kind: python_call_eq
  category: identity
  id_prefix: baid43

  columns: [id, function, args, expected, description]
  rows:
    - [boundarguments_name,
       BoundArguments.__name__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__ == 'BoundArguments' — pure-Python class in Lib/inspect.py; 14-char name; holds the result of Signature.bind()"]
    - [boundarguments_qualname,
       BoundArguments.__qualname__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__qualname__ == 'BoundArguments' — top-level class; __qualname__ == __name__ (no enclosing class scope); 14 chars"]
    - [boundarguments_module,
       BoundArguments.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__ == 'inspect' — pure-Python class defined in Lib/inspect.py; 7-char module name; same as all inspect classes"]

# ---------------------------------------------------------------------------
# inspect.FullArgSpec and inspect.FrameInfo __name__ — extra43 namespace
#
# inspect.FullArgSpec.__name__ is 'FullArgSpec' (11 chars) and
# inspect.FullArgSpec.__module__ is 'inspect' (7 chars). FullArgSpec is a
# named tuple defined in Lib/inspect.py by collections.namedtuple and used
# as the return type of getfullargspec(). inspect.ArgSpec does not exist in
# Python 3.9+ (it was removed). inspect.FrameInfo.__name__ is 'FrameInfo'
# (9 chars) — a named tuple (or dataclass in newer Python) holding frame
# inspection results. Prior specs recorded getfullargspec.__qualname__.__len__()
# but not FullArgSpec or FrameInfo type identity. These invariants are new.
# ---------------------------------------------------------------------------

table inspect_extra43.namedtuple_types_identity:
  description: "inspect.FullArgSpec and FrameInfo __name__ and __module__ — named tuples / result types defined in Lib/inspect.py"
  kind: python_call_eq
  category: identity
  id_prefix: ntid43

  columns: [id, function, args, expected, description]
  rows:
    - [fullargspec_name,
       FullArgSpec.__name__.__eq__,
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__name__ == 'FullArgSpec' — named tuple; 11-char name; return type of inspect.getfullargspec(); holds args/varargs/varkw/defaults/kwonlyargs/kwonlydefaults/annotations"]
    - [fullargspec_module,
       FullArgSpec.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FullArgSpec.__module__ == 'inspect' — named tuple defined in Lib/inspect.py; 7-char module name; same as all inspect types"]
    - [frameinfo_name,
       FrameInfo.__name__.__eq__,
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__name__ == 'FrameInfo' — named tuple or dataclass in Lib/inspect.py; 9-char name; holds frame/filename/lineno/function/code_context/index fields returned by stack()"]
