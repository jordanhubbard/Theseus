spec: zipfile_extra8
version: ">=3.9"
backend: python_module(zipfile)

docs: https://docs.python.org/3/library/zipfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zipfile.html — Python zipfile documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zipfile/__init__.py"
  notes:
    - "This spec extends zipfile.zspec.zsdl through zipfile_extra7.zspec.zsdl."
    - "zipfile (base) covers: ZIP_STORED/ZIP_DEFLATED/ZIP_BZIP2/ZIP_LZMA values; ZIP64_LIMIT/ZIP_FILECOUNT_LIMIT/ZIP_MAX_COMMENT values; ZipFile/ZipInfo/BadZipFile/LargeZipFile/Path __name__; BadZipFile/LargeZipFile bases; ZipInfo construction; is_zipfile false on non-zip; ZipFile raises BadZipFile."
    - "zipfile_extra through zipfile_extra7 cover: class __name__/__module__/__qualname__/__class__.__name__ for ZipFile/ZipInfo/BadZipFile/LargeZipFile/Path; is_zipfile __name__/__qualname__/__module__/__class__.__name__; compression constants class names and values; limit constant class names; ZipInfo filename vectors; exception base hierarchy."
    - "This spec adds: ZIP_STORED class (int) via __class__.__name__ bool form; compression constant integer class checks (bool) for ZIP_DEFLATED/ZIP_BZIP2/ZIP_LZMA; ZipExtFile.__name__/__module__/__qualname__/__class__.__name__; BadZipfile (legacy alias) __name__ check; ZipFile.__bases__[0].__name__; ZipInfo.__bases__[0].__name__; is_zipfile raises TypeError on non-bytes-non-path; ZipInfo('data.bin').filename == 'data.bin' (distinct filename vector)."
    - "zipfile.ZipExtFile is the file-like object returned by ZipFile.open(); not covered in any prior zipfile spec."
    - "zipfile.ZipExtFile.__bases__[0].__name__ == 'BufferedIOBase' — ZipExtFile inherits from io.BufferedIOBase."
    - "zipfile.BadZipfile is an alias for BadZipFile preserved for backward compatibility; __name__ still returns 'BadZipFile'."
    - "zipfile.ZipFile.__bases__[0].__name__ == 'object' — ZipFile has no custom base class."
    - "zipfile.ZipInfo.__bases__[0].__name__ == 'object' — ZipInfo has no custom base class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Compression constant integer type checks — bool form
# Prior specs check __class__.__name__ for ZIP_STORED (extra7 limtype7 table
# is for limit constants; ZIP_STORED class name in extra/extra2/extra4 is string
# form). This table uses the bool equality pattern for ZIP_DEFLATED/ZIP_BZIP2/
# ZIP_LZMA — none have bool-form class name checks in any prior spec.
# ZIP_STORED bool form is also new (extra7 covers limit constants, not zip consts).
# ---------------------------------------------------------------------------

table zipfile_extra8.compression_constant_class_checks:
  description: "Compression constants ZIP_STORED/ZIP_DEFLATED/ZIP_BZIP2/ZIP_LZMA are plain int"
  kind: python_call_eq
  category: constants
  id_prefix: cctype8

  columns: [id, function, args, expected]
  rows:
    - [ZIP_STORED,   ZIP_STORED.__class__.__name__.__eq__,   ["int"], true]
    - [ZIP_DEFLATED, ZIP_DEFLATED.__class__.__name__.__eq__, ["int"], true]
    - [ZIP_BZIP2,    ZIP_BZIP2.__class__.__name__.__eq__,    ["int"], true]
    - [ZIP_LZMA,     ZIP_LZMA.__class__.__name__.__eq__,     ["int"], true]

# ---------------------------------------------------------------------------
# ZipExtFile class metadata — not covered in any prior zipfile spec.
# ZipExtFile is the file-like object returned by ZipFile.open().
# ---------------------------------------------------------------------------

invariant zipfile_extra8.ZipExtFile.name:
  description: "zipfile.ZipExtFile.__name__ == 'ZipExtFile'"
  category: class_metadata
  kind: python_call_eq
  function: ZipExtFile.__name__.__eq__
  args: ["ZipExtFile"]
  expected: true

invariant zipfile_extra8.ZipExtFile.module:
  description: "zipfile.ZipExtFile.__module__ == 'zipfile'"
  category: module
  kind: python_call_eq
  function: ZipExtFile.__module__.__eq__
  args: ["zipfile"]
  expected: true

invariant zipfile_extra8.ZipExtFile.qualname:
  description: "zipfile.ZipExtFile.__qualname__ == 'ZipExtFile'"
  category: qualnames
  kind: python_call_eq
  function: ZipExtFile.__qualname__.__eq__
  args: ["ZipExtFile"]
  expected: true

invariant zipfile_extra8.ZipExtFile.class_is_type:
  description: "zipfile.ZipExtFile.__class__.__name__ == 'type' — ZipExtFile is a class object"
  category: type_identity
  kind: python_call_eq
  function: ZipExtFile.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant zipfile_extra8.ZipExtFile.base_name:
  description: "zipfile.ZipExtFile.__bases__[0].__name__ == 'BufferedIOBase'"
  category: hierarchy
  kind: python_call_eq
  function: ZipExtFile.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BufferedIOBase"

# ---------------------------------------------------------------------------
# BadZipfile legacy alias — __name__ still resolves to 'BadZipFile'
# zipfile.BadZipfile (lowercase 'f') is an alias preserved for backward
# compatibility; no prior spec checks BadZipfile (alias form) directly.
# ---------------------------------------------------------------------------

invariant zipfile_extra8.BadZipfile.alias_name:
  description: "zipfile.BadZipfile.__name__ == 'BadZipFile' — BadZipfile is an alias for BadZipFile"
  category: class_metadata
  kind: python_call_eq
  function: BadZipfile.__name__.__eq__
  args: ["BadZipFile"]
  expected: true

# ---------------------------------------------------------------------------
# ZipFile and ZipInfo direct base class checks
# Neither ZipFile nor ZipInfo has a custom base class; both inherit directly
# from object. Not covered in any prior zipfile spec.
# ---------------------------------------------------------------------------

invariant zipfile_extra8.ZipFile.base_name:
  description: "zipfile.ZipFile.__bases__[0].__name__ == 'object' — ZipFile inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: ZipFile.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant zipfile_extra8.ZipInfo.base_name:
  description: "zipfile.ZipInfo.__bases__[0].__name__ == 'object' — ZipInfo inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: ZipInfo.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# ZipInfo with a distinct filename vector — 'data.bin'
# base covers 'hello.txt'; extra4 covers 'test.txt'; extra7 covers 'archive.zip'.
# 'data.bin' is a fresh vector confirming generality.
# ---------------------------------------------------------------------------

invariant zipfile_extra8.ZipInfo.filename_data_bin:
  description: "zipfile.ZipInfo('data.bin').filename == 'data.bin'"
  category: zipinfo
  kind: python_call_eq
  function: ZipInfo
  args: ["data.bin"]
  method: filename
  expected: "data.bin"

# ---------------------------------------------------------------------------
# is_zipfile raises TypeError on invalid argument type
# Prior specs only check False return values on bytes input.
# Passing an integer raises TypeError — new error coverage.
# ---------------------------------------------------------------------------

invariant zipfile_extra8.is_zipfile.raises_on_int:
  description: "zipfile.is_zipfile(42) raises TypeError — only path-like or file-like objects accepted"
  category: errors
  kind: python_call_raises
  function: is_zipfile
  args: [42]
  raises: TypeError
