    - ["ppx2971_015", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__index__"], false]
    - ["ppx2971_016", operator.contains, [pathlib.Path.__dict__,            "__floor__"], false]
    - ["ppx2971_017", operator.contains, [pathlib.PurePath.__dict__,        "__ceil__"],  false]
