    - ["ppx2971_019", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__floor__"], false]
    - ["ppx2971_020", operator.contains, [pathlib.Path.__dict__,            "__ceil__"],  false]
    - ["ppx2971_021", operator.contains, [pathlib.PurePath.__dict__,        "__index__"], false]
    - ["ppx2971_022", operator.contains, [pathlib.PurePosixPath.__dict__,   "__floor__"], false]
    - ["ppx2971_023", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__ceil__"],  false]
    - ["ppx2971_024", operator.contains, [pathlib.Path.__dict__,            "__index__"], false]
