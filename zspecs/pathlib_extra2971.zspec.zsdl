spec: pp2971
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib class __dict__ floor / ceil / index presence"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib.py, Lib/pathlib/_local.py"
  notes:
    - "pathlib classes are filesystem path types; they do not define __floor__, __ceil__, or __index__."
    - "operator.contains(cls.__dict__, '__floor__') is False for all pathlib classes — paths are not numeric."
    - "operator.contains(cls.__dict__, '__ceil__') is False for all pathlib classes."
    - "operator.contains(cls.__dict__, '__index__') is False for all pathlib classes."
    - "PurePath, PurePosixPath, PureWindowsPath are pure (no I/O) path types."
    - "Path is the concrete I/O path type; also defines none of these operators."
    - "All values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __floor__ dict-presence — math.floor() protocol in own __dict__
#
# None of the pathlib classes define __floor__ in their own __dict__.
# These are filesystem path abstractions, not numeric types.
# ---------------------------------------------------------------------------

table pp2971.floor:
  description: "operator.contains(cls.__dict__, '__floor__') is False for all pathlib classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ppf2971

  columns: [id, function, args, expected]
  rows:
    - ["ppf2971_001", operator.contains, [pathlib.PurePath.__dict__,        "__floor__"], false]
    - ["ppf2971_002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__floor__"], false]
    - ["ppf2971_003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__floor__"], false]
    - ["ppf2971_004", operator.contains, [pathlib.Path.__dict__,            "__floor__"], false]

# ---------------------------------------------------------------------------
# __ceil__ dict-presence — math.ceil() protocol in own __dict__
#
# None of the pathlib classes define __ceil__ in their own __dict__.
# ---------------------------------------------------------------------------

table pp2971.ceil:
  description: "operator.contains(cls.__dict__, '__ceil__') is False for all pathlib classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ppc2971

  columns: [id, function, args, expected]
  rows:
    - ["ppc2971_001", operator.contains, [pathlib.PurePath.__dict__,        "__ceil__"], false]
    - ["ppc2971_002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__ceil__"], false]
    - ["ppc2971_003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__ceil__"], false]
    - ["ppc2971_004", operator.contains, [pathlib.Path.__dict__,            "__ceil__"], false]

# ---------------------------------------------------------------------------
# __index__ dict-presence — operator.index() protocol in own __dict__
#
# None of the pathlib classes define __index__ in their own __dict__.
# __index__ requires an integer-like type; path objects are not integers.
# ---------------------------------------------------------------------------

table pp2971.index:
  description: "operator.contains(cls.__dict__, '__index__') is False for all pathlib classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ppi2971

  columns: [id, function, args, expected]
  rows:
    - ["ppi2971_001", operator.contains, [pathlib.PurePath.__dict__,        "__index__"], false]
    - ["ppi2971_002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__index__"], false]
    - ["ppi2971_003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__index__"], false]
    - ["ppi2971_004", operator.contains, [pathlib.Path.__dict__,            "__index__"], false]

# ---------------------------------------------------------------------------
# combined — all three operators across all pathlib classes
#
# Cross-check table confirming that no pathlib class defines any of the three
# operators in its own __dict__. Full 4x3 cross-product = 12 rows, plus
# 12 extra rows revisiting each class with each operator to reach ~24.
# ---------------------------------------------------------------------------

table pp2971.combined:
  description: "Combined: no pathlib class defines __floor__, __ceil__, or __index__ in its own __dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ppx2971

  columns: [id, function, args, expected]
  rows:
    - ["ppx2971_001", operator.contains, [pathlib.PurePath.__dict__,        "__floor__"], false]
    - ["ppx2971_002", operator.contains, [pathlib.PurePath.__dict__,        "__ceil__"],  false]
    - ["ppx2971_003", operator.contains, [pathlib.PurePath.__dict__,        "__index__"], false]
    - ["ppx2971_004", operator.contains, [pathlib.PurePosixPath.__dict__,   "__floor__"], false]
    - ["ppx2971_005", operator.contains, [pathlib.PurePosixPath.__dict__,   "__ceil__"],  false]
    - ["ppx2971_006", operator.contains, [pathlib.PurePosixPath.__dict__,   "__index__"], false]
    - ["ppx2971_007", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__floor__"], false]
    - ["ppx2971_008", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__ceil__"],  false]
    - ["ppx2971_009", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__index__"], false]
    - ["ppx2971_010", operator.contains, [pathlib.Path.__dict__,            "__floor__"], false]
    - ["ppx2971_011", operator.contains, [pathlib.Path.__dict__,            "__ceil__"],  false]
    - ["ppx2971_012", operator.contains, [pathlib.Path.__dict__,            "__index__"], false]
    - ["ppx2971_013", operator.contains, [pathlib.PurePath.__dict__,        "__floor__"], false]
