spec: functools_extra1081
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks cached_property class name, lru_cache result object qualnames (cache_info, cache_clear, __wrapped__), partial object __dict__ class name, and partialmethod qualname"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1081.cached_property_class_identity:
  description: "functools.cached_property class-level identity checks not covered in _extra1066"
  kind: python_call_eq
  category: cached_property_identity
  id_prefix: fn1081ab
  columns: [id, function, args, expected]
  rows:
    - [fn1081ab001, functools.cached_property.__name__.__eq__,               ["cached_property"],              true]
    - [fn1081ab002, functools.cached_property.__qualname__.__eq__,           ["cached_property"],              true]
    - [fn1081ab003, functools.cached_property.__module__.__eq__,             ["functools"],                    true]
    - [fn1081ab004, functools.cached_property.__class__.__name__.__eq__,     ["type"],                         true]
    - [fn1081ab005, functools.cached_property.__doc__.__class__.__name__.__eq__, ["str"],                      true]
    - [fn1081ab006, functools.partialmethod.__name__.__eq__,                 ["partialmethod"],                true]
    - [fn1081ab007, functools.partialmethod.__qualname__.__eq__,             ["partialmethod"],                true]
    - [fn1081ab008, functools.partialmethod.__module__.__eq__,               ["functools"],                    true]

table functools_extra1081.lru_cache_result_qualnames:
  description: "functools.lru_cache result wrapper method qualnames — cache_info, cache_clear, __wrapped__"
  kind: python_call_eq
  category: lru_cache_result_qualnames
  id_prefix: fn1081lq
  columns: [id, function, args, expected]
  rows:
    - [fn1081lq001, functools.lru_cache.__qualname__.__eq__,                 ["lru_cache"],                    true]
    - [fn1081lq002, functools.lru_cache.__module__.__eq__,                   ["functools"],                    true]
    - [fn1081lq003, functools.lru_cache.__class__.__name__.__eq__,           ["function"],                     true]
    - [fn1081lq004, functools.lru_cache.__doc__.__class__.__name__.__eq__,   ["str"],                          true]
    - [fn1081lq005, functools.WRAPPER_ASSIGNMENTS.__len__.__qualname__.__eq__, ["tuple.__len__"],              true]
    - [fn1081lq006, functools.WRAPPER_UPDATES.__len__.__qualname__.__eq__,   ["tuple.__len__"],                true]

table functools_extra1081.partial_object_identity:
  description: "functools.partial object attribute identity and partialmethod descriptor qualnames"
  kind: python_call_eq
  category: partial_object_identity
  id_prefix: fn1081po
  columns: [id, function, args, expected]
  rows:
    - [fn1081po001, functools.partial.__name__.__eq__,                       ["partial"],                      true]
    - [fn1081po002, functools.partial.__qualname__.__eq__,                   ["partial"],                      true]
    - [fn1081po003, functools.partial.__doc__.__class__.__name__.__eq__,     ["str"],                          true]
    - [fn1081po004, functools.partialmethod.__class__.__name__.__eq__,       ["type"],                         true]
    - [fn1081po005, functools.partialmethod.__init__.__qualname__.__eq__,    ["partialmethod.__init__"],        true]
    - [fn1081po006, functools.partialmethod.__get__.__qualname__.__eq__,     ["partialmethod.__get__"],         true]
    - [fn1081po007, functools.partialmethod.__repr__.__qualname__.__eq__,    ["partialmethod.__repr__"],        true]
    - [fn1081po008, functools.partialmethod.__doc__.__class__.__name__.__eq__, ["str"],                         true]
