spec: re_extra269
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.Pattern.__name__ == 'Pattern' and re.Pattern.__module__ == 're'."
    - "re.Match.__name__ == 'Match' and re.Match.__module__ == 're'."
    - "type(re.compile('x')) is re.Pattern — compile returns the Pattern class."
    - "Pattern methods (match, search, findall, sub, fullmatch, finditer, split) are all method_descriptor objects."
    - "Pattern method qualnames follow the pattern 'Pattern.<method_name>'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: re.Pattern and re.Match class identity
# ---------------------------------------------------------------------------

table re_extra269.pattern_match_class_identity:
  description: "re.Pattern and re.Match __name__ and __module__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: cls

  columns: [id, function, args, expected, description]
  rows:
    - [Pattern_name,   Pattern.__name__.__eq__,   ["Pattern"], true, "re.Pattern.__name__ == 'Pattern'"]
    - [Pattern_module, Pattern.__module__.__eq__,  ["re"],      true, "re.Pattern.__module__ == 're'"]
    - [Match_name,     Match.__name__.__eq__,      ["Match"],   true, "re.Match.__name__ == 'Match'"]
    - [Match_module,   Match.__module__.__eq__,    ["re"],      true, "re.Match.__module__ == 're'"]

# ---------------------------------------------------------------------------
# Table: re.Pattern method __name__ identity
# ---------------------------------------------------------------------------

table re_extra269.pattern_method_names:
  description: "re.Pattern method __name__ for match, search, findall, sub, fullmatch, finditer, split"
  kind: python_call_eq
  category: identity
  id_prefix: nm

  columns: [id, function, args, expected, description]
  rows:
    - [match_name,     Pattern.match.__name__.__eq__,     ["match"],     true, "re.Pattern.match.__name__ == 'match'"]
    - [search_name,    Pattern.search.__name__.__eq__,    ["search"],    true, "re.Pattern.search.__name__ == 'search'"]
    - [findall_name,   Pattern.findall.__name__.__eq__,   ["findall"],   true, "re.Pattern.findall.__name__ == 'findall'"]
    - [sub_name,       Pattern.sub.__name__.__eq__,       ["sub"],       true, "re.Pattern.sub.__name__ == 'sub'"]
    - [fullmatch_name, Pattern.fullmatch.__name__.__eq__, ["fullmatch"], true, "re.Pattern.fullmatch.__name__ == 'fullmatch'"]
    - [finditer_name,  Pattern.finditer.__name__.__eq__,  ["finditer"],  true, "re.Pattern.finditer.__name__ == 'finditer'"]
    - [split_name,     Pattern.split.__name__.__eq__,     ["split"],     true, "re.Pattern.split.__name__ == 'split'"]

# ---------------------------------------------------------------------------
# Table: re.Pattern method __class__.__name__ (all method_descriptor)
# ---------------------------------------------------------------------------

table re_extra269.pattern_method_classes:
  description: "re.Pattern method __class__.__name__ for match, search, findall, sub, fullmatch, finditer, split"
  kind: python_call_eq
  category: identity
  id_prefix: mcls

  columns: [id, function, args, expected, description]
  rows:
    - [match_class,     Pattern.match.__class__.__name__.__eq__,     ["method_descriptor"], true, "re.Pattern.match.__class__.__name__ == 'method_descriptor'"]
    - [search_class,    Pattern.search.__class__.__name__.__eq__,    ["method_descriptor"], true, "re.Pattern.search.__class__.__name__ == 'method_descriptor'"]
    - [findall_class,   Pattern.findall.__class__.__name__.__eq__,   ["method_descriptor"], true, "re.Pattern.findall.__class__.__name__ == 'method_descriptor'"]
    - [sub_class,       Pattern.sub.__class__.__name__.__eq__,       ["method_descriptor"], true, "re.Pattern.sub.__class__.__name__ == 'method_descriptor'"]
    - [fullmatch_class, Pattern.fullmatch.__class__.__name__.__eq__, ["method_descriptor"], true, "re.Pattern.fullmatch.__class__.__name__ == 'method_descriptor'"]
    - [finditer_class,  Pattern.finditer.__class__.__name__.__eq__,  ["method_descriptor"], true, "re.Pattern.finditer.__class__.__name__ == 'method_descriptor'"]
    - [split_class,     Pattern.split.__class__.__name__.__eq__,     ["method_descriptor"], true, "re.Pattern.split.__class__.__name__ == 'method_descriptor'"]

# ---------------------------------------------------------------------------
# Table: re.Pattern method __qualname__ identity
# ---------------------------------------------------------------------------

table re_extra269.pattern_method_qualnames:
  description: "re.Pattern method __qualname__ for match, search, findall, sub"
  kind: python_call_eq
  category: identity
  id_prefix: qn

  columns: [id, function, args, expected, description]
  rows:
    - [match_qualname,   Pattern.match.__qualname__.__eq__,   ["Pattern.match"],   true, "re.Pattern.match.__qualname__ == 'Pattern.match'"]
    - [search_qualname,  Pattern.search.__qualname__.__eq__,  ["Pattern.search"],  true, "re.Pattern.search.__qualname__ == 'Pattern.search'"]
    - [findall_qualname, Pattern.findall.__qualname__.__eq__, ["Pattern.findall"], true, "re.Pattern.findall.__qualname__ == 'Pattern.findall'"]
    - [sub_qualname,     Pattern.sub.__qualname__.__eq__,     ["Pattern.sub"],     true, "re.Pattern.sub.__qualname__ == 'Pattern.sub'"]

# ---------------------------------------------------------------------------
# Standalone invariants: cross-checks for Pattern and Match
# ---------------------------------------------------------------------------

invariant re_extra269.Pattern.name:
  description: "re.Pattern.__name__ == 'Pattern'"
  category: identity
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra269.Match.name:
  description: "re.Match.__name__ == 'Match'"
  category: identity
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra269.Pattern.match.is_method_descriptor:
  description: "re.Pattern.match is a method_descriptor (C-extension method)"
  category: identity
  kind: python_call_eq
  function: Pattern.match.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant re_extra269.Pattern.sub.qualname:
  description: "re.Pattern.sub.__qualname__ == 'Pattern.sub'"
  category: identity
  kind: python_call_eq
  function: Pattern.sub.__qualname__.__eq__
  args: ["Pattern.sub"]
  expected: true
