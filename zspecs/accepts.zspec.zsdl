spec: accepts
version: ">=1.0.0"
backend: node(accepts)

docs: https://github.com/jshttp/accepts#readme

provenance:
  derived_from:
    - "accepts README — https://github.com/jshttp/accepts#readme"
    - "RFC 7231 — HTTP/1.1 Content Negotiation"
    - "Test vectors verified with accepts@1.3.8 via Node.js 25.6.0 on macOS/Darwin 25.4.0, 2026-04-09"
    - "accepts source: index.js (MIT; source inspection permitted)"
  not_derived_from:
    - "accepts source: internal negotiation scoring"
  notes:
    - "accepts(req) takes a request-like object ({headers: {...}}) and returns an Accepts instance."
    - "Accepts.type(types) returns the best matching media type string, or false if no match."
    - "Accepts.encoding(encodings) returns the best matching encoding string, or false if no match."
    - "Accepts.charset(charsets) returns the best matching charset string, or false if no match."
    - "Accepts.language(languages) returns the best matching language string, or false if no match."
    - "When Accept header is absent, the first offered type is returned (all types acceptable)."
    - "When Accept-Encoding header is absent, 'identity' is always acceptable."
    - "When Accept-Charset header is absent, the first offered charset is returned."
    - "When Accept-Language header is absent, the first offered language is returned."
    - "q-values control priority: higher q-value wins. Default q is 1.0."
    - "Returns false (JSON null from JSON.stringify) when no offered type matches."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Returns false when no match. node exits 0 for all invariants."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# accepts().type() — media type negotiation
# ---------------------------------------------------------------------------

invariant accepts.type.html_match:
  description: "accepts({headers:{accept:'text/html'}}).type(['html','json']) == 'html'"
  category: type
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {accept: "text/html"}}]
  method: type
  method_args: [["html", "json"]]
  expected: "html"

invariant accepts.type.json_preferred_by_q:
  description: "accepts with json q=1 and html q=0.9 prefers json"
  category: type
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {accept: "application/json, text/html;q=0.9"}}]
  method: type
  method_args: [["html", "json"]]
  expected: "json"

invariant accepts.type.json_preferred_q_value:
  description: "accepts({accept: 'text/html;q=0.5, application/json'}).type(['html','json']) == 'json'"
  category: type
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {accept: "text/html;q=0.5, application/json"}}]
  method: type
  method_args: [["html", "json"]]
  expected: "json"

invariant accepts.type.no_match_returns_false:
  description: "accepts with json/html accept but xml/text offered returns false"
  category: type
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {accept: "application/json, text/html;q=0.9"}}]
  method: type
  method_args: [["xml", "text"]]
  expected: false

invariant accepts.type.no_accept_header_first_wins:
  description: "accepts with empty headers returns first offered type"
  category: type
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {}}]
  method: type
  method_args: [["html", "json"]]
  expected: "html"

invariant accepts.type.wildcard_accept_first_wins:
  description: "accepts({accept:'*/*'}).type(['html','json']) returns first offered type"
  category: type
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {accept: "*/*"}}]
  method: type
  method_args: [["html", "json"]]
  expected: "html"

invariant accepts.type.text_wildcard:
  description: "accepts({accept:'text/*'}).type(['html','json']) == 'html' (text/* matches text/html)"
  category: type
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {accept: "text/*"}}]
  method: type
  method_args: [["html", "json"]]
  expected: "html"

invariant accepts.type.image_no_match:
  description: "accepts({accept:'image/png'}).type(['html','json']) == false"
  category: type
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {accept: "image/png"}}]
  method: type
  method_args: [["html", "json"]]
  expected: false

invariant accepts.type.single_type:
  description: "accepts({accept:'text/html'}).type(['html']) == 'html'"
  category: type
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {accept: "text/html"}}]
  method: type
  method_args: [["html"]]
  expected: "html"

invariant accepts.type.application_json:
  description: "accepts({accept:'application/json'}).type(['json','html']) == 'json'"
  category: type
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {accept: "application/json"}}]
  method: type
  method_args: [["json", "html"]]
  expected: "json"

# ---------------------------------------------------------------------------
# accepts().encoding() — content encoding negotiation
# ---------------------------------------------------------------------------

invariant accepts.encoding.gzip_match:
  description: "accepts with 'gzip, deflate' encoding and ['gzip','identity'] returns 'gzip'"
  category: encoding
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {"accept-encoding": "gzip, deflate"}}]
  method: encoding
  method_args: [["gzip", "identity"]]
  expected: "gzip"

invariant accepts.encoding.deflate_only_offered:
  description: "accepts with 'gzip, deflate' encoding and ['deflate'] returns 'deflate'"
  category: encoding
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {"accept-encoding": "gzip, deflate"}}]
  method: encoding
  method_args: [["deflate"]]
  expected: "deflate"

invariant accepts.encoding.br_no_match:
  description: "accepts with 'gzip, deflate' encoding and ['br'] returns false"
  category: encoding
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {"accept-encoding": "gzip, deflate"}}]
  method: encoding
  method_args: [["br"]]
  expected: false

invariant accepts.encoding.no_header_identity:
  description: "accepts with no Accept-Encoding header, identity is always acceptable"
  category: encoding
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {}}]
  method: encoding
  method_args: [["gzip", "identity"]]
  expected: "identity"

# ---------------------------------------------------------------------------
# accepts().charset() — character set negotiation
# ---------------------------------------------------------------------------

invariant accepts.charset.utf8_preferred:
  description: "accepts({accept-charset:'utf-8, iso-8859-1;q=0.9'}).charset(['utf-8','iso-8859-1']) == 'utf-8'"
  category: charset
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {"accept-charset": "utf-8, iso-8859-1;q=0.9"}}]
  method: charset
  method_args: [["utf-8", "iso-8859-1"]]
  expected: "utf-8"

invariant accepts.charset.iso_only:
  description: "accepts({accept-charset:'iso-8859-1'}).charset(['utf-8','iso-8859-1']) == 'iso-8859-1'"
  category: charset
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {"accept-charset": "iso-8859-1"}}]
  method: charset
  method_args: [["utf-8", "iso-8859-1"]]
  expected: "iso-8859-1"

invariant accepts.charset.no_header_first_wins:
  description: "accepts with no Accept-Charset header returns first offered charset"
  category: charset
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {}}]
  method: charset
  method_args: [["utf-8", "iso-8859-1"]]
  expected: "utf-8"

invariant accepts.charset.no_match_false:
  description: "accepts({accept-charset:'utf-8'}).charset(['ascii']) == false"
  category: charset
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {"accept-charset": "utf-8"}}]
  method: charset
  method_args: [["ascii"]]
  expected: false

# ---------------------------------------------------------------------------
# accepts().language() — language negotiation
# ---------------------------------------------------------------------------

invariant accepts.language.en_us_preferred:
  description: "accepts with 'en-US, en;q=0.9, fr;q=0.8' prefers en-US"
  category: language
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {"accept-language": "en-US, en;q=0.9, fr;q=0.8"}}]
  method: language
  method_args: [["en-US", "fr"]]
  expected: "en-US"

invariant accepts.language.fr_preferred:
  description: "accepts with 'fr, en;q=0.9' prefers fr"
  category: language
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {"accept-language": "fr, en;q=0.9"}}]
  method: language
  method_args: [["en", "fr"]]
  expected: "fr"

invariant accepts.language.no_header_first_wins:
  description: "accepts with no Accept-Language header returns first offered language"
  category: language
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {}}]
  method: language
  method_args: [["en", "fr"]]
  expected: "en"

invariant accepts.language.no_match_false:
  description: "accepts({accept-language:'en'}).language(['fr','de']) == false"
  category: language
  kind: node_factory_call_eq
  factory: ~
  factory_args: [{headers: {"accept-language": "en"}}]
  method: language
  method_args: [["fr", "de"]]
  expected: false

