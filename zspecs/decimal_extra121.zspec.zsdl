spec: decimal_extra121
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Context method __qualname__ values and lengths."
    - "Context is a C extension type from _decimal; its methods are method_descriptors with __qualname__ attributes."
    - "decimal.Context.add.__qualname__ = 'Context.add' (length 11)."
    - "decimal.Context.subtract.__qualname__ = 'Context.subtract' (length 16)."
    - "decimal.Context.multiply.__qualname__ = 'Context.multiply' (length 16)."
    - "decimal.Context.divide.__qualname__ = 'Context.divide' (length 14)."
    - "decimal.Context.power.__qualname__ = 'Context.power' (length 13)."
    - "decimal.Context.sqrt.__qualname__ = 'Context.sqrt' (length 12)."
    - "decimal.Context.abs.__qualname__ = 'Context.abs' (length 11)."
    - "decimal.Context.compare.__qualname__ = 'Context.compare' (length 15)."
    - "decimal.Context.divmod.__qualname__ = 'Context.divmod' (length 14)."
    - "decimal.Context.remainder.__qualname__ = 'Context.remainder' (length 17)."
    - "decimal.Context.fma.__qualname__ = 'Context.fma' (length 11)."
    - "decimal.Context.exp.__qualname__ = 'Context.exp' (length 11)."
    - "decimal.Context.ln.__qualname__ = 'Context.ln' (length 10)."
    - "decimal.Context.log10.__qualname__ = 'Context.log10' (length 13)."
    - "All qualnames follow the 'Context.<method>' pattern (no underscore prefix since Context is exposed under its own name)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context arithmetic method __qualname__ values and lengths
# add=11, subtract=16, multiply=16, divide=14, power=13, sqrt=12, abs=11.
# All follow the 'Context.<method>' pattern.
# ---------------------------------------------------------------------------

table decimal_extra121.Context_arithmetic_method_qualnames:
  description: "decimal.Context arithmetic method __qualname__ values and lengths: add, subtract, multiply, divide, power, sqrt, abs"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: decctxmeth121

  columns: [id, function, args, expected, description]
  rows:
    - [add_qname_eq,      Context.add.__qualname__.__eq__,      ["Context.add"],      true,  "Context.add.__qualname__ == 'Context.add'"]
    - [add_qname_len,     Context.add.__qualname__.__len__,     [],                   11,    "Context.add.__qualname__ has 11 characters"]
    - [sub_qname_eq,      Context.subtract.__qualname__.__eq__, ["Context.subtract"], true,  "Context.subtract.__qualname__ == 'Context.subtract'"]
    - [sub_qname_len,     Context.subtract.__qualname__.__len__,[],                   16,    "Context.subtract.__qualname__ has 16 characters"]
    - [mul_qname_eq,      Context.multiply.__qualname__.__eq__, ["Context.multiply"], true,  "Context.multiply.__qualname__ == 'Context.multiply'"]
    - [mul_qname_len,     Context.multiply.__qualname__.__len__,[],                   16,    "Context.multiply.__qualname__ has 16 characters"]
    - [div_qname_eq,      Context.divide.__qualname__.__eq__,   ["Context.divide"],   true,  "Context.divide.__qualname__ == 'Context.divide'"]
    - [div_qname_len,     Context.divide.__qualname__.__len__,  [],                   14,    "Context.divide.__qualname__ has 14 characters"]
    - [pow_qname_eq,      Context.power.__qualname__.__eq__,    ["Context.power"],    true,  "Context.power.__qualname__ == 'Context.power'"]
    - [pow_qname_len,     Context.power.__qualname__.__len__,   [],                   13,    "Context.power.__qualname__ has 13 characters"]
    - [sqrt_qname_eq,     Context.sqrt.__qualname__.__eq__,     ["Context.sqrt"],     true,  "Context.sqrt.__qualname__ == 'Context.sqrt'"]
    - [sqrt_qname_len,    Context.sqrt.__qualname__.__len__,    [],                   12,    "Context.sqrt.__qualname__ has 12 characters"]
    - [abs_qname_eq,      Context.abs.__qualname__.__eq__,      ["Context.abs"],      true,  "Context.abs.__qualname__ == 'Context.abs'"]
    - [abs_qname_len,     Context.abs.__qualname__.__len__,     [],                   11,    "Context.abs.__qualname__ has 11 characters"]

# ---------------------------------------------------------------------------
# decimal.Context comparison and transcendental method __qualname__ values
# compare=15, divmod=14, remainder=17, fma=11, exp=11, ln=10, log10=13.
# ---------------------------------------------------------------------------

table decimal_extra121.Context_compare_transcendental_qualnames:
  description: "decimal.Context compare and transcendental method __qualname__ values and lengths: compare, divmod, remainder, fma, exp, ln, log10"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: decctxmeth121

  columns: [id, function, args, expected, description]
  rows:
    - [cmp_qname_eq,   Context.compare.__qualname__.__eq__,   ["Context.compare"],   true,  "Context.compare.__qualname__ == 'Context.compare'"]
    - [cmp_qname_len,  Context.compare.__qualname__.__len__,  [],                    15,    "Context.compare.__qualname__ has 15 characters"]
    - [dm_qname_eq,    Context.divmod.__qualname__.__eq__,    ["Context.divmod"],    true,  "Context.divmod.__qualname__ == 'Context.divmod'"]
    - [dm_qname_len,   Context.divmod.__qualname__.__len__,   [],                    14,    "Context.divmod.__qualname__ has 14 characters"]
    - [rem_qname_eq,   Context.remainder.__qualname__.__eq__, ["Context.remainder"], true,  "Context.remainder.__qualname__ == 'Context.remainder'"]
    - [rem_qname_len,  Context.remainder.__qualname__.__len__,[],                    17,    "Context.remainder.__qualname__ has 17 characters"]
    - [fma_qname_eq,   Context.fma.__qualname__.__eq__,       ["Context.fma"],       true,  "Context.fma.__qualname__ == 'Context.fma'"]
    - [fma_qname_len,  Context.fma.__qualname__.__len__,      [],                    11,    "Context.fma.__qualname__ has 11 characters"]
    - [exp_qname_eq,   Context.exp.__qualname__.__eq__,       ["Context.exp"],       true,  "Context.exp.__qualname__ == 'Context.exp'"]
    - [exp_qname_len,  Context.exp.__qualname__.__len__,      [],                    11,    "Context.exp.__qualname__ has 11 characters"]
    - [ln_qname_eq,    Context.ln.__qualname__.__eq__,        ["Context.ln"],        true,  "Context.ln.__qualname__ == 'Context.ln'"]
    - [ln_qname_len,   Context.ln.__qualname__.__len__,       [],                    10,    "Context.ln.__qualname__ has 10 characters"]
    - [log10_qname_eq, Context.log10.__qualname__.__eq__,     ["Context.log10"],     true,  "Context.log10.__qualname__ == 'Context.log10'"]
    - [log10_qname_len,Context.log10.__qualname__.__len__,    [],                    13,    "Context.log10.__qualname__ has 13 characters"]

# ---------------------------------------------------------------------------
# Cross-check: qualname length ordering and negative assertions
# subtract and multiply both have length 16.
# ln (10) is the shortest. remainder (17) is the longest.
# add, abs, fma, exp all have length 11.
# ---------------------------------------------------------------------------

table decimal_extra121.Context_qualname_length_cross_checks:
  description: "decimal.Context method qualname length ordering: ln=10, add=abs=fma=exp=11, sqrt=12, power=log10=13, divide=divmod=14, compare=15, subtract=multiply=16, remainder=17"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: decctxmeth121

  columns: [id, function, args, expected, description]
  rows:
    - [ln_shortest,       Context.ln.__qualname__.__len__,      [], 10, "Context.ln qualname is shortest at 10 characters"]
    - [rem_longest,       Context.remainder.__qualname__.__len__,[],17, "Context.remainder qualname is longest at 17 characters"]
    - [fma_len_11,        Context.fma.__qualname__.__len__,     [], 11, "Context.fma qualname len 11 — same as add and abs"]
    - [exp_len_11,        Context.exp.__qualname__.__len__,     [], 11, "Context.exp qualname len 11 — same as add and fma"]
    - [sub_not_len14,     Context.subtract.__qualname__.__len__,[],14, false]
    - [add_not_bare,      Context.add.__qualname__.__eq__,      ["add"], false, "Context.add.__qualname__ != 'add' (includes 'Context.' prefix)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra121.Context.add_qualname:
  description: "decimal.Context.add.__qualname__ == 'Context.add' (length 11; Context method qualnames use 'Context.' prefix, unlike Decimal class where the public name matches)"
  category: method_qualnames
  kind: python_call_eq
  function: Context.add.__qualname__.__eq__
  args: ["Context.add"]
  expected: true

invariant decimal_extra121.Context.remainder_qualname_len:
  description: "decimal.Context.remainder.__qualname__.__len__() == 17 ('Context.remainder' has 17 characters, the longest of the Context method qualnames)"
  category: method_qualnames
  kind: python_call_eq
  function: Context.remainder.__qualname__.__len__
  args: []
  expected: 17

invariant decimal_extra121.Context.subtract_qualname_len:
  description: "decimal.Context.subtract.__qualname__.__len__() == 16 ('Context.subtract' has 16 characters; same length as multiply)"
  category: method_qualnames
  kind: python_call_eq
  function: Context.subtract.__qualname__.__len__
  args: []
  expected: 16

invariant decimal_extra121.Context.ln_qualname_len:
  description: "decimal.Context.ln.__qualname__.__len__() == 10 ('Context.ln' has 10 characters, the shortest Context method qualname)"
  category: method_qualnames
  kind: python_call_eq
  function: Context.ln.__qualname__.__len__
  args: []
  expected: 10

invariant decimal_extra121.Context.compare_qualname:
  description: "decimal.Context.compare.__qualname__ == 'Context.compare' (length 15)"
  category: method_qualnames
  kind: python_call_eq
  function: Context.compare.__qualname__.__eq__
  args: ["Context.compare"]
  expected: true

