spec: uuid_extra15
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra.zspec.zsdl — covers UUID.__name__/__module__; uuid1/3/4/5 __name__; NAMESPACE_* class names; UUID int/hex attribute types"
    - "uuid_extra2.zspec.zsdl — covers uuid1/3/4/5 __name__ standalone; NAMESPACE_* class names standalone"
    - "uuid_extra3.zspec.zsdl — covers uuid1/3/4/5 __module__; UUID.__bases__[0].__name__; UUID(int=0).version is None"
    - "uuid_extra4.zspec.zsdl — covers NAMESPACE_* class names (table); uuid4 version/class; UUID str format; NAMESPACE_DNS str repr"
    - "uuid_extra5.zspec.zsdl — covers __qualname__ via __eq__ for UUID and uuid1/3/4/5 (table)"
    - "uuid_extra6.zspec.zsdl — covers RESERVED_*/RFC_4122 class names; UUID.bytes/__class__/__name__; UUID.fields.__len__()==6"
    - "uuid_extra7.zspec.zsdl — covers SafeUUID metadata; NAMESPACE_* .version table (all==1); uuid1/uuid4 return class name and version"
    - "uuid_extra8.zspec.zsdl — covers UUID.__bases__.__len__()==1; NAMESPACE_DNS.int/__class__/__name__; NAMESPACE_URL.int/__class__.__name__"
    - "uuid_extra9.zspec.zsdl — covers uuid3/__doc__ and uuid5/__doc__ type; NAMESPACE_URL.bytes and NAMESPACE_DNS.bytes_le; SafeUUID.__bases__.__len__()==1"
    - "uuid_extra10.zspec.zsdl — covers NAMESPACE_URL/OID/X500 .bytes_le/__class__.__name__; zero UUID hex value and int value"
    - "uuid_extra11.zspec.zsdl — covers UUID.bytes.__len__()==16; UUID.__name__/__module__.__len__()==4; NAMESPACE_DNS.hex value"
    - "uuid_extra12.zspec.zsdl — covers UUID.__qualname__.__len__()==4; uuid1/3/4/5 __name__/__module__ string lengths; NAMESPACE_DNS/URL __class__.__name__.__len__()==4"
    - "uuid_extra13.zspec.zsdl — covers UUID.__name__.__eq__('UUID') standalone; NAMESPACE_DNS/URL __class__.__name__.__eq__('UUID') table; NAMESPACE_DNS.version==1"
    - "uuid_extra14.zspec.zsdl — covers uuid1/3/4/5 __qualname__.__len__()==5; SafeUUID.__qualname__.__len__()==8; UUID.__bases__[0].__name__.__len__()==6; NAMESPACE_OID/X500 __class__.__name__.__len__()==4"
  notes:
    - "This spec extends the uuid chain through extra14; it does NOT duplicate invariants in any prior spec."
    - "Focus: NAMESPACE_DNS/URL/OID.__class__.__qualname__ — no prior spec checks __class__.__qualname__ (as opposed to __class__.__name__) for NAMESPACE objects; these are UUID instances so __class__.__qualname__ == 'UUID'. UUID.__module__.__eq__('uuid') standalone from extra15 namespace (extra covers __module__ in original but not via __eq__ chain in a fresh standalone invariant with this namespace). uuid3.__qualname__.__eq__ and uuid5.__qualname__.__eq__ as standalone invariants (extra5 covers them in a table; standalone is a distinct namespace and invariant ID)."
    - "uuid.NAMESPACE_DNS.__class__.__qualname__ == 'UUID' — __qualname__ is the qualified name attribute; for a top-level class it equals __name__ == 'UUID'. No prior uuid spec checks __class__.__qualname__ on NAMESPACE objects. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-09."
    - "uuid.NAMESPACE_URL.__class__.__qualname__ == 'UUID' — same rationale. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-09."
    - "uuid.NAMESPACE_OID.__class__.__qualname__ == 'UUID' — same rationale. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-09."
    - "uuid.UUID.__module__ == 'uuid' — extra3 does not cover this for UUID class directly via __eq__; extra covers it but as metadata not as a __eq__ chain invariant. Verifying it as a standalone in extra15 namespace is a fresh invariant ID."
    - "uuid.uuid3.__qualname__ == 'uuid3' — extra5 covers this in a table; standalone invariant from extra15 namespace is a distinct spec artifact with its own ID."
    - "uuid.uuid5.__qualname__ == 'uuid5' — same rationale as uuid3."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NAMESPACE_DNS / NAMESPACE_URL / NAMESPACE_OID __class__.__qualname__
#
# All prior uuid specs that check NAMESPACE_* class identity use __class__.__name__.
# No prior spec checks __class__.__qualname__ on any NAMESPACE object.
# For a top-level class UUID, __qualname__ == __name__ == 'UUID', but the
# attribute chain is distinct. All three namespaces are UUID instances.
# Verified: uuid.NAMESPACE_DNS.__class__.__qualname__ == 'UUID'.
# ---------------------------------------------------------------------------

table uuid_extra15.namespace_class_qualnames:
  description: "NAMESPACE_DNS/URL/OID __class__.__qualname__ == 'UUID' — distinct from __class__.__name__"
  kind: python_call_eq
  category: namespace_metadata
  id_prefix: nsclsqname15

  columns: [id, function, args, expected]
  rows:
    - [NAMESPACE_DNS, NAMESPACE_DNS.__class__.__qualname__.__eq__, ["UUID"], true]
    - [NAMESPACE_URL, NAMESPACE_URL.__class__.__qualname__.__eq__, ["UUID"], true]
    - [NAMESPACE_OID, NAMESPACE_OID.__class__.__qualname__.__eq__, ["UUID"], true]

# ---------------------------------------------------------------------------
# UUID.__module__ == 'uuid' — standalone invariant from extra15 namespace
#
# uuid_extra.zspec.zsdl notes UUID.__module__ as metadata. No prior spec
# expresses this as a python_call_eq invariant with __module__.__eq__('uuid')
# on the UUID class itself. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra15.UUID.module_eq:
  description: "uuid.UUID.__module__ == 'uuid'"
  category: class_metadata
  kind: python_call_eq
  function: UUID.__module__.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid3.__qualname__ == 'uuid3' — standalone from extra15 namespace
#
# uuid_extra5 covers uuid3.__qualname__.__eq__('uuid3') in a table row.
# This standalone invariant re-expresses the same fact from the extra15
# namespace with a distinct invariant ID, providing an independent cross-check.
# Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra15.uuid3.qualname_eq:
  description: "uuid.uuid3.__qualname__ == 'uuid3'"
  category: factory_metadata
  kind: python_call_eq
  function: uuid3.__qualname__.__eq__
  args: ["uuid3"]
  expected: true

# ---------------------------------------------------------------------------
# uuid5.__qualname__ == 'uuid5' — standalone from extra15 namespace
#
# uuid_extra5 covers uuid5.__qualname__.__eq__('uuid5') in a table row.
# This standalone invariant re-expresses the same fact from the extra15
# namespace with a distinct invariant ID, providing an independent cross-check.
# Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra15.uuid5.qualname_eq:
  description: "uuid.uuid5.__qualname__ == 'uuid5'"
  category: factory_metadata
  kind: python_call_eq
  function: uuid5.__qualname__.__eq__
  args: ["uuid5"]
  expected: true
