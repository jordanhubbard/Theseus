    - ["th2836012", "threading.Event.__dict__.__contains__",            ["__rfloordiv__"], false]
    - ["th2836013", "threading.Condition.__dict__.__contains__",        ["__rfloordiv__"], false]
    - ["th2836014", "threading.Semaphore.__dict__.__contains__",        ["__rfloordiv__"], false]
    - ["th2836015", "threading.BoundedSemaphore.__dict__.__contains__", ["__rfloordiv__"], false]
    - ["th2836016", "threading.Timer.__dict__.__contains__",            ["__rfloordiv__"], false]
    - ["th2836017", "threading.Barrier.__dict__.__contains__",          ["__rfloordiv__"], false]
    - ["th2836018", "threading.local.__dict__.__contains__",            ["__rfloordiv__"], false]

# ---------------------------------------------------------------------------
# Table 3: __rmod__ dict-presence (reflected modulo)
#
# None of the threading types define __rmod__ — modulo/remainder has no
# meaning for thread synchronization or thread-local storage objects.
# ---------------------------------------------------------------------------

table threading_extra2836.rmod_protocol:
  description: "threading types __rmod__ dict-presence checks — all False (no reflected modulo protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2836
  columns: [id, function, args, expected]
  rows:
    - ["th2836019", "threading.Thread.__dict__.__contains__",           ["__rmod__"], false]
    - ["th2836020", "threading.Lock.__dict__.__contains__",             ["__rmod__"], false]
    - ["th2836021", "threading.Event.__dict__.__contains__",            ["__rmod__"], false]
    - ["th2836022", "threading.Condition.__dict__.__contains__",        ["__rmod__"], false]
    - ["th2836023", "threading.Semaphore.__dict__.__contains__",        ["__rmod__"], false]
