# ---------------------------------------------------------------------------
# Table 4: combined reflected division/modulo operator absence — all types, all ops
#
# Cross-check: each threading type lacks all three reflected division/modulo operators.
# Confirms that the threading API is a synchronization surface only — mutual
# exclusion, signaling, and phase barriers have no numeric division/modulo protocol.
# ---------------------------------------------------------------------------

table threading_extra2836.reflected_divmod_absent:
