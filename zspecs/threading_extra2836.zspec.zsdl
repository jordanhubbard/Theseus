spec: threading_extra2836
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "any proprietary source"
    - "zspecs/threading_extra2821.zspec.zsdl — wave 635 predecessor (__radd__, __rsub__, __rmul__)"
  notes:
    - "Wave 636 (_extra2836): __rtruediv__, __rfloordiv__, and __rmod__ dict-presence checks (reflected true division, floor division, modulo)."
    - "threading.Thread does NOT define __rtruediv__, __rfloordiv__, or __rmod__ — thread lifecycle management has no numeric arithmetic semantics."
    - "threading.Lock (alias for _thread.lock) does NOT define these operators — it is a mutex primitive with acquire/release only."
    - "threading.Event does NOT define these operators — it is a flag-based synchronization primitive."
    - "threading.Condition does NOT define these operators — it is a monitor-style synchronization primitive."
    - "threading.Semaphore does NOT define these operators — it is a counting semaphore, not a numeric type."
    - "threading.BoundedSemaphore does NOT define these operators — same rationale as Semaphore."
    - "threading.Timer does NOT define these operators — it is a Thread subclass for delayed execution."
    - "threading.Barrier does NOT define these operators — it is a phase synchronization barrier."
    - "threading.local does NOT define these operators — it provides thread-local storage, not numeric values."
    - "Reflected operators (__rtruediv__, __rfloordiv__, __rmod__) are invoked when the left operand does not support the operation; synchronization primitives have no arithmetic role."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __rtruediv__ dict-presence (reflected true division)
#
# threading.Thread, Lock, Event, Condition, Semaphore — none define __rtruediv__.
# Synchronization primitives have no numeric true division semantics.
# ---------------------------------------------------------------------------

table threading_extra2836.rtruediv_protocol:
  description: "threading types __rtruediv__ dict-presence checks — all False (no reflected true division protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2836
  columns: [id, function, args, expected]
  rows:
    - ["th2836001", "threading.Thread.__dict__.__contains__",           ["__rtruediv__"], false]
    - ["th2836002", "threading.Lock.__dict__.__contains__",             ["__rtruediv__"], false]
    - ["th2836003", "threading.Event.__dict__.__contains__",            ["__rtruediv__"], false]
    - ["th2836004", "threading.Condition.__dict__.__contains__",        ["__rtruediv__"], false]
    - ["th2836005", "threading.Semaphore.__dict__.__contains__",        ["__rtruediv__"], false]
    - ["th2836006", "threading.BoundedSemaphore.__dict__.__contains__", ["__rtruediv__"], false]
    - ["th2836007", "threading.Timer.__dict__.__contains__",            ["__rtruediv__"], false]
    - ["th2836008", "threading.Barrier.__dict__.__contains__",          ["__rtruediv__"], false]
    - ["th2836009", "threading.local.__dict__.__contains__",            ["__rtruediv__"], false]

