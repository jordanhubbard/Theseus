spec: slug
version: ">=5.0.0"
backend: node(slug)

docs: https://www.npmjs.com/package/slug

provenance:
  derived_from:
    - "slug README — https://www.npmjs.com/package/slug"
    - "Test vectors verified with slug@5.3.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "slug source"
  notes:
    - "slug is an npm package. Install: npm install slug@5"
    - "slug@6+ is ESM-only; slug@5 is CJS-compatible."
    - "slug(str) converts a string to a URL-safe slug (lowercase, hyphens)."
    - "Transliterates accented characters to ASCII equivalents."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns URL-safe slug string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table slug.slug:
  kind: node_module_call_eq
  function: ~
  category: slug
  id_prefix: slg

  columns: [id, args, expected]
  rows:
    - [basic,     ["Hello World"],         "hello-world"]
    - [ampersand, ["foo & bar"],           "foo-bar"]
    - [sentence,  ["The quick brown fox"], "the-quick-brown-fox"]
    - [accents,   ["Héllo Wörld"],         "hello-world"]
    - [spaces,    ["  spaces  "],          "spaces"]
