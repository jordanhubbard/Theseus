spec: uuid_extra121
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__ code attributes (co_name, co_argcount) / UUID.__str__/__repr__ method qualname equality and length / UUID.__eq__/__hash__/__lt__ method qualname equality and length (table + invariants)."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants (NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500) __class__.__name__, hex values, str() values, version attributes (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality / property qualname lengths / type(UUID.hex).__name__=='property' (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__/__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length (table + invariants)."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID enum member values / UUID property fget qualname lengths (table + invariants)."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / uuid3/uuid5/getnode qualname lengths / SafeUUID metaclass/module/MRO depth (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior uuid spec files."
    - "Wave 271 theme: uuid module — uuid6/uuid7/uuid8 function identity (Python 3.14 additions) / uuid.NIL and uuid.MAX sentinel UUID identity (nil/max UUIDs)."
    - "uuid.uuid6.__name__ == 'uuid6'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid7.__name__ == 'uuid7'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid8.__name__ == 'uuid8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid6.__qualname__ == 'uuid6'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid7.__qualname__ == 'uuid7'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid8.__qualname__ == 'uuid8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid6.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid7.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid8.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid6.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid7.__code__.co_argcount == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid8.__code__.co_argcount == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.NIL).__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.MAX).__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NIL.hex == '00000000000000000000000000000000'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.MAX.hex == 'ffffffffffffffffffffffffffffffff'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NIL.hex.__len__() == 32. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.MAX.hex.__len__() == 32. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid6.__code__.co_name == 'uuid6'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid7.__code__.co_name == 'uuid7'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid8.__code__.co_name == 'uuid8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.uuid6, uuid.uuid7, uuid.uuid8 are added in Python 3.14 (RFC 9562 UUIDs). uuid7 has 0 positional args (takes only keyword-or-positional with default None). uuid8 has 3 args (hi, mid, lo custom fields). uuid6 has 2 args (node, clock_seq) like uuid1."
    - "Note: uuid.NIL and uuid.MAX are UUID sentinel constants (nil = all-zeros, max = all-ones) defined in uuid.py. NIL.version is None because a nil UUID has no defined version. MAX.version is also None."
    - "Note: uuid module has no __all__ attribute (confirmed by hasattr check). The uuid6/uuid7/uuid8 functions and NIL/MAX constants are accessed directly as module attributes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid6.__name__.__eq__('uuid6')
# uuid.uuid7.__name__.__eq__('uuid7')
# uuid.uuid8.__name__.__eq__('uuid8')
# uuid.uuid6.__qualname__.__eq__('uuid6')
# uuid.uuid7.__qualname__.__eq__('uuid7')
#
# Wave 271 theme: uuid6/uuid7/uuid8 function name and qualname identity.
#
# uuid6, uuid7, uuid8 are Python functions added in Python 3.14 implementing
# RFC 9562 time-ordered and custom UUIDs. Like uuid1/uuid3/uuid4/uuid5 (anchored
# in extra86/96), each new function's __name__ and __qualname__ equal its own
# identifier (top-level function, no class prefix). uuid8 is unusual in having
# 3 positional args (hi, mid, lo). No prior uuid spec anchors uuid6/uuid7/uuid8
# identity under uuidv678_121. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra121.uuid678_name_qualname:
  description: "uuid.uuid6/__name__.__eq__('uuid6')==True / uuid7/__name__.__eq__('uuid7')==True / uuid8/__name__.__eq__('uuid8')==True / uuid6/__qualname__.__eq__('uuid6')==True / uuid7/__qualname__.__eq__('uuid7')==True — uuid6/7/8 are RFC 9562 functions added in Python 3.14; __name__==__qualname__ for top-level functions; extra86/96 anchor uuid1/3/4/5 identity; no prior uuid spec anchors uuid6/7/8; first uuidv678_121 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidv678_121

  columns: [id, function, args, expected, description]
  rows:
    - [uuid6_name,     uuid6.__name__.__eq__,     ["uuid6"], true, "uuid6.__name__ is 'uuid6' (RFC 9562 time-ordered UUID v6, reorders uuid1 fields)"]
    - [uuid7_name,     uuid7.__name__.__eq__,     ["uuid7"], true, "uuid7.__name__ is 'uuid7' (RFC 9562 Unix timestamp UUID v7, 0 positional args)"]
    - [uuid8_name,     uuid8.__name__.__eq__,     ["uuid8"], true, "uuid8.__name__ is 'uuid8' (RFC 9562 custom UUID v8, 3 positional args hi/mid/lo)"]
    - [uuid6_qualname, uuid6.__qualname__.__eq__,  ["uuid6"], true, "uuid6.__qualname__ is 'uuid6' (top-level function, no class prefix)"]
    - [uuid7_qualname, uuid7.__qualname__.__eq__,  ["uuid7"], true, "uuid7.__qualname__ is 'uuid7' (top-level function, no class prefix)"]

# ---------------------------------------------------------------------------
# uuid.uuid8.__qualname__.__eq__('uuid8')
# uuid.uuid6.__module__.__eq__('uuid')
# uuid.uuid7.__module__.__eq__('uuid')
# uuid.uuid8.__module__.__eq__('uuid')
# uuid.uuid6.__code__.co_argcount.__eq__(2)
# uuid.uuid7.__code__.co_argcount.__eq__(0)
# uuid.uuid8.__code__.co_argcount.__eq__(3)
#
# Wave 271 theme: uuid6/uuid7/uuid8 module and co_argcount.
#
# All three functions are pure Python, defined in Lib/uuid.py, with __module__=='uuid'.
# Their co_argcount values differ by design: uuid6 has 2 (node, clock_seq, like uuid1),
# uuid7 has 0 (no positional args; takes millisecond-precision Unix timestamp from
# time.time()), uuid8 has 3 (hi, mid, lo — custom 48/12/62-bit fields per RFC 9562).
# No prior uuid spec anchors these three functions' module or co_argcount values
# under uuidv678_121. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra121.uuid678_module_co_argcount:
  description: "uuid8/__qualname__.__eq__('uuid8')==True / uuid6/__module__.__eq__('uuid')==True / uuid7/__module__.__eq__('uuid')==True / uuid8/__module__.__eq__('uuid')==True / uuid6/__code__/co_argcount.__eq__(2)==True / uuid7/__code__/co_argcount.__eq__(0)==True / uuid8/__code__/co_argcount.__eq__(3)==True — uuid6/7/8 are pure Python functions in Lib/uuid.py; co_argcount differs: uuid6=2 (node/clock_seq), uuid7=0 (no args), uuid8=3 (hi/mid/lo); first uuidv678_121 anchor for module and co_argcount"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidv678_121

  columns: [id, function, args, expected, description]
  rows:
    - [uuid8_qualname,       uuid8.__qualname__.__eq__,             ["uuid8"], true, "uuid8.__qualname__ is 'uuid8' (top-level function, no class prefix)"]
    - [uuid6_module,         uuid6.__module__.__eq__,               ["uuid"],  true, "uuid6.__module__ is 'uuid' (defined in Lib/uuid.py)"]
    - [uuid7_module,         uuid7.__module__.__eq__,               ["uuid"],  true, "uuid7.__module__ is 'uuid' (defined in Lib/uuid.py)"]
    - [uuid8_module,         uuid8.__module__.__eq__,               ["uuid"],  true, "uuid8.__module__ is 'uuid' (defined in Lib/uuid.py)"]
    - [uuid6_co_argcount,    "uuid6.__code__.co_argcount.__eq__",   [2],       true, "uuid6 co_argcount is 2 (node, clock_seq — same signature pattern as uuid1)"]
    - [uuid7_co_argcount,    "uuid7.__code__.co_argcount.__eq__",   [0],       true, "uuid7 co_argcount is 0 (no positional args; timestamp comes from time.time())"]
    - [uuid8_co_argcount,    "uuid8.__code__.co_argcount.__eq__",   [3],       true, "uuid8 co_argcount is 3 (hi=48-bit, mid=12-bit, lo=62-bit custom fields per RFC 9562)"]

# ---------------------------------------------------------------------------
# uuid.NIL.__class__.__name__.__eq__('UUID')
# uuid.MAX.__class__.__name__.__eq__('UUID')
# uuid.NIL.hex.__eq__('00000000000000000000000000000000')
# uuid.MAX.hex.__eq__('ffffffffffffffffffffffffffffffff')
# uuid.NIL.hex.__len__()==32
# uuid.MAX.hex.__len__()==32
#
# Wave 271 theme: uuid.NIL and uuid.MAX sentinel UUID identity.
#
# uuid.NIL is the nil UUID (all-zeros, 32 hex zeros), and uuid.MAX is the max UUID
# (all-ones, 32 hex 'f's). Both are UUID instances (type name 'UUID'). Their hex
# attributes are 32-char strings without hyphens. uuid_extra98 anchors the four
# NAMESPACE constants (__class__.__name__, hex, str, version); this table first
# anchors NIL and MAX sentinel identity under uuidv678_121. Both have version==None
# since nil/max UUIDs have no defined RFC version.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra121.NIL_MAX_identity:
  description: "uuid.NIL/__class__.__name__.__eq__('UUID')==True / MAX/__class__.__name__.__eq__('UUID')==True / NIL/hex/__eq__('00000000000000000000000000000000')==True / MAX/hex/__eq__('ffffffffffffffffffffffffffffffff')==True / NIL/hex/__len__()==32 / MAX/hex/__len__()==32 — NIL (all-zeros) and MAX (all-ones) are UUID sentinel instances; hex is 32 chars (no hyphens); extra98 anchors NAMESPACE constants; first uuidv678_121 anchor for NIL/MAX identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidv678_121

  columns: [id, function, args, expected, description]
  rows:
    - [nil_class_name,   "NIL.__class__.__name__.__eq__",  ["UUID"],                              true, "uuid.NIL is a UUID instance (all-zeros nil UUID, RFC 9562)"]
    - [max_class_name,   "MAX.__class__.__name__.__eq__",  ["UUID"],                              true, "uuid.MAX is a UUID instance (all-ones max UUID, RFC 9562)"]
    - [nil_hex_eq,       "NIL.hex.__eq__",                 ["00000000000000000000000000000000"],   true, "NIL.hex is 32 zero hex chars (nil UUID with no version or variant)"]
    - [max_hex_eq,       "MAX.hex.__eq__",                 ["ffffffffffffffffffffffffffffffff"],   true, "MAX.hex is 32 'f' hex chars (all-bits-set maximum UUID)"]
    - [nil_hex_len,      NIL.hex.__len__,                  [],                                    32,   "NIL.hex length is 32 (UUID hex always 32 chars without hyphens)"]
    - [max_hex_len,      MAX.hex.__len__,                  [],                                    32,   "MAX.hex length is 32 (UUID hex always 32 chars without hyphens)"]

# ---------------------------------------------------------------------------
# uuid.uuid6.__module__.__eq__('uuid') — standalone
#
# uuid.uuid6.__module__ is 'uuid'. uuid6 is a pure Python function defined in
# Lib/uuid.py implementing the RFC 9562 time-ordered UUID version 6 — a reordering
# of the uuid1 fields to make UUIDs lexicographically sortable by timestamp.
# Like uuid1/3/4/5 (anchored in extra86), uuid6 has __module__=='uuid'. No prior
# uuid spec anchors uuid6.__module__.__eq__ as a standalone under uuidv678_121.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra121.uuid6_module_uuid:
  description: "uuid.uuid6.__module__.__eq__('uuid') == True — uuid6 is a pure Python function in Lib/uuid.py implementing RFC 9562 time-ordered UUID v6 (reordered uuid1 fields for lexicographic timestamp sorting); __module__=='uuid' like uuid1/3/4/5; extra86 anchors uuid1-5 module; first standalone for uuid6.__module__ under uuidv678_121"
  category: function_identity
  kind: python_call_eq
  function: uuid6.__module__.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid7.__code__.co_argcount.__eq__(0) — standalone
#
# uuid.uuid7.__code__.co_argcount is 0. uuid7 is the RFC 9562 Unix timestamp
# UUID version 7. It takes no positional arguments — the timestamp is derived
# internally from time.time_ns() (millisecond precision). This contrasts with
# uuid6 (co_argcount=2: node, clock_seq) and uuid8 (co_argcount=3: hi, mid, lo).
# co_argcount of 0 is also different from uuid4 (co_argcount=0 was not checked).
# No prior uuid spec anchors uuid7.__code__.co_argcount as a standalone under
# uuidv678_121. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra121.uuid7_co_argcount_0:
  description: "uuid.uuid7.__code__.co_argcount.__eq__(0) == True — uuid7 (RFC 9562 Unix-timestamp UUID v7) takes 0 positional args; timestamp derived from time.time_ns() internally; contrasts with uuid6 (2 args) and uuid8 (3 args); first standalone for uuid7 co_argcount under uuidv678_121"
  category: function_identity
  kind: python_call_eq
  function: "uuid7.__code__.co_argcount.__eq__"
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NIL.__class__.__name__.__eq__('UUID') — standalone
#
# uuid.NIL.__class__.__name__ is 'UUID'. NIL is the nil UUID (RFC 4122 Section 4.1.7
# and RFC 9562), representing the all-zeros UUID constant
# '00000000-0000-0000-0000-000000000000'. It is a UUID instance stored as a
# module-level constant in Lib/uuid.py. uuid_extra98 anchors the NAMESPACE_*
# constants as UUID instances; this spec first anchors NIL.__class__.__name__
# as a standalone under uuidv678_121. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra121.NIL_class_UUID:
  description: "uuid.NIL.__class__.__name__.__eq__('UUID') == True — NIL is the all-zeros nil UUID (RFC 9562), a UUID instance stored as a module-level constant; extra98 anchors NAMESPACE_* as UUID instances; first standalone for NIL.__class__.__name__ under uuidv678_121"
  category: type_identity
  kind: python_call_eq
  function: "NIL.__class__.__name__.__eq__"
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NIL.hex.__len__() == 32 — standalone
#
# uuid.NIL.hex.__len__() is 32. The hex property of a UUID always returns a
# 32-character hexadecimal string (128 bits = 32 hex digits) without hyphens.
# For NIL, this is 32 zero characters ('00...0'). The hex string is a fixed
# 32-char string regardless of the UUID version. uuid_extra98 anchors
# NAMESPACE_DNS.hex.__len__()==32; this spec first anchors NIL.hex.__len__()
# as a standalone under uuidv678_121. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra121.NIL_hex_len_32:
  description: "uuid.NIL.hex.__len__() == 32 — UUID.hex always returns 32 hex chars (128 bits, no hyphens); NIL hex is 32 zeros; extra98 anchors NAMESPACE_DNS.hex.__len__()==32; first standalone for NIL.hex.__len__() under uuidv678_121"
  category: type_identity
  kind: python_call_eq
  function: NIL.hex.__len__
  args: []
  expected: 32

# ---------------------------------------------------------------------------
# uuid.MAX.__class__.__name__.__eq__('UUID') — standalone
#
# uuid.MAX.__class__.__name__ is 'UUID'. MAX is the max UUID (RFC 9562 Section 5.10),
# representing the all-ones UUID constant 'ffffffff-ffff-ffff-ffff-ffffffffffff'.
# It is a UUID instance stored as a module-level constant in Lib/uuid.py. Like
# NIL, its version property is None because no RFC-defined version corresponds
# to the all-ones UUID. No prior uuid spec anchors MAX.__class__.__name__.__eq__
# as a standalone under uuidv678_121. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra121.MAX_class_UUID:
  description: "uuid.MAX.__class__.__name__.__eq__('UUID') == True — MAX is the all-ones max UUID (RFC 9562 Section 5.10), a UUID instance; version is None (no RFC version for all-ones UUID); no prior uuid spec anchors MAX.__class__.__name__ as standalone; first standalone for MAX identity under uuidv678_121"
  category: type_identity
  kind: python_call_eq
  function: "MAX.__class__.__name__.__eq__"
  args: ["UUID"]
  expected: true
