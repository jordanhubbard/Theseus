spec: threading_extra201
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra.zspec.zsdl — covers class_modules (BoundedSemaphore, Condition, Semaphore, Event, RLock), local.__name__/__module__, current_thread class name is str, get_ident returns int, TIMEOUT_MAX is float, stack_size returns int"
    - "threading_extra200.zspec.zsdl — covers threading_extra200 series"
  notes:
    - "This spec covers __doc__.__class__.__name__ identity for public threading classes and functions: Thread, Event, Condition, Semaphore, Barrier, Timer, local, current_thread."
    - "threading.Thread.__doc__.__class__.__name__ == 'str' — Thread is a Python class with a string docstring. Verified with Python 3.14.3."
    - "threading.Event.__doc__.__class__.__name__ == 'str' — Event is a Python class with a string docstring. Verified with Python 3.14.3."
    - "threading.Condition.__doc__.__class__.__name__ == 'str' — Condition is a Python class with a string docstring. Verified with Python 3.14.3."
    - "threading.Semaphore.__doc__.__class__.__name__ == 'str' — Semaphore is a Python class with a string docstring. Verified with Python 3.14.3."
    - "threading.Barrier.__doc__.__class__.__name__ == 'str' — Barrier is a Python class with a string docstring. Verified with Python 3.14.3."
    - "threading.Timer.__doc__.__class__.__name__ == 'str' — Timer is a Python class (Thread subclass) with a string docstring. Verified with Python 3.14.3."
    - "threading.local.__doc__.__class__.__name__ == 'str' — local is a C-level type (_thread.local) with a string docstring. Verified with Python 3.14.3."
    - "threading.current_thread.__doc__.__class__.__name__ == 'str' — current_thread is a Python function with a string docstring. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __doc__.__class__.__name__ for core threading synchronization classes
#
# Thread, Event, Condition: core Python threading classes.
# All have non-None string docstrings; __class__.__name__ is 'str'.
# ---------------------------------------------------------------------------

table threading_extra201.doc_class_core_classes:
  description: "threading core classes: Thread, Event, Condition __doc__.__class__.__name__=='str'; new to extra201"
  kind: python_call_eq
  category: doc_class_identity
  id_prefix: threadingdocs201

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_doc_class_str,
       Thread.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Thread.__doc__.__class__.__name__.__eq__('str') == True — Thread is the base Python threading class; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra201"]
    - [Event_doc_class_str,
       Event.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Event.__doc__.__class__.__name__.__eq__('str') == True — Event is a Python synchronization primitive class; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra201"]
    - [Condition_doc_class_str,
       Condition.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Condition.__doc__.__class__.__name__.__eq__('str') == True — Condition is a Python synchronization primitive class; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra201"]

