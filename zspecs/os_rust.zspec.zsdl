spec: os_rust
version: ">=3.9"
backend: rust_module(os_rust)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os documentation"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
  notes:
    - "Clean-room Rust reimplementation of Python os module constants, exposed via PyO3."
    - "Targets POSIX systems (Linux, macOS): sep='/', pathsep=':', name='posix'."
    - "sep == '/' — path separator (forward slash on POSIX)."
    - "pathsep == ':' — PATH separator (colon on POSIX)."
    - "devnull == '/dev/null' — null device path on POSIX."
    - "curdir == '.' — current directory symbol."
    - "pardir == '..' — parent directory symbol."
    - "extsep == '.' — extension separator."
    - "linesep == '\\n' — line separator (LF on POSIX; CRLF on Windows)."
    - "name == 'posix' — OS family name on POSIX systems."
    - "All test vectors verified against Python 3.14.3 os module on POSIX."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# POSIX path and OS constants
table os_rust.constants.path:
  kind: python_call_eq
  category: constants
  id_prefix: os_const

  columns: [id, function, args, expected]
  rows:
    - [sep,     sep.__eq__,     ["/"],         true]
    - [pathsep, pathsep.__eq__, [":"],         true]
    - [curdir,  curdir.__eq__,  ["."],         true]
    - [pardir,  pardir.__eq__,  [".."],        true]
    - [extsep,  extsep.__eq__,  ["."],         true]
    - [devnull, devnull.__eq__, ["/dev/null"], true]
    - [name,    name.__eq__,    ["posix"],     true]

# linesep — LF on POSIX
invariant os_rust.linesep:
  description: "os.linesep == '\\n' on POSIX"
  category: constants
  kind: python_call_eq
  function: linesep.__eq__
  args: ["\n"]
  expected: true

# sep, curdir, pardir via __len__ for additional verification
table os_rust.constants.lengths:
  kind: python_call_eq
  category: constants
  id_prefix: os_len

  columns: [id, function, args, expected]
  rows:
    - [sep_len,    sep.__len__,    [], 1]
    - [curdir_len, curdir.__len__, [], 1]
    - [pardir_len, pardir.__len__, [], 2]
    - [extsep_len, extsep.__len__, [], 1]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T21:05:46Z
  iterations: 1
  pass_count: 12
  fail_count: 0
  total_invariants: 12
  notes: Synthesis succeeded in 1 iteration(s). 12 invariants passing.
  infeasible_reason: null
