spec: struct_extra1381
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "Wave 539 (_extra1381): focuses on __abstractmethods__ frozenset checks."
    - "struct.Struct is a C extension type implementing the compiled struct API; it defines no abstract methods, so struct.Struct.__dict__.__contains__('__abstractmethods__') returns False."
    - "struct.error is a concrete exception class inheriting from Exception; it defines no abstract methods, so struct.error.__dict__.__contains__('__abstractmethods__') returns False."
    - "frozenset is the type that __abstractmethods__ would be assigned to on abstract classes; frozenset.__class__.__name__ == 'type' (frozenset's metaclass is type)."
    - "frozenset.__bases__.__class__.__name__ == 'tuple' — the bases attribute of any class is always a tuple."
    - "struct.Struct.__dict__.__class__.__name__ == 'mappingproxy' — all Python class __dict__ attributes are mappingproxy instances."
    - "struct.error.__dict__.__class__.__name__ == 'mappingproxy' — same property holds for exception subclasses."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table struct_extra1381.struct_class_abstractmethods_absent:
  description: "struct.Struct class dict does not contain __abstractmethods__ — Struct is a concrete C extension type with no abstract methods; __dict__.__contains__ returns False"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: st1381sa
  columns: [id, function, args, expected]
  rows:
    - [st1381sa001, struct.Struct.__dict__.__contains__,             ["__abstractmethods__"], false]
    - [st1381sa002, struct.error.__dict__.__contains__,              ["__abstractmethods__"], false]
    - [st1381sa003, struct.Struct.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [st1381sa004, struct.error.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true]
    - [st1381sa005, struct.Struct.__mro__.__class__.__name__.__eq__, ["tuple"], true]
    - [st1381sa006, struct.error.__mro__.__class__.__name__.__eq__,  ["tuple"], true]

table struct_extra1381.frozenset_abstractmethods_type_checks:
  description: "frozenset (the type __abstractmethods__ would be set to on abstract classes) class-level checks; frozenset.__class__.__name__ == 'type' and frozenset.__bases__.__class__.__name__ == 'tuple'"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: st1381fa
  columns: [id, function, args, expected]
  rows:
    - [st1381fa001, frozenset.__class__.__name__.__eq__,            ["type"],         true]
    - [st1381fa002, frozenset.__bases__.__class__.__name__.__eq__,  ["tuple"],        true]
    - [st1381fa003, frozenset.__name__.__class__.__name__.__eq__,   ["str"],          true]
    - [st1381fa004, frozenset.__dict__.__contains__,                 ["__abstractmethods__"], false]
    - [st1381fa005, frozenset.__dict__.__class__.__name__.__eq__,   ["mappingproxy"], true]
    - [st1381fa006, frozenset.__mro__.__class__.__name__.__eq__,    ["tuple"],        true]

table struct_extra1381.struct_error_bases_and_class_name_checks:
  description: "struct.Struct and struct.error __bases__ and __class__.__name__ cross-checks; verifies the inheritance structure attributes are consistent with the abstractmethods theme"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: st1381bc
  columns: [id, function, args, expected]
  rows:
    - [st1381bc001, struct.Struct.__bases__.__class__.__name__.__eq__,  ["tuple"],  true]
    - [st1381bc002, struct.error.__bases__.__class__.__name__.__eq__,   ["tuple"],  true]
    - [st1381bc003, struct.Struct.__class__.__name__.__eq__,            ["type"],   true]
    - [st1381bc004, struct.error.__class__.__name__.__eq__,             ["type"],   true]
    - [st1381bc005, struct.Struct.__name__.__class__.__name__.__eq__,   ["str"],    true]
    - [st1381bc006, struct.error.__name__.__class__.__name__.__eq__,    ["str"],    true]
