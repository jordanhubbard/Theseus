spec: tz_lookup
version: ">=1.0.0"
backend: node(tz-lookup)

docs: https://www.npmjs.com/package/tz-lookup

provenance:
  derived_from:
    - "tz-lookup README — https://www.npmjs.com/package/tz-lookup"
    - "Test vectors verified with tz-lookup via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "tz-lookup source"
  notes:
    - "tz-lookup is an npm package. Install: npm install tz-lookup"
    - "tzlookup(lat, lng) returns the IANA timezone name for the given coordinates."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns IANA timezone name string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table tz_lookup.tzlookup:
  kind: node_module_call_eq
  function: ~
  category: lookup
  id_prefix: tzl

  columns: [id, args, expected]
  rows:
    - [new_york, [42.7235, -73.6931], "America/New_York"]
    - [paris,    [48.8567, 2.3508],   "Europe/Paris"]
    - [tokyo,    [35.6895, 139.6917], "Asia/Tokyo"]
