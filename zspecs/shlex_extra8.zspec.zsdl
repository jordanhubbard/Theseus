spec: shlex_extra8
version: ">=3.8"
backend: python_module(shlex)

docs: https://docs.python.org/3/library/shlex.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shlex.html — Python shlex module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/shlex.py"
    - "shlex_extra7.zspec.zsdl — covers split('hello world')==['hello','world']; split('hello \"world foo\"')==['hello','world foo']; split(\"it's fine\") raises ValueError; quote('hello')=='hello'; quote('hello world')==\"'hello world'\"; quote(\"it's\")==\"'it'\\\"'\\\"'s'\"."
    - "shlex_extra6.zspec.zsdl — covers shlex instance attrs (quotes, commenters, escape, token, eof, debug, whitespace_split, punctuation_chars); split backslash-escaped space; quote forward-slash; quote underscore+dot."
  notes:
    - "This spec extends shlex_extra7.zspec.zsdl."
    - "Prior specs covered: behavioral split/quote/join vectors; shlex instance attribute types; __mro__/__bases__/__dict__ structure from earlier specs."
    - "This spec covers NEW angles: shlex.__all__.__len__()==4; shlex.__all__.__class__.__name__.__len__()==4 ('list'); shlex.__name__.__len__()==5; shlex.__doc__.__class__.__name__.__len__()==3 ('str'); shlex.shlex.__dict__.__class__.__name__.__len__()==12 ('mappingproxy'); shlex.shlex.__mro__.__len__()==2; shlex.shlex.__bases__[0].__name__.__len__()==6 ('object'); shlex.shlex.__qualname__.__len__()==5; shlex.shlex method __qualname__.__len__() for read_token(16)/get_token(15)/push_token(16)/push_source(17)/pop_source(16)/sourcehook(16)/error_leader(18)/__init__(14); split(5)/join(4)/quote(5) __qualname__.__len__(); shlex.join(['hello','world'])=='hello world'."
    - "shlex.__all__ == ['shlex', 'split', 'quote', 'join'] (len 4). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "shlex.shlex.__mro__ == [shlex.shlex, object] — len 2. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "shlex.shlex.__qualname__ == 'shlex' (len 5) — qualname equals the class name, not the module path. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "shlex.shlex.read_token.__qualname__ == 'shlex.read_token' (len 16). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "shlex.shlex.get_token.__qualname__ == 'shlex.get_token' (len 15). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "shlex.shlex.push_token.__qualname__ == 'shlex.push_token' (len 16). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "shlex.shlex.push_source.__qualname__ == 'shlex.push_source' (len 17). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "shlex.shlex.pop_source.__qualname__ == 'shlex.pop_source' (len 16). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "shlex.shlex.sourcehook.__qualname__ == 'shlex.sourcehook' (len 16). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "shlex.shlex.error_leader.__qualname__ == 'shlex.error_leader' (len 18). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "shlex.shlex.__init__.__qualname__ == 'shlex.__init__' (len 14). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "shlex.join(['hello', 'world']) == 'hello world' (len 11). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# shlex module-level membership: __all__, __name__, __doc__ class name
#
# No prior spec checks __all__.__len__(), __all__.__class__.__name__.__len__(),
# __name__.__len__(), or __doc__.__class__.__name__.__len__() for shlex.
# shlex.__all__ == ['shlex', 'split', 'quote', 'join'] (len 4, class 'list').
# shlex.__name__ == 'shlex' (len 5). shlex.__doc__ is a str (len 3).
# ---------------------------------------------------------------------------

invariant shlex_extra8.all.len:
  description: "shlex.__all__.__len__() == 4 — four public names: shlex, split, quote, join"
  category: module_membership
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 4

invariant shlex_extra8.all.class.name.len:
  description: "shlex.__all__.__class__.__name__.__len__() == 4 — __all__ is a 'list'"
  category: module_membership
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

invariant shlex_extra8.module.name.len:
  description: "shlex.__name__.__len__() == 5 — module name 'shlex' has 5 characters"
  category: module_membership
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 5

invariant shlex_extra8.module.doc.class.name.len:
  description: "shlex.__doc__.__class__.__name__.__len__() == 3 — module docstring is a 'str'"
  category: module_membership
  kind: python_call_eq
  function: __doc__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# shlex.shlex class introspection: __dict__, __mro__, __bases__, __qualname__
#
# shlex.shlex.__dict__.__class__.__name__ == 'mappingproxy' (len 12).
# shlex.shlex.__mro__ has 2 entries: [shlex, object].
# shlex.shlex.__bases__[0].__name__ == 'object' (len 6).
# shlex.shlex.__qualname__ == 'shlex' (len 5) — equals the class name.
# ---------------------------------------------------------------------------

invariant shlex_extra8.shlex.dict.class.name.len:
  description: "shlex.shlex.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy'"
  category: class_introspection
  kind: python_call_eq
  function: shlex.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant shlex_extra8.shlex.mro.len:
  description: "shlex.shlex.__mro__.__len__() == 2 — MRO: [shlex, object]"
  category: class_introspection
  kind: python_call_eq
  function: shlex.__mro__.__len__
  args: []
  expected: 2

invariant shlex_extra8.shlex.bases.name.len:
  description: "shlex.shlex.__bases__[0].__name__.__len__() == 6 — base class is 'object'"
  category: class_introspection
  kind: python_call_eq
  function: "shlex.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant shlex_extra8.shlex.qualname.len:
  description: "shlex.shlex.__qualname__.__len__() == 5 — class qualname 'shlex' has 5 characters"
  category: class_identity
  kind: python_call_eq
  function: shlex.__qualname__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# shlex.join behavioral: join(['hello', 'world']) == 'hello world'
#
# shlex.join is the inverse of shlex.split for simple cases. Joining
# ['hello', 'world'] produces 'hello world' (len 11). This is a new
# behavioral angle not in any prior shlex spec.
# ---------------------------------------------------------------------------

invariant shlex_extra8.join.basic:
  description: "shlex.join(['hello', 'world']) == 'hello world' — basic join produces space-separated string"
  category: join
  kind: python_call_eq
  function: join
  args: [["hello", "world"]]
  expected: "hello world"

# ---------------------------------------------------------------------------
# Table: module-level function __qualname__.__len__() — split, join, quote
#
# No prior spec checks __qualname__.__len__() for split, join, or quote.
# split.__qualname__ == 'split' (len 5); join.__qualname__ == 'join' (len 4);
# quote.__qualname__ == 'quote' (len 5).
# ---------------------------------------------------------------------------

table shlex_extra8.module_function_qualnames:
  description: "shlex module-level function __qualname__.__len__() — split (5), join (4), quote (5)"
  kind: python_call_eq
  category: string_length

  columns: [id, function, args, expected, description]
  rows:
    - [split_qualname_len,
       split.__qualname__.__len__,
       [],
       5,
       "len('split') == 5"]
    - [join_qualname_len,
       join.__qualname__.__len__,
       [],
       4,
       "len('join') == 4"]
    - [quote_qualname_len,
       quote.__qualname__.__len__,
       [],
       5,
       "len('quote') == 5"]

# ---------------------------------------------------------------------------
# Table: shlex.shlex instance method __qualname__.__len__()
#
# No prior spec checks __qualname__.__len__() for any shlex.shlex methods.
# read_token(16), get_token(15), push_token(16), push_source(17),
# pop_source(16), sourcehook(16), error_leader(18), __init__(14).
# ---------------------------------------------------------------------------

table shlex_extra8.shlex_method_qualnames:
  description: "shlex.shlex method __qualname__.__len__() — read_token (16), get_token (15), push_token (16), push_source (17), pop_source (16), sourcehook (16), error_leader (18), __init__ (14)"
  kind: python_call_eq
  category: string_length

  columns: [id, function, args, expected, description]
  rows:
    - [read_token_qualname_len,
       shlex.read_token.__qualname__.__len__,
       [],
       16,
       "len('shlex.read_token') == 16"]
    - [get_token_qualname_len,
       shlex.get_token.__qualname__.__len__,
       [],
       15,
       "len('shlex.get_token') == 15"]
    - [push_token_qualname_len,
       shlex.push_token.__qualname__.__len__,
       [],
       16,
       "len('shlex.push_token') == 16"]
    - [push_source_qualname_len,
       shlex.push_source.__qualname__.__len__,
       [],
       17,
       "len('shlex.push_source') == 17"]
    - [pop_source_qualname_len,
       shlex.pop_source.__qualname__.__len__,
       [],
       16,
       "len('shlex.pop_source') == 16"]
    - [sourcehook_qualname_len,
       shlex.sourcehook.__qualname__.__len__,
       [],
       16,
       "len('shlex.sourcehook') == 16"]
    - [error_leader_qualname_len,
       shlex.error_leader.__qualname__.__len__,
       [],
       18,
       "len('shlex.error_leader') == 18"]
    - [init_qualname_len,
       "shlex.__init__.__qualname__.__len__",
       [],
       14,
       "len('shlex.__init__') == 14"]
