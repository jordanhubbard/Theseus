invariant cx_oracle_rust.has_database_error:
  description: "cx_Oracle.DatabaseError is a class"
  category: presence
  kind: python_call_eq
  function: cx_oracle_has_database_error
  args: []
  expected: true

invariant cx_oracle_rust.version_nonempty:
  description: "cx_Oracle.version is non-empty"
  category: version
  kind: python_call_eq
  function: cx_oracle_version_nonempty
  args: []
  expected: true

