spec: uuid_extra2146
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid.zspec.zsdl — covers UUID construction, hex, str, int, bytes, version, variant attrs"
    - "uuid_extra.zspec.zsdl — covers SafeUUID enum values, uuid1/uuid3/uuid4/uuid5 function names"
    - "uuid_extra2131.zspec.zsdl — covers exception protocol dict-presence wave"
  notes:
    - "Wave (_extra2146): numeric conversion protocol dict-presence — checking __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__ in class __dict__."
    - "uuid.UUID is a pure-Python class using __slots__; it defines __int__ in its __dict__ (returns the UUID integer value), but none of the other numeric conversion dunders."
    - "uuid.SafeUUID is an IntEnum subclass; its own __dict__ does NOT directly contain __int__, __index__, or __bool__ — those are inherited from IntEnum/int ancestors, not stored in SafeUUID.__dict__ itself."
    - "UUID.__dict__ confirmed to contain __int__: True. All others (__trunc__, __floor__, __ceil__, __index__, __complex__, __bool__): False."
    - "SafeUUID.__dict__ confirmed: all seven numeric conversion dunders absent (False)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra2146.uuid_trunc_floor_ceil:
  description: "uuid.UUID __dict__ numeric conversion dict-presence — __trunc__, __floor__, __ceil__ absent"
  kind: python_call_eq
  category: dict_contains

  columns: [id, function, args, expected]
  rows:
    - ["uu2146001", "uuid.UUID.__dict__.__contains__", ["__trunc__"], false]
    - ["uu2146002", "uuid.UUID.__dict__.__contains__", ["__floor__"], false]
    - ["uu2146003", "uuid.UUID.__dict__.__contains__", ["__ceil__"], false]

table uuid_extra2146.uuid_index_complex:
  description: "uuid.UUID __dict__ numeric conversion dict-presence — __index__ and __complex__ absent"
  kind: python_call_eq
  category: dict_contains

  columns: [id, function, args, expected]
  rows:
    - ["uu2146004", "uuid.UUID.__dict__.__contains__", ["__index__"], false]
    - ["uu2146005", "uuid.UUID.__dict__.__contains__", ["__complex__"], false]

table uuid_extra2146.uuid_bool_int:
  description: "uuid.UUID __dict__ numeric conversion dict-presence — __bool__ absent, __int__ present (UUID defines integer conversion)"
  kind: python_call_eq
  category: dict_contains

  columns: [id, function, args, expected]
  rows:
    - ["uu2146006", "uuid.UUID.__dict__.__contains__", ["__bool__"], false]
    - ["uu2146007", "uuid.UUID.__dict__.__contains__", ["__int__"],  true]

table uuid_extra2146.safeuuid_trunc_floor_ceil:
  description: "uuid.SafeUUID __dict__ numeric conversion dict-presence — __trunc__, __floor__, __ceil__ absent from SafeUUID own dict"
  kind: python_call_eq
  category: dict_contains

  columns: [id, function, args, expected]
  rows:
    - ["uu2146008", "uuid.SafeUUID.__dict__.__contains__", ["__trunc__"], false]
    - ["uu2146009", "uuid.SafeUUID.__dict__.__contains__", ["__floor__"], false]
    - ["uu2146010", "uuid.SafeUUID.__dict__.__contains__", ["__ceil__"], false]

table uuid_extra2146.safeuuid_index_complex:
  description: "uuid.SafeUUID __dict__ numeric conversion dict-presence — __index__ and __complex__ absent from SafeUUID own dict"
  kind: python_call_eq
  category: dict_contains

  columns: [id, function, args, expected]
  rows:
    - ["uu2146011", "uuid.SafeUUID.__dict__.__contains__", ["__index__"], false]
    - ["uu2146012", "uuid.SafeUUID.__dict__.__contains__", ["__complex__"], false]

table uuid_extra2146.safeuuid_bool_int:
  description: "uuid.SafeUUID __dict__ numeric conversion dict-presence — __bool__ and __int__ absent from SafeUUID own dict (inherited from IntEnum, not in SafeUUID.__dict__)"
  kind: python_call_eq
  category: dict_contains

  columns: [id, function, args, expected]
  rows:
    - ["uu2146013", "uuid.SafeUUID.__dict__.__contains__", ["__bool__"], false]
    - ["uu2146014", "uuid.SafeUUID.__dict__.__contains__", ["__int__"],  false]

table uuid_extra2146.uuid_real_attrs:
  description: "uuid.UUID __dict__ positive presence — known real attributes confirm __dict__.__contains__ works for UUID"
  kind: python_call_eq
  category: dict_contains

  columns: [id, function, args, expected]
  rows:
    - ["uu2146015", "uuid.UUID.__dict__.__contains__", ["__slots__"],   true]
    - ["uu2146016", "uuid.UUID.__dict__.__contains__", ["__hash__"],    true]
    - ["uu2146017", "uuid.UUID.__dict__.__contains__", ["__eq__"],      true]
    - ["uu2146018", "uuid.UUID.__dict__.__contains__", ["__repr__"],    true]
    - ["uu2146019", "uuid.UUID.__dict__.__contains__", ["hex"],         true]
    - ["uu2146020", "uuid.UUID.__dict__.__contains__", ["bytes"],       true]
    - ["uu2146021", "uuid.UUID.__dict__.__contains__", ["version"],     true]
    - ["uu2146022", "uuid.UUID.__dict__.__contains__", ["variant"],     true]

table uuid_extra2146.safeuuid_real_attrs:
  description: "uuid.SafeUUID __dict__ positive presence — known enum members confirm __dict__.__contains__ works for SafeUUID"
  kind: python_call_eq
  category: dict_contains

  columns: [id, function, args, expected]
  rows:
    - ["uu2146023", "uuid.SafeUUID.__dict__.__contains__", ["safe"],    true]
    - ["uu2146024", "uuid.SafeUUID.__dict__.__contains__", ["unsafe"],  true]
    - ["uu2146025", "uuid.SafeUUID.__dict__.__contains__", ["unknown"], true]
    - ["uu2146026", "uuid.SafeUUID.__dict__.__contains__", ["_generate_next_value_"], true]
