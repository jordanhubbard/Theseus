spec: pathlib_extra219
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra218.zspec.zsdl — covers pathlib class __qualname__ attribute checks"
  notes:
    - "pathlib.Path.__doc__ starts with 'PurePath subclass that can make system calls.'; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__doc__ starts with 'Base class for manipulating paths without I/O.'; confirmed Python 3.14.3 macOS."
    - "pathlib.PosixPath.__doc__ starts with 'Path subclass for non-Windows systems.'; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePosixPath.__doc__ starts with 'PurePath subclass for non-Windows systems.'; confirmed Python 3.14.3 macOS."
    - "pathlib.WindowsPath.__doc__ starts with 'Path subclass for Windows systems.'; confirmed Python 3.14.3 macOS."
    - "pathlib.PosixPath.__doc__.__contains__('path') == False; doc says 'Path subclass' not 'path subclass'; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __doc__ contains checks for Path and PurePath classes
# Path and PurePath __doc__ string substring membership checks
# ---------------------------------------------------------------------------

table pathlib_extra219.path_doc_contains:
  description: "pathlib.Path and pathlib.PurePath __doc__ string contains expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibdoccontains219

  columns: [id, function, args, expected, description]
  rows:
    - [path_doc_contains_path,         pathlib.Path.__doc__.__contains__,     ["path"],         true,  "pathlib.Path.__doc__.__contains__('path') == True; doc describes it as a filesystem path; confirmed Python 3.14.3 macOS"]
    - [path_doc_contains_Path,         pathlib.Path.__doc__.__contains__,     ["Path"],         true,  "pathlib.Path.__doc__.__contains__('Path') == True; doc contains 'Path' as part of 'PurePath subclass'; confirmed Python 3.14.3 macOS"]
    - [path_doc_contains_filesystem,   pathlib.Path.__doc__.__contains__,     ["filesystem"],   true,  "pathlib.Path.__doc__.__contains__('filesystem') == True; doc describes a filesystem path; confirmed Python 3.14.3 macOS"]
    - [path_doc_contains_system_calls, pathlib.Path.__doc__.__contains__,     ["system calls"], true,  "pathlib.Path.__doc__.__contains__('system calls') == True; doc says 'can make system calls'; confirmed Python 3.14.3 macOS"]
    - [purepath_doc_contains_path,     pathlib.PurePath.__doc__.__contains__,  ["path"],         true,  "pathlib.PurePath.__doc__.__contains__('path') == True; doc describes filesystem path manipulation; confirmed Python 3.14.3 macOS"]
    - [purepath_doc_contains_PurePath, pathlib.PurePath.__doc__.__contains__,  ["PurePath"],     true,  "pathlib.PurePath.__doc__.__contains__('PurePath') == True; doc mentions 'PurePath' by name; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: __doc__ contains checks for PurePath manipulation keywords
# PurePath __doc__ string manipulation and filesystem substring checks
# ---------------------------------------------------------------------------

table pathlib_extra219.purepath_doc_contains:
  description: "pathlib.PurePath __doc__ string contains manipulation and filesystem substrings"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibdoccontains219

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_doc_contains_Base,         pathlib.PurePath.__doc__.__contains__,  ["Base"],         true,  "pathlib.PurePath.__doc__.__contains__('Base') == True; doc starts with 'Base class'; confirmed Python 3.14.3 macOS"]
    - [purepath_doc_contains_manipulating, pathlib.PurePath.__doc__.__contains__,  ["manipulating"], true,  "pathlib.PurePath.__doc__.__contains__('manipulating') == True; doc says 'for manipulating paths'; confirmed Python 3.14.3 macOS"]
    - [purepath_doc_contains_filesystem,   pathlib.PurePath.__doc__.__contains__,  ["filesystem"],   true,  "pathlib.PurePath.__doc__.__contains__('filesystem') == True; doc mentions filesystem path; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_doc_contains_Pure,    pathlib.PurePosixPath.__doc__.__contains__, ["Pure"],      true,  "pathlib.PurePosixPath.__doc__.__contains__('Pure') == True; doc contains 'PurePath subclass'; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_doc_contains_PurePath, pathlib.PurePosixPath.__doc__.__contains__, ["PurePath"], true,  "pathlib.PurePosixPath.__doc__.__contains__('PurePath') == True; doc describes it as a PurePath subclass; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_doc_contains_non_Windows, pathlib.PurePosixPath.__doc__.__contains__, ["non-Windows"], true, "pathlib.PurePosixPath.__doc__.__contains__('non-Windows') == True; doc says 'for non-Windows systems'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: __doc__ contains checks for PosixPath and WindowsPath classes
# PosixPath and WindowsPath __doc__ string substring membership checks
# ---------------------------------------------------------------------------

table pathlib_extra219.posixpath_and_windowspath_doc_contains:
  description: "pathlib.PosixPath and pathlib.WindowsPath __doc__ string contains expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibdoccontains219

  columns: [id, function, args, expected, description]
  rows:
    - [posixpath_doc_contains_Path,        pathlib.PosixPath.__doc__.__contains__,   ["Path"],        true,  "pathlib.PosixPath.__doc__.__contains__('Path') == True; doc says 'Path subclass'; confirmed Python 3.14.3 macOS"]
    - [posixpath_doc_contains_POSIX,       pathlib.PosixPath.__doc__.__contains__,   ["POSIX"],       true,  "pathlib.PosixPath.__doc__.__contains__('POSIX') == True; doc mentions 'On a POSIX system'; confirmed Python 3.14.3 macOS"]
    - [posixpath_doc_contains_non_Windows, pathlib.PosixPath.__doc__.__contains__,   ["non-Windows"], true,  "pathlib.PosixPath.__doc__.__contains__('non-Windows') == True; doc says 'for non-Windows systems'; confirmed Python 3.14.3 macOS"]
    - [windowspath_doc_contains_Windows,   pathlib.WindowsPath.__doc__.__contains__,  ["Windows"],     true,  "pathlib.WindowsPath.__doc__.__contains__('Windows') == True; doc says 'Path subclass for Windows systems'; confirmed Python 3.14.3 macOS"]
    - [windowspath_doc_contains_Path,      pathlib.WindowsPath.__doc__.__contains__,  ["Path"],        true,  "pathlib.WindowsPath.__doc__.__contains__('Path') == True; doc says 'Path subclass'; confirmed Python 3.14.3 macOS"]
    - [path_doc_contains_PurePath,         pathlib.Path.__doc__.__contains__,         ["PurePath"],    true,  "pathlib.Path.__doc__.__contains__('PurePath') == True; doc starts with 'PurePath subclass'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra219.path_doc_contains_path:
  description: "pathlib.Path.__doc__.__contains__('path') == True — Path doc describes it as a filesystem path; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__doc__.__contains__
  args: ["path"]
  expected: true

invariant pathlib_extra219.path_doc_contains_filesystem:
  description: "pathlib.Path.__doc__.__contains__('filesystem') == True — Path doc describes a filesystem path; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__doc__.__contains__
  args: ["filesystem"]
  expected: true

invariant pathlib_extra219.path_doc_contains_system_calls:
  description: "pathlib.Path.__doc__.__contains__('system calls') == True — Path doc says 'can make system calls'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__doc__.__contains__
  args: ["system calls"]
  expected: true

invariant pathlib_extra219.purepath_doc_contains_manipulating:
  description: "pathlib.PurePath.__doc__.__contains__('manipulating') == True — PurePath doc says 'for manipulating paths'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__doc__.__contains__
  args: ["manipulating"]
  expected: true

invariant pathlib_extra219.purepath_doc_contains_PurePath:
  description: "pathlib.PurePath.__doc__.__contains__('PurePath') == True — PurePath doc mentions PurePath by name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__doc__.__contains__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra219.posixpath_doc_contains_POSIX:
  description: "pathlib.PosixPath.__doc__.__contains__('POSIX') == True — PosixPath doc mentions 'On a POSIX system'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PosixPath.__doc__.__contains__
  args: ["POSIX"]
  expected: true

invariant pathlib_extra219.windowspath_doc_contains_Windows:
  description: "pathlib.WindowsPath.__doc__.__contains__('Windows') == True — WindowsPath doc says 'Path subclass for Windows systems'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.WindowsPath.__doc__.__contains__
  args: ["Windows"]
  expected: true

invariant pathlib_extra219.pureposixpath_doc_contains_non_Windows:
  description: "pathlib.PurePosixPath.__doc__.__contains__('non-Windows') == True — PurePosixPath doc says 'for non-Windows systems'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePosixPath.__doc__.__contains__
  args: ["non-Windows"]
  expected: true
