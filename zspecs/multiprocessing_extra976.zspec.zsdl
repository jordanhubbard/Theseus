spec: multiprocessing_extra976
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing.Process method qualnames and class identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra976.process_lifecycle_qualnames:
  description: "multiprocessing.Process lifecycle method __qualname__ identity"
  kind: python_call_eq
  category: process_lifecycle_qualnames
  id_prefix: mp976pl
  columns: [id, function, args, expected]
  rows:
    - [mp976pl001, multiprocessing.Process.start.__qualname__.__eq__,     ["Process.start"],     true]
    - [mp976pl002, multiprocessing.Process.run.__qualname__.__eq__,       ["Process.run"],       true]
    - [mp976pl003, multiprocessing.Process.join.__qualname__.__eq__,      ["Process.join"],      true]
    - [mp976pl004, multiprocessing.Process.terminate.__qualname__.__eq__, ["Process.terminate"], true]
    - [mp976pl005, multiprocessing.Process.kill.__qualname__.__eq__,      ["Process.kill"],      true]
    - [mp976pl006, multiprocessing.Process.close.__qualname__.__eq__,     ["Process.close"],     true]
    - [mp976pl007, multiprocessing.Process.is_alive.__qualname__.__eq__,  ["Process.is_alive"],  true]

table multiprocessing_extra976.process_init_qualnames:
  description: "multiprocessing.Process init and utility method __qualname__ identity"
  kind: python_call_eq
  category: process_init_qualnames
  id_prefix: mp976pi
  columns: [id, function, args, expected]
  rows:
    - [mp976pi001, multiprocessing.Process.__init__.__qualname__.__eq__,   ["Process.__init__"],   true]
    - [mp976pi002, multiprocessing.Process.__repr__.__qualname__.__eq__,   ["Process.__repr__"],   true]
    - [mp976pi003, multiprocessing.Process.__str__.__qualname__.__eq__,    ["BaseProcess.__str__"], true]

table multiprocessing_extra976.class_identity:
  description: "multiprocessing.Process class identity and module membership"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp976ci
  columns: [id, function, args, expected]
  rows:
    - [mp976ci001, multiprocessing.Process.__name__.__eq__,              ["Process"],        true]
    - [mp976ci002, multiprocessing.Process.__class__.__name__.__eq__,    ["type"],           true]
    - [mp976ci003, multiprocessing.Process.__module__.__eq__,            ["multiprocessing.process"], true]
    - [mp976ci004, multiprocessing.Process.__bases__.__class__.__name__.__eq__, ["tuple"],   true]
    - [mp976ci005, multiprocessing.Process.daemon.fget.__qualname__.__eq__, ["BaseProcess.daemon"], true]
