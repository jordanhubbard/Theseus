spec: concurrent_futures_extra45
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra44.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens for all methods, class __dict__.__class__.__name__.__len__() tables, as_completed/wait __module__.__len__(), __all__.__len__()==14, __mro__.__len__() tables, __bases__[0].__name__.__len__() for all classes, Executor context manager qualname lens, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, map/__qualname__.__len__() for both executors, Future method __name__/__qualname__.__len__() tables, ThreadPoolExecutor submit/shutdown __name__/__qualname__.__len__() tables, InvalidStateError/__name__.__len__()==17, CancelledError/__qualname__.__len__()==14, BrokenExecutor/__name__/__qualname__.__len__()==14, BrokenExecutor/__module__.__len__()==24, CancelledError/__module__.__len__()==24, TimeoutError/__name__/__module__.__len__(), concurrent.futures.__package__.__len__()==18, ThreadPoolExecutor/__name__=='ThreadPoolExecutor', ProcessPoolExecutor/__name__=='ProcessPoolExecutor', executor __module__ string equality, wait/__name__=='wait', function __module__ string equality, Executor/__name__=='Executor'/__module__==concurrent.futures._base, Executor map/submit qualname lengths, InvalidStateError/BrokenExecutor __name__/__module__ string equality, ProcessPoolExecutor/ThreadPoolExecutor/__bases__[0].__name__=='Executor', Future/__bases__[0].__name__=='object', exception MRO depths, ProcessPoolExecutor/ThreadPoolExecutor/__mro__.__len__()==3, Future/__mro__.__len__()==2, Executor/__mro__.__len__()==2, ThreadPoolExecutor/__qualname__=='ThreadPoolExecutor', ProcessPoolExecutor/__qualname__=='ProcessPoolExecutor', Future/__qualname__=='Future', Executor/__qualname__=='Executor', CancelledError/__qualname__=='CancelledError', BrokenExecutor/__qualname__=='BrokenExecutor', all class __qualname__.__len__() tables (extra41), InvalidStateError/__qualname__=='InvalidStateError', TimeoutError/__qualname__=='TimeoutError', ThreadPoolExecutor/ProcessPoolExecutor/InvalidStateError/TimeoutError __module__.__len__(), module string equality for thread/process/builtins modules (extra42), Future method __module__ string equality and __module__.__len__()==24, Executor.map __module__ string equality and length (extra43), ThreadPoolExecutor/__class__.__name__=='type', ProcessPoolExecutor/__class__.__name__=='type', Future/__class__.__name__=='type', Executor/__class__.__name__=='type', CancelledError/__class__.__name__=='type', BrokenExecutor/__class__.__name__=='type', wait/__class__.__name__=='function', as_completed/__class__.__name__=='function', class __class__.__name__.__len__()==4, function __class__.__name__.__len__()==8 (extra44)."
    - "This spec covers: ThreadPoolExecutor/__class__.__qualname__=='type'; ProcessPoolExecutor/__class__.__qualname__=='type'; Future/__class__.__qualname__=='type'; Executor/__class__.__qualname__=='type'; CancelledError/__class__.__qualname__=='type'; BrokenExecutor/__class__.__qualname__=='type'; wait/__class__.__qualname__=='function'; as_completed/__class__.__qualname__=='function'; class __class__.__qualname__.__len__()==4 for all six classes; function __class__.__qualname__.__len__()==8 for both functions; wait/__class__.__module__=='builtins'; ThreadPoolExecutor/__class__.__module__=='builtins'."
    - "concurrent.futures.ThreadPoolExecutor.__class__.__qualname__ == 'type'. ThreadPoolExecutor is a plain Python class; its metaclass is the built-in 'type'. The built-in type has __qualname__ == __name__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__class__.__qualname__ == 'type'. ProcessPoolExecutor is a plain Python class; its metaclass is the built-in 'type'. __class__.__qualname__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__class__.__qualname__ == 'type'. Future is a plain Python class; its metaclass is the built-in 'type'. __class__.__qualname__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__class__.__qualname__ == 'type'. Executor is the abstract base class; its metaclass is the built-in 'type'. __class__.__qualname__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.CancelledError.__class__.__qualname__ == 'type'. CancelledError is an exception class; its metaclass is the built-in 'type'. __class__.__qualname__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__class__.__qualname__ == 'type'. BrokenExecutor is an exception class; its metaclass is the built-in 'type'. __class__.__qualname__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__class__.__qualname__ == 'function'. wait is a plain Python function in _base.py; its __class__ is the built-in 'function' type, whose __qualname__ == 'function' (8 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__class__.__qualname__ == 'function'. as_completed is a plain Python generator function in _base.py; its __class__.__qualname__ == 'function' (8 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__class__.__module__ == 'builtins'. The 'function' type is a built-in type defined in builtins; therefore any Python function's __class__.__module__ == 'builtins' (8 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__class__.__module__ == 'builtins'. The 'type' metaclass is a built-in type defined in builtins; therefore any standard Python class's __class__.__module__ == 'builtins' (8 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "For all Python built-in types, __qualname__ == __name__ (no enclosing scope). Therefore __class__.__qualname__ and __class__.__name__ are identical: 'type' for all six cf classes, 'function' for both cf functions. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures class __class__.__qualname__ string equality — extra45
#
# All six concurrent.futures classes are instances of the built-in 'type'.
# The built-in type has __qualname__ == __name__ == 'type' (no enclosing scope):
#   ThreadPoolExecutor.__class__.__qualname__ == 'type'
#   ProcessPoolExecutor.__class__.__qualname__ == 'type'
#   Future.__class__.__qualname__             == 'type'
#   Executor.__class__.__qualname__           == 'type'
#   CancelledError.__class__.__qualname__     == 'type'
#   BrokenExecutor.__class__.__qualname__     == 'type'
# Prior specs captured __class__.__name__ (extra44). Extra45 captures
# __class__.__qualname__ for the first time.
# ---------------------------------------------------------------------------

table concurrent_futures_extra45.class_metaclass_qualname_eq:
  description: "concurrent.futures class __class__.__qualname__ string equality in extra45 namespace — six classes all have metaclass qualname 'type'"
  kind: python_call_eq
  category: class_names
  id_prefix: cfclsqual45

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__class__.__qualname__.__eq__,  ["type"], true, "ThreadPoolExecutor.__class__.__qualname__ == 'type' — plain Python class in thread.py; metaclass built-in type has __qualname__ == 'type' (4 chars)"]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__class__.__qualname__.__eq__, ["type"], true, "ProcessPoolExecutor.__class__.__qualname__ == 'type' — plain Python class in process.py; metaclass built-in type has __qualname__ == 'type' (4 chars)"]
    - [Future,              Future.__class__.__qualname__.__eq__,              ["type"], true, "Future.__class__.__qualname__ == 'type' — plain Python class in _base.py; metaclass built-in type has __qualname__ == 'type' (4 chars)"]
    - [Executor,            Executor.__class__.__qualname__.__eq__,            ["type"], true, "Executor.__class__.__qualname__ == 'type' — abstract base class in _base.py; metaclass built-in type has __qualname__ == 'type' (4 chars)"]
    - [CancelledError,      CancelledError.__class__.__qualname__.__eq__,      ["type"], true, "CancelledError.__class__.__qualname__ == 'type' — exception class; metaclass built-in type has __qualname__ == 'type' (4 chars)"]
    - [BrokenExecutor,      BrokenExecutor.__class__.__qualname__.__eq__,      ["type"], true, "BrokenExecutor.__class__.__qualname__ == 'type' — exception class; metaclass built-in type has __qualname__ == 'type' (4 chars)"]

# ---------------------------------------------------------------------------
# concurrent.futures function __class__.__qualname__ string equality — extra45
#
# Both module-level functions have __class__.__qualname__ == 'function':
#   wait.__class__.__qualname__         == 'function'
#   as_completed.__class__.__qualname__ == 'function'
# wait is a regular function; as_completed is a generator function.
# Both are instances of the built-in 'function' type whose __qualname__ == 'function'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra45.function_class_qualname_eq:
  description: "concurrent.futures function __class__.__qualname__ string equality in extra45 namespace — wait and as_completed both have __class__.__qualname__ == 'function'"
  kind: python_call_eq
  category: class_names
  id_prefix: cffuncclsqual45

  columns: [id, function, args, expected, description]
  rows:
    - [wait,         wait.__class__.__qualname__.__eq__,         ["function"], true, "wait.__class__.__qualname__ == 'function' — plain Python function in _base.py; built-in 'function' type has __qualname__ == 'function' (8 chars)"]
    - [as_completed, as_completed.__class__.__qualname__.__eq__, ["function"], true, "as_completed.__class__.__qualname__ == 'function' — generator function in _base.py; built-in 'function' type has __qualname__ == 'function' (8 chars)"]

# ---------------------------------------------------------------------------
# concurrent.futures class and function __class__.__qualname__.__len__() — extra45
#
# All six classes share __class__.__qualname__.__len__() == 4 ('type'):
#   ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor/CancelledError/BrokenExecutor == 4
# Both functions share __class__.__qualname__.__len__() == 8 ('function'):
#   wait/as_completed == 8
# ---------------------------------------------------------------------------

table concurrent_futures_extra45.class_qualname_lengths:
  description: "concurrent.futures class and function __class__.__qualname__.__len__() in extra45 namespace — classes == 4, functions == 8"
  kind: python_call_eq
  category: class_names
  id_prefix: cfclsquallen45

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__class__.__qualname__.__len__,  [], 4, "ThreadPoolExecutor.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__class__.__qualname__.__len__, [], 4, "ProcessPoolExecutor.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [Future,              Future.__class__.__qualname__.__len__,              [], 4, "Future.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [Executor,            Executor.__class__.__qualname__.__len__,            [], 4, "Executor.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [CancelledError,      CancelledError.__class__.__qualname__.__len__,      [], 4, "CancelledError.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [BrokenExecutor,      BrokenExecutor.__class__.__qualname__.__len__,      [], 4, "BrokenExecutor.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [wait,                wait.__class__.__qualname__.__len__,                [], 8, "wait.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"]
    - [as_completed,        as_completed.__class__.__qualname__.__len__,        [], 8, "as_completed.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"]

# ---------------------------------------------------------------------------
# concurrent.futures __class__.__module__ string equality — extra45
#
# The 'function' type is a built-in type → __module__ == 'builtins':
#   wait.__class__.__module__ == 'builtins'
# The 'type' metaclass is a built-in type → __module__ == 'builtins':
#   ThreadPoolExecutor.__class__.__module__ == 'builtins'
# These two cases together confirm that both the function type and the type
# metaclass report 'builtins' as their home module.
# ---------------------------------------------------------------------------

table concurrent_futures_extra45.class_module_eq:
  description: "concurrent.futures object __class__.__module__ string equality in extra45 namespace — function type and type metaclass both from 'builtins'"
  kind: python_call_eq
  category: module_identity
  id_prefix: cfclsmoduleq45

  columns: [id, function, args, expected, description]
  rows:
    - [wait,               wait.__class__.__module__.__eq__,               ["builtins"], true, "wait.__class__.__module__ == 'builtins' — 'function' type is a built-in type whose __module__ == 'builtins' (8 chars)"]
    - [ThreadPoolExecutor, ThreadPoolExecutor.__class__.__module__.__eq__, ["builtins"], true, "ThreadPoolExecutor.__class__.__module__ == 'builtins' — 'type' metaclass is a built-in type whose __module__ == 'builtins' (8 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra45
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra45.ThreadPoolExecutor_class_qualname_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__class__.__qualname__ == 'type' — plain Python class in thread.py; metaclass built-in type has __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: ThreadPoolExecutor.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant concurrent_futures_extra45.ProcessPoolExecutor_class_qualname_eq:
  description: "concurrent.futures.ProcessPoolExecutor.__class__.__qualname__ == 'type' — plain Python class in process.py; metaclass built-in type has __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: ProcessPoolExecutor.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant concurrent_futures_extra45.Future_class_qualname_eq:
  description: "concurrent.futures.Future.__class__.__qualname__ == 'type' — plain Python class in _base.py; metaclass built-in type has __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: Future.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant concurrent_futures_extra45.Executor_class_qualname_eq:
  description: "concurrent.futures.Executor.__class__.__qualname__ == 'type' — abstract base class in _base.py; metaclass built-in type has __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: Executor.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant concurrent_futures_extra45.CancelledError_class_qualname_eq:
  description: "concurrent.futures.CancelledError.__class__.__qualname__ == 'type' — exception class; metaclass built-in type has __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: CancelledError.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant concurrent_futures_extra45.BrokenExecutor_class_qualname_eq:
  description: "concurrent.futures.BrokenExecutor.__class__.__qualname__ == 'type' — exception class; metaclass built-in type has __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: BrokenExecutor.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant concurrent_futures_extra45.wait_class_qualname_eq:
  description: "concurrent.futures.wait.__class__.__qualname__ == 'function' — plain Python function in _base.py; built-in 'function' type has __qualname__ == 'function' (8 chars)"
  category: class_names
  kind: python_call_eq
  function: wait.__class__.__qualname__.__eq__
  args: ["function"]
  expected: true

invariant concurrent_futures_extra45.as_completed_class_qualname_eq:
  description: "concurrent.futures.as_completed.__class__.__qualname__ == 'function' — generator function in _base.py; built-in 'function' type has __qualname__ == 'function' (8 chars)"
  category: class_names
  kind: python_call_eq
  function: as_completed.__class__.__qualname__.__eq__
  args: ["function"]
  expected: true

invariant concurrent_futures_extra45.wait_class_module_eq:
  description: "concurrent.futures.wait.__class__.__module__ == 'builtins' — 'function' type is a built-in type; its __module__ == 'builtins' (8 chars)"
  category: module_identity
  kind: python_call_eq
  function: wait.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant concurrent_futures_extra45.ThreadPoolExecutor_class_module_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__class__.__module__ == 'builtins' — 'type' metaclass is a built-in type; its __module__ == 'builtins' (8 chars)"
  category: module_identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant concurrent_futures_extra45.ThreadPoolExecutor_class_qualname_len:
  description: "concurrent.futures.ThreadPoolExecutor.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"
  category: class_names
  kind: python_call_eq
  function: ThreadPoolExecutor.__class__.__qualname__.__len__
  args: []
  expected: 4

invariant concurrent_futures_extra45.wait_class_qualname_len:
  description: "concurrent.futures.wait.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"
  category: class_names
  kind: python_call_eq
  function: wait.__class__.__qualname__.__len__
  args: []
  expected: 8

invariant concurrent_futures_extra45.as_completed_class_qualname_len:
  description: "concurrent.futures.as_completed.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"
  category: class_names
  kind: python_call_eq
  function: as_completed.__class__.__qualname__.__len__
  args: []
  expected: 8
