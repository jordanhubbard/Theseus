spec: itertools_extra116
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra115.zspec.zsdl."
    - "This spec covers: itertools.chain class method and slot attributes not yet covered — chain.from_iterable.__name__, chain.__new__.__qualname__, chain.__new__.__name__, chain.__init__.__qualname__, chain.__next__.__qualname__, chain.__next__.__name__, chain.__next__.__class__.__name__, chain.__iter__.__name__; wave 267."
    - "itertools.chain.from_iterable.__name__ == 'from_iterable'. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__name__.__len__() == 13. Verified with Python 3.14.3."
    - "itertools.chain.__new__.__qualname__ == 'chain.__new__'. Verified with Python 3.14.3."
    - "itertools.chain.__new__.__name__ == '__new__'. Verified with Python 3.14.3."
    - "itertools.chain.__init__.__qualname__ == 'object.__init__'. Verified with Python 3.14.3."
    - "itertools.chain.__next__.__qualname__ == 'chain.__next__'. Verified with Python 3.14.3."
    - "itertools.chain.__next__.__name__ == '__next__'. Verified with Python 3.14.3."
    - "itertools.chain.__next__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.chain.__iter__.__name__ == '__iter__'. Verified with Python 3.14.3."
    - "len(itertools.chain.__iter__.__qualname__) == 14. Verified with Python 3.14.3."
    - "len(itertools.chain.__next__.__qualname__) == 14. Verified with Python 3.14.3."
    - "len(itertools.chain.__new__.__qualname__) == 13. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain.from_iterable __name__ and length
#
# Wave 267 theme: itertools.chain.from_iterable is a C-extension classmethod
# (builtin_function_or_method) that chains iterables from a single iterable
# of iterables. Its __name__ is 'from_iterable' (13 chars) — the bare method
# name without the class prefix. Its __qualname__ is 'chain.from_iterable' (19
# chars, already covered in earlier specs). The __name__ attribute is new to
# extra116. Previously covered: __class__.__name__, __qualname__,
# __qualname__.__len__, __doc__.__class__.__name__ (earlier specs).
# New here: from_iterable.__name__, from_iterable.__name__.__len__.
#
# from_iterable.__name__ == 'from_iterable'   (len 13)
# from_iterable.__qualname__ == 'chain.from_iterable'   (len 19, already covered)
#
# New to extra116.
# ---------------------------------------------------------------------------

table itertools_extra116.chain_from_iterable_name:
  description: "itertools.chain.from_iterable: __name__='from_iterable'(13 chars); classmethod; builtin_function_or_method; __name__ is bare method name without class prefix; wave 267; new to extra116"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscfin116

  columns: [id, function, args, expected, description]
  rows:
    - [from_iterable_name,
       "chain.from_iterable.__name__.__eq__",
       ["from_iterable"],
       true,
       "itertools.chain.from_iterable.__name__.__eq__('from_iterable') == True — the __name__ is the bare method name without the class prefix 'chain.'; str.__eq__('from_iterable') returns True; new to extra116"]
    - [from_iterable_name_len,
       "chain.from_iterable.__name__.__len__",
       [],
       13,
       "itertools.chain.from_iterable.__name__.__len__() == 13 — 'from_iterable' has 13 chars: f-r-o-m(4)+_(1)+i-t-e-r-a-b-l-e(8); shorter than __qualname__ 'chain.from_iterable' (19); str.__len__() returns 13; new to extra116"]
    - [from_iterable_class_name,
       "chain.from_iterable.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.chain.from_iterable.__class__.__name__.__eq__('builtin_function_or_method') == True — from_iterable is a C-extension classmethod; its type name is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra116"]
    - [from_iterable_qualname_len,
       "chain.from_iterable.__qualname__.__len__",
       [],
       19,
       "itertools.chain.from_iterable.__qualname__.__len__() == 19 — 'chain.from_iterable' has 19 chars: chain(5)+dot(1)+from_iterable(13); qualname includes the class prefix; str.__len__() returns 19; new to extra116"]
    - [from_iterable_name_ne_qualname,
       "chain.from_iterable.__name__.__eq__",
       ["chain.from_iterable"],
       false,
       "itertools.chain.from_iterable.__name__.__eq__('chain.from_iterable') == False — __name__ is the bare 'from_iterable' while __qualname__ is 'chain.from_iterable'; they differ by 6 chars (the 'chain.' prefix); str.__eq__('chain.from_iterable') returns False; new to extra116"]

# ---------------------------------------------------------------------------
# Table 2: itertools.chain.__new__ and __init__ qualnames
#
# Wave 267 theme: itertools.chain is a C-extension type that defines its own
# tp_new slot (__new__), so chain.__new__.__qualname__ is 'chain.__new__' (13
# chars). However, chain does not define a custom tp_init, so chain.__init__
# is inherited from object; its __qualname__ is 'object.__init__' (15 chars).
# This asymmetry — __new__ is chain-specific but __init__ falls through to
# object — is distinctive. chain.__new__.__name__ == '__new__'.
# Previously covered: __new__.__class__.__name__ (earlier specs).
# New here: __new__.__qualname__, __new__.__name__, __init__.__qualname__,
# __init__.__name__.
#
# chain.__new__.__qualname__ == 'chain.__new__'      (len 13)
# chain.__init__.__qualname__ == 'object.__init__'   (len 15)
# chain.__new__.__name__ == '__new__'
#
# New to extra116.
# ---------------------------------------------------------------------------

table itertools_extra116.chain_new_init_qualnames:
  description: "itertools.chain: __new__.__qualname__='chain.__new__'(13), __init__.__qualname__='object.__init__'(15) — __new__ is chain-specific but __init__ falls through to object; wave 267; new to extra116"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscniq116

  columns: [id, function, args, expected, description]
  rows:
    - [chain_new_qualname,
       "chain.__new__.__qualname__.__eq__",
       ["chain.__new__"],
       true,
       "itertools.chain.__new__.__qualname__.__eq__('chain.__new__') == True — chain defines its own tp_new slot; __qualname__ is 'chain.__new__' with the chain prefix; str.__eq__('chain.__new__') returns True; new to extra116"]
    - [chain_new_qualname_len,
       "chain.__new__.__qualname__.__len__",
       [],
       13,
       "itertools.chain.__new__.__qualname__.__len__() == 13 — 'chain.__new__' has 13 chars: chain(5)+dot(1)+__new__(7); str.__len__() returns 13; new to extra116"]
    - [chain_new_name,
       "chain.__new__.__name__.__eq__",
       ["__new__"],
       true,
       "itertools.chain.__new__.__name__.__eq__('__new__') == True — the bare __name__ is '__new__' (7 chars, dunder prefix and suffix); str.__eq__('__new__') returns True; new to extra116"]
    - [chain_init_qualname,
       "chain.__init__.__qualname__.__eq__",
       ["object.__init__"],
       true,
       "itertools.chain.__init__.__qualname__.__eq__('object.__init__') == True — chain does not define tp_init; it falls through to object.__init__; __qualname__ is 'object.__init__' (15 chars); str.__eq__('object.__init__') returns True; new to extra116"]
    - [chain_init_qualname_len,
       "chain.__init__.__qualname__.__len__",
       [],
       15,
       "itertools.chain.__init__.__qualname__.__len__() == 15 — 'object.__init__' has 15 chars: object(6)+dot(1)+__init__(8); longer than chain.__new__.__qualname__ (13); str.__len__() returns 15; new to extra116"]
    - [chain_init_name,
       "chain.__init__.__name__.__eq__",
       ["__init__"],
       true,
       "itertools.chain.__init__.__name__.__eq__('__init__') == True — the bare __name__ of the inherited wrapper_descriptor is '__init__'; str.__eq__('__init__') returns True; new to extra116"]

# ---------------------------------------------------------------------------
# Table 3: itertools.chain.__next__ and __iter__ slot qualnames
#
# Wave 267 theme: itertools.chain implements the iterator protocol with both
# __next__ and __iter__ slots. chain.__next__.__qualname__ == 'chain.__next__'
# (14 chars) and chain.__iter__.__qualname__ == 'chain.__iter__' (14 chars) —
# both have the same length! Both are wrapper_descriptor objects (C slots
# wrapped in Python). chain.__next__.__name__ == '__next__'. The __next__
# qualname (14) is one char longer than chain.__new__.__qualname__ (13).
# Previously covered: chain.__iter__.__qualname__ (earlier specs).
# New here: __next__.__qualname__, __next__.__name__, __next__.__class__.__name__,
# __iter__.__name__, __iter__.__qualname__.__len__ (confirming 14).
#
# chain.__next__.__qualname__ == 'chain.__next__'   (len 14)
# chain.__iter__.__qualname__ == 'chain.__iter__'   (len 14)
# chain.__next__.__class__.__name__ == 'wrapper_descriptor'
#
# New to extra116.
# ---------------------------------------------------------------------------

table itertools_extra116.chain_next_iter_qualnames:
  description: "itertools.chain iterator protocol: __next__.__qualname__='chain.__next__'(14), __iter__.__qualname__='chain.__iter__'(14) — equal lengths; both wrapper_descriptor; wave 267; new to extra116"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscniq2116

  columns: [id, function, args, expected, description]
  rows:
    - [chain_next_qualname,
       "chain.__next__.__qualname__.__eq__",
       ["chain.__next__"],
       true,
       "itertools.chain.__next__.__qualname__.__eq__('chain.__next__') == True — chain defines tp_iternext which surfaces as '__next__' in the class dict; __qualname__ is 'chain.__next__'; str.__eq__('chain.__next__') returns True; new to extra116"]
    - [chain_next_qualname_len,
       "chain.__next__.__qualname__.__len__",
       [],
       14,
       "itertools.chain.__next__.__qualname__.__len__() == 14 — 'chain.__next__' has 14 chars: chain(5)+dot(1)+__next__(8); same length as chain.__iter__.__qualname__; str.__len__() returns 14; new to extra116"]
    - [chain_next_name,
       "chain.__next__.__name__.__eq__",
       ["__next__"],
       true,
       "itertools.chain.__next__.__name__.__eq__('__next__') == True — the bare __name__ is '__next__' (8 chars, dunder prefix and suffix); str.__eq__('__next__') returns True; new to extra116"]
    - [chain_next_class_name,
       "chain.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.chain.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — C slot tp_iternext is exposed as a wrapper_descriptor; same type as __iter__; str.__eq__('wrapper_descriptor') returns True; new to extra116"]
    - [chain_iter_name,
       "chain.__iter__.__name__.__eq__",
       ["__iter__"],
       true,
       "itertools.chain.__iter__.__name__.__eq__('__iter__') == True — the bare __name__ of the tp_iter slot wrapper is '__iter__' (8 chars); str.__eq__('__iter__') returns True; new to extra116"]
    - [chain_iter_qualname_len,
       "chain.__iter__.__qualname__.__len__",
       [],
       14,
       "itertools.chain.__iter__.__qualname__.__len__() == 14 — 'chain.__iter__' has 14 chars: chain(5)+dot(1)+__iter__(8); equal to chain.__next__.__qualname__.__len__(); str.__len__() returns 14; new to extra116"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra116
# ---------------------------------------------------------------------------

invariant itertools_extra116.from_iterable_name:
  description: "itertools.chain.from_iterable.__name__ == 'from_iterable' — bare method name without class prefix; length 13; wave 267; new to extra116"
  kind: python_call_eq
  function: chain.from_iterable.__name__.__eq__
  args: ["from_iterable"]
  expected: true

invariant itertools_extra116.chain_new_qualname:
  description: "itertools.chain.__new__.__qualname__ == 'chain.__new__' — chain defines its own tp_new; qualname length 13; wave 267; new to extra116"
  kind: python_call_eq
  function: chain.__new__.__qualname__.__eq__
  args: ["chain.__new__"]
  expected: true

invariant itertools_extra116.chain_init_qualname_object:
  description: "itertools.chain.__init__.__qualname__ == 'object.__init__' — chain has no custom tp_init; falls through to object; qualname length 15; wave 267; new to extra116"
  kind: python_call_eq
  function: chain.__init__.__qualname__.__eq__
  args: ["object.__init__"]
  expected: true

invariant itertools_extra116.chain_next_qualname:
  description: "itertools.chain.__next__.__qualname__ == 'chain.__next__' — tp_iternext slot; qualname length 14; same as __iter__ qualname length; wave 267; new to extra116"
  kind: python_call_eq
  function: chain.__next__.__qualname__.__eq__
  args: ["chain.__next__"]
  expected: true

invariant itertools_extra116.chain_next_class_name:
  description: "itertools.chain.__next__.__class__.__name__ == 'wrapper_descriptor' — C slot tp_iternext wrapped as wrapper_descriptor; same type as __iter__; wave 267; new to extra116"
  kind: python_call_eq
  function: chain.__next__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true
