spec: sk3346
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 670 (sk3346): __neg__, __pos__, __abs__ dict-presence checks for socket types."
    - "Theme: __neg__/__pos__/__abs__ dict-presence (unary operators: -x, +x, abs(x))."
    - "All values False — UUID, Struct, and socket types have no unary arithmetic protocol."
    - "socket.socket is a Python class; it does not define __neg__, __pos__, or __abs__ in its __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses (EnumType metaclass)."
    - "AddressFamily and SocketKind are IntEnum but do NOT define __neg__, __pos__, or __abs__ in their own __dict__; these methods are not overridden at the subclass level."
    - "operator.contains(socket.AddressFamily.__dict__, '__neg__') is False — not present in AddressFamily's own __dict__."
    - "operator.contains(socket.SocketKind.__dict__, '__neg__') is False — same reasoning as AddressFamily."
    - "All values are False for all 3 socket types across all 3 operators."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk3346.neg:
  description: "socket types __neg__ dict-presence checks; wave 670"
