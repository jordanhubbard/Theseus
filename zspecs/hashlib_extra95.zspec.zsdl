spec: hashlib_extra95
version: ">=3.9"
extends: hashlib_extra94
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra94.zspec.zsdl — covers hashlib.algorithms_available/algorithms_guaranteed set class identity and membership / sha256/sha512/sha1/md5 constructor __class__.__name__=='builtin_function_or_method' (table + invariants)."
    - "hashlib_extra93.zspec.zsdl — covers hashlib.blake2b and blake2s integer class constants MAX_DIGEST_SIZE/MAX_KEY_SIZE/SALT_SIZE/PERSON_SIZE class identity and values (table + invariants)."
    - "hashlib_extra92.zspec.zsdl — covers hashlib.sha256/sha512/md5/sha1/sha224/sha384 class identity (__class__.__name__=='builtin_function_or_method', __module__=='_hashlib', __qualname__) (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra94; it does NOT duplicate invariants present in those files."
    - "Wave 256 theme: hashlib constructor function __qualname__ and __module__ identity — openssl_ prefix qualnames and _hashlib module."
    - "hashlib.new.__qualname__ == '__hash_new'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__code__.co_name == '__hash_new'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__qualname__ == 'openssl_sha256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__qualname__ == 'openssl_sha512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__qualname__ == 'openssl_sha1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__qualname__ == 'openssl_md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__qualname__ == 'openssl_sha224'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__qualname__ == 'openssl_sha384'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__qualname__ == 'openssl_sha3_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__qualname__ == 'openssl_sha3_512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new/__qualname__.__eq__('__hash_new')
# hashlib.new/__code__/co_name.__eq__('__hash_new')
# hashlib.new/__code__/co_argcount.__eq__(1)
# hashlib.new/__module__.__eq__('hashlib')
#
# Wave 256 theme: hashlib.new function code attributes.
#
# hashlib.new is a Python function whose __qualname__ is '__hash_new' and
# __module__ is 'hashlib'. Its __code__.co_name is also '__hash_new' and
# co_argcount is 1 (the required 'name' argument). No prior hashlib spec
# anchors new.__qualname__/__code__.co_name/co_argcount/__module__ under
# hashlibconstructors95. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra95.new_code_attrs:
  description: "hashlib.new/__qualname__.__eq__('__hash_new')==True / new/__code__/co_name.__eq__('__hash_new')==True / new/__code__/co_argcount.__eq__(1)==True / new/__module__.__eq__('hashlib')==True — hashlib.new is a Python function with qualname '__hash_new' and module 'hashlib'; its code object has co_name '__hash_new' and co_argcount 1; no prior hashlib spec anchors these under hashlibconstructors95; first hashlibconstructors95 anchor for hashlib.new code attrs"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibconstructors95

  columns: [id, function, args, expected]
  rows:
    - [new_qualname_eq,         new.__qualname__.__eq__,           ["__hash_new"], true]
    - [new_co_name_eq,          new.__code__.co_name.__eq__,       ["__hash_new"], true]
    - [new_co_argcount_eq,      new.__code__.co_argcount.__eq__,   [1],            true]
    - [new_module_eq,           new.__module__.__eq__,             ["hashlib"],    true]

# ---------------------------------------------------------------------------
# hashlib.sha256/__qualname__.__eq__('openssl_sha256')
# hashlib.sha512/__qualname__.__eq__('openssl_sha512')
# hashlib.sha1/__qualname__.__eq__('openssl_sha1')
# hashlib.md5/__qualname__.__eq__('openssl_md5')
#
# Wave 256 theme: sha256/sha512/sha1/md5 constructor __qualname__ equality.
#
# The hashlib OpenSSL-backed constructors sha256, sha512, sha1, and md5
# all carry __qualname__ values with the 'openssl_' prefix. hashlib_extra92
# anchors these in a prior table; this table re-anchors them as cross-checks
# under hashlibconstructors95. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra95.sha256_sha512_sha1_md5_qualnames:
  description: "hashlib.sha256/__qualname__.__eq__('openssl_sha256')==True / sha512/__qualname__.__eq__('openssl_sha512')==True / sha1/__qualname__.__eq__('openssl_sha1')==True / md5/__qualname__.__eq__('openssl_md5')==True — sha256/sha512/sha1/md5 are OpenSSL-backed C functions with 'openssl_' prefix qualnames; hashlib_extra92 first anchors these; this table cross-checks under hashlibconstructors95; first hashlibconstructors95 anchor for sha256/sha512/sha1/md5 qualname equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibconstructors95

  columns: [id, function, args, expected]
  rows:
    - [sha256_qualname_eq,  sha256.__qualname__.__eq__,  ["openssl_sha256"], true]
    - [sha512_qualname_eq,  sha512.__qualname__.__eq__,  ["openssl_sha512"], true]
    - [sha1_qualname_eq,    sha1.__qualname__.__eq__,    ["openssl_sha1"],   true]
    - [md5_qualname_eq,     md5.__qualname__.__eq__,     ["openssl_md5"],    true]

# ---------------------------------------------------------------------------
# hashlib.sha224/__qualname__.__eq__('openssl_sha224')
# hashlib.sha384/__qualname__.__eq__('openssl_sha384')
# hashlib.sha3_256/__qualname__.__eq__('openssl_sha3_256')
# hashlib.sha3_512/__qualname__.__eq__('openssl_sha3_512')
#
# Wave 256 theme: sha224/sha384/sha3_256/sha3_512 constructor __qualname__ equality.
#
# The hashlib OpenSSL-backed constructors sha224, sha384, sha3_256, and sha3_512
# all carry __qualname__ values with the 'openssl_' prefix. hashlib_extra92
# anchors sha224/sha384; this table anchors sha3_256/sha3_512 for the first time
# and cross-checks sha224/sha384 under hashlibconstructors95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra95.sha224_sha384_sha3_qualnames:
  description: "hashlib.sha224/__qualname__.__eq__('openssl_sha224')==True / sha384/__qualname__.__eq__('openssl_sha384')==True / sha3_256/__qualname__.__eq__('openssl_sha3_256')==True / sha3_512/__qualname__.__eq__('openssl_sha3_512')==True — sha224/sha384/sha3_256/sha3_512 are OpenSSL-backed C functions with 'openssl_' prefix qualnames; hashlib_extra92 first anchors sha224/sha384; this table cross-checks them and first-anchors sha3_256/sha3_512 under hashlibconstructors95; first hashlibconstructors95 anchor for sha3 qualname equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibconstructors95

  columns: [id, function, args, expected]
  rows:
    - [sha224_qualname_eq,   sha224.__qualname__.__eq__,   ["openssl_sha224"],   true]
    - [sha384_qualname_eq,   sha384.__qualname__.__eq__,   ["openssl_sha384"],   true]
    - [sha3_256_qualname_eq, sha3_256.__qualname__.__eq__, ["openssl_sha3_256"], true]
    - [sha3_512_qualname_eq, sha3_512.__qualname__.__eq__, ["openssl_sha3_512"], true]

# ---------------------------------------------------------------------------
# hashlib.sha256/__module__.__eq__('_hashlib')
# hashlib.sha512/__module__.__eq__('_hashlib')
# hashlib.sha1/__module__.__eq__('_hashlib')
# hashlib.md5/__module__.__eq__('_hashlib')
# hashlib.sha224/__module__.__eq__('_hashlib')
# hashlib.sha384/__module__.__eq__('_hashlib')
# hashlib.sha3_256/__module__.__eq__('_hashlib')
# hashlib.sha3_512/__module__.__eq__('_hashlib')
#
# Wave 256 theme: all constructor __module__ equality to '_hashlib'.
#
# All eight OpenSSL-backed constructor functions in hashlib have __module__
# equal to '_hashlib' (the C extension). hashlib_extra92 first anchors
# __module__ for sha256/sha512/sha1/md5/sha224/sha384; this table groups all
# eight for the first time under hashlibconstructors95, adding sha3_256/sha3_512.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra95.all_constructor_modules:
  description: "hashlib.sha256/__module__.__eq__('_hashlib')==True / sha512/__module__.__eq__('_hashlib')==True / sha1/__module__.__eq__('_hashlib')==True / md5/__module__.__eq__('_hashlib')==True / sha224/__module__.__eq__('_hashlib')==True / sha384/__module__.__eq__('_hashlib')==True / sha3_256/__module__.__eq__('_hashlib')==True / sha3_512/__module__.__eq__('_hashlib')==True — all eight OpenSSL-backed constructors have __module__=='_hashlib' (the C extension); hashlib_extra92 first anchors sha256/sha512/sha1/md5/sha224/sha384; this table first-anchors sha3_256/sha3_512 and groups all eight under hashlibconstructors95; first hashlibconstructors95 anchor for all constructor __module__ equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibconstructors95

  columns: [id, function, args, expected]
  rows:
    - [sha256_module_eq,   sha256.__module__.__eq__,   ["_hashlib"], true]
    - [sha512_module_eq,   sha512.__module__.__eq__,   ["_hashlib"], true]
    - [sha1_module_eq,     sha1.__module__.__eq__,     ["_hashlib"], true]
    - [md5_module_eq,      md5.__module__.__eq__,      ["_hashlib"], true]
    - [sha224_module_eq,   sha224.__module__.__eq__,   ["_hashlib"], true]
    - [sha384_module_eq,   sha384.__module__.__eq__,   ["_hashlib"], true]
    - [sha3_256_module_eq, sha3_256.__module__.__eq__, ["_hashlib"], true]
    - [sha3_512_module_eq, sha3_512.__module__.__eq__, ["_hashlib"], true]

# ---------------------------------------------------------------------------
# hashlib.new/__qualname__.__eq__('__hash_new') — standalone
#
# hashlib.new.__qualname__ is '__hash_new'. The hashlib.new function is a Python
# wrapper that dispatches to the appropriate OpenSSL or builtin hash constructor.
# No prior hashlib spec anchors new.__qualname__.__eq__('__hash_new') as a
# standalone under hashlibconstructors95. First standalone for hashlib.new qualname.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra95.new_qualname_eq:
  description: "hashlib.new.__qualname__.__eq__('__hash_new') == True — hashlib.new is a Python wrapper function with qualname '__hash_new'; it dispatches to the appropriate OpenSSL or builtin hash constructor; no prior hashlib spec anchors this __eq__ call; first standalone for hashlib.new qualname under hashlibconstructors95"
  category: type_identity
  kind: python_call_eq
  function: new.__qualname__.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new/__module__.__eq__('hashlib') — standalone
#
# hashlib.new.__module__ is 'hashlib' (unlike the constructor shortcuts which
# have __module__ '_hashlib'). hashlib.new is defined in the hashlib.py Python
# wrapper module, not the C extension. No prior hashlib spec anchors
# new.__module__.__eq__('hashlib') as a standalone under hashlibconstructors95.
# First standalone for hashlib.new __module__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra95.new_module_eq:
  description: "hashlib.new.__module__.__eq__('hashlib') == True — hashlib.new is defined in the hashlib.py Python wrapper (not the _hashlib C extension), so its __module__ is 'hashlib'; this contrasts with sha256/sha512 etc. whose __module__ is '_hashlib'; no prior hashlib spec anchors this __eq__ call; first standalone for hashlib.new __module__ under hashlibconstructors95"
  category: type_identity
  kind: python_call_eq
  function: new.__module__.__eq__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256/__qualname__.__eq__('openssl_sha256') — standalone
#
# hashlib.sha256.__qualname__ is 'openssl_sha256'. The 'openssl_' prefix reflects
# that this constructor is backed by the OpenSSL library. hashlib_extra92 first
# anchors this in a table; this standalone re-anchors it under hashlibconstructors95.
# First standalone for sha256 qualname under hashlibconstructors95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra95.sha256_qualname_eq:
  description: "hashlib.sha256.__qualname__.__eq__('openssl_sha256') == True — hashlib.sha256 is an OpenSSL-backed C constructor with qualname 'openssl_sha256'; the 'openssl_' prefix reflects its OpenSSL backend; hashlib_extra92 first anchors this; first standalone for sha256 qualname under hashlibconstructors95"
  category: type_identity
  kind: python_call_eq
  function: sha256.__qualname__.__eq__
  args: ["openssl_sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256/__qualname__.__eq__('openssl_sha3_256') — standalone
#
# hashlib.sha3_256.__qualname__ is 'openssl_sha3_256'. This is the first hashlib
# spec to anchor sha3_256.__qualname__ as a standalone. The sha3_256 constructor
# is OpenSSL-backed and carries the 'openssl_' prefix in its qualname.
# No prior hashlib spec anchors this as a standalone under hashlibconstructors95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra95.sha3_256_qualname_eq:
  description: "hashlib.sha3_256.__qualname__.__eq__('openssl_sha3_256') == True — hashlib.sha3_256 is an OpenSSL-backed C constructor with qualname 'openssl_sha3_256'; this is the first hashlib spec to anchor sha3_256.__qualname__ as a standalone; no prior hashlib spec anchors this __eq__ call; first standalone for sha3_256 qualname under hashlibconstructors95"
  category: type_identity
  kind: python_call_eq
  function: sha3_256.__qualname__.__eq__
  args: ["openssl_sha3_256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_512/__module__.__eq__('_hashlib') — standalone
#
# hashlib.sha3_512.__module__ is '_hashlib'. The sha3_512 constructor is
# implemented in the _hashlib C extension. This is the first hashlib spec to
# anchor sha3_512.__module__ as a standalone under hashlibconstructors95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra95.sha3_512_module_eq:
  description: "hashlib.sha3_512.__module__.__eq__('_hashlib') == True — hashlib.sha3_512 is implemented in the _hashlib C extension; its __module__ is '_hashlib'; this is the first hashlib spec to anchor sha3_512.__module__ as a standalone; no prior hashlib spec anchors this __eq__ call; first standalone for sha3_512 __module__ under hashlibconstructors95"
  category: type_identity
  kind: python_call_eq
  function: sha3_512.__module__.__eq__
  args: ["_hashlib"]
  expected: true
