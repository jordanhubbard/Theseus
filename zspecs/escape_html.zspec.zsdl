spec: escape_html
version: ">=1.0.0"
backend: node(escape-html)

docs: https://github.com/component/escape-html#readme

provenance:
  derived_from:
    - "escape-html README — https://github.com/component/escape-html#readme"
    - "HTML 5 spec — Character references — https://html.spec.whatwg.org/multipage/syntax.html#character-references"
    - "Test vectors verified with escape-html@1.0.3 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "escape-html source: index.js"
  notes:
    - "escape-html exports the escape function as the module default (CJS)."
    - "require('escape-html') returns the function directly; fn_name is null (call module itself)."
    - "Escapes 5 characters: & → &amp;  < → &lt;  > → &gt;  \" → &quot;  ' → &#39;"
    - "Single quotes use numeric &#39; not &apos; for broader HTML4 compatibility."
    - "Strings with no special characters are returned unchanged."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "No errors thrown for string inputs. Returns the HTML-escaped string directly."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

# ---------------------------------------------------------------------------
# HTML entity escaping
# ---------------------------------------------------------------------------

table escape_html.entities:
  kind: node_module_call_eq
  function: ~
  category: entities
  id_prefix: esc

  columns: [id, args, expected]
  rows:
    - [ampersand,    ["a&b"],      "a&amp;b"]
    - [lt,           ["a<b"],      "a&lt;b"]
    - [gt,           ["a>b"],      "a&gt;b"]
    - [double_quote, ["a\"b"],     "a&quot;b"]
    - [single_quote, ["a'b"],      "a&#39;b"]

table escape_html.passthrough:
  kind: node_module_call_eq
  function: ~
  category: passthrough
  id_prefix: pass

  columns: [id, args, expected]
  rows:
    - [plain,   ["hello"],          "hello"]
    - [empty,   [""],               ""]
    - [digits,  ["abc123"],         "abc123"]
    - [slash,   ["/path/to/page"],  "/path/to/page"]

table escape_html.combined:
  kind: node_module_call_eq
  function: ~
  category: combined
  id_prefix: combined

  columns: [id, args, expected]
  rows:
    - [html_tag,    ["<b>bold</b>"],             "&lt;b&gt;bold&lt;/b&gt;"]
    - [attr_value,  ["<a href=\"x\">link</a>"],  "&lt;a href=&quot;x&quot;&gt;link&lt;/a&gt;"]
    - [all_five,    ["<a href=\"x\">test & 'more'</a>"], "&lt;a href=&quot;x&quot;&gt;test &amp; &#39;more&#39;&lt;/a&gt;"]
