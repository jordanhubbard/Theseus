spec: pathlib_extra220
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra219.zspec.zsdl — covers pathlib class __doc__ contains checks (different words)"
  notes:
    - "pathlib.Path.__doc__.__contains__('subclass') == True; doc says 'PurePath subclass that can make system calls'; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__doc__.__contains__('methods') == True; doc mentions methods; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__doc__.__contains__('offers') == True; doc says 'offers operations'; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__doc__.__contains__('without') == True; doc says 'without I/O'; confirmed Python 3.14.3 macOS."
    - "pathlib.PosixPath.__doc__.__contains__('instantiating') == True; doc says 'instantiating a Path should return this object'; confirmed Python 3.14.3 macOS."
    - "pathlib.PosixPath.__doc__.__contains__('system') == True; doc says 'On a POSIX system'; confirmed Python 3.14.3 macOS."
    - "pathlib.WindowsPath.__doc__.__contains__('instantiating') == True; doc says 'instantiating a Path should return this object'; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePosixPath.__doc__.__contains__('subclass') == True; doc says 'PurePath subclass'; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __doc__ contains checks for Path and PurePath (new words)
# Path and PurePath __doc__ string substring membership — different words
# ---------------------------------------------------------------------------

table pathlib_extra220.path_doc_contains_extra:
  description: "pathlib.Path and pathlib.PurePath __doc__ string contains additional expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibdoccontains220a

  columns: [id, function, args, expected, description]
  rows:
    - [path_doc_contains_subclass,      pathlib.Path.__doc__.__contains__,     ["subclass"],    true, "pathlib.Path.__doc__.__contains__('subclass') == True; doc says 'PurePath subclass'; confirmed Python 3.14.3 macOS"]
    - [path_doc_contains_calls,         pathlib.Path.__doc__.__contains__,     ["calls"],        true, "pathlib.Path.__doc__.__contains__('calls') == True; doc says 'make system calls'; confirmed Python 3.14.3 macOS"]
    - [path_doc_contains_methods,       pathlib.Path.__doc__.__contains__,     ["methods"],      true, "pathlib.Path.__doc__.__contains__('methods') == True; doc mentions methods; confirmed Python 3.14.3 macOS"]
    - [path_doc_contains_also,          pathlib.Path.__doc__.__contains__,     ["also"],         true, "pathlib.Path.__doc__.__contains__('also') == True; doc says 'also offers'; confirmed Python 3.14.3 macOS"]
    - [purepath_doc_contains_offers,    pathlib.PurePath.__doc__.__contains__,  ["offers"],      true, "pathlib.PurePath.__doc__.__contains__('offers') == True; doc says 'offers operations'; confirmed Python 3.14.3 macOS"]
    - [purepath_doc_contains_without,   pathlib.PurePath.__doc__.__contains__,  ["without"],     true, "pathlib.PurePath.__doc__.__contains__('without') == True; doc says 'without I/O'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: __doc__ contains checks for PurePath and PurePosixPath (new words)
# PurePath and PurePosixPath __doc__ string substring membership
# ---------------------------------------------------------------------------

table pathlib_extra220.purepath_doc_contains_extra:
  description: "pathlib.PurePath and pathlib.PurePosixPath __doc__ string contains additional expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibdoccontains220b

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_doc_contains_operations,       pathlib.PurePath.__doc__.__contains__,     ["operations"],    true, "pathlib.PurePath.__doc__.__contains__('operations') == True; doc says 'offers operations'; confirmed Python 3.14.3 macOS"]
    - [purepath_doc_contains_Base,             pathlib.PurePath.__doc__.__contains__,     ["Base"],           true, "pathlib.PurePath.__doc__.__contains__('Base') == True; doc starts with 'Base class'; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_doc_contains_subclass,    pathlib.PurePosixPath.__doc__.__contains__, ["subclass"],      true, "pathlib.PurePosixPath.__doc__.__contains__('subclass') == True; doc says 'PurePath subclass'; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_doc_contains_system,      pathlib.PurePosixPath.__doc__.__contains__, ["system"],        true, "pathlib.PurePosixPath.__doc__.__contains__('system') == True; doc says 'On a POSIX system'; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_doc_contains_directly,    pathlib.PurePosixPath.__doc__.__contains__, ["directly"],      true, "pathlib.PurePosixPath.__doc__.__contains__('directly') == True; doc says 'instantiate it directly on any system'; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_doc_contains_instantiate, pathlib.PurePosixPath.__doc__.__contains__, ["instantiate"],   true, "pathlib.PurePosixPath.__doc__.__contains__('instantiate') == True; doc says 'can also instantiate it directly'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: __doc__ contains checks for PosixPath and WindowsPath (new words)
# PosixPath and WindowsPath __doc__ string substring membership
# ---------------------------------------------------------------------------

table pathlib_extra220.concrete_path_doc_contains_extra:
  description: "pathlib.PosixPath and pathlib.WindowsPath __doc__ string contains additional expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibdoccontains220c

  columns: [id, function, args, expected, description]
  rows:
    - [posixpath_doc_contains_instantiating, pathlib.PosixPath.__doc__.__contains__,   ["instantiating"], true, "pathlib.PosixPath.__doc__.__contains__('instantiating') == True; doc says 'instantiating a Path should return this object'; confirmed Python 3.14.3 macOS"]
    - [posixpath_doc_contains_system,        pathlib.PosixPath.__doc__.__contains__,   ["system"],        true, "pathlib.PosixPath.__doc__.__contains__('system') == True; doc says 'On a POSIX system'; confirmed Python 3.14.3 macOS"]
    - [posixpath_doc_contains_return,        pathlib.PosixPath.__doc__.__contains__,   ["return"],        true, "pathlib.PosixPath.__doc__.__contains__('return') == True; doc says 'should return this object'; confirmed Python 3.14.3 macOS"]
    - [windowspath_doc_contains_instantiating, pathlib.WindowsPath.__doc__.__contains__, ["instantiating"], true, "pathlib.WindowsPath.__doc__.__contains__('instantiating') == True; doc says 'instantiating a Path should return this object'; confirmed Python 3.14.3 macOS"]
    - [windowspath_doc_contains_subclass,    pathlib.WindowsPath.__doc__.__contains__,  ["subclass"],      true, "pathlib.WindowsPath.__doc__.__contains__('subclass') == True; doc says 'Path subclass for Windows systems'; confirmed Python 3.14.3 macOS"]
    - [windowspath_doc_contains_system,      pathlib.WindowsPath.__doc__.__contains__,  ["system"],        true, "pathlib.WindowsPath.__doc__.__contains__('system') == True; doc says 'On a Windows system'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra220.path_doc_contains_subclass:
  description: "pathlib.Path.__doc__.__contains__('subclass') == True — Path doc says 'PurePath subclass that can make system calls'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__doc__.__contains__
  args: ["subclass"]
  expected: true

invariant pathlib_extra220.purepath_doc_contains_offers:
  description: "pathlib.PurePath.__doc__.__contains__('offers') == True — PurePath doc says 'offers operations which don't involve I/O'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__doc__.__contains__
  args: ["offers"]
  expected: true

invariant pathlib_extra220.purepath_doc_contains_without:
  description: "pathlib.PurePath.__doc__.__contains__('without') == True — PurePath doc says 'manipulating paths without I/O'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__doc__.__contains__
  args: ["without"]
  expected: true

invariant pathlib_extra220.posixpath_doc_contains_instantiating:
  description: "pathlib.PosixPath.__doc__.__contains__('instantiating') == True — PosixPath doc says 'instantiating a Path should return this object'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PosixPath.__doc__.__contains__
  args: ["instantiating"]
  expected: true

invariant pathlib_extra220.pureposixpath_doc_contains_subclass:
  description: "pathlib.PurePosixPath.__doc__.__contains__('subclass') == True — PurePosixPath doc says 'PurePath subclass for non-Windows systems'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePosixPath.__doc__.__contains__
  args: ["subclass"]
  expected: true

invariant pathlib_extra220.windowspath_doc_contains_instantiating:
  description: "pathlib.WindowsPath.__doc__.__contains__('instantiating') == True — WindowsPath doc says 'instantiating a Path should return this object'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.WindowsPath.__doc__.__contains__
  args: ["instantiating"]
  expected: true
