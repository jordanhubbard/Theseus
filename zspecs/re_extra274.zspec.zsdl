spec: re_extra274
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.compile(r'\\p') raises re.error (PatternError) for a bad escape sequence at position 0."
    - "re.compile(r'(\\w+)\\2') raises re.error (PatternError) for an invalid group reference (group 2 does not exist)."
    - "re.sub(r'(\\w+)', r'\\2', 'hello') raises re.error (PatternError) for an invalid group reference in the replacement."
    - "re.match(None, 'test') raises TypeError: first argument must be string or compiled pattern."
    - "re.compile('test', re.LOCALE | re.UNICODE) raises ValueError: cannot use LOCALE flag with a str pattern."
    - "re.compile, re.sub, and re.match are all pure Python functions (__class__.__name__ == 'function')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: re function class identity (compile, sub, match are Python functions)
# ---------------------------------------------------------------------------

table re_extra274.re_function_identity:
  description: "re.compile, re.sub, re.match __class__.__name__ identity — all are pure Python functions"
  kind: python_call_eq
  category: identity
  id_prefix: rfi

  columns: [id, function, args, expected, description]
  rows:
    - [compile_class, compile.__class__.__name__.__eq__, ["function"], true, "re.compile.__class__.__name__ == 'function' — re.compile is a pure Python function"]
    - [sub_class,     sub.__class__.__name__.__eq__,     ["function"], true, "re.sub.__class__.__name__ == 'function' — re.sub is a pure Python function"]
    - [match_class,   match.__class__.__name__.__eq__,   ["function"], true, "re.match.__class__.__name__ == 'function' — re.match is a pure Python function"]

# ---------------------------------------------------------------------------
# Standalone invariants: error-raising cases for compile, sub, match
# ---------------------------------------------------------------------------

invariant re_extra274.compile_bad_escape:
  description: "re.compile(r'\\p') raises re.error (PatternError) — bad escape sequence \\p at position 0"
  category: errors
  kind: python_call_raises
  function: compile
  args: ["\\p"]
  raises: error

invariant re_extra274.compile_invalid_group_ref:
  description: "re.compile(r'(\\w+)\\2') raises re.error (PatternError) — group 2 does not exist"
  category: errors
  kind: python_call_raises
  function: compile
  args: ["(\\w+)\\2"]
  raises: error

invariant re_extra274.sub_invalid_group_ref:
  description: "re.sub(r'(\\w+)', r'\\2', 'hello') raises re.error (PatternError) — invalid group reference 2 in replacement"
  category: errors
  kind: python_call_raises
  function: sub
  args: ["(\\w+)", "\\2", "hello"]
  raises: error

invariant re_extra274.match_none_pattern:
  description: "re.match(None, 'test') raises TypeError — first argument must be string or compiled pattern"
  category: errors
  kind: python_call_raises
  function: match
  args: [null, "test"]
  raises: TypeError

invariant re_extra274.compile_locale_unicode_flags:
  description: "re.compile('test', re.LOCALE | re.UNICODE) raises ValueError — cannot use LOCALE flag with a str pattern"
  category: errors
  kind: python_call_raises
  function: re.compile
  args: ["test", 36]
  raises: ValueError

invariant re_extra274.compile_is_function:
  description: "re.compile.__class__.__name__ == 'function' — re.compile is a pure Python function"
  category: identity
  kind: python_call_eq
  function: compile.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant re_extra274.sub_is_function:
  description: "re.sub.__class__.__name__ == 'function' — re.sub is a pure Python function"
  category: identity
  kind: python_call_eq
  function: sub.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant re_extra274.match_is_function:
  description: "re.match.__class__.__name__ == 'function' — re.match is a pure Python function"
  category: identity
  kind: python_call_eq
  function: match.__class__.__name__.__eq__
  args: ["function"]
  expected: true
