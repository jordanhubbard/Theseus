spec: uuid_extra1396
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 540 (_extra1396): focuses on __class_getitem__ and __init_subclass__ method checks."
    - "uuid.UUID is a concrete pure-Python class. It does not define __class_getitem__ in its own __dict__, so uuid.UUID.__dict__.__contains__('__class_getitem__') returns False."
    - "uuid.SafeUUID is an IntEnum subclass (metaclass EnumType). It also does not define __class_getitem__ in its own __dict__, so uuid.SafeUUID.__dict__.__contains__('__class_getitem__') returns False."
    - "Neither uuid.UUID nor uuid.SafeUUID defines __init_subclass__ in their own __dict__; both inherit it from object."
    - "When accessed as uuid.UUID.__init_subclass__, the classmethod_descriptor in object.__dict__ is bound through the descriptor protocol, yielding a 'builtin_function_or_method'."
    - "uuid.SafeUUID.__class__.__name__ == 'EnumType' — SafeUUID's metaclass is EnumType (formerly EnumMeta), not the plain 'type'."
    - "uuid.UUID.__class__.__name__ == 'type' — UUID is a plain Python class with metaclass type."
    - "object.__dict__.__contains__('__init_subclass__') returns True; object is the owner of __init_subclass__ as a classmethod_descriptor."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table uuid_extra1396.uuid_class_getitem_absent:
  description: "uuid.UUID and uuid.SafeUUID class dicts do not contain __class_getitem__ — neither class opted into the generic alias protocol; __dict__.__contains__ returns False for both"
  kind: python_call_eq
  category: class_getitem_checks
  id_prefix: uu1396cg
  columns: [id, function, args, expected]
  rows:
    - [uu1396cg001, uuid.UUID.__dict__.__contains__,                                ["__class_getitem__"], false]
    - [uu1396cg002, uuid.SafeUUID.__dict__.__contains__,                            ["__class_getitem__"], false]
    - [uu1396cg003, uuid.UUID.__dict__.__contains__,                                ["__init_subclass__"], false]
    - [uu1396cg004, uuid.SafeUUID.__dict__.__contains__,                            ["__init_subclass__"], false]
    - [uu1396cg005, uuid.UUID.__dict__.__class__.__name__.__eq__,                   ["mappingproxy"],      true]
    - [uu1396cg006, uuid.SafeUUID.__dict__.__class__.__name__.__eq__,               ["mappingproxy"],      true]

table uuid_extra1396.uuid_init_subclass_bound_checks:
  description: "uuid.UUID and uuid.SafeUUID inherit __init_subclass__ from object; when accessed as an attribute the descriptor protocol yields a builtin_function_or_method; object.__dict__ contains the classmethod_descriptor"
  kind: python_call_eq
  category: init_subclass_checks
  id_prefix: uu1396is
  columns: [id, function, args, expected]
  rows:
    - [uu1396is001, uuid.UUID.__init_subclass__.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [uu1396is002, uuid.SafeUUID.__init_subclass__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [uu1396is003, object.__dict__.__contains__,                                ["__init_subclass__"],          true]
    - [uu1396is004, object.__dict__.__contains__,                                ["__class_getitem__"],          false]
    - [uu1396is005, uuid.UUID.__class__.__name__.__eq__,                         ["type"],                       true]
    - [uu1396is006, uuid.SafeUUID.__class__.__name__.__eq__,                     ["EnumType"],                   true]

table uuid_extra1396.uuid_metaclass_and_mro_checks:
  description: "uuid.UUID and uuid.SafeUUID metaclass and MRO consistency checks; SafeUUID metaclass is EnumType while UUID metaclass is the plain type; both MROs are tuples"
  kind: python_call_eq
  category: class_getitem_checks
  id_prefix: uu1396mc
  columns: [id, function, args, expected]
  rows:
    - [uu1396mc001, uuid.UUID.__mro__.__class__.__name__.__eq__,               ["tuple"],    true]
    - [uu1396mc002, uuid.SafeUUID.__mro__.__class__.__name__.__eq__,           ["tuple"],    true]
    - [uu1396mc003, uuid.UUID.__bases__.__class__.__name__.__eq__,             ["tuple"],    true]
    - [uu1396mc004, uuid.SafeUUID.__bases__.__class__.__name__.__eq__,         ["tuple"],    true]
    - [uu1396mc005, uuid.UUID.__name__.__class__.__name__.__eq__,              ["str"],      true]
    - [uu1396mc006, uuid.SafeUUID.__name__.__class__.__name__.__eq__,          ["str"],      true]
