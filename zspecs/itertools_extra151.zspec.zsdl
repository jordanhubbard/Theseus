spec: itertools_extra151
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools C-type __qualname__ equality — combinations 'combinations' len 12, permutations 'permutations' len 12, filterfalse 'filterfalse' len 11, takewhile 'takewhile' len 9, dropwhile 'dropwhile' len 9, compress 'compress' len 8, combinations_with_replacement 'combinations_with_replacement' len 29; all __qualname__ == __name__ for these C types (Wave 280)."
    - "itertools.combinations.__qualname__ == 'combinations' (len 12) — C extension types have simple qualnames equal to their __name__ (no nesting prefix). Verified with Python 3.14.3."
    - "itertools.permutations.__qualname__ == 'permutations' (len 12) — same pattern as combinations. Verified with Python 3.14.3."
    - "itertools.filterfalse.__qualname__ == 'filterfalse' (len 11) — C type simple qualname. Verified with Python 3.14.3."
    - "itertools.takewhile.__qualname__ == 'takewhile' (len 9) — C type simple qualname. Verified with Python 3.14.3."
    - "itertools.dropwhile.__qualname__ == 'dropwhile' (len 9) — C type simple qualname. Verified with Python 3.14.3."
    - "itertools.compress.__qualname__ == 'compress' (len 8) — C type simple qualname. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement' (len 29) — C type simple qualname equals __name__. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools C-type __qualname__ equality — combinations and permutations
#
# Wave 280 theme: C extension types have simple __qualname__ == __name__.
#
# itertools.combinations.__qualname__ == 'combinations' (len 12)
# itertools.permutations.__qualname__ == 'permutations' (len 12)
#
# C types defined in Modules/itertoolsmodule.c have __qualname__ equal to their
# simple __name__ because they are not nested. New to extra151.
# ---------------------------------------------------------------------------

table itertools_extra151.ctype_qualname_combinations_permutations:
  description: "itertools combinations/permutations __qualname__ == __name__: combinations 'combinations' len 12, permutations 'permutations' len 12; C type simple qualnames; wave 280; new to extra151"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscqn151

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_qualname_eq,
       "combinations.__qualname__.__eq__",
       ["combinations"],
       true,
       "itertools.combinations.__qualname__.__eq__('combinations') == True — combinations is a C extension type defined in Modules/itertoolsmodule.c; C types at module scope have __qualname__ equal to their simple name; str.__eq__('combinations') returns True; new to extra151"]
    - [combinations_qualname_len_eq_12,
       "combinations.__qualname__.__len__",
       [],
       12,
       "itertools.combinations.__qualname__.__len__() == 12 — __qualname__ is 'combinations' which has 12 characters; len('combinations') == 12; new to extra151"]
    - [combinations_qualname_eq_name,
       "combinations.__qualname__.__eq__",
       ["combinations"],
       true,
       "itertools.combinations.__qualname__.__eq__(itertools.combinations.__name__) — qualname equals name for C types at module scope; both are 'combinations'; new to extra151"]
    - [permutations_qualname_eq,
       "permutations.__qualname__.__eq__",
       ["permutations"],
       true,
       "itertools.permutations.__qualname__.__eq__('permutations') == True — permutations is a C extension type; its __qualname__ equals its simple __name__ 'permutations'; str.__eq__('permutations') returns True; new to extra151"]
    - [permutations_qualname_len_eq_12,
       "permutations.__qualname__.__len__",
       [],
       12,
       "itertools.permutations.__qualname__.__len__() == 12 — __qualname__ is 'permutations' which has 12 characters; len('permutations') == 12; new to extra151"]

# ---------------------------------------------------------------------------
# Table 2: itertools C-type __qualname__ — filterfalse, takewhile, dropwhile
#
# Wave 280 theme: filtering C types have simple qualnames.
#
# itertools.filterfalse.__qualname__ == 'filterfalse' (len 11)
# itertools.takewhile.__qualname__ == 'takewhile' (len 9)
# itertools.dropwhile.__qualname__ == 'dropwhile' (len 9)
#
# All three are C extension types in itertoolsmodule.c with simple qualnames.
# New to extra151.
# ---------------------------------------------------------------------------

table itertools_extra151.ctype_qualname_filter_types:
  description: "itertools filterfalse/takewhile/dropwhile __qualname__: filterfalse 'filterfalse' len 11, takewhile 'takewhile' len 9, dropwhile 'dropwhile' len 9; C type simple qualnames; wave 280; new to extra151"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsfiltqn151

  columns: [id, function, args, expected, description]
  rows:
    - [filterfalse_qualname_eq,
       "filterfalse.__qualname__.__eq__",
       ["filterfalse"],
       true,
       "itertools.filterfalse.__qualname__.__eq__('filterfalse') == True — filterfalse is a C extension type; it yields elements for which predicate is False; its __qualname__ equals its simple __name__; str.__eq__('filterfalse') returns True; new to extra151"]
    - [filterfalse_qualname_len_eq_11,
       "filterfalse.__qualname__.__len__",
       [],
       11,
       "itertools.filterfalse.__qualname__.__len__() == 11 — __qualname__ is 'filterfalse' which has 11 characters; len('filterfalse') == 11; new to extra151"]
    - [takewhile_qualname_eq,
       "takewhile.__qualname__.__eq__",
       ["takewhile"],
       true,
       "itertools.takewhile.__qualname__.__eq__('takewhile') == True — takewhile is a C extension type that yields elements while predicate is true; its __qualname__ is 'takewhile'; str.__eq__('takewhile') returns True; new to extra151"]
    - [takewhile_qualname_len_eq_9,
       "takewhile.__qualname__.__len__",
       [],
       9,
       "itertools.takewhile.__qualname__.__len__() == 9 — __qualname__ is 'takewhile' which has 9 characters; len('takewhile') == 9; new to extra151"]
    - [dropwhile_qualname_eq,
       "dropwhile.__qualname__.__eq__",
       ["dropwhile"],
       true,
       "itertools.dropwhile.__qualname__.__eq__('dropwhile') == True — dropwhile is a C extension type that drops elements while predicate is true then yields the rest; its __qualname__ is 'dropwhile'; str.__eq__('dropwhile') returns True; new to extra151"]
    - [dropwhile_qualname_len_eq_9,
       "dropwhile.__qualname__.__len__",
       [],
       9,
       "itertools.dropwhile.__qualname__.__len__() == 9 — __qualname__ is 'dropwhile' which has 9 characters; len('dropwhile') == 9; new to extra151"]

# ---------------------------------------------------------------------------
# Table 3: itertools C-type __qualname__ — compress and combinations_with_replacement
#
# Wave 280 theme: compress and combinations_with_replacement qualname equality.
#
# itertools.compress.__qualname__ == 'compress' (len 8)
# itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement' (len 29)
#
# compress filters elements where selectors are true; combinations_with_replacement
# produces sorted tuples allowing repeated elements. Both are C types with simple
# qualnames. New to extra151.
# ---------------------------------------------------------------------------

table itertools_extra151.ctype_qualname_compress_cwr:
  description: "itertools compress/combinations_with_replacement __qualname__: compress 'compress' len 8, combinations_with_replacement len 29; C type simple qualnames; wave 280; new to extra151"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscompqn151

  columns: [id, function, args, expected, description]
  rows:
    - [compress_qualname_eq,
       "compress.__qualname__.__eq__",
       ["compress"],
       true,
       "itertools.compress.__qualname__.__eq__('compress') == True — compress is a C extension type that filters elements using a selectors iterable; its __qualname__ equals its simple __name__ 'compress'; str.__eq__('compress') returns True; new to extra151"]
    - [compress_qualname_len_eq_8,
       "compress.__qualname__.__len__",
       [],
       8,
       "itertools.compress.__qualname__.__len__() == 8 — __qualname__ is 'compress' which has 8 characters; len('compress') == 8; new to extra151"]
    - ["combinations_with_replacement_qualname_eq",
       "combinations_with_replacement.__qualname__.__eq__",
       ["combinations_with_replacement"],
       true,
       "itertools.combinations_with_replacement.__qualname__.__eq__('combinations_with_replacement') == True — combinations_with_replacement is a C extension type producing r-length subsequences with repetition; its __qualname__ equals its simple __name__; str.__eq__('combinations_with_replacement') returns True; new to extra151"]
    - ["combinations_with_replacement_qualname_len_eq_29",
       "combinations_with_replacement.__qualname__.__len__",
       [],
       29,
       "itertools.combinations_with_replacement.__qualname__.__len__() == 29 — __qualname__ is 'combinations_with_replacement' which has 29 characters; len('combinations_with_replacement') == 29; new to extra151"]

