spec: globby
version: ">=16.0.0"
backend: node(globby)

docs: https://github.com/sindresorhus/globby#readme

provenance:
  derived_from:
    - "globby README — https://github.com/sindresorhus/globby#readme"
    - "Test vectors verified with globby via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "globby source"
  notes:
    - "User-friendly glob with .gitignore support — wraps fast-glob."
    - "Install: npm install globby"
    - "v16 ESM only; named exports globby / globbySync / globbyStream / isDynamicPattern / isGitIgnored."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Throws TypeError on invalid pattern; globbySync returns [] on no match."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant globby.isDynamicPattern_glob_true:
  description: "isDynamicPattern('*.js') is true"
  category: helpers
  kind: node_chain_eq
  entry: named
  function: isDynamicPattern
  entry_args: ["*.js"]
  chain: []
  expected: true

invariant globby.isDynamicPattern_literal_false:
  description: "isDynamicPattern('foo.txt') is false"
  category: helpers
  kind: node_chain_eq
  entry: named
  function: isDynamicPattern
  entry_args: ["foo.txt"]
  chain: []
  expected: false

invariant globby.isDynamicPattern_globstar_true:
  description: "isDynamicPattern('**/*.ts') is true (globstar)"
  category: helpers
  kind: node_chain_eq
  entry: named
  function: isDynamicPattern
  entry_args: ["**/*.ts"]
  chain: []
  expected: true

invariant globby.isDynamicPattern_question_true:
  description: "isDynamicPattern('?.js') is true (single-char wildcard)"
  category: helpers
  kind: node_chain_eq
  entry: named
  function: isDynamicPattern
  entry_args: ["?.js"]
  chain: []
  expected: true

invariant globby.globbySync_no_match:
  description: "globbySync on non-matching pattern returns []"
  category: glob
  kind: node_chain_eq
  entry: named
  function: globbySync
  entry_args: [["/tmp/no-such-globby-pattern-xyz/*.txt"]]
  chain:
    - {get: length}
  expected: 0

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:38:38Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
