spec: fnmatch_extra9
version: ">=3.9"
backend: python_module(fnmatch)

docs: https://docs.python.org/3/library/fnmatch.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fnmatch.html — Python fnmatch module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fnmatch.py"
  notes:
    - "This spec extends fnmatch.zspec.zsdl and fnmatch_extra through fnmatch_extra8.zspec.zsdl."
    - "fnmatch_extra8 covers __class__.__name__ == 'function' for all 4 functions; fnmatch [a-z]/[0-9] range vectors; filter '??.py' pattern; translate '[0-9]' type/length."
    - "fnmatch_extra7 covers function __module__ anchors; fnmatch/fnmatchcase/filter additional vectors."
    - "fnmatch_extra6 covers translate pattern table; fnmatch negation/compound; fnmatchcase case mismatch."
    - "fnmatch_extra5 covers translate('*') and translate(''); fnmatch empty_matches_empty; filter empty_list."
    - "NOT yet covered: fnmatch.fnmatch('hello', 'h?llo') == True — single-char wildcard matching a middle character."
    - "NOT yet covered: fnmatch.fnmatch('hllo', 'h?llo') == False — '?' requires exactly one character."
    - "NOT yet covered: fnmatch.fnmatchcase('Hello', 'H?llo') == True — fnmatchcase with '?' wildcard."
    - "NOT yet covered: fnmatch.fnmatchcase('Hello', 'h?llo') == False — case-sensitive '?' mismatch."
    - "NOT yet covered: fnmatch.filter(['a.py','b.py','c.txt'], '[ab].py') == ['a.py','b.py'] — bracket pattern."
    - "NOT yet covered: fnmatch.filter(['foo.py','bar.py','baz.txt'], 'b*.py') == ['bar.py'] — star with prefix."
    - "NOT yet covered: fnmatch.translate('h?llo') returns non-empty str."
    - "NOT yet covered: fnmatch.translate('*.py') exact string value (Python 3.12 format)."
    - "fnmatch.fnmatch('hello', 'h?llo') == True — '?' matches exactly one char 'e'."
    - "fnmatch.fnmatch('hllo', 'h?llo') == False — 'h' followed directly by 'llo' has no char for '?'."
    - "fnmatch.fnmatchcase('Hello', 'H?llo') == True — case-sensitive, 'e' matches '?'."
    - "fnmatch.fnmatchcase('Hello', 'h?llo') == False — 'H' != 'h' in fnmatchcase."
    - "fnmatch.filter(['a.py','b.py','c.txt'], '[ab].py') == ['a.py','b.py'] — bracket char-class filter."
    - "fnmatch.filter(['foo.py','bar.py','baz.txt'], 'b*.py') == ['bar.py'] — star with leading char."
    - "fnmatch.translate('h?llo').__len__() > 0 — translate always returns non-empty str."
    - "fnmatch.translate('*.py') == '(?s:.*\\.py)\\z' — Python 3.12 regex format."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# fnmatch — '?' single-character wildcard behavioral vectors
#
# fnmatch.zspec covers star ('*') and character-class patterns.
# No prior fnmatch spec exercises '?' in the middle of a pattern with an
# exact-length constraint (both match and no-match cases).
# ---------------------------------------------------------------------------

invariant fnmatch_extra9.fnmatch.question_mark_match:
  description: "fnmatch.fnmatch('hello', 'h?llo') == True — '?' matches exactly one char"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["hello", "h?llo"]
  expected: true

invariant fnmatch_extra9.fnmatch.question_mark_no_match:
  description: "fnmatch.fnmatch('hllo', 'h?llo') == False — '?' requires exactly one character"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["hllo", "h?llo"]
  expected: false

# ---------------------------------------------------------------------------
# fnmatchcase — '?' wildcard with case sensitivity
#
# fnmatch_extra3/4/5 cover fnmatchcase case-sensitivity with '*' patterns.
# No prior spec tests fnmatchcase with a '?' pattern.
# ---------------------------------------------------------------------------

invariant fnmatch_extra9.fnmatchcase.question_mark_case_match:
  description: "fnmatch.fnmatchcase('Hello', 'H?llo') == True — case-sensitive, '?' matches 'e'"
  category: fnmatchcase
  kind: python_call_eq
  function: fnmatchcase
  args: ["Hello", "H?llo"]
  expected: true

invariant fnmatch_extra9.fnmatchcase.question_mark_case_mismatch:
  description: "fnmatch.fnmatchcase('Hello', 'h?llo') == False — 'H' != 'h' in fnmatchcase"
  category: fnmatchcase
  kind: python_call_eq
  function: fnmatchcase
  args: ["Hello", "h?llo"]
  expected: false

# ---------------------------------------------------------------------------
# filter — bracket character-class pattern and prefix-star pattern
#
# fnmatch.zspec covers filter with '*.py'. No prior spec uses a bracket
# char-class pattern or a 'letter + star' prefix pattern with filter.
# ---------------------------------------------------------------------------

invariant fnmatch_extra9.filter.bracket_class_pattern:
  description: "fnmatch.filter(['a.py','b.py','c.txt'], '[ab].py') == ['a.py','b.py']"
  category: filter
  kind: python_call_eq
  function: filter
  args: [["a.py", "b.py", "c.txt"], "[ab].py"]
  expected: ["a.py", "b.py"]

invariant fnmatch_extra9.filter.prefix_star_pattern:
  description: "fnmatch.filter(['foo.py','bar.py','baz.txt'], 'b*.py') == ['bar.py']"
  category: filter
  kind: python_call_eq
  function: filter
  args: [["foo.py", "bar.py", "baz.txt"], "b*.py"]
  expected: ["bar.py"]

# ---------------------------------------------------------------------------
# translate — '?' pattern and '*.py' exact value
#
# fnmatch_extra5 covers translate('*') and translate('').
# fnmatch_extra6 covers translate('[a-z]') and translate('*.md') exact values.
# fnmatch_extra8 covers translate('[0-9]') type/length.
# New: translate('h?llo') length check and translate('*.py') exact value.
# ---------------------------------------------------------------------------

invariant fnmatch_extra9.translate.question_pattern_nonempty:
  description: "fnmatch.translate('h?llo') is non-empty str"
  category: translate
  kind: python_call_eq
  function: translate
  args: ["h?llo"]
  method: __len__.__gt__
  method_args: [0]
  expected: true

invariant fnmatch_extra9.translate.star_py_exact:
  description: "fnmatch.translate('*.py') == '(?s:.*\\.py)\\z' — Python 3.12 regex format"
  category: translate
  kind: python_call_eq
  function: translate
  args: ["*.py"]
  expected: "(?s:.*\\.py)\\z"

# ---------------------------------------------------------------------------
# fnmatch — star pattern anchored by leading character
#
# No prior spec checks fnmatch with a 'b*' pattern (letter + star).
# This vector complements the filter.prefix_star_pattern invariant above.
# ---------------------------------------------------------------------------

invariant fnmatch_extra9.fnmatch.prefix_star_match:
  description: "fnmatch.fnmatch('bar.py', 'b*.py') == True"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["bar.py", "b*.py"]
  expected: true

invariant fnmatch_extra9.fnmatch.prefix_star_no_match:
  description: "fnmatch.fnmatch('foo.py', 'b*.py') == False — 'foo' does not start with 'b'"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["foo.py", "b*.py"]
  expected: false
