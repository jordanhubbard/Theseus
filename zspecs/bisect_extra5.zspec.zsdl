spec: bisect_extra5
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "Python bisect documentation — https://docs.python.org/3/library/bisect.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "Extends bisect.zspec.zsdl, bisect_extra.zspec.zsdl, bisect_extra2.zspec.zsdl, bisect_extra3.zspec.zsdl, and bisect_extra4.zspec.zsdl."
    - "No prior spec covers __qualname__ for any bisect function; this spec adds all of them."
    - "bisect/__qualname__=='bisect_right' — bisect is an alias for bisect_right; qualname follows the aliased name."
    - "insort/__qualname__=='insort_right' — insort is an alias for insort_right."
    - "bisect_left.__module__ == '_bisect' (C extension) is already in bisect_extra; not duplicated here."
    - "Behavioral vectors use input [1,3,5,7] — bisect_left([1,3,5,7], 4)==2 is in bisect_extra2; all other [1,3,5,7] vectors below are new."
    - "bisect_right([1,3,5,7], 4) == 2 — 4 absent; left and right agree (no equal element)."
    - "bisect_left([1,3,5,7], 3) == 1 — 3 is at index 1; left insertion point is 1."
    - "bisect_right([1,3,5,7], 3) == 2 — one past index 1; right insertion point is 2."
    - "bisect_left([1,3,5,7], 0) == 0 — 0 is before all elements."
    - "bisect_right([1,3,5,7], 9) == 4 — 9 is after all four elements."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — all bisect functions
# bisect/__qualname__=='bisect_right' because bisect is an alias for bisect_right.
# insort/__qualname__=='insort_right' because insort is an alias for insort_right.
# ---------------------------------------------------------------------------

table bisect_extra5.qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [bisect,       bisect.__qualname__.__eq__,       ["bisect_right"], true]
    - [bisect_left,  bisect_left.__qualname__.__eq__,  ["bisect_left"],  true]
    - [bisect_right, bisect_right.__qualname__.__eq__, ["bisect_right"], true]
    - [insort,       insort.__qualname__.__eq__,       ["insort_right"], true]
    - [insort_left,  insort_left.__qualname__.__eq__,  ["insort_left"],  true]
    - [insort_right, insort_right.__qualname__.__eq__, ["insort_right"], true]

# ---------------------------------------------------------------------------
# Behavioral invariants — input [1, 3, 5, 7]
#
# bisect_extra2 covers bisect_left([1,3,5,7], 4) == 2.
# All vectors below use the same list but different search values; each is new.
# ---------------------------------------------------------------------------

invariant bisect_extra5.bisect_right.gap_four:
  description: "bisect_right([1,3,5,7], 4) == 2 — 4 absent; left and right agree"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[1, 3, 5, 7], 4]
  expected: 2

invariant bisect_extra5.bisect_left.present_three:
  description: "bisect_left([1,3,5,7], 3) == 1 — 3 is at index 1; left insertion point is 1"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[1, 3, 5, 7], 3]
  expected: 1

invariant bisect_extra5.bisect_right.present_three:
  description: "bisect_right([1,3,5,7], 3) == 2 — one past index 1; right insertion point is 2"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[1, 3, 5, 7], 3]
  expected: 2

invariant bisect_extra5.bisect_left.before_all:
  description: "bisect_left([1,3,5,7], 0) == 0 — 0 is before all elements"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[1, 3, 5, 7], 0]
  expected: 0

invariant bisect_extra5.bisect_right.after_all:
  description: "bisect_right([1,3,5,7], 9) == 4 — 9 is after all four elements"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[1, 3, 5, 7], 9]
  expected: 4
