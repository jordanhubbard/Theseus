spec: concurrent_futures_extra276
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "concurrent_futures_extra275.zspec.zsdl — covers ThreadPoolExecutor identity (__name__, __module__, __bases__[0].__name__, __mro__.__len__(), __qualname__, __name__.__len__()); ThreadPoolExecutor method qualnames (submit, shutdown, map); ThreadPoolExecutor._work_queue type"
  notes:
    - "This spec covers: concurrent.futures.wait and concurrent.futures.as_completed function identity; concurrent.futures.ProcessPoolExecutor class identity and method qualnames. NEW in extra276: concurrent.futures.wait.__name__=='wait'; concurrent.futures.wait.__module__=='concurrent.futures._base'; concurrent.futures.wait.__class__.__name__=='function'; concurrent.futures.wait.__qualname__=='wait'; concurrent.futures.as_completed.__name__=='as_completed'; concurrent.futures.as_completed.__module__=='concurrent.futures._base'; concurrent.futures.as_completed.__qualname__=='as_completed'; concurrent.futures.ProcessPoolExecutor.__name__=='ProcessPoolExecutor'; concurrent.futures.ProcessPoolExecutor.__module__=='concurrent.futures.process'; concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__=='Executor'; concurrent.futures.ProcessPoolExecutor.__mro__.__len__()==3; ProcessPoolExecutor.submit.__qualname__=='ProcessPoolExecutor.submit' (len=26); ProcessPoolExecutor.shutdown.__qualname__=='ProcessPoolExecutor.shutdown' (len=28, longest); ProcessPoolExecutor.map.__qualname__=='ProcessPoolExecutor.map' (len=23). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures.wait.__module__ == 'concurrent.futures._base'. wait() is defined in Lib/concurrent/futures/_base.py alongside Future, Executor, as_completed, and the FIRST_COMPLETED/ALL_COMPLETED constants; its __module__ is 'concurrent.futures._base' (len=24: 'concurrent.futures.'=19+'_base'=5). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures.ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (len=23). Unlike ThreadPoolExecutor.map (which returns 'Executor.map' because it is unoverridden), ProcessPoolExecutor.map is overridden in process.py and so its qualname is 'ProcessPoolExecutor.map'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process'. ProcessPoolExecutor is defined in Lib/concurrent/futures/process.py; its __module__ is 'concurrent.futures.process' (len=26: 'concurrent.futures.'=19+'process'=7), the same length as 'concurrent.futures.thread' (len=26). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.wait and as_completed function identity — extra276
#
# concurrent.futures.wait.__name__              == 'wait'
# concurrent.futures.wait.__module__            == 'concurrent.futures._base'
# concurrent.futures.wait.__class__.__name__    == 'function'
# concurrent.futures.wait.__qualname__          == 'wait'
# concurrent.futures.as_completed.__name__      == 'as_completed'
# concurrent.futures.as_completed.__module__    == 'concurrent.futures._base'
# concurrent.futures.as_completed.__qualname__  == 'as_completed'
# ---------------------------------------------------------------------------

table concurrent_futures_extra276.cf_wait_as_completed_identity:
  description: "concurrent.futures.wait and as_completed function identity checks in cfwait276 namespace — both wait() and as_completed() are defined in Lib/concurrent/futures/_base.py; wait.__name__.__eq__('wait')==True; wait.__module__.__eq__('concurrent.futures._base')==True (len=24: 'concurrent.futures.'=19+'_base'=5); wait.__class__.__name__.__eq__('function')==True (regular Python function, not a generator); wait.__qualname__.__eq__('wait')==True (module-level function, qualname equals name); wait.__name__.__len__()==4 ('wait'=4, shortest identifier in spec); as_completed.__name__.__eq__('as_completed')==True; as_completed.__module__.__eq__('concurrent.futures._base')==True (same module as wait); as_completed.__class__.__name__.__eq__('function')==True; as_completed.__qualname__.__eq__('as_completed')==True; as_completed.__name__.__len__()==12 ('as_completed'=12); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfwait276

  columns: [id, function, args, expected, description]
  rows:
    - [wait_name_eq,   "concurrent.futures.wait.__name__.__eq__",                    ["wait"],                          true, "concurrent.futures.wait.__name__ == 'wait'; verified with Python 3.14.3"]
    - [wait_mod_eq,    "concurrent.futures.wait.__module__.__eq__",                  ["concurrent.futures._base"],      true, "concurrent.futures.wait.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [wait_cls_eq,    "concurrent.futures.wait.__class__.__name__.__eq__",          ["function"],                      true, "concurrent.futures.wait.__class__.__name__ == 'function' (regular Python function); verified with Python 3.14.3"]
    - [wait_qn_eq,     "concurrent.futures.wait.__qualname__.__eq__",                ["wait"],                          true, "concurrent.futures.wait.__qualname__ == 'wait' (module-level function); verified with Python 3.14.3"]
    - [wait_name_len,  "concurrent.futures.wait.__name__.__len__",                   [],                                4,    "concurrent.futures.wait.__name__.__len__() == 4 ('wait'=4, shortest in spec); verified with Python 3.14.3"]
    - [ac_name_eq,     "concurrent.futures.as_completed.__name__.__eq__",            ["as_completed"],                  true, "concurrent.futures.as_completed.__name__ == 'as_completed'; verified with Python 3.14.3"]
    - [ac_mod_eq,      "concurrent.futures.as_completed.__module__.__eq__",          ["concurrent.futures._base"],      true, "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base' (same as wait); verified with Python 3.14.3"]
    - [ac_cls_eq,      "concurrent.futures.as_completed.__class__.__name__.__eq__",  ["function"],                      true, "concurrent.futures.as_completed.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [ac_qn_eq,       "concurrent.futures.as_completed.__qualname__.__eq__",        ["as_completed"],                  true, "concurrent.futures.as_completed.__qualname__ == 'as_completed' (module-level function); verified with Python 3.14.3"]
    - [ac_name_len,    "concurrent.futures.as_completed.__name__.__len__",           [],                                12,   "concurrent.futures.as_completed.__name__.__len__() == 12 ('as_completed'=12); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.ProcessPoolExecutor class identity and method qualnames — extra276
#
# concurrent.futures.ProcessPoolExecutor.__name__               == 'ProcessPoolExecutor'
# concurrent.futures.ProcessPoolExecutor.__module__             == 'concurrent.futures.process'
# concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__  == 'Executor'
# concurrent.futures.ProcessPoolExecutor.__mro__.__len__()      == 3
# concurrent.futures.ProcessPoolExecutor.__qualname__           == 'ProcessPoolExecutor'
# ProcessPoolExecutor.submit.__qualname__                       == 'ProcessPoolExecutor.submit'   (len=26)
# ProcessPoolExecutor.shutdown.__qualname__                     == 'ProcessPoolExecutor.shutdown' (len=28, longest)
# ProcessPoolExecutor.map.__qualname__                          == 'ProcessPoolExecutor.map'      (len=23)
# ---------------------------------------------------------------------------

table concurrent_futures_extra276.cf_process_pool_executor_identity:
  description: "concurrent.futures.ProcessPoolExecutor class identity and method qualnames in cfppe276 namespace — ProcessPoolExecutor is defined in Lib/concurrent/futures/process.py; ProcessPoolExecutor.__name__.__eq__('ProcessPoolExecutor')==True; ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process')==True (len=26: 'concurrent.futures.'=19+'process'=7, same length as 'concurrent.futures.thread'=26); ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True (sole direct base, parallel to ThreadPoolExecutor.__bases__[0].__name__=='Executor'); ProcessPoolExecutor.__mro__.__len__()==3 ([ProcessPoolExecutor, Executor, object]); ProcessPoolExecutor.__qualname__.__eq__('ProcessPoolExecutor')==True; ProcessPoolExecutor.submit.__qualname__.__eq__('ProcessPoolExecutor.submit')==True (len=26: 'ProcessPoolExecutor.'=20+'submit'=6, own method); ProcessPoolExecutor.shutdown.__qualname__.__eq__('ProcessPoolExecutor.shutdown')==True (len=28: 'ProcessPoolExecutor.'=20+'shutdown'=8, longest method qualname in spec); ProcessPoolExecutor.map.__qualname__.__eq__('ProcessPoolExecutor.map')==True (len=23: 'ProcessPoolExecutor.'=20+'map'=3, own method overriding Executor.map unlike ThreadPoolExecutor); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfppe276

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_name_eq,      "concurrent.futures.ProcessPoolExecutor.__name__.__eq__",                   ["ProcessPoolExecutor"],            true, "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor'; verified with Python 3.14.3"]
    - [ppe_mod_eq,       "concurrent.futures.ProcessPoolExecutor.__module__.__eq__",                 ["concurrent.futures.process"],     true, "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (len=26); verified with Python 3.14.3"]
    - [ppe_base0_eq,     "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__",      ["Executor"],                       true, "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'; verified with Python 3.14.3"]
    - [ppe_mro_len,      "concurrent.futures.ProcessPoolExecutor.__mro__.__len__",                   [],                                 3,    "concurrent.futures.ProcessPoolExecutor.__mro__.__len__() == 3 — [ProcessPoolExecutor, Executor, object]; verified with Python 3.14.3"]
    - [ppe_qn_eq,        "concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__",               ["ProcessPoolExecutor"],            true, "concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor'; verified with Python 3.14.3"]
    - [ppe_submit_qn,    "concurrent.futures.ProcessPoolExecutor.submit.__qualname__.__eq__",        ["ProcessPoolExecutor.submit"],     true, "ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit' (len=26, own method); verified with Python 3.14.3"]
    - [ppe_submit_len,   "concurrent.futures.ProcessPoolExecutor.submit.__qualname__.__len__",       [],                                 26,   "ProcessPoolExecutor.submit.__qualname__.__len__() == 26 ('ProcessPoolExecutor.'=20+'submit'=6); verified with Python 3.14.3"]
    - [ppe_shutdown_qn,  "concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__.__eq__",      ["ProcessPoolExecutor.shutdown"],   true, "ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' (len=28, longest in spec); verified with Python 3.14.3"]
    - [ppe_shutdown_len, "concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__.__len__",     [],                                 28,   "ProcessPoolExecutor.shutdown.__qualname__.__len__() == 28 ('ProcessPoolExecutor.'=20+'shutdown'=8); verified with Python 3.14.3"]
    - [ppe_map_qn,       "concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__",           ["ProcessPoolExecutor.map"],        true, "ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (len=23, own method overriding Executor.map); verified with Python 3.14.3"]
    - [ppe_map_len,      "concurrent.futures.ProcessPoolExecutor.map.__qualname__.__len__",          [],                                 23,   "ProcessPoolExecutor.map.__qualname__.__len__() == 23 ('ProcessPoolExecutor.'=20+'map'=3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra276
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra276.wait_module_is_concurrent_futures_base:
  description: "concurrent.futures.wait.__module__.__eq__('concurrent.futures._base') returns True — wait() is defined in Lib/concurrent/futures/_base.py alongside Future, Executor, as_completed, and FIRST_COMPLETED/ALL_COMPLETED; its __module__ is 'concurrent.futures._base' (len=24: 'concurrent.futures.'=19+'_base'=5); wait() accepts a set of futures and returns two sets: done and not_done; it is a module-level function (wait.__qualname__ == 'wait'); compare submodule __module__ values: Future.__module__='concurrent.futures._base', Executor.__module__='concurrent.futures._base', ThreadPoolExecutor.__module__='concurrent.futures.thread', ProcessPoolExecutor.__module__='concurrent.futures.process'; NEW in extra276: first standalone wait.__module__ invariant in cfwait276 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.wait.__module__.__eq__"
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra276.as_completed_module_is_concurrent_futures_base:
  description: "concurrent.futures.as_completed.__module__.__eq__('concurrent.futures._base') returns True — as_completed() is defined in Lib/concurrent/futures/_base.py alongside wait(), Future, and Executor; its __module__ is 'concurrent.futures._base' (len=24, same as wait.__module__); as_completed() is a generator function that yields futures as they complete; as_completed.__qualname__ == 'as_completed' (module-level, not nested); as_completed.__class__.__name__ == 'function'; as_completed.__name__.__len__() == 12 ('as_completed'=12); wait.__name__.__len__() == 4 ('wait'=4); as_completed and wait both live in '_base' not in 'thread' or 'process'; NEW in extra276: first standalone as_completed.__module__ invariant in cfwait276 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.as_completed.__module__.__eq__"
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra276.ProcessPoolExecutor_module_is_process:
  description: "concurrent.futures.ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process') returns True — ProcessPoolExecutor is defined in Lib/concurrent/futures/process.py; its __module__ is 'concurrent.futures.process' (len=26: 'concurrent.futures.'=19+'process'=7); this is the same length as ThreadPoolExecutor.__module__ 'concurrent.futures.thread' (len=26) but different submodule name; ProcessPoolExecutor.__mro__.__len__() is 3 ([ProcessPoolExecutor, Executor, object]); Executor.__module__ is 'concurrent.futures._base'; ProcessPoolExecutor.__bases__[0].__name__ is 'Executor'; NEW in extra276: first standalone ProcessPoolExecutor.__module__ invariant in cfppe276 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__module__.__eq__"
  args: ["concurrent.futures.process"]
  expected: true

invariant concurrent_futures_extra276.ProcessPoolExecutor_map_qualname_is_own:
  description: "concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__('ProcessPoolExecutor.map') returns True — ProcessPoolExecutor.map is an own method (overriding Executor.map), so its qualname is 'ProcessPoolExecutor.map' (len=23: 'ProcessPoolExecutor.'=20+'map'=3); this distinguishes ProcessPoolExecutor from ThreadPoolExecutor: ThreadPoolExecutor.map.__qualname__ is 'Executor.map' (ThreadPoolExecutor does NOT override map, inheriting it from Executor), while ProcessPoolExecutor.map.__qualname__ is 'ProcessPoolExecutor.map' (ProcessPoolExecutor DOES override map); the override in process.py adds cancel_futures support; ProcessPoolExecutor.map.__qualname__.__len__() is 23; compare: submit=26, shutdown=28, map=23 (shortest own method qualname in spec); NEW in extra276: first standalone ProcessPoolExecutor.map qualname invariant in cfppe276 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__"
  args: ["ProcessPoolExecutor.map"]
  expected: true

invariant concurrent_futures_extra276.ProcessPoolExecutor_shutdown_qualname_len_28:
  description: "concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__.__len__() == 28 — ProcessPoolExecutor.shutdown.__qualname__ is 'ProcessPoolExecutor.shutdown' (28 chars: 'ProcessPoolExecutor.'=20+'shutdown'=8); this is the longest method qualname in this spec; compare qualname lengths: ProcessPoolExecutor.map=23, ProcessPoolExecutor.submit=26, ProcessPoolExecutor.shutdown=28 (longest); the 'ProcessPoolExecutor.' prefix (20 chars) is shared by all three own methods; ProcessPoolExecutor.shutdown() overrides Executor.shutdown() to gracefully terminate worker processes; NEW in extra276: first standalone ProcessPoolExecutor.shutdown qualname length invariant in cfppe276 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__.__len__"
  args: []
  expected: 28
