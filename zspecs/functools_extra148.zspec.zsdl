# ---------------------------------------------------------------------------
# Table 4: functools.total_ordering — Python function identity, qualname, doc
#
# Wave 271 theme: functools.total_ordering — class decorator that fills in
# missing comparison methods from a minimal set.
#
# functools.total_ordering.__class__.__name__ == 'function'
# functools.total_ordering.__qualname__ == 'total_ordering' (len 14)
# functools.total_ordering.__module__ == 'functools' (len 9)
# len(functools.total_ordering.__doc__) == 54
# functools.total_ordering.__code__.co_argcount == 1
#
# total_ordering(cls) fills __le__, __gt__, __ge__ from __lt__ and __eq__.
# Defined in Lib/functools.py. New to extra148.
# ---------------------------------------------------------------------------

