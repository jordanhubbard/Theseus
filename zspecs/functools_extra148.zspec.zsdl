# ---------------------------------------------------------------------------
# Table 3: functools.lru_cache and functools.cache — Python function attrs
#
# Wave 271 theme: memoisation decorators in functools.
#
# functools.lru_cache.__class__.__name__ == 'function'
# functools.lru_cache.__qualname__ == 'lru_cache' (len 9)
# functools.lru_cache.__module__ == 'functools' (len 9)
# len(functools.lru_cache.__doc__) == 743
# functools.cache.__class__.__name__ == 'function'
# functools.cache.__qualname__ == 'cache' (len 5)
# functools.cache.__module__ == 'functools' (len 9)
# len(functools.cache.__doc__) == 64
# functools.cache.__code__.co_argcount == 1
# len(functools.cache.__code__.co_varnames) == 1
#
# lru_cache is the bounded memoisation decorator (max size); cache is
# unbounded shorthand. Both defined in Lib/functools.py. New to extra148.
# ---------------------------------------------------------------------------

