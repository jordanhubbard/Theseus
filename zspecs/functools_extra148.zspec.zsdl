spec: functools_extra148
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.partial (C type), functools.partialmethod (Python class), functools.lru_cache (Python function), functools.cache (Python function), functools.total_ordering (Python function) — doc string len, __qualname__, __module__, __name__, MRO len, co_argcount (Wave 271)."
    - "functools.partial is a C type: __class__.__name__ == 'type'; __name__ == 'partial'; __qualname__ == 'partial' (len 7); __module__ == 'functools' (len 9); __doc__ len == 83; MRO len == 2. Verified with Python 3.14.3."
    - "functools.partialmethod is a Python class: __class__.__name__ == 'type'; __name__ == 'partialmethod'; __qualname__ == 'partialmethod' (len 13); __module__ == 'functools'; __doc__ len == 178; MRO len == 2. Verified with Python 3.14.3."
    - "functools.lru_cache is a Python function: __class__.__name__ == 'function'; __qualname__ == 'lru_cache' (len 9); __module__ == 'functools'; __doc__ len == 743. Verified with Python 3.14.3."
    - "functools.cache is a Python function: __class__.__name__ == 'function'; __qualname__ == 'cache' (len 5); __module__ == 'functools'; __doc__ len == 64; co_argcount == 1; co_varnames len == 1. Verified with Python 3.14.3."
    - "functools.total_ordering is a Python function: __class__.__name__ == 'function'; __qualname__ == 'total_ordering' (len 14); __module__ == 'functools'; __doc__ len == 54; co_argcount == 1. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial — C type identity, qualname, module, doc, MRO
#
# Wave 271 theme: functools.partial — the C extension type for partial functions.
#
# functools.partial.__class__.__name__ == 'type'
# functools.partial.__name__ == 'partial' (len 7)
# functools.partial.__qualname__ == 'partial' (len 7)
# functools.partial.__module__ == 'functools' (len 9)
# len(functools.partial.__doc__) == 83
# len(functools.partial.__mro__) == 2
#
# partial(func, *args, **kwargs) — new function with partial application.
# Implemented in _functoolsmodule.c. New to extra148.
# ---------------------------------------------------------------------------

table functools_extra148.partial_type_attrs:
  description: "functools.partial: C type, __name__ 'partial' len 7, __qualname__ len 7, __module__ 'functools', __doc__ len 83, MRO len 2; wave 271; new to extra148"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartial148

  columns: [id, function, args, expected, description]
  rows:
    - [partial_class_eq_type,
       "partial.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is a C extension type; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra148"]
    - [partial_name_eq,
       "partial.__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — the C type's __name__ is 'partial'; str.__eq__('partial') returns True; new to extra148"]
    - [partial_name_len_eq_7,
       "partial.__name__.__len__",
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — __name__ is 'partial' which has 7 characters; len('partial') == 7; new to extra148"]
    - [partial_qualname_eq,
       "partial.__qualname__.__eq__",
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — the C type's __qualname__ is 'partial'; str.__eq__('partial') returns True; new to extra148"]
    - [partial_module_eq_functools,
       "partial.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial is in the functools module; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra148"]
    - [partial_doc_len_eq_83,
       "partial.__doc__.__len__",
       [],
       83,
       "functools.partial.__doc__.__len__() == 83 — the partial type docstring has 83 characters; len(__doc__) == 83; verified with Python 3.14.3; new to extra148"]
    - [partial_mro_len_eq_2,
       "partial.__mro__.__len__",
       [],
       2,
       "functools.partial.__mro__.__len__() == 2 — partial's MRO is [partial, object]; len(__mro__) is 2; new to extra148"]

