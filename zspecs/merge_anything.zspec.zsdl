spec: merge_anything
version: ">=6.0.6"
backend: node(merge-anything)

docs: https://www.npmjs.com/package/merge-anything

provenance:
  derived_from:
    - "merge-anything README — https://www.npmjs.com/package/merge-anything"
    - "Test vectors verified with merge-anything via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "merge-anything source"
  notes:
    - "merge-anything is an npm package. Install: npm install merge-anything"
    - "Deep merges two or more objects, with later sources overriding earlier ones."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a merged object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table merge_anything.merge:
  kind: node_module_call_eq
  function: merge
  category: object
  id_prefix: merga

  columns: [id, args, expected]
  rows:
    - [disjoint,  [{"a": 1}, {"b": 2}],             {"a": 1, "b": 2}]
    - [override,  [{"a": 1}, {"a": 2, "c": 3}],     {"a": 2, "c": 3}]
    - [empty,     [{}, {"a": 1, "b": 2}],            {"a": 1, "b": 2}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:12:31Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
