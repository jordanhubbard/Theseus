invariant itertools_extra74.chain_from_iterable_class_builtin:
  description: "itertools.chain.from_iterable.__class__.__name__.__eq__('builtin_function_or_method') == True — chain.from_iterable is a builtin_function_or_method; wave 240 chain.from_iterable identity; new to extra74"
  kind: python_call_eq
  function: chain.from_iterable.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra74.chain_from_iterable_qualname:
  description: "itertools.chain.from_iterable.__qualname__.__eq__('chain.from_iterable') == True — chain.from_iterable.__qualname__ is 'chain.from_iterable'; wave 240 chain.from_iterable identity; new to extra74"
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__eq__
  args: ["chain.from_iterable"]
  expected: true

