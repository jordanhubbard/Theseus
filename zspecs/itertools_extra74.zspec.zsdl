spec: itertools_extra74
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra73.zspec.zsdl."
    - "Wave 240 theme: itertools chain.from_iterable class method identity and C type base classes."
    - "itertools has no __file__ attribute — itertools is a built-in C extension (not loaded from a .so file on this platform); accessing itertools.__file__ raises AttributeError. Verified with Python 3.14.3."
    - "chain.from_iterable.__class__.__name__ == 'builtin_function_or_method' — from_iterable is a classmethod on the C type chain; its __class__.__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "chain.from_iterable.__qualname__ == 'chain.from_iterable' — the qualname of the classmethod includes the class name as prefix. Verified with Python 3.14.3."
    - "product.__bases__[0].__name__ == 'object' — product is a C extension type that inherits directly from object. Verified with Python 3.14.3."
    - "combinations.__bases__[0].__name__ == 'object' — combinations is a C extension type that inherits directly from object. Verified with Python 3.14.3."
    - "permutations.__bases__[0].__name__ == 'object' — permutations is a C extension type that inherits directly from object. Verified with Python 3.14.3."
    - "accumulate.__bases__[0].__name__ == 'object' — accumulate is a C extension type that inherits directly from object. Verified with Python 3.14.3."
    - "cycle.__bases__[0].__name__ == 'object' — cycle is a C extension type that inherits directly from object. Verified with Python 3.14.3."
    - "groupby.__bases__[0].__name__ == 'object' — groupby is a C extension type that inherits directly from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# chain.from_iterable class method identity — extra74
#
# Wave 240 theme: chain.from_iterable is a classmethod on a C type.
#
# itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method'
# itertools.chain.from_iterable.__qualname__       == 'chain.from_iterable'
#
# No prior itertools spec checks chain.from_iterable identity via itertmore74. New to extra74.
# ---------------------------------------------------------------------------

table itertools_extra74.chain_from_iterable_identity:
  description: "chain.from_iterable.__class__.__name__=='builtin_function_or_method', __qualname__=='chain.from_iterable'; wave 240 chain.from_iterable identity; new to extra74"
  kind: python_call_eq
  category: function_identity
  id_prefix: itertmore74

  columns: [id, function, args, expected, description]
  rows:
    - [chain_from_iterable_class_name_eq_builtin,
       chain.from_iterable.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "itertools.chain.from_iterable.__class__.__name__.__eq__('builtin_function_or_method') == True — chain.from_iterable is a classmethod descriptor on the C extension type chain; when accessed from the class it produces a 'builtin_function_or_method' object; __class__.__name__ is 'builtin_function_or_method' (26 chars); str.__eq__('builtin_function_or_method') returns True; no prior itertools spec checks chain.from_iterable.__class__.__name__ via itertmore74; new to extra74"]
    - [chain_from_iterable_qualname_eq,
       chain.from_iterable.__qualname__.__eq__,
       ["chain.from_iterable"],
       true,
       "itertools.chain.from_iterable.__qualname__.__eq__('chain.from_iterable') == True — chain.from_iterable is a classmethod defined on the C type chain; its __qualname__ includes the class name as a dotted prefix giving 'chain.from_iterable' (19 chars); str.__eq__('chain.from_iterable') returns True; no prior itertools spec checks chain.from_iterable.__qualname__ via itertmore74; new to extra74"]

# ---------------------------------------------------------------------------
# product and combinations base class — extra74
#
# Wave 240 theme: product and combinations are C types inheriting from object.
#
# itertools.product.__bases__[0].__name__      == 'object'
# itertools.combinations.__bases__[0].__name__ == 'object'
#
# No prior itertools spec checks product/combinations __bases__ via itertmore74. New to extra74.
# ---------------------------------------------------------------------------

table itertools_extra74.product_combinations_bases:
  description: "product.__bases__[0].__name__=='object', combinations.__bases__[0].__name__=='object'; wave 240 C type base classes; new to extra74"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertmore74

  columns: [id, function, args, expected, description]
  rows:
    - [product_bases0_name_eq_object,
       "product.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.product.__bases__[0].__name__.__eq__('object') == True — product is a C extension type defined in Modules/itertoolsmodule.c that computes Cartesian products; it inherits directly from object with no intermediate base classes; __bases__[0] is object and object.__name__ == 'object' (6 chars); str.__eq__('object') returns True; no prior itertools spec checks product.__bases__[0].__name__ via itertmore74; new to extra74"]
    - [combinations_bases0_name_eq_object,
       "combinations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations.__bases__[0].__name__.__eq__('object') == True — combinations is a C extension type defined in Modules/itertoolsmodule.c that returns successive r-length combinations; it inherits directly from object; __bases__[0] is object and object.__name__ == 'object' (6 chars); str.__eq__('object') returns True; no prior itertools spec checks combinations.__bases__[0].__name__ via itertmore74; new to extra74"]

