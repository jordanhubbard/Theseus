  id_prefix: itertmore74

  columns: [id, function, args, expected, description]
  rows:
    - [permutations_bases0_name_eq_object,
       "permutations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.permutations.__bases__[0].__name__.__eq__('object') == True — permutations is a C extension type defined in Modules/itertoolsmodule.c that returns successive r-length permutations; it inherits directly from object; __bases__[0] is object and object.__name__ == 'object' (6 chars); str.__eq__('object') returns True; no prior itertools spec checks permutations.__bases__[0].__name__ via itertmore74; new to extra74"]
    - [accumulate_bases0_name_eq_object,
       "accumulate.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.accumulate.__bases__[0].__name__.__eq__('object') == True — accumulate is a C extension type defined in Modules/itertoolsmodule.c that returns accumulated sums (or other binary function results); it inherits directly from object; __bases__[0] is object and object.__name__ == 'object' (6 chars); str.__eq__('object') returns True; no prior itertools spec checks accumulate.__bases__[0].__name__ via itertmore74; new to extra74"]

