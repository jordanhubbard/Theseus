spec: functools_extra2251
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "Wave extra2251: callable protocol and function-attribute dict-presence checks — __call__, __code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__ in functools class __dict__."
    - "functools.partial defines __call__ in its class __dict__ (True) — it is a C extension type whose instances are callable; __call__ is the slot-wrapper for calling partial objects."
    - "functools._lru_cache_wrapper defines __call__ in its class __dict__ (True) — it is the C type backing lru_cache-decorated functions; calling it invokes the cached function."
    - "functools.GenericAlias defines __call__ in its class __dict__ (True) — types.GenericAlias is exposed via functools; __call__ enables instantiation of parameterized generic aliases."
    - "functools.MethodType defines __call__ in its class __dict__ (True) — bound method objects are callable; __call__ is the core protocol slot."
    - "functools._singledispatchmethod_get defines __call__ in its class __dict__ (True) — this descriptor helper is callable."
    - "functools.itemgetter defines __call__ in its class __dict__ (True) — operator.itemgetter is re-exposed via functools internals; instances are callable."
    - "functools.partialmethod, cached_property, singledispatchmethod, _CacheInfo do NOT define __call__ in their class __dict__."
    - "__code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__ are function-object attributes; none of these functools type objects define them in their own __dict__."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table functools_extra2251.call_protocol_true:
  description: "functools types that define __call__ in their __dict__: partial, _lru_cache_wrapper, GenericAlias, MethodType, _singledispatchmethod_get, itemgetter"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2251

  columns: [id, function, args, expected]
  rows:
    - ["ft2251001", "functools.partial.__dict__.__contains__", ["__call__"], true]
    - ["ft2251002", "functools._lru_cache_wrapper.__dict__.__contains__", ["__call__"], true]
    - ["ft2251003", "functools.GenericAlias.__dict__.__contains__", ["__call__"], true]
    - ["ft2251004", "functools.MethodType.__dict__.__contains__", ["__call__"], true]
    - ["ft2251005", "functools._singledispatchmethod_get.__dict__.__contains__", ["__call__"], true]
    - ["ft2251006", "functools.itemgetter.__dict__.__contains__", ["__call__"], true]

table functools_extra2251.call_protocol_false:
  description: "functools types that do NOT define __call__ in their __dict__: partialmethod, cached_property, singledispatchmethod, _CacheInfo, _PlaceholderType"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2251

  columns: [id, function, args, expected]
  rows:
    - ["ft2251007", "functools.partialmethod.__dict__.__contains__", ["__call__"], false]
    - ["ft2251008", "functools.cached_property.__dict__.__contains__", ["__call__"], false]
    - ["ft2251009", "functools.singledispatchmethod.__dict__.__contains__", ["__call__"], false]
    - ["ft2251010", "functools._CacheInfo.__dict__.__contains__", ["__call__"], false]
    - ["ft2251011", "functools._PlaceholderType.__dict__.__contains__", ["__call__"], false]

table functools_extra2251.code_globals_absent:
  description: "functools types do NOT define __code__ or __globals__ in their __dict__ — these are function-object attributes, not type attributes"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2251

  columns: [id, function, args, expected]
  rows:
    - ["ft2251012", "functools.partial.__dict__.__contains__", ["__code__"], false]
    - ["ft2251013", "functools.partial.__dict__.__contains__", ["__globals__"], false]
    - ["ft2251014", "functools._lru_cache_wrapper.__dict__.__contains__", ["__code__"], false]
    - ["ft2251015", "functools._lru_cache_wrapper.__dict__.__contains__", ["__globals__"], false]
    - ["ft2251016", "functools.partialmethod.__dict__.__contains__", ["__code__"], false]
    - ["ft2251017", "functools.partialmethod.__dict__.__contains__", ["__globals__"], false]
    - ["ft2251018", "functools.cached_property.__dict__.__contains__", ["__code__"], false]
    - ["ft2251019", "functools.cached_property.__dict__.__contains__", ["__globals__"], false]

