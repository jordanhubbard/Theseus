    - ["ft2251023", "functools._lru_cache_wrapper.__dict__.__contains__", ["__kwdefaults__"], false]
    - ["ft2251024", "functools.singledispatchmethod.__dict__.__contains__", ["__defaults__"], false]
    - ["ft2251025", "functools.singledispatchmethod.__dict__.__contains__", ["__kwdefaults__"], false]

