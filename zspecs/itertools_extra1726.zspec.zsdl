spec: itertools_extra1726
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 562 (_extra1726): comparison/ordering protocol dict-presence checks."
    - "All itertools types are C extension types and define no comparison operators in their own __dict__."
    - "itertools.chain.__dict__.__contains__('__lt__') is False — chain is a C extension type with no ordering protocol."
    - "itertools.islice.__dict__.__contains__('__lt__') is False — islice is a C extension type with no ordering protocol."
    - "itertools.count.__dict__.__contains__('__lt__') is False — count is a C extension type with no ordering protocol."
    - "itertools.cycle.__dict__.__contains__('__lt__') is False — cycle is a C extension type with no ordering protocol."
    - "itertools.repeat.__dict__.__contains__('__lt__') is False — repeat is a C extension type with no ordering protocol."
    - "None of the itertools types define __le__, __gt__, __ge__, or __ne__ in their own __dict__."
    - "None of the itertools types define __eq__ or __hash__ in their own __dict__ either."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table itertools_extra1726.comparison_protocol_chain_islice:
  description: "itertools.chain and itertools.islice comparison protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1726

  columns: [id, function, args, expected]
  rows:
    - ["it1726001", "itertools.chain.__dict__.__contains__", ["__lt__"], false]
    - ["it1726002", "itertools.chain.__dict__.__contains__", ["__le__"], false]
    - ["it1726003", "itertools.chain.__dict__.__contains__", ["__gt__"], false]
    - ["it1726004", "itertools.chain.__dict__.__contains__", ["__ge__"], false]
    - ["it1726005", "itertools.chain.__dict__.__contains__", ["__ne__"], false]
    - ["it1726006", "itertools.islice.__dict__.__contains__", ["__lt__"], false]
    - ["it1726007", "itertools.islice.__dict__.__contains__", ["__le__"], false]
    - ["it1726008", "itertools.islice.__dict__.__contains__", ["__gt__"], false]
    - ["it1726009", "itertools.islice.__dict__.__contains__", ["__ge__"], false]
    - ["it1726010", "itertools.islice.__dict__.__contains__", ["__ne__"], false]

