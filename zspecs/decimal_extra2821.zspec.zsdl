spec: decimal_extra2821
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "Wave 635 theme: __radd__, __rsub__, and __rmul__ dict-presence checks (reflected arithmetic operators)."
    - "decimal.Decimal is a full numeric type and DOES define __radd__, __rsub__, and __rmul__ in its own __dict__."
    - "Reflected operators are needed so that expressions like '1 + Decimal(2)' work when int.__add__ returns NotImplemented."
    - "decimal.Context is a configuration object, not a numeric value — it does NOT define any reflected arithmetic operators."
    - "decimal.DecimalException is an exception class — it does NOT define any reflected arithmetic operators."
    - "The asymmetry (Decimal: true, Context/DecimalException: false) is the key behavioral signal for this wave."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __radd__ dict-presence
# Decimal defines it; Context and DecimalException do not
# ---------------------------------------------------------------------------

table decimal_extra2821.radd_protocol:
  description: "__radd__ is present in decimal.Decimal.__dict__ (full numeric type) but absent from Context and DecimalException"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2821

  columns: [id, function, args, expected]
  rows:
    - ["dc2821001", "decimal.Decimal.__dict__.__contains__",          ["__radd__"], true]
    - ["dc2821002", "decimal.Context.__dict__.__contains__",          ["__radd__"], false]
    - ["dc2821003", "decimal.DecimalException.__dict__.__contains__", ["__radd__"], false]

