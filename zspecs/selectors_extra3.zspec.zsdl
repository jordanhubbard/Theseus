spec: selectors_extra3
version: ">=3.9"
backend: python_module(selectors)

docs: https://docs.python.org/3/library/selectors.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/selectors.html — Python selectors module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/selectors.py"
  notes:
    - "Extends selectors.zspec.zsdl, selectors_extra.zspec.zsdl, and selectors_extra2.zspec.zsdl."
    - "selectors.zspec.zsdl covers: EVENT_READ=1/EVENT_WRITE=2 values and types; BaseSelector/SelectSelector/KqueueSelector/DefaultSelector class names and modules; SelectorKey class name, base class, and _fields membership."
    - "selectors_extra.zspec.zsdl covers: BaseSelector/SelectSelector/DefaultSelector/SelectorKey class names; EVENT_READ/EVENT_WRITE types and values."
    - "selectors_extra2.zspec.zsdl covers: SelectorKey module, field count, fields by index, and base class; SelectSelector module; BaseSelector name and module; DefaultSelector name; EVENT_READ and EVENT_WRITE values."
    - "This spec adds: PollSelector class name and module (available on macOS); SelectSelector and KqueueSelector base class names (_BaseSelectorImpl); DefaultSelector.__module__ (not yet covered); EVENT_READ | EVENT_WRITE == 3 (union mask); EVENT_READ & EVENT_WRITE == 0 (no overlap); selectors module __name__."
    - "PollSelector is available on macOS and Linux (built on poll()); its __bases__[0].__name__ is '_PollLikeSelector'."
    - "SelectSelector.__bases__[0].__name__ == '_BaseSelectorImpl' — the internal mixin base class."
    - "KqueueSelector.__bases__[0].__name__ == '_BaseSelectorImpl' — same internal base as SelectSelector."
    - "EVENT_READ | EVENT_WRITE == 3 — combined read+write interest mask (1 | 2 == 3)."
    - "EVENT_READ & EVENT_WRITE == 0 — the two masks share no bits."
    - "DefaultSelector.__module__ == 'selectors' — confirmed via module attribute, not yet a standalone invariant."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PollSelector — class name and module (available on macOS and Linux)
# Not covered by any prior spec. PollSelector uses poll() and is exported from
# the selectors module; its __name__ and __module__ should be stable.
# ---------------------------------------------------------------------------

invariant selectors_extra3.PollSelector.class_name:
  description: "selectors.PollSelector.__name__ == 'PollSelector'"
  category: classnames
  kind: python_call_eq
  function: PollSelector.__name__.__eq__
  args: ["PollSelector"]
  expected: true

invariant selectors_extra3.PollSelector.module:
  description: "selectors.PollSelector.__module__ == 'selectors'"
  category: classnames
  kind: python_call_eq
  function: PollSelector.__module__.__eq__
  args: ["selectors"]
  expected: true

# ---------------------------------------------------------------------------
# SelectSelector and KqueueSelector — base class (_BaseSelectorImpl)
# No prior spec checks the __bases__ of SelectSelector or KqueueSelector.
# Both inherit from the internal _BaseSelectorImpl mixin.
# ---------------------------------------------------------------------------

invariant selectors_extra3.SelectSelector.base_class:
  description: "selectors.SelectSelector.__bases__[0].__name__ == '_BaseSelectorImpl'"
  category: hierarchy
  kind: python_call_eq
  function: SelectSelector.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_BaseSelectorImpl"

invariant selectors_extra3.KqueueSelector.base_class:
  description: "selectors.KqueueSelector.__bases__[0].__name__ == '_BaseSelectorImpl'"
  category: hierarchy
  kind: python_call_eq
  function: KqueueSelector.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_BaseSelectorImpl"

# ---------------------------------------------------------------------------
# DefaultSelector.__module__ — not covered as a standalone invariant
# selectors_extra2.DefaultSelector.name covers __name__ only.
# ---------------------------------------------------------------------------

invariant selectors_extra3.DefaultSelector.module:
  description: "selectors.DefaultSelector.__module__ == 'selectors'"
  category: classnames
  kind: python_call_eq
  function: DefaultSelector.__module__.__eq__
  args: ["selectors"]
  expected: true

# ---------------------------------------------------------------------------
# KqueueSelector.__module__ — not yet a standalone invariant
# selectors.zspec.zsdl covers KqueueSelector.__module__ in a table but not as
# an individual invariant; selectors_extra2 skips it entirely.
# ---------------------------------------------------------------------------

invariant selectors_extra3.KqueueSelector.module:
  description: "selectors.KqueueSelector.__module__ == 'selectors'"
  category: classnames
  kind: python_call_eq
  function: KqueueSelector.__module__.__eq__
  args: ["selectors"]
  expected: true

# ---------------------------------------------------------------------------
# EVENT_READ | EVENT_WRITE — combined interest mask
# EVENT_READ == 1, EVENT_WRITE == 2; their bitwise OR is 3.
# No prior spec tests this combined expression.
# ---------------------------------------------------------------------------

invariant selectors_extra3.event_mask.read_or_write:
  description: "selectors.EVENT_READ | selectors.EVENT_WRITE == 3 — combined read+write interest mask"
  category: constants
  kind: python_call_eq
  function: EVENT_READ.__or__
  args: [2]
  method: __eq__
  method_args: [3]
  expected: true

# ---------------------------------------------------------------------------
# EVENT_READ & EVENT_WRITE — no shared bits
# The two masks are disjoint: 1 & 2 == 0.
# No prior spec tests this.
# ---------------------------------------------------------------------------

invariant selectors_extra3.event_mask.read_and_write_zero:
  description: "selectors.EVENT_READ & selectors.EVENT_WRITE == 0 — masks share no bits"
  category: constants
  kind: python_call_eq
  function: EVENT_READ.__and__
  args: [2]
  method: __eq__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# selectors module __name__ attribute
# Confirms the module reports its own name correctly.
# No prior spec checks this directly.
# ---------------------------------------------------------------------------

invariant selectors_extra3.module.name:
  description: "selectors.__name__ == 'selectors' — the module's own __name__ attribute"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["selectors"]
  expected: true
