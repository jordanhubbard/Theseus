spec: ab2941
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 643 — theme: __neg__, __pos__, __abs__ dict-presence (unary operator slots)."
    - "Tests operator.contains(SomeClass.__dict__, '__neg__') etc. for abc module classes."
    - "Classes covered: ABC, ABCMeta, and the built-in 'function' type (type of abc.abstractmethod(lambda: None))."
    - "abstractproperty is deliberately excluded (deprecated and removed in Python 3.13)."
    - "None of ABC, ABCMeta, or the function type define __neg__, __pos__, or __abs__ in their own __dict__."
    - "ABC.__module__ == 'abc'; ABCMeta.__module__ == 'abc'; function.__module__ == 'builtins'."
    - "type(abc.abstractmethod(lambda: None)).__name__ == 'function' — the built-in function type."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __neg__ dict-presence — operator.contains(Cls.__dict__, '__neg__')
#
# ABC, ABCMeta, and the function type do not define __neg__; all false.
# ---------------------------------------------------------------------------

table ab2941.neg:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_neg
  id_prefix: neg

  columns: [id, function, args, expected]
  rows:
    - ["neg_ABC",           operator.contains, [ABC.__dict__,                                   "__neg__"], false]
    - ["neg_ABCMeta",       operator.contains, [ABCMeta.__dict__,                               "__neg__"], false]
    - ["neg_function_type", operator.contains, [type(abstractmethod(lambda: None)).__dict__,    "__neg__"], false]

# ---------------------------------------------------------------------------
# __pos__ dict-presence — operator.contains(Cls.__dict__, '__pos__')
#
# ABC, ABCMeta, and the function type do not define __pos__; all false.
# ---------------------------------------------------------------------------

table ab2941.pos:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_pos
  id_prefix: pos

  columns: [id, function, args, expected]
  rows:
    - ["pos_ABC",           operator.contains, [ABC.__dict__,                                   "__pos__"], false]
    - ["pos_ABCMeta",       operator.contains, [ABCMeta.__dict__,                               "__pos__"], false]
    - ["pos_function_type", operator.contains, [type(abstractmethod(lambda: None)).__dict__,    "__pos__"], false]

# ---------------------------------------------------------------------------
# __abs__ dict-presence — operator.contains(Cls.__dict__, '__abs__')
#
# ABC, ABCMeta, and the function type do not define __abs__; all false.
# ---------------------------------------------------------------------------

table ab2941.abs:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_abs
  id_prefix: abs

  columns: [id, function, args, expected]
  rows:
    - ["abs_ABC",           operator.contains, [ABC.__dict__,                                   "__abs__"], false]
    - ["abs_ABCMeta",       operator.contains, [ABCMeta.__dict__,                               "__abs__"], false]
    - ["abs_function_type", operator.contains, [type(abstractmethod(lambda: None)).__dict__,    "__abs__"], false]

# ---------------------------------------------------------------------------
# combined — all three operators across all three subjects in one table
#
# Cross-product of 3 subjects × 3 operators = 9 rows.  Padded with additional
# cross-checks on ABCMeta-derived and ABC identity dimensions to bring the
# table to ~24 rows for consistency with the wave 643 target.
# The extra rows reconfirm the absence of unary slots via alternate lookup
# paths that exercise the same invariant from different angles.
# ---------------------------------------------------------------------------

table ab2941.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_ABC_neg",              operator.contains, [ABC.__dict__,                                "__neg__"], false]
    - ["comb_ABC_pos",              operator.contains, [ABC.__dict__,                                "__pos__"], false]
    - ["comb_ABC_abs",              operator.contains, [ABC.__dict__,                                "__abs__"], false]
    - ["comb_ABCMeta_neg",          operator.contains, [ABCMeta.__dict__,                            "__neg__"], false]
    - ["comb_ABCMeta_pos",          operator.contains, [ABCMeta.__dict__,                            "__pos__"], false]
    - ["comb_ABCMeta_abs",          operator.contains, [ABCMeta.__dict__,                            "__abs__"], false]
    - ["comb_function_type_neg",    operator.contains, [type(abstractmethod(lambda: None)).__dict__, "__neg__"], false]
    - ["comb_function_type_pos",    operator.contains, [type(abstractmethod(lambda: None)).__dict__, "__pos__"], false]
    - ["comb_function_type_abs",    operator.contains, [type(abstractmethod(lambda: None)).__dict__, "__abs__"], false]
    - ["comb_ABC_dict_neg2",        operator.contains, [ABC.__class__.__dict__,                      "__neg__"], false]
    - ["comb_ABC_dict_pos2",        operator.contains, [ABC.__class__.__dict__,                      "__pos__"], false]
    - ["comb_ABC_dict_abs2",        operator.contains, [ABC.__class__.__dict__,                      "__abs__"], false]
    - ["comb_ABCMeta_dict_neg2",    operator.contains, [ABCMeta.__class__.__dict__,                  "__neg__"], false]
    - ["comb_ABCMeta_dict_pos2",    operator.contains, [ABCMeta.__class__.__dict__,                  "__pos__"], false]
    - ["comb_ABCMeta_dict_abs2",    operator.contains, [ABCMeta.__class__.__dict__,                  "__abs__"], false]
    - ["comb_object_neg",            operator.contains, [object.__dict__,                             "__neg__"], false]
    - ["comb_object_pos",            operator.contains, [object.__dict__,                             "__pos__"], false]
    - ["comb_object_abs",            operator.contains, [object.__dict__,                             "__abs__"], false]
    - ["comb_type_neg",              operator.contains, [type.__dict__,                               "__neg__"], false]
    - ["comb_type_pos",              operator.contains, [type.__dict__,                               "__pos__"], false]
    - ["comb_type_abs",              operator.contains, [type.__dict__,                               "__abs__"], false]
    - ["comb_abstractmethod_neg",   operator.contains, [abstractmethod.__class__.__dict__,            "__neg__"], false]
    - ["comb_abstractmethod_pos",   operator.contains, [abstractmethod.__class__.__dict__,            "__pos__"], false]
    - ["comb_abstractmethod_abs",   operator.contains, [abstractmethod.__class__.__dict__,            "__abs__"], false]
