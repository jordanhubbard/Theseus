spec: http_client_extra13
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
    - "http_client_extra2.zspec.zsdl — covers __qualname__.__eq__ for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException/NotConnected/InvalidURL; __module__.__eq__ for HTTPException/HTTPResponse/NotConnected/InvalidURL."
    - "http_client_extra9.zspec.zsdl — covers __name__.__len__() for several classes; __bases__[0].__name__ for HTTPSConnection/HTTPResponse/LineTooLong."
    - "http_client_extra10.zspec.zsdl — covers __qualname__.__len__() for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException/NotConnected; __module__.__len__()==11."
    - "http_client_extra11.zspec.zsdl — covers __qualname__.__eq__ and __len__() for HTTPConnection.request/getresponse/connect/close and HTTPResponse.read/getheader."
    - "http_client_extra12.zspec.zsdl — covers __qualname__.__eq__ and __len__() for HTTPResponse.getheaders/geturl/info; HTTPSConnection.connect __qualname__; HTTPException.__bases__[0].__name__; cross-namespace anchors for HTTPSConnection/NotConnected/InvalidURL."
  notes:
    - "This spec extends the http.client chain through http_client_extra12; it does NOT duplicate invariants in any prior spec."
    - "Focus: (1) HTTPResponse.__qualname__ and __module__ — extra2 covers __qualname__.__eq__ but not __module__ for HTTPResponse as a standalone invariant from this namespace; extra10 covers __qualname__.__len__() but not __module__.__len__(); (2) HTTPResponse.read and getheader __qualname__.__len__() — extra11 covers __qualname__.__eq__ but not lengths; (3) HTTPMessage.__qualname__, __module__, and __bases__[0].__name__ — no prior spec checks HTTPMessage attributes; (4) http.client.responses.__class__.__name__ == 'dict' — no prior spec checks this; (5) HTTPException.__qualname__ cross-namespace anchor from extra13 namespace."
    - "http.client.HTTPResponse.__qualname__ == 'HTTPResponse' — len 12. Cross-namespace anchor; extra2 covers in table."
    - "http.client.HTTPResponse.__module__ == 'http.client' — len 11. No prior spec provides a standalone HTTPResponse.__module__ anchor. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.read.__qualname__ == 'HTTPResponse.read' — len 17. extra11 covers __qualname__.__eq__; this spec adds __len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.getheader.__qualname__ == 'HTTPResponse.getheader' — len 23. extra11 covers __qualname__.__eq__; this spec adds __len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPMessage.__qualname__ == 'HTTPMessage' — len 11. No prior spec checks HTTPMessage attributes. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPMessage.__module__ == 'http.client' — len 11. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPMessage.__bases__[0].__name__ == 'Message' — HTTPMessage inherits from email.message.Message. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.responses.__class__.__name__ == 'dict' — responses is a plain dict mapping int status codes to reason strings; len == 62. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPException.__qualname__ == 'HTTPException' — cross-namespace anchor from extra13 namespace; extra2 covers in table."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HTTPResponse __qualname__ cross-namespace anchor and __module__ checks
#
# http_client_extra2 covers HTTPResponse.__qualname__.__eq__ == 'HTTPResponse'
# in its table. http_client_extra10 covers __qualname__.__len__() == 12.
# No prior spec provides a standalone __module__ check for HTTPResponse.
# HTTPResponse.__module__ == 'http.client' (len 11).
# ---------------------------------------------------------------------------

invariant http_client_extra13.HTTPResponse.qualname_eq:
  description: "http.client.HTTPResponse.__qualname__ == 'HTTPResponse' — cross-namespace anchor from extra13; extra2 covers in table"
  category: class_qualnames
  kind: python_call_eq
  function: HTTPResponse.__qualname__.__eq__
  args: ["HTTPResponse"]
  expected: true

invariant http_client_extra13.HTTPResponse.module_eq:
  description: "http.client.HTTPResponse.__module__ == 'http.client' — no prior spec provides standalone __module__ check for HTTPResponse"
  category: class_module
  kind: python_call_eq
  function: HTTPResponse.__module__.__eq__
  args: ["http.client"]
  expected: true

invariant http_client_extra13.HTTPResponse.module_len:
  description: "len(http.client.HTTPResponse.__module__) == 11 — len('http.client') == 11"
  category: class_module
  kind: python_call_eq
  function: HTTPResponse.__module__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# HTTPResponse.read and getheader __qualname__.__len__() checks
#
# http_client_extra11 covers __qualname__.__eq__ for HTTPResponse.read and
# HTTPResponse.getheader. No prior spec checks their __qualname__.__len__().
# 'HTTPResponse.read' == len 17.
# 'HTTPResponse.getheader' == len 23.
# ---------------------------------------------------------------------------

table http_client_extra13.http_response_method_qualname_lengths:
  description: "__qualname__.__len__() for HTTPResponse.read and HTTPResponse.getheader — extra11 covers __eq__ but not lengths"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: hrmqlen13

  columns: [id, function, args, expected]
  rows:
    - [read,      HTTPResponse.read.__qualname__.__len__,      [], 17]
    - [getheader, HTTPResponse.getheader.__qualname__.__len__, [], 23]

# ---------------------------------------------------------------------------
# HTTPMessage __qualname__, __module__, and __bases__[0].__name__
#
# HTTPMessage is used as the response headers container. No prior spec checks
# any attribute of HTTPMessage. HTTPMessage inherits from email.message.Message.
# __qualname__ == 'HTTPMessage' (len 11).
# __module__ == 'http.client' (len 11).
# __bases__[0].__name__ == 'Message'.
# ---------------------------------------------------------------------------

invariant http_client_extra13.HTTPMessage.qualname_eq:
  description: "http.client.HTTPMessage.__qualname__ == 'HTTPMessage' — no prior spec checks HTTPMessage attributes"
  category: class_qualnames
  kind: python_call_eq
  function: HTTPMessage.__qualname__.__eq__
  args: ["HTTPMessage"]
  expected: true

invariant http_client_extra13.HTTPMessage.qualname_len:
  description: "len(http.client.HTTPMessage.__qualname__) == 11 — len('HTTPMessage') == 11"
  category: class_qualnames
  kind: python_call_eq
  function: HTTPMessage.__qualname__.__len__
  args: []
  expected: 11

invariant http_client_extra13.HTTPMessage.module_eq:
  description: "http.client.HTTPMessage.__module__ == 'http.client' — HTTPMessage is defined in the http.client module"
  category: class_module
  kind: python_call_eq
  function: HTTPMessage.__module__.__eq__
  args: ["http.client"]
  expected: true

invariant http_client_extra13.HTTPMessage.bases0_name_eq:
  description: "http.client.HTTPMessage.__bases__[0].__name__ == 'Message' — HTTPMessage inherits from email.message.Message"
  category: class_hierarchy
  kind: python_call_eq
  "function": "HTTPMessage.__bases__[0].__name__.__eq__"
  args: ["Message"]
  expected: true

# ---------------------------------------------------------------------------
# http.client.responses.__class__.__name__ == 'dict'
#
# http.client.responses is a module-level dict mapping integer HTTP status
# codes to their reason phrase strings (e.g. 200 -> 'OK', 404 -> 'Not Found').
# No prior spec checks the type of this object. It is a plain Python dict.
# len(http.client.responses) == 62 at Python 3.12.
# ---------------------------------------------------------------------------

invariant http_client_extra13.responses.class_name_eq:
  description: "http.client.responses.__class__.__name__ == 'dict' — responses maps int status codes to reason strings; it is a plain dict"
  category: module_attributes
  kind: python_call_eq
  "function": "responses.__class__.__name__.__eq__"
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPException __qualname__ cross-namespace anchor
#
# http_client_extra2 covers HTTPException.__qualname__.__eq__ == 'HTTPException'
# in its table. http_client_extra12 establishes HTTPException.__bases__[0].__name__
# == 'Exception'. This standalone invariant anchors HTTPException.__qualname__
# from the extra13 namespace.
# ---------------------------------------------------------------------------

invariant http_client_extra13.HTTPException.qualname_eq:
  description: "http.client.HTTPException.__qualname__ == 'HTTPException' — cross-namespace anchor from extra13; extra2 covers in table"
  category: class_qualnames
  kind: python_call_eq
  function: HTTPException.__qualname__.__eq__
  args: ["HTTPException"]
  expected: true
