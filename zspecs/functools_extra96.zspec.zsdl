spec: functools_extra96
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra95

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra95.zspec.zsdl."
    - "This spec covers: functools Python function __code__.co_name and __code__.co_argcount introspection (Wave 251)."
    - "functools.update_wrapper.__code__.co_name == 'update_wrapper' — co_name is the name at the def statement. Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_name == 'wraps' — co_name is 'wraps'. Verified with Python 3.14.3."
    - "functools.total_ordering.__code__.co_name == 'total_ordering' — co_name is 'total_ordering'. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_name == 'singledispatch' — co_name is 'singledispatch'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__code__.co_argcount == 4 — takes wrapper, wrapped, assigned, updated. Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_argcount == 3 — takes wrapped, assigned, updated. Verified with Python 3.14.3."
    - "functools.total_ordering.__code__.co_argcount == 1 — takes cls. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_argcount == 1 — takes func. Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_argcount == 2 — takes maxsize and typed. Verified with Python 3.14.3."
    - "functools.cached_property.__init__.__code__.co_argcount == 2 — takes self and func. Verified with Python 3.14.3."
    - "functools.cached_property.__init__.__code__.co_name == '__init__' — co_name is '__init__'. Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_name == 'lru_cache' — co_name is 'lru_cache'. Verified with Python 3.14.3."
    - "functools.partialmethod has no __init__ in its own __dict__; it inherits object.__init__ which is a wrapper_descriptor with no __code__ attribute. The spec covers cached_property.__init__ and other pure-Python __code__ bearers instead."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Python function co_name equality
#
# Wave 251 theme: functools Python function __code__.co_name identity.
#
# functools.update_wrapper.__code__.co_name.__eq__('update_wrapper') == True
# functools.wraps.__code__.co_name.__eq__('wraps')                   == True
# functools.total_ordering.__code__.co_name.__eq__('total_ordering') == True
# functools.singledispatch.__code__.co_name.__eq__('singledispatch') == True
#
# co_name is the string name at the `def` statement in the source.
# Prior spec extra95 checked __module__ for these functions. This spec (extra96) checks __code__.co_name. New to extra96.
# ---------------------------------------------------------------------------

table functools_extra96.co_name_equality:
  description: "update_wrapper/wraps/total_ordering/singledispatch __code__.co_name identity; pure-Python functions; wave 251; new to extra96"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolscoattr96

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_co_name_eq,
       "update_wrapper.__code__.co_name.__eq__",
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__code__.co_name.__eq__('update_wrapper') == True — update_wrapper is a pure-Python function in Lib/functools.py; __code__.co_name holds the name of the function as written at the def statement; co_name is 'update_wrapper'; str.__eq__('update_wrapper') returns True; prior spec extra95 checked __module__; this spec (extra96) checks __code__.co_name; new to extra96"]
    - [wraps_co_name_eq,
       "wraps.__code__.co_name.__eq__",
       ["wraps"],
       true,
       "functools.wraps.__code__.co_name.__eq__('wraps') == True — wraps is a pure-Python convenience decorator in Lib/functools.py; __code__.co_name is 'wraps'; str.__eq__('wraps') returns True; new to extra96"]
    - [total_ordering_co_name_eq,
       "total_ordering.__code__.co_name.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__code__.co_name.__eq__('total_ordering') == True — total_ordering is a pure-Python class decorator in Lib/functools.py; __code__.co_name is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra96"]
    - [singledispatch_co_name_eq,
       "singledispatch.__code__.co_name.__eq__",
       ["singledispatch"],
       true,
       "functools.singledispatch.__code__.co_name.__eq__('singledispatch') == True — singledispatch is a pure-Python decorator in Lib/functools.py; __code__.co_name is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra96"]

# ---------------------------------------------------------------------------
# co_argcount values for key functions
#
# Wave 251 theme: functools Python function __code__.co_argcount values.
#
# functools.update_wrapper.__code__.co_argcount == 4  (wrapper, wrapped, assigned, updated)
# functools.wraps.__code__.co_argcount           == 3  (wrapped, assigned, updated)
# functools.total_ordering.__code__.co_argcount  == 1  (cls)
# functools.singledispatch.__code__.co_argcount  == 1  (func)
#
# co_argcount counts positional/keyword parameters (excluding * and **). New to extra96.
# ---------------------------------------------------------------------------

table functools_extra96.co_argcount_key_functions:
  description: "update_wrapper/wraps/total_ordering/singledispatch __code__.co_argcount values; pure-Python functions; wave 251; new to extra96"
  kind: python_call_eq
  category: integer_identity
  id_prefix: functoolscoattr96

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_co_argcount_eq_4,
       "update_wrapper.__code__.co_argcount.__eq__",
       [4],
       true,
       "functools.update_wrapper.__code__.co_argcount.__eq__(4) == True — update_wrapper takes wrapper, wrapped, assigned, updated as positional-or-keyword parameters; co_argcount counts these 4 positional/keyword parameters (excludes *args and **kwargs); int.__eq__(4) returns True; new to extra96"]
    - [wraps_co_argcount_eq_3,
       "wraps.__code__.co_argcount.__eq__",
       [3],
       true,
       "functools.wraps.__code__.co_argcount.__eq__(3) == True — wraps takes wrapped, assigned, updated as positional-or-keyword parameters; co_argcount is 3; int.__eq__(3) returns True; new to extra96"]
    - [total_ordering_co_argcount_eq_1,
       "total_ordering.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.total_ordering.__code__.co_argcount.__eq__(1) == True — total_ordering takes a single cls parameter as a class decorator; co_argcount is 1; int.__eq__(1) returns True; new to extra96"]
    - [singledispatch_co_argcount_eq_1,
       "singledispatch.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.singledispatch.__code__.co_argcount.__eq__(1) == True — singledispatch takes a single func parameter as a function decorator; co_argcount is 1; int.__eq__(1) returns True; new to extra96"]

# ---------------------------------------------------------------------------
# cached_property and lru_cache __code__ attributes
#
# Wave 251 theme: functools __code__ attrs for cached_property.__init__ and lru_cache.
#
# functools.cached_property.__init__.__code__.co_argcount == 2  (self, func)
# functools.cached_property.__init__.__code__.co_name.__eq__('__init__') == True
# functools.lru_cache.__code__.co_argcount == 2  (maxsize, typed)
# functools.lru_cache.__code__.co_name.__eq__('lru_cache') == True
#
# No prior functools spec checks cached_property or lru_cache __code__ attrs via functoolscoattr96. New to extra96.
# ---------------------------------------------------------------------------

table functools_extra96.cached_property_lru_cache_code_attrs:
  description: "cached_property.__init__ and lru_cache __code__.co_argcount and co_name; wave 251; new to extra96"
  kind: python_call_eq
  category: integer_identity
  id_prefix: functoolscoattr96

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_init_co_argcount_eq_2,
       "cached_property.__init__.__code__.co_argcount.__eq__",
       [2],
       true,
       "functools.cached_property.__init__.__code__.co_argcount.__eq__(2) == True — cached_property.__init__ takes self and func as positional-or-keyword parameters; co_argcount is 2 (self counts because it is an explicit positional parameter in a regular method, not a slot wrapper); int.__eq__(2) returns True; no prior functools spec checks cached_property or lru_cache __code__ attrs via functoolscoattr96; new to extra96"]
    - [cached_property_init_co_name_eq,
       "cached_property.__init__.__code__.co_name.__eq__",
       ["__init__"],
       true,
       "functools.cached_property.__init__.__code__.co_name.__eq__('__init__') == True — the code object name matches the def statement name '__init__'; str.__eq__('__init__') returns True; new to extra96"]
    - [lru_cache_co_argcount_eq_2,
       "lru_cache.__code__.co_argcount.__eq__",
       [2],
       true,
       "functools.lru_cache.__code__.co_argcount.__eq__(2) == True — lru_cache takes maxsize and typed as positional-or-keyword parameters; co_argcount is 2; int.__eq__(2) returns True; new to extra96"]
    - [lru_cache_co_name_eq,
       "lru_cache.__code__.co_name.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__code__.co_name.__eq__('lru_cache') == True — lru_cache code object co_name is 'lru_cache' matching its def statement; str.__eq__('lru_cache') returns True; new to extra96"]

# ---------------------------------------------------------------------------
# Cross-checks: co_argcount distinguishes functions
#
# Wave 251 theme: cross-check co_argcount values confirm singledispatch and total_ordering differ from update_wrapper.
#
# functools.update_wrapper.__code__.co_argcount.__eq__(1) == False  (has 4 params, not 1)
# functools.wraps.__code__.co_argcount.__eq__(1)          == False  (has 3 params, not 1)
# functools.total_ordering.__code__.co_argcount.__eq__(4) == False  (has 1 param, not 4)
# functools.lru_cache.__code__.co_argcount.__eq__(1)      == False  (has 2 params, not 1)
#
# Cross-checks confirm co_argcount distinguishes these functions from each other. New to extra96.
# ---------------------------------------------------------------------------

table functools_extra96.co_argcount_cross_checks:
  description: "co_argcount cross-checks confirming update_wrapper!=1, wraps!=1, total_ordering!=4, lru_cache!=1; wave 251; new to extra96"
  kind: python_call_eq
  category: integer_identity
  id_prefix: functoolscoattr96

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_co_argcount_ne_1,
       "update_wrapper.__code__.co_argcount.__eq__",
       [1],
       false,
       "functools.update_wrapper.__code__.co_argcount.__eq__(1) == False — update_wrapper has 4 positional/keyword parameters (wrapper, wrapped, assigned, updated), not 1; int.__eq__(1) returns False; confirms update_wrapper differs from single-arg decorators like total_ordering; new to extra96"]
    - [wraps_co_argcount_ne_1,
       "wraps.__code__.co_argcount.__eq__",
       [1],
       false,
       "functools.wraps.__code__.co_argcount.__eq__(1) == False — wraps has 3 positional/keyword parameters (wrapped, assigned, updated), not 1; int.__eq__(1) returns False; confirms wraps differs from single-arg decorators; new to extra96"]
    - [total_ordering_co_argcount_ne_4,
       "total_ordering.__code__.co_argcount.__eq__",
       [4],
       false,
       "functools.total_ordering.__code__.co_argcount.__eq__(4) == False — total_ordering has 1 positional/keyword parameter (cls), not 4; int.__eq__(4) returns False; confirms total_ordering is a simple single-arg class decorator unlike update_wrapper; new to extra96"]
    - [lru_cache_co_argcount_ne_1,
       "lru_cache.__code__.co_argcount.__eq__",
       [1],
       false,
       "functools.lru_cache.__code__.co_argcount.__eq__(1) == False — lru_cache has 2 positional/keyword parameters (maxsize, typed), not 1; int.__eq__(1) returns False; confirms lru_cache has more parameters than single-arg decorators like total_ordering; new to extra96"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra96
# ---------------------------------------------------------------------------

invariant functools_extra96.update_wrapper_co_name_eq:
  description: "functools.update_wrapper.__code__.co_name.__eq__('update_wrapper') == True — co_name matches def statement; wave 251; new to extra96"
  kind: python_call_eq
  function: "update_wrapper.__code__.co_name.__eq__"
  args: ["update_wrapper"]
  expected: true

invariant functools_extra96.update_wrapper_co_argcount_eq_4:
  description: "functools.update_wrapper.__code__.co_argcount.__eq__(4) == True — takes wrapper/wrapped/assigned/updated; wave 251; new to extra96"
  kind: python_call_eq
  function: "update_wrapper.__code__.co_argcount.__eq__"
  args: [4]
  expected: true

invariant functools_extra96.total_ordering_co_argcount_eq_1:
  description: "functools.total_ordering.__code__.co_argcount.__eq__(1) == True — single cls parameter; wave 251; new to extra96"
  kind: python_call_eq
  function: "total_ordering.__code__.co_argcount.__eq__"
  args: [1]
  expected: true

invariant functools_extra96.cached_property_init_co_argcount_eq_2:
  description: "functools.cached_property.__init__.__code__.co_argcount.__eq__(2) == True — takes self and func; wave 251; new to extra96"
  kind: python_call_eq
  function: "cached_property.__init__.__code__.co_argcount.__eq__"
  args: [2]
  expected: true

invariant functools_extra96.lru_cache_co_name_eq:
  description: "functools.lru_cache.__code__.co_name.__eq__('lru_cache') == True — co_name matches def statement; wave 251; new to extra96"
  kind: python_call_eq
  function: "lru_cache.__code__.co_name.__eq__"
  args: ["lru_cache"]
  expected: true
