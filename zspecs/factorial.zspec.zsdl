spec: factorial
version: ">=2.0.0"
backend: node(factorial)

docs: https://www.npmjs.com/package/factorial

provenance:
  derived_from:
    - "factorial README — https://www.npmjs.com/package/factorial"
    - "Test vectors verified with factorial via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "factorial source"
  notes:
    - "factorial is an npm package. Install: npm install factorial"
    - "Returns the factorial of a non-negative integer."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table factorial.factorial:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: fact

  columns: [id, args, expected]
  rows:
    - [five,   [5],  120]
    - [three,  [3],  6]
    - [zero,   [0],  1]
    - [one,    [1],  1]

