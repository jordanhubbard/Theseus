spec: pydantic_settings_rust
version: ">=3.9"
backend: rust_module(pydantic_settings_rust)

docs: https://docs.pydantic.dev/latest/concepts/pydantic_settings/

provenance:
  derived_from:
    - "https://docs.pydantic.dev/latest/concepts/pydantic_settings/ — pydantic-settings"
  notes:
    - "pydantic-settings provides settings management with Pydantic."
    - "pydantic_settings.BaseSettings is a class."
    - "pydantic_settings.SettingsConfigDict is a class."
    - "pydantic_settings.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pydantic_settings_rust.has_base_settings:
  description: "pydantic_settings.BaseSettings is a class"
  category: presence
  kind: python_call_eq
  function: pydantic_settings_has_base_settings
  args: []
  expected: true

invariant pydantic_settings_rust.has_settings_config_dict:
  description: "pydantic_settings.SettingsConfigDict is defined"
  category: presence
  kind: python_call_eq
  function: pydantic_settings_has_settings_config_dict
  args: []
  expected: true

invariant pydantic_settings_rust.version_nonempty:
  description: "pydantic_settings.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pydantic_settings_version_nonempty
  args: []
  expected: true

