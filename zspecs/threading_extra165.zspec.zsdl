spec: threading_extra165
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Thread.__dict__.__contains__('start') True; threading.Thread.__dict__.__contains__('run') True; threading.Thread.__dict__.__contains__('join') True; threading.Thread.__dict__.__contains__('is_alive') True; threading.Thread.__dict__.__contains__('__init__') True; threading.Thread.__dict__.__contains__('daemon') True; threading.Thread.__dict__.__len__() 28; threading.Thread.__dict__.__class__.__name__ 'mappingproxy' (Wave 293)."
    - "threading.Thread.__dict__.__contains__('start') == True — Thread.start() is the public method that starts the thread's activity by invoking the run() method in a new OS thread; 'start' is a key in Thread.__dict__. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('run') == True — Thread.run() is the method representing the thread's activity; it is overridden by subclasses; 'run' is a key in Thread.__dict__. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('join') == True — Thread.join(timeout=None) blocks the calling thread until the thread terminates; 'join' is a key in Thread.__dict__. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('is_alive') == True — Thread.is_alive() returns True if the thread is currently executing; 'is_alive' is a key in Thread.__dict__. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('__init__') == True — Thread.__init__() initializes the thread with group/target/name/args/kwargs/daemon; '__init__' is a key in Thread.__dict__. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('daemon') == True — Thread.daemon is a property that controls whether the thread is a daemon thread; 'daemon' is a key in Thread.__dict__. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__len__() == 28 — Thread.__dict__ has 28 entries in Python 3.14.3 on macOS/Darwin 25.4.0. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__class__.__name__ == 'mappingproxy' — Thread.__dict__ is a read-only mappingproxy (types.MappingProxyType) as for all Python classes. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread.__dict__ membership — core public methods
#
# Wave 293 theme: threading.Thread class __dict__ membership — the core
# public methods 'start', 'run', 'join', 'is_alive' are all present.
#
# threading.Thread.__dict__.__contains__('start') == True
# threading.Thread.__dict__.__contains__('run') == True
# threading.Thread.__dict__.__contains__('join') == True
# threading.Thread.__dict__.__contains__('is_alive') == True
#
# threading.Thread is the central class in Lib/threading.py representing a
# thread of control. It has several key public methods: start() launches the
# thread in a new OS thread; run() contains the thread's activity (override
# in subclasses); join() blocks until the thread terminates; is_alive()
# returns True while the thread is executing. All four are present as keys
# in Thread.__dict__ (the class mappingproxy). New to extra165.
# ---------------------------------------------------------------------------

table threading_extra165.thread_dict_core_methods_membership:
  description: "threading.Thread.__dict__: contains 'start', 'run', 'join', 'is_alive'; wave 293; new to extra165"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtdcmm165

  columns: [id, function, args, expected, description]
  rows:
    - [td_has_start,
       "Thread.__dict__.__contains__",
       ["start"],
       true,
       "threading.Thread.__dict__.__contains__('start') == True — Thread.start() is the public method that starts the thread's activity by arranging for run() to be called in a separate OS thread; 'start' is a key in Thread.__dict__; mappingproxy.__contains__('start') returns True; new to extra165"]
    - [td_has_run,
       "Thread.__dict__.__contains__",
       ["run"],
       true,
       "threading.Thread.__dict__.__contains__('run') == True — Thread.run() represents the thread's activity and is called by start(); it invokes the callable passed as target with args/kwargs; 'run' is a key in Thread.__dict__; mappingproxy.__contains__('run') returns True; new to extra165"]
    - [td_has_join,
       "Thread.__dict__.__contains__",
       ["join"],
       true,
       "threading.Thread.__dict__.__contains__('join') == True — Thread.join(timeout=None) blocks the calling thread until the thread whose join() method is called terminates or the optional timeout elapses; 'join' is a key in Thread.__dict__; mappingproxy.__contains__('join') returns True; new to extra165"]
    - [td_has_is_alive,
       "Thread.__dict__.__contains__",
       ["is_alive"],
       true,
       "threading.Thread.__dict__.__contains__('is_alive') == True — Thread.is_alive() returns True if the thread is currently alive (between start() and termination); 'is_alive' is a key in Thread.__dict__; mappingproxy.__contains__('is_alive') returns True; new to extra165"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread.__dict__ membership — __init__ and daemon,
# plus __dict__ metadata
#
# Wave 293 theme: threading.Thread class __dict__ membership for '__init__'
# and 'daemon'; also __dict__ total length and class name.
#
# threading.Thread.__dict__.__contains__('__init__') == True
# threading.Thread.__dict__.__contains__('daemon') == True
# threading.Thread.__dict__.__len__() == 28
# threading.Thread.__dict__.__class__.__name__ == 'mappingproxy'
#
# Thread.__init__(group=None, target=None, name=None, args=(), kwargs={},
# daemon=None) initializes the Thread with all configuration. Thread.daemon
# is a property controlling daemon-thread status; daemon threads are abruptly
# terminated when the main program exits. Thread.__dict__ is a read-only
# mappingproxy with 28 entries in Python 3.14.3. New to extra165.
# ---------------------------------------------------------------------------

table threading_extra165.thread_dict_init_daemon_and_metadata:
  description: "threading.Thread.__dict__: contains '__init__', 'daemon'; __len__() 28; __class__.__name__ 'mappingproxy'; wave 293; new to extra165"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtdidm165

  columns: [id, function, args, expected, description]
  rows:
    - [td_has_init,
       "Thread.__dict__.__contains__",
       ["__init__"],
       true,
       "threading.Thread.__dict__.__contains__('__init__') == True — Thread.__init__() is the constructor that initializes the thread with group/target/name/args/kwargs/daemon parameters; '__init__' is a key in Thread.__dict__; mappingproxy.__contains__('__init__') returns True; new to extra165"]
    - [td_has_daemon,
       "Thread.__dict__.__contains__",
       ["daemon"],
       true,
       "threading.Thread.__dict__.__contains__('daemon') == True — Thread.daemon is a property that reads/sets daemon status for the thread; daemon threads are forcefully terminated when the interpreter exits; 'daemon' is a key in Thread.__dict__; mappingproxy.__contains__('daemon') returns True; new to extra165"]
    - [td_len_eq_28,
       "Thread.__dict__.__len__",
       [],
       28,
       "threading.Thread.__dict__.__len__() == 28 — Thread.__dict__ contains 28 entries in Python 3.14.3 on macOS/Darwin 25.4.0 including public methods (start, run, join, is_alive), properties (daemon, name, ident, native_id), deprecated aliases (getName, setName, isDaemon, setDaemon), and internal helpers; mappingproxy.__len__() returns 28; new to extra165"]
    - [td_class_name_mappingproxy,
       "Thread.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Thread.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Thread.__dict__ is a read-only mappingproxy (types.MappingProxyType) as for all Python class __dict__ attributes; its __class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra165"]

