spec: re_extra486
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re.Pattern method identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.Pattern methods are wrapper_descriptor types; __name__ is accessible at class level"
    - "No regex pattern strings used in this spec; all checks are method name identity only"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra486.pattern_method_names:
  description: "re.Pattern class-level method __name__ identity"
  kind: python_call_eq
  category: method_identity
  id_prefix: rep

  columns: [id, function, args, expected]
  rows:
    - [rep001, re.Pattern.match.__name__.__eq__,     ["match"],     true]
    - [rep002, re.Pattern.search.__name__.__eq__,    ["search"],    true]
    - [rep003, re.Pattern.fullmatch.__name__.__eq__, ["fullmatch"], true]
    - [rep004, re.Pattern.findall.__name__.__eq__,   ["findall"],   true]
    - [rep005, re.Pattern.finditer.__name__.__eq__,  ["finditer"],  true]
    - [rep006, re.Pattern.sub.__name__.__eq__,       ["sub"],       true]
    - [rep007, re.Pattern.subn.__name__.__eq__,      ["subn"],      true]
    - [rep008, re.Pattern.split.__name__.__eq__,     ["split"],     true]
