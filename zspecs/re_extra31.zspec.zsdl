spec: re_extra31
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra30.zspec.zsdl — covers compile/match/search/fullmatch/sub __module__.__len__()==2; compile/match/search/fullmatch/sub __name__.__len__(); Pattern/__module__.__len__()==2; Match/__module__.__len__()==2."
  notes:
    - "This spec extends re_extra30.zspec.zsdl."
    - "Prior specs covered: re.compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape/purge __name__/__module__/__qualname__, Pattern/Match/__name__/__module__/__qualname__/__bases__[0].__name__, re.error/__name__/__module__, re.IGNORECASE/MULTILINE/DOTALL/VERBOSE values, compile/match/search/fullmatch/sub __module__.__len__()==2 and __name__.__len__(), Pattern/__module__.__len__()==2, Match/__module__.__len__()==2."
    - "This spec covers: split/__module__.__len__()==2; findall/__module__.__len__()==2; finditer/__module__.__len__()==2; purge/__module__.__len__()==2; escape/__module__.__len__()==2; split/__name__.__len__()==5; findall/__name__.__len__()==7; finditer/__name__.__len__()==8; purge/__name__.__len__()==5; escape/__name__.__len__()==6; Pattern/__name__.__len__()==7; Match/__name__.__len__()==5; Pattern/__qualname__.__len__()==7; Match/__qualname__.__len__()==5."
    - "re.split.__module__ == 're' (len 2). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "re.findall.__module__ == 're' (len 2). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "re.finditer.__module__ == 're' (len 2). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "re.purge.__module__ == 're' (len 2). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "re.escape.__module__ == 're' (len 2). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "re.split.__name__ == 'split' (len 5). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "re.findall.__name__ == 'findall' (len 7). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "re.finditer.__name__ == 'finditer' (len 8). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "re.purge.__name__ == 'purge' (len 5). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "re.escape.__name__ == 'escape' (len 6). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "re.Pattern.__name__ == 'Pattern' (len 7). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "re.Match.__name__ == 'Match' (len 5). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "re.Pattern.__qualname__ == 'Pattern' (len 7). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "re.Match.__qualname__ == 'Match' (len 5). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__()==2 for split, findall, finditer, purge, escape
#
# re_extra30 covers __module__.__len__()==2 for compile/match/search/fullmatch/sub.
# This spec extends coverage to the remaining five public functions in the
# re module. All have __module__ == 're' (len 2).
# ---------------------------------------------------------------------------

table re_extra31.remaining_function_module_lengths:
  description: "len(__module__) == 2 for split/findall/finditer/purge/escape — all 're'; extends extra30 coverage to remaining functions"
  kind: python_call_eq
  category: string_length
  id_prefix: rfml31

  columns: [id, function, args, expected]
  rows:
    - [split_module_len,   split.__module__.__len__,   [], 2]
    - [findall_module_len, findall.__module__.__len__, [], 2]
    - [finditer_module_len, finditer.__module__.__len__, [], 2]
    - [purge_module_len,   purge.__module__.__len__,   [], 2]
    - [escape_module_len,  escape.__module__.__len__,  [], 2]

# ---------------------------------------------------------------------------
# __name__.__len__() for split, findall, finditer, purge, escape
#
# re_extra30 covers __name__.__len__() for compile/match/search/fullmatch/sub.
# This spec covers the remaining five public functions.
# split=5, findall=7, finditer=8, purge=5, escape=6.
# ---------------------------------------------------------------------------

invariant re_extra31.split.name.len:
  description: "re.split.__name__.__len__() == 5 — 'split' has 5 characters"
  category: string_length
  kind: python_call_eq
  function: split.__name__.__len__
  args: []
  expected: 5

invariant re_extra31.finditer.name.len:
  description: "re.finditer.__name__.__len__() == 8 — 'finditer' has 8 characters"
  category: string_length
  kind: python_call_eq
  function: finditer.__name__.__len__
  args: []
  expected: 8

table re_extra31.remaining_function_name_lengths:
  description: "len(__name__) for findall (7), purge (5), escape (6) — completes __name__.__len__() coverage for all public re functions"
  kind: python_call_eq
  category: string_length
  id_prefix: rfnl31

  columns: [id, function, args, expected]
  rows:
    - [findall_name_len, findall.__name__.__len__, [], 7]
    - [purge_name_len,   purge.__name__.__len__,   [], 5]
    - [escape_name_len,  escape.__name__.__len__,  [], 6]

# ---------------------------------------------------------------------------
# re.Pattern.__name__.__len__() and re.Match.__name__.__len__()
#
# re_extra30 covers Pattern/__module__.__len__()==2 and Match/__module__.__len__()==2.
# No prior spec checks __name__.__len__() for Pattern or Match.
# Pattern.__name__ == 'Pattern' (len 7); Match.__name__ == 'Match' (len 5).
# ---------------------------------------------------------------------------

invariant re_extra31.Pattern.name.len:
  description: "re.Pattern.__name__.__len__() == 7 — 'Pattern' has 7 characters; novel invariant"
  category: string_length
  kind: python_call_eq
  function: Pattern.__name__.__len__
  args: []
  expected: 7

invariant re_extra31.Match.name.len:
  description: "re.Match.__name__.__len__() == 5 — 'Match' has 5 characters; novel invariant"
  category: string_length
  kind: python_call_eq
  function: Match.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# re.Pattern.__qualname__.__len__() and re.Match.__qualname__.__len__()
#
# No prior spec checks __qualname__.__len__() for Pattern or Match.
# For top-level types, __qualname__ equals __name__:
# Pattern.__qualname__ == 'Pattern' (len 7); Match.__qualname__ == 'Match' (len 5).
# ---------------------------------------------------------------------------

table re_extra31.type_qualname_lengths:
  description: "len(__qualname__) for Pattern (7) and Match (5) — novel invariants; qualname equals name for top-level types"
  kind: python_call_eq
  category: string_length
  id_prefix: tql31

  columns: [id, function, args, expected]
  rows:
    - [Pattern_qualname_len, Pattern.__qualname__.__len__, [], 7]
    - [Match_qualname_len,   Match.__qualname__.__len__,   [], 5]
