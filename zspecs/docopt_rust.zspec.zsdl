spec: docopt_rust
version: ">=3.9"
backend: rust_module(docopt_rust)

docs: https://github.com/docopt/docopt.py

provenance:
  derived_from:
    - "https://github.com/docopt/docopt.py — docopt documentation"
  not_derived_from:
    - "docopt source: docopt.py"
  notes:
    - "docopt creates CLI interfaces from docstring specifications."
    - "docopt is available as a module."
    - "docopt.docopt is the main function."
    - "from docopt import docopt — importable."
    - "Expose docopt_has_docopt() -> bool: hasattr(docopt, 'docopt')."
    - "Expose docopt_main_callable() -> bool: callable(docopt.docopt)."
    - "All test vectors verified against docopt 0.6.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# docopt_has_docopt — docopt function present
invariant docopt_rust.module.has_docopt:
  description: "docopt.docopt is available"
  category: module
  kind: python_call_eq
  function: docopt_has_docopt
  args: []
  expected: true

# docopt_main_callable — docopt is callable
invariant docopt_rust.module.main_callable:
  description: "docopt.docopt is callable"
  category: callable
  kind: python_call_eq
  function: docopt_main_callable
  args: []
  expected: true

