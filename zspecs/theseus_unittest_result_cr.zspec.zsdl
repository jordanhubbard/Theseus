spec: theseus_unittest_result_cr
version: ">=3.0"
backend: python_cleanroom(theseus_unittest_result_cr)
blocks: unittest.result

docs: https://docs.python.org/3/library/unittest.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/unittest.html"
  not_derived_from:
    - "CPython source: Lib/unittest/result.py"
  notes:
    - "Clean-room unittest.result module. Do NOT import unittest.result."

error_model: python_exceptions

invariant theseus_unittest_result_cr.utresult2_testresult:
  description: "TestResult class tracks test outcomes"
  category: behavior
  kind: python_call_eq
  function: utresult2_testresult
  args: []
  expected: true

invariant theseus_unittest_result_cr.utresult2_errors:
  description: "failures and errors lists track test failures"
  category: behavior
  kind: python_call_eq
  function: utresult2_errors
  args: []
  expected: true

invariant theseus_unittest_result_cr.utresult2_counts:
  description: "testsRun and skipped counts are tracked"
  category: behavior
  kind: python_call_eq
  function: utresult2_counts
  args: []
  expected: true
