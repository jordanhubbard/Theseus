spec: struct_extra125
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths / Struct.size/__format__ descriptor __doc__ equality and length / struct.__doc__ length (1278) (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / Struct.size/__format__ qualname/name lengths and __objclass__.__name__ / Struct.__doc__ length (table + invariants)."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct.__module__/__len__()==7 / error/__module__/__len__()==6 (table + invariants)."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__/__len__() and error.__name__/__len__() (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 / module-level function __module__.__eq__('_struct') (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth / module-level function __qualname__.__len__() (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / struct.error inheritance and __module__/__qualname__ (table + invariants)."
    - "struct_extra92.zspec.zsdl — covers struct module-level function __class__.__name__ / Struct method __class__.__name__ (table + invariants)."
    - "struct_extra91.zspec.zsdl — covers struct.calcsize return values / Struct.__doc__/__class__.__name__ / struct.error/__class__.__name__ (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior struct spec files."
    - "Wave 273 theme: struct.__all__ list membership — all 8 entries (calcsize, pack, pack_into, unpack, unpack_from, iter_unpack, Struct, error) / struct.__all__ class name ('list') and length (8) / Struct.pack.__objclass__ identity."
    - "struct.__all__.__class__.__name__ == 'list'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__all__.__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'calcsize' in struct.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'pack' in struct.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'pack_into' in struct.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'unpack' in struct.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'unpack_from' in struct.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'iter_unpack' in struct.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'Struct' in struct.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'error' in struct.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct has __all__ (a list); this was confirmed by hasattr(struct, '__all__') == True. The list has exactly 8 entries: the 6 module-level functions plus Struct class and error exception."
    - "Note: struct.__all__[0] == 'calcsize' and struct.__all__[-1] == 'error'. The ordering is calcsize, pack, pack_into, unpack, unpack_from, iter_unpack, Struct, error."
    - "Note: struct.Struct.pack is a method_descriptor (C-level). Its __objclass__ is the Struct class, confirming it is bound to the Struct type."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__all__.__class__.__name__.__eq__('list')
# struct.__all__.__len__()==8
# struct.__all__.__contains__('calcsize')
# struct.__all__.__contains__('pack')
# struct.__all__.__contains__('pack_into')
#
# Wave 273 theme: struct.__all__ list class identity and function membership.
#
# struct.__all__ is a list (not a tuple) with 8 entries. This contrasts with
# hashlib.__all__ which is a tuple. The 8 entries cover the 6 module-level
# functions plus Struct class and error exception. calcsize, pack, pack_into
# are the first three alphabetically/positionally in the list (struct.__all__[0]
# is 'calcsize'). No prior struct spec anchors __all__ class name or membership
# under structall125. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra125.all_class_and_function_members:
  description: "struct.__all__/__class__/__name__.__eq__('list')==True / __all__/__len__()==8 / __all__/__contains__('calcsize')==True / __all__/__contains__('pack')==True / __all__/__contains__('pack_into')==True — __all__ is a list with 8 entries (6 functions + Struct + error); __all__[0]=='calcsize'; contrasts with hashlib.__all__ (tuple); no prior struct spec anchors __all__ class or membership; first structall125 anchor"
  kind: python_call_eq
  category: module_all
  id_prefix: structall125

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_name,         "__all__.__class__.__name__.__eq__", ["list"],       true, "struct.__all__ is a list (not a tuple, unlike hashlib.__all__)"]
    - [all_len,                __all__.__len__,                     [],             8,    "struct.__all__ has 8 entries: 6 functions + Struct class + error exception"]
    - [all_contains_calcsize,  __all__.__contains__,                ["calcsize"],   true, "struct.__all__ contains 'calcsize' (first entry, returns packed size of format)"]
    - [all_contains_pack,      __all__.__contains__,                ["pack"],       true, "struct.__all__ contains 'pack' (packs values into bytes by format string)"]
    - [all_contains_pack_into, __all__.__contains__,                ["pack_into"],  true, "struct.__all__ contains 'pack_into' (packs into writable buffer at offset)"]

# ---------------------------------------------------------------------------
# struct.__all__.__contains__('unpack')
# struct.__all__.__contains__('unpack_from')
# struct.__all__.__contains__('iter_unpack')
# struct.__all__.__contains__('Struct')
# struct.__all__.__contains__('error')
#
# Wave 273 theme: struct.__all__ list membership for remaining entries.
#
# The remaining 5 entries in struct.__all__ are unpack, unpack_from, iter_unpack,
# Struct, and error. unpack/unpack_from/iter_unpack are the unpack-side functions.
# Struct is the class providing compiled format caching. error is the exception
# class raised on pack/unpack failures. All 5 are listed in __all__, confirming
# they are part of the struct public API. No prior struct spec anchors these
# membership checks under structall125. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra125.all_remaining_members:
  description: "struct.__all__/__contains__('unpack')==True / __contains__('unpack_from')==True / __contains__('iter_unpack')==True / __contains__('Struct')==True / __contains__('error')==True — completes the 8-entry __all__ list coverage: unpack/unpack_from/iter_unpack (unpack-side functions) + Struct (compiled format cache class) + error (exception class); no prior struct spec anchors these; first structall125 anchor for remaining __all__ members"
  kind: python_call_eq
  category: module_all
  id_prefix: structall125

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_unpack,      __all__.__contains__, ["unpack"],      true, "struct.__all__ contains 'unpack' (unpacks bytes to tuple by format string)"]
    - [all_contains_unpack_from, __all__.__contains__, ["unpack_from"], true, "struct.__all__ contains 'unpack_from' (unpacks from buffer at offset)"]
    - [all_contains_iter_unpack, __all__.__contains__, ["iter_unpack"], true, "struct.__all__ contains 'iter_unpack' (returns iterator over repeated format)"]
    - [all_contains_Struct,      __all__.__contains__, ["Struct"],      true, "struct.__all__ contains 'Struct' (compiled Struct class for repeated use)"]
    - [all_contains_error,       __all__.__contains__, ["error"],       true, "struct.__all__ contains 'error' (exception raised on pack/unpack errors; last entry)"]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__objclass__.__name__.__eq__('Struct')
# struct.Struct.unpack.__objclass__.__name__.__eq__('Struct')
# struct.Struct.pack_into.__objclass__.__name__.__eq__('Struct')
# struct.Struct.unpack_from.__objclass__.__name__.__eq__('Struct')
# struct.Struct.iter_unpack.__objclass__.__name__.__eq__('Struct')
#
# Wave 273 theme: Struct method_descriptor __objclass__.__name__ identity.
#
# struct.Struct.pack, unpack, pack_into, unpack_from, iter_unpack are all
# method_descriptor objects (C-level methods from _struct.c). Each has an
# __objclass__ attribute pointing to the Struct class, confirming they are
# bound methods of the Struct type. struct_extra93 first anchors their __name__
# equality; struct_extra92 anchors their __class__.__name__=='method_descriptor';
# no prior struct spec anchors any Struct method's __objclass__.__name__ under
# structall125. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra125.Struct_method_objclass_names:
  description: "struct.Struct.pack/__objclass__/__name__.__eq__('Struct')==True / unpack/__objclass__/__name__.__eq__('Struct')==True / pack_into/__objclass__/__name__.__eq__('Struct')==True / unpack_from/__objclass__/__name__.__eq__('Struct')==True / iter_unpack/__objclass__/__name__.__eq__('Struct')==True — all five are method_descriptors from _struct.c; __objclass__ points to the Struct class; extra93 anchors __name__ equality; extra92 anchors class names; first structall125 anchor for Struct method __objclass__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: structall125

  columns: [id, function, args, expected, description]
  rows:
    - [pack_objclass,        Struct.pack.__objclass__.__name__.__eq__,        ["Struct"], true, "Struct.pack.__objclass__ is the Struct class (method_descriptor from _struct.c)"]
    - [unpack_objclass,      Struct.unpack.__objclass__.__name__.__eq__,      ["Struct"], true, "Struct.unpack.__objclass__ is the Struct class (method_descriptor from _struct.c)"]
    - [pack_into_objclass,   Struct.pack_into.__objclass__.__name__.__eq__,   ["Struct"], true, "Struct.pack_into.__objclass__ is the Struct class (method_descriptor from _struct.c)"]
    - [unpack_from_objclass, Struct.unpack_from.__objclass__.__name__.__eq__, ["Struct"], true, "Struct.unpack_from.__objclass__ is the Struct class (method_descriptor from _struct.c)"]
    - [iter_unpack_objclass, Struct.iter_unpack.__objclass__.__name__.__eq__, ["Struct"], true, "Struct.iter_unpack.__objclass__ is the Struct class (method_descriptor from _struct.c)"]

# ---------------------------------------------------------------------------
# struct.__all__.__class__.__name__.__eq__('list') — standalone
#
# struct.__all__.__class__.__name__ is 'list'. struct defines __all__ as a list
# (not a tuple). This contrasts with hashlib.__all__ (a tuple with 19 entries).
# The choice of list vs. tuple for __all__ varies by module — struct uses a list,
# hashlib uses a tuple. The 8-entry list enumerates all public names exported
# by the struct module. No prior struct spec anchors __all__.__class__.__name__
# as a standalone under structall125. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra125.all_class_list:
  description: "struct.__all__.__class__.__name__.__eq__('list') == True — struct.__all__ is a list (not tuple, unlike hashlib.__all__ which is a tuple); 8-entry list enumerates all public struct names; no prior struct spec anchors __all__ class name as standalone; first standalone under structall125"
  category: module_all
  kind: python_call_eq
  function: "__all__.__class__.__name__.__eq__"
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__all__.__len__()==8 — standalone
#
# struct.__all__.__len__() is 8. The 8 entries are: 'calcsize', 'pack',
# 'pack_into', 'unpack', 'unpack_from', 'iter_unpack', 'Struct', 'error'.
# This covers 6 module-level functions plus the Struct class and the error
# exception. No private helpers, internal names, or format constants are
# included in __all__. No prior struct spec anchors __all__.__len__()==8 as
# a standalone under structall125. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra125.all_len_8:
  description: "struct.__all__.__len__() == 8 — __all__ has 8 entries: calcsize, pack, pack_into, unpack, unpack_from, iter_unpack, Struct, error (6 functions + 1 class + 1 exception); no private helpers or format constants included; no prior struct spec anchors __all__.__len__() as standalone; first standalone under structall125"
  category: module_all
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# struct.Struct.pack.__objclass__.__name__.__eq__('Struct') — standalone
#
# struct.Struct.pack.__objclass__.__name__ is 'Struct'. pack is a method_descriptor
# (C-level method from _struct.c). The __objclass__ attribute on a method_descriptor
# is the class that owns the descriptor — in this case, the Struct class. This
# confirms that pack is a genuine bound-to-Struct C method, not a standalone
# function. struct_extra93 anchors Struct.pack.__name__=='pack'; struct_extra92
# anchors Struct.pack.__class__.__name__=='method_descriptor'; no prior struct spec
# anchors Struct.pack.__objclass__.__name__ as a standalone under structall125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra125.Struct_pack_objclass_Struct:
  description: "struct.Struct.pack.__objclass__.__name__.__eq__('Struct') == True — Struct.pack is a method_descriptor from _struct.c; __objclass__ is the Struct class, confirming it is bound to the Struct type; extra93 anchors __name__=='pack'; extra92 anchors class=='method_descriptor'; first standalone for Struct.pack.__objclass__ under structall125"
  category: type_identity
  kind: python_call_eq
  function: Struct.pack.__objclass__.__name__.__eq__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__all__.__contains__('Struct') — standalone
#
# struct.__all__ contains 'Struct'. The Struct class is the central object of
# the struct module — it precompiles a format string for repeated use, avoiding
# the overhead of parsing the format string on every pack/unpack call. Its
# presence in __all__ confirms it is a primary public API entry point.
# struct_extra93 anchors Struct.__qualname__ and Struct.__module__; no prior
# struct spec anchors __all__.__contains__('Struct') as a standalone under
# structall125. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra125.all_contains_Struct:
  description: "struct.__all__.__contains__('Struct') == True — Struct is in the 8-entry __all__ list; it is the central struct module class providing compiled format string caching; extra93 anchors Struct.__qualname__/__module__; first standalone for __all__.__contains__('Struct') under structall125"
  category: module_all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__all__.__contains__('error') — standalone
#
# struct.__all__ contains 'error'. struct.error is the exception class raised
# when pack/unpack operations fail due to incompatible format strings or data.
# It is the last entry in the 8-element __all__ list. struct_extra93 anchors
# struct.error.__module__ and __qualname__; struct_extra91 anchors
# struct.error.__class__.__name__=='type'; no prior struct spec anchors
# __all__.__contains__('error') as a standalone under structall125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra125.all_contains_error:
  description: "struct.__all__.__contains__('error') == True — struct.error is in the 8-entry __all__ list as the last entry; it is the exception raised on pack/unpack failures; extra93 anchors error.__module__/__qualname__; extra91 anchors error class name; first standalone for __all__.__contains__('error') under structall125"
  category: module_all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["error"]
  expected: true
