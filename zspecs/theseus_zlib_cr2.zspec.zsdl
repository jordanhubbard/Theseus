spec: theseus_zlib_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_zlib_cr2)
blocks: zlib

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html"
    - "https://www.rfc-editor.org/rfc/rfc1950 — zlib format"
    - "https://www.rfc-editor.org/rfc/rfc1952 — gzip format"
  notes:
    - "Clean-room extended zlib utilities. Do NOT import zlib."
    - "adler32(data): compute Adler-32 checksum (uint32)."
    - "crc32(data): compute CRC-32 checksum (uint32)."
    - "compress(data, level=6) + decompress(data): already in theseus_zlib_cr."
    - "zlib2_adler32_hello(): adler32(b'hello') == 103547413."
    - "zlib2_crc32_hello(): crc32(b'hello') == 907060870."
    - "zlib2_adler32_empty(): adler32(b'') == 1."
    - "Export: adler32, crc32 (checksum functions returning unsigned int)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_zlib_cr2.adler32_hello:
  description: "adler32(b'hello') == 103547413"
  category: checksum
  kind: python_call_eq
  function: zlib2_adler32_hello
  args: []
  expected: 103547413

invariant theseus_zlib_cr2.crc32_hello:
  description: "crc32(b'hello') == 907060870"
  category: checksum
  kind: python_call_eq
  function: zlib2_crc32_hello
  args: []
  expected: 907060870

invariant theseus_zlib_cr2.adler32_empty:
  description: "adler32(b'') == 1"
  category: checksum
  kind: python_call_eq
  function: zlib2_adler32_empty
  args: []
  expected: 1
