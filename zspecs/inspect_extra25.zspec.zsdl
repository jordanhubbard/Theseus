spec: inspect_extra25
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra24.zspec.zsdl."
    - "Focus: __qualname__ and __module__ values for inspect.Parameter, Signature, FrameInfo, and BoundArguments in the extra25 namespace, plus Parameter.POSITIONAL_ONLY and FrameInfo._fields type metadata."
    - "inspect_extra24 covers module-level function qualnames (getmembers/getmro/getmodule/getfile/getsource/getsourcelines/getsourcefile/isclass/isfunction/ismethod) in a combined table."
    - "inspect_extra23 covers Parameter/Signature instance method qualnames (Parameter.__repr__/__eq__/__hash__/replace/__init__, Signature.__eq__/replace/__init__) and Parameter.empty sentinel qualname."
    - "inspect_extra7 covers Parameter.__qualname__.__eq__ and Signature.__qualname__.__eq__ as standalone invariants."
    - "No prior inspect spec has all four of Parameter/Signature/FrameInfo/BoundArguments together in a combined __qualname__ table in the extra25 namespace."
    - "No prior inspect spec has all four of Parameter/Signature/FrameInfo/BoundArguments together in a combined __module__ table in the extra25 namespace."
    - "No prior inspect spec records Parameter.POSITIONAL_ONLY.__class__.__qualname__ == '_ParameterKind' in any invariant or table."
    - "No prior inspect spec records FrameInfo._fields.__class__.__name__ == 'tuple' or len(FrameInfo._fields) == 6 in any invariant or table."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect class __qualname__ values — combined table
#
# Parameter, Signature, FrameInfo, and BoundArguments are all defined at
# module level in inspect; each has __qualname__ equal to its own class name.
# inspect_extra7 covers Parameter and Signature as standalone invariants.
# No prior inspect spec has all four together in a combined table in the
# extra25 namespace.
# ---------------------------------------------------------------------------

table inspect_extra25.class_qualnames:
  description: "__qualname__.__eq__ for inspect.Parameter, Signature, FrameInfo, BoundArguments"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Parameter,      Parameter.__qualname__.__eq__,      ["Parameter"],      true]
    - [Signature,      Signature.__qualname__.__eq__,      ["Signature"],      true]
    - [FrameInfo,      FrameInfo.__qualname__.__eq__,      ["FrameInfo"],      true]
    - [BoundArguments, BoundArguments.__qualname__.__eq__, ["BoundArguments"], true]

# ---------------------------------------------------------------------------
# inspect class __qualname__.__len__() — combined table
#
# Verifies the string length of each class __qualname__:
#   Parameter -> 9, Signature -> 9, FrameInfo -> 9, BoundArguments -> 14
# No prior inspect spec collects these four qualname lengths together in a
# single table in the extra25 namespace.
# ---------------------------------------------------------------------------

table inspect_extra25.class_qualname_lens:
  description: "__qualname__.__len__() for inspect.Parameter, Signature, FrameInfo, BoundArguments"
  kind: python_call_eq
  category: class_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [Parameter,      Parameter.__qualname__.__len__,      [],  9]
    - [Signature,      Signature.__qualname__.__len__,      [],  9]
    - [FrameInfo,      FrameInfo.__qualname__.__len__,      [],  9]
    - [BoundArguments, BoundArguments.__qualname__.__len__, [], 14]

# ---------------------------------------------------------------------------
# inspect class __module__ values — combined table
#
# Parameter, Signature, FrameInfo, and BoundArguments all have
# __module__ == 'inspect'. No prior inspect spec has all four together in
# a combined __module__ table in the extra25 namespace.
# ---------------------------------------------------------------------------

table inspect_extra25.class_modules:
  description: "__module__.__eq__ for inspect.Parameter, Signature, FrameInfo, BoundArguments"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Parameter,      Parameter.__module__.__eq__,      ["inspect"], true]
    - [Signature,      Signature.__module__.__eq__,      ["inspect"], true]
    - [FrameInfo,      FrameInfo.__module__.__eq__,      ["inspect"], true]
    - [BoundArguments, BoundArguments.__module__.__eq__, ["inspect"], true]

# ---------------------------------------------------------------------------
# inspect class __module__.__len__() — combined table
#
# All four __module__ strings equal 'inspect' which has length 7.
# No prior inspect spec collects these four module name lengths together
# in a single table in the extra25 namespace.
# ---------------------------------------------------------------------------

table inspect_extra25.class_module_lens:
  description: "__module__.__len__() for inspect.Parameter, Signature, FrameInfo, BoundArguments"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [Parameter,      Parameter.__module__.__len__,      [], 7]
    - [Signature,      Signature.__module__.__len__,      [], 7]
    - [FrameInfo,      FrameInfo.__module__.__len__,      [], 7]
    - [BoundArguments, BoundArguments.__module__.__len__, [], 7]

# ---------------------------------------------------------------------------
# inspect.Parameter.POSITIONAL_ONLY.__class__.__qualname__ == '_ParameterKind'
#
# Parameter.POSITIONAL_ONLY is a member of the internal _ParameterKind enum;
# its __class__.__qualname__ is '_ParameterKind'.
# No prior inspect spec records this attribute in any invariant or table.
# ---------------------------------------------------------------------------

invariant inspect_extra25.Parameter.POSITIONAL_ONLY_class_qualname:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__qualname__ == '_ParameterKind' — POSITIONAL_ONLY is a _ParameterKind enum member"
  category: sentinel_attrs
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__qualname__.__eq__
  args: ["_ParameterKind"]
  expected: true

# ---------------------------------------------------------------------------
# len(inspect.Parameter.POSITIONAL_ONLY.__class__.__qualname__) == 14
#
# len('_ParameterKind') == 14.
# No prior inspect spec records this length in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra25.Parameter.POSITIONAL_ONLY_class_qualname_len:
  description: "len(inspect.Parameter.POSITIONAL_ONLY.__class__.__qualname__) == 14 — len('_ParameterKind') == 14"
  category: sentinel_attr_lengths
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# inspect.FrameInfo._fields.__class__.__name__ == 'tuple' — standalone invariant
#
# FrameInfo is a named tuple; its _fields attribute is a plain tuple of strings.
# No prior inspect spec records FrameInfo._fields.__class__.__name__ in any invariant.
# ---------------------------------------------------------------------------

invariant inspect_extra25.FrameInfo.fields_class_name:
  description: "inspect.FrameInfo._fields.__class__.__name__ == 'tuple' — _fields is a plain tuple of field name strings"
  category: namedtuple_attrs
  kind: python_call_eq
  function: FrameInfo._fields.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# len(inspect.FrameInfo._fields) == 6 — standalone invariant
#
# FrameInfo has six fields: frame, filename, lineno, function, code_context, index.
# No prior inspect spec records len(FrameInfo._fields) in any invariant or table.
# ---------------------------------------------------------------------------

invariant inspect_extra25.FrameInfo.fields_len:
  description: "len(inspect.FrameInfo._fields) == 6 — FrameInfo has 6 named fields: frame/filename/lineno/function/code_context/index"
  category: namedtuple_attrs
  kind: python_call_eq
  function: FrameInfo._fields.__len__
  args: []
  expected: 6
