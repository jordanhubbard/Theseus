spec: hl3391
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 673 (hl3391): __int__, __float__, __complex__ dict-presence checks for hashlib types."
    - "Theme: __int__/__float__/__complex__ dict-presence (int(x), float(x), complex(x))."
    - "All values False — hashlib types are cryptographic hash objects with no numeric conversion support."
    - "type(hashlib.md5()), type(hashlib.sha1()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "None of the hashlib types define __int__, __float__, or __complex__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3391.int:
  description: "hashlib types __int__ dict-presence checks; wave 673"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: hl3391
  columns: [id, function, args, expected]
  rows:
    - ["hl3391001", operator.contains, [type(hashlib.md5()).__dict__,        "__int__"], false]
    - ["hl3391002", operator.contains, [type(hashlib.sha1()).__dict__,       "__int__"], false]
    - ["hl3391003", operator.contains, [type(hashlib.sha256()).__dict__,     "__int__"], false]
    - ["hl3391004", operator.contains, [type(hashlib.sha512()).__dict__,     "__int__"], false]
    - ["hl3391005", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__int__"], false]

