spec: threading_extra646
version: ">=3.9"
backend: python_module(threading)
docs: "Behavioral spec for threading.Event and threading.BoundedSemaphore method qualnames and identity checks."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__ and __module__ for threading.Event and threading.BoundedSemaphore, including method qualnames for set, clear, wait, is_set, __init__, acquire, and release."
  created_at: "2026-04-12T00:00:00Z"

table threading_extra646.event_identity:
  description: "Verify threading.Event class and method __qualname__ and __module__"
  kind: python_call_eq
  category: class_identity
  id_prefix: th646ev
  columns: [id, function, args, expected]
  rows:
    - [th646ev001, threading.Event.__qualname__.__eq__, ["Event"], true]
    - [th646ev002, threading.Event.__module__.__eq__, ["threading"], true]
    - [th646ev003, threading.Event.set.__qualname__.__eq__, ["Event.set"], true]
    - [th646ev004, threading.Event.clear.__qualname__.__eq__, ["Event.clear"], true]
    - [th646ev005, threading.Event.wait.__qualname__.__eq__, ["Event.wait"], true]
    - [th646ev006, threading.Event.is_set.__qualname__.__eq__, ["Event.is_set"], true]

table threading_extra646.bounded_semaphore_identity:
  description: "Verify threading.BoundedSemaphore class and method __qualname__, __module__, and __doc__ type"
  kind: python_call_eq
  category: class_identity
  id_prefix: th646sm
  columns: [id, function, args, expected]
  rows:
    - [th646sm001, threading.BoundedSemaphore.__qualname__.__eq__, ["BoundedSemaphore"], true]
    - [th646sm002, threading.BoundedSemaphore.__module__.__eq__, ["threading"], true]
    - [th646sm003, threading.BoundedSemaphore.__init__.__qualname__.__eq__, ["BoundedSemaphore.__init__"], true]
    - [th646sm004, threading.BoundedSemaphore.acquire.__qualname__.__eq__, ["BoundedSemaphore.acquire"], true]
    - [th646sm005, threading.BoundedSemaphore.release.__qualname__.__eq__, ["BoundedSemaphore.release"], true]
    - [th646sm006, threading.BoundedSemaphore.__doc__.__class__.__name__.__eq__, ["str"], true]
