spec: ssl_extra14
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "OpenSSL source"
  notes:
    - "This spec extends ssl.zspec.zsdl and prior extras through ssl_extra13.zspec.zsdl."
    - "ssl_extra13 covers: SSLContext.__bases__[0]/__mro__[1/2].__name__; SSLSocket.__bases__[0]/__mro__[2].__name__; PROTOCOL_TLS_SERVER.__class__.__name__; Purpose member class names."
    - "ssl_extra12 covers: SSLSyscallError/__qualname__; SSLEOFError/__qualname__; SSLZeroReturnError/__qualname__; SSLError/__mro__[1]; SSLSyscallError/__mro__[2]; SSLEOFError/__mro__[2]; SSLCertVerificationError/__mro__[2/3]; SSLWantReadError/__mro__[2]; SSLWantWriteError/__mro__[2]; SSLZeroReturnError/__mro__[2]."
    - "ssl_extra11 covers: TLSVersion name/value; VerifyMode name/value; AlertDescription/SSLErrorNumber values."
    - "ssl_extra10 covers: Purpose.__bases__/__module__/__qualname__; OP_NO_TLSv1/1_1/1_2; AlertDescription.ALERT_DESCRIPTION_CLOSE_NOTIFY.value; SSLErrorNumber.SSL_ERROR_SSL.value."
    - "ssl_extra9 covers: Protocol/__name__/__module__/__qualname__/__bases__; SSLWantReadError/SSLWantWriteError/SSLObject qualnames; AlertDescription/SSLErrorNumber qualnames; wrap_socket.__module__."
    - "ssl_extra7 covers: SSLSyscallError/__name__/__bases__/__module__; SSLEOFError/__name__/__bases__/__module__; CertificateError/__name__/__bases__/__module__."
    - "ssl.zspec.zsdl covers: SSLError/SSLContext/SSLSocket/SSLCertVerificationError class names; SSLError.__bases__[0] == OSError; CERT_NONE/CERT_OPTIONAL/CERT_REQUIRED values; HAS_SNI/HAS_ALPN type checks."
    - "No prior spec covers: SSLError.__mro__[0].__name__ == 'SSLError' (MRO self-check at index 0)."
    - "No prior spec covers: SSLError.__mro__[2].__name__ == 'Exception' (MRO depth 2)."
    - "No prior spec covers: SSLError.__mro__[3].__name__ == 'BaseException' (MRO depth 3)."
    - "No prior spec covers: SSLCertVerificationError.__bases__[0].__name__ == 'SSLError' (direct base)."
    - "No prior spec covers: SSLWantReadError.__name__ == 'SSLWantReadError' (base __name__ check)."
    - "No prior spec covers: SSLWantWriteError.__name__ == 'SSLWantWriteError' (base __name__ check)."
    - "No prior spec covers: SSLZeroReturnError.__name__ == 'SSLZeroReturnError' (base __name__ check)."
    - "No prior spec covers: SSLObject.__name__ == 'SSLObject' (class name)."
    - "No prior spec covers: SSLObject.__module__ == 'ssl'."
    - "ssl.SSLError.__mro__: [SSLError, OSError, Exception, BaseException, object] — ssl_extra12 checks mro[1] == OSError; indices 0/2/3 are new."
    - "SSLCertVerificationError directly inherits from SSLError (ssl_extra12 checks mro[2/3])."
    - "SSLWantReadError, SSLWantWriteError, SSLZeroReturnError are ssl_extra9/12 qualname targets; their __name__ is not checked in any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SSLError MRO — complete MRO coverage at indices 0, 2, and 3
#
# ssl_extra12 covers SSLError.__mro__[1].__name__ == 'OSError'.
# ssl.zspec.zsdl covers SSLError.__bases__[0].__name__ == 'OSError'.
# Indices 0 (self), 2 (Exception), and 3 (BaseException) are not yet covered.
# SSLError.__mro__: [SSLError, OSError, Exception, BaseException, object]
# ---------------------------------------------------------------------------

invariant ssl_extra14.SSLError.mro_index0:
  description: "ssl.SSLError.__mro__[0].__name__ == 'SSLError' — MRO self-check at index 0"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLError.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "SSLError"

invariant ssl_extra14.SSLError.mro_index2:
  description: "ssl.SSLError.__mro__[2].__name__ == 'Exception' — SSLError MRO depth 2"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLError.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Exception"

invariant ssl_extra14.SSLError.mro_index3:
  description: "ssl.SSLError.__mro__[3].__name__ == 'BaseException' — SSLError MRO depth 3"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLError.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "BaseException"

# ---------------------------------------------------------------------------
# SSLCertVerificationError — direct base class check
#
# ssl.zspec.zsdl covers SSLCertVerificationError.__name__ == 'SSLCertVerificationError'.
# ssl_extra12 covers SSLCertVerificationError.__mro__[2].__name__ == 'SSLError' and
#   SSLCertVerificationError.__mro__[3].__name__ == 'OSError'.
# No prior spec covers SSLCertVerificationError.__bases__[0].__name__ == 'SSLError'.
# ---------------------------------------------------------------------------

invariant ssl_extra14.SSLCertVerificationError.base_name:
  description: "ssl.SSLCertVerificationError.__bases__[0].__name__ == 'SSLError' — direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLCertVerificationError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "SSLError"

# ---------------------------------------------------------------------------
# SSLWantReadError, SSLWantWriteError, SSLZeroReturnError — __name__ checks
#
# ssl_extra9 covers __qualname__; ssl_extra12 covers __mro__[2].__name__.
# No prior spec checks the __name__ attribute of these three classes directly.
# ---------------------------------------------------------------------------

table ssl_extra14.ssl_subclass_names:
  description: "SSLWantReadError, SSLWantWriteError, SSLZeroReturnError class __name__ checks"
  kind: python_call_eq
  category: class_names
  id_prefix: subname

  columns: [id, function, args, expected]
  rows:
    - [SSLWantReadError,   SSLWantReadError.__name__.__eq__,   ["SSLWantReadError"],   true]
    - [SSLWantWriteError,  SSLWantWriteError.__name__.__eq__,  ["SSLWantWriteError"],  true]
    - [SSLZeroReturnError, SSLZeroReturnError.__name__.__eq__, ["SSLZeroReturnError"], true]

# ---------------------------------------------------------------------------
# SSLObject — class name and module
#
# ssl.SSLObject is the lightweight wrapper returned by SSLContext.wrap_bio().
# ssl_extra9 covers SSLObject.__qualname__. No prior spec checks __name__ or __module__.
# ---------------------------------------------------------------------------

invariant ssl_extra14.SSLObject.name:
  description: "ssl.SSLObject.__name__ == 'SSLObject'"
  category: class_names
  kind: python_call_eq
  function: SSLObject.__name__.__eq__
  args: ["SSLObject"]
  expected: true

invariant ssl_extra14.SSLObject.module:
  description: "ssl.SSLObject.__module__ == 'ssl'"
  category: modules
  kind: python_call_eq
  function: SSLObject.__module__.__eq__
  args: ["ssl"]
  expected: true

# ---------------------------------------------------------------------------
# HAS_SNI and HAS_ALPN — value checks (not just type checks)
#
# ssl.zspec.zsdl covers HAS_SNI/HAS_ALPN __class__.__name__ == 'bool' (type checks).
# No prior spec verifies the actual boolean value is True on modern Python/OpenSSL builds.
# On CPython 3.9+ with a modern OpenSSL, both HAS_SNI and HAS_ALPN are True.
# ---------------------------------------------------------------------------

invariant ssl_extra14.HAS_SNI.value:
  description: "ssl.HAS_SNI == True — SNI (Server Name Indication) is supported"
  category: constants
  kind: python_call_eq
  function: HAS_SNI.__eq__
  args: [true]
  expected: true

invariant ssl_extra14.HAS_ALPN.value:
  description: "ssl.HAS_ALPN == True — ALPN (Application-Layer Protocol Negotiation) is supported"
  category: constants
  kind: python_call_eq
  function: HAS_ALPN.__eq__
  args: [true]
  expected: true
