spec: concurrent_futures_extra295
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "concurrent.futures.FIRST_COMPLETED, FIRST_EXCEPTION, and ALL_COMPLETED are plain str constants (not enums)."
    - "wait.__module__ and as_completed.__module__ both resolve to 'concurrent.futures._base' (the private submodule)."
    - "concurrent.futures.__spec__.name == 'concurrent.futures' (the importlib ModuleSpec name)."
    - "All expected values verified by running Python 3.14.3 concurrent.futures module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module identity
# ---------------------------------------------------------------------------

invariant concurrent_futures.module.name:
  description: "concurrent.futures.__name__ == 'concurrent.futures'"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures.module.spec_name:
  description: "concurrent.futures.__spec__.name == 'concurrent.futures'"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["concurrent.futures"]
  expected: true

# ---------------------------------------------------------------------------
# wait — function identity
# ---------------------------------------------------------------------------

invariant concurrent_futures.wait.name:
  description: "concurrent.futures.wait.__name__ == 'wait'"
  category: wait
  kind: python_call_eq
  function: wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant concurrent_futures.wait.module:
  description: "concurrent.futures.wait.__module__ == 'concurrent.futures._base'"
  category: wait
  kind: python_call_eq
  function: wait.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

# ---------------------------------------------------------------------------
# as_completed — function identity
# ---------------------------------------------------------------------------

invariant concurrent_futures.as_completed.name:
  description: "concurrent.futures.as_completed.__name__ == 'as_completed'"
  category: as_completed
  kind: python_call_eq
  function: as_completed.__name__.__eq__
  args: ["as_completed"]
  expected: true

invariant concurrent_futures.as_completed.module:
  description: "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base'"
  category: as_completed
  kind: python_call_eq
  function: as_completed.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

# ---------------------------------------------------------------------------
# String constants — FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED
#
# These are plain str values, not enum members.
# ---------------------------------------------------------------------------

invariant concurrent_futures.constants.first_completed_class:
  description: "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: FIRST_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures.constants.first_exception_class:
  description: "concurrent.futures.FIRST_EXCEPTION.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: FIRST_EXCEPTION.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures.constants.all_completed_class:
  description: "concurrent.futures.ALL_COMPLETED.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: ALL_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures.constants.first_completed_value:
  description: "concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED') == True"
  category: constants
  kind: python_call_eq
  function: FIRST_COMPLETED.__eq__
  args: ["FIRST_COMPLETED"]
  expected: true
