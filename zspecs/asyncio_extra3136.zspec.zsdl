spec: as3136
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 656 (as3136): __call__, __len__, __getitem__ dict-presence for asyncio types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: asyncio.Task, asyncio.Future, asyncio.Queue, asyncio.Event, asyncio.Semaphore, asyncio.Lock, asyncio.Condition, asyncio.BoundedSemaphore, asyncio.Handle, asyncio.TimerHandle, asyncio.Timeout, asyncio.TaskGroup, asyncio.StreamReader, asyncio.StreamWriter."
    - "Key finding (__call__): all 14 asyncio classes return false for __call__. None define __call__ in their own __dict__. asyncio primitives are not callable objects — they are managed via await and async-with syntax, not via direct call. Even asyncio.Handle (which exposes a cancel() method) does not define __call__; its execution is driven by the event loop, not by calling the handle directly."
    - "Key finding (__len__): all 14 asyncio classes return false for __len__. asyncio.Queue does NOT define __len__ in its __dict__; the qsize() method is the way to query queue length — there is no __len__ shortcut. Similarly asyncio.Semaphore, Lock, and Condition do not expose a size protocol."
    - "Key finding (__getitem__): all 14 asyncio classes return false for __getitem__. No asyncio type supports subscript access via [] in its own __dict__. asyncio is concerned with concurrency primitives, not with container indexing."
    - "asyncio.Queue.qsize() exists and returns the current queue size, but __len__ is deliberately absent — the asyncio maintainers chose not to alias qsize to __len__, keeping the API explicit."
    - "asyncio.Handle.__call__ is absent: handles are not designed as callables from user code. The event loop invokes the underlying callback directly; users interact with handles only through cancel() and cancelled()."
    - "asyncio.Timeout (added in 3.11) defines __aenter__ and __aexit__ (confirmed in earlier waves) but no __call__, __len__, or __getitem__."
    - "asyncio.TaskGroup likewise defines only async-context-manager protocol; none of the three methods in this wave are present."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __call__ dict-presence — operator.contains(Cls.__dict__, '__call__')
#
# All 14 asyncio classes return false for __call__.
# asyncio objects use the coroutine/await protocol, not the callable protocol.
# asyncio.Handle does not expose __call__ — the event loop drives it internally.
# asyncio.Semaphore and Lock are async context managers (not callables).
# asyncio.Queue, Event, Condition, BoundedSemaphore, Timeout, TaskGroup,
# StreamReader, and StreamWriter: none define __call__ in their own __dict__.
# ---------------------------------------------------------------------------

table as3136.call:
  description: "asyncio types __call__ dict-presence checks; wave 656"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: as3136

  columns: [id, function, args, expected]
  rows:
