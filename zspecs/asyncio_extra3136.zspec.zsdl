    - ["as3136014", operator.contains, [asyncio.StreamWriter.__dict__,     "__call__"], false]

# ---------------------------------------------------------------------------
# __len__ dict-presence — operator.contains(Cls.__dict__, '__len__')
#
# All 14 asyncio classes return false for __len__.
# asyncio.Queue does NOT define __len__ — use qsize() to query current size.
# The asyncio maintainers chose to keep the API explicit rather than adding
# a len() shortcut that could be misread as a synchronous snapshot.
# No other asyncio type has size semantics at all.
# ---------------------------------------------------------------------------

