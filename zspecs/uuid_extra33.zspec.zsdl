spec: uuid_extra33
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra32.zspec.zsdl — covers UUID.__str__.__name__.__eq__('__str__') and __module__.__eq__('uuid'); RFC_4122.__class__.__module__.__eq__('builtins')."
    - "uuid_extra31.zspec.zsdl — covers RESERVED_NCS/MICROSOFT/FUTURE __len__(); getnode __name__/__qualname__.__eq__."
    - "uuid_extra30.zspec.zsdl — covers UUID.__name__/__module__ string eq; UUID.__bases__[0].__name__.__eq__('object'); uuid1/3/4/5 __name__ string eq; NAMESPACE_DNS.__class__.__name__.__eq__('UUID')."
    - "uuid_extra22.zspec.zsdl — covers UUID.__str__.__qualname__.__len__()==12."
    - "uuid_extra21.zspec.zsdl — covers UUID.__init__.__qualname__.__len__()==13 and UUID.__init__.__module__.__len__()==4."
    - "uuid_extra20.zspec.zsdl — covers uuid3/4/5/1 __qualname__.__eq__; UUID.__init__.__qualname__.__eq__('UUID.__init__')."
    - "uuid_extra16.zspec.zsdl — covers UUID.__str__.__qualname__.__eq__('UUID.__str__') and UUID.__init__.__qualname__.__eq__('UUID.__init__')."
  notes:
    - "This spec extends uuid through uuid_extra32; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: uuid_extra16 covers UUID.__str__.__qualname__.__eq__('UUID.__str__') and uuid_extra20 covers UUID.__init__.__qualname__.__eq__('UUID.__init__'). But NO prior spec checks UUID.__repr__.__qualname__, UUID.__hash__.__qualname__, UUID.__eq__.__qualname__, or UUID.__int__.__qualname__. These are all Python methods defined in Lib/uuid.py and follow the 'UUID.<method>' qualname pattern. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__'. Python method defined in Lib/uuid.py; qualname is class-prefixed. No prior uuid spec checks UUID.__repr__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__'. uuid.UUID defines its own __hash__ method (not inherited from object). No prior uuid spec checks UUID.__hash__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__'. UUID defines __eq__ for value comparison. No prior uuid spec checks UUID.__eq__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__qualname__ == 'UUID.__int__'. UUID defines __int__ to return the integer value of the UUID. No prior uuid spec checks UUID.__int__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior uuid spec checks UUID.hex.fget.__qualname__. The hex attribute is a property on UUID (returns the UUID as a 32-character hex string). As a property, uuid.UUID.hex.fget is the getter function with __qualname__ == 'UUID.hex'. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__qualname__ == 'UUID.hex'. uuid.UUID.hex is a property; its fget function has qualname 'UUID.hex'. No prior uuid spec accesses .hex.fget or checks __qualname__ for any UUID property getter. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID dunder method __qualname__ string eq checks
#
# uuid_extra16 covers UUID.__str__.__qualname__.__eq__('UUID.__str__').
# uuid_extra20 covers UUID.__init__.__qualname__.__eq__('UUID.__init__').
# No prior spec checks UUID.__repr__/__hash__/__eq__/__int__ __qualname__.__eq__.
# All are Python methods in Lib/uuid.py with 'UUID.<method>' qualname pattern.
# ---------------------------------------------------------------------------

table uuid_extra33.UUID_dunder_qualname_eq:
  description: "uuid.UUID.__repr__/__hash__/__eq__/__int__ __qualname__.__eq__ string values — novel: extra16 covers UUID.__str__.__qualname__.__eq__; extra20 covers UUID.__init__.__qualname__.__eq__; no prior spec checks __repr__/__hash__/__eq__/__int__ __qualname__.__eq__ for UUID"
  kind: python_call_eq
  category: function_names
  id_prefix: udqe33

  columns: [id, function, args, expected]
  rows:
    - [repr_qualname_eq, "UUID.__repr__.__qualname__.__eq__", ["UUID.__repr__"], true]
    - [hash_qualname_eq, "UUID.__hash__.__qualname__.__eq__", ["UUID.__hash__"], true]
    - [eq_qualname_eq,   "UUID.__eq__.__qualname__.__eq__",   ["UUID.__eq__"],   true]
    - [int_qualname_eq,  "UUID.__int__.__qualname__.__eq__",  ["UUID.__int__"],  true]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__qualname__ check
#
# uuid.UUID.hex is a property. No prior uuid spec accesses .hex.fget or
# checks __qualname__ for any UUID property getter.
# uuid.UUID.hex.fget.__qualname__ == 'UUID.hex' (not 'UUID.hex.fget').
# ---------------------------------------------------------------------------

invariant uuid_extra33.UUID_hex_fget_qualname_eq:
  description: "uuid.UUID.hex.fget.__qualname__ == 'UUID.hex' — hex is a property; fget is the getter function with qualname 'UUID.hex'; novel: no prior uuid spec checks any UUID property fget or UUID.hex.fget.__qualname__"
  category: function_names
  kind: python_call_eq
  function: "UUID.hex.fget.__qualname__.__eq__"
  args: ["UUID.hex"]
  expected: true
