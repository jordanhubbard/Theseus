spec: cf3166
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 658 (cf3166): __add__, __sub__, __mul__ dict-presence for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor, concurrent.futures.Executor."
    - "Key finding (__add__): all 4 concurrent.futures classes return false for __add__. No class defines addition or concatenation in its own __dict__. concurrent.futures.Future is a result container for a single pending computation — future + future is not a defined operation. ThreadPoolExecutor and ProcessPoolExecutor are pool managers: work is submitted via submit()/map(), not combined with +. Executor is an abstract base with no arithmetic semantics."
    - "Key finding (__sub__): all 4 concurrent.futures classes return false for __sub__. Subtraction is not defined for any concurrent.futures type. There is no concept of removing work from an executor via -. Future encapsulates one result — future - future is semantically undefined. Executor.shutdown() terminates the pool, but that is not subtraction."
    - "Key finding (__mul__): all 4 concurrent.futures classes return false for __mul__. Multiplication is not defined for any concurrent.futures type. ThreadPoolExecutor/ProcessPoolExecutor do not support executor * n for pool replication. Future does not define repetition. Executor is abstract with no arithmetic interface."
    - "This is the sixth consecutive all-false wave for all 4 concurrent.futures subjects (every dunder since wave 652 has been false for all subjects, with the sole exception of Future.__repr__ in wave 655). The concurrent.futures API is deliberately minimal: submit work, await results, shut down. No arithmetic, sequence, or collection protocol is part of its design."
    - "Cross-wave summary for cf subjects:"
    - "  Wave 652 (cf3076): __get__/__set__/__delete__ — all false for all 4."
    - "  Wave 653 (cf3091): __hash__/__eq__/__bool__ — all false for all 4."
    - "  Wave 654 (cf3106): __lt__/__le__/__gt__ — all false for all 4."
    - "  Wave 655 (cf3121): __ge__ false; __repr__ true only for Future; __str__ false."
    - "  Wave 656 (cf3136): __call__/__len__/__getitem__ — all false for all 4."
    - "  Wave 657 (cf3151): __setitem__/__delitem__/__contains__ — all false for all 4."
    - "  Wave 658 (cf3166): __add__/__sub__/__mul__ — all false for all 4."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __add__ dict-presence — operator.contains(Cls.__dict__, '__add__')
#
# All 4 concurrent.futures classes return false for __add__.
# concurrent.futures.Future: holds a single pending result; future + future
#   is not a defined operation. Results are retrieved via result()/exception().
# ThreadPoolExecutor/ProcessPoolExecutor: worker pool managers dispatching
#   callables via submit()/map(); no concatenation protocol.
# Executor: abstract base class; no arithmetic interface.
# ---------------------------------------------------------------------------

table cf3166.add:
  description: "concurrent.futures types __add__ dict-presence checks; wave 658"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3166

  columns: [id, function, args, expected]
  rows:
    - ["cf3166001", operator.contains, [concurrent.futures.Future.__dict__,              "__add__"], false]
    - ["cf3166002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__add__"], false]
    - ["cf3166003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__add__"], false]
    - ["cf3166004", operator.contains, [concurrent.futures.Executor.__dict__,            "__add__"], false]

# ---------------------------------------------------------------------------
# __sub__ dict-presence — operator.contains(Cls.__dict__, '__sub__')
#
# All 4 concurrent.futures classes return false for __sub__.
# concurrent.futures.Future: a single-result container; subtraction is not
#   meaningful. Cancellation uses cancel(), not -.
# ThreadPoolExecutor/ProcessPoolExecutor: pool shutdown uses shutdown(), not -.
#   There is no concept of reducing a pool via subtraction.
# Executor: abstract base; no arithmetic protocol.
# ---------------------------------------------------------------------------

table cf3166.sub:
  description: "concurrent.futures types __sub__ dict-presence checks; wave 658"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3166

  columns: [id, function, args, expected]
  rows:
    - ["cf3166005", operator.contains, [concurrent.futures.Future.__dict__,              "__sub__"], false]
    - ["cf3166006", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__sub__"], false]
    - ["cf3166007", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__sub__"], false]
    - ["cf3166008", operator.contains, [concurrent.futures.Executor.__dict__,            "__sub__"], false]

# ---------------------------------------------------------------------------
# __mul__ dict-presence — operator.contains(Cls.__dict__, '__mul__')
#
# All 4 concurrent.futures classes return false for __mul__.
# concurrent.futures.Future: wraps one computation; future * n is undefined.
# ThreadPoolExecutor/ProcessPoolExecutor: thread/process count is set at
#   construction time (max_workers); no runtime replication via *.
# Executor: abstract base; no arithmetic protocol.
# ---------------------------------------------------------------------------

table cf3166.mul:
  description: "concurrent.futures types __mul__ dict-presence checks; wave 658"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3166

  columns: [id, function, args, expected]
  rows:
    - ["cf3166009",  operator.contains, [concurrent.futures.Future.__dict__,              "__mul__"], false]
    - ["cf3166010", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__mul__"], false]
    - ["cf3166011", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__mul__"], false]
    - ["cf3166012", operator.contains, [concurrent.futures.Executor.__dict__,            "__mul__"], false]

# ---------------------------------------------------------------------------
# combined — __add__, __sub__, __mul__ across all 4 cf subjects
#
# Covers the full matrix: 4 classes x 3 methods = 12 rows.
# __add__: false for all 4.
# __sub__: false for all 4.
# __mul__: false for all 4.
# All 12 values are false.
# concurrent.futures maintains its all-false streak across arithmetic operators.
# The design of concurrent.futures is deliberately narrow: submit work, retrieve
# results, shut down. No arithmetic, sequence, or collection protocol is offered.
# Future.__repr__ (wave 655) remains the only non-false result across all waves
# for any concurrent.futures subject.
# Cross-wave summary for cf subjects:
#   Wave 652 (cf3076): __get__/__set__/__delete__ — all false for all 4.
#   Wave 653 (cf3091): __hash__/__eq__/__bool__ — all false for all 4.
#   Wave 654 (cf3106): __lt__/__le__/__gt__ — all false for all 4.
#   Wave 655 (cf3121): __ge__ false; __repr__ true only for Future; __str__ false.
#   Wave 656 (cf3136): __call__/__len__/__getitem__ — all false for all 4.
#   Wave 657 (cf3151): __setitem__/__delitem__/__contains__ — all false for all 4.
#   Wave 658 (cf3166): __add__/__sub__/__mul__ — all false for all 4.
# ---------------------------------------------------------------------------

