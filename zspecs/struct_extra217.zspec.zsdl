invariant struct_extra217.pack_qualname_eq:
  description: "struct.pack.__qualname__.__eq__('pack') == True — struct.pack is a module-level C builtin function; its qualname equals its name 'pack'; packs values into binary data according to a format string; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "struct.pack.__qualname__.__eq__"
  args: ["pack"]
  expected: true

invariant struct_extra217.Struct_qualname_eq:
  description: "struct.Struct.__qualname__.__eq__('Struct') == True — struct.Struct is a C-level class; its qualname is 'Struct'; used to pre-compile format strings for repeated pack/unpack operations; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "struct.Struct.__qualname__.__eq__"
  args: ["Struct"]
  expected: true

invariant struct_extra217.Struct_pack_qualname_eq:
  description: "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — Struct.pack is a C-level builtin method descriptor; qualified name 'Struct.pack' correctly names the class and method; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "struct.Struct.pack.__qualname__.__eq__"
  args: ["Struct.pack"]
  expected: true

invariant struct_extra217.Struct_unpack_from_qualname_eq:
  description: "struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') == True — Struct.unpack_from is a C-level builtin method descriptor; unpacks from buffer at given offset without consuming the entire buffer; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "struct.Struct.unpack_from.__qualname__.__eq__"
  args: ["Struct.unpack_from"]
  expected: true

invariant struct_extra217.Struct_iter_unpack_qualname_eq:
  description: "struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack') == True — Struct.iter_unpack is a C-level builtin method descriptor; iteratively unpacks from a buffer; same length as unpack_from (18 chars); verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "struct.Struct.iter_unpack.__qualname__.__eq__"
  args: ["Struct.iter_unpack"]
  expected: true

