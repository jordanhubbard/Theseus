spec: functools_extra410
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.0 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.lru_cache.__doc__.__len__() == 743 — lru_cache is a Python function with a docstring of 743 characters. Verified with Python 3.14.0."
    - "functools.singledispatch.__doc__.__len__() == 339 — singledispatch is a Python function with a docstring of 339 characters. Verified with Python 3.14.0."
    - "functools.wraps.__doc__.__len__() == 356 — wraps is a Python function with a docstring of 356 characters. Verified with Python 3.14.0."
    - "functools.reduce.__doc__.__len__() == 389 — reduce is a built-in function with a docstring of 389 characters. Verified with Python 3.14.0."
    - "All expected values verified by running Python 3.14.0 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools function docstring lengths
#
# functools.lru_cache, functools.singledispatch, functools.wraps, and
# functools.reduce all carry non-empty docstrings. The __len__() method
# on the str docstring returns the character count. All values verified
# with Python 3.14.0 on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table functools_extra410.function_doc_len:
  description: "functools function __doc__.__len__() values — non-empty docstrings on lru_cache, singledispatch, wraps, reduce; new to extra410"
  kind: python_call_eq
  category: introspection
  id_prefix: functoolsdl410

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_doc_len_eq,
       "lru_cache.__doc__.__len__",
       [],
       743,
       "functools.lru_cache.__doc__.__len__() == 743 — lru_cache carries a 743-character docstring; __len__() returns 743; new to extra410"]
    - [singledispatch_doc_len_eq,
       "singledispatch.__doc__.__len__",
       [],
       339,
       "functools.singledispatch.__doc__.__len__() == 339 — singledispatch carries a 339-character docstring; __len__() returns 339; new to extra410"]
    - [wraps_doc_len_eq,
       "wraps.__doc__.__len__",
       [],
       356,
       "functools.wraps.__doc__.__len__() == 356 — wraps carries a 356-character docstring; __len__() returns 356; new to extra410"]
    - [reduce_doc_len_eq,
       "reduce.__doc__.__len__",
       [],
       389,
       "functools.reduce.__doc__.__len__() == 389 — reduce carries a 389-character docstring; __len__() returns 389; new to extra410"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra410
# ---------------------------------------------------------------------------

invariant functools_extra410.lru_cache_doc_len:
  description: "functools.lru_cache.__doc__.__len__() == 743 — non-empty docstring on lru_cache; new to extra410"
  kind: python_call_eq
  function: lru_cache.__doc__.__len__
  args: []
  expected: 743

invariant functools_extra410.singledispatch_doc_len:
  description: "functools.singledispatch.__doc__.__len__() == 339 — non-empty docstring on singledispatch; new to extra410"
  kind: python_call_eq
  function: singledispatch.__doc__.__len__
  args: []
  expected: 339

invariant functools_extra410.wraps_doc_len:
  description: "functools.wraps.__doc__.__len__() == 356 — non-empty docstring on wraps; new to extra410"
  kind: python_call_eq
  function: wraps.__doc__.__len__
  args: []
  expected: 356

invariant functools_extra410.reduce_doc_len:
  description: "functools.reduce.__doc__.__len__() == 389 — non-empty docstring on reduce; new to extra410"
  kind: python_call_eq
  function: reduce.__doc__.__len__
  args: []
  expected: 389
