spec: io_extra243
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/textio.c"
    - "CPython source: Modules/_io/_iomodule.c"
    - "_io_extra.zspec.zsdl — covers TextIOWrapper/__name__, TextIOWrapper/__module__, TextIOWrapper/__class__/__name__"
  notes:
    - "This spec covers: io.TextIOWrapper class identity contracts — __name__, __module__, __qualname__, __bases__, __class__, and method name/qualname checks."
    - "io.TextIOWrapper is the C class for wrapping a binary stream as text; its __module__ is '_io' (C extension), not 'io'."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' — the class name is 13 characters; verified Python 3.14.3 macOS."
    - "io.TextIOWrapper.__module__ == '_io' — defined in the C extension, length 3; verified Python 3.14.3 macOS."
    - "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — matches __name__ for a top-level class; verified Python 3.14.3 macOS."
    - "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — the immediate base class is _TextIOBase; verified Python 3.14.3 macOS."
    - "io.TextIOWrapper.__class__.__name__ == 'type' — TextIOWrapper is a class object, not an instance; verified Python 3.14.3 macOS."
    - "io.TextIOWrapper.read.__name__ == 'read' — the read method name is 'read', length 4; verified Python 3.14.3 macOS."
    - "io.TextIOWrapper.write.__name__ == 'write' — the write method name is 'write', length 5; verified Python 3.14.3 macOS."
    - "io.TextIOWrapper.readline.__name__ == 'readline' — the readline method name is 'readline', length 8; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.TextIOWrapper class name and module identity contracts
# These verify the class object's identity attributes from the io module.
# io.TextIOWrapper is re-exported from _io (C extension).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra243.TextIOWrapper.name_eq:
  description: "io.TextIOWrapper.__name__ == 'TextIOWrapper' — C class name is 'TextIOWrapper'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra243.TextIOWrapper.name_len:
  description: "len(io.TextIOWrapper.__name__) == 13 — 'TextIOWrapper' has 13 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__name__.__len__
  args: []
  expected: 13

invariant io_extra243.TextIOWrapper.module_eq:
  description: "io.TextIOWrapper.__module__ == '_io' — TextIOWrapper is defined in the C extension _io, not in io.py; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra243.TextIOWrapper.module_len:
  description: "len(io.TextIOWrapper.__module__) == 3 — '_io' has 3 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__module__.__len__
  args: []
  expected: 3

invariant io_extra243.TextIOWrapper.qualname_eq:
  description: "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — qualname matches __name__ for a top-level class; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__qualname__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra243.TextIOWrapper.qualname_len:
  description: "len(io.TextIOWrapper.__qualname__) == 13 — 'TextIOWrapper' has 13 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__qualname__.__len__
  args: []
  expected: 13

invariant io_extra243.TextIOWrapper.class_is_type:
  description: "io.TextIOWrapper.__class__.__name__ == 'type' — TextIOWrapper is a class object (its metaclass is type); verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# io.TextIOWrapper.__bases__[0].__name__ identity contract
# The immediate base class of TextIOWrapper is _TextIOBase.
# Accessed via __bases__.__getitem__(0).__name__.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra243.TextIOWrapper.base_name:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — immediate base class of TextIOWrapper; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_TextIOBase"

# ---------------------------------------------------------------------------
# io.TextIOWrapper method name identity contracts
# read, write, and readline are the three primary I/O methods.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra243.TextIOWrapper.read.name_eq:
  description: "io.TextIOWrapper.read.__name__ == 'read' — method name is 'read'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: TextIOWrapper.read.__name__.__eq__
  args: ["read"]
  expected: true

invariant io_extra243.TextIOWrapper.write.name_eq:
  description: "io.TextIOWrapper.write.__name__ == 'write' — method name is 'write'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: TextIOWrapper.write.__name__.__eq__
  args: ["write"]
  expected: true

invariant io_extra243.TextIOWrapper.readline.name_eq:
  description: "io.TextIOWrapper.readline.__name__ == 'readline' — method name is 'readline'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: TextIOWrapper.readline.__name__.__eq__
  args: ["readline"]
  expected: true

# ---------------------------------------------------------------------------
# io.TextIOWrapper method name length spot-checks
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra243.TextIOWrapper_method_name_lengths:
  description: "io.TextIOWrapper method __name__ lengths; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: iotextio243

  columns: [id, function, args, expected]
  rows:
    - [read_len,     TextIOWrapper.read.__name__.__len__,     [], 4]
    - [write_len,    TextIOWrapper.write.__name__.__len__,    [], 5]
    - [readline_len, TextIOWrapper.readline.__name__.__len__, [], 8]
