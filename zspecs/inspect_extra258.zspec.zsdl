spec: inspect_extra258
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getmembers, inspect.isclass, inspect.isfunction, inspect.ismethod function identity — name, qualname, module, class name."
    - "inspect.getmembers.__name__ == 'getmembers' — Python function name. Verified with Python 3.14.4."
    - "inspect.getmembers.__qualname__ == 'getmembers' — top-level function; qualname equals name. Verified with Python 3.14.4."
    - "inspect.getmembers.__module__ == 'inspect' — defined in inspect. Verified with Python 3.14.4."
    - "inspect.getmembers.__class__.__name__ == 'function' — it is a Python function (not a C builtin). Verified with Python 3.14.4."
    - "inspect.isclass.__name__ == 'isclass' — Python function name. Verified with Python 3.14.4."
    - "inspect.isclass.__qualname__ == 'isclass' — top-level function; qualname equals name. Verified with Python 3.14.4."
    - "inspect.isclass.__module__ == 'inspect' — defined in inspect. Verified with Python 3.14.4."
    - "inspect.isfunction.__name__ == 'isfunction' — Python function name. Verified with Python 3.14.4."
    - "inspect.isfunction.__qualname__ == 'isfunction' — top-level function; qualname equals name. Verified with Python 3.14.4."
    - "inspect.ismethod.__name__ == 'ismethod' — Python function name. Verified with Python 3.14.4."
    - "inspect.ismethod.__qualname__ == 'ismethod' — top-level function; qualname equals name. Verified with Python 3.14.4."
    - "inspect.isbuiltin.__name__ == 'isbuiltin' — Python function name. Verified with Python 3.14.4."
    - "inspect.isbuiltin.__qualname__ == 'isbuiltin' — top-level function; qualname equals name. Verified with Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getmembers function identity contracts
#
# inspect.getmembers.__name__              == 'getmembers'
# inspect.getmembers.__qualname__          == 'getmembers'
# inspect.getmembers.__module__            == 'inspect'
# inspect.getmembers.__class__.__name__    == 'function'
# inspect.getmembers.__qualname__.__class__.__name__ == 'str'
#
# getmembers is a Python function. New to extra258.
# ---------------------------------------------------------------------------

table inspect_extra258.getmembers_identity:
  description: "inspect.getmembers name, qualname, module, class contracts; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: ingm258

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_name_eq,
       getmembers.__name__.__eq__,
       ["getmembers"],
       true,
       "inspect.getmembers.__name__.__eq__('getmembers') == True — Python function name; new to extra258"]
    - [getmembers_qualname_eq,
       getmembers.__qualname__.__eq__,
       ["getmembers"],
       true,
       "inspect.getmembers.__qualname__.__eq__('getmembers') == True — top-level function; qualname equals name; new to extra258"]
    - [getmembers_module_eq,
       getmembers.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getmembers.__module__.__eq__('inspect') == True — defined in inspect; new to extra258"]
    - [getmembers_class_name_eq,
       getmembers.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getmembers.__class__.__name__.__eq__('function') == True — it is a Python function; new to extra258"]
    - [getmembers_qualname_class_eq,
       getmembers.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.getmembers.__qualname__.__class__.__name__.__eq__('str') == True — __qualname__ is a str; new to extra258"]

# ---------------------------------------------------------------------------
# Table 2: inspect.isclass and inspect.isfunction identity contracts
#
# inspect.isclass.__name__     == 'isclass'
# inspect.isclass.__qualname__ == 'isclass'
# inspect.isclass.__module__   == 'inspect'
# inspect.isfunction.__name__     == 'isfunction'
# inspect.isfunction.__qualname__ == 'isfunction'
#
# New to extra258.
# ---------------------------------------------------------------------------

table inspect_extra258.isclass_isfunction_identity:
  description: "inspect.isclass and inspect.isfunction name, qualname, module contracts; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: incf258

  columns: [id, function, args, expected, description]
  rows:
    - [isclass_name_eq,
       isclass.__name__.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__name__.__eq__('isclass') == True — Python function name; new to extra258"]
    - [isclass_qualname_eq,
       isclass.__qualname__.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__qualname__.__eq__('isclass') == True — top-level function; qualname equals name; new to extra258"]
    - [isclass_module_eq,
       isclass.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isclass.__module__.__eq__('inspect') == True — defined in inspect; new to extra258"]
    - [isfunction_name_eq,
       isfunction.__name__.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__name__.__eq__('isfunction') == True — Python function name; new to extra258"]
    - [isfunction_qualname_eq,
       isfunction.__qualname__.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__qualname__.__eq__('isfunction') == True — top-level function; qualname equals name; new to extra258"]

# ---------------------------------------------------------------------------
# Table 3: inspect.ismethod and inspect.isbuiltin identity contracts
#
# inspect.ismethod.__name__     == 'ismethod'
# inspect.ismethod.__qualname__ == 'ismethod'
# inspect.isbuiltin.__name__     == 'isbuiltin'
# inspect.isbuiltin.__qualname__ == 'isbuiltin'
# inspect.isbuiltin.__module__   == 'inspect'
#
# New to extra258.
# ---------------------------------------------------------------------------

table inspect_extra258.ismethod_isbuiltin_identity:
  description: "inspect.ismethod and inspect.isbuiltin name, qualname, module contracts; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: inmb258

  columns: [id, function, args, expected, description]
  rows:
    - [ismethod_name_eq,
       ismethod.__name__.__eq__,
       ["ismethod"],
       true,
       "inspect.ismethod.__name__.__eq__('ismethod') == True — Python function name; new to extra258"]
    - [ismethod_qualname_eq,
       ismethod.__qualname__.__eq__,
       ["ismethod"],
       true,
       "inspect.ismethod.__qualname__.__eq__('ismethod') == True — top-level function; qualname equals name; new to extra258"]
    - [isbuiltin_name_eq,
       isbuiltin.__name__.__eq__,
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__name__.__eq__('isbuiltin') == True — Python function name; new to extra258"]
    - [isbuiltin_qualname_eq,
       isbuiltin.__qualname__.__eq__,
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__qualname__.__eq__('isbuiltin') == True — top-level function; qualname equals name; new to extra258"]
    - [isbuiltin_module_eq,
       isbuiltin.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isbuiltin.__module__.__eq__('inspect') == True — defined in inspect; new to extra258"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra258
# ---------------------------------------------------------------------------

invariant inspect_extra258.getmembers.name_eq:
  description: "inspect.getmembers.__name__ == 'getmembers' — Python function name; new to extra258"
  category: identity
  kind: python_call_eq
  function: getmembers.__name__.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra258.getmembers.qualname_eq:
  description: "inspect.getmembers.__qualname__ == 'getmembers' — top-level function; qualname equals name; new to extra258"
  category: identity
  kind: python_call_eq
  function: getmembers.__qualname__.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra258.getmembers.module_eq:
  description: "inspect.getmembers.__module__ == 'inspect' — defined in inspect; new to extra258"
  category: identity
  kind: python_call_eq
  function: getmembers.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra258.getmembers.class_is_function:
  description: "inspect.getmembers.__class__.__name__ == 'function' — it is a Python function; new to extra258"
  category: identity
  kind: python_call_eq
  function: getmembers.__class__.__name__.__eq__
  args: ["function"]
  expected: true

