spec: re_extra37
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra36.zspec.zsdl — covers Match.expand/groupdict __qualname__.__len__(); RegexFlag member .name.__len__() for IGNORECASE/MULTILINE/DOTALL/VERBOSE/ASCII/UNICODE/NOFLAG."
    - "re_extra34.zspec.zsdl — covers module-level function __qualname__.__len__() for compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape/purge."
    - "re_extra32.zspec.zsdl — covers Pattern method __qualname__.__len__() for match/search/findall/sub/split/fullmatch/finditer/subn; Match method __qualname__.__len__() for group/groups/span/start/end."
  notes:
    - "This spec extends re_extra36.zspec.zsdl."
    - "Prior specs covered: all Pattern/Match/__name__/__module__/__qualname__ and their lengths; all public function __name__/__module__/__qualname__/__qualname__.__len__(); error/__name__/__module__/__qualname__/__bases__; RegexFlag attributes; IGNORECASE/MULTILINE/DOTALL/VERBOSE values and class names; Pattern/Match method __qualname__.__len__() for all main methods (re_extra32); module-level function __qualname__.__len__() (re_extra34); Match.expand/groupdict __qualname__.__len__() (re_extra36); RegexFlag member .name lengths (re_extra36)."
    - "This spec covers: Pattern member_descriptor attribute __qualname__.__len__() for pattern(15)/flags(13)/groups(14)/groupindex(18) (NOVEL — no prior re spec checks __qualname__.__len__() for any Pattern descriptor attribute; prior specs check Pattern method qualname lengths but not attribute/descriptor qualname lengths); Match member_descriptor attribute __qualname__.__len__() for string(12)/re(8)/pos(9)/endpos(12)/lastindex(15)/lastgroup(15) (NOVEL — no prior re spec checks __qualname__.__len__() for any Match descriptor attribute)."
    - "re.Pattern is a C-extension type whose instance attributes (pattern, flags, groups, groupindex) are exposed as member_descriptor objects accessible via type(pattern_obj).__dict__. Each descriptor carries a __qualname__ of the form 'Pattern.<attr>'."
    - "re.Match is a C-extension type whose instance attributes (string, re, pos, endpos, lastindex, lastgroup) are similarly exposed as member_descriptor objects via type(match_obj).__dict__."
    - "Pattern.pattern descriptor.__qualname__ == 'Pattern.pattern' — len 15. No prior re spec checks __qualname__.__len__() for any Pattern descriptor. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Pattern.flags descriptor.__qualname__ == 'Pattern.flags' — len 13. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Pattern.groups descriptor.__qualname__ == 'Pattern.groups' — len 14. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Pattern.groupindex descriptor.__qualname__ == 'Pattern.groupindex' — len 18. Longest Pattern descriptor qualname. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Match.string descriptor.__qualname__ == 'Match.string' — len 12. No prior re spec checks __qualname__.__len__() for any Match descriptor. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Match.re descriptor.__qualname__ == 'Match.re' — len 8. Shortest Match descriptor qualname. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Match.pos descriptor.__qualname__ == 'Match.pos' — len 9. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Match.endpos descriptor.__qualname__ == 'Match.endpos' — len 12. Equals Match.string (12). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Match.lastindex descriptor.__qualname__ == 'Match.lastindex' — len 15. Equals Match.lastgroup (15). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Match.lastgroup descriptor.__qualname__ == 'Match.lastgroup' — len 15. Equals Match.lastindex (15). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern member_descriptor attribute __qualname__.__len__()
#
# Pattern (a C-extension type, re.Pattern == type(re.compile(''))) exposes
# its instance attributes as member_descriptor objects in its class __dict__.
# Each descriptor has a __qualname__ of the form 'Pattern.<attr>'. No prior
# re spec checks __qualname__.__len__() for any Pattern descriptor attribute
# (prior specs cover method qualname lengths, not attribute descriptor lengths).
#
#   Pattern.pattern    descriptor -> 'Pattern.pattern'    -> 15
#   Pattern.flags      descriptor -> 'Pattern.flags'      -> 13
#   Pattern.groups     descriptor -> 'Pattern.groups'     -> 14
#   Pattern.groupindex descriptor -> 'Pattern.groupindex' -> 18 (longest)
#
# All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
#
# Note: the function path uses __dict__['attr'] notation (quoted with double
# quotes per spec rules) to access descriptor objects, not method objects.
# ---------------------------------------------------------------------------

table re_extra37.Pattern_descriptor_qualname_lens:
  description: "re.Pattern member_descriptor attribute __qualname__.__len__() — pattern(15)/flags(13)/groups(14)/groupindex(18); all novel; no prior re spec checks descriptor qualname lengths"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: rpdq37

  columns: [id, function, args, expected]
  rows:
    - [pattern,    "Pattern.__dict__['pattern'].__qualname__.__len__",    [], 15]
    - [flags,      "Pattern.__dict__['flags'].__qualname__.__len__",      [], 13]
    - [groups,     "Pattern.__dict__['groups'].__qualname__.__len__",     [], 14]
    - [groupindex, "Pattern.__dict__['groupindex'].__qualname__.__len__", [], 18]

# ---------------------------------------------------------------------------
# re.Match member_descriptor attribute __qualname__.__len__()
#
# Match (re.Match == type(re.compile('').match(''))) exposes its instance
# attributes as member_descriptor objects in its class __dict__. Each
# descriptor has a __qualname__ of the form 'Match.<attr>'. No prior re spec
# checks __qualname__.__len__() for any Match descriptor attribute.
#
#   Match.string    descriptor -> 'Match.string'    -> 12
#   Match.re        descriptor -> 'Match.re'        ->  8 (shortest)
#   Match.pos       descriptor -> 'Match.pos'       ->  9
#   Match.endpos    descriptor -> 'Match.endpos'    -> 12
#   Match.lastindex descriptor -> 'Match.lastindex' -> 15
#   Match.lastgroup descriptor -> 'Match.lastgroup' -> 15
#
# All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra37.Match_descriptor_qualname_lens:
  description: "re.Match member_descriptor attribute __qualname__.__len__() — string(12)/re(8)/pos(9)/endpos(12)/lastindex(15)/lastgroup(15); all novel"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: rmdq37

  columns: [id, function, args, expected]
  rows:
    - [string,    "Match.__dict__['string'].__qualname__.__len__",    [], 12]
    - [re,        "Match.__dict__['re'].__qualname__.__len__",        [],  8]
    - [pos,       "Match.__dict__['pos'].__qualname__.__len__",       [],  9]
    - [endpos,    "Match.__dict__['endpos'].__qualname__.__len__",    [], 12]
    - [lastindex, "Match.__dict__['lastindex'].__qualname__.__len__", [], 15]
    - [lastgroup, "Match.__dict__['lastgroup'].__qualname__.__len__", [], 15]
