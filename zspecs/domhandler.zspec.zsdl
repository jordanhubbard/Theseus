spec: domhandler
version: ">=5.0.0"
backend: node(domhandler)

docs: https://github.com/fb55/domhandler#readme

provenance:
  derived_from:
    - "domhandler README — https://github.com/fb55/domhandler#readme"
    - "Test vectors verified with domhandler via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "domhandler source"
  notes:
    - "DOM-like node classes used by htmlparser2 to build the AST."
    - "Install: npm install domhandler"
    - "Static helpers: hasChildren, isCDATA, isText, isTag, isComment, cloneNode."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure helpers; never throw on Node-shaped input."
  stderr: "null"
  stickiness: "N/A — pure type predicates."
  codes: {}

# Predicates on plain Element-shaped objects
table domhandler.isTag:
  kind: node_module_call_eq
  category: isTag
  function: isTag
  id_prefix: isTag

  columns: [id, args, expected]
  rows:
    - [tag_node,        [{type: "tag", name: "p"}],     true]
    - [text_node,       [{type: "text", data: "hi"}],   false]
    - [script_tag,      [{type: "script", name: "script"}], true]
    - [style_tag,       [{type: "style", name: "style"}], true]

table domhandler.isText:
  kind: node_module_call_eq
  category: isText
  function: isText
  id_prefix: isText

  columns: [id, args, expected]
  rows:
    - [text_node,       [{type: "text", data: "hi"}],   true]
    - [tag_node,        [{type: "tag", name: "p"}],     false]

table domhandler.isComment:
  kind: node_module_call_eq
  category: isComment
  function: isComment
  id_prefix: isComment

  columns: [id, args, expected]
  rows:
    - [comment_node,    [{type: "comment", data: "x"}],  true]
    - [tag_node,        [{type: "tag", name: "p"}],      false]

table domhandler.isCDATA:
  kind: node_module_call_eq
  category: isCDATA
  function: isCDATA
  id_prefix: isCDATA

  columns: [id, args, expected]
  rows:
    - [cdata_node,      [{type: "cdata"}],               true]
    - [tag_node,        [{type: "tag", name: "p"}],      false]

# hasChildren — true for nodes that may contain children
table domhandler.hasChildren:
  kind: node_module_call_eq
  category: hasChildren
  function: hasChildren
  id_prefix: hasChildren

  columns: [id, args, expected]
  rows:
    - [tag_with_children, [{type: "tag", name: "p", children: []}],  true]
    - [text_node,         [{type: "text", data: "x"}],                false]
