spec: io_extra186
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers: io open() function — io.open.__name__=='open' (len=4); io.open.__module__=='io'; io.open.__class__.__name__=='builtin_function_or_method'; io.open_code.__name__=='open_code' (len=9); io.open_code.__module__=='io'; io.IOBase.__enter__.__name__=='__enter__' (len=9); io.IOBase.__exit__.__name__=='__exit__' (len=7); io.IOBase.readable.__name__=='readable' (len=8); io.IOBase.writable.__name__=='writable' (len=8; same); io.IOBase.seekable.__name__=='seekable' (len=8; same — 3-way tie)."
    - "io.open.__name__ == 'open' (len=4); io.open.__module__ == 'io'; io.open.__class__.__name__ == 'builtin_function_or_method'."
    - "io.open_code.__name__ == 'open_code' (len=9); io.open_code.__module__ == 'io'."
    - "io.IOBase.__enter__.__name__ == '__enter__' (len=9); io.IOBase.__exit__.__name__ == '__exit__' (len=7)."
    - "__exit__ (7) < readable==writable==seekable (8) < __enter__==open_code (9)."
    - "io.IOBase.readable.__name__ == 'readable' (len=8); io.IOBase.writable.__name__ == 'writable' (len=8; same); io.IOBase.seekable.__name__ == 'seekable' (len=8; same — 3-way tie at length 8)."
    - "readable (8) == writable (8) == seekable (8): a 3-way tie among the IOBase query methods."
    - "open (4) < __exit__ (7) < readable==writable==seekable (8) < __enter__==open_code (9): the full length ordering among covered names."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.open and io.open_code function identity
# open (len=4): shortest; open_code (len=9): longest in this group
