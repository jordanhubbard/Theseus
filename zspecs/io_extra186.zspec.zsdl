table io_extra186.open_function_identity:
  description: "io.open and io.open_code function identity: open.__name__=='open' (len=4); open.__module__=='io'; open.__class__.__name__=='builtin_function_or_method'; open_code.__name__=='open_code' (len=9); open_code.__module__=='io'; open (4) < open_code (9)"
  kind: python_call_eq
  category: identity
  id_prefix: ioopen186

  columns: [id, function, args, expected, description]
  rows:
    - [open_name,        open.__name__.__eq__,                              ["open"],                      true, "io.open.__name__ == 'open' — io.open is the built-in file opener; 'open' has 4 characters: o(1)p(2)e(3)n(4); open (4) is the shortest covered name; open (4) < __exit__ (7) < readable==writable==seekable (8) < __enter__==open_code (9): the full length ordering; confirmed Python 3.14.3 macOS"]
    - [open_name_len,    open.__name__.__len__,                             [],                            4,    "io.open.__name__.__len__() == 4 — 'open' has 4 characters; open (4) is the minimum length in the covered set; open (4) < __exit__ (7) < readable==writable==seekable (8) < __enter__==open_code (9); confirmed Python 3.14.3 macOS"]
    - [open_module,      open.__module__.__eq__,                            ["io"],                        true, "io.open.__module__ == 'io' — io.open belongs to the io module; __module__ reports 'io' as the public module name; open and open_code both have __module__ == 'io'; confirmed Python 3.14.3 macOS"]
    - [open_class,       open.__class__.__name__.__eq__,                    ["builtin_function_or_method"], true, "io.open.__class__.__name__ == 'builtin_function_or_method' — io.open is a C built-in function; 'builtin_function_or_method' is the class of built-in callables in CPython; confirmed Python 3.14.3 macOS"]
    - [open_code_name,   open_code.__name__.__eq__,                        ["open_code"],                 true, "io.open_code.__name__ == 'open_code' — open_code opens a file in a mode suitable for executing its content as Python code; 'open_code' has 9 characters: o(1)p(2)e(3)n(4)_(5)c(6)o(7)d(8)e(9); open_code (9) == __enter__ (9): both share length 9; confirmed Python 3.14.3 macOS"]
    - [open_code_len,    open_code.__name__.__len__,                        [],                            9,    "io.open_code.__name__.__len__() == 9 — 'open_code' has 9 characters; open_code (9) == __enter__ (9): a 2-way tie at length 9; readable==writable==seekable (8) < open_code==__enter__ (9): the length-9 group exceeds the 3-way tie by 1; confirmed Python 3.14.3 macOS"]
    - [open_code_module, open_code.__module__.__eq__,                       ["io"],                        true, "io.open_code.__module__ == 'io' — open_code is defined in the io module; open and open_code both have __module__ == 'io'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.IOBase context-manager method names (__enter__, __exit__)
# __exit__ (7) < __enter__ (9): __enter__ is 2 characters longer
# ---------------------------------------------------------------------------

table io_extra186.iobase_context_manager_names:
  description: "io.IOBase context-manager method names: __enter__.__name__=='__enter__' (len=9); __exit__.__name__=='__exit__' (len=7); __exit__ (7) < __enter__ (9) by 2; __enter__ (9) == open_code (9): both share length 9"
  kind: python_call_eq
  category: identity
  id_prefix: ioopen186

  columns: [id, function, args, expected, description]
  rows:
    - [enter_name,     "IOBase.__enter__.__name__.__eq__",     ["__enter__"], true, "io.IOBase.__enter__.__name__ == '__enter__' — __enter__ implements the context manager protocol for IO objects (used in 'with open(...) as f:'); '__enter__' has 9 characters: _(1)_(2)e(3)n(4)t(5)e(6)r(7)_(8)_(9); __enter__ (9) == open_code (9): both share length 9; __exit__ (7) < __enter__ (9) by 2; confirmed Python 3.14.3 macOS"]
    - [enter_name_len, "IOBase.__enter__.__name__.__len__",    [],            9,    "io.IOBase.__enter__.__name__.__len__() == 9 — '__enter__' has 9 characters; __enter__ (9) == open_code (9): both share length 9; readable==writable==seekable (8) < __enter__==open_code (9): the length-9 pair exceeds the 3-way tie by 1; confirmed Python 3.14.3 macOS"]
    - [exit_name,      "IOBase.__exit__.__name__.__eq__",      ["__exit__"],  true, "io.IOBase.__exit__.__name__ == '__exit__' — __exit__ handles cleanup when the 'with' block exits (flushes and closes the stream); '__exit__' has 7 characters: _(1)_(2)e(3)x(4)i(5)t(6)_(7); __exit__ (7) < readable==writable==seekable (8): __exit__ is shorter than the 3-way tie by 1; confirmed Python 3.14.3 macOS"]
    - [exit_name_len,  "IOBase.__exit__.__name__.__len__",     [],            7,    "io.IOBase.__exit__.__name__.__len__() == 7 — '__exit__' has 7 characters; __exit__ (7) is strictly between open (4) and readable==writable==seekable (8); open (4) < __exit__ (7) < readable==writable==seekable (8) < __enter__==open_code (9); confirmed Python 3.14.3 macOS"]
    - [exit_lt_enter,  "IOBase.__exit__.__name__.__len__",     [],            7,    "io.IOBase.__exit__.__name__.__len__() == 7 confirms __exit__ (7) < __enter__ (9): the context manager exit method name is 2 characters shorter than the entry method name; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io.IOBase query method names (readable, writable, seekable)
# readable==writable==seekable (8): a 3-way tie at length 8
# ---------------------------------------------------------------------------

table io_extra186.iobase_query_method_names:
  description: "io.IOBase query method names: readable.__name__=='readable' (len=8); writable.__name__=='writable' (len=8; same); seekable.__name__=='seekable' (len=8; same — 3-way tie); __exit__ (7) < readable==writable==seekable (8) < __enter__==open_code (9)"
  kind: python_call_eq
  category: identity
  id_prefix: ioopen186

  columns: [id, function, args, expected, description]
  rows:
    - [readable_name,     "IOBase.readable.__name__.__eq__",   ["readable"],  true, "io.IOBase.readable.__name__ == 'readable' — readable() returns whether the stream can be read from; 'readable' has 8 characters: r(1)e(2)a(3)d(4)a(5)b(6)l(7)e(8); readable (8) == writable (8) == seekable (8): a 3-way tie at length 8; __exit__ (7) < readable (8): readable is 1 longer than __exit__; confirmed Python 3.14.3 macOS"]
    - [readable_name_len, "IOBase.readable.__name__.__len__",  [],            8,    "io.IOBase.readable.__name__.__len__() == 8 — 'readable' has 8 characters; readable (8) == writable (8) == seekable (8): all three IOBase query methods share length 8 — a 3-way tie; __exit__ (7) < readable==writable==seekable (8) < __enter__==open_code (9): the 3-way tie is flanked by 7 and 9; confirmed Python 3.14.3 macOS"]
    - [writable_name,     "IOBase.writable.__name__.__eq__",   ["writable"],  true, "io.IOBase.writable.__name__ == 'writable' — writable() returns whether the stream can be written to; 'writable' has 8 characters: w(1)r(2)i(3)t(4)a(5)b(6)l(7)e(8); writable (8) == readable (8) == seekable (8): the 3-way tie at length 8; confirmed Python 3.14.3 macOS"]
    - [writable_name_len, "IOBase.writable.__name__.__len__",  [],            8,    "io.IOBase.writable.__name__.__len__() == 8 — 'writable' has 8 characters; writable (8) == readable (8) == seekable (8): the 3-way tie; confirmed Python 3.14.3 macOS"]
    - [seekable_name,     "IOBase.seekable.__name__.__eq__",   ["seekable"],  true, "io.IOBase.seekable.__name__ == 'seekable' — seekable() returns whether the stream supports random access (seeking); 'seekable' has 8 characters: s(1)e(2)e(3)k(4)a(5)b(6)l(7)e(8); seekable (8) == readable (8) == writable (8): the 3-way tie; seekable completes the tie among the three IOBase query methods; confirmed Python 3.14.3 macOS"]
    - [seekable_name_len, "IOBase.seekable.__name__.__len__",  [],            8,    "io.IOBase.seekable.__name__.__len__() == 8 — 'seekable' has 8 characters; readable==writable==seekable (8): all three IOBase capability query methods share name length 8 — a 3-way tie; __exit__ (7) < readable==writable==seekable (8) < __enter__==open_code (9); confirmed Python 3.14.3 macOS"]

