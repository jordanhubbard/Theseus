invariant io_extra186.iobase_enter_name_len_is_9:
  description: "io.IOBase.__enter__.__name__.__len__() == 9 — '__enter__' has 9 characters; __enter__ (9) == open_code (9): a 2-way tie at length 9; readable==writable==seekable (8) < __enter__==open_code (9): the length-9 pair exceeds the 3-way tie by 1; confirmed Python 3.14.3 macOS"
  category: identity
