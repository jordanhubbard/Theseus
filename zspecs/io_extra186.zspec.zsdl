invariant io_extra186.iobase_exit_name_is_exit:
  description: "io.IOBase.__exit__.__name__ == '__exit__' — __exit__ handles context manager cleanup for IO streams; '__exit__' has 7 characters; __exit__ (7) < readable==writable==seekable (8): __exit__ is 1 character shorter than the 3-way tie; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
