spec: concurrent_futures_extra82
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra81.zspec.zsdl."
    - "This spec covers: wave 246 theme — concurrent.futures class __qualname__ string equality. NEW in extra82: ThreadPoolExecutor.__qualname__.__eq__('ThreadPoolExecutor')==True; ProcessPoolExecutor.__qualname__.__eq__('ProcessPoolExecutor')==True; Executor.__qualname__.__eq__('Executor')==True; Future.__qualname__.__eq__('Future')==True; CancelledError.__qualname__.__eq__('CancelledError')==True; TimeoutError.__qualname__.__eq__('TimeoutError')==True; BrokenExecutor.__qualname__.__eq__('BrokenExecutor')==True; InvalidStateError.__qualname__.__eq__('InvalidStateError')==True; ThreadPoolExecutor.__name__.__eq__('ThreadPoolExecutor')==True; ProcessPoolExecutor.__name__.__eq__('ProcessPoolExecutor')==True; Future.__name__.__eq__('Future')==True; Executor.__name__.__eq__('Executor')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor'. Simple top-level class qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor'. Simple top-level class qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__qualname__ == 'Executor'. Simple top-level class qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__qualname__ == 'Future'. Simple top-level class qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.CancelledError.__qualname__ == 'CancelledError'. Simple top-level exception class qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.TimeoutError.__qualname__ == 'TimeoutError'. Simple top-level exception class qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor'. Simple top-level exception class qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__qualname__ == 'InvalidStateError'. Simple top-level exception class qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures executor __qualname__ equality checks — extra82
#
# Wave 246 theme: concurrent.futures class __qualname__ string equality.
#
# ThreadPoolExecutor.__qualname__.__eq__('ThreadPoolExecutor') == True
# ProcessPoolExecutor.__qualname__.__eq__('ProcessPoolExecutor') == True
# Executor.__qualname__.__eq__('Executor') == True
# Future.__qualname__.__eq__('Future') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra82.executor_qualnames:
  description: "concurrent.futures executor and Future __qualname__ equality checks in cfextra82 namespace — wave 246 theme: concurrent.futures class __qualname__ string equality; ThreadPoolExecutor.__qualname__.__eq__('ThreadPoolExecutor')==True; ProcessPoolExecutor.__qualname__.__eq__('ProcessPoolExecutor')==True; Executor.__qualname__.__eq__('Executor')==True; Future.__qualname__.__eq__('Future')==True; all are simple top-level class names with no enclosing scope; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfextra82

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_qualname,    ThreadPoolExecutor.__qualname__.__eq__,    ["ThreadPoolExecutor"],  true, "ThreadPoolExecutor.__qualname__.__eq__('ThreadPoolExecutor') == True — simple top-level class qualname; verified with Python 3.14.3"]
    - [ppe_qualname,    ProcessPoolExecutor.__qualname__.__eq__,   ["ProcessPoolExecutor"], true, "ProcessPoolExecutor.__qualname__.__eq__('ProcessPoolExecutor') == True — simple top-level class qualname; verified with Python 3.14.3"]
    - [exec_qualname,   Executor.__qualname__.__eq__,              ["Executor"],            true, "Executor.__qualname__.__eq__('Executor') == True — simple top-level class qualname; verified with Python 3.14.3"]
    - [future_qualname, Future.__qualname__.__eq__,                ["Future"],              true, "Future.__qualname__.__eq__('Future') == True — simple top-level class qualname; verified with Python 3.14.3"]

