invariant concurrent_futures_extra82.ThreadPoolExecutor_qualname:
  description: "concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__('ThreadPoolExecutor') returns True — ThreadPoolExecutor is a top-level class and its __qualname__ equals its simple class name; NEW in extra82: first standalone __qualname__ equality invariant for ThreadPoolExecutor in cfextra82 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__qualname__.__eq__
  args: ["ThreadPoolExecutor"]
  expected: true

invariant concurrent_futures_extra82.ProcessPoolExecutor_qualname:
  description: "concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__('ProcessPoolExecutor') returns True — ProcessPoolExecutor is a top-level class and its __qualname__ equals its simple class name; NEW in extra82: first standalone __qualname__ equality invariant for ProcessPoolExecutor in cfextra82 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__qualname__.__eq__
  args: ["ProcessPoolExecutor"]
  expected: true

invariant concurrent_futures_extra82.Executor_qualname:
  description: "concurrent.futures.Executor.__qualname__.__eq__('Executor') returns True — Executor is the abstract base class for all executors and is a top-level class; its __qualname__ equals its simple class name; NEW in extra82: first standalone __qualname__ equality invariant for Executor in cfextra82 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Executor.__qualname__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra82.CancelledError_qualname:
  description: "concurrent.futures.CancelledError.__qualname__.__eq__('CancelledError') returns True — CancelledError is a top-level exception class in concurrent.futures; its __qualname__ equals its simple class name; NEW in extra82: first standalone __qualname__ equality invariant for CancelledError in cfextra82 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: CancelledError.__qualname__.__eq__
  args: ["CancelledError"]
  expected: true

invariant concurrent_futures_extra82.BrokenExecutor_qualname:
  description: "concurrent.futures.BrokenExecutor.__qualname__.__eq__('BrokenExecutor') returns True — BrokenExecutor is a top-level exception class raised when an executor is broken; its __qualname__ equals its simple class name; NEW in extra82: first standalone __qualname__ equality invariant for BrokenExecutor in cfextra82 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BrokenExecutor.__qualname__.__eq__
  args: ["BrokenExecutor"]
  expected: true
