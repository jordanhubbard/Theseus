spec: pkgutil_extra4
version: ">=3.9"
backend: python_module(pkgutil)

docs: https://docs.python.org/3/library/pkgutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pkgutil.html — Python pkgutil documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pkgutil.py"
  notes:
    - "This spec extends pkgutil.zspec.zsdl through pkgutil_extra3.zspec.zsdl."
    - "pkgutil (base) covers: walk/iter/get/extend/resolve_name __name__ and type; ModuleInfo _fields len/items; resolve_name('builtins.len'); extend_path returns list."
    - "pkgutil_extra covers: __qualname__ for walk/iter/get/extend/resolve_name; read_code __name__/__qualname__/type; ModuleInfo __module__/__qualname__/_fields[0]; function __doc__ class; resolve_name('builtins.int'); bad resolve raises."
    - "pkgutil_extra2 covers: get_importer __name__/__qualname__/type/__module__; function __module__ table; ModuleInfo._fields class (tuple) and is_type; get_importer __doc__; _fields __contains__ checks."
    - "pkgutil_extra3 covers: module __name__; read_code __module__; ModuleInfo._fields[0] via __eq__ chain; function_names_direct table; resolve_name/__doc__ len>0; get_importer/__doc__ len>0."
    - "This spec adds: module __spec__.name == 'pkgutil'; ModuleInfo._make.__name__; ModuleInfo._asdict.__name__; iter_modules __doc__ len>0; walk_packages __doc__ len>0; resolve_name('builtins.str') resolves to 'str'; get_importer.__qualname__ via __eq__ chain (complementary angle); read_code.__doc__.__class__.__name__ == 'str'."
    - "ModuleInfo._make is the namedtuple classmethod for creating instances from an iterable."
    - "ModuleInfo._asdict is the namedtuple method for converting an instance to a dict."
    - "pkgutil.get_loader and pkgutil.find_loader were deprecated in Python 3.12 and removed in 3.14; they are excluded."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# module __spec__.name — the importlib ModuleSpec records the module name.
# Not covered in any prior pkgutil spec.
# ---------------------------------------------------------------------------

invariant pkgutil_extra4.module.spec_name:
  description: "pkgutil.__spec__.name == 'pkgutil' — ModuleSpec records the correct module name"
  category: module
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["pkgutil"]
  expected: true

# ---------------------------------------------------------------------------
# ModuleInfo._make — namedtuple classmethod for building instances
# _make.__name__ == '_make' on all Python versions.
# Not covered in any prior pkgutil spec.
# ---------------------------------------------------------------------------

invariant pkgutil_extra4.ModuleInfo._make_name:
  description: "pkgutil.ModuleInfo._make.__name__ == '_make' — namedtuple classmethod name"
  category: ModuleInfo
  kind: python_call_eq
  function: ModuleInfo._make.__name__.__eq__
  args: ["_make"]
  expected: true

# ---------------------------------------------------------------------------
# ModuleInfo._asdict — namedtuple method for converting to a dict.
# _asdict.__name__ == '_asdict' on all Python versions.
# Not covered in any prior pkgutil spec.
# ---------------------------------------------------------------------------

invariant pkgutil_extra4.ModuleInfo._asdict_name:
  description: "pkgutil.ModuleInfo._asdict.__name__ == '_asdict' — namedtuple method name"
  category: ModuleInfo
  kind: python_call_eq
  function: ModuleInfo._asdict.__name__.__eq__
  args: ["_asdict"]
  expected: true

# ---------------------------------------------------------------------------
# Function __doc__ length > 0 — iter_modules and walk_packages have docstrings.
# pkgutil_extra checks that __doc__ is a str; this spec adds length > 0.
# Not covered in any prior pkgutil spec.
# ---------------------------------------------------------------------------

table pkgutil_extra4.function_doc_lengths:
  kind: python_call_eq
  category: functions
  id_prefix: doc_len

  columns: [id, function, args, expected, method, method_args]
  rows:
    - [iter_modules,  iter_modules.__doc__.__len__,  [], true, __gt__, [0]]
    - [walk_packages, walk_packages.__doc__.__len__, [], true, __gt__, [0]]
    - [extend_path,   extend_path.__doc__.__len__,   [], true, __gt__, [0]]

# ---------------------------------------------------------------------------
# resolve_name('builtins.str') — resolves to the built-in str type.
# Prior specs resolve 'builtins.len' and 'builtins.int'; 'builtins.str' is new.
# Not covered in any prior pkgutil spec.
# ---------------------------------------------------------------------------

invariant pkgutil_extra4.resolve_name.builtins_str:
  description: "pkgutil.resolve_name('builtins.str').__name__ == 'str' — resolves to the str type"
  category: resolve_name
  kind: python_call_eq
  function: resolve_name
  args: ["builtins.str"]
  method: __name__
  expected: "str"

# ---------------------------------------------------------------------------
# read_code.__doc__ — read_code is documented (type is str).
# pkgutil_extra checks __name__/__qualname__/type for read_code;
# pkgutil_extra3 checks __module__; __doc__ is new here.
# Not covered in any prior pkgutil spec.
# ---------------------------------------------------------------------------

invariant pkgutil_extra4.read_code.doc_is_str:
  description: "pkgutil.read_code.__doc__.__class__.__name__ == 'str' — read_code has a docstring"
  category: functions
  kind: python_call_eq
  function: read_code.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
