spec: cf3016
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 648 — theme: __iter__, __next__, __reversed__ dict-presence (iterator protocol)."
    - "Tests operator.contains(SomeClass.__dict__, '__iter__') etc. for concurrent.futures classes."
    - "Classes covered: Future, ThreadPoolExecutor, ProcessPoolExecutor, CancelledError, TimeoutError, BrokenExecutor, InvalidStateError."
    - "None of these classes define __iter__, __next__, or __reversed__ in their own __dict__."
    - "concurrent.futures.Future is a result-holder, not a sequence; it has no iterator protocol."
    - "Executor classes (ThreadPoolExecutor, ProcessPoolExecutor) manage internal work queues but do not expose the iterator protocol to callers."
    - "Exception subclasses (CancelledError, TimeoutError, BrokenExecutor, InvalidStateError) inherit from the standard exception hierarchy with no iterator slots."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iter__ dict-presence — operator.contains(Cls.__dict__, '__iter__')
#
# No concurrent.futures class defines __iter__; all results are false.
# ---------------------------------------------------------------------------

table cf3016.iter:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: iter_iter
  id_prefix: it

  columns: [id, function, args, expected]
  rows:
    - ["it_Future",            operator.contains, [concurrent.futures.Future.__dict__,              "__iter__"], false]
    - ["it_ThreadPoolExec",    operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__iter__"], false]
    - ["it_ProcessPoolExec",   operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__iter__"], false]
    - ["it_CancelledError",    operator.contains, [concurrent.futures.CancelledError.__dict__,      "__iter__"], false]
    - ["it_TimeoutError",      operator.contains, [concurrent.futures.TimeoutError.__dict__,        "__iter__"], false]
    - ["it_BrokenExecutor",    operator.contains, [concurrent.futures.BrokenExecutor.__dict__,      "__iter__"], false]
    - ["it_InvalidStateError", operator.contains, [concurrent.futures.InvalidStateError.__dict__,   "__iter__"], false]

