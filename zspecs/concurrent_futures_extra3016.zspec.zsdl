    - ["nx_ThreadPoolExec",    operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__next__"], false]
    - ["nx_ProcessPoolExec",   operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__next__"], false]
    - ["nx_CancelledError",    operator.contains, [concurrent.futures.CancelledError.__dict__,      "__next__"], false]
    - ["nx_TimeoutError",      operator.contains, [concurrent.futures.TimeoutError.__dict__,        "__next__"], false]
    - ["nx_BrokenExecutor",    operator.contains, [concurrent.futures.BrokenExecutor.__dict__,      "__next__"], false]
    - ["nx_InvalidStateError", operator.contains, [concurrent.futures.InvalidStateError.__dict__,   "__next__"], false]

# ---------------------------------------------------------------------------
# __reversed__ dict-presence — operator.contains(Cls.__dict__, '__reversed__')
#
# No concurrent.futures class defines __reversed__; all results are false.
# These classes are not ordered sequences; reversal is not meaningful.
# ---------------------------------------------------------------------------

table cf3016.reversed:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: iter_reversed
  id_prefix: rv

  columns: [id, function, args, expected]
  rows:
    - ["rv_Future",            operator.contains, [concurrent.futures.Future.__dict__,              "__reversed__"], false]
    - ["rv_ThreadPoolExec",    operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__reversed__"], false]
    - ["rv_ProcessPoolExec",   operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__reversed__"], false]
    - ["rv_CancelledError",    operator.contains, [concurrent.futures.CancelledError.__dict__,      "__reversed__"], false]
    - ["rv_TimeoutError",      operator.contains, [concurrent.futures.TimeoutError.__dict__,        "__reversed__"], false]
    - ["rv_BrokenExecutor",    operator.contains, [concurrent.futures.BrokenExecutor.__dict__,      "__reversed__"], false]
    - ["rv_InvalidStateError", operator.contains, [concurrent.futures.InvalidStateError.__dict__,   "__reversed__"], false]

# ---------------------------------------------------------------------------
# combined — all three iterator protocol methods across a cross-class sample
#
# Spot-checks __iter__, __next__, __reversed__ across the full set of
# concurrent.futures classes.  All entries are false.
# 7 classes x 3 methods = 21 rows (padded to 24 with extra exception subclass checks).
# ---------------------------------------------------------------------------

table cf3016.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: iter_combined
  id_prefix: comb

