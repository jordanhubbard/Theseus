spec: threading_extra229
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading behavioral output contracts: Event/Condition/RLock basic attribute contracts — class names, qualnames, and module names."
    - "threading.Event().__class__.__name__ == 'Event' — instances of threading.Event have class name 'Event'. Verified with Python 3.14.3."
    - "threading.Condition().__class__.__name__ == 'Condition' — instances of threading.Condition have class name 'Condition'. Verified with Python 3.14.3."
    - "threading.RLock().__class__.__name__ == 'RLock' — instances returned by threading.RLock() have class name 'RLock'. Verified with Python 3.14.3."
    - "threading.Lock().__class__.__name__ == 'lock' — instances of the Lock type have class name 'lock' (lowercase, C type). Verified with Python 3.14.3."
    - "threading.Event.__name__ == 'Event' — the Event class has __name__=='Event'. Verified with Python 3.14.3."
    - "threading.Condition.__name__ == 'Condition' — the Condition class has __name__=='Condition'. Verified with Python 3.14.3."
    - "threading.Semaphore.__name__ == 'Semaphore' — the Semaphore class has __name__=='Semaphore'. Verified with Python 3.14.3."
    - "threading.Barrier.__name__ == 'Barrier' — the Barrier class has __name__=='Barrier'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading synchronization class __name__ contracts
#
# threading.Event.__name__ == 'Event'
# threading.Condition.__name__ == 'Condition'
# threading.Semaphore.__name__ == 'Semaphore'
# threading.Barrier.__name__ == 'Barrier'
# threading.Thread.__name__ == 'Thread'
#
# New to extra229.
# ---------------------------------------------------------------------------

table threading_extra229.sync_class_names:
  description: "threading Event/Condition/Semaphore/Barrier/Thread __name__ contracts; new to extra229"
  kind: python_call_eq
  category: behavioral
  id_prefix: threadingextra229syncnames

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_eq,
       Event.__name__.__eq__,
       ["Event"],
       true,
       "threading.Event.__name__ == 'Event' — threading.Event is a Python class defined in Lib/threading.py; its __name__ is 'Event'; __name__.__eq__('Event') returns True; new to extra229"]
    - [condition_name_eq,
       Condition.__name__.__eq__,
       ["Condition"],
       true,
       "threading.Condition.__name__ == 'Condition' — threading.Condition is a Python class defined in Lib/threading.py; its __name__ is 'Condition'; __name__.__eq__('Condition') returns True; new to extra229"]
    - [semaphore_name_eq,
       Semaphore.__name__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__ == 'Semaphore' — threading.Semaphore is a Python class defined in Lib/threading.py; its __name__ is 'Semaphore'; __name__.__eq__('Semaphore') returns True; new to extra229"]
    - [barrier_name_eq,
       Barrier.__name__.__eq__,
       ["Barrier"],
       true,
       "threading.Barrier.__name__ == 'Barrier' — threading.Barrier is a Python class defined in Lib/threading.py; its __name__ is 'Barrier'; __name__.__eq__('Barrier') returns True; new to extra229"]
    - [thread_name_eq,
       Thread.__name__.__eq__,
       ["Thread"],
       true,
       "threading.Thread.__name__ == 'Thread' — threading.Thread is the base thread class; its __name__ is 'Thread'; __name__.__eq__('Thread') returns True; new to extra229"]

# ---------------------------------------------------------------------------
# Table 2: threading synchronization class __name__ length contracts
#
# threading.Event.__name__.__len__() == 5
# threading.Condition.__name__.__len__() == 9
# threading.Semaphore.__name__.__len__() == 9
# threading.Barrier.__name__.__len__() == 7
# threading.Thread.__name__.__len__() == 6
#
# New to extra229.
# ---------------------------------------------------------------------------

table threading_extra229.sync_class_name_lengths:
  description: "threading Event/Condition/Semaphore/Barrier/Thread __name__ length contracts; new to extra229"
  kind: python_call_eq
  category: behavioral
  id_prefix: threadingextra229syncnamelen

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_len_5,
       Event.__name__.__len__,
       [],
       5,
       "threading.Event.__name__.__len__() == 5 — 'Event' has exactly 5 characters (E-v-e-n-t); __len__() returns 5; new to extra229"]
    - [condition_name_len_9,
       Condition.__name__.__len__,
       [],
       9,
       "threading.Condition.__name__.__len__() == 9 — 'Condition' has exactly 9 characters (C-o-n-d-i-t-i-o-n); __len__() returns 9; new to extra229"]
    - [semaphore_name_len_9,
       Semaphore.__name__.__len__,
       [],
       9,
       "threading.Semaphore.__name__.__len__() == 9 — 'Semaphore' has exactly 9 characters (S-e-m-a-p-h-o-r-e); __len__() returns 9; new to extra229"]
    - [barrier_name_len_7,
       Barrier.__name__.__len__,
       [],
       7,
       "threading.Barrier.__name__.__len__() == 7 — 'Barrier' has exactly 7 characters (B-a-r-r-i-e-r); __len__() returns 7; new to extra229"]
    - [thread_name_len_6,
       Thread.__name__.__len__,
       [],
       6,
       "threading.Thread.__name__.__len__() == 6 — 'Thread' has exactly 6 characters (T-h-r-e-a-d); __len__() returns 6; new to extra229"]

# ---------------------------------------------------------------------------
# Table 3: threading synchronization class __module__ contracts
#
# threading.Event.__module__ == 'threading'
# threading.Condition.__module__ == 'threading'
# threading.Semaphore.__module__ == 'threading'
# threading.Barrier.__module__ == 'threading'
# threading.Thread.__module__ == 'threading'
#
# All synchronization primitives are defined in the threading module.
# New to extra229.
# ---------------------------------------------------------------------------

table threading_extra229.sync_class_modules:
  description: "threading Event/Condition/Semaphore/Barrier/Thread __module__=='threading' contracts; new to extra229"
  kind: python_call_eq
  category: behavioral
  id_prefix: threadingextra229syncmod

  columns: [id, function, args, expected, description]
  rows:
    - [event_module_eq,
       Event.__module__.__eq__,
       ["threading"],
       true,
       "threading.Event.__module__ == 'threading' — Event is defined in Lib/threading.py; __module__.__eq__('threading') returns True; new to extra229"]
    - [condition_module_eq,
       Condition.__module__.__eq__,
       ["threading"],
       true,
       "threading.Condition.__module__ == 'threading' — Condition is defined in Lib/threading.py; __module__.__eq__('threading') returns True; new to extra229"]
    - [semaphore_module_eq,
       Semaphore.__module__.__eq__,
       ["threading"],
       true,
       "threading.Semaphore.__module__ == 'threading' — Semaphore is defined in Lib/threading.py; __module__.__eq__('threading') returns True; new to extra229"]
    - [barrier_module_eq,
       Barrier.__module__.__eq__,
       ["threading"],
       true,
       "threading.Barrier.__module__ == 'threading' — Barrier is defined in Lib/threading.py; __module__.__eq__('threading') returns True; new to extra229"]
    - [thread_module_eq,
       Thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.Thread.__module__ == 'threading' — Thread is defined in Lib/threading.py; __module__.__eq__('threading') returns True; new to extra229"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra229
# ---------------------------------------------------------------------------

invariant threading_extra229.event_name_eq:
  description: "threading.Event.__name__ == 'Event'; new to extra229"
  kind: python_call_eq
  function: Event.__name__.__eq__
  args: ["Event"]
  expected: true

