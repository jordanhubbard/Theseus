spec: pathlib_extra1876
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "pathlib module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party pathlib extensions"
  notes:
    - "Tests attribute access protocol membership in pathlib types"
    - "PurePath and its subclasses use __slots__ to restrict instance attributes"
    - "Path.__dict__ contains lstat, lchmod, owner, group and other filesystem-level methods"
  created_at: "2026-04-12"

table pathlib_extra1876.attr_access_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["pl1876-aa-001", "pathlib.PurePath.__dict__.__contains__", ["__getattr__"], false]
    - ["pl1876-aa-002", "pathlib.PurePath.__dict__.__contains__", ["__setattr__"], false]
    - ["pl1876-aa-003", "pathlib.PurePath.__dict__.__contains__", ["__delattr__"], false]
    - ["pl1876-aa-004", "pathlib.PurePath.__dict__.__contains__", ["__getattribute__"], false]
    - ["pl1876-aa-005", "pathlib.Path.__dict__.__contains__", ["__getattr__"], false]
    - ["pl1876-aa-006", "pathlib.Path.__dict__.__contains__", ["__setattr__"], false]
    - ["pl1876-aa-007", "pathlib.PurePosixPath.__dict__.__contains__", ["__getattr__"], false]
    - ["pl1876-aa-008", "pathlib.PureWindowsPath.__dict__.__contains__", ["__getattr__"], false]

