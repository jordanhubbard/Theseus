spec: socket_extra2791
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra2776.zspec.zsdl — covers __isub__, __imul__, and __itruediv__ absence for socket.socket, AddressFamily, SocketKind."
    - "socket_extra2761.zspec.zsdl — covers __matmul__, __truediv__, and __iadd__ absence for socket.socket, AddressFamily, SocketKind."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "socket.socket.__dict__.__contains__('__iand__') == False — socket.socket is a network I/O type; it defines no in-place bitwise AND operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.socket.__dict__.__contains__('__ior__') == False — socket.socket defines no in-place bitwise OR operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.socket.__dict__.__contains__('__ixor__') == False — socket.socket defines no in-place bitwise XOR operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__iand__') == False — AddressFamily is an IntEnum subclass; it does not add in-place bitwise AND to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__ior__') == False — AddressFamily does not add in-place bitwise OR to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__ixor__') == False — AddressFamily does not add in-place bitwise XOR to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__iand__') == False — SocketKind is an IntEnum subclass; it does not add in-place bitwise AND to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__ior__') == False — SocketKind does not add in-place bitwise OR to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__ixor__') == False — SocketKind does not add in-place bitwise XOR to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket.socket.__dict__ — __iand__, __ior__, __ixor__ absence
# socket.socket is the main socket class; it wraps a file descriptor and
# provides network I/O methods (connect, bind, send, recv, etc.). In-place
# bitwise operators (&=, |=, ^=) have no meaning for a network socket.
# ---------------------------------------------------------------------------

table socket_extra2791.socket_dict_iand_ior_ixor:
  description: "socket.socket.__dict__ does not contain __iand__, __ior__, or __ixor__ — socket.socket is a network I/O type with no in-place bitwise operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2791

  columns: [id, function, args, expected]
  rows:
    - ["sk2791-sock-iand", socket.socket.__dict__.__contains__, ["__iand__"], false]
    - ["sk2791-sock-ior",  socket.socket.__dict__.__contains__, ["__ior__"],  false]
    - ["sk2791-sock-ixor", socket.socket.__dict__.__contains__, ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Table 2: socket.AddressFamily.__dict__ — __iand__, __ior__, __ixor__ absence
# AddressFamily is an IntEnum subclass (AF_INET=2, AF_INET6=10, AF_UNIX=1, etc.).
# It inherits integer arithmetic from int/IntEnum but does not add in-place
# bitwise operators to its own __dict__ (checked with 'in AddressFamily.__dict__',
# not MRO lookup).
# ---------------------------------------------------------------------------

table socket_extra2791.addressfamily_dict_iand_ior_ixor:
  description: "socket.AddressFamily.__dict__ does not contain __iand__, __ior__, or __ixor__ — AddressFamily (IntEnum subclass) adds no new in-place bitwise operators to its own __dict__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2791

  columns: [id, function, args, expected]
  rows:
    - ["sk2791-af-iand", socket.AddressFamily.__dict__.__contains__, ["__iand__"], false]
    - ["sk2791-af-ior",  socket.AddressFamily.__dict__.__contains__, ["__ior__"],  false]
    - ["sk2791-af-ixor", socket.AddressFamily.__dict__.__contains__, ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Table 3: socket.SocketKind.__dict__ — __iand__, __ior__, __ixor__ absence
# SocketKind is an IntEnum subclass (SOCK_STREAM=1, SOCK_DGRAM=2, etc.).
# Like AddressFamily, it does not add in-place bitwise operators to its
# own __dict__.
# ---------------------------------------------------------------------------

table socket_extra2791.socketkind_dict_iand_ior_ixor:
  description: "socket.SocketKind.__dict__ does not contain __iand__, __ior__, or __ixor__ — SocketKind (IntEnum subclass) adds no new in-place bitwise operators to its own __dict__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2791

  columns: [id, function, args, expected]
  rows:
    - ["sk2791-sk-iand", socket.SocketKind.__dict__.__contains__, ["__iand__"], false]
    - ["sk2791-sk-ior",  socket.SocketKind.__dict__.__contains__, ["__ior__"],  false]
    - ["sk2791-sk-ixor", socket.SocketKind.__dict__.__contains__, ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — socket, AddressFamily, SocketKind all absent
# ---------------------------------------------------------------------------

table socket_extra2791.all_types_all_dunders_absent:
  description: "socket.socket, socket.AddressFamily, and socket.SocketKind all lack __iand__, __ior__, and __ixor__ in __dict__ — no socket type defines these in-place bitwise operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2791

  columns: [id, function, args, expected]
  rows:
    - ["sk2791-x-sock-iand", socket.socket.__dict__.__contains__,        ["__iand__"], false]
    - ["sk2791-x-sock-ior",  socket.socket.__dict__.__contains__,        ["__ior__"],  false]
    - ["sk2791-x-sock-ixor", socket.socket.__dict__.__contains__,        ["__ixor__"], false]
    - ["sk2791-x-af-iand",   socket.AddressFamily.__dict__.__contains__, ["__iand__"], false]
    - ["sk2791-x-af-ior",    socket.AddressFamily.__dict__.__contains__, ["__ior__"],  false]
    - ["sk2791-x-af-ixor",   socket.AddressFamily.__dict__.__contains__, ["__ixor__"], false]
    - ["sk2791-x-sk-iand",   socket.SocketKind.__dict__.__contains__,   ["__iand__"], false]
    - ["sk2791-x-sk-ior",    socket.SocketKind.__dict__.__contains__,   ["__ior__"],  false]
    - ["sk2791-x-sk-ixor",   socket.SocketKind.__dict__.__contains__,   ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra2791.socket_no_iand:
  description: "socket.socket.__dict__.__contains__('__iand__') == False — socket.socket is a network I/O object; it defines no &= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: socket.socket.__dict__.__contains__
  args: ["__iand__"]
  expected: false

invariant socket_extra2791.socket_no_ior:
  description: "socket.socket.__dict__.__contains__('__ior__') == False — socket.socket defines no |= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: socket.socket.__dict__.__contains__
  args: ["__ior__"]
  expected: false

