spec: pathlib_extra1156
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module __package__.__class__.__name__, __loader__.__class__.__name__, __all__.__class__.__name__, and Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath __module__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks pathlib.__package__.__class__.__name__, pathlib.__loader__.__class__.__name__, pathlib.__all__.__class__.__name__, pathlib.Path.__module__, pathlib.PurePath.__module__, pathlib.PurePosixPath.__module__, pathlib.PureWindowsPath.__module__, pathlib.PosixPath.__module__; none of these __package__/__loader__/__all__ class name checks were covered in _extra1126 or _extra1141; __module__ checks on Path/PurePath not previously covered"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1156.module_dunder_class_names:
  description: "pathlib module __package__, __loader__, and __all__ __class__.__name__ checks"
  kind: python_call_eq
  category: module_dunder_class_names
  id_prefix: pl1156mc
  columns: [id, function, args, expected]
  rows:
    - [pl1156mc001, pathlib.__package__.__class__.__name__.__eq__,  ["str"],   true]
    - [pl1156mc002, pathlib.__loader__.__class__.__name__.__eq__,   ["SourceFileLoader"], true]
    - [pl1156mc003, pathlib.__all__.__class__.__name__.__eq__,      ["list"],  true]
    - [pl1156mc004, pathlib.__package__.__class__.__name__.__eq__,  ["bytes"], false]
    - [pl1156mc005, pathlib.__package__.__class__.__name__.__eq__,  ["NoneType"], false]
    - [pl1156mc006, pathlib.__all__.__class__.__name__.__eq__,      ["tuple"], false]
    - [pl1156mc007, pathlib.__package__.__eq__,                     ["pathlib"], true]
    - [pl1156mc008, pathlib.__package__.__class__.__name__.__eq__,  ["str"],   true]

table pathlib_extra1156.purepath_family_modules:
  description: "pathlib PurePath, PurePosixPath, PureWindowsPath __module__ checks — all must equal 'pathlib'"
  kind: python_call_eq
  category: purepath_family_modules
  id_prefix: pl1156pm
  columns: [id, function, args, expected]
  rows:
    - [pl1156pm001, pathlib.PurePath.__module__.__eq__,       ["pathlib"], true]
    - [pl1156pm002, pathlib.PurePosixPath.__module__.__eq__,  ["pathlib"], true]
    - [pl1156pm003, pathlib.PureWindowsPath.__module__.__eq__, ["pathlib"], true]
    - [pl1156pm004, pathlib.PurePath.__module__.__eq__,       ["_pathlib"], false]
    - [pl1156pm005, pathlib.PurePosixPath.__module__.__eq__,  ["builtins"], false]
    - [pl1156pm006, pathlib.PureWindowsPath.__module__.__eq__, ["os.path"], false]
    - [pl1156pm007, pathlib.PurePath.__module__.__class__.__name__.__eq__, ["str"], true]
    - [pl1156pm008, pathlib.PurePosixPath.__module__.__class__.__name__.__eq__, ["str"], true]
    - [pl1156pm009, pathlib.PureWindowsPath.__module__.__class__.__name__.__eq__, ["str"], true]

table pathlib_extra1156.path_and_posixpath_modules:
  description: "pathlib.Path and pathlib.PosixPath __module__ checks, plus __all__ membership spot-checks"
  kind: python_call_eq
  category: path_and_posixpath_modules
  id_prefix: pl1156pa
  columns: [id, function, args, expected]
  rows:
    - [pl1156pa001, pathlib.Path.__module__.__eq__,     ["pathlib"], true]
    - [pl1156pa002, pathlib.PosixPath.__module__.__eq__, ["pathlib"], true]
    - [pl1156pa003, pathlib.Path.__module__.__eq__,     ["_pathlib"], false]
    - [pl1156pa004, pathlib.PosixPath.__module__.__eq__, ["builtins"], false]
    - [pl1156pa005, pathlib.Path.__module__.__class__.__name__.__eq__,     ["str"], true]
    - [pl1156pa006, pathlib.PosixPath.__module__.__class__.__name__.__eq__, ["str"], true]
    - [pl1156pa007, pathlib.__loader__.__class__.__name__.__eq__,          ["BuiltinImporter"], false]
    - [pl1156pa008, pathlib.__all__.__class__.__name__.__eq__,             ["list"], true]
