spec: asyncio_extra202
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
  notes:
    - "This spec covers asyncio module-level dunder attributes: __name__, __package__, __spec__.name, __loader__.__class__.__name__, __doc__.__class__.__name__."
    - "asyncio.__name__ == 'asyncio' — the module's own __name__ attribute. Verified with Python 3.14.3."
    - "asyncio.__package__ == 'asyncio' — asyncio is a package; __package__ equals __name__. Verified with Python 3.14.3."
    - "asyncio.__spec__.name == 'asyncio' — the ModuleSpec's name attribute matches the module name. Verified with Python 3.14.3."
    - "asyncio.__loader__.__class__.__name__ == 'SourceFileLoader' — asyncio is loaded from source files on disk; its loader is a SourceFileLoader instance. Verified with Python 3.14.3."
    - "asyncio.__doc__.__class__.__name__ == 'str' — asyncio has a docstring; __doc__ is a str instance. Verified with Python 3.14.3."
    - "asyncio.__spec__.__class__.__name__ == 'ModuleSpec' — the spec object is an importlib.machinery.ModuleSpec instance. Verified with Python 3.14.3."
    - "asyncio.__path__.__class__.__name__ == 'list' — asyncio is a package; __path__ is a list. Verified with Python 3.14.3."
    - "asyncio.__loader__.name == 'asyncio' — SourceFileLoader.name attribute matches the module name. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.__name__ and asyncio.__package__ identity
#
# asyncio.__name__ == 'asyncio'
# asyncio.__package__ == 'asyncio'
#
# asyncio is a package; its __name__ and __package__ are both 'asyncio'.
# New to asyncio_extra202.
# ---------------------------------------------------------------------------

table asyncio_extra202.module_name_package:
  description: "asyncio.__name__ and asyncio.__package__ both equal 'asyncio'; asyncio is a package so name equals package; new to asyncio_extra202"
  kind: python_call_eq
  category: module_identity
  id_prefix: asynciomod202

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,
       "__name__.__eq__",
       ["asyncio"],
       true,
       "asyncio.__name__.__eq__('asyncio') == True — the module's __name__ attribute equals 'asyncio'; new to asyncio_extra202"]
    - [module_name_len_eq_7,
       "__name__.__len__",
       [],
       7,
       "asyncio.__name__.__len__() == 7 — 'asyncio' has 7 characters; new to asyncio_extra202"]
    - [module_package_eq,
       "__package__.__eq__",
       ["asyncio"],
       true,
       "asyncio.__package__.__eq__('asyncio') == True — asyncio is a package so __package__ equals __name__; new to asyncio_extra202"]
    - [module_package_class_eq,
       "__package__.__class__.__name__.__eq__",
       ["str"],
       true,
       "asyncio.__package__.__class__.__name__.__eq__('str') == True — __package__ is a str instance; new to asyncio_extra202"]

