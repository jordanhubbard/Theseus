spec: dc3391
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 673 (dc3391): __int__, __float__, __complex__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "Theme: __int__/__float__/__complex__ dict-presence (int(x), float(x), complex(x))."
    - "decimal.Decimal defines __int__ (true) and __float__ (true) in its own __dict__: int(Decimal('3')) and float(Decimal('3.14')) are valid Python expressions."
    - "decimal.Decimal does NOT define __complex__ in its own __dict__ (false): complex() on a Decimal is not directly supported via __complex__."
    - "decimal.Decimal DOES define __int__ in its own __dict__: true. Decimal supports int(); __int__ returns the integer value (truncated toward zero), consistent with int(Decimal('3')) == 3."
    - "decimal.Decimal DOES define __float__ in its own __dict__: true. Decimal supports float(); __float__ returns the nearest IEEE 754 double-precision approximation, consistent with float(Decimal('3.14'))."
    - "decimal.Decimal does NOT define __complex__ in its own __dict__: false. Decimal is not a complex numeric type and does not implement __complex__; complex() on a Decimal is not directly supported."
    - "decimal.Context does NOT define __int__, __float__, or __complex__ in its own __dict__: Context is a precision/rounding configuration object, not a numeric operand."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow are exception subclasses with no arithmetic protocol defined in their own __dict__."
    - "decimal.Decimal is unique among the covered types in this wave: it is the only type defining __int__ and __float__ (true), reflecting its status as a complete IEEE 754 numeric type supporting integer and float conversion. However, Decimal does not define __complex__ (false)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __int__ dict-presence — operator.contains(Cls.__dict__, '__int__')
#
# decimal.Decimal DOES define __int__ in its own __dict__: true.
# int(d) is supported by Decimal; __int__ returns the integer value
# truncated toward zero (e.g., int(Decimal('3.7')) == 3).
# All other decimal classes: false.
# ---------------------------------------------------------------------------

table dc3391.int:
  description: "decimal types __int__ dict-presence checks; wave 673"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3391

  columns: [id, function, args, expected]
  rows:
    - ["dc3391001", operator.contains, [decimal.Decimal.__dict__,          "__int__"], true]
    - ["dc3391002", operator.contains, [decimal.Context.__dict__,           "__int__"], false]
    - ["dc3391003", operator.contains, [decimal.DecimalException.__dict__,  "__int__"], false]
    - ["dc3391004", operator.contains, [decimal.InvalidOperation.__dict__,  "__int__"], false]
    - ["dc3391005", operator.contains, [decimal.Overflow.__dict__,          "__int__"], false]
    - ["dc3391006", operator.contains, [decimal.Underflow.__dict__,         "__int__"], false]

