spec: socket_extra108
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra107.zspec.zsdl — covers socket SO_* option constants (SO_REUSEADDR, SO_KEEPALIVE, SO_SNDBUF, SO_RCVBUF, SO_REUSEPORT) class names and integer values / socket.error and socket.timeout class identity and MRO (table + invariants)."
    - "socket_extra106.zspec.zsdl — covers IPPROTO_TCP/UDP/IP/ICMP/IPV6 class names (all 'int') and integer values / SOL_SOCKET class name (int) and value (65535) / IPPROTO_TCP class module ('builtins') and bases ('object') (table + invariants)."
    - "socket_extra105.zspec.zsdl — covers AF_*/SOCK_* class module/qualname/mro / AF_*/SOCK_* IntEnum base and int values / AddressFamily/SocketKind name/module/metaclass/base identity (table + invariants)."
    - "socket_extra104.zspec.zsdl — covers socket.socket C-method types (method_descriptor) / socket.socket method qualname lengths / socket.socket Python-level method types (function) and class identity (table + invariants)."
    - "socket_extra103.zspec.zsdl — covers socket.inet_aton/ntoa/pton/ntop __class__.__name__ and qualname lengths / htons/htonl/ntohs/ntohl class names and qualname lengths / herror/gaierror __mro__.__len__()==5 / AddressFamily/SocketKind __mro__.__len__()==6 (table + invariants)."
    - "socket_extra102.zspec.zsdl — covers socket.socket/__qualname__/__name__/__len__()==6 / error/__name__.__eq__('OSError') / herror/gaierror qualname/module/bases / AddressFamily/SocketKind qualname lengths and module (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module-level function qualname lengths / SocketIO class metaclass/module/bases (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC and SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ (table + invariants)."
  notes:
    - "This spec extends socket through socket_extra107; it does NOT duplicate invariants present in those files."
    - "Wave 270 theme: socket module-level function class names (gethostname, gethostbyname, getaddrinfo, getnameinfo, getfqdn, setdefaulttimeout, getdefaulttimeout, create_connection) — mix of builtin_function_or_method (_socket) and function (socket module Python functions)."
    - "type(socket.gethostname).__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.gethostbyname).__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.getaddrinfo).__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.getnameinfo).__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getnameinfo.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.getfqdn).__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.setdefaulttimeout).__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.getdefaulttimeout).__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.create_connection).__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__qualname__ == 'getfqdn'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__code__.co_name == 'getfqdn'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__code__.co_name == 'create_connection'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__code__.co_argcount == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: The socket module has a dual structure: C-level functions from _socket (builtin_function_or_method, module=='_socket') and Python-level wrapper/utility functions from Lib/socket.py (function, module=='socket'). gethostname/gethostbyname/getnameinfo/setdefaulttimeout/getdefaulttimeout are C-level (_socket). getaddrinfo/getfqdn/create_connection are Python-level (socket)."
    - "Note: socket_extra99 anchors module-level function qualname lengths; this spec anchors function class names and module equality, covering the C vs Python distinction."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# type(socket.gethostname).__name__.__eq__('builtin_function_or_method')
# socket.gethostname.__module__.__eq__('_socket')
# type(socket.gethostbyname).__name__.__eq__('builtin_function_or_method')
# socket.gethostbyname.__module__.__eq__('_socket')
# type(socket.getnameinfo).__name__.__eq__('builtin_function_or_method')
#
# Wave 270 theme: C-level socket name resolution functions from _socket.
#
# gethostname, gethostbyname, and getnameinfo are C-level functions from the
# _socket C extension module. Their type is builtin_function_or_method and
# their __module__ is '_socket'. socket_extra99 anchors qualname lengths for
# module-level socket functions; no prior socket spec anchors the type names
# and module equality for gethostname/gethostbyname/getnameinfo as a grouped
# table under sockfn108. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra108.C_level_name_resolution_functions:
  description: "type(gethostname).__name__.__eq__('builtin_function_or_method')==True / gethostname.__module__.__eq__('_socket')==True / type(gethostbyname).__name__.__eq__('builtin_function_or_method')==True / gethostbyname.__module__.__eq__('_socket')==True / type(getnameinfo).__name__.__eq__('builtin_function_or_method')==True — gethostname/gethostbyname/getnameinfo are C-level from _socket; type is builtin_function_or_method; extra99 anchors qualname lengths; no prior spec anchors type names and modules for these functions; first sockfn108 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: sockfn108

  columns: [id, function, args, expected, description]
  rows:
    - [gethostname_type,     "gethostname.__class__.__name__.__eq__",   ["builtin_function_or_method"], true, "type(gethostname) is 'builtin_function_or_method' (C-level function from _socket C extension)"]
    - [gethostname_module,   "gethostname.__module__.__eq__",           ["_socket"],                   true, "gethostname.__module__ is '_socket' (C extension module, not the Python 'socket' wrapper)"]
    - [gethostbyname_type,   "gethostbyname.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "type(gethostbyname) is 'builtin_function_or_method' (C-level function from _socket C extension)"]
    - [gethostbyname_module, "gethostbyname.__module__.__eq__",         ["_socket"],                   true, "gethostbyname.__module__ is '_socket' (C extension module)"]
    - [getnameinfo_type,     "getnameinfo.__class__.__name__.__eq__",   ["builtin_function_or_method"], true, "type(getnameinfo) is 'builtin_function_or_method' (C-level function from _socket C extension)"]

# ---------------------------------------------------------------------------
# socket.getnameinfo.__module__.__eq__('_socket')
# type(socket.getaddrinfo).__name__.__eq__('function')
# socket.getaddrinfo.__module__.__eq__('socket')
# type(socket.getfqdn).__name__.__eq__('function')
# socket.getfqdn.__module__.__eq__('socket')
#
# Wave 270 theme: C vs Python distinction for getnameinfo vs getaddrinfo/getfqdn.
#
# getnameinfo is C-level (_socket), but getaddrinfo and getfqdn are Python-level
# (socket module, Lib/socket.py). This is the key structural contrast for name
# resolution functions. getaddrinfo.__module__=='socket' and
# getfqdn.__module__=='socket'. No prior socket spec anchors this C vs Python
# distinction for name resolution functions as a grouped table under sockfn108.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra108.C_vs_python_name_resolution_contrast:
  description: "getnameinfo.__module__.__eq__('_socket')==True / type(getaddrinfo).__name__.__eq__('function')==True / getaddrinfo.__module__.__eq__('socket')==True / type(getfqdn).__name__.__eq__('function')==True / getfqdn.__module__.__eq__('socket')==True — getnameinfo is C-level (_socket); getaddrinfo and getfqdn are Python-level (socket); key C vs Python distinction for name resolution; no prior spec anchors this contrast; first sockfn108 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: sockfn108

  columns: [id, function, args, expected, description]
  rows:
    - [getnameinfo_module,   "getnameinfo.__module__.__eq__",            ["_socket"], true, "getnameinfo.__module__ is '_socket' (C-level; contrasts with getaddrinfo which is Python-level)"]
    - [getaddrinfo_type,     "getaddrinfo.__class__.__name__.__eq__",    ["function"], true, "type(getaddrinfo) is 'function' (Python-level function in Lib/socket.py; not C-level builtin)"]
    - [getaddrinfo_module,   "getaddrinfo.__module__.__eq__",            ["socket"],   true, "getaddrinfo.__module__ is 'socket' (Python module; Python wrapper around the C-level resolver)"]
    - [getfqdn_type,         "getfqdn.__class__.__name__.__eq__",        ["function"], true, "type(getfqdn) is 'function' (Python-level function in Lib/socket.py; returns fully qualified domain name)"]
    - [getfqdn_module,       "getfqdn.__module__.__eq__",                ["socket"],   true, "getfqdn.__module__ is 'socket' (Python module; pure Python utility wrapping gethostname and getaddrinfo)"]

# ---------------------------------------------------------------------------
# type(socket.setdefaulttimeout).__name__.__eq__('builtin_function_or_method')
# type(socket.getdefaulttimeout).__name__.__eq__('builtin_function_or_method')
# type(socket.create_connection).__name__.__eq__('function')
# socket.getfqdn.__code__.co_name.__eq__('getfqdn')
# socket.getfqdn.__code__.co_argcount.__eq__(1)
#
# Wave 270 theme: timeout functions C-level identity / create_connection Python / getfqdn code attrs.
#
# setdefaulttimeout and getdefaulttimeout are C-level functions from _socket.
# create_connection is a Python-level function (Lib/socket.py). getfqdn is
# also Python-level: its __code__.co_name is 'getfqdn' and co_argcount is 1
# (optional 'name' parameter; defaults to ''). No prior socket spec anchors
# setdefaulttimeout/getdefaulttimeout type names or create_connection type
# or getfqdn code attributes as a grouped table under sockfn108.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra108.timeout_and_connection_function_types_and_getfqdn_code:
  description: "type(setdefaulttimeout).__name__.__eq__('builtin_function_or_method')==True / type(getdefaulttimeout).__name__.__eq__('builtin_function_or_method')==True / type(create_connection).__name__.__eq__('function')==True / getfqdn.__code__.co_name.__eq__('getfqdn')==True / getfqdn.__code__.co_argcount.__eq__(1)==True — setdefaulttimeout/getdefaulttimeout are C-level; create_connection is Python-level; getfqdn has co_argcount=1 (optional name param); no prior spec anchors these as group; first sockfn108 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: sockfn108

  columns: [id, function, args, expected, description]
  rows:
    - [setdefaulttimeout_type,   "setdefaulttimeout.__class__.__name__.__eq__",   ["builtin_function_or_method"], true, "type(setdefaulttimeout) is 'builtin_function_or_method' (C-level from _socket; sets global socket timeout)"]
    - [getdefaulttimeout_type,   "getdefaulttimeout.__class__.__name__.__eq__",   ["builtin_function_or_method"], true, "type(getdefaulttimeout) is 'builtin_function_or_method' (C-level from _socket; returns global socket timeout)"]
    - [create_connection_type,   "create_connection.__class__.__name__.__eq__",   ["function"],                   true, "type(create_connection) is 'function' (Python-level function in Lib/socket.py; convenience wrapper)"]
    - [getfqdn_co_name,          "getfqdn.__code__.co_name.__eq__",               ["getfqdn"],                    true, "getfqdn.__code__.co_name is 'getfqdn' (def statement name matches function name)"]
    - [getfqdn_co_argcount,      "getfqdn.__code__.co_argcount.__eq__",           [1],                            true, "getfqdn.__code__.co_argcount is 1 (takes optional 'name' parameter; defaults to '' for gethostname())"]

# ---------------------------------------------------------------------------
# type(socket.gethostname).__name__.__eq__('builtin_function_or_method') — standalone
#
# type(socket.gethostname).__name__ is 'builtin_function_or_method'. gethostname
# is the simplest socket name resolution function — it takes no arguments and
# returns the standard hostname of the local machine as a string. It is a direct
# C-level function from the _socket extension, not a Python wrapper. Because it
# takes no arguments, it has no co_argcount (no __code__ attribute). Its type
# 'builtin_function_or_method' distinguishes it from Python-level functions
# like getfqdn. No prior socket spec anchors gethostname's type name as a
# standalone under sockfn108. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra108.gethostname_is_builtin:
  description: "type(socket.gethostname).__name__.__eq__('builtin_function_or_method') == True — gethostname is C-level from _socket; takes no arguments; returns local hostname as string; no __code__ attribute (contrast with Python-level getfqdn); type 'builtin_function_or_method' vs 'function' for Python-level wrappers; no prior spec anchors gethostname type as standalone; first standalone under sockfn108"
  category: function_identity
  kind: python_call_eq
  function: "gethostname.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# type(socket.getaddrinfo).__name__.__eq__('function') — standalone
#
# type(socket.getaddrinfo).__name__ is 'function'. getaddrinfo is a Python-level
# function defined in Lib/socket.py. It wraps the C-level _socket.getaddrinfo
# with additional logic (e.g., handling the timeout parameter). Its __module__
# is 'socket' (the Python wrapper module). getaddrinfo is the most general-purpose
# address lookup function, returning a list of (family, type, proto, canonname,
# sockaddr) tuples. Unlike C-level gethostbyname (which only returns IPv4),
# getaddrinfo supports both IPv4 and IPv6. No prior socket spec anchors
# getaddrinfo type as a standalone under sockfn108.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra108.getaddrinfo_is_function:
  description: "type(socket.getaddrinfo).__name__.__eq__('function') == True — getaddrinfo is Python-level (Lib/socket.py); wraps C-level resolver with timeout support; module is 'socket' (Python wrapper); supports both IPv4 and IPv6 (unlike C-level gethostbyname); returns list of (family, type, proto, canonname, sockaddr) tuples; no prior spec anchors getaddrinfo type as standalone; first standalone under sockfn108"
  category: function_identity
  kind: python_call_eq
  function: "getaddrinfo.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getfqdn.__code__.co_argcount.__eq__(1) — standalone
#
# socket.getfqdn.__code__.co_argcount is 1. getfqdn takes a single optional
# parameter 'name' which defaults to '' (empty string). When name is '' or not
# provided, getfqdn calls gethostname() to get the local hostname and then
# resolves it via getaddrinfo. co_argcount==1 includes the 'name' parameter
# (all non-kw-only, non-variadic args). The function is defined in Lib/socket.py.
# No prior socket spec anchors getfqdn co_argcount as a standalone under
# sockfn108. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra108.getfqdn_co_argcount_1:
  description: "socket.getfqdn.__code__.co_argcount.__eq__(1) == True — getfqdn takes 1 arg (optional 'name'; defaults to ''); when name=='' calls gethostname() then getaddrinfo; Python-level function (has __code__); co_argcount counts non-kw-only non-variadic args; no prior spec anchors getfqdn co_argcount as standalone; first standalone under sockfn108"
  category: function_identity
  kind: python_call_eq
  function: "getfqdn.__code__.co_argcount.__eq__"
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# type(socket.getfqdn).__name__.__eq__('function') — standalone
#
# type(socket.getfqdn).__name__ is 'function'. getfqdn is a pure Python utility
# function defined in Lib/socket.py. It returns the fully qualified domain name
# (FQDN) for a given hostname, or for the local machine if no hostname is given.
# Being Python-level, getfqdn has a __code__ attribute (unlike C-level functions).
# Its __module__ is 'socket'. This contrasts with getnameinfo (C-level,
# builtin_function_or_method, module '_socket') despite both being name
# resolution functions. No prior socket spec anchors getfqdn type as a
# standalone under sockfn108. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra108.getfqdn_is_function:
  description: "type(socket.getfqdn).__name__.__eq__('function') == True — getfqdn is Python-level (Lib/socket.py); has __code__ attribute; module is 'socket'; contrasts with getnameinfo (C-level, builtin_function_or_method, module '_socket'); getfqdn returns FQDN for hostname; no prior spec anchors getfqdn type as standalone; first standalone under sockfn108"
  category: function_identity
  kind: python_call_eq
  function: "getfqdn.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# type(socket.create_connection).__name__.__eq__('function') — standalone
#
# type(socket.create_connection).__name__ is 'function'. create_connection is
# a Python-level convenience function defined in Lib/socket.py. It creates a
# TCP/IP socket and connects to a given (host, port) address, with optional
# timeout and source_address parameters. Its __code__.co_argcount is 3
# (address, timeout, source_address). Being Python-level, it has a __code__
# attribute with co_name=='create_connection'. No prior socket spec anchors
# create_connection's type name as a standalone under sockfn108.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra108.create_connection_is_function:
  description: "type(socket.create_connection).__name__.__eq__('function') == True — create_connection is Python-level (Lib/socket.py); has __code__ with co_name=='create_connection' and co_argcount==3 (address, timeout, source_address); convenience TCP connect wrapper; no prior spec anchors create_connection type as standalone; first standalone under sockfn108"
  category: function_identity
  kind: python_call_eq
  function: "create_connection.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

