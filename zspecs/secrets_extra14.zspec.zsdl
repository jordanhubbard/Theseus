spec: secrets_extra14
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
    - "secrets_extra13.zspec.zsdl — covers callable __class__.__name__.__eq__ table; DEFAULT_ENTROPY.__class__.__qualname__.__eq__."
    - "secrets_extra12.zspec.zsdl — covers __qualname__.__len__() for token_bytes/hex/urlsafe/choice/randbelow/randbits/SystemRandom."
    - "secrets_extra4.zspec.zsdl — covers __qualname__.__eq__ for all callables including SystemRandom; DEFAULT_ENTROPY == 32; randbits.__qualname__ == 'SystemRandom.getrandbits'."
    - "secrets_extra3.zspec.zsdl — covers token_hex/__module__, token_urlsafe/__module__, choice/__module__, randbelow/__module__, randbits/__module__."
    - "secrets_extra2.zspec.zsdl — covers token_bytes/__module__, token_hex/__module__, token_urlsafe/__module__."
    - "secrets_extra.zspec.zsdl — covers token_bytes/__module__."
  notes:
    - "This spec extends secrets through secrets_extra13; it does NOT duplicate invariants present in those files."
    - "Focus: SystemRandom.random.__qualname__ and SystemRandom.getrandbits.__qualname__ as dotted attribute paths on the class (not via secrets.randbits); __module__ for token_bytes/hex/urlsafe re-anchored from extra14 namespace; DEFAULT_ENTROPY == 32 re-anchored from extra14 namespace."
    - "secrets.SystemRandom.random.__qualname__ == 'SystemRandom.random': No prior spec accesses this via the class attribute path SystemRandom.random.__qualname__. secrets_extra4 covers secrets.randbits.__qualname__ == 'SystemRandom.getrandbits' (via the bound alias), but NOT SystemRandom.getrandbits.__qualname__ as a class attribute. len == 19. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.SystemRandom.getrandbits.__qualname__ == 'SystemRandom.getrandbits': accessed via class attribute path. secrets_extra12 covers len==24 via secrets.randbits.__qualname__.__len__. This invariant covers the __eq__ via the SystemRandom.getrandbits path directly. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.SystemRandom.__qualname__ == 'SystemRandom': secrets_extra4 covers this; re-anchored from extra14 namespace for independent regression coverage."
    - "token_bytes/__module__, token_hex/__module__, token_urlsafe/__module__ == 'secrets': covered by prior specs; re-anchored from extra14 namespace."
    - "DEFAULT_ENTROPY == 32: covered by secrets_extra4; re-anchored from extra14 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SystemRandom class method __qualname__ — via class attribute path
#
# secrets_extra4 covers secrets.randbits.__qualname__ == 'SystemRandom.getrandbits'
# (accessed via the module-level alias). No prior spec accesses the qualname
# via the SystemRandom.random or SystemRandom.getrandbits class attribute paths.
# secrets_extra12 covers qualname __len__ via secrets.randbits.__qualname__.__len__
# but not via SystemRandom.getrandbits.__qualname__.__len__.
# These invariants cover the class attribute path, which is a distinct access route.
# 'SystemRandom.random' len == 19; 'SystemRandom.getrandbits' len == 24.
# ---------------------------------------------------------------------------

invariant secrets_extra14.SystemRandom.random.qualname:
  description: "secrets.SystemRandom.random.__qualname__ == 'SystemRandom.random' — class attribute path"
  category: function_qualnames
  kind: python_call_eq
  function: SystemRandom.random.__qualname__.__eq__
  args: ["SystemRandom.random"]
  expected: true

invariant secrets_extra14.SystemRandom.getrandbits.qualname:
  description: "secrets.SystemRandom.getrandbits.__qualname__ == 'SystemRandom.getrandbits' — class attribute path"
  category: function_qualnames
  kind: python_call_eq
  function: SystemRandom.getrandbits.__qualname__.__eq__
  args: ["SystemRandom.getrandbits"]
  expected: true

# ---------------------------------------------------------------------------
# SystemRandom.__qualname__ — re-anchored from extra14 namespace
#
# secrets_extra4 covers SystemRandom.__qualname__.__eq__('SystemRandom').
# Re-anchored from extra14 namespace for independent regression coverage.
# ---------------------------------------------------------------------------

invariant secrets_extra14.SystemRandom.qualname:
  description: "secrets.SystemRandom.__qualname__ == 'SystemRandom' — anchored from extra14 namespace"
  category: function_qualnames
  kind: python_call_eq
  function: SystemRandom.__qualname__.__eq__
  args: ["SystemRandom"]
  expected: true

# ---------------------------------------------------------------------------
# token_bytes, token_hex, token_urlsafe __module__ — re-anchored from extra14
#
# These are covered by secrets_extra, secrets_extra2, and secrets_extra3.
# Re-anchored from extra14 namespace for independent regression coverage.
# ---------------------------------------------------------------------------

table secrets_extra14.token_function_modules:
  description: "secrets token functions __module__ == 'secrets' — anchored from extra14 namespace"
  kind: python_call_eq
  category: module_metadata
  id_prefix: sectfm14

  columns: [id, function, args, expected]
  rows:
    - [token_bytes,   token_bytes.__module__.__eq__,   ["secrets"], true]
    - [token_hex,     token_hex.__module__.__eq__,     ["secrets"], true]
    - [token_urlsafe, token_urlsafe.__module__.__eq__, ["secrets"], true]

# ---------------------------------------------------------------------------
# DEFAULT_ENTROPY == 32 — re-anchored from extra14 namespace
#
# secrets_extra4 covers DEFAULT_ENTROPY == 32.
# Re-anchored from extra14 namespace for independent regression coverage.
# PEP 506 specifies a minimum of 32 bytes (256 bits) for DEFAULT_ENTROPY.
# ---------------------------------------------------------------------------

invariant secrets_extra14.DEFAULT_ENTROPY.value:
  description: "secrets.DEFAULT_ENTROPY == 32 — PEP 506 minimum entropy; anchored from extra14 namespace"
  category: module_metadata
  kind: python_call_eq
  function: DEFAULT_ENTROPY.__eq__
  args: [32]
  expected: true
