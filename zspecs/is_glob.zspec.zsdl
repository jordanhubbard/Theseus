spec: is_glob
version: ">=4.0.3"
backend: node(is-glob)

docs: https://www.npmjs.com/package/is-glob

provenance:
  derived_from:
    - "is-glob README — https://www.npmjs.com/package/is-glob"
    - "Test vectors verified with is-glob via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-glob source"
  notes:
    - "is-glob is an npm package. Install: npm install is-glob"
    - "Returns true if the string contains glob pattern characters."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_glob.check:
  kind: node_module_call_eq
  function: ~
  category: path
  id_prefix: isglob

  columns: [id, args, expected]
  rows:
    - [wildcard,   ["*.js"],    true]
    - [plain,      ["foo.js"],  false]
    - [braces,     ["{a,b}"],   true]
