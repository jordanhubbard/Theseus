spec: contextlib_extra16
version: ">=3.10"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib.zspec.zsdl through contextlib_extra15.zspec.zsdl."
    - "contextlib_extra15 covers: redirect_stdout/redirect_stderr MRO[1]/[2]; nullcontext MRO[1]/[2]; AsyncExitStack MRO len/[1]/[2]/[3]; aclosing MRO[2]; suppress.__name__ standalone."
    - "contextlib_extra14 covers: ExitStack MRO[1]/[2]/[3]; aclosing MRO len/[1]; nullcontext/closing/redirect_stdout __module__ standalone; ContextDecorator/AsyncContextDecorator/__qualname__; AbstractContextManager/AbstractAsyncContextManager __qualname__."
    - "contextlib_extra12 covers: contextmanager/__qualname__; asynccontextmanager/__qualname__; nullcontext/__qualname__; aclosing/__qualname__; AsyncExitStack/__qualname__; redirect_stdout/__qualname__; redirect_stderr/__qualname__."
    - "NOT yet covered: contextlib.suppress.__qualname__ (standalone __eq__ invariant)."
    - "NOT yet covered: contextlib.closing.__qualname__ (standalone __eq__ invariant)."
    - "NOT yet covered: contextlib.ExitStack.__qualname__ (standalone __eq__ invariant)."
    - "NOT yet covered: contextlib.suppress.__mro__[1].__name__ == 'AbstractContextManager'."
    - "NOT yet covered: contextlib.suppress.__mro__[2].__name__ == 'ABC'."
    - "NOT yet covered: contextlib.nullcontext.__mro__[3].__name__ == 'ABC'."
    - "NOT yet covered: contextlib.nullcontext.__mro__[4].__name__ == 'object'."
    - "NOT yet covered: contextlib.redirect_stderr.__module__ (standalone __eq__ invariant)."
    - "contextlib.suppress.__qualname__ == 'suppress' — top-level class, qualname equals name."
    - "contextlib.closing.__qualname__ == 'closing' — top-level class, qualname equals name."
    - "contextlib.ExitStack.__qualname__ == 'ExitStack' — top-level class, qualname equals name."
    - "contextlib.suppress MRO: [suppress, AbstractContextManager, ABC, object] — MRO[1] is AbstractContextManager."
    - "contextlib.suppress.__mro__[2].__name__ == 'ABC' — suppress MRO[2] is ABC."
    - "contextlib.nullcontext.__mro__[3].__name__ == 'ABC' — nullcontext MRO[3] is ABC."
    - "contextlib.nullcontext.__mro__[4].__name__ == 'object' — nullcontext MRO[4] is object."
    - "contextlib.redirect_stderr.__module__ == 'contextlib' — standalone __eq__ invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# suppress, closing, ExitStack — __qualname__ standalone invariants
#
# contextlib_extra12 covers __qualname__ for contextmanager, asynccontextmanager,
# nullcontext, aclosing, AsyncExitStack, redirect_stdout, redirect_stderr.
# contextlib_extra14 covers ContextDecorator and AsyncContextDecorator __qualname__.
# No prior spec covers suppress.__qualname__, closing.__qualname__, or
# ExitStack.__qualname__ as standalone invariants.
# ---------------------------------------------------------------------------

invariant contextlib_extra16.suppress.qualname:
  description: "contextlib.suppress.__qualname__ == 'suppress' — top-level class, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: suppress.__qualname__.__eq__
  args: ["suppress"]
  expected: true

invariant contextlib_extra16.closing.qualname:
  description: "contextlib.closing.__qualname__ == 'closing' — top-level class, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: closing.__qualname__.__eq__
  args: ["closing"]
  expected: true

invariant contextlib_extra16.ExitStack.qualname:
  description: "contextlib.ExitStack.__qualname__ == 'ExitStack' — top-level class, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: ExitStack.__qualname__.__eq__
  args: ["ExitStack"]
  expected: true

# ---------------------------------------------------------------------------
# suppress MRO intermediate entries
#
# contextlib_extra15 confirms suppress.__name__ == 'suppress' as standalone.
# The suppress MRO is [suppress, AbstractContextManager, ABC, object].
# Its length was verified in contextlib_extra11 == 4 (via __abstractmethods__ coverage).
# No prior spec checks suppress.__mro__[1] or suppress.__mro__[2] by __getitem__.
# ---------------------------------------------------------------------------

invariant contextlib_extra16.suppress.mro_1:
  description: "contextlib.suppress.__mro__[1].__name__ == 'AbstractContextManager' — direct abstract base"
  category: suppress_mro
  kind: python_call_eq
  function: suppress.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "AbstractContextManager"

invariant contextlib_extra16.suppress.mro_2:
  description: "contextlib.suppress.__mro__[2].__name__ == 'ABC' — ABC in suppress MRO"
  category: suppress_mro
  kind: python_call_eq
  function: suppress.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "ABC"

# ---------------------------------------------------------------------------
# nullcontext MRO tail entries
#
# contextlib_extra15 covers nullcontext MRO[1] and MRO[2].
# The nullcontext MRO is [nullcontext, AbstractContextManager,
# AbstractAsyncContextManager, ABC, object] — length 5 (verified in extra11).
# No prior spec checks nullcontext MRO[3] (ABC) or MRO[4] (object).
# ---------------------------------------------------------------------------

invariant contextlib_extra16.nullcontext.mro_3:
  description: "contextlib.nullcontext.__mro__[3].__name__ == 'ABC' — ABC in nullcontext MRO"
  category: nullcontext_mro
  kind: python_call_eq
  function: nullcontext.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "ABC"

invariant contextlib_extra16.nullcontext.mro_4:
  description: "contextlib.nullcontext.__mro__[4].__name__ == 'object' — object at tail of nullcontext MRO"
  category: nullcontext_mro
  kind: python_call_eq
  function: nullcontext.__mro__.__getitem__
  args: [4]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# redirect_stderr __module__ — standalone invariant
#
# contextlib_extra14 covers redirect_stdout.__module__ == 'contextlib' as a
# standalone invariant. No prior spec covers redirect_stderr.__module__ in the
# same standalone __eq__ form.
# ---------------------------------------------------------------------------

invariant contextlib_extra16.redirect_stderr.module:
  description: "contextlib.redirect_stderr.__module__ == 'contextlib' — standalone __eq__ check"
  category: module_names
  kind: python_call_eq
  function: redirect_stderr.__module__.__eq__
  args: ["contextlib"]
  expected: true
