spec: signal
version: ">=3.5"
backend: python_module(signal)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "Python signal documentation — https://docs.python.org/3/library/signal.html"
    - "POSIX.1-2017 — The Open Group Base Specifications (signal functions)"
    - "Test vectors verified by running Python 3.14.3 signal module on macOS/Darwin 25.4.0, 2026-04-08"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
  notes:
    - "SIGINT=2, SIGTERM=15, SIGHUP=1, SIGKILL=9, SIGQUIT=3, SIGALRM=14, SIGPIPE=13 are consistent across POSIX platforms."
    - "SIGUSR1, SIGUSR2, SIGCHLD values are platform-dependent (macOS: 30, 31, 20; Linux: 10, 12, 17) and are not tested."
    - "signal.Signals is an IntEnum; values compare equal to plain ints via __eq__."
    - "signal.Handlers is an IntEnum with SIG_DFL=0 and SIG_IGN=1."
    - "signal.valid_signals() returns a set (not frozenset) on Python 3.14; type may vary."
    - "signal.strsignal() strings are OS-dependent; values verified on macOS/Darwin 25.4.0."
    - "signal.NSIG == 32 on this platform (macOS); may differ on Linux."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-08."
  created_at: "2026-04-08T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Signal constants — POSIX-consistent integer values
# SIGINT=2, SIGTERM=15, SIGHUP=1, SIGKILL=9, SIGQUIT=3, SIGALRM=14, SIGPIPE=13
# ---------------------------------------------------------------------------

table signal.constants.posix_values:
  kind: python_call_eq
  category: constants
  id_prefix: sig

  columns: [id, function, args, expected]
  rows:
    - [sigint,  SIGINT.__eq__,  [2],  true]
    - [sigterm, SIGTERM.__eq__, [15], true]
    - [sighup,  SIGHUP.__eq__,  [1],  true]
    - [sigkill, SIGKILL.__eq__, [9],  true]
    - [sigquit, SIGQUIT.__eq__, [3],  true]
    - [sigalrm, SIGALRM.__eq__, [14], true]
    - [sigpipe, SIGPIPE.__eq__, [13], true]

# ---------------------------------------------------------------------------
# Signals enum — class identity and member values
# ---------------------------------------------------------------------------

invariant signal.Signals.class_name:
  description: "signal.Signals.__name__ == 'Signals'"
  category: enum
  kind: python_call_eq
  function: Signals.__name__.__eq__
  args: ["Signals"]
  expected: true

invariant signal.Signals.SIGINT_value:
  description: "signal.Signals.SIGINT.value == 2"
  category: enum
  kind: python_call_eq
  function: Signals.SIGINT.value.__eq__
  args: [2]
  expected: true

invariant signal.Signals.SIGTERM_value:
  description: "signal.Signals.SIGTERM.value == 15"
  category: enum
  kind: python_call_eq
  function: Signals.SIGTERM.value.__eq__
  args: [15]
  expected: true

invariant signal.Signals.SIGINT_name:
  description: "signal.Signals.SIGINT.name == 'SIGINT'"
  category: enum
  kind: python_call_eq
  function: Signals.SIGINT.name.__eq__
  args: ["SIGINT"]
  expected: true

invariant signal.Signals.SIGTERM_name:
  description: "signal.Signals.SIGTERM.name == 'SIGTERM'"
  category: enum
  kind: python_call_eq
  function: Signals.SIGTERM.name.__eq__
  args: ["SIGTERM"]
  expected: true

# ---------------------------------------------------------------------------
# Handlers enum — SIG_DFL=0, SIG_IGN=1
# ---------------------------------------------------------------------------

invariant signal.Handlers.class_name:
  description: "signal.Handlers.__name__ == 'Handlers'"
  category: handlers
  kind: python_call_eq
  function: Handlers.__name__.__eq__
  args: ["Handlers"]
  expected: true

invariant signal.Handlers.SIG_DFL_value:
  description: "signal.Handlers.SIG_DFL.value == 0"
  category: handlers
  kind: python_call_eq
  function: Handlers.SIG_DFL.value.__eq__
  args: [0]
  expected: true

invariant signal.Handlers.SIG_IGN_value:
  description: "signal.Handlers.SIG_IGN.value == 1"
  category: handlers
  kind: python_call_eq
  function: Handlers.SIG_IGN.value.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# strsignal — OS-level signal description strings (macOS/Darwin)
# ---------------------------------------------------------------------------

table signal.strsignal.posix_descriptions:
  kind: python_call_eq
  category: strsignal
  id_prefix: strsignal

  columns: [id, function, args, expected]
  rows:
    - [sigint,  strsignal, [2],  "Interrupt: 2"  ]
    - [sigterm, strsignal, [15], "Terminated: 15"]
    - [sighup,  strsignal, [1],  "Hangup: 1"     ]
    - [sigkill, strsignal, [9],  "Killed: 9"     ]
    - [sigquit, strsignal, [3],  "Quit: 3"       ]
    - [sigalrm, strsignal, [14], "Alarm clock: 14"]
    - [sigpipe, strsignal, [13], "Broken pipe: 13"]

