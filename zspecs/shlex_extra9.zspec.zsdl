spec: shlex_extra9
version: ">=3.8"
backend: python_module(shlex)

docs: https://docs.python.org/3/library/shlex.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shlex.html — Python shlex module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/shlex.py"
    - "shlex_extra8.zspec.zsdl — covers __all__.__len__()==4; __all__.__class__.__name__.__len__()==4; __name__.__len__()==5; __doc__.__class__.__name__.__len__()==3; shlex.shlex.__dict__.__class__.__name__.__len__()==12; shlex.shlex.__mro__.__len__()==2; shlex.shlex.__bases__[0].__name__.__len__()==6; shlex.shlex.__qualname__.__len__()==5; shlex.shlex method __qualname__ lens for read_token(16)/get_token(15)/push_token(16)/push_source(17)/pop_source(16)/sourcehook(16)/error_leader(18)/__init__(14); split/join/quote __qualname__ lens (5/4/5); join(['hello','world'])=='hello world'."
    - "shlex_extra7.zspec.zsdl — covers split('hello world')/split with quotes/split raises ValueError/quote basic/quote with space/quote with apostrophe."
    - "shlex_extra6.zspec.zsdl — covers shlex instance attrs (quotes/commenters/escape/token/eof/debug/whitespace_split/punctuation_chars); split backslash-escaped; quote with forward-slash/underscore+dot."
  notes:
    - "This spec extends shlex_extra8.zspec.zsdl."
    - "Prior specs covered: all major behavioral split/quote/join vectors; shlex instance attribute types; __mro__/__bases__/__qualname__/__dict__ structure; __all__ membership; module-level __name__/__doc__ class names; all shlex.shlex method __qualname__ lens; split/join/quote __qualname__ lens."
    - "This spec covers NEW angles: shlex.shlex.__name__.__len__()==5; shlex.split.__name__.__len__()==5; shlex.join.__name__.__len__()==4; shlex.quote.__name__.__len__()==5; shlex.split.__module__.__len__()==5; shlex.split('a b c').__len__()==3 (three-token behavioral)."
    - "shlex.shlex.__name__ == 'shlex' (len 5) — the class name, not the module name. Both happen to be 'shlex'."
    - "shlex.split.__name__ == 'split' (len 5); __qualname__ also 'split' (len 5) — flat top-level function."
    - "shlex.split.__module__ == 'shlex' (len 5) — the module where split is defined."
    - "shlex.split('a b c') == ['a', 'b', 'c'] — three whitespace-separated tokens produce a list of len 3."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# shlex.shlex.__name__.__len__() and module-level function __name__.__len__()
#
# shlex_extra8 covered __qualname__.__len__() for split/join/quote and shlex
# class. This spec covers __name__.__len__() for the same set, confirming that
# __name__ and __qualname__ agree for all four (they are all flat, top-level):
#   shlex.shlex.__name__ == 'shlex'  (5)
#   shlex.split.__name__ == 'split'  (5)
#   shlex.join.__name__  == 'join'   (4)
#   shlex.quote.__name__ == 'quote'  (5)
# ---------------------------------------------------------------------------

table shlex_extra9.function_name_lens:
  description: "__name__.__len__() for shlex.shlex class (5), split (5), join (4), quote (5)"
  kind: python_call_eq
  category: name_attr_lengths
  id_prefix: shlex9_name

  columns: [id, function, args, expected, description]
  rows:
    - [shlex_class_name,
       shlex.__name__.__len__,
       [],
       5,
       "len(shlex.shlex.__name__) == 5 — 'shlex' (the class, not the module)"]
    - [split_name,
       split.__name__.__len__,
       [],
       5,
       "len(shlex.split.__name__) == 5 — 'split'"]
    - [join_name,
       join.__name__.__len__,
       [],
       4,
       "len(shlex.join.__name__) == 4 — 'join'"]
    - [quote_name,
       quote.__name__.__len__,
       [],
       5,
       "len(shlex.quote.__name__) == 5 — 'quote'"]

# ---------------------------------------------------------------------------
# shlex.split.__module__.__len__() == 5 — module attribution
#
# shlex.split.__module__ == 'shlex' (5 characters). This confirms that the
# split function is defined in the shlex module itself, not imported from
# another module. No prior shlex spec records __module__.__len__() for split.
# ---------------------------------------------------------------------------

invariant shlex_extra9.split.module.len:
  description: "shlex.split.__module__.__len__() == 5 — split is defined in module 'shlex' (5 characters)"
  category: name_attr_lengths
  kind: python_call_eq
  function: split.__module__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# shlex.split('a b c').__len__() == 3 — three-token behavioral
#
# Splitting the string 'a b c' on whitespace produces three tokens: ['a', 'b',
# 'c']. The result list has length 3. This extends the behavioral coverage of
# shlex_extra7 (which tested two-token splits and quoted strings) with a simple
# three-token case. The split is performed by the shlex tokenizer, which
# handles POSIX-mode splitting by default.
# ---------------------------------------------------------------------------

invariant shlex_extra9.split.three_tokens:
  description: "shlex.split('a b c').__len__() == 3 — three whitespace-separated tokens produce list of length 3"
  category: behavioral
  kind: python_call_eq
  function: split
  args: ["a b c"]
  method_chain: __len__
  method_chain_args: []
  expected: 3
