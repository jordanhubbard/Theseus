invariant concurrent_futures_extra169.cf_module_name_eq:
  description: "concurrent.futures.__name__.__eq__('concurrent.futures') returns True — concurrent.futures.__name__=='concurrent.futures' (len=18: 'concurrent'=10+'.'=1+'futures'=7=18); the __name__ of a module is its fully qualified dotted path; for the concurrent.futures package (the __init__.py), __name__=='concurrent.futures' is the top-level package identity; concurrent.futures is a namespace package under the 'concurrent' namespace package — 'concurrent' itself is a namespace package with no code, just a container for concurrent.futures; 'concurrent.futures'=18 is the longest top-level-ish package name encountered in this spec series: 'abc'=3 < 'asyncio'=7 < 'multiprocessing'=15 < 'concurrent.futures'=18; NEW in extra169: first standalone concurrent.futures.__name__ identity invariant in cfmodname169 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.__name__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra169.cf_module_package_eq:
  description: "concurrent.futures.__package__.__eq__('concurrent.futures') returns True — concurrent.futures.__package__=='concurrent.futures' (len=18; equal to __name__='concurrent.futures'=18); for a package module (a directory with __init__.py), __package__ and __name__ are always equal — both hold the full dotted package path; this contrasts with submodules: concurrent.futures._base.__package__=='concurrent.futures' (the parent package) while concurrent.futures._base.__name__=='concurrent.futures._base' (the submodule's own name); KEY: __name__==__package__ is the defining property of a Python package-level module vs a submodule; COMPARISON: abc.__package__=='' (empty string — abc is a top-level module, not a package; its __package__ is empty); multiprocessing.__package__=='multiprocessing' (equal to __name__); concurrent.futures.__package__=='concurrent.futures' (equal to __name__); NEW in extra169: first standalone concurrent.futures.__package__ identity invariant in cfmodname169 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.__package__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra169.cf_base_name_eq:
  description: "concurrent.futures._base.__name__.__eq__('concurrent.futures._base') returns True — concurrent.futures._base.__name__=='concurrent.futures._base' (len=24: 'concurrent.futures'=18+'.'=1+'_base'=5=24); _base is the private internal implementation module for concurrent.futures; it defines Future, Executor, DoneAndNotDoneFutures, PENDING/RUNNING/CANCELLED/FINISHED state constants, and the core wait() and as_completed() implementations; the underscore prefix in '_base' signals it is private — user code should not import from concurrent.futures._base directly; however, its __name__ attribute is publicly accessible and equals 'concurrent.futures._base'; 'concurrent.futures._base'=24 is the LONGEST module name path in this spec series: 'abc'=3 < 'asyncio.tasks'=13 < 'asyncio.events'=14 < 'asyncio.runners'=15 < 'multiprocessing.process'=23 < 'concurrent.futures._base'=24; NEW in extra169: first standalone concurrent.futures._base.__name__ invariant in cfbasename169 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.__name__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra169.cf_spec_class_is_ModuleSpec:
  description: "concurrent.futures.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — concurrent.futures.__spec__.__class__.__name__=='ModuleSpec' (len=10: 'Module'=6+'Spec'=4=10); every module imported by Python 3.4+ via importlib has a __spec__ attribute of type importlib.machinery.ModuleSpec; ModuleSpec holds: name (the module's dotted name), loader (the loader used to load the module), submodule_search_locations (for packages, the list of directories to search), origin (the file path), and other metadata; ModuleSpec.__class__.__name__=='ModuleSpec' is an invariant of any importlib-loaded module; 'ModuleSpec'=10 chars: 'Module'=6+'Spec'=4=10; NOTE: concurrent.futures is a package so its __spec__.submodule_search_locations is not None; this is the universal module metadata type across all standard library modules; NEW in extra169: first standalone concurrent.futures.__spec__.__class__.__name__ invariant in cfspecname169 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant concurrent_futures_extra169.cf_doc_class_is_str:
  description: "concurrent.futures.__doc__.__class__.__name__.__eq__('str') returns True — concurrent.futures.__doc__.__class__.__name__=='str' (len=3: 's'+'t'+'r'=3); the concurrent.futures package docstring is a str instance: 'Execute computations asynchronously using threads or processes.'; __doc__ is a str for any module that has a docstring; 'str'=3 is the shortest type name length encountered in this spec series — matching 'abc'=3 (the module name) and 'run'=3 (asyncio.run.__name__ from extra171); KEY: __doc__.__class__.__name__=='str' holds for any module with a docstring (as opposed to NoneType if the module has no docstring); the doc attribute also being a str is a universal invariant for all documented Python modules; COMPARISON of class name lengths in this spec: 'str'=3 < 'ModuleSpec'=10 < (other values); NEW in extra169: first standalone concurrent.futures.__doc__.__class__.__name__ invariant in cfdocname169 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
