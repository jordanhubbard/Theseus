spec: uuid_extra503
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module classes, functions, and namespace constants"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers UUID and SafeUUID __qualname__ identity, uuid generation function names, and namespace constant class identity"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra503.qualname_checks:
  description: "uuid module class and function __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: UE503

  columns: [id, function, args, expected]
  rows:
    - [id001, uuid.UUID.__qualname__.__eq__, ["UUID"], true]
    - [id002, uuid.SafeUUID.__qualname__.__eq__, ["SafeUUID"], true]
    - [id003, uuid.uuid1.__qualname__.__eq__, ["uuid1"], true]
    - [id004, uuid.uuid3.__qualname__.__eq__, ["uuid3"], true]
    - [id005, uuid.uuid4.__qualname__.__eq__, ["uuid4"], true]
    - [id006, uuid.uuid5.__qualname__.__eq__, ["uuid5"], true]

table uuid_extra503.namespace_class_checks:
  description: "uuid namespace constant class name identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: UE503N

  columns: [id, function, args, expected]
  rows:
    - [id001, uuid.NAMESPACE_DNS.__class__.__name__.__eq__, ["UUID"], true]
    - [id002, uuid.NAMESPACE_URL.__class__.__name__.__eq__, ["UUID"], true]
    - [id003, uuid.NAMESPACE_OID.__class__.__name__.__eq__, ["UUID"], true]
    - [id004, uuid.NAMESPACE_X500.__class__.__name__.__eq__, ["UUID"], true]
