spec: concurrent_futures_extra1816
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 568 (_extra1816): __format__ string formatting protocol; __reduce__/__copy__/__deepcopy__ copy/pickle protocol; executor attribute dict-presence checks for concurrent.futures types."
    - "concurrent.futures.Future does not define __repr__ (uses object.__repr__)."
    - "ThreadPoolExecutor.submit is defined directly; map is inherited from Executor."
    - "Executor.submit is abstract (not in Executor.__dict__ as a concrete method)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra1816.format_protocol:
  description: "concurrent.futures types __format__/__repr__/__str__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1816

  columns: [id, function, args, expected]
  rows:
    - ["cf1816001", "concurrent.futures.Future.__dict__.__contains__", ["__format__"], false]
    - ["cf1816002", "concurrent.futures.Future.__dict__.__contains__", ["__repr__"], false]
    - ["cf1816003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__repr__"], false]
    - ["cf1816004", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__repr__"], false]
    - ["cf1816005", "concurrent.futures.Future.__dict__.__contains__", ["__str__"], false]
    - ["cf1816006", "concurrent.futures.Executor.__dict__.__contains__", ["__repr__"], false]
    - ["cf1816007", "concurrent.futures.Executor.__dict__.__contains__", ["__str__"], false]
    - ["cf1816008", "concurrent.futures.Future.__dict__.__contains__", ["__format__"], false]

table concurrent_futures_extra1816.copy_protocol:
  description: "concurrent.futures types __reduce__/__copy__/__deepcopy__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1816

  columns: [id, function, args, expected]
  rows:
    - ["cf1816101", "concurrent.futures.Future.__dict__.__contains__", ["__reduce__"], false]
    - ["cf1816102", "concurrent.futures.Future.__dict__.__contains__", ["__copy__"], false]
    - ["cf1816103", "concurrent.futures.Future.__dict__.__contains__", ["__deepcopy__"], false]
    - ["cf1816104", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__reduce__"], false]
    - ["cf1816105", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__reduce__"], false]
    - ["cf1816106", "concurrent.futures.Executor.__dict__.__contains__", ["__reduce__"], false]
    - ["cf1816107", "concurrent.futures.Executor.__dict__.__contains__", ["__copy__"], false]
    - ["cf1816108", "concurrent.futures.Executor.__dict__.__contains__", ["__deepcopy__"], false]

table concurrent_futures_extra1816.executor_attrs:
  description: "Executor subclass attribute dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1816

  columns: [id, function, args, expected]
  rows:
    - ["cf1816201", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["submit"], true]
    - ["cf1816202", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["map"], false]
    - ["cf1816203", "concurrent.futures.Executor.__dict__.__contains__", ["map"], true]
    - ["cf1816204", "concurrent.futures.Executor.__dict__.__contains__", ["submit"], false]
    - ["cf1816205", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["shutdown"], true]
    - ["cf1816206", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["submit"], true]
    - ["cf1816207", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["shutdown"], true]
    - ["cf1816208", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__init__"], true]
    - ["cf1816209", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__init__"], true]
    - ["cf1816210", "concurrent.futures.Future.__dict__.__contains__", ["__init__"], true]
