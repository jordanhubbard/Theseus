spec: io_extra145
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.UnsupportedOperation class identity (__name__, __module__, __qualname__, __class__.__name__), multiple-inheritance structure (__bases__.__len__(), bases[0].__name__='OSError', bases[1].__name__='ValueError'), and MRO structure (__mro__.__len__()=6, mro names)."
    - "io.UnsupportedOperation is unusual: it inherits from BOTH OSError and ValueError, making it catchable as either an OS-level error or a ValueError."
    - "io.UnsupportedOperation.__name__ == 'UnsupportedOperation' (length 20)."
    - "io.UnsupportedOperation.__module__ == 'io' (length 2)."
    - "io.UnsupportedOperation.__bases__.__len__() == 2 (OSError at index 0, ValueError at index 1)."
    - "io.UnsupportedOperation.__mro__.__len__() == 6: UnsupportedOperation, OSError, ValueError, Exception, BaseException, object."
    - "type(io.UnsupportedOperation).__name__ == 'type' — the metaclass is the plain type, not ABCMeta."
    - "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' (length 7); bases[1].__name__ == 'ValueError' (length 10)."
    - "io.UnsupportedOperation.__mro__ is a tuple: __mro__.__class__.__name__ == 'tuple'."
    - "io.UnsupportedOperation.__bases__ is a tuple: __bases__.__class__.__name__ == 'tuple'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.UnsupportedOperation class identity
# UnsupportedOperation is defined in the io module (Python layer).
# __name__ == 'UnsupportedOperation' (20), __module__ == 'io' (2),
# __qualname__ == 'UnsupportedOperation' (20), __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

table io_extra145.UnsupportedOperation_class_identity:
  description: "io.UnsupportedOperation class identity: __name__='UnsupportedOperation' (20), __module__='io' (2), __qualname__='UnsupportedOperation' (20), __class__.__name__='type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: iounop145

  columns: [id, function, args, expected]
  rows:
    - [name_eq,      UnsupportedOperation.__name__.__eq__,          ["UnsupportedOperation"], true]
    - [name_len,     UnsupportedOperation.__name__.__len__,         [],                       20]
    - [module_eq,    UnsupportedOperation.__module__.__eq__,        ["io"],                   true]
    - [module_len,   UnsupportedOperation.__module__.__len__,       [],                       2]
    - [qualname_eq,  UnsupportedOperation.__qualname__.__eq__,      ["UnsupportedOperation"], true]
    - [qualname_len, UnsupportedOperation.__qualname__.__len__,     [],                       20]
    - [cls_eq,       UnsupportedOperation.__class__.__name__.__eq__, ["type"],                true]

# ---------------------------------------------------------------------------
# io.UnsupportedOperation multiple-inheritance base classes
# __bases__ is a tuple of length 2: (OSError, ValueError).
# bases[0].__name__ == 'OSError' (7), bases[1].__name__ == 'ValueError' (10).
# Both base classes have __module__ == 'builtins'.
# __bases__.__class__.__name__ == 'tuple'.
# ---------------------------------------------------------------------------

table io_extra145.UnsupportedOperation_bases:
  description: "io.UnsupportedOperation __bases__: tuple of length 2, bases[0]='OSError' (7), bases[1]='ValueError' (10), both in builtins"
  kind: python_call_eq
  category: class_identity
  id_prefix: iounop145

  columns: [id, function, args, expected]
  rows:
    - [bases_cls_eq,      "UnsupportedOperation.__bases__.__class__.__name__.__eq__",  ["tuple"],      true]
    - [bases_len,         "UnsupportedOperation.__bases__.__len__",                    [],             2]
    - [base0_name_eq,     "UnsupportedOperation.__bases__[0].__name__.__eq__",         ["OSError"],    true]
    - [base0_name_len,    "UnsupportedOperation.__bases__[0].__name__.__len__",        [],             7]
    - [base0_module_eq,   "UnsupportedOperation.__bases__[0].__module__.__eq__",       ["builtins"],   true]
    - [base1_name_eq,     "UnsupportedOperation.__bases__[1].__name__.__eq__",         ["ValueError"], true]
    - [base1_name_len,    "UnsupportedOperation.__bases__[1].__name__.__len__",        [],             10]
    - [base1_module_eq,   "UnsupportedOperation.__bases__[1].__module__.__eq__",       ["builtins"],   true]

# ---------------------------------------------------------------------------
# io.UnsupportedOperation MRO
# __mro__ is a tuple of length 6:
# (UnsupportedOperation, OSError, ValueError, Exception, BaseException, object).
# __mro__.__class__.__name__ == 'tuple'.
# ---------------------------------------------------------------------------

table io_extra145.UnsupportedOperation_mro:
  description: "io.UnsupportedOperation __mro__: tuple of length 6 — UnsupportedOperation, OSError, ValueError, Exception, BaseException, object"
  kind: python_call_eq
  category: class_identity
  id_prefix: iounop145

  columns: [id, function, args, expected]
  rows:
    - [mro_cls_eq,   "UnsupportedOperation.__mro__.__class__.__name__.__eq__", ["tuple"],               true]
    - [mro_len,      "UnsupportedOperation.__mro__.__len__",                   [],                      6]
    - [mro0_name_eq, "UnsupportedOperation.__mro__[0].__name__.__eq__",        ["UnsupportedOperation"], true]
    - [mro1_name_eq, "UnsupportedOperation.__mro__[1].__name__.__eq__",        ["OSError"],             true]
    - [mro2_name_eq, "UnsupportedOperation.__mro__[2].__name__.__eq__",        ["ValueError"],          true]
    - [mro3_name_eq, "UnsupportedOperation.__mro__[3].__name__.__eq__",        ["Exception"],           true]
    - [mro4_name_eq, "UnsupportedOperation.__mro__[4].__name__.__eq__",        ["BaseException"],       true]
    - [mro5_name_eq, "UnsupportedOperation.__mro__[5].__name__.__eq__",        ["object"],              true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra145.UnsupportedOperation.name_len_20:
  description: "io.UnsupportedOperation.__name__.__len__() == 20 ('UnsupportedOperation' has 20 characters; the longest class name in the io public API)"
  category: class_identity
  kind: python_call_eq
  function: UnsupportedOperation.__name__.__len__
  args: []
  expected: 20

invariant io_extra145.UnsupportedOperation.module_is_io:
  description: "io.UnsupportedOperation.__module__ == 'io' (length 2; UnsupportedOperation is defined in the Python io wrapper module, not in the C extension _io)"
  category: class_identity
  kind: python_call_eq
  function: UnsupportedOperation.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra145.UnsupportedOperation.bases_len_2:
  description: "io.UnsupportedOperation.__bases__.__len__() == 2 (UnsupportedOperation is a multiple-inheritance exception class, inheriting from both OSError and ValueError simultaneously)"
  category: class_identity
  kind: python_call_eq
  function: "UnsupportedOperation.__bases__.__len__"
  args: []
  expected: 2

invariant io_extra145.UnsupportedOperation.mro_len_6:
  description: "io.UnsupportedOperation.__mro__.__len__() == 6 (MRO is: UnsupportedOperation, OSError, ValueError, Exception, BaseException, object — 6 entries reflecting C3 linearization of the diamond)"
  category: class_identity
  kind: python_call_eq
  function: "UnsupportedOperation.__mro__.__len__"
  args: []
  expected: 6

invariant io_extra145.UnsupportedOperation.base0_is_OSError:
  description: "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' (the first base class; raising UnsupportedOperation will be caught by 'except OSError' since it is the first listed base)"
  category: class_identity
  kind: python_call_eq
  function: "UnsupportedOperation.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

invariant io_extra145.UnsupportedOperation.base1_is_ValueError:
  description: "io.UnsupportedOperation.__bases__[1].__name__ == 'ValueError' (the second base class; raising UnsupportedOperation will also be caught by 'except ValueError', e.g. when the operation argument is invalid)"
  category: class_identity
  kind: python_call_eq
  function: "UnsupportedOperation.__bases__[1].__name__.__eq__"
  args: ["ValueError"]
  expected: true
