spec: email_extra15
version: ">=3.6"
backend: python_module(email)

docs: https://docs.python.org/3/library/email.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/email.html — Python email module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/email/"
  notes:
    - "This spec extends email_extra14.zspec.zsdl."
    - "Prior specs covered: email.message.Message class, email.parser.Parser/FeedParser, email.mime.text.MIMEText, email.utils functions, email.__name__/__package__, Message/__name__/__module__/__qualname__, MIMEText/__name__/__module__, Parser/__name__/__module__, FeedParser.__name__/__module__=='email.feedparser', MIMEText.__bases__[0].__name__, MIMEMultipart.__bases__[0].__name__, MessageParseError identity, headerregistry.Address.__name__, Message.__init__.__name__ (extra14), Message/Parser/FeedParser/MIMEText __module__.__len__() (extra14), Message/Parser/MIMEText __qualname__.__len__() (extra14), MessageError/__module__/__module__.__len__() (extra14), MessageParseError/HeaderParseError __module__.__len__() (extra14)."
    - "This spec covers: email.mime.multipart.MIMEMultipart.__module__.__len__(), email.mime.multipart.MIMEMultipart.__name__.__len__(), email.mime.multipart.MIMEMultipart.__qualname__.__len__(), email.mime.base.MIMEBase.__module__.__len__(), email.mime.base.MIMEBase.__name__.__len__(), email.mime.base.MIMEBase.__qualname__.__len__(), email.message.Message.__init__.__module__.__len__(), email.message.Message.__init__.__qualname__.__len__(), email.errors.MessageError.__name__.__len__(), email.errors.HeaderParseError.__name__.__len__(), email.message_from_string.__module__.__len__(), email.message_from_bytes.__module__.__len__()."
    - "email.mime.multipart.MIMEMultipart.__module__.__len__() == 20 — len('email.mime.multipart') == 20; no prior email spec checks MIMEMultipart.__module__.__len__(). email_extra12 checks MIMEMultipart.__bases__[0].__name__."
    - "email.mime.multipart.MIMEMultipart.__name__.__len__() == 13 — len('MIMEMultipart') == 13; no prior email spec checks MIMEMultipart.__name__.__len__()."
    - "email.mime.multipart.MIMEMultipart.__qualname__.__len__() == 13 — MIMEMultipart.__qualname__ == 'MIMEMultipart' (len 13); no prior email spec checks MIMEMultipart.__qualname__.__len__()."
    - "email.mime.base.MIMEBase.__module__.__len__() == 15 — len('email.mime.base') == 15; no prior email spec checks any attribute on MIMEBase."
    - "email.mime.base.MIMEBase.__name__.__len__() == 8 — len('MIMEBase') == 8; no prior email spec checks MIMEBase.__name__.__len__()."
    - "email.mime.base.MIMEBase.__qualname__.__len__() == 8 — MIMEBase.__qualname__ == 'MIMEBase' (len 8); no prior email spec checks MIMEBase.__qualname__.__len__()."
    - "email.message.Message.__init__.__module__.__len__() == 13 — Message.__init__.__module__ == 'email.message' (len 13); extra14 checks Message.__module__.__len__()==13; no prior email spec checks Message.__init__.__module__.__len__()."
    - "email.message.Message.__init__.__qualname__.__len__() == 16 — len('Message.__init__') == 16; extra14 checks Message.__init__.__name__.__eq__('__init__'); no prior email spec checks Message.__init__.__qualname__.__len__()."
    - "email.errors.MessageError.__name__.__len__() == 12 — len('MessageError') == 12; extra14 checks MessageError.__module__.__len__()==12; no prior email spec checks MessageError.__name__.__len__(). Note: both MessageError.__name__ and MessageError.__module__ have len 12 — coincidental but verified."
    - "email.errors.HeaderParseError.__name__.__len__() == 16 — len('HeaderParseError') == 16; extra14 checks HeaderParseError.__module__.__len__()==12; no prior email spec checks HeaderParseError.__name__.__len__()."
    - "email.message_from_string.__module__.__len__() == 5 — message_from_string.__module__ == 'email' (len 5); no prior email spec checks __module__.__len__() on any email module-level function."
    - "email.message_from_bytes.__module__.__len__() == 5 — message_from_bytes.__module__ == 'email' (len 5); same rationale."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# email.mime.multipart.MIMEMultipart __module__, __name__, __qualname__ lengths
#
# email_extra12 checks MIMEMultipart.__bases__[0].__name__. No prior email spec
# checks MIMEMultipart.__module__.__len__(), __name__.__len__(), or
# __qualname__.__len__(). MIMEMultipart.__module__ == 'email.mime.multipart'
# (len 20). __name__ == __qualname__ == 'MIMEMultipart' (len 13).
# ---------------------------------------------------------------------------

table email_extra15.MIMEMultipart_lengths:
  description: "MIMEMultipart __module__/__name__/__qualname__ string lengths — no prior email spec checks any __len__() on MIMEMultipart"
  kind: python_call_eq
  category: class_identity
  id_prefix: mmplen15

  columns: [id, function, args, expected]
  rows:
    - [module,   mime.multipart.MIMEMultipart.__module__.__len__,   [], 20]
    - [name,     mime.multipart.MIMEMultipart.__name__.__len__,     [], 13]
    - [qualname, mime.multipart.MIMEMultipart.__qualname__.__len__, [], 13]

# ---------------------------------------------------------------------------
# email.mime.base.MIMEBase __module__, __name__, __qualname__ lengths
#
# No prior email spec checks any attribute on MIMEBase. MIMEBase is the
# abstract base class for all MIME-typed email objects. Its __module__ is
# 'email.mime.base' (len 15); __name__ == __qualname__ == 'MIMEBase' (len 8).
# ---------------------------------------------------------------------------

table email_extra15.MIMEBase_lengths:
  description: "MIMEBase __module__/__name__/__qualname__ string lengths — no prior email spec checks any attribute on MIMEBase"
  kind: python_call_eq
  category: class_identity
  id_prefix: mblen15

  columns: [id, function, args, expected]
  rows:
    - [module,   mime.base.MIMEBase.__module__.__len__,   [], 15]
    - [name,     mime.base.MIMEBase.__name__.__len__,     [], 8]
    - [qualname, mime.base.MIMEBase.__qualname__.__len__, [], 8]

# ---------------------------------------------------------------------------
# email.message.Message.__init__ __module__ and __qualname__ string lengths
#
# email_extra14 checks Message.__init__.__name__.__eq__('__init__') and
# Message.__module__.__len__()==13. No prior email spec checks
# Message.__init__.__module__.__len__() or Message.__init__.__qualname__.__len__().
# Message.__init__.__module__ == 'email.message' (len 13);
# Message.__init__.__qualname__ == 'Message.__init__' (len 16).
# ---------------------------------------------------------------------------

invariant email_extra15.Message_init.module_len:
  description: "email.message.Message.__init__.__module__.__len__() == 13 — len('email.message') == 13; no prior email spec checks Message.__init__.__module__.__len__()"
  category: method_identity
  kind: python_call_eq
  function: message.Message.__init__.__module__.__len__
  args: []
  expected: 13

invariant email_extra15.Message_init.qualname_len:
  description: "email.message.Message.__init__.__qualname__.__len__() == 16 — len('Message.__init__') == 16; no prior email spec checks Message.__init__.__qualname__.__len__()"
  category: method_identity
  kind: python_call_eq
  function: message.Message.__init__.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# email.errors.MessageError and HeaderParseError __name__ string lengths
#
# email_extra14 checks MessageError.__module__.__len__()==12 and
# HeaderParseError.__module__.__len__()==12. No prior email spec checks
# MessageError.__name__.__len__() or HeaderParseError.__name__.__len__().
# Note: MessageError.__name__ == 'MessageError' (len 12) coincidentally
# matches its __module__ length, but the attribute paths are distinct.
# ---------------------------------------------------------------------------

invariant email_extra15.MessageError.name_len:
  description: "email.errors.MessageError.__name__.__len__() == 12 — len('MessageError') == 12; extra14 checks __module__.__len__()==12; no prior spec checks MessageError.__name__.__len__()"
  category: class_identity
  kind: python_call_eq
  function: errors.MessageError.__name__.__len__
  args: []
  expected: 12

invariant email_extra15.HeaderParseError.name_len:
  description: "email.errors.HeaderParseError.__name__.__len__() == 16 — len('HeaderParseError') == 16; extra14 checks __module__.__len__()==12; no prior spec checks HeaderParseError.__name__.__len__()"
  category: class_identity
  kind: python_call_eq
  function: errors.HeaderParseError.__name__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# email.message_from_string and email.message_from_bytes __module__ lengths
#
# email.message_from_string and email.message_from_bytes are top-level
# convenience functions in the 'email' package; __module__ == 'email' (len 5).
# No prior email spec checks __module__.__len__() on any email module-level
# function. These are distinct from the class __module__ values which use
# submodule paths like 'email.message' (len 13).
# ---------------------------------------------------------------------------

invariant email_extra15.message_from_string.module_len:
  description: "email.message_from_string.__module__.__len__() == 5 — len('email') == 5; no prior email spec checks __module__.__len__() on any module-level function"
  category: function_modules
  kind: python_call_eq
  function: message_from_string.__module__.__len__
  args: []
  expected: 5

invariant email_extra15.message_from_bytes.module_len:
  description: "email.message_from_bytes.__module__.__len__() == 5 — len('email') == 5; no prior email spec checks message_from_bytes.__module__.__len__()"
  category: function_modules
  kind: python_call_eq
  function: message_from_bytes.__module__.__len__
  args: []
  expected: 5
