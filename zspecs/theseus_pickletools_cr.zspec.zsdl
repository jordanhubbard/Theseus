spec: theseus_pickletools_cr
version: ">=3.0"
backend: python_cleanroom(theseus_pickletools_cr)
blocks: pickletools

docs: https://docs.python.org/3/library/pickletools.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pickletools.html"
  not_derived_from:
    - "CPython source: Lib/pickletools.py"
  notes:
    - "Clean-room pickletools module. Do NOT import pickletools."

error_model: python_exceptions

invariant theseus_pickletools_cr.pickletools2_opcodes:
  description: "opcodes list exists with opcode objects"
  category: behavior
  kind: python_call_eq
  function: pickletools2_opcodes
  args: []
  expected: true

invariant theseus_pickletools_cr.pickletools2_dis:
  description: "dis() function can disassemble a pickle stream"
  category: behavior
  kind: python_call_eq
  function: pickletools2_dis
  args: []
  expected: true

invariant theseus_pickletools_cr.pickletools2_optimize:
  description: "optimize() function returns a bytes object"
  category: behavior
  kind: python_call_eq
  function: pickletools2_optimize
  args: []
  expected: true
