spec: isemail
version: ">=3.0.0"
backend: node(isemail)

docs: https://github.com/skenqbx/isemail#readme

provenance:
  derived_from:
    - "isemail README — https://github.com/skenqbx/isemail#readme"
    - "RFC 5321 / 5322 / 6531 / 6532 / 6854"
    - "Test vectors verified with isemail via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "isemail source"
  notes:
    - "isemail is the most strictly RFC-compliant email validator for Node — superset of email-validator's checks."
    - "Install: npm install isemail"
    - "validate(addr) returns boolean (with default options)."
    - "Internationalized email addresses (RFC 6531) are supported when {minDomainAtoms: 2}."
  rfcs:
    - "RFC 5321 — Simple Mail Transfer Protocol"
    - "RFC 5322 — Internet Message Format"
    - "RFC 6531 — SMTP Extension for Internationalized Email"
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure boolean predicate; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table isemail.validate:
  kind: node_module_call_eq
  category: validate
  function: validate
  id_prefix: validate

  columns: [id, args, expected]
  rows:
    - [simple,             ["a@b.com"],                     true]
    - [longer_local_part,  ["jordan.h@example.com"],        true]
    - [plus_tag,           ["plus+tag@example.com"],        true]
    - [hyphen_in_domain,   ["a@my-host.com"],                true]
    - [subdomain,          ["a@x.example.com"],              true]
    - [no_at_symbol,       ["not"],                           false]
    - [empty_string,       [""],                              false]
    - [whitespace,         ["a @b.com"],                      false]
    - [missing_local,      ["@example.com"],                  false]
    - [missing_domain,     ["a@"],                            false]
    - [trailing_dot,       ["a@b.com."],                      false]
