spec: uuid_extra706
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers uuid module-level function qualnames and UUID class properties"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra706.qualnames:
  description: "uuid module-level function and UUID class qualname and module attribute checks"
  kind: python_call_eq
  category: qualnames
  id_prefix: uu706qn
  columns: [id, function, args, expected]
  rows:
    - [uu706qn001, uuid.uuid1.__qualname__.__eq__, ["uuid1"], true]
    - [uu706qn002, uuid.uuid1.__module__.__eq__, ["uuid"], true]
    - [uu706qn003, uuid.uuid3.__qualname__.__eq__, ["uuid3"], true]
    - [uu706qn004, uuid.uuid3.__module__.__eq__, ["uuid"], true]
    - [uu706qn005, uuid.uuid4.__qualname__.__eq__, ["uuid4"], true]
    - [uu706qn006, uuid.uuid4.__module__.__eq__, ["uuid"], true]
    - [uu706qn007, uuid.uuid5.__qualname__.__eq__, ["uuid5"], true]
    - [uu706qn008, uuid.uuid5.__module__.__eq__, ["uuid"], true]
    - [uu706qn009, uuid.UUID.__qualname__.__eq__, ["UUID"], true]
    - [uu706qn010, uuid.UUID.__module__.__eq__, ["uuid"], true]
    - [uu706qn011, uuid.UUID.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu706qn012, uuid.UUID.hex.__class__.__name__.__eq__, ["property"], true]
