spec: itertools_extra841
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - itertools module standard library documentation
    - Python 3.9+ itertools API
  not_derived_from:
    - more-itertools third-party package
    - toolz or cytoolz alternatives
  notes:
    - Covers __qualname__, __module__, and __doc__ class name identity for combinatoric itertools
    - Validates product, permutations, combinations, and combinations_with_replacement
    - All covered types are C-implemented iterators exposed as Python types
  created_at: "2026-04-12"

table itertools_extra841.qualname_module_doc:
  description: Verify __qualname__, __module__, and __doc__ class name identity for itertools combinatoric types
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: it841xx
  columns: [id, function, args, expected]
  rows:
    - [it841xx001, itertools.product.__qualname__.__eq__, ["product"], true]
    - [it841xx002, itertools.product.__module__.__eq__, ["itertools"], true]
    - [it841xx003, itertools.product.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [it841xx004, itertools.permutations.__qualname__.__eq__, ["permutations"], true]
    - [it841xx005, itertools.permutations.__module__.__eq__, ["itertools"], true]
    - [it841xx006, itertools.permutations.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [it841xx007, itertools.combinations.__qualname__.__eq__, ["combinations"], true]
    - [it841xx008, itertools.combinations.__module__.__eq__, ["itertools"], true]
    - [it841xx009, itertools.combinations.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [it841xx010, itertools.combinations_with_replacement.__qualname__.__eq__, ["combinations_with_replacement"], true]
    - [it841xx011, itertools.combinations_with_replacement.__module__.__eq__, ["itertools"], true]
    - [it841xx012, itertools.combinations_with_replacement.__doc__.__class__.__name__.__eq__, ["str"], true]
