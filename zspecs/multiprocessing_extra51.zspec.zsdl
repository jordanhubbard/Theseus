spec: multiprocessing_extra51
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — Pool documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing_extra50.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__ tables, DefaultContext method qualname lengths, BaseProcess metadata, function __name__.__len__() tables, pool result class tables, Process/__name__=='Process', Pool/__name__=='Pool', Pool/__module__=='multiprocessing.pool', Pool/__qualname__=='Pool', Pool/__bases__[0].__name__=='object', Pool/__mro__.__len__()==2, cpu_count/__module__==multiprocessing, Process method __qualname__ string equality, function __name__/__module__ equality, AuthenticationError/__name__/__module__/__bases__[0].__name__, ProcessError/__name__/__bases__[0].__name__, ProcessError/__mro__.__len__()==4, exception subclass MRO depths, class/function qualname string equality tables, context class tables, Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__qualname__=='function', cpu_count/__class__.__qualname__=='method', ProcessError/__bases__[0].__name__=='Exception', AuthenticationError/__bases__[0].__name__=='ProcessError', ProcessError/__module__=='multiprocessing.context', AuthenticationError/__module__=='multiprocessing.context', Queue/__class__.__name__=='method', Pipe/__class__.__name__=='method', Process/__doc__/__class__/__name__=='str', Pool/__class__.__qualname__=='type', Pool/__doc__/__class__/__name__=='str', Pool/__doc__/__class__.__qualname__=='str', Pool/__doc__/__class__/__module__=='builtins', BufferTooShort/__doc__/__class__/__name__=='str', TimeoutError/__doc__/__class__/__name__=='str', Pool/__name__.__len__()==4, Pool/__module__.__len__()==20 (extra50). Process property descriptor __class__.__name__=='property' for pid/name/daemon/exitcode/authkey/sentinel, Process.__init__.__qualname__=='BaseProcess.__init__' (extra49)."
    - "This spec covers: multiprocessing.Pool.apply.__qualname__.__len__()==10; Pool.map.__qualname__.__len__()==8; Pool.starmap.__qualname__.__len__()==12; Pool.apply_async.__qualname__.__len__()==16; Pool.map_async.__qualname__.__len__()==14; Pool.close.__qualname__.__len__()==10; Pool.terminate.__qualname__.__len__()==14; Pool.join.__qualname__.__len__()==9. Also: Pool.apply.__qualname__.__eq__('Pool.apply'); Pool.map.__qualname__.__eq__('Pool.map'); Pool.starmap.__qualname__.__eq__('Pool.starmap'); Pool.apply_async.__qualname__.__eq__('Pool.apply_async'); Pool.map_async.__qualname__.__eq__('Pool.map_async'); Pool.close.__qualname__.__eq__('Pool.close'); Pool.terminate.__qualname__.__eq__('Pool.terminate'); Pool.join.__qualname__.__eq__('Pool.join')."
    - "multiprocessing.Pool.apply.__qualname__ == 'Pool.apply'. apply is a method defined directly on Pool in Lib/multiprocessing/pool.py. Its __qualname__ is 'Pool.apply' (10 chars: 'Pool'(4) + '.'(1) + 'apply'(5) = 10). Prior specs (multiprocessing_extra) measured a Pool method __qualname__.__len__() for some methods; extra51 extends this to apply, map, starmap, apply_async, map_async, close, terminate, and join in the mppool51 namespace. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.map.__qualname__ == 'Pool.map'. map is a method on Pool; __qualname__ is 'Pool.map' (8 chars: 'Pool'(4) + '.'(1) + 'map'(3) = 8). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.starmap.__qualname__ == 'Pool.starmap'. starmap is the variant of map that accepts argument tuples; __qualname__ is 'Pool.starmap' (12 chars: 'Pool'(4) + '.'(1) + 'starmap'(7) = 12). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.apply_async.__qualname__ == 'Pool.apply_async'. apply_async is the asynchronous variant of apply; __qualname__ is 'Pool.apply_async' (16 chars: 'Pool'(4) + '.'(1) + 'apply_async'(11) = 16). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.map_async.__qualname__ == 'Pool.map_async'. map_async is the asynchronous variant of map; __qualname__ is 'Pool.map_async' (14 chars: 'Pool'(4) + '.'(1) + 'map_async'(9) = 14). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.close.__qualname__ == 'Pool.close'. close prevents further tasks from being submitted to the pool; __qualname__ is 'Pool.close' (10 chars: 'Pool'(4) + '.'(1) + 'close'(5) = 10). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.terminate.__qualname__ == 'Pool.terminate'. terminate immediately stops the worker processes; __qualname__ is 'Pool.terminate' (14 chars: 'Pool'(4) + '.'(1) + 'terminate'(9) = 14). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.join.__qualname__ == 'Pool.join'. join waits for worker processes to exit (must be called after close or terminate); __qualname__ is 'Pool.join' (9 chars: 'Pool'(4) + '.'(1) + 'join'(4) = 9). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Pool method __qualname__.__len__() — extra51
#
# Pool defines a full set of worker management methods in Lib/multiprocessing/pool.py.
# Each method has __qualname__ == 'Pool.<method_name>', encoding the class name
# 'Pool' (4 chars) followed by a period and the method name. The eight primary
# public methods and their qualname lengths are:
#
#   apply        → 'Pool.apply'        (10)
#   map          → 'Pool.map'          ( 8)
#   starmap      → 'Pool.starmap'      (12)
#   apply_async  → 'Pool.apply_async'  (16)
#   map_async    → 'Pool.map_async'    (14)
#   close        → 'Pool.close'        (10)
#   terminate    → 'Pool.terminate'    (14)
#   join         → 'Pool.join'         ( 9)
#
# Prior specs measured qualname lengths for some Pool methods in other namespaces;
# extra51 captures all eight in a unified mppool51 table.
# ---------------------------------------------------------------------------

table multiprocessing_extra51.pool_method_qualname_len:
  description: "multiprocessing.Pool method __qualname__.__len__() in extra51 namespace — 8 primary Pool methods with qualnames 'Pool.<method>'"
  kind: python_call_eq
  category: method_names
  id_prefix: mppool51qualnamelen

  columns: [id, function, args, expected, description]
  rows:
    - [apply,       Pool.apply.__qualname__.__len__,       [], 10, "Pool.apply.__qualname__.__len__() == 10 — 'Pool.apply': 'Pool'(4) + '.'(1) + 'apply'(5) = 10"]
    - [map,         Pool.map.__qualname__.__len__,         [],  8, "Pool.map.__qualname__.__len__() == 8 — 'Pool.map': 'Pool'(4) + '.'(1) + 'map'(3) = 8"]
    - [starmap,     Pool.starmap.__qualname__.__len__,     [], 12, "Pool.starmap.__qualname__.__len__() == 12 — 'Pool.starmap': 'Pool'(4) + '.'(1) + 'starmap'(7) = 12"]
    - [apply_async, Pool.apply_async.__qualname__.__len__, [], 16, "Pool.apply_async.__qualname__.__len__() == 16 — 'Pool.apply_async': 'Pool'(4) + '.'(1) + 'apply_async'(11) = 16"]
    - [map_async,   Pool.map_async.__qualname__.__len__,   [], 14, "Pool.map_async.__qualname__.__len__() == 14 — 'Pool.map_async': 'Pool'(4) + '.'(1) + 'map_async'(9) = 14"]
    - [close,       Pool.close.__qualname__.__len__,       [], 10, "Pool.close.__qualname__.__len__() == 10 — 'Pool.close': 'Pool'(4) + '.'(1) + 'close'(5) = 10"]
    - [terminate,   Pool.terminate.__qualname__.__len__,   [], 14, "Pool.terminate.__qualname__.__len__() == 14 — 'Pool.terminate': 'Pool'(4) + '.'(1) + 'terminate'(9) = 14"]
    - [join,        Pool.join.__qualname__.__len__,        [],  9, "Pool.join.__qualname__.__len__() == 9 — 'Pool.join': 'Pool'(4) + '.'(1) + 'join'(4) = 9"]

# ---------------------------------------------------------------------------
# multiprocessing.Pool method __qualname__ string equality — extra51
#
# The string equality checks confirm the full __qualname__ strings for all
# eight Pool methods. These complement the __len__() checks in the table above.
# All qualnames follow the pattern 'Pool.<method_name>', reflecting that these
# methods are defined directly on Pool (not inherited or nested).
# ---------------------------------------------------------------------------

table multiprocessing_extra51.pool_method_qualname_eq:
  description: "multiprocessing.Pool method __qualname__ string equality in extra51 namespace — all 8 primary methods with 'Pool.<method>' qualnames"
  kind: python_call_eq
  category: method_names
  id_prefix: mppool51qualnameeq

  columns: [id, function, args, expected, description]
  rows:
    - [apply,       Pool.apply.__qualname__.__eq__,       ["Pool.apply"],       true, "Pool.apply.__qualname__ == 'Pool.apply' — apply submits a single callable to the pool and blocks until result is ready"]
    - [map,         Pool.map.__qualname__.__eq__,         ["Pool.map"],         true, "Pool.map.__qualname__ == 'Pool.map' — map distributes an iterable across pool workers synchronously"]
    - [starmap,     Pool.starmap.__qualname__.__eq__,     ["Pool.starmap"],     true, "Pool.starmap.__qualname__ == 'Pool.starmap' — starmap distributes argument tuples across pool workers synchronously"]
    - [apply_async, Pool.apply_async.__qualname__.__eq__, ["Pool.apply_async"], true, "Pool.apply_async.__qualname__ == 'Pool.apply_async' — asynchronous variant of apply; returns AsyncResult immediately"]
    - [map_async,   Pool.map_async.__qualname__.__eq__,   ["Pool.map_async"],   true, "Pool.map_async.__qualname__ == 'Pool.map_async' — asynchronous variant of map; returns AsyncResult immediately"]
    - [close,       Pool.close.__qualname__.__eq__,       ["Pool.close"],       true, "Pool.close.__qualname__ == 'Pool.close' — prevents new tasks from being submitted; workers finish pending tasks"]
    - [terminate,   Pool.terminate.__qualname__.__eq__,   ["Pool.terminate"],   true, "Pool.terminate.__qualname__ == 'Pool.terminate' — immediately stops worker processes without waiting for tasks to complete"]
    - [join,        Pool.join.__qualname__.__eq__,        ["Pool.join"],        true, "Pool.join.__qualname__ == 'Pool.join' — waits for worker processes to exit; must be called after close() or terminate()"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra51
# ---------------------------------------------------------------------------

invariant multiprocessing_extra51.Pool_apply_qualname_eq:
  description: "multiprocessing.Pool.apply.__qualname__ == 'Pool.apply' — apply is defined directly on Pool in pool.py; __qualname__ encodes the class chain 'Pool.apply' (10 chars: 'Pool'(4)+'.'(1)+'apply'(5))"
  category: method_names
  kind: python_call_eq
  function: Pool.apply.__qualname__.__eq__
  args: ["Pool.apply"]
  expected: true

invariant multiprocessing_extra51.Pool_map_qualname_eq:
  description: "multiprocessing.Pool.map.__qualname__ == 'Pool.map' — map is defined directly on Pool; __qualname__ is 'Pool.map' (8 chars: 'Pool'(4)+'.'(1)+'map'(3))"
  category: method_names
  kind: python_call_eq
  function: Pool.map.__qualname__.__eq__
  args: ["Pool.map"]
  expected: true

invariant multiprocessing_extra51.Pool_apply_qualname_len:
  description: "multiprocessing.Pool.apply.__qualname__.__len__() == 10 — 'Pool.apply' has 10 characters"
  category: method_names
  kind: python_call_eq
  function: Pool.apply.__qualname__.__len__
  args: []
  expected: 10

invariant multiprocessing_extra51.Pool_map_qualname_len:
  description: "multiprocessing.Pool.map.__qualname__.__len__() == 8 — 'Pool.map' has 8 characters"
  category: method_names
  kind: python_call_eq
  function: Pool.map.__qualname__.__len__
  args: []
  expected: 8

invariant multiprocessing_extra51.Pool_apply_async_qualname_len:
  description: "multiprocessing.Pool.apply_async.__qualname__.__len__() == 16 — 'Pool.apply_async' has 16 characters: 'Pool'(4)+'.'(1)+'apply_async'(11) = 16"
  category: method_names
  kind: python_call_eq
  function: Pool.apply_async.__qualname__.__len__
  args: []
  expected: 16

invariant multiprocessing_extra51.Pool_join_qualname_len:
  description: "multiprocessing.Pool.join.__qualname__.__len__() == 9 — 'Pool.join' has 9 characters: 'Pool'(4)+'.'(1)+'join'(4) = 9"
  category: method_names
  kind: python_call_eq
  function: Pool.join.__qualname__.__len__
  args: []
  expected: 9
