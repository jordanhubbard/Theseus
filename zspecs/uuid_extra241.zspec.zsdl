spec: uuid_extra241
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name and co_argcount / UUID.__module__ / UUID.__class__.__name__ / UUID.__qualname__ equality and length (table + invariants)."
    - "uuid_extra240.zspec.zsdl — covers uuid4/uuid1 generator function __name__/__module__/__class__.__name__ / uuid4()/uuid1() instance __class__.__name__/__module__ / UUID.__name__/__bases__[0].__name__ (table + invariants)."
  notes:
    - "Wave 295 theme: uuid.uuid3 and uuid.uuid5 behavioral contracts — function identity and deterministic UUID generation."
    - "uuid.uuid3.__name__ == 'uuid3'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__name__ == 'uuid5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "str(uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org')) == '6fa459ea-ee8a-3ca4-894e-db77e160355e'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "str(uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org')) == '886313e1-3b8a-5372-9b90-0c9aee199e5d'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org').version == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org').version == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org').__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org').__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid3 uses MD5 hashing of the namespace UUID and name; uuid5 uses SHA-1. Both produce deterministic UUIDs — the same inputs always yield the same UUID. This is why uuid.uuid3 and uuid.uuid5 are used when you need reproducible UUID generation from a known name."
    - "Note: uuid.uuid3.__class__.__name__ is 'function' (pure Python function in Lib/uuid.py). This contrasts with hashlib constructors (builtin_function_or_method). uuid_extra96 anchors __code__.co_name; uuid_extra240 anchors uuid4/uuid1 function identity; this spec anchors uuid3/uuid5."
    - "Note: uuid.NAMESPACE_DNS is the UUID 6ba7b810-9dad-11d1-80b4-00c04fd430c8 (a well-known namespace UUID for DNS names). The test vector str(uuid3(NAMESPACE_DNS, 'python.org'))=='6fa459ea-ee8a-3ca4-894e-db77e160355e' is the canonical example from RFC 4122 Appendix B / PEP 367 and Python uuid module documentation."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid3 and uuid.uuid5 function identity
#
# Wave 295 theme: uuid3/uuid5 pure Python function __name__, __module__, __class__.
#
# uuid.uuid3 and uuid.uuid5 are pure Python functions defined in Lib/uuid.py.
# Their __class__.__name__ is 'function' (not builtin_function_or_method). Their
# __name__ matches the function name and __module__ is 'uuid'. uuid_extra96
# anchors __code__.co_name for uuid3 and uuid5; uuid_extra240 anchors uuid4/uuid1
# identity; no prior spec anchors __name__/__module__/__class__.__name__ for uuid3
# and uuid5 together as a grouped table under uuiddet295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra241.uuid3_uuid5_function_identity:
  description: "uuid3.__name__.__eq__('uuid3')==True / uuid3.__module__.__eq__('uuid')==True / uuid3.__class__.__name__.__eq__('function')==True / uuid5.__name__.__eq__('uuid5')==True / uuid5.__module__.__eq__('uuid')==True / uuid5.__class__.__name__.__eq__('function')==True — uuid3/uuid5 are pure Python functions (not builtins); uuid3 uses MD5; uuid5 uses SHA-1; both deterministic; extra96 anchors __code__.co_name; extra240 anchors uuid4/uuid1 identity; first uuiddet295 anchor for uuid3/uuid5 function identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuiddet295

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_name_eq,    "uuid3.__name__.__eq__",           ["uuid3"],    true, "uuid.uuid3.__name__ is 'uuid3' (function name as defined in Lib/uuid.py)"]
    - [uuid3_module_eq,  "uuid3.__module__.__eq__",          ["uuid"],    true, "uuid.uuid3.__module__ is 'uuid' (top-level function in the uuid module)"]
    - [uuid3_class_eq,   "uuid3.__class__.__name__.__eq__",  ["function"], true, "uuid.uuid3.__class__.__name__ is 'function' (pure Python, not C builtin)"]
    - [uuid5_name_eq,    "uuid5.__name__.__eq__",           ["uuid5"],    true, "uuid.uuid5.__name__ is 'uuid5' (function name as defined in Lib/uuid.py)"]
    - [uuid5_module_eq,  "uuid5.__module__.__eq__",          ["uuid"],    true, "uuid.uuid5.__module__ is 'uuid' (top-level function in the uuid module)"]
    - [uuid5_class_eq,   "uuid5.__class__.__name__.__eq__",  ["function"], true, "uuid.uuid5.__class__.__name__ is 'function' (pure Python, not C builtin)"]

# ---------------------------------------------------------------------------
# uuid.uuid3 and uuid.uuid5 deterministic UUID generation with NAMESPACE_DNS
#
# Wave 295 theme: uuid3(NAMESPACE_DNS, 'python.org') and uuid5(NAMESPACE_DNS, 'python.org')
# produce specific deterministic UUID values and instance type/version properties.
#
# uuid3 and uuid5 generate UUIDs deterministically from a namespace UUID and a
# name string. The canonical test vector using NAMESPACE_DNS and 'python.org'
# is documented in the Python uuid module docs. The returned UUID instances have
# __class__.__name__=='UUID', version==3 (for uuid3) or version==5 (for uuid5),
# and a fixed string representation. No prior spec anchors these deterministic
# test vectors as a grouped table under uuiddet295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra241.uuid3_uuid5_deterministic_generation:
  description: "uuid3(NAMESPACE_DNS,'python.org').__class__.__name__.__eq__('UUID')==True / uuid3(...).version.__eq__(3)==True / str(uuid3(...)).__eq__('6fa459ea-ee8a-3ca4-894e-db77e160355e')==True / uuid5(NAMESPACE_DNS,'python.org').__class__.__name__.__eq__('UUID')==True / uuid5(...).version.__eq__(5)==True / str(uuid5(...)).__eq__('886313e1-3b8a-5372-9b90-0c9aee199e5d')==True — uuid3/uuid5 produce deterministic UUIDs; uuid3 uses MD5 (version 3); uuid5 uses SHA-1 (version 5); test vectors from Python uuid docs and RFC 4122; no prior spec anchors these vectors; first uuiddet295 anchor"
  kind: python_call_eq
  category: deterministic_generation
  id_prefix: uuiddet295

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_inst_class,    "uuid3(NAMESPACE_DNS,'python.org').__class__.__name__.__eq__",  ["UUID"],                                  true, "uuid3(NAMESPACE_DNS, 'python.org') returns a UUID instance"]
    - [uuid3_version_eq,    "uuid3(NAMESPACE_DNS,'python.org').version.__eq__",              [3],                                       true, "uuid3 result has version==3 (MD5-based name UUID)"]
    - [uuid3_str_eq,        "str(uuid3(NAMESPACE_DNS,'python.org')).__eq__",                ["6fa459ea-ee8a-3ca4-894e-db77e160355e"],   true, "uuid3(NAMESPACE_DNS, 'python.org') canonical test vector (RFC 4122 / Python docs)"]
    - [uuid5_inst_class,    "uuid5(NAMESPACE_DNS,'python.org').__class__.__name__.__eq__",  ["UUID"],                                  true, "uuid5(NAMESPACE_DNS, 'python.org') returns a UUID instance"]
    - [uuid5_version_eq,    "uuid5(NAMESPACE_DNS,'python.org').version.__eq__",              [5],                                       true, "uuid5 result has version==5 (SHA-1-based name UUID)"]
    - [uuid5_str_eq,        "str(uuid5(NAMESPACE_DNS,'python.org')).__eq__",                ["886313e1-3b8a-5372-9b90-0c9aee199e5d"],   true, "uuid5(NAMESPACE_DNS, 'python.org') canonical test vector (Python uuid module docs)"]

# ---------------------------------------------------------------------------
# uuid.uuid3.__name__.__eq__('uuid3') — standalone
#
# uuid.uuid3.__name__ is 'uuid3'. The uuid3 function is defined in Lib/uuid.py
# as a module-level function named 'uuid3'. It generates a name-based UUID
# using MD5 as the hash algorithm. MD5 is cryptographically broken for security
# uses but is retained for uuid3 compatibility with RFC 4122 (which specifies MD5
# for version-3 UUIDs). uuid_extra96 anchors __code__.co_name for uuid3;
# uuid_extra240 anchors uuid4.__name__ as a standalone; no prior spec anchors
# uuid3.__name__.__eq__ as a standalone under uuiddet295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra241.uuid3_name_eq:
  description: "uuid.uuid3.__name__.__eq__('uuid3') == True — uuid3.__name__ is 'uuid3'; defined in Lib/uuid.py as module-level function; generates name-based UUID using MD5 (RFC 4122 version 3); MD5 is cryptographically broken but retained for RFC 4122 compatibility; produces deterministic UUIDs from namespace + name inputs; extra96 anchors __code__.co_name; first standalone under uuiddet295"
  category: function_identity
  kind: python_call_eq
  function: "uuid3.__name__.__eq__"
  args: ["uuid3"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid5.__name__.__eq__('uuid5') — standalone
#
# uuid.uuid5.__name__ is 'uuid5'. The uuid5 function is defined in Lib/uuid.py
# as a module-level function named 'uuid5'. It generates a name-based UUID
# using SHA-1 as the hash algorithm. SHA-1 is cryptographically weak but is
# retained for uuid5 compatibility with RFC 4122. uuid5 is preferred over uuid3
# (MD5) when generating name-based UUIDs because SHA-1 is considered stronger
# than MD5 for this purpose. uuid_extra96 anchors __code__.co_name for uuid5;
# no prior spec anchors uuid5.__name__.__eq__ as a standalone under uuiddet295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra241.uuid5_name_eq:
  description: "uuid.uuid5.__name__.__eq__('uuid5') == True — uuid5.__name__ is 'uuid5'; defined in Lib/uuid.py as module-level function; generates name-based UUID using SHA-1 (RFC 4122 version 5); SHA-1 preferred over MD5 for name-based UUIDs; deterministic — same namespace+name always gives the same UUID; extra96 anchors __code__.co_name; first standalone under uuiddet295"
  category: function_identity
  kind: python_call_eq
  function: "uuid5.__name__.__eq__"
  args: ["uuid5"]
  expected: true
