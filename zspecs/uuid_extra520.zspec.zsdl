spec: uuid_extra520
backend: python_module(uuid)

table uuid_extra520.uuid_property_fget_names:
  description: uuid.UUID property fget __name__ checks
  columns: [id, function, expected]
  rows:
    - [uuid_int_fget_name,      uuid.UUID.int.fget.__name__.__eq__,      int]
    - [uuid_hex_fget_name,      uuid.UUID.hex.fget.__name__.__eq__,      hex]
    - [uuid_bytes_fget_name,    uuid.UUID.bytes.fget.__name__.__eq__,    bytes]
    - [uuid_bytes_le_fget_name, uuid.UUID.bytes_le.fget.__name__.__eq__, bytes_le]
    - [uuid_fields_fget_name,   uuid.UUID.fields.fget.__name__.__eq__,   fields]
    - [uuid_time_low_fget_name, uuid.UUID.time_low.fget.__name__.__eq__, time_low]
    - [uuid_time_mid_fget_name, uuid.UUID.time_mid.fget.__name__.__eq__, time_mid]
    - [uuid_version_fget_name,  uuid.UUID.version.fget.__name__.__eq__,  version]
    - [uuid_variant_fget_name,  uuid.UUID.variant.fget.__name__.__eq__,  variant]
    - [uuid_urn_fget_name,      uuid.UUID.urn.fget.__name__.__eq__,      urn]
    - [uuid_node_fget_name,     uuid.UUID.node.fget.__name__.__eq__,     node]
    - [uuid_is_safe_fget_name,  uuid.UUID.is_safe.fget.__name__.__eq__,  is_safe]
  invariant_template:
    kind: python_call_eq
    function: "{function}"
    args: ["{expected}"]
    expected: true
