spec: inspect_extra165
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.CO_OPTIMIZED == 1; inspect.CO_NEWLOCALS == 2; inspect.CO_VARARGS == 4; inspect.CO_VARKEYWORDS == 8; all have __class__.__name__ 'int' (Wave 294)."
    - "inspect.CO_OPTIMIZED == 1 — CO_OPTIMIZED is a code object flag constant defined in Lib/inspect.py that corresponds to the CPython compiler flag indicating that the code object uses optimized locals (via LOAD_FAST/STORE_FAST instead of the slower dict-based LOAD_NAME/STORE_NAME); its integer value is 1. Verified with Python 3.14.3."
    - "inspect.CO_NEWLOCALS == 2 — CO_NEWLOCALS is a code object flag constant indicating that a new local namespace dict should be created for the code object at call time; its integer value is 2. Verified with Python 3.14.3."
    - "inspect.CO_VARARGS == 4 — CO_VARARGS is a code object flag constant indicating that the code object accepts a *args variadic positional argument tuple; its integer value is 4. Verified with Python 3.14.3."
    - "inspect.CO_VARKEYWORDS == 8 — CO_VARKEYWORDS is a code object flag constant indicating that the code object accepts a **kwargs variadic keyword argument dict; its integer value is 8. Verified with Python 3.14.3."
    - "All CO_* constants have __class__.__name__ == 'int' — these constants are plain Python int objects; their __class__.__name__ is 'int'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect CO_OPTIMIZED and CO_NEWLOCALS flag constant values
#
# Wave 294 theme: inspect module code-object flag constants — CO_OPTIMIZED and
# CO_NEWLOCALS integer values and class names.
#
# inspect.CO_OPTIMIZED == 1
# inspect.CO_OPTIMIZED.__class__.__name__ == 'int'
# inspect.CO_NEWLOCALS == 2
# inspect.CO_NEWLOCALS.__class__.__name__ == 'int'
#
# Code objects in CPython have a co_flags integer bitmask. inspect exposes
# named constants for the individual flag bits. CO_OPTIMIZED (bit 0, value 1)
# indicates that local variable access uses LOAD_FAST/STORE_FAST (optimized
# locals) rather than the slower namespace dict. CO_NEWLOCALS (bit 1, value 2)
# indicates that a fresh local namespace dict must be created at call time.
# Both are plain Python int constants; their __class__.__name__ is 'int'.
# New to extra165.
# ---------------------------------------------------------------------------

table inspect_extra165.co_optimized_and_co_newlocals_constants:
  description: "inspect: CO_OPTIMIZED == 1, CO_OPTIMIZED.__class__.__name__ 'int', CO_NEWLOCALS == 2, CO_NEWLOCALS.__class__.__name__ 'int'; wave 294; new to extra165"
  kind: python_call_eq
  category: identity
  id_prefix: inspectconc165

  columns: [id, function, args, expected, description]
  rows:
    - [co_opt_eq_1,
       "CO_OPTIMIZED.__eq__",
       [1],
       true,
       "inspect.CO_OPTIMIZED.__eq__(1) == True — CO_OPTIMIZED is the code-object flag constant (bit 0, value 1) indicating that the code object uses optimized local variable access via LOAD_FAST/STORE_FAST rather than the slower dict-based LOAD_NAME/STORE_NAME; int.__eq__(1) returns True; new to extra165"]
    - [co_opt_cls_name_int,
       "CO_OPTIMIZED.__class__.__name__.__eq__",
       ["int"],
       true,
       "inspect.CO_OPTIMIZED.__class__.__name__.__eq__('int') == True — CO_OPTIMIZED is a plain Python int constant; its __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra165"]
    - [co_newloc_eq_2,
       "CO_NEWLOCALS.__eq__",
       [2],
       true,
       "inspect.CO_NEWLOCALS.__eq__(2) == True — CO_NEWLOCALS is the code-object flag constant (bit 1, value 2) indicating that a new local namespace dict must be created at call time for the code object; int.__eq__(2) returns True; new to extra165"]
    - [co_newloc_cls_name_int,
       "CO_NEWLOCALS.__class__.__name__.__eq__",
       ["int"],
       true,
       "inspect.CO_NEWLOCALS.__class__.__name__.__eq__('int') == True — CO_NEWLOCALS is a plain Python int constant; its __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra165"]

# ---------------------------------------------------------------------------
# Table 2: inspect CO_VARARGS and CO_VARKEYWORDS flag constant values
#
# Wave 294 theme: inspect module code-object flag constants — CO_VARARGS and
# CO_VARKEYWORDS integer values and class names.
#
# inspect.CO_VARARGS == 4
# inspect.CO_VARARGS.__class__.__name__ == 'int'
# inspect.CO_VARKEYWORDS == 8
# inspect.CO_VARKEYWORDS.__class__.__name__ == 'int'
#
# CO_VARARGS (bit 2, value 4) indicates that the code object accepts a *args
# variadic positional argument tuple (the 'varargs' extra parameter). Functions
# defined with *args have this flag set in co_flags. CO_VARKEYWORDS (bit 3,
# value 8) indicates that the code object accepts a **kwargs variadic keyword
# argument dict. Functions defined with **kwargs have this flag set. Both are
# plain Python int constants defined in Lib/inspect.py. New to extra165.
# ---------------------------------------------------------------------------

table inspect_extra165.co_varargs_and_co_varkeywords_constants:
  description: "inspect: CO_VARARGS == 4, CO_VARARGS.__class__.__name__ 'int', CO_VARKEYWORDS == 8, CO_VARKEYWORDS.__class__.__name__ 'int'; wave 294; new to extra165"
  kind: python_call_eq
  category: identity
  id_prefix: inspectcvkc165

  columns: [id, function, args, expected, description]
  rows:
    - [co_varargs_eq_4,
       "CO_VARARGS.__eq__",
       [4],
       true,
       "inspect.CO_VARARGS.__eq__(4) == True — CO_VARARGS is the code-object flag constant (bit 2, value 4) indicating that the code object accepts a *args variadic positional argument tuple; functions defined with *args have this flag set in co_flags; int.__eq__(4) returns True; new to extra165"]
    - [co_varargs_cls_name_int,
       "CO_VARARGS.__class__.__name__.__eq__",
       ["int"],
       true,
       "inspect.CO_VARARGS.__class__.__name__.__eq__('int') == True — CO_VARARGS is a plain Python int constant; its __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra165"]
    - [co_varkw_eq_8,
       "CO_VARKEYWORDS.__eq__",
       [8],
       true,
       "inspect.CO_VARKEYWORDS.__eq__(8) == True — CO_VARKEYWORDS is the code-object flag constant (bit 3, value 8) indicating that the code object accepts a **kwargs variadic keyword argument dict; functions defined with **kwargs have this flag set in co_flags; int.__eq__(8) returns True; new to extra165"]
    - [co_varkw_cls_name_int,
       "CO_VARKEYWORDS.__class__.__name__.__eq__",
       ["int"],
       true,
       "inspect.CO_VARKEYWORDS.__class__.__name__.__eq__('int') == True — CO_VARKEYWORDS is a plain Python int constant; its __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra165"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra165
# ---------------------------------------------------------------------------

invariant inspect_extra165.co_optimized_eq_1:
  description: "inspect.CO_OPTIMIZED == 1 — bit 0 flag: code object uses LOAD_FAST/STORE_FAST for locals; wave 294; new to extra165"
