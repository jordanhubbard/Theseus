  expected: true

invariant inspect_extra165.co_varkeywords_eq_8:
  description: "inspect.CO_VARKEYWORDS == 8 — bit 3 flag: code object accepts **kwargs variadic keyword dict; wave 294; new to extra165"
  kind: python_call_eq
  function: CO_VARKEYWORDS.__eq__
  args: [8]
  expected: true

invariant inspect_extra165.co_varkeywords_class_int:
  description: "inspect.CO_VARKEYWORDS.__class__.__name__ == 'int' — CO_VARKEYWORDS is a plain Python int constant; wave 294; new to extra165"
  kind: python_call_eq
