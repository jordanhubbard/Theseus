  expected: true

invariant inspect_extra165.co_varargs_class_int:
  description: "inspect.CO_VARARGS.__class__.__name__ == 'int' — CO_VARARGS is a plain Python int constant; wave 294; new to extra165"
  kind: python_call_eq
