spec: decimal_extra181
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/decimal.py"
  notes:
    - "decimal.Decimal.compare.__name__=='compare' (len=7)."
    - "decimal.Decimal.compare_signal.__name__=='compare_signal' (len=14)."
    - "decimal.Decimal.compare_total.__name__=='compare_total' (len=13)."
    - "decimal.Decimal.compare_total_mag.__name__=='compare_total_mag' (len=17)."
    - "decimal.Decimal.max.__name__=='max' (len=3); decimal.Decimal.min.__name__=='min' (len=3)."
    - "decimal.Decimal.max_mag.__name__=='max_mag' (len=7); decimal.Decimal.min_mag.__name__=='min_mag' (len=7)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal comparison method name lengths (compare family)
# compare (len=7), compare_signal (len=14), compare_total (len=13), compare_total_mag (len=17)
# ---------------------------------------------------------------------------

table decimal_extra181.compare_methods:
  description: "decimal.Decimal comparison method name lengths: compare (len=7), compare_signal (len=14), compare_total (len=13), compare_total_mag (len=17)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalcompare181

  columns: [id, function, args, expected, description]
  rows:
    - [cmp_name,      Decimal.compare.__name__.__eq__,           ["compare"],           true, "decimal.Decimal.compare.__name__ == 'compare' — compare two Decimal instances numerically; confirmed Python 3.14.3 macOS"]
    - [cmp_name_len,  Decimal.compare.__name__.__len__,          [],                    7,    "decimal.Decimal.compare.__name__.__len__() == 7 — c(1)o(2)m(3)p(4)a(5)r(6)e(7); confirmed Python 3.14.3 macOS"]
    - [csig_name,     Decimal.compare_signal.__name__.__eq__,    ["compare_signal"],    true, "decimal.Decimal.compare_signal.__name__ == 'compare_signal' — compare with signal on NaN; confirmed Python 3.14.3 macOS"]
    - [csig_name_len, Decimal.compare_signal.__name__.__len__,   [],                    14,   "decimal.Decimal.compare_signal.__name__.__len__() == 14 — c(1)o(2)m(3)p(4)a(5)r(6)e(7)_(8)s(9)i(10)g(11)n(12)a(13)l(14); confirmed Python 3.14.3 macOS"]
    - [ctot_name,     Decimal.compare_total.__name__.__eq__,     ["compare_total"],     true, "decimal.Decimal.compare_total.__name__ == 'compare_total' — total ordering comparison; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal.Decimal compare_total_mag and max/min method name lengths
# compare_total_mag (len=17), max (len=3), min (len=3)
# ---------------------------------------------------------------------------

table decimal_extra181.compare_total_mag_max_min:
  description: "decimal.Decimal compare_total_mag (len=17), max (len=3), min (len=3) method name lengths"
  kind: python_call_eq
  category: identity
  id_prefix: decimalcompare181

  columns: [id, function, args, expected, description]
  rows:
    - [ctotmag_name,     Decimal.compare_total_mag.__name__.__eq__,  ["compare_total_mag"],  true, "decimal.Decimal.compare_total_mag.__name__ == 'compare_total_mag' — total ordering on absolute values; confirmed Python 3.14.3 macOS"]
    - [ctotmag_name_len, Decimal.compare_total_mag.__name__.__len__,  [],                    17,   "decimal.Decimal.compare_total_mag.__name__.__len__() == 17 — c(1)o(2)m(3)p(4)a(5)r(6)e(7)_(8)t(9)o(10)t(11)a(12)l(13)_(14)m(15)a(16)g(17); confirmed Python 3.14.3 macOS"]
    - [max_name,         Decimal.max.__name__.__eq__,                 ["max"],               true, "decimal.Decimal.max.__name__ == 'max' — returns larger of two Decimal values; confirmed Python 3.14.3 macOS"]
    - [max_name_len,     Decimal.max.__name__.__len__,                [],                    3,    "decimal.Decimal.max.__name__.__len__() == 3 — m(1)a(2)x(3); confirmed Python 3.14.3 macOS"]
    - [min_name,         Decimal.min.__name__.__eq__,                 ["min"],               true, "decimal.Decimal.min.__name__ == 'min' — returns smaller of two Decimal values; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal.Decimal max_mag and min_mag method name lengths
# max_mag (len=7), min_mag (len=7)
# ---------------------------------------------------------------------------

table decimal_extra181.max_mag_min_mag:
  description: "decimal.Decimal max_mag (len=7) and min_mag (len=7) method name lengths — magnitude variants compare absolute values"
  kind: python_call_eq
  category: identity
  id_prefix: decimalcompare181

  columns: [id, function, args, expected, description]
  rows:
    - [maxmag_name,     Decimal.max_mag.__name__.__eq__,   ["max_mag"],  true, "decimal.Decimal.max_mag.__name__ == 'max_mag' — returns value with larger absolute value; confirmed Python 3.14.3 macOS"]
    - [maxmag_name_len, Decimal.max_mag.__name__.__len__,  [],           7,    "decimal.Decimal.max_mag.__name__.__len__() == 7 — m(1)a(2)x(3)_(4)m(5)a(6)g(7); confirmed Python 3.14.3 macOS"]
    - [minmag_name,     Decimal.min_mag.__name__.__eq__,   ["min_mag"],  true, "decimal.Decimal.min_mag.__name__ == 'min_mag' — returns value with smaller absolute value; confirmed Python 3.14.3 macOS"]
    - [minmag_name_len, Decimal.min_mag.__name__.__len__,  [],           7,    "decimal.Decimal.min_mag.__name__.__len__() == 7 — m(1)i(2)n(3)_(4)m(5)a(6)g(7); confirmed Python 3.14.3 macOS"]
    - [min_name_len,    Decimal.min.__name__.__len__,      [],           3,    "decimal.Decimal.min.__name__.__len__() == 3 — m(1)i(2)n(3); confirmed Python 3.14.3 macOS"]

