spec: deep_extend
version: ">=0.6.0"
backend: node(deep-extend)

docs: https://www.npmjs.com/package/deep-extend

provenance:
  derived_from:
    - "deep-extend README — https://www.npmjs.com/package/deep-extend"
    - "Test vectors verified with deep-extend via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "deep-extend source"
  notes:
    - "deep-extend is an npm package. Install: npm install deep-extend"
    - "extend(target, ...sources) recursively merges sources into target and returns target."
    - "Properties in later sources overwrite earlier ones at each level."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns merged target object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table deep_extend.extend:
  kind: node_module_call_eq
  function: ~
  category: extend
  id_prefix: dext

  columns: [id, args, expected]
  rows:
    - [simple,   [{}, {"a": 1}],                           {"a": 1}]
    - [merge,    [{}, {"a": 1}, {"b": 2}],                 {"a": 1, "b": 2}]
    - [overwrite,[{}, {"a": 1}, {"a": 2}],                 {"a": 2}]
    - [deep,     [{}, {"a": {"x": 1}}, {"a": {"y": 2}}],   {"a": {"x": 1, "y": 2}}]
    - [array,    [{}, {"a": [1, 2]}],                      {"a": [1, 2]}]
