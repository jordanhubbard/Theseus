spec: csv_extra25
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra24.zspec.zsdl."
    - "Prior specs covered: reader/writer/DictReader/DictWriter/Dialect/Error __name__/__module__/__qualname__/__bases__, DictReader/DictWriter __init__.__name__, reader/writer __qualname__, register_dialect/unregister_dialect/list_dialects/field_size_limit/get_dialect __name__, QUOTE_ALL/QUOTE_MINIMAL/QUOTE_NONNUMERIC/QUOTE_NONE values and __class__.__module__."
    - "This spec covers: __len__() of __module__ strings for DictReader, DictWriter, Dialect, Error, reader, writer, register_dialect, field_size_limit; __len__() of __name__ strings for DictReader, DictWriter, Dialect, Error."
    - "No prior csv spec checks csv.DictReader.__module__.__len__()."
    - "No prior csv spec checks csv.DictWriter.__module__.__len__()."
    - "No prior csv spec checks csv.Dialect.__module__.__len__()."
    - "No prior csv spec checks csv.Error.__module__.__len__()."
    - "No prior csv spec checks csv.DictReader.__name__.__len__()."
    - "No prior csv spec checks csv.DictWriter.__name__.__len__()."
    - "No prior csv spec checks csv.Dialect.__name__.__len__()."
    - "No prior csv spec checks csv.Error.__name__.__len__()."
    - "No prior csv spec checks csv.reader.__module__.__len__()."
    - "No prior csv spec checks csv.writer.__module__.__len__()."
    - "No prior csv spec checks csv.register_dialect.__module__.__len__()."
    - "No prior csv spec checks csv.field_size_limit.__module__.__len__()."
    - "csv.DictReader.__module__ == 'csv' — len 3 (pure-Python class)."
    - "csv.DictWriter.__module__ == 'csv' — len 3 (pure-Python class)."
    - "csv.Dialect.__module__ == 'csv' — len 3."
    - "csv.Error.__module__ == '_csv' — len 4 (C extension class)."
    - "csv.DictReader.__name__ == 'DictReader' — len 10."
    - "csv.DictWriter.__name__ == 'DictWriter' — len 10."
    - "csv.Dialect.__name__ == 'Dialect' — len 7."
    - "csv.Error.__name__ == 'Error' — len 5."
    - "csv.reader.__module__ == '_csv' — len 4 (C extension type)."
    - "csv.writer.__module__ == '_csv' — len 4 (C extension type)."
    - "csv.register_dialect.__module__ == '_csv' — len 4 (C extension function)."
    - "csv.field_size_limit.__module__ == '_csv' — len 4 (C extension function)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() for DictReader, DictWriter, Dialect, Error
#
# DictReader, DictWriter, and Dialect are pure-Python classes in 'csv' (len 3).
# Error is a C extension class in '_csv' (len 4).  No prior csv spec checks the
# length of any class's __module__ string.
# ---------------------------------------------------------------------------

invariant csv_extra25.DictReader.module.len:
  description: "csv.DictReader.__module__.__len__() == 3 — 'csv' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: DictReader.__module__.__len__
  args: []
  expected: 3

invariant csv_extra25.DictWriter.module.len:
  description: "csv.DictWriter.__module__.__len__() == 3 — 'csv' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: DictWriter.__module__.__len__
  args: []
  expected: 3

invariant csv_extra25.Dialect.module.len:
  description: "csv.Dialect.__module__.__len__() == 3 — 'csv' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: Dialect.__module__.__len__
  args: []
  expected: 3

invariant csv_extra25.Error.module.len:
  description: "csv.Error.__module__.__len__() == 4 — '_csv' has 4 characters"
  category: string_lengths
  kind: python_call_eq
  function: Error.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# __name__.__len__() for DictReader, DictWriter, Dialect, Error
#
# 'DictReader' and 'DictWriter' each have length 10; 'Dialect' has length 7;
# 'Error' has length 5.  No prior csv spec checks the length of any class's
# __name__ string.
# ---------------------------------------------------------------------------

invariant csv_extra25.DictReader.name.len:
  description: "csv.DictReader.__name__.__len__() == 10 — 'DictReader' has 10 characters"
  category: string_lengths
  kind: python_call_eq
  function: DictReader.__name__.__len__
  args: []
  expected: 10

invariant csv_extra25.DictWriter.name.len:
  description: "csv.DictWriter.__name__.__len__() == 10 — 'DictWriter' has 10 characters"
  category: string_lengths
  kind: python_call_eq
  function: DictWriter.__name__.__len__
  args: []
  expected: 10

invariant csv_extra25.Dialect.name.len:
  description: "csv.Dialect.__name__.__len__() == 7 — 'Dialect' has 7 characters"
  category: string_lengths
  kind: python_call_eq
  function: Dialect.__name__.__len__
  args: []
  expected: 7

invariant csv_extra25.Error.name.len:
  description: "csv.Error.__name__.__len__() == 5 — 'Error' has 5 characters"
  category: string_lengths
  kind: python_call_eq
  function: Error.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# __module__.__len__() for reader, writer, register_dialect, field_size_limit
#
# reader, writer, register_dialect, and field_size_limit are all C extension
# objects with __module__ == '_csv' (len 4).  No prior csv spec checks the
# length of any of these __module__ strings.
# ---------------------------------------------------------------------------

invariant csv_extra25.reader.module.len:
  description: "csv.reader.__module__.__len__() == 4 — '_csv' has 4 characters"
  category: string_lengths
  kind: python_call_eq
  function: reader.__module__.__len__
  args: []
  expected: 4

invariant csv_extra25.writer.module.len:
  description: "csv.writer.__module__.__len__() == 4 — '_csv' has 4 characters"
  category: string_lengths
  kind: python_call_eq
  function: writer.__module__.__len__
  args: []
  expected: 4

invariant csv_extra25.register_dialect.module.len:
  description: "csv.register_dialect.__module__.__len__() == 4 — '_csv' has 4 characters"
  category: string_lengths
  kind: python_call_eq
  function: register_dialect.__module__.__len__
  args: []
  expected: 4

invariant csv_extra25.field_size_limit.module.len:
  description: "csv.field_size_limit.__module__.__len__() == 4 — '_csv' has 4 characters"
  category: string_lengths
  kind: python_call_eq
  function: field_size_limit.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Consolidated table — all twelve new invariants
#
# All twelve are first covered in this spec (csv_extra25).
# ---------------------------------------------------------------------------

table csv_extra25.module_and_name_lengths:
  description: "csv class and function __module__/__name__ string lengths via __len__()"
  kind: python_call_eq
  category: string_lengths
  id_prefix: cfa25

  columns: [id, function, args, expected]
  rows:
    - [DictReader_module_len,         DictReader.__module__.__len__,         [], 3]
    - [DictWriter_module_len,         DictWriter.__module__.__len__,         [], 3]
    - [Dialect_module_len,            Dialect.__module__.__len__,            [], 3]
    - [Error_module_len,              Error.__module__.__len__,              [], 4]
    - [DictReader_name_len,           DictReader.__name__.__len__,           [], 10]
    - [DictWriter_name_len,           DictWriter.__name__.__len__,           [], 10]
    - [Dialect_name_len,              Dialect.__name__.__len__,              [],  7]
    - [Error_name_len,                Error.__name__.__len__,                [],  5]
    - [reader_module_len,             reader.__module__.__len__,             [],  4]
    - [writer_module_len,             writer.__module__.__len__,             [],  4]
    - [register_dialect_module_len,   register_dialect.__module__.__len__,   [],  4]
    - [field_size_limit_module_len,   field_size_limit.__module__.__len__,   [],  4]
