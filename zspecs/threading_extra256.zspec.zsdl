spec: threading_extra256
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading.TIMEOUT_MAX type and value contracts; threading.__all__ membership checks."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant (9223372036.0 on this platform). Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__gt__(1000000) == True — TIMEOUT_MAX is much larger than one million seconds. Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is positive. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('Thread') == True — Thread is in the public API. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('Lock') == True — Lock is in the public API. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('Event') == True — Event is in the public API. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('TIMEOUT_MAX') == True — TIMEOUT_MAX is in the public API. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('BrokenBarrierError') == True — BrokenBarrierError is in the public API. Verified with Python 3.14.3."
    - "threading.__all__.__len__() == 28 — __all__ has exactly 28 public members. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.TIMEOUT_MAX type and value contracts
#
# threading.TIMEOUT_MAX.__class__.__name__ == 'float'
# threading.TIMEOUT_MAX.__gt__(1000000) == True
# threading.TIMEOUT_MAX.__gt__(0) == True
#
# TIMEOUT_MAX is a platform-dependent float constant representing the maximum
# timeout value accepted by blocking primitives. New to extra256.
# ---------------------------------------------------------------------------

table threading_extra256.timeout_max_contracts:
  description: "threading.TIMEOUT_MAX class, gt(1000000), gt(0) behavioral contracts; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: tmax256

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_max_class_eq,
       TIMEOUT_MAX.__class__.__name__.__eq__,
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — TIMEOUT_MAX is a float constant; __class__.__name__ is 'float'; new to extra256"]
    - [timeout_max_gt_million,
       TIMEOUT_MAX.__gt__,
       [1000000],
       true,
       "threading.TIMEOUT_MAX.__gt__(1000000) == True — TIMEOUT_MAX is much larger than one million seconds; new to extra256"]
    - [timeout_max_gt_zero,
       TIMEOUT_MAX.__gt__,
       [0],
       true,
       "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a positive float value; new to extra256"]
    - [timeout_max_class_name_len_5,
       TIMEOUT_MAX.__class__.__name__.__len__,
       [],
       5,
       "threading.TIMEOUT_MAX.__class__.__name__.__len__() == 5 — 'float' has 5 characters; new to extra256"]
    - [timeout_max_class_class_eq,
       TIMEOUT_MAX.__class__.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.TIMEOUT_MAX.__class__.__class__.__name__.__eq__('type') == True — float's metaclass is 'type'; new to extra256"]

# ---------------------------------------------------------------------------
# Table 2: threading.__all__ membership
#
# threading.__all__ contains 'Thread', 'Lock', 'Event', 'TIMEOUT_MAX',
# 'BrokenBarrierError'. __len__ is 28.
#
# These are core public API members of the threading module. New to extra256.
# ---------------------------------------------------------------------------

table threading_extra256.all_membership:
  description: "threading.__all__ contains core public API members and has length 28; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: thdall256

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_thread,
       "__all__.__contains__",
       ["Thread"],
       true,
       "threading.__all__.__contains__('Thread') == True — Thread is a public API member of threading listed in __all__; new to extra256"]
    - [all_contains_lock,
       "__all__.__contains__",
       ["Lock"],
       true,
       "threading.__all__.__contains__('Lock') == True — Lock is a public API member of threading listed in __all__; new to extra256"]
    - [all_contains_event,
       "__all__.__contains__",
       ["Event"],
       true,
       "threading.__all__.__contains__('Event') == True — Event is a public API member of threading listed in __all__; new to extra256"]
    - [all_contains_timeout_max,
       "__all__.__contains__",
       ["TIMEOUT_MAX"],
       true,
       "threading.__all__.__contains__('TIMEOUT_MAX') == True — TIMEOUT_MAX is a public API member of threading listed in __all__; new to extra256"]
    - [all_len_28,
       "__all__.__len__",
       [],
       28,
       "threading.__all__.__len__() == 28 — __all__ has exactly 28 public members; new to extra256"]

# ---------------------------------------------------------------------------
# Table 3: threading.__all__ additional membership
#
# threading.__all__ also contains 'BrokenBarrierError', 'Barrier', 'Timer',
# 'ThreadError'. New to extra256.
# ---------------------------------------------------------------------------

table threading_extra256.all_membership_ext:
  description: "threading.__all__ contains BrokenBarrierError, Barrier, Timer, ThreadError; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: thdallext256

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_broken_barrier_error,
       "__all__.__contains__",
       ["BrokenBarrierError"],
       true,
       "threading.__all__.__contains__('BrokenBarrierError') == True — BrokenBarrierError is a public API member of threading listed in __all__; new to extra256"]
    - [all_contains_barrier,
       "__all__.__contains__",
       ["Barrier"],
       true,
       "threading.__all__.__contains__('Barrier') == True — Barrier is a public API member of threading listed in __all__; new to extra256"]
    - [all_contains_timer,
       "__all__.__contains__",
       ["Timer"],
       true,
       "threading.__all__.__contains__('Timer') == True — Timer is a public API member of threading listed in __all__; new to extra256"]
    - [all_contains_thread_error,
       "__all__.__contains__",
       ["ThreadError"],
       true,
       "threading.__all__.__contains__('ThreadError') == True — ThreadError is a public API member of threading listed in __all__; new to extra256"]
    - [all_contains_rlock,
       "__all__.__contains__",
       ["RLock"],
       true,
       "threading.__all__.__contains__('RLock') == True — RLock is a public API member of threading listed in __all__; new to extra256"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra256
# ---------------------------------------------------------------------------

invariant threading_extra256.TIMEOUT_MAX.class_is_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant; new to extra256"
  category: identity
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra256.TIMEOUT_MAX.gt_million:
  description: "threading.TIMEOUT_MAX.__gt__(1000000) == True — TIMEOUT_MAX exceeds one million seconds; new to extra256"
  category: identity
  kind: python_call_eq
  function: TIMEOUT_MAX.__gt__
  args: [1000000]
  expected: true

invariant threading_extra256.TIMEOUT_MAX.gt_zero:
  description: "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a positive value; new to extra256"
  category: identity
  kind: python_call_eq
  function: TIMEOUT_MAX.__gt__
  args: [0]
  expected: true

invariant threading_extra256.all.contains_thread:
  description: "threading.__all__.__contains__('Thread') == True — Thread is in the threading public API; new to extra256"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Thread"]
  expected: true

invariant threading_extra256.all.contains_lock:
  description: "threading.__all__.__contains__('Lock') == True — Lock is in the threading public API; new to extra256"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Lock"]
  expected: true

invariant threading_extra256.all.contains_event:
  description: "threading.__all__.__contains__('Event') == True — Event is in the threading public API; new to extra256"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Event"]
  expected: true

invariant threading_extra256.all.contains_timeout_max:
  description: "threading.__all__.__contains__('TIMEOUT_MAX') == True — TIMEOUT_MAX is in the threading public API; new to extra256"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["TIMEOUT_MAX"]
  expected: true

invariant threading_extra256.all.contains_broken_barrier_error:
  description: "threading.__all__.__contains__('BrokenBarrierError') == True — BrokenBarrierError is in the threading public API; new to extra256"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["BrokenBarrierError"]
  expected: true

invariant threading_extra256.all.len_28:
  description: "threading.__all__.__len__() == 28 — exactly 28 public members in __all__; new to extra256"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 28
