# ---------------------------------------------------------------------------
# socket.socket.bind/__class__.__name__.__eq__('method_descriptor') — standalone
#
# socket.socket.bind is a C-level method_descriptor from _socket.SocketType.
# bind is the foundational method for binding a socket to an address. No prior
# socket spec anchors socket.socket.bind.__class__.__name__.__eq__ as a standalone
# under socketsocketmethods93. First standalone for socket.socket.bind class name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra93.bind_method_desc:
  description: "socket.socket.bind.__class__.__name__.__eq__('method_descriptor') == True — socket.socket.bind is a C-level method_descriptor from _socket.SocketType; bind is the foundational method for binding a socket to an address; no prior socket spec anchors this __eq__ call as a standalone; first standalone for socket.socket.bind class name under socketsocketmethods93"
  category: class_attrs
  kind: python_call_eq
  function: socket.bind.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
