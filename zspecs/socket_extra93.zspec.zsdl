# socketsocketmethods93. First standalone for socket.socket.recv class name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra93.recv_method_desc:
  description: "socket.socket.recv.__class__.__name__.__eq__('method_descriptor') == True — socket.socket.recv is a C-level method_descriptor; it is the primary method for receiving data from a connected socket; no prior socket spec anchors this __eq__ call as a standalone; first standalone for socket.socket.recv class name under socketsocketmethods93"
  category: class_attrs
  kind: python_call_eq
  function: socket.recv.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

