# ---------------------------------------------------------------------------
# socket.socket.send/__class__.__name__.__eq__('method_descriptor')
# socket.socket.sendall/__class__.__name__.__eq__('method_descriptor')
# socket.socket.sendfile/__class__.__name__.__eq__('function')
# socket.socket.makefile/__class__.__name__.__eq__('function')
# socket.socket.detach/__class__.__name__.__eq__('function')
#
# Wave 257 theme: socket.socket send methods and Python-level method cross-checks.
#
# send and sendall are C-level method_descriptor objects. sendfile, makefile,
# and detach are Python-level function objects (socket_extra90 first anchors them).
# This table groups C-level send methods and adds Python-level cross-checks
# under socketsocketmethods93. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra93.socket_send_and_python_methods:
  description: "socket.socket.send/__class__.__name__.__eq__('method_descriptor')==True / sendall/__class__.__name__.__eq__('method_descriptor')==True / sendfile/__class__.__name__.__eq__('function')==True / makefile/__class__.__name__.__eq__('function')==True / detach/__class__.__name__.__eq__('function')==True — send/sendall are C-level method_descriptor; sendfile/makefile/detach are Python-level function (socket_extra90 first anchors the function ones); this table first-anchors send/sendall and cross-checks the Python methods; first socketsocketmethods93 anchor for send/sendall class names"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketsocketmethods93

  columns: [id, function, args, expected]
  rows:
    - [send_method_desc,     socket.send.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [sendall_method_desc,  socket.sendall.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [sendfile_func_xchk,   socket.sendfile.__class__.__name__.__eq__, ["function"],          true]
    - [makefile_func_xchk,   socket.makefile.__class__.__name__.__eq__, ["function"],          true]
    - [detach_func_xchk,     socket.detach.__class__.__name__.__eq__,   ["function"],          true]

