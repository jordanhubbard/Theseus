  id_prefix: socketsocketmethods93

  columns: [id, function, args, expected]
  rows:
    - [getsockopt_method_desc, socket.getsockopt.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [setsockopt_method_desc, socket.setsockopt.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [gettimeout_method_desc, socket.gettimeout.__class__.__name__.__eq__, ["method_descriptor"], true]
