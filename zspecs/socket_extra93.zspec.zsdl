  function: socket.settimeout.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.fileno/__class__.__name__.__eq__('method_descriptor') — standalone
#
# socket.socket.fileno is a C-level method_descriptor. fileno returns the
# integer file descriptor of the socket, used for integration with I/O
# multiplexing calls like select() and poll(). No prior socket spec anchors
# socket.socket.fileno.__class__.__name__.__eq__ as a standalone under
# socketsocketmethods93. First standalone for socket.socket.fileno class name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra93.fileno_method_desc:
  description: "socket.socket.fileno.__class__.__name__.__eq__('method_descriptor') == True — socket.socket.fileno is a C-level method_descriptor returning the integer file descriptor; used with select()/poll() for I/O multiplexing; no prior socket spec anchors this __eq__ call as a standalone; first standalone for socket.socket.fileno class name under socketsocketmethods93"
  category: class_attrs
  kind: python_call_eq
  function: socket.fileno.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true
