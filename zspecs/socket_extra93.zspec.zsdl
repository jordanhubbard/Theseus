spec: socket_extra93
version: ">=3.9"
extends: socket_extra92
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra92.zspec.zsdl — covers socket.socket class string identity / socket.socket class hierarchy / socket exception hierarchy / AddressFamily/SocketKind class identity (table + invariants)."
    - "socket_extra91.zspec.zsdl — covers socket module string identity cross-checks / socket.socket dunder method class names / socket constant class names and values (table + invariants)."
    - "socket_extra90.zspec.zsdl — covers socket.socket Python-level method __class__.__name__ identity (accept/close/makefile/__init__/sendfile/detach/dup/__enter__/__exit__/__repr__/create_connection/create_server/getfqdn all 'function') (table + invariants)."
    - "socket_extra89.zspec.zsdl — covers socket module integer constants class identity (AF_INET/AF_INET6/AF_UNSPEC AddressFamily, SOCK_DGRAM/SOCK_RAW/SOCK_SEQPACKET SocketKind, IPPROTO_TCP/IPPROTO_UDP/IPPROTO_ICMP int) (table + invariants)."
    - "socket_extra88.zspec.zsdl — covers socket.socket.__dict__ negative membership / AddressFamily and SocketKind class identity (__qualname__/__module__/__mro__.__len__()==6/__name__) (table + invariants)."
    - "socket_extra86.zspec.zsdl — covers socket.socket/__module__/__qualname__/__mro__.__len__()==3/__bases__[0].__name__ / AF_INET/SOCK_STREAM class identity / AddressFamily/SocketKind __bases__[0].__name__/__qualname__ (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra92; it does NOT duplicate invariants present in those files."
    - "Wave 257 theme: socket.socket method class names — C-level methods are method_descriptor, Python-level methods are function."
    - "socket.socket.bind.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.connect_ex.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv_into.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.send.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendall.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockopt.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.gettimeout.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.fileno.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.shutdown.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom_into.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendto.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recvmsg.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendmsg.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setblocking.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getblocking.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockname.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getpeername.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: bind/connect/connect_ex/listen/recv/recv_into/recvfrom/recvfrom_into/send/sendto/sendall/getsockname/getpeername/getsockopt/setsockopt/gettimeout/settimeout/setblocking/getblocking/fileno/shutdown/recvmsg/sendmsg are all C-level method_descriptor objects from _socket.SocketType."
    - "Note: socket_extra90 anchors accept/close/makefile/sendfile/detach/dup as Python-level 'function'; this spec anchors the complementary C-level method_descriptor group."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.bind/__class__.__name__.__eq__('method_descriptor')
# socket.socket.connect/__class__.__name__.__eq__('method_descriptor')
# socket.socket.connect_ex/__class__.__name__.__eq__('method_descriptor')
# socket.socket.listen/__class__.__name__.__eq__('method_descriptor')
# socket.socket.recv/__class__.__name__.__eq__('method_descriptor')
# socket.socket.recv_into/__class__.__name__.__eq__('method_descriptor')
#
# Wave 257 theme: socket.socket C-level method_descriptor class names (group 1).
#
# bind, connect, connect_ex, listen, recv, and recv_into are C-level methods
# from _socket.SocketType; their __class__.__name__ is 'method_descriptor'.
# No prior socket spec anchors any of these under socketsocketmethods93.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra93.socket_methods_c_level_group1:
  description: "socket.socket.bind/__class__.__name__.__eq__('method_descriptor')==True / connect/__class__.__name__.__eq__('method_descriptor')==True / connect_ex/__class__.__name__.__eq__('method_descriptor')==True / listen/__class__.__name__.__eq__('method_descriptor')==True / recv/__class__.__name__.__eq__('method_descriptor')==True / recv_into/__class__.__name__.__eq__('method_descriptor')==True — bind/connect/connect_ex/listen/recv/recv_into are C-level method_descriptor objects from _socket.SocketType; no prior socket spec anchors these under socketsocketmethods93; first socketsocketmethods93 anchor for C-level socket method class names (group 1)"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketsocketmethods93

  columns: [id, function, args, expected]
  rows:
    - [bind_method_desc,       socket.bind.__class__.__name__.__eq__,       ["method_descriptor"], true]
    - [connect_method_desc,    socket.connect.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [connect_ex_method_desc, socket.connect_ex.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [listen_method_desc,     socket.listen.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [recv_method_desc,       socket.recv.__class__.__name__.__eq__,       ["method_descriptor"], true]
    - [recv_into_method_desc,  socket.recv_into.__class__.__name__.__eq__,  ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# socket.socket.getsockopt/__class__.__name__.__eq__('method_descriptor')
# socket.socket.setsockopt/__class__.__name__.__eq__('method_descriptor')
# socket.socket.gettimeout/__class__.__name__.__eq__('method_descriptor')
# socket.socket.settimeout/__class__.__name__.__eq__('method_descriptor')
# socket.socket.fileno/__class__.__name__.__eq__('method_descriptor')
# socket.socket.shutdown/__class__.__name__.__eq__('method_descriptor')
#
# Wave 257 theme: socket.socket C-level method_descriptor class names (group 2).
#
# getsockopt, setsockopt, gettimeout, settimeout, fileno, and shutdown are
# C-level methods from _socket.SocketType. Their __class__.__name__ is
# 'method_descriptor'. No prior socket spec anchors these under socketsocketmethods93.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra93.socket_methods_c_level_group2:
  description: "socket.socket.getsockopt/__class__.__name__.__eq__('method_descriptor')==True / setsockopt/__class__.__name__.__eq__('method_descriptor')==True / gettimeout/__class__.__name__.__eq__('method_descriptor')==True / settimeout/__class__.__name__.__eq__('method_descriptor')==True / fileno/__class__.__name__.__eq__('method_descriptor')==True / shutdown/__class__.__name__.__eq__('method_descriptor')==True — getsockopt/setsockopt/gettimeout/settimeout/fileno/shutdown are C-level method_descriptor objects from _socket.SocketType; no prior socket spec anchors these under socketsocketmethods93; first socketsocketmethods93 anchor for C-level socket method class names (group 2)"
