# ---------------------------------------------------------------------------
# socket.socket.settimeout/__class__.__name__.__eq__('method_descriptor') — standalone
#
# socket.socket.settimeout is a C-level method_descriptor. settimeout controls
# the socket's blocking/timeout behavior and is a commonly used configuration
# method. No prior socket spec anchors socket.socket.settimeout.__class__.__name__.__eq__
# as a standalone under socketsocketmethods93.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra93.settimeout_method_desc:
  description: "socket.socket.settimeout.__class__.__name__.__eq__('method_descriptor') == True — socket.socket.settimeout is a C-level method_descriptor controlling the socket's blocking/timeout behavior; no prior socket spec anchors this __eq__ call as a standalone; first standalone for socket.socket.settimeout class name under socketsocketmethods93"
  category: class_attrs
