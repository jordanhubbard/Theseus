spec: multiprocessing_extra305
version: ">=3.4"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Extends multiprocessing.zspec.zsdl, multiprocessing_extra.zspec.zsdl, multiprocessing_extra2.zspec.zsdl, multiprocessing_extra3.zspec.zsdl."
    - "This spec focuses on module-level identity attributes and top-level function return-type checks."
    - "multiprocessing.__name__ == 'multiprocessing' — the module name attribute."
    - "multiprocessing.__package__ == 'multiprocessing' — the package attribute."
    - "multiprocessing.__spec__.name == 'multiprocessing' — the ModuleSpec name."
    - "multiprocessing.cpu_count().__class__.__name__ == 'int' — cpu_count always returns an int."
    - "multiprocessing.cpu_count().__gt__(0) == True — at least one CPU is always present."
    - "multiprocessing.get_start_method().__class__.__name__ == 'str' — start method is a string."
    - "multiprocessing.get_start_method().__eq__('spawn') == True — default on macOS is 'spawn' (Python 3.12+)."
    - "multiprocessing.get_all_start_methods().__class__.__name__ == 'list' — returns a list of strings."
    - "On macOS with Python 3.12+, the default start method changed from 'fork' to 'spawn'. Verified: 'spawn' on Python 3.14.4/macOS."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module identity — __name__, __package__, __spec__.name
#
# These three attributes collectively identify the multiprocessing module.
# __spec__.name is accessible via the dotted attribute chain __spec__.__name__
# using the ModuleSpec object's name field.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra305.module.name:
  description: "multiprocessing.__name__ == 'multiprocessing'"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["multiprocessing"]
  expected: true

invariant multiprocessing_extra305.module.package:
  description: "multiprocessing.__package__ == 'multiprocessing'"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["multiprocessing"]
  expected: true

invariant multiprocessing_extra305.module.spec_name:
  description: "multiprocessing.__spec__.name == 'multiprocessing'"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["multiprocessing"]
  expected: true

# ---------------------------------------------------------------------------
# cpu_count() — return type and positivity
#
# cpu_count() returns a platform-specific integer representing the number of
# CPUs. multiprocessing_extra3 covers the return type; this spec rechecks it
# as a standalone invariant and also verifies the value is positive.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra305.cpu_count.class_is_int:
  description: "multiprocessing.cpu_count().__class__.__name__ == 'int'"
  category: cpu_count
  kind: python_call_eq
  function: cpu_count
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["int"]
  expected: true

invariant multiprocessing_extra305.cpu_count.gt_zero:
  description: "multiprocessing.cpu_count().__gt__(0) == True — at least one CPU"
  category: cpu_count
  kind: python_call_eq
  function: cpu_count
  args: []
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# get_start_method() — return type and default value on macOS
#
# On macOS with Python 3.12 and later, the default start method is 'spawn'.
# get_start_method() returns a str; its value is 'spawn' on this platform.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra305.get_start_method.class_is_str:
  description: "multiprocessing.get_start_method().__class__.__name__ == 'str'"
  category: start_methods
  kind: python_call_eq
  function: get_start_method
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

invariant multiprocessing_extra305.get_start_method.default_is_spawn:
  description: "multiprocessing.get_start_method() == 'spawn' on macOS Python 3.12+"
  category: start_methods
  kind: python_call_eq
  function: get_start_method
  args: []
  method: __eq__
  method_args: ["spawn"]
  expected: true

# ---------------------------------------------------------------------------
# get_all_start_methods() — return type
#
# get_all_start_methods() returns a list of the supported start method names
# for the current platform. On macOS this is ['spawn', 'fork', 'forkserver'].
# ---------------------------------------------------------------------------

invariant multiprocessing_extra305.get_all_start_methods.class_is_list:
  description: "multiprocessing.get_all_start_methods().__class__.__name__ == 'list'"
  category: start_methods
  kind: python_call_eq
  function: get_all_start_methods
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["list"]
  expected: true
