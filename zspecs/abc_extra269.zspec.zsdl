spec: abc_extra269
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "collections.abc.MutableSequence.__module__ == 'collections.abc'; __bases__[0].__name__ == 'Sequence'."
    - "collections.abc.MutableMapping.__module__ == 'collections.abc'; __bases__[0].__name__ == 'Mapping'."
    - "collections.abc.MutableSet.__module__ == 'collections.abc'; __bases__[0].__name__ == 'Set'."
    - "MutableSequence.__abstractmethods__ includes insert, __setitem__, __delitem__, __getitem__, __len__."
    - "MutableMapping.__abstractmethods__ includes __setitem__, __delitem__, __getitem__, __iter__, __len__."
    - "MutableSet.__abstractmethods__ includes add, discard, __contains__, __iter__, __len__."
    - "MutableSequence.append.__qualname__ == 'MutableSequence.append' (mixin method defined on the class)."
    - "MutableMapping.update.__qualname__ == 'MutableMapping.update'; MutableSet.remove.__qualname__ == 'MutableSet.remove'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# collections.abc.MutableSequence class identity — table
#
# MutableSequence inherits from Sequence and adds mutation methods.
# ---------------------------------------------------------------------------

table abc_extra269.mutablesequence_identity:
  description: "collections.abc.MutableSequence class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: msid

  columns: [id, function, args, expected, description]
  rows:
    - [ms_name,      collections.abc.MutableSequence.__name__.__eq__,    ["MutableSequence"],  true, "collections.abc.MutableSequence.__name__ == 'MutableSequence'"]
    - [ms_module,    collections.abc.MutableSequence.__module__.__eq__,  ["collections.abc"],  true, "collections.abc.MutableSequence.__module__ == 'collections.abc'"]
    - [ms_append,    collections.abc.MutableSequence.append.__name__.__eq__, ["append"],       true, "MutableSequence.append.__name__ == 'append'"]
    - [ms_insert,    collections.abc.MutableSequence.insert.__name__.__eq__, ["insert"],       true, "MutableSequence.insert.__name__ == 'insert'"]
    - [ms_remove,    collections.abc.MutableSequence.remove.__name__.__eq__, ["remove"],       true, "MutableSequence.remove.__name__ == 'remove'"]
    - [ms_extend,    collections.abc.MutableSequence.extend.__name__.__eq__, ["extend"],       true, "MutableSequence.extend.__name__ == 'extend'"]

# ---------------------------------------------------------------------------
# collections.abc.MutableMapping and MutableSet class identity — table
#
# MutableMapping inherits from Mapping; MutableSet inherits from Set.
# ---------------------------------------------------------------------------

table abc_extra269.mutablemapping_mutableset_identity:
  description: "collections.abc.MutableMapping and MutableSet class identity values"
  kind: python_call_eq
  category: identity
  id_prefix: mmsetid

  columns: [id, function, args, expected, description]
  rows:
    - [mm_name,    collections.abc.MutableMapping.__name__.__eq__,            ["MutableMapping"],  true, "collections.abc.MutableMapping.__name__ == 'MutableMapping'"]
    - [mm_module,  collections.abc.MutableMapping.__module__.__eq__,          ["collections.abc"], true, "collections.abc.MutableMapping.__module__ == 'collections.abc'"]
    - [mm_base,    "collections.abc.MutableMapping.__bases__[0].__name__.__eq__", ["Mapping"],     true, "MutableMapping.__bases__[0].__name__ == 'Mapping'"]
    - [mm_update,  collections.abc.MutableMapping.update.__name__.__eq__,     ["update"],          true, "MutableMapping.update.__name__ == 'update'"]
    - [ms_name,    collections.abc.MutableSet.__name__.__eq__,                ["MutableSet"],      true, "collections.abc.MutableSet.__name__ == 'MutableSet'"]
    - [ms_module,  collections.abc.MutableSet.__module__.__eq__,              ["collections.abc"], true, "collections.abc.MutableSet.__module__ == 'collections.abc'"]
    - [ms_base,    "collections.abc.MutableSet.__bases__[0].__name__.__eq__", ["Set"],             true, "MutableSet.__bases__[0].__name__ == 'Set'"]
    - [ms_discard, collections.abc.MutableSet.discard.__name__.__eq__,        ["discard"],         true, "MutableSet.discard.__name__ == 'discard'"]

# ---------------------------------------------------------------------------
# collections.abc.MutableSequence base class — standalone invariant
# ---------------------------------------------------------------------------

invariant abc_extra269.MutableSequence.bases0_name:
  description: "collections.abc.MutableSequence.__bases__[0].__name__ == 'Sequence'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.MutableSequence.__bases__[0].__name__.__eq__"
  args: ["Sequence"]
  expected: true

