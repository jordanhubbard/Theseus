spec: multiprocessing_extra95
version: ">=3.9"
backend: python_module(multiprocessing)
extends: multiprocessing_extra94

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/managers.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing_extra94.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing Manager class identity + multiprocessing.managers module info. NEW in extra95: BaseManager.__name__=='BaseManager'; BaseManager.__module__=='multiprocessing.managers'; BaseManager.__bases__[0].__name__=='object'; BaseManager.__mro__.__len__()==2; SyncManager.__name__=='SyncManager'; SyncManager.__module__=='multiprocessing.managers'; SyncManager.__bases__[0].__name__=='BaseManager'; SyncManager.__mro__.__len__()==3; multiprocessing.Manager.__class__.__name__=='method' (it is a bound method of the process context); multiprocessing.Manager.__qualname__=='BaseContext.Manager' (len=19); multiprocessing.cpu_count.__class__.__name__=='method'; multiprocessing.cpu_count.__qualname__=='BaseContext.cpu_count' (len=21); multiprocessing.active_children.__class__.__name__=='function'; multiprocessing.active_children.__qualname__=='active_children' (len=15); multiprocessing.freeze_support.__qualname__=='BaseContext.freeze_support' (len=26). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "BaseManager.__name__ == 'BaseManager'. BaseManager is the base class for all manager types in multiprocessing.managers. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "SyncManager.__bases__[0].__name__ == 'BaseManager'. SyncManager inherits directly from BaseManager. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Manager.__class__.__name__ == 'method'. multiprocessing.Manager is a bound method of the process context object, not a class. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Manager.__qualname__ == 'BaseContext.Manager' (len=19). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.active_children.__class__.__name__ == 'function'. active_children is a module-level function, not a bound method. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BaseManager class identity — extra95
#
# Wave 254 theme: multiprocessing Manager class identity + managers module info.
#
# BaseManager.__name__ == 'BaseManager'
# BaseManager.__module__ == 'multiprocessing.managers'
# BaseManager.__bases__[0].__name__ == 'object'
# BaseManager.__mro__.__len__() == 2
# ---------------------------------------------------------------------------

table multiprocessing_extra95.basemanager_identity:
  description: "multiprocessing.managers.BaseManager class identity checks in mpmanager95 namespace — wave 254 theme: multiprocessing Manager class identity; BaseManager is the base class for all manager types in multiprocessing.managers; it provides a way to create and use shared state between processes; BaseManager.__name__.__eq__('BaseManager')==True; BaseManager.__module__.__eq__('multiprocessing.managers')==True; BaseManager.__bases__[0].__name__.__eq__('object')==True (direct subclass of object with no intermediate base); BaseManager.__mro__.__len__()==2 (MRO is [BaseManager, object], minimal inheritance chain); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmanager95

  columns: [id, function, args, expected, description]
  rows:
    - [bm_name,    "BaseManager.__name__.__eq__",              ["BaseManager"],               true, "BaseManager.__name__ == 'BaseManager'; verified with Python 3.14.3"]
    - [bm_module,  "BaseManager.__module__.__eq__",            ["multiprocessing.managers"],  true, "BaseManager.__module__ == 'multiprocessing.managers'; verified with Python 3.14.3"]
    - [bm_base0,   "BaseManager.__bases__[0].__name__.__eq__", ["object"],                    true, "BaseManager.__bases__[0].__name__ == 'object' — direct subclass of object; verified with Python 3.14.3"]
    - [bm_mro_len, "BaseManager.__mro__.__len__",              [],                            2,    "BaseManager.__mro__.__len__() == 2 — MRO is [BaseManager, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# SyncManager class identity — extra95
#
# SyncManager.__name__ == 'SyncManager'
# SyncManager.__module__ == 'multiprocessing.managers'
# SyncManager.__bases__[0].__name__ == 'BaseManager'
# SyncManager.__mro__.__len__() == 3
# ---------------------------------------------------------------------------

table multiprocessing_extra95.syncmanager_identity:
  description: "multiprocessing.managers.SyncManager class identity checks in mpmanager95 namespace — wave 254 theme: multiprocessing SyncManager class identity; SyncManager is the concrete manager class returned by multiprocessing.Manager(); it registers many synchronization primitives (Lock, Event, Condition, Queue, dict, list, etc.) for inter-process sharing; SyncManager.__name__.__eq__('SyncManager')==True; SyncManager.__module__.__eq__('multiprocessing.managers')==True; SyncManager.__bases__[0].__name__.__eq__('BaseManager')==True (direct subclass of BaseManager, not object); SyncManager.__mro__.__len__()==3 (MRO is [SyncManager, BaseManager, object], one level deeper than BaseManager); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmanager95a

  columns: [id, function, args, expected, description]
  rows:
    - [sm_name,    "SyncManager.__name__.__eq__",              ["SyncManager"],               true, "SyncManager.__name__ == 'SyncManager'; verified with Python 3.14.3"]
    - [sm_module,  "SyncManager.__module__.__eq__",            ["multiprocessing.managers"],  true, "SyncManager.__module__ == 'multiprocessing.managers'; verified with Python 3.14.3"]
    - [sm_base0,   "SyncManager.__bases__[0].__name__.__eq__", ["BaseManager"],               true, "SyncManager.__bases__[0].__name__ == 'BaseManager' — direct subclass of BaseManager; verified with Python 3.14.3"]
    - [sm_mro_len, "SyncManager.__mro__.__len__",              [],                            3,    "SyncManager.__mro__.__len__() == 3 — MRO is [SyncManager, BaseManager, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Manager __class__.__name__ and __qualname__ — extra95
#
# multiprocessing.Manager.__class__.__name__ == 'method'
# multiprocessing.Manager.__qualname__ == 'BaseContext.Manager'
# multiprocessing.Manager.__qualname__.__len__() == 19
# multiprocessing.Manager.__module__ == 'multiprocessing.context'
# ---------------------------------------------------------------------------

table multiprocessing_extra95.mp_manager_accessor_identity:
  description: "multiprocessing.Manager accessor identity checks in mpmanager95 namespace — wave 254 theme: multiprocessing.Manager is a bound method (not a class); multiprocessing.Manager is the public API for creating a SyncManager; it is a bound method of the process context object (BaseContext), not a standalone class or function; multiprocessing.Manager.__class__.__name__.__eq__('method')==True; multiprocessing.Manager.__qualname__.__eq__('BaseContext.Manager')==True; multiprocessing.Manager.__qualname__.__len__()==19; multiprocessing.Manager.__module__.__eq__('multiprocessing.context')==True; contrast with multiprocessing.active_children which is a plain function (class='function'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmanager95b

  columns: [id, function, args, expected, description]
  rows:
    - [mgr_class_nm,   "multiprocessing.Manager.__class__.__name__.__eq__", ["method"],                    true, "multiprocessing.Manager.__class__.__name__ == 'method' — it is a bound method of the process context; verified with Python 3.14.3"]
    - [mgr_qualname,   "multiprocessing.Manager.__qualname__.__eq__",       ["BaseContext.Manager"],       true, "multiprocessing.Manager.__qualname__ == 'BaseContext.Manager'; verified with Python 3.14.3"]
    - [mgr_qlen,       "multiprocessing.Manager.__qualname__.__len__",      [],                            19,   "multiprocessing.Manager.__qualname__.__len__() == 19 ('BaseContext.Manager'); verified with Python 3.14.3"]
    - [mgr_module,     "multiprocessing.Manager.__module__.__eq__",         ["multiprocessing.context"],   true, "multiprocessing.Manager.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing utility function identity — extra95
#
# cpu_count.__class__.__name__ == 'method' (bound method of context)
# cpu_count.__qualname__ == 'BaseContext.cpu_count' (len=21)
# active_children.__class__.__name__ == 'function'
# active_children.__qualname__ == 'active_children' (len=15)
# current_process.__qualname__ == 'current_process' (len=15)
# freeze_support.__qualname__ == 'BaseContext.freeze_support' (len=26)
# ---------------------------------------------------------------------------

table multiprocessing_extra95.mp_utility_function_identity:
  description: "multiprocessing utility function identity checks in mpmanager95 namespace — wave 254 theme: multiprocessing utility function class names; multiprocessing exposes some callables as bound context methods and others as plain module-level functions; cpu_count.__class__.__name__.__eq__('method')==True (bound to process context, like Manager); cpu_count.__qualname__.__eq__('BaseContext.cpu_count')==True (len=21); active_children.__class__.__name__.__eq__('function')==True (plain module-level function, not a bound method); active_children.__qualname__.__eq__('active_children')==True (len=15, same as current_process.__qualname__ len=15); freeze_support.__qualname__.__eq__('BaseContext.freeze_support')==True (len=26, bound method); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmanager95c

  columns: [id, function, args, expected, description]
  rows:
    - [cpu_class_nm,      "multiprocessing.cpu_count.__class__.__name__.__eq__",     ["method"],                      true, "multiprocessing.cpu_count.__class__.__name__ == 'method' — bound context method like Manager; verified with Python 3.14.3"]
    - [cpu_qualname,      "multiprocessing.cpu_count.__qualname__.__eq__",           ["BaseContext.cpu_count"],        true, "multiprocessing.cpu_count.__qualname__ == 'BaseContext.cpu_count' (len=21); verified with Python 3.14.3"]
    - [active_class_nm,   "multiprocessing.active_children.__class__.__name__.__eq__", ["function"],                  true, "multiprocessing.active_children.__class__.__name__ == 'function' — plain module-level function; verified with Python 3.14.3"]
    - [active_qualname,   "multiprocessing.active_children.__qualname__.__eq__",     ["active_children"],             true, "multiprocessing.active_children.__qualname__ == 'active_children' (len=15); verified with Python 3.14.3"]
    - [freeze_qualname,   "multiprocessing.freeze_support.__qualname__.__eq__",      ["BaseContext.freeze_support"],  true, "multiprocessing.freeze_support.__qualname__ == 'BaseContext.freeze_support' (len=26); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra95
# ---------------------------------------------------------------------------

invariant multiprocessing_extra95.BaseManager_name_eq:
  description: "multiprocessing.managers.BaseManager.__name__.__eq__('BaseManager') returns True — BaseManager is the foundational class in multiprocessing.managers from which all manager types inherit; it provides the start(), connect(), shutdown(), register() and other methods for managing shared-state server processes; BaseManager.__name__ is 'BaseManager' (len=11); BaseManager.__bases__[0].__name__ is 'object' so its MRO length is 2; NEW in extra95: first standalone BaseManager.__name__.__eq__ invariant in mpmanager95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "BaseManager.__name__.__eq__"
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra95.SyncManager_base_is_BaseManager:
  description: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__('BaseManager') returns True — SyncManager inherits directly from BaseManager and not from object; this creates a 3-element MRO ([SyncManager, BaseManager, object]) vs BaseManager's 2-element MRO ([BaseManager, object]); SyncManager registers all the standard synchronization primitives (Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Barrier, Queue, JoinableQueue, SimpleQueue, Array, Value, Namespace, dict, list) for inter-process use; NEW in extra95: first standalone SyncManager base class invariant in mpmanager95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "SyncManager.__bases__[0].__name__.__eq__"
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra95.Manager_is_method_not_class:
  description: "multiprocessing.Manager.__class__.__name__.__eq__('method') returns True — multiprocessing.Manager is a bound method of the process context object, not a standalone class or factory function; calling multiprocessing.Manager() invokes BaseContext.Manager which creates and starts a SyncManager instance; this is why Manager.__class__.__name__ is 'method' rather than 'type' or 'function'; it contrasts with multiprocessing.active_children which has class 'function'; NEW in extra95: first standalone Manager class name invariant in mpmanager95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.Manager.__class__.__name__.__eq__"
  args: ["method"]
  expected: true

invariant multiprocessing_extra95.Manager_qualname_eq:
  description: "multiprocessing.Manager.__qualname__.__eq__('BaseContext.Manager') returns True — multiprocessing.Manager.__qualname__ is 'BaseContext.Manager' (len=19) reflecting that the underlying method is defined in BaseContext in Lib/multiprocessing/context.py; the 'BaseContext.' prefix (12 chars) plus 'Manager' (7 chars) = 19 chars total; this qualname pattern is shared by cpu_count ('BaseContext.cpu_count') and freeze_support ('BaseContext.freeze_support'), all of which are context-bound methods; NEW in extra95: first standalone Manager qualname invariant in mpmanager95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.Manager.__qualname__.__eq__"
  args: ["BaseContext.Manager"]
  expected: true

invariant multiprocessing_extra95.active_children_is_function:
  description: "multiprocessing.active_children.__class__.__name__.__eq__('function') returns True — active_children is a plain module-level Python function (not a bound context method like Manager or cpu_count); its __qualname__ is 'active_children' (len=15) without a 'BaseContext.' prefix, confirming it is not wrapped in the context mechanism; active_children returns a list of all currently alive child processes; current_process also has class 'function' and qualname 'current_process' (len=15), identical length to active_children; NEW in extra95: first standalone active_children class name invariant in mpmanager95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.active_children.__class__.__name__.__eq__"
  args: ["function"]
  expected: true
