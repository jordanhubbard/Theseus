  id_prefix: as1981

  columns: [id, function, args, expected]
  rows:
    - ["as1981019", "asyncio.Task.__dict__.__contains__",      ["__ceil__"], false]
    - ["as1981020", "asyncio.Future.__dict__.__contains__",    ["__ceil__"], false]
    - ["as1981021", "asyncio.Event.__dict__.__contains__",     ["__ceil__"], false]
    - ["as1981022", "asyncio.Lock.__dict__.__contains__",      ["__ceil__"], false]
    - ["as1981023", "asyncio.Queue.__dict__.__contains__",     ["__ceil__"], false]
    - ["as1981024", "asyncio.Semaphore.__dict__.__contains__", ["__ceil__"], false]

# ---------------------------------------------------------------------------
# Table 5: __trunc__ dict-presence checks
#
# math.trunc() dispatches to __trunc__ on the argument type when defined in
