spec: asyncio_extra1981
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 579 (_extra1981): __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence checks."
    - "asyncio.Task is a C extension type (subclass of asyncio.Future); it does NOT define __sizeof__ in its own __dict__ -> False."
    - "asyncio.Future is a C extension type (_asyncio.Future); it does NOT define __sizeof__ in its own __dict__ -> False."
    - "asyncio.Event, asyncio.Lock, asyncio.Queue, asyncio.Semaphore are pure Python classes; none define __sizeof__ -> False."
    - "__length_hint__ is an iterator protocol method; none of the asyncio synchronisation/task types implement iterators -> False for all."
    - "__floor__, __ceil__, __trunc__ are math rounding protocol methods (math.floor/ceil/trunc dispatch); asyncio types are not numeric -> False for all."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __sizeof__ dict-presence checks
#
# Wave 579 theme: asyncio classes are either C extension types (Task, Future)
# or pure Python synchronisation primitives. None define __sizeof__ in their
# own __dict__; the slot is inherited from object (C types) or from the pure-
# Python base chain without override.
# ---------------------------------------------------------------------------

table asyncio_extra1981.sizeof_protocol:
  description: "asyncio types __sizeof__ dict-presence checks — none define __sizeof__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1981

  columns: [id, function, args, expected]
  rows:
    - ["as1981001", "asyncio.Task.__dict__.__contains__",      ["__sizeof__"], false]
    - ["as1981002", "asyncio.Future.__dict__.__contains__",    ["__sizeof__"], false]
    - ["as1981003", "asyncio.Event.__dict__.__contains__",     ["__sizeof__"], false]
    - ["as1981004", "asyncio.Lock.__dict__.__contains__",      ["__sizeof__"], false]
    - ["as1981005", "asyncio.Queue.__dict__.__contains__",     ["__sizeof__"], false]
    - ["as1981006", "asyncio.Semaphore.__dict__.__contains__", ["__sizeof__"], false]

# ---------------------------------------------------------------------------
# Table 2: __length_hint__ dict-presence checks
#
# __length_hint__ is part of the iterator length-estimation protocol
# (PEP 424 / operator.length_hint). asyncio synchronisation primitives and
# task types are not sequences or iterators and do not implement this protocol.
# ---------------------------------------------------------------------------

table asyncio_extra1981.length_hint_protocol:
  description: "asyncio types __length_hint__ dict-presence checks — none define __length_hint__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1981

  columns: [id, function, args, expected]
  rows:
    - ["as1981007", "asyncio.Task.__dict__.__contains__",      ["__length_hint__"], false]
    - ["as1981008", "asyncio.Future.__dict__.__contains__",    ["__length_hint__"], false]
    - ["as1981009", "asyncio.Event.__dict__.__contains__",     ["__length_hint__"], false]
    - ["as1981010", "asyncio.Lock.__dict__.__contains__",      ["__length_hint__"], false]
    - ["as1981011", "asyncio.Queue.__dict__.__contains__",     ["__length_hint__"], false]
    - ["as1981012", "asyncio.Semaphore.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Table 3: __floor__ dict-presence checks
#
# math.floor() dispatches to __floor__ on the argument type when defined in
# its __dict__. asyncio types are not numeric and do not implement the math
# rounding protocol; none define __floor__ in their own __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra1981.floor_protocol:
  description: "asyncio types __floor__ dict-presence checks — none define __floor__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1981

  columns: [id, function, args, expected]
  rows:
    - ["as1981013", "asyncio.Task.__dict__.__contains__",      ["__floor__"], false]
    - ["as1981014", "asyncio.Future.__dict__.__contains__",    ["__floor__"], false]
    - ["as1981015", "asyncio.Event.__dict__.__contains__",     ["__floor__"], false]
    - ["as1981016", "asyncio.Lock.__dict__.__contains__",      ["__floor__"], false]
    - ["as1981017", "asyncio.Queue.__dict__.__contains__",     ["__floor__"], false]
    - ["as1981018", "asyncio.Semaphore.__dict__.__contains__", ["__floor__"], false]

# ---------------------------------------------------------------------------
# Table 4: __ceil__ dict-presence checks
#
# math.ceil() dispatches to __ceil__ on the argument type when defined in
# its __dict__. asyncio types are not numeric; none define __ceil__.
# ---------------------------------------------------------------------------

table asyncio_extra1981.ceil_protocol:
  description: "asyncio types __ceil__ dict-presence checks — none define __ceil__ in own __dict__"
  kind: python_call_eq
