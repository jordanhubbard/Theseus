spec: zoneinfo_extra9
version: ">=3.9"
backend: python_module(zoneinfo)

docs: https://docs.python.org/3/library/zoneinfo.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zoneinfo.html — Python zoneinfo module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zoneinfo/_common.py, Lib/zoneinfo/_tzpath.py"
    - "tzdata package — https://pypi.org/project/tzdata/"
    - "zoneinfo_extra2.zspec.zsdl — covers __qualname__ for ZoneInfo/ZoneInfoNotFoundError/available_timezones; ZoneInfo.__bases__[0].__name__=='tzinfo'; ZoneInfoNotFoundError/__module__; available_timezones/__module__"
    - "zoneinfo_extra4.zspec.zsdl — covers __qualname__ for ZoneInfo.no_cache/clear_cache/from_file; ZoneInfoNotFoundError MRO length; method __module__ for no_cache/clear_cache"
    - "zoneinfo_extra5.zspec.zsdl — covers ZoneInfo/__qualname__/__module__; ZoneInfoNotFoundError/__qualname__/base KeyError; available_timezones __name__/returns_set/min_count"
    - "zoneinfo_extra7.zspec.zsdl — covers __name__ table for ZoneInfo/ZoneInfoNotFoundError/available_timezones; ZoneInfo/ZoneInfoNotFoundError base class standalone invariants; ZoneInfo/__qualname__ and ZoneInfoNotFoundError/__qualname__ standalone"
    - "zoneinfo_extra8.zspec.zsdl — covers available_timezones/__qualname__; ZoneInfo/__module__; ZoneInfoNotFoundError/__module__; UTC/America/New_York/Europe/London containment"
  notes:
    - "This spec extends zoneinfo.zspec.zsdl and prior extras through zoneinfo_extra8.zspec.zsdl."
    - "NEW in extra9 — Axis 1: __qualname__ for ZoneInfo.utcoffset, ZoneInfo.tzname, ZoneInfo.dst, ZoneInfo.fromutc — the tzinfo protocol methods. No prior spec checks these."
    - "NEW in extra9 — Axis 2: ZoneInfo.__qualname__ == 'ZoneInfo' and ZoneInfo.__module__ == 'zoneinfo' as standalone extra9-namespace invariants for systematic chain continuity."
    - "NEW in extra9 — Axis 3: available_timezones.__qualname__ == 'available_timezones' as standalone extra9-namespace invariant."
    - "NEW in extra9 — Axis 4: type(ZoneInfo.key).__name__ == 'member_descriptor' — the key attribute is a C-level member descriptor, not a Python property."
    - "zoneinfo.ZoneInfo.utcoffset.__qualname__ == 'ZoneInfo.utcoffset' — verified Python 3.12."
    - "zoneinfo.ZoneInfo.tzname.__qualname__ == 'ZoneInfo.tzname' — verified Python 3.12."
    - "zoneinfo.ZoneInfo.dst.__qualname__ == 'ZoneInfo.dst' — verified Python 3.12."
    - "zoneinfo.ZoneInfo.fromutc.__qualname__ == 'ZoneInfo.fromutc' — verified Python 3.12."
    - "zoneinfo.ZoneInfo.__qualname__ == 'ZoneInfo' — verified Python 3.12."
    - "zoneinfo.ZoneInfo.__module__ == 'zoneinfo' — verified Python 3.12."
    - "zoneinfo.available_timezones.__qualname__ == 'available_timezones' — verified Python 3.12."
    - "type(zoneinfo.ZoneInfo.key).__name__ == 'member_descriptor' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ZoneInfo tzinfo protocol method __qualname__ values
#
# ZoneInfo implements the tzinfo protocol by providing utcoffset(), tzname(),
# dst(), and fromutc(). Prior specs check __name__ for class-level methods
# (no_cache, clear_cache, from_file) but no prior spec checks the __qualname__
# of the tzinfo protocol methods. All four have dotted qualnames.
# ---------------------------------------------------------------------------

table zoneinfo_extra9.ZoneInfo_protocol_method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qn

  columns: [id, function, args, expected]
  rows:
    - [utcoffset, "ZoneInfo.utcoffset.__qualname__.__eq__", ["ZoneInfo.utcoffset"], true]
    - [tzname,    "ZoneInfo.tzname.__qualname__.__eq__",    ["ZoneInfo.tzname"],    true]
    - [dst,       "ZoneInfo.dst.__qualname__.__eq__",       ["ZoneInfo.dst"],       true]
    - [fromutc,   "ZoneInfo.fromutc.__qualname__.__eq__",   ["ZoneInfo.fromutc"],   true]

# ---------------------------------------------------------------------------
# ZoneInfo.__qualname__ and ZoneInfo.__module__ — standalone extra9-namespace
#
# zoneinfo_extra2, extra5, extra7, and extra8 cover these in various contexts.
# This spec re-anchors them as standalone invariants in the extra9 namespace
# for systematic chain continuity alongside the novel protocol-method axes.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra9.ZoneInfo.qualname:
  description: "zoneinfo.ZoneInfo.__qualname__ == 'ZoneInfo' — flat class qualname"
  category: class_qualnames
  kind: python_call_eq
  function: ZoneInfo.__qualname__.__eq__
  args: ["ZoneInfo"]
  expected: true

invariant zoneinfo_extra9.ZoneInfo.module:
  description: "zoneinfo.ZoneInfo.__module__ == 'zoneinfo'"
  category: class_modules
  kind: python_call_eq
  function: ZoneInfo.__module__.__eq__
  args: ["zoneinfo"]
  expected: true

# ---------------------------------------------------------------------------
# available_timezones.__qualname__ — standalone extra9-namespace invariant
#
# zoneinfo_extra2, extra5, extra7, and extra8 cover this. Re-anchored in the
# extra9 namespace for continuity alongside the novel axes in this spec.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra9.available_timezones.qualname:
  description: "zoneinfo.available_timezones.__qualname__ == 'available_timezones'"
  category: function_qualnames
  kind: python_call_eq
  function: available_timezones.__qualname__.__eq__
  args: ["available_timezones"]
  expected: true

# ---------------------------------------------------------------------------
# type(ZoneInfo.key).__name__ == 'member_descriptor'
#
# The ZoneInfo.key attribute is a C-level member descriptor (not a Python
# property), which stores the IANA timezone key string on each instance.
# No prior spec checks the type name of this descriptor itself.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra9.ZoneInfo.key_descriptor_type:
  description: "type(zoneinfo.ZoneInfo.key).__name__ == 'member_descriptor' — key is a C member descriptor"
  category: descriptor_types
  kind: python_call_eq
  function: ZoneInfo.key.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true
