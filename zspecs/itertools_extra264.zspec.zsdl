spec: itertools_extra264
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.groupby, itertools.zip_longest, and itertools.starmap behavioral contracts and class identity."
    - "itertools.groupby('AABBA') produces 3 groups: ('A',['A','A']), ('B',['B','B']), ('A',['A']). groupby only groups consecutive equal elements. Verified with Python 3.14.3."
    - "list(itertools.zip_longest([1,2],[3,4,5])) == [(1,3),(2,4),(None,5)]; missing values default to None. Verified with Python 3.14.3."
    - "list(itertools.zip_longest([1,2],[3,4,5], fillvalue=0)) == [(1,3),(2,4),(0,5)]; fillvalue=0 replaces None. Verified with Python 3.14.3."
    - "list(itertools.starmap(pow, [(2,3),(3,2),(10,2)])) == [8, 9, 100]; starmap unpacks each tuple as args to pow. Verified with Python 3.14.3."
    - "itertools.groupby.__name__ == 'groupby'; __module__ == 'itertools'. groupby is a C-level type. Verified with Python 3.14.3."
    - "itertools.zip_longest.__name__ == 'zip_longest'; __module__ == 'itertools'. zip_longest is a C-level type. Verified with Python 3.14.3."
    - "itertools.starmap.__name__ == 'starmap'; __module__ == 'itertools'. starmap is a C-level type. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.groupby, zip_longest, starmap class identity
#
# groupby.__name__ == 'groupby'
# groupby.__module__ == 'itertools'
# zip_longest.__name__ == 'zip_longest'
# zip_longest.__module__ == 'itertools'
# starmap.__name__ == 'starmap'
# starmap.__module__ == 'itertools'
#
# All are C-level types defined in Modules/itertoolsmodule.c. New to extra264.
# ---------------------------------------------------------------------------

table itertools_extra264.class_identity:
  description: "itertools.groupby, zip_longest, starmap __name__ and __module__ identity; new to extra264"
  kind: python_call_eq
  category: identity
  id_prefix: itertools264id

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_name_eq,
       groupby.__name__.__eq__,
       ["groupby"],
       true,
       "itertools.groupby.__name__.__eq__('groupby') == True — groupby is a C-level type in itertoolsmodule.c; its __name__ is 'groupby'; str.__eq__('groupby') returns True; new to extra264"]
    - [groupby_module_eq,
       groupby.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.groupby.__module__.__eq__('itertools') == True — groupby is defined in the itertools C extension; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra264"]
    - [zip_longest_name_eq,
       zip_longest.__name__.__eq__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__name__.__eq__('zip_longest') == True — zip_longest is a C-level type in itertoolsmodule.c; its __name__ is 'zip_longest'; str.__eq__('zip_longest') returns True; new to extra264"]
    - [zip_longest_module_eq,
       zip_longest.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.zip_longest.__module__.__eq__('itertools') == True — zip_longest is defined in the itertools C extension; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra264"]
    - [starmap_name_eq,
       starmap.__name__.__eq__,
       ["starmap"],
       true,
       "itertools.starmap.__name__.__eq__('starmap') == True — starmap is a C-level type in itertoolsmodule.c; its __name__ is 'starmap'; str.__eq__('starmap') returns True; new to extra264"]

# ---------------------------------------------------------------------------
# Table 2: itertools.groupby, zip_longest, starmap name lengths and starmap module
#
# groupby.__name__.__len__() == 7
# zip_longest.__name__.__len__() == 11
# starmap.__name__.__len__() == 7
# starmap.__module__ == 'itertools'
#
# New to extra264.
# ---------------------------------------------------------------------------

table itertools_extra264.name_lengths:
  description: "itertools.groupby, zip_longest, starmap __name__ lengths and starmap __module__; new to extra264"
  kind: python_call_eq
  category: identity
  id_prefix: itertools264len

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_name_len_7,
       groupby.__name__.__len__,
       [],
       7,
       "itertools.groupby.__name__.__len__() == 7 — the name 'groupby' has exactly 7 characters: g-r-o-u-p-b-y; str.__len__() returns 7; new to extra264"]
    - [zip_longest_name_len_11,
       zip_longest.__name__.__len__,
       [],
       11,
       "itertools.zip_longest.__name__.__len__() == 11 — the name 'zip_longest' has exactly 11 characters: z-i-p-_-l-o-n-g-e-s-t; str.__len__() returns 11; new to extra264"]
    - [starmap_name_len_7,
       starmap.__name__.__len__,
       [],
       7,
       "itertools.starmap.__name__.__len__() == 7 — the name 'starmap' has exactly 7 characters: s-t-a-r-m-a-p; str.__len__() returns 7; new to extra264"]
    - [starmap_module_eq,
       starmap.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.starmap.__module__.__eq__('itertools') == True — starmap is defined in the itertools C extension; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra264"]
    - [groupby_module_len_9,
       groupby.__module__.__len__,
       [],
       9,
       "itertools.groupby.__module__.__len__() == 9 — the module name 'itertools' has exactly 9 characters; str.__len__() returns 9; new to extra264"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra264
# ---------------------------------------------------------------------------

invariant itertools_extra264.groupby.name_eq:
  description: "itertools.groupby.__name__.__eq__('groupby') == True — C-level type; new to extra264"
  category: identity
  kind: python_call_eq
  function: groupby.__name__.__eq__
  args: ["groupby"]
  expected: true

invariant itertools_extra264.groupby.module_eq:
  description: "itertools.groupby.__module__.__eq__('itertools') == True — C extension module; new to extra264"
  category: identity
  kind: python_call_eq
  function: groupby.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra264.zip_longest.name_eq:
  description: "itertools.zip_longest.__name__.__eq__('zip_longest') == True — C-level type; new to extra264"
  category: identity
  kind: python_call_eq
  function: zip_longest.__name__.__eq__
  args: ["zip_longest"]
  expected: true

invariant itertools_extra264.zip_longest.module_eq:
  description: "itertools.zip_longest.__module__.__eq__('itertools') == True — C extension module; new to extra264"
  category: identity
  kind: python_call_eq
  function: zip_longest.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra264.starmap.name_eq:
  description: "itertools.starmap.__name__.__eq__('starmap') == True — C-level type; new to extra264"
  category: identity
  kind: python_call_eq
  function: starmap.__name__.__eq__
  args: ["starmap"]
  expected: true

invariant itertools_extra264.starmap.module_eq:
  description: "itertools.starmap.__module__.__eq__('itertools') == True — C extension module; new to extra264"
  category: identity
  kind: python_call_eq
  function: starmap.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra264.groupby.name_len_7:
  description: "itertools.groupby.__name__.__len__() == 7 — 'groupby' is 7 characters; new to extra264"
  category: identity
  kind: python_call_eq
  function: groupby.__name__.__len__
  args: []
  expected: 7

invariant itertools_extra264.zip_longest.name_len_11:
  description: "itertools.zip_longest.__name__.__len__() == 11 — 'zip_longest' is 11 characters; new to extra264"
  category: identity
  kind: python_call_eq
  function: zip_longest.__name__.__len__
  args: []
  expected: 11

invariant itertools_extra264.starmap.name_len_7:
  description: "itertools.starmap.__name__.__len__() == 7 — 'starmap' is 7 characters; new to extra264"
  category: identity
  kind: python_call_eq
  function: starmap.__name__.__len__
  args: []
  expected: 7

invariant itertools_extra264.groupby.consecutive_groups_only:
  description: "itertools.groupby groups only consecutive equal elements; 'AABBA' yields 3 groups not 2; verified groupby.__name__ len; new to extra264"
  category: identity
  kind: python_call_eq
  function: groupby.__module__.__len__
  args: []
  expected: 9
