spec: threading_extra486
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading.Thread method and property identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.Thread is a pure-Python class; methods are functions and properties are property descriptors"
    - "getName/setName/isDaemon/setDaemon are deprecated but still present in Python 3.9+"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra486.method_names:
  description: "threading.Thread method __name__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [mname001, threading.Thread.start.__name__.__eq__, ["start"], true]
    - [mname002, threading.Thread.run.__name__.__eq__, ["run"], true]
    - [mname003, threading.Thread.join.__name__.__eq__, ["join"], true]
    - [mname004, threading.Thread.is_alive.__name__.__eq__, ["is_alive"], true]
    - [mname005, threading.Thread.getName.__name__.__eq__, ["getName"], true]
    - [mname006, threading.Thread.setName.__name__.__eq__, ["setName"], true]
    - [mname007, threading.Thread.isDaemon.__name__.__eq__, ["isDaemon"], true]
    - [mname008, threading.Thread.setDaemon.__name__.__eq__, ["setDaemon"], true]

table threading_extra486.property_types:
  description: "threading.Thread property descriptor __class__.__name__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: prop

  columns: [id, function, args, expected]
  rows:
    - [prop001, threading.Thread.name.__class__.__name__.__eq__, ["property"], true]
    - [prop002, threading.Thread.daemon.__class__.__name__.__eq__, ["property"], true]
    - [prop003, threading.Thread.ident.__class__.__name__.__eq__, ["property"], true]
    - [prop004, threading.Thread.native_id.__class__.__name__.__eq__, ["property"], true]
