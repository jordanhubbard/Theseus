spec: pytz_extra_rust
version: ">=3.9"
backend: rust_module(pytz_extra_rust)

docs: https://pythonhosted.org/pytz/

provenance:
  derived_from:
    - "https://pythonhosted.org/pytz/ — pytz timezone library"
  notes:
    - "pytz provides timezone support for Python."
    - "pytz.timezone('US/Eastern') returns a timezone object."
    - "pytz.utc is the UTC timezone."
    - "pytz.VERSION is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pytz_extra_rust.timezone_name:
  description: "pytz.timezone('UTC').zone == 'UTC'"
  category: timezone
  kind: python_call_eq
  function: pytz_utc_zone
  args: []
  expected: "UTC"

invariant pytz_extra_rust.has_utc:
  description: "pytz.utc is not None"
  category: presence
  kind: python_call_eq
  function: pytz_has_utc
  args: []
  expected: true

invariant pytz_extra_rust.version_nonempty:
  description: "pytz.VERSION is non-empty"
  category: version
  kind: python_call_eq
  function: pytz_version_nonempty
  args: []
  expected: true

