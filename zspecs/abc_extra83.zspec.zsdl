    - [co_filename_cls_cross,   "abstractmethod.__code__.co_filename.__class__.__name__.__eq__",   ["str"],            true, "abstractmethod.__code__.co_filename.__class__.__name__ == 'str' — cross-check; verified with Python 3.14.3"]
