# Wave 248 theme: abc.abstractmethod code object attribute class names.
#
# abstractmethod.__code__.co_filename.__class__.__name__ == 'str'
# abstractmethod.__code__.co_firstlineno.__class__.__name__ == 'int'
# abstractmethod.__code__.co_flags.__class__.__name__ == 'int'
# abstractmethod.__code__.co_name.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table abc_extra83.abstractmethod_code_attr_class_names:
  description: "abc abstractmethod code object attribute class names in abccodeattrname83 namespace — wave 248 theme: abc.abstractmethod code object attribute class names; abstractmethod.__code__.co_filename.__class__.__name__=='str' (source file path is a string); abstractmethod.__code__.co_firstlineno.__class__.__name__=='int' (first line number is an int); abstractmethod.__code__.co_flags.__class__.__name__=='int' (flags bitmask is an int); abstractmethod.__code__.co_name.__class__.__name__=='str' (function name is a str); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abccodeattrname83

  columns: [id, function, args, expected, description]
  rows:
    - [co_filename_class,    "abstractmethod.__code__.co_filename.__class__.__name__.__eq__",    ["str"], true, "abstractmethod.__code__.co_filename.__class__.__name__ == 'str' — source file path is a string; verified with Python 3.14.3"]
    - [co_firstlineno_class, "abstractmethod.__code__.co_firstlineno.__class__.__name__.__eq__", ["int"], true, "abstractmethod.__code__.co_firstlineno.__class__.__name__ == 'int' — first line number is an int; verified with Python 3.14.3"]
    - [co_flags_class,       "abstractmethod.__code__.co_flags.__class__.__name__.__eq__",       ["int"], true, "abstractmethod.__code__.co_flags.__class__.__name__ == 'int' — flags bitmask is an int; verified with Python 3.14.3"]
    - [co_name_class,        "abstractmethod.__code__.co_name.__class__.__name__.__eq__",        ["str"], true, "abstractmethod.__code__.co_name.__class__.__name__ == 'str' — function name in code object is a str; verified with Python 3.14.3"]

