    - [abcmeta_doc_cls,        "ABCMeta.__doc__.__class__.__name__.__eq__",         ["str"], true, "ABCMeta.__doc__.__class__.__name__ == 'str' — ABCMeta has a docstring; verified with Python 3.14.3"]
    - [abc_doc_cls,            "ABC.__doc__.__class__.__name__.__eq__",             ["str"], true, "ABC.__doc__.__class__.__name__ == 'str' — ABC has a docstring; verified with Python 3.14.3"]
