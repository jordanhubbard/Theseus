spec: abc_extra83
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra82

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra82.zspec.zsdl."
    - "This spec covers: wave 248 theme — abc.abstractmethod code object attribute class names and doc string class names. NEW in extra83: abstractmethod.__code__.co_filename.__class__.__name__=='str'; abstractmethod.__code__.co_firstlineno.__class__.__name__=='int'; abstractmethod.__code__.co_flags.__class__.__name__=='int'; abstractmethod.__code__.co_name.__eq__('abstractmethod')==True; ABCMeta.register.__module__.__eq__('abc')==True; update_abstractmethods.__module__.__eq__('abc')==True; abstractmethod.__doc__.__class__.__name__=='str'; ABCMeta.__doc__.__class__.__name__=='str'; ABC.__doc__.__class__.__name__=='str'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_filename.__class__.__name__ == 'str'. The source file path stored in the code object is a str. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_firstlineno.__class__.__name__ == 'int'. The first line number in the code object is an int. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_flags.__class__.__name__ == 'int'. The flags bitmask in the code object is an int. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.co_name.__eq__('abstractmethod') == True. The function name stored in the code object equals 'abstractmethod'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__module__.__eq__('abc') == True. ABCMeta.register is defined in abc.py; its __module__ is 'abc'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__module__.__eq__('abc') == True. update_abstractmethods is a module-level function in abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__doc__.__class__.__name__ == 'str'. abstractmethod has a docstring; the docstring is a str. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__doc__.__class__.__name__ == 'str'. ABCMeta has a docstring; the docstring is a str. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__doc__.__class__.__name__ == 'str'. ABC has a docstring ('Helper class that provides a standard way to create an ABC using inheritance.'); the docstring is a str. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc abstractmethod code attr class names — extra83
