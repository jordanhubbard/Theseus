    - [uam_module_cross,       update_abstractmethods.__module__.__eq__,            ["abc"], true, "update_abstractmethods.__module__ == 'abc' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra83
# ---------------------------------------------------------------------------

invariant abc_extra83.abstractmethod_co_name_eq:
  description: "abc.abstractmethod.__code__.co_name.__eq__('abstractmethod') returns True — the function name stored in the code object equals 'abstractmethod', confirming the code object belongs to the abstractmethod decorator function; NEW in extra83: first standalone code object co_name equality invariant for abstractmethod in abccodeattrname83 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__code__.co_name.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra83.abstractmethod_co_filename_class:
  description: "abc.abstractmethod.__code__.co_filename.__class__.__name__.__eq__('str') returns True — the source file path stored in the code object is a str, confirming co_filename holds a filesystem path string; NEW in extra83: first standalone code object co_filename class name invariant for abstractmethod in abccodeattrname83 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__code__.co_filename.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra83.abstractmethod_co_firstlineno_class:
  description: "abc.abstractmethod.__code__.co_firstlineno.__class__.__name__.__eq__('int') returns True — the first line number in the code object is an int; NEW in extra83: first standalone code object co_firstlineno class name invariant for abstractmethod in abccodeattrname83 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__code__.co_firstlineno.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant abc_extra83.ABCMeta_register_module:
  description: "abc.ABCMeta.register.__module__.__eq__('abc') returns True — ABCMeta.register is defined in abc.py; its __module__ attribute confirms its origin as the abc module; NEW in extra83: first standalone __module__ equality invariant for ABCMeta.register in abccodeattrname83 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.register.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra83.abstractmethod_doc_is_str:
  description: "abc.abstractmethod.__doc__.__class__.__name__.__eq__('str') returns True — abstractmethod has a docstring, and that docstring is a str instance; this confirms abstractmethod is documented; NEW in extra83: first standalone doc class name invariant for abstractmethod in abccodeattrname83 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
