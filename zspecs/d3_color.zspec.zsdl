spec: d3_color
version: ">=3.0.0"
backend: node(d3-color)

docs: https://d3js.org/d3-color/

provenance:
  derived_from:
    - "d3-color documentation — https://d3js.org/d3-color/"
    - "CSS Color Module Level 4 — https://www.w3.org/TR/css-color-4/"
    - "Test vectors verified with d3-color via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "d3-color source"
  notes:
    - "d3-color is the standalone color module from D3.js (Mike Bostock)."
    - "Install: npm install d3-color"
    - "Exports color factories: color() (general), rgb(), hsl(), lab(), lch(), hcl(), cubehelix(), gray()."
    - "color(input).formatHex() returns lowercase 6-char hex."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; color() returns null on un-parseable input (no throw)."
  stderr: "null"
  stickiness: "N/A — color instances are values."
  codes: {}

# color(input).formatHex() — primary entry
table d3_color.formatHex:
  kind: node_chain_eq
  category: formatHex
  entry: named
  function: color
  id_prefix: hex

  columns: [id, entry_args, chain, expected]
  rows:
    - [named_red,    ["red"],     [{method: formatHex, args: []}], "#ff0000"]
    - [named_blue,   ["blue"],    [{method: formatHex, args: []}], "#0000ff"]
    - [shorthand_hex, ["#f00"],   [{method: formatHex, args: []}], "#ff0000"]

# rgb('red').r — channel access
table d3_color.rgb_channels:
  kind: node_chain_eq
  category: rgb_channels
  entry: named
  function: rgb
  id_prefix: rgb

  columns: [id, entry_args, chain, expected]
  rows:
    - [red_r,    ["red"],   [{get: r}], 255]
    - [red_g,    ["red"],   [{get: g}], 0]
    - [red_b,    ["red"],   [{get: b}], 0]
    - [green_r,  ["green"], [{get: r}], 0]
    - [blue_b,   ["blue"],  [{get: b}], 255]
    - [white_all,["white"], [{get: r}], 255]

# hsl('red').h — hue channel
invariant d3_color.hsl_hue_red:
  description: "hsl('red').h == 0 (red is at 0° on the HSL color wheel)"
  category: hsl
  kind: node_chain_eq
  entry: named
  function: hsl
  entry_args: ["red"]
  chain:
    - {get: h}
  expected: 0

invariant d3_color.hsl_hue_green:
  description: "hsl('green').h == 120 (green at 120°)"
  category: hsl
  kind: node_chain_eq
  entry: named
  function: hsl
  entry_args: ["green"]
  chain:
    - {get: h}
  expected: 120
