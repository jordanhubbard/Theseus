spec: concurrent_futures_extra229
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.CancelledError.__name__ == 'CancelledError'; module is 'concurrent.futures._base'; base is 'Error' (concurrent.futures._base.Error); verified with Python 3.14.3."
    - "concurrent.futures.TimeoutError.__name__ == 'TimeoutError'; module is 'builtins'; base is 'OSError'; verified with Python 3.14.3."
    - "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor'; module is 'concurrent.futures._base'; base is 'RuntimeError'; verified with Python 3.14.3."
    - "concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError'; module is 'concurrent.futures._base'; base is 'Error'; verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'; base is 'Executor'; module is 'concurrent.futures.thread'; verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor'; base is 'Executor'; module is 'concurrent.futures.process'; verified with Python 3.14.3."
    - "concurrent.futures.Executor.__name__ == 'Executor'; base is 'object'; module is 'concurrent.futures._base'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures exception class name and module contracts — extra229 namespace
#
# CancelledError and InvalidStateError live in concurrent.futures._base.
# TimeoutError is the builtin TimeoutError (lives in builtins).
# BrokenExecutor lives in concurrent.futures._base.
# ---------------------------------------------------------------------------

table concurrent_futures_extra229.exception_class_names:
  description: "concurrent.futures exception __name__ and __module__ identity contracts in cf229exc namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cf229exc

  columns: [id, function, args, expected, description]
  rows:
    - [cancelled_name_eq,        CancelledError.__name__.__eq__,      ["CancelledError"],                  true, "concurrent.futures.CancelledError.__name__ == 'CancelledError'; verified with Python 3.14.3"]
    - [cancelled_module_eq,      CancelledError.__module__.__eq__,    ["concurrent.futures._base"],        true, "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [timeout_name_eq,          TimeoutError.__name__.__eq__,        ["TimeoutError"],                    true, "concurrent.futures.TimeoutError.__name__ == 'TimeoutError'; verified with Python 3.14.3"]
    - [timeout_module_eq,        TimeoutError.__module__.__eq__,      ["builtins"],                        true, "concurrent.futures.TimeoutError.__module__ == 'builtins' — it is the builtin TimeoutError; verified with Python 3.14.3"]
    - [broken_exec_name_eq,      BrokenExecutor.__name__.__eq__,      ["BrokenExecutor"],                  true, "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor'; verified with Python 3.14.3"]
    - [broken_exec_module_eq,    BrokenExecutor.__module__.__eq__,    ["concurrent.futures._base"],        true, "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [invalid_state_name_eq,    InvalidStateError.__name__.__eq__,   ["InvalidStateError"],               true, "concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError'; verified with Python 3.14.3"]
    - [invalid_state_module_eq,  InvalidStateError.__module__.__eq__, ["concurrent.futures._base"],        true, "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures exception base class contracts — extra229 namespace
#
# TimeoutError.__bases__[0].__name__ == 'OSError' — builtin OSError.
# BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra229.timeout_base_is_oserror:
  description: "concurrent.futures.TimeoutError.__bases__[0].__name__ == 'OSError' — inherits from builtin OSError"
  category: class_hierarchy
  kind: python_call_eq
  function: "TimeoutError.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

invariant concurrent_futures_extra229.broken_executor_base_is_runtimeerror:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'"
  category: class_hierarchy
  kind: python_call_eq
  function: "BrokenExecutor.__bases__[0].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true

# ---------------------------------------------------------------------------
# concurrent.futures executor class identity contracts — extra229 namespace
#
# ThreadPoolExecutor.__name__ and module; ProcessPoolExecutor.__name__ and module.
# Both directly inherit from Executor.
# ---------------------------------------------------------------------------

table concurrent_futures_extra229.executor_class_names:
  description: "concurrent.futures executor class __name__ and __module__ contracts in cf229ecn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cf229ecn

  columns: [id, function, args, expected, description]
  rows:
    - [executor_name_eq,    Executor.__name__.__eq__,             ["Executor"],                    true, "concurrent.futures.Executor.__name__ == 'Executor'; verified with Python 3.14.3"]
    - [executor_module_eq,  Executor.__module__.__eq__,           ["concurrent.futures._base"],    true, "concurrent.futures.Executor.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [tpe_name_eq,         ThreadPoolExecutor.__name__.__eq__,   ["ThreadPoolExecutor"],          true, "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'; verified with Python 3.14.3"]
    - [tpe_module_eq,       ThreadPoolExecutor.__module__.__eq__, ["concurrent.futures.thread"],   true, "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'; verified with Python 3.14.3"]
    - [ppe_name_eq,         ProcessPoolExecutor.__name__.__eq__,  ["ProcessPoolExecutor"],         true, "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor'; verified with Python 3.14.3"]
    - [ppe_module_eq,       ProcessPoolExecutor.__module__.__eq__, ["concurrent.futures.process"], true, "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process'; verified with Python 3.14.3"]

invariant concurrent_futures_extra229.tpe_base_is_executor:
  description: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'"
  category: class_hierarchy
  kind: python_call_eq
  function: "ThreadPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra229.ppe_base_is_executor:
  description: "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'"
  category: class_hierarchy
  kind: python_call_eq
  function: "ProcessPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true
