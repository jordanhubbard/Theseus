spec: imaplib_extra2
version: ">=3.9"
backend: python_module(imaplib)

docs: https://docs.python.org/3/library/imaplib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/imaplib.html — Python imaplib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/imaplib.py"
    - "imaplib.zspec.zsdl — covers class names table (IMAP4/IMAP4_SSL/IMAP4_stream/error/abort/readonly), IMAP4.__module__, IMAP4.port=143, IMAP4_SSL.port=993, abort/__bases__, readonly/__bases__, method names table"
    - "imaplib_extra.zspec.zsdl — covers IMAP4.__name__, IMAP4.__module__, IMAP4_SSL.__name__, IMAP4_SSL.__bases__, nested IMAP4.error/abort/readonly __name__ and hierarchy, method names table (login/logout/select/search/fetch/append/close/expunge/store/copy)"
  notes:
    - "This spec extends imaplib.zspec.zsdl and imaplib_extra.zspec.zsdl with new vectors."
    - "imaplib.IMAP4_stream.__name__ == 'IMAP4_stream' — covered in imaplib.zspec table but not as a standalone invariant."
    - "imaplib.IMAP4_stream.__bases__[0].__name__ == 'IMAP4' — IMAP4_stream inherits directly from IMAP4."
    - "imaplib.error.__name__ == 'error' — module-level alias for IMAP4.error; covered in imaplib.zspec table only."
    - "imaplib.abort.__name__ == 'abort' — module-level alias for IMAP4.abort; covered in imaplib.zspec table only."
    - "imaplib.readonly.__name__ == 'readonly' — module-level alias; covered in imaplib.zspec table only."
    - "imaplib.error.__bases__[0].__name__ == 'Exception' — module-level error class inherits from Exception."
    - "imaplib.abort.__bases__[0].__name__ == 'error' — module-level abort inherits from error."
    - "imaplib.IMAP4.port.__class__.__name__ == 'int' — port is an integer class attribute."
    - "imaplib.IMAP4_SSL.__module__ == 'imaplib' — module check for IMAP4_SSL."
    - "imaplib.IMAP4_stream.__module__ == 'imaplib' — module check for IMAP4_stream."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class names table — IMAP4, IMAP4_SSL, IMAP4_stream
# (imaplib.zspec and imaplib_extra cover these; this table serves as
#  cross-spec verification vectors with a focused three-class table.)
# ---------------------------------------------------------------------------

table imaplib_extra2.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [IMAP4,        IMAP4.__name__.__eq__,        ["IMAP4"],        true]
    - [IMAP4_SSL,    IMAP4_SSL.__name__.__eq__,    ["IMAP4_SSL"],    true]
    - [IMAP4_stream, IMAP4_stream.__name__.__eq__, ["IMAP4_stream"], true]

# ---------------------------------------------------------------------------
# IMAP4_stream — standalone invariants (not in imaplib_extra)
# ---------------------------------------------------------------------------

invariant imaplib_extra2.IMAP4_stream.name:
  description: "imaplib.IMAP4_stream.__name__ == 'IMAP4_stream'"
  category: class_names
  kind: python_call_eq
  function: IMAP4_stream.__name__.__eq__
  args: ["IMAP4_stream"]
  expected: true

invariant imaplib_extra2.IMAP4_stream.base_class:
  description: "imaplib.IMAP4_stream.__bases__[0].__name__ == 'IMAP4' — IMAP4_stream inherits directly from IMAP4"
  category: class_hierarchy
  kind: python_call_eq
  function: IMAP4_stream.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IMAP4"

invariant imaplib_extra2.IMAP4_stream.module:
  description: "imaplib.IMAP4_stream.__module__ == 'imaplib'"
  category: class_modules
  kind: python_call_eq
  function: IMAP4_stream.__module__.__eq__
  args: ["imaplib"]
  expected: true

# ---------------------------------------------------------------------------
# IMAP4_SSL — module check (not in imaplib_extra)
# ---------------------------------------------------------------------------

invariant imaplib_extra2.IMAP4_SSL.module:
  description: "imaplib.IMAP4_SSL.__module__ == 'imaplib'"
  category: class_modules
  kind: python_call_eq
  function: IMAP4_SSL.__module__.__eq__
  args: ["imaplib"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level exception class names — error, abort, readonly
# (imaplib.zspec covers these in a class_names table;
#  imaplib_extra covers IMAP4.error/abort/readonly as nested attributes.
#  This spec tests the module-level names directly as standalone invariants.)
# ---------------------------------------------------------------------------

invariant imaplib_extra2.error.name:
  description: "imaplib.error.__name__ == 'error' — module-level exception class"
  category: class_names
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant imaplib_extra2.abort.name:
  description: "imaplib.abort.__name__ == 'abort' — module-level exception class"
  category: class_names
  kind: python_call_eq
  function: abort.__name__.__eq__
  args: ["abort"]
  expected: true

invariant imaplib_extra2.readonly.name:
  description: "imaplib.readonly.__name__ == 'readonly' — module-level exception class"
  category: class_names
  kind: python_call_eq
  function: readonly.__name__.__eq__
  args: ["readonly"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level exception hierarchy
# (imaplib.zspec covers abort.__bases__ and readonly.__bases__;
#  imaplib_extra covers these via IMAP4.error/abort/readonly nested attrs.
#  This spec adds error.__bases__[0].__name__ == 'Exception' for the
#  module-level error class, which is not covered as a standalone invariant.)
# ---------------------------------------------------------------------------

invariant imaplib_extra2.error.base_is_Exception:
  description: "imaplib.error.__bases__[0].__name__ == 'Exception' — module-level error inherits from Exception"
  category: class_hierarchy
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant imaplib_extra2.abort.base_is_error:
  description: "imaplib.abort.__bases__[0].__name__ == 'error' — module-level abort inherits from error"
  category: class_hierarchy
  kind: python_call_eq
  function: abort.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "error"

# ---------------------------------------------------------------------------
# IMAP4.port class attribute — type is int
# (imaplib.zspec covers IMAP4.port == 143; this adds type check.)
# ---------------------------------------------------------------------------

invariant imaplib_extra2.IMAP4.port_class_name:
  description: "imaplib.IMAP4.port.__class__.__name__ == 'int' — port is an integer class attribute"
  category: constants
  kind: python_call_eq
  function: IMAP4.port.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# IMAP4_SSL.port class attribute — type is int and value is 993
# (imaplib.zspec covers IMAP4_SSL.port == 993; this adds type check.)
# ---------------------------------------------------------------------------

invariant imaplib_extra2.IMAP4_SSL.port_class_name:
  description: "imaplib.IMAP4_SSL.port.__class__.__name__ == 'int' — IMAP4_SSL.port is an integer class attribute"
  category: constants
  kind: python_call_eq
  function: IMAP4_SSL.port.__class__.__name__.__eq__
  args: ["int"]
  expected: true
