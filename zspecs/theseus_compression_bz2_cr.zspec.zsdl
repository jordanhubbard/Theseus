spec: theseus_compression_bz2_cr
version: ">=3.14"
backend: python_cleanroom(theseus_compression_bz2_cr)
blocks: compression.bz2

docs: https://docs.python.org/3/library/compression.bz2.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/compression.bz2.html"
  not_derived_from:
    - "CPython source: Lib/compression/bz2.py"
  notes:
    - "Clean-room compression.bz2 module (Python 3.14+). Do NOT import compression.bz2."

error_model: python_exceptions

invariant theseus_compression_bz2_cr.cbz22_compress:
  description: "compress/decompress roundtrip works"
  category: behavior
  kind: python_call_eq
  function: cbz22_compress
  args: []
  expected: true

invariant theseus_compression_bz2_cr.cbz22_classes:
  description: "BZ2File, BZ2Compressor, BZ2Decompressor classes exist"
  category: behavior
  kind: python_call_eq
  function: cbz22_classes
  args: []
  expected: true

invariant theseus_compression_bz2_cr.cbz22_open:
  description: "open() creates a readable compressed file"
  category: behavior
  kind: python_call_eq
  function: cbz22_open
  args: []
  expected: true
