    - ["mp3466021",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__len__"], false]
    - ["mp3466022",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__len__"], false]
    - ["mp3466023",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__len__"], false]
    - ["mp3466024",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__len__"], false]

# ---------------------------------------------------------------------------
# combined — __iter__, __next__, __len__ across all 8 mp subjects
#
# Covers the full matrix: 8 classes x 3 methods = 24 rows.
# __iter__: false for all 8 — not in any type's own __dict__.
# __next__: false for all 8 — not in any type's own __dict__.
# __len__:  false for all 8 — not in any type's own __dict__.
# All 24 values are false.
# The proxy types (_BaseSetProxy, _BaseDictProxy, BaseListProxy) are the most
#   analytically interesting subjects here. At runtime, these proxy types relay
#   iteration and sizing to a managed server process via IPC proxy dispatch.
#   However, none of __iter__, __next__, or __len__ is defined in their own
#   Python-level __dict__ — the proxy dispatch mechanism operates below the
#   dunder level and is not expressed through these protocol slots in the class __dict__.
# Contrast with wave 658 (mp3166): BaseListProxy __add__ and __mul__ were true
#   because those dunders ARE directly defined in BaseListProxy.__dict__. The
#   iterator and sizing dunders (__iter__, __next__, __len__) are not
#   directly defined in the same way.
# multiprocessing is a process-based concurrency library; its types interact
#   exclusively through explicit method calls, subprocess lifecycle management,
#   and IPC — not through iterator or sizing protocol overrides in any class __dict__.
# ---------------------------------------------------------------------------

