    - ["mp3466009",  operator.contains, [multiprocessing.Process.__dict__,                 "__next__"], false]
    - ["mp3466010",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__next__"], false]
    - ["mp3466011",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__next__"], false]
    - ["mp3466012",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__next__"], false]
    - ["mp3466013",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__next__"], false]
    - ["mp3466014",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__next__"], false]
    - ["mp3466015",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__next__"], false]
    - ["mp3466016",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__next__"], false]

# ---------------------------------------------------------------------------
# __len__ dict-presence — operator.contains(Cls.__dict__, '__len__')
#
# All 8 multiprocessing classes return false for __len__.
# len(x) delegates to __len__ when defined in the class's own __dict__.
# None of the 8 multiprocessing classes define a Python-level __len__
#   in their own __dict__.
# managers._BaseDictProxy key note: _BaseDictProxy relays len() to the
#   managed server process via IPC proxy dispatch, but __len__ is NOT defined
#   in _BaseDictProxy.__dict__ at the Python class level.
# managers.BaseListProxy: proxies list length via proxy dispatch;
#   __len__ is not in BaseListProxy.__dict__.
# managers._BaseSetProxy: proxies set length via proxy dispatch;
#   __len__ is absent from its own __dict__.
# multiprocessing.Process: no __len__ defined; processes are not sized containers.
# pool.Pool/AsyncResult/MapResult/SyncManager: no __len__ in their own
#   __dict__; sizing is not part of the pool or result-handle API.
# ---------------------------------------------------------------------------

