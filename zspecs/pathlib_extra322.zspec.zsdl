spec: pathlib_extra322
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path filesystem predicate invariants (read-only, known system paths)
# All test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0.
# Path('/').is_dir() == True; Path('/').is_file() == False
# Path('/tmp').is_dir() == True (macOS has /tmp as a symlink to /private/tmp)
# Path('/nonexistent/xyz123abc').exists() == False; .is_dir() == False; .is_file() == False
# Path('/').stat().__class__.__name__ == 'stat_result'
# Path('/tmp').resolve().__class__.__name__ == 'PosixPath'
# ---------------------------------------------------------------------------

invariant pathlib_extra322.Path.root_is_dir:
  description: "pathlib.Path('/').is_dir() == True — the filesystem root is always a directory; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: "Path('/').is_dir"
  args: []
  expected: true

invariant pathlib_extra322.Path.root_is_not_file:
  description: "pathlib.Path('/').is_file() == False — the filesystem root is not a regular file; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: "Path('/').is_file"
  args: []
  expected: false

invariant pathlib_extra322.Path.tmp_is_dir:
  description: "pathlib.Path('/tmp').is_dir() == True — /tmp exists and is a directory (symlink to /private/tmp on macOS); verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: "Path('/tmp').is_dir"
  args: []
  expected: true

invariant pathlib_extra322.Path.nonexistent_not_exists:
  description: "pathlib.Path('/nonexistent/xyz123abc').exists() == False — a path that does not exist returns False for exists(); verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: "Path('/nonexistent/xyz123abc').exists"
  args: []
  expected: false

invariant pathlib_extra322.Path.nonexistent_not_dir:
  description: "pathlib.Path('/nonexistent/xyz123abc').is_dir() == False — a nonexistent path is not a directory; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: "Path('/nonexistent/xyz123abc').is_dir"
  args: []
  expected: false

invariant pathlib_extra322.Path.nonexistent_not_file:
  description: "pathlib.Path('/nonexistent/xyz123abc').is_file() == False — a nonexistent path is not a regular file; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: "Path('/nonexistent/xyz123abc').is_file"
  args: []
  expected: false

invariant pathlib_extra322.Path.stat_class_name:
  description: "pathlib.Path('/').stat().__class__.__name__ == 'stat_result' — stat() returns an os.stat_result instance; verified Python 3.14.3 macOS"
  category: classnames
  kind: python_call_eq
  function: "Path('/').stat().__class__.__name__.__eq__"
  args: ["stat_result"]
  expected: true

invariant pathlib_extra322.Path.resolve_class_name:
  description: "pathlib.Path('/tmp').resolve().__class__.__name__ == 'PosixPath' — resolve() returns a PosixPath on POSIX systems; verified Python 3.14.3 macOS"
  category: classnames
  kind: python_call_eq
  function: "Path('/tmp').resolve().__class__.__name__.__eq__"
  args: ["PosixPath"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.Path filesystem predicates — table form
# Consolidates is_dir/is_file/exists checks for known paths
# ---------------------------------------------------------------------------

table pathlib_extra322.known_path_predicates:
  description: "pathlib.Path filesystem predicates for known system paths on macOS"
  kind: python_call_eq
  category: behavioral
  id_prefix: pathlibfs322

  columns: [id, function, args, expected]
  rows:
    - [root_isdir,       "Path('/').is_dir",                     [], true]
    - [root_isfile,      "Path('/').is_file",                    [], false]
    - [tmp_isdir,        "Path('/tmp').is_dir",                  [], true]
    - [tmp_isfile,       "Path('/tmp').is_file",                 [], false]
    - [noexist_exists,   "Path('/nonexistent/xyz123abc').exists", [], false]
    - [noexist_isdir,    "Path('/nonexistent/xyz123abc').is_dir", [], false]
    - [noexist_isfile,   "Path('/nonexistent/xyz123abc').is_file", [], false]
