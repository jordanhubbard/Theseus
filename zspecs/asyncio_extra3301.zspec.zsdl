    - ["as3301026", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__imod__"], false]
    - ["as3301027", operator.contains, [asyncio.Condition.__dict__,        "__imod__"], false]
    - ["as3301028", operator.contains, [asyncio.Queue.__dict__,            "__imod__"], false]
