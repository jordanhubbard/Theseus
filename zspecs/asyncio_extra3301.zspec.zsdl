    - ["as3301002", operator.contains, [asyncio.Future.__dict__,           "__itruediv__"], false]
    - ["as3301003", operator.contains, [asyncio.Event.__dict__,            "__itruediv__"], false]
    - ["as3301004", operator.contains, [asyncio.Lock.__dict__,             "__itruediv__"], false]
    - ["as3301005", operator.contains, [asyncio.Semaphore.__dict__,        "__itruediv__"], false]
    - ["as3301006", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__itruediv__"], false]
    - ["as3301007", operator.contains, [asyncio.Condition.__dict__,        "__itruediv__"], false]
    - ["as3301008", operator.contains, [asyncio.Queue.__dict__,            "__itruediv__"], false]
    - ["as3301009", operator.contains, [asyncio.PriorityQueue.__dict__,    "__itruediv__"], false]
    - ["as3301010", operator.contains, [asyncio.LifoQueue.__dict__,        "__itruediv__"], false]

# ---------------------------------------------------------------------------
# __ifloordiv__ dict-presence — operator.contains(Cls.__dict__, '__ifloordiv__')
#
# All 10 asyncio classes return false for __ifloordiv__.
# In-place floor division (__ifloordiv__, //=) is the augmented assignment
#   variant of __floordiv__. asyncio types define no __floordiv__ (wave 659),
#   so __ifloordiv__ is equally absent.
# asyncio synchronization primitives (Event, Lock, Condition, Semaphore,
#   BoundedSemaphore) have no numeric data model that //= could operate on.
# asyncio.Task/Future: coroutine result handles; //= is not defined for
#   pending result objects.
# asyncio.Queue/PriorityQueue/LifoQueue: item stores; in-place floor division
#   is entirely absent — items are managed through put()/get() coroutines only.
# ---------------------------------------------------------------------------

