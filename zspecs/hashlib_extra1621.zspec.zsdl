spec: hashlib_extra1621
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __weakref__ and weak reference protocol"
    - "hashlib hash types (md5, sha1, sha256, sha512, sha3_256, sha3_512) are C extension instances of type HASH from _hashlib; C types do NOT have __weakref__ in their own class __dict__"
    - "The HASH C type may still support weak references via tp_weaklistoffset in the C struct without exposing __weakref__ in the class dict"
    - "algorithms_guaranteed and algorithms_available are plain set objects in Python 3.14, not frozenset"
    - "sha3_256, sha3_512 are C types from _sha3 (or _hashlib on newer builds); they also lack __weakref__ in class dict"
    - "blake2b and blake2s are C types; they also lack __weakref__ in class dict"
    - "shake_128 and shake_256 are HASHXOF C type objects; they also lack __weakref__ in class dict"
    - "algorithms_guaranteed is a set; guaranteed to contain sha256, sha1, md5, sha512, sha3_256, sha3_512, blake2b, blake2s, shake_128, shake_256"
  created_at: "2026-04-12"
error_model: python_exceptions

table hashlib_extra1621.hash_type_no_weakref:
  description: "HASH C extension types for md5/sha1/sha256/sha512/sha3_256/sha3_512 do NOT have __weakref__ in their class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1621nw

  columns: [id, function, args, expected]
  rows:
    - ["hl1621nw001", "type(hashlib.md5(b'')).__dict__.__contains__",    ["__weakref__"], false]
    - ["hl1621nw002", "type(hashlib.sha1(b'')).__dict__.__contains__",   ["__weakref__"], false]
    - ["hl1621nw003", "type(hashlib.sha256(b'')).__dict__.__contains__", ["__weakref__"], false]
    - ["hl1621nw004", "type(hashlib.sha512(b'')).__dict__.__contains__", ["__weakref__"], false]
    - ["hl1621nw005", "type(hashlib.md5(b'')).__dict__.__contains__",    ["__slots__"],   false]
    - ["hl1621nw006", "type(hashlib.sha1(b'')).__dict__.__contains__",   ["__slots__"],   false]
    - ["hl1621nw007", "type(hashlib.sha256(b'')).__dict__.__contains__", ["__slots__"],   false]
    - ["hl1621nw008", "type(hashlib.sha512(b'')).__dict__.__contains__", ["__slots__"],   false]
    - ["hl1621nw009", "type(hashlib.md5(b'')).__name__.__eq__",          ["HASH"],        true]
    - ["hl1621nw010", "type(hashlib.sha1(b'')).__name__.__eq__",         ["HASH"],        true]
    - ["hl1621nw011", "type(hashlib.sha256(b'')).__name__.__eq__",       ["HASH"],        true]
    - ["hl1621nw012", "type(hashlib.sha512(b'')).__name__.__eq__",       ["HASH"],        true]
    - ["hl1621nw013", "type(hashlib.md5(b'')).__module__.__eq__",        ["_hashlib"],    true]
    - ["hl1621nw014", "type(hashlib.sha1(b'')).__module__.__eq__",       ["_hashlib"],    true]
    - ["hl1621nw015", "type(hashlib.sha256(b'')).__module__.__eq__",     ["_hashlib"],    true]
    - ["hl1621nw016", "type(hashlib.sha512(b'')).__module__.__eq__",     ["_hashlib"],    true]
    - ["hl1621nw017", "type(hashlib.md5(b'')).__dict__.__contains__",    ["__dict__"],    false]
    - ["hl1621nw018", "type(hashlib.sha1(b'')).__dict__.__contains__",   ["__dict__"],    false]
    - ["hl1621nw019", "type(hashlib.sha256(b'')).__dict__.__contains__", ["__dict__"],    false]
    - ["hl1621nw020", "type(hashlib.sha512(b'')).__dict__.__contains__", ["__dict__"],    false]
    - ["hl1621nw021", "type(hashlib.md5(b'')).__dict__.__contains__",    ["name"],        true]
    - ["hl1621nw022", "type(hashlib.md5(b'')).__dict__.__contains__",    ["digest_size"], true]
    - ["hl1621nw023", "type(hashlib.md5(b'')).__dict__.__contains__",    ["block_size"],  true]
    - ["hl1621nw024", "type(hashlib.md5(b'')).__dict__.__contains__",    ["update"],      true]
    - ["hl1621nw025", "type(hashlib.md5(b'')).__dict__.__contains__",    ["hexdigest"],   true]

table hashlib_extra1621.algorithms_set_type:
  description: "algorithms_guaranteed and algorithms_available are plain set objects (not frozenset) in Python 3.9+"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1621st

  columns: [id, function, args, expected]
  rows:
    - ["hl1621st001", "type(hashlib.algorithms_guaranteed).__name__.__eq__",      ["set"],  true]
    - ["hl1621st002", "type(hashlib.algorithms_available).__name__.__eq__",        ["set"],  true]
    - ["hl1621st003", "hashlib.algorithms_guaranteed.__class__.__name__.__eq__",   ["set"],  true]
    - ["hl1621st004", "hashlib.algorithms_available.__class__.__name__.__eq__",    ["set"],  true]
    - ["hl1621st005", "hashlib.algorithms_guaranteed.__contains__",                ["md5"],      true]
    - ["hl1621st006", "hashlib.algorithms_guaranteed.__contains__",                ["sha1"],     true]
    - ["hl1621st007", "hashlib.algorithms_guaranteed.__contains__",                ["sha256"],   true]
    - ["hl1621st008", "hashlib.algorithms_guaranteed.__contains__",                ["sha512"],   true]
    - ["hl1621st009", "hashlib.algorithms_guaranteed.__contains__",                ["sha224"],   true]
    - ["hl1621st010", "hashlib.algorithms_guaranteed.__contains__",                ["sha384"],   true]
    - ["hl1621st011", "hashlib.algorithms_available.__contains__",                 ["md5"],      true]
    - ["hl1621st012", "hashlib.algorithms_available.__contains__",                 ["sha256"],   true]
    - ["hl1621st013", "len(hashlib.algorithms_guaranteed).__ge__",                 [6],          true]
    - ["hl1621st014", "len(hashlib.algorithms_available).__ge__",                  [6],          true]
    - ["hl1621st015", "hashlib.algorithms_guaranteed.__contains__",                ["sha3_256"], true]
    - ["hl1621st016", "hashlib.algorithms_guaranteed.__contains__",                ["sha3_512"], true]
    - ["hl1621st017", "hashlib.algorithms_guaranteed.__contains__",                ["blake2b"],  true]
    - ["hl1621st018", "hashlib.algorithms_guaranteed.__contains__",                ["blake2s"],  true]
    - ["hl1621st019", "issubclass(type(hashlib.algorithms_guaranteed), set).__eq__", [true],    true]
    - ["hl1621st020", "issubclass(type(hashlib.algorithms_available), set).__eq__",  [true],    true]
    - ["hl1621st021", "type(hashlib.algorithms_guaranteed).__name__.__eq__",       ["frozenset"], false]
    - ["hl1621st022", "type(hashlib.algorithms_available).__name__.__eq__",        ["frozenset"], false]
    - ["hl1621st023", "hashlib.algorithms_available.__class__.__name__.__eq__",    ["frozenset"], false]
    - ["hl1621st024", "hashlib.algorithms_guaranteed.__class__.__name__.__eq__",   ["frozenset"], false]
    - ["hl1621st025", "hashlib.algorithms_guaranteed.__contains__",                ["sha3_256"],  true]

table hashlib_extra1621.algorithms_sha3_blake2:
  description: "sha3_256, sha3_512, blake2b, blake2s, shake_128, shake_256 are in algorithms_guaranteed; their hash type __dict__ also lacks __weakref__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1621sb

  columns: [id, function, args, expected]
  rows:
    - ["hl1621sb001", "hashlib.algorithms_guaranteed.__contains__",                    ["sha3_256"],  true]
    - ["hl1621sb002", "hashlib.algorithms_guaranteed.__contains__",                    ["sha3_512"],  true]
    - ["hl1621sb003", "hashlib.algorithms_guaranteed.__contains__",                    ["blake2b"],   true]
    - ["hl1621sb004", "hashlib.algorithms_guaranteed.__contains__",                    ["blake2s"],   true]
    - ["hl1621sb005", "hashlib.algorithms_guaranteed.__contains__",                    ["shake_128"], true]
    - ["hl1621sb006", "hashlib.algorithms_guaranteed.__contains__",                    ["shake_256"], true]
    - ["hl1621sb007", "type(hashlib.sha3_256(b'')).__dict__.__contains__",             ["__weakref__"], false]
    - ["hl1621sb008", "type(hashlib.sha3_512(b'')).__dict__.__contains__",             ["__weakref__"], false]
    - ["hl1621sb009", "type(hashlib.blake2b(b'')).__dict__.__contains__",              ["__weakref__"], false]
    - ["hl1621sb010", "type(hashlib.blake2s(b'')).__dict__.__contains__",              ["__weakref__"], false]
    - ["hl1621sb011", "type(hashlib.sha3_256(b'')).__dict__.__contains__",             ["__slots__"],   false]
    - ["hl1621sb012", "type(hashlib.sha3_512(b'')).__dict__.__contains__",             ["__slots__"],   false]
    - ["hl1621sb013", "type(hashlib.blake2b(b'')).__dict__.__contains__",              ["__slots__"],   false]
    - ["hl1621sb014", "type(hashlib.blake2s(b'')).__dict__.__contains__",              ["__slots__"],   false]
    - ["hl1621sb015", "type(hashlib.sha3_256(b'')).__dict__.__contains__",             ["digest_size"], true]
    - ["hl1621sb016", "type(hashlib.sha3_512(b'')).__dict__.__contains__",             ["digest_size"], true]
    - ["hl1621sb017", "type(hashlib.blake2b(b'')).__dict__.__contains__",              ["digest_size"], true]
    - ["hl1621sb018", "type(hashlib.blake2s(b'')).__dict__.__contains__",              ["digest_size"], true]
    - ["hl1621sb019", "hashlib.sha3_256(b'').digest_size.__eq__",                      [32],            true]
    - ["hl1621sb020", "hashlib.sha3_512(b'').digest_size.__eq__",                      [64],            true]
    - ["hl1621sb021", "hashlib.blake2b(b'').digest_size.__eq__",                       [64],            true]
    - ["hl1621sb022", "hashlib.blake2s(b'').digest_size.__eq__",                       [32],            true]
    - ["hl1621sb023", "type(hashlib.sha3_256(b'')).__dict__.__contains__",             ["update"],      true]
    - ["hl1621sb024", "type(hashlib.sha3_256(b'')).__dict__.__contains__",             ["hexdigest"],   true]
    - ["hl1621sb025", "type(hashlib.sha3_256(b'')).__dict__.__contains__",             ["digest"],      true]
