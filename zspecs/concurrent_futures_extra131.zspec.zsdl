spec: concurrent_futures_extra131
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py, Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: wave 257 theme — concurrent.futures.ThreadPoolExecutor and concurrent.futures.Future method qualnames and class identity. NEW in extra131: concurrent.futures.ThreadPoolExecutor.__init__.__qualname__=='ThreadPoolExecutor.__init__' (len=27); concurrent.futures.ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=25); concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__=='ThreadPoolExecutor.shutdown' (len=27); concurrent.futures.ThreadPoolExecutor.__module__=='concurrent.futures.thread' (len=25); concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__=='Executor'; concurrent.futures.Future.__init__.__qualname__=='Future.__init__' (len=15); concurrent.futures.Future.result.__qualname__=='Future.result' (len=13); concurrent.futures.Future.__module__=='concurrent.futures._base' (len=24); concurrent.futures.Future.__bases__[0].__name__=='object'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (len=25). ThreadPoolExecutor is defined in Lib/concurrent/futures/thread.py, a different submodule from Future which is in _base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.__bases__[0].__name__ == 'object'. Future does not inherit from any intermediate base class — its MRO is [Future, object] (length=2). This distinguishes Future from exception classes in concurrent.futures which have deeper MROs. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount == 5 (self, max_workers, thread_name_prefix, initializer, initargs). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor method qualnames — extra131
