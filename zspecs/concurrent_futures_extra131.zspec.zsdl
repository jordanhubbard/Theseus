# ---------------------------------------------------------------------------
# Standalone invariants — extra131
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra131.ThreadPoolExecutor_init_qualname_len_27:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__() == 27 — ThreadPoolExecutor.__init__.__qualname__ is 'ThreadPoolExecutor.__init__' (27 chars: 'ThreadPoolExecutor'=18 + '.'=1 + '__init__'=8 = 27); this matches shutdown's qualname length (also 27) since 'shutdown' is 8 chars like '__init__'; submit has qualname len=25 ('submit'=6 < 8); ThreadPoolExecutor.__init__.__code__.co_argcount is 5 (self, max_workers, thread_name_prefix, initializer, initargs); ThreadPoolExecutor.__module__ is 'concurrent.futures.thread' (len=25); NEW in extra131: first standalone ThreadPoolExecutor.__init__ qualname length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__"
  args: []
  expected: 27

invariant concurrent_futures_extra131.ThreadPoolExecutor_module_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread') returns True — ThreadPoolExecutor.__module__ is 'concurrent.futures.thread' (25 chars: 'concurrent'=10 + '.'=1 + 'futures'=7 + '.'=1 + 'thread'=6 = 25); this is distinct from Future.__module__ which is 'concurrent.futures._base' (24 chars); ThreadPoolExecutor is defined in Lib/concurrent/futures/thread.py while ProcessPoolExecutor is in Lib/concurrent/futures/process.py; ThreadPoolExecutor.__bases__[0].__name__ is 'Executor' (len=8); ThreadPoolExecutor.__mro__.__len__() is 3 ([ThreadPoolExecutor, Executor, object]); NEW in extra131: first standalone ThreadPoolExecutor module equality invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__module__.__eq__"
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra131.Future_mro_len_2:
  description: "concurrent.futures.Future.__mro__.__len__() == 2 — Future's MRO is [Future, object] (length=2); Future does not inherit from any intermediate base class, making it one of the shallowest class hierarchies in concurrent.futures; contrast with ThreadPoolExecutor (MRO len=3, via Executor) and exception classes like InvalidStateError (MRO len=5); Future.__bases__[0].__name__ is 'object'; Future.__module__ is 'concurrent.futures._base' (len=24); Future.__qualname__.__len__() is 6; NEW in extra131: first standalone Future MRO length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.__mro__.__len__"
  args: []
  expected: 2

invariant concurrent_futures_extra131.Future_module_len_24:
  description: "concurrent.futures.Future.__module__.__len__() == 24 — Future.__module__ is 'concurrent.futures._base' (24 chars: 'concurrent'=10 + '.'=1 + 'futures'=7 + '.'=1 + '_base'=5 = 24); this is the same module as concurrent.futures.InvalidStateError and concurrent.futures.BrokenExecutor — all three are defined in Lib/concurrent/futures/_base.py; ThreadPoolExecutor.__module__ is 'concurrent.futures.thread' (len=25, one char longer); Future.__init__.__qualname__ is 'Future.__init__' (len=15); Future.__qualname__.__len__() is 6; NEW in extra131: first standalone Future module length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.__module__.__len__"
  args: []
  expected: 24

invariant concurrent_futures_extra131.Future_init_argc_1:
  description: "concurrent.futures.Future.__init__.__code__.co_argcount.__eq__(1) returns True — Future.__init__ takes only self (co_argcount==1); this contrasts sharply with ThreadPoolExecutor.__init__.__code__.co_argcount which is 5 (self, max_workers, thread_name_prefix, initializer, initargs); Future.__init__.__qualname__ is 'Future.__init__' (len=15); Future.result.__code__.co_argcount is 2 (self + timeout); Future.cancel.__code__.co_argcount is 1 (self only); Future.done.__code__.co_argcount is 1 (self only); Future.__module__ is 'concurrent.futures._base'; NEW in extra131: first standalone Future.__init__ co_argcount invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.__init__.__code__.co_argcount.__eq__"
  args: [1]
  expected: true

