  kind: python_call_eq
  category: identity
  id_prefix: cftpe131

  columns: [id, function, args, expected, description]
  rows:
    - [init_qn_eq,     "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__",    ["ThreadPoolExecutor.__init__"],    true, "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' (len=27); verified with Python 3.14.3"]
    - [submit_qn_eq,   "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__",      ["ThreadPoolExecutor.submit"],      true, "concurrent.futures.ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' (len=25); verified with Python 3.14.3"]
    - [shutdown_qn_eq, "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__eq__",    ["ThreadPoolExecutor.shutdown"],    true, "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' (len=27); verified with Python 3.14.3"]

