spec: cf3211
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 661 (cf3211): __and__, __or__, __xor__ dict-presence for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor."
    - "Key finding (__and__): all 3 concurrent.futures classes return false for __and__. Executor and future types are not integer types or set-like collections; none define bitwise AND in their __dict__. concurrent.futures.Future is a result handle with a state machine (PENDING/RUNNING/CANCELLED/FINISHED) — not a numeric or set value. f & g is not a valid operation for futures. ThreadPoolExecutor and ProcessPoolExecutor manage worker pools via submit()/map()/shutdown(); & is not defined for combining executors."
    - "Key finding (__or__): all 3 concurrent.futures classes return false for __or__. The | operator has union-type annotation semantics in Python 3.10+ at the metaclass level, but concurrent.futures types do not expose __or__ in their own __dict__. concurrent.futures.Future does not define | for future combination — done callbacks are composed via add_done_callback(). ThreadPoolExecutor and ProcessPoolExecutor have no | shorthand for combining pools or dispatching to multiple executors simultaneously."
    - "Key finding (__xor__): all 3 concurrent.futures classes return false for __xor__. Bitwise XOR (^) applies to integers and sets; concurrent.futures types are neither. concurrent.futures.Future does not define ^ for symmetric-difference of pending results. Executor types (ThreadPoolExecutor, ProcessPoolExecutor) have no XOR semantics — they manage worker pools, not mathematical sets of work items."
    - "All 9 values in this wave are false. concurrent.futures is a high-level parallel execution API operating entirely through method calls — submit(), map(), result(), cancel(), add_done_callback(), shutdown() — with no bitwise or set-algebra operator overloading of any kind."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __and__ dict-presence — operator.contains(Cls.__dict__, '__and__')
#
# All 3 concurrent.futures classes return false for __and__.
# concurrent.futures types are executor and future abstractions; they are
#   not integer or set-like types, so bitwise AND is not defined.
# concurrent.futures.Future: a result-handle with PENDING/RUNNING/CANCELLED/
#   FINISHED states; f & g is not a defined Python expression.
# ThreadPoolExecutor/ProcessPoolExecutor: worker-pool managers with an
#   entirely method-based API; & is not defined for pool composition.
# ---------------------------------------------------------------------------

table cf3211.and_:
  description: "concurrent.futures types __and__ dict-presence checks; wave 661"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3211

  columns: [id, function, args, expected]
  rows:
    - ["cf3211001", operator.contains, [concurrent.futures.Future.__dict__,              "__and__"], false]
    - ["cf3211002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__and__"], false]
    - ["cf3211003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__and__"], false]

# ---------------------------------------------------------------------------
# __or__ dict-presence — operator.contains(Cls.__dict__, '__or__')
#
# All 3 concurrent.futures classes return false for __or__.
# concurrent.futures.Future does not define | for combining futures or
#   chaining callbacks; done callbacks are registered via add_done_callback().
# ThreadPoolExecutor/ProcessPoolExecutor do not implement | as a shorthand
#   for submitting work to multiple pools — their API is purely method-based.
# The Python 3.10+ union-type | operator is a metaclass-level feature;
#   it does not place __or__ in these classes' own __dict__.
# ---------------------------------------------------------------------------

table cf3211.or_:
  description: "concurrent.futures types __or__ dict-presence checks; wave 661"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3211

  columns: [id, function, args, expected]
  rows:
    - ["cf3211004", operator.contains, [concurrent.futures.Future.__dict__,              "__or__"], false]
    - ["cf3211005", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__or__"], false]
    - ["cf3211006", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__or__"], false]

# ---------------------------------------------------------------------------
# __xor__ dict-presence — operator.contains(Cls.__dict__, '__xor__')
#
# All 3 concurrent.futures classes return false for __xor__.
# Bitwise XOR (^) is defined for integers and sets; concurrent.futures
#   types are neither.
# concurrent.futures.Future does not define ^ — futures hold a single
#   pending computation result; symmetric-difference of results is not
#   a defined concept.
# ThreadPoolExecutor/ProcessPoolExecutor: pool managers with no set-algebra
#   semantics; ^ is undefined for combining or differencing pools.
# ---------------------------------------------------------------------------

table cf3211.xor:
  description: "concurrent.futures types __xor__ dict-presence checks; wave 661"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3211

  columns: [id, function, args, expected]
  rows:
    - ["cf3211007", operator.contains, [concurrent.futures.Future.__dict__,              "__xor__"], false]
    - ["cf3211008", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__xor__"], false]
    - ["cf3211009", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__xor__"], false]

# ---------------------------------------------------------------------------
# combined — __and__, __or__, __xor__ across all 3 cf subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __and__: false for all 3 — no bitwise AND defined.
# __or__:  false for all 3 — no bitwise OR defined.
# __xor__: false for all 3 — no bitwise XOR defined.
# All 9 values are false.
# concurrent.futures is a high-level parallel execution API. Its entire
#   public surface is method-based: submit(), map(), result(), cancel(),
#   done(), running(), cancelled(), add_done_callback(), shutdown().
#   No arithmetic or bitwise operator overloading appears anywhere in the
#   concurrent.futures type hierarchy.
# concurrent.futures.Future note: despite the name implying a value
#   arriving "in the future", Future is a result handle with a state machine
#   — not a numeric or collection type. &, |, ^ are all absent.
# ThreadPoolExecutor/ProcessPoolExecutor note: executor types encapsulate
#   a pool of worker threads or processes; they expose only lifecycle and
#   dispatch methods. No operator overloads are defined.
# ---------------------------------------------------------------------------

table cf3211.combined:
  description: "concurrent.futures types combined __and__/__or__/__xor__; wave 661"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3211

  columns: [id, function, args, expected]
  rows:
    - ["cf3211010", operator.contains, [concurrent.futures.Future.__dict__,              "__and__"], false]
    - ["cf3211011", operator.contains, [concurrent.futures.Future.__dict__,              "__or__"],  false]
    - ["cf3211012", operator.contains, [concurrent.futures.Future.__dict__,              "__xor__"], false]
    - ["cf3211013", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__and__"], false]
    - ["cf3211014", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__or__"],  false]
    - ["cf3211015", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__xor__"], false]
    - ["cf3211016", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__and__"], false]
    - ["cf3211017", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__or__"],  false]
    - ["cf3211018", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__xor__"], false]
