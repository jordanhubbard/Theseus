spec: io2956
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io class __dict__ bitwise invert / round / trunc presence"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/"
  notes:
    - "io I/O classes are stream/file types; they do not define __invert__, __round__, or __trunc__."
    - "operator.contains(cls.__dict__, '__invert__') is False for all io classes — these are not numeric types."
    - "operator.contains(cls.__dict__, '__round__') is False for all io classes."
    - "operator.contains(cls.__dict__, '__trunc__') is False for all io classes."
    - "All values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __invert__ dict-presence — bitwise invert operator in own __dict__
#
# None of the io classes define __invert__ in their own __dict__.
# These are stream/file abstractions, not numeric types.
# ---------------------------------------------------------------------------

table io2956.invert:
  description: "operator.contains(cls.__dict__, '__invert__') is False for all io classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ioi2956

  columns: [id, function, args, expected]
  rows:
    - ["ioi2956_001", operator.contains, [io.IOBase.__dict__,        "__invert__"], false]
    - ["ioi2956_002", operator.contains, [io.RawIOBase.__dict__,     "__invert__"], false]
    - ["ioi2956_003", operator.contains, [io.BufferedIOBase.__dict__, "__invert__"], false]
    - ["ioi2956_004", operator.contains, [io.TextIOBase.__dict__,    "__invert__"], false]
    - ["ioi2956_005", operator.contains, [io.FileIO.__dict__,        "__invert__"], false]
    - ["ioi2956_006", operator.contains, [io.BytesIO.__dict__,       "__invert__"], false]
    - ["ioi2956_007", operator.contains, [io.StringIO.__dict__,      "__invert__"], false]
    - ["ioi2956_008", operator.contains, [io.BufferedReader.__dict__, "__invert__"], false]
    - ["ioi2956_009", operator.contains, [io.BufferedWriter.__dict__, "__invert__"], false]
    - ["ioi2956_010", operator.contains, [io.BufferedRandom.__dict__, "__invert__"], false]
    - ["ioi2956_011", operator.contains, [io.TextIOWrapper.__dict__,  "__invert__"], false]

