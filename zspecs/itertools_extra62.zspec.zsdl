spec: itertools_extra62
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra61.zspec.zsdl."
    - "Wave 228 theme: __doc__ string content checks, __annotations__ class identity, __globals__ keys presence checks."
    - "itertools.groupby is a C extension type. Its __doc__ does NOT contain the word 'groupby' (capital or lowercase) — the docstring reads 'make an iterator that returns consecutive keys and groups from the iterable' with no self-reference by name. However it DOES contain 'iterable'. This is a notable fact: the type's docstring does not name the type."
    - "itertools.chain is a C extension type. Its __doc__ begins 'Return a chain object whose .__next__() method returns elements from the\\nfirst iterable until it is exhausted...'. The word 'chain' appears in 'chain object'. chain.__doc__.__contains__('chain') returns True."
    - "itertools.count is a C extension type. Its __doc__ begins 'Return a count object whose .__next__() method returns consecutive values...'. The word 'count' appears in 'count object'. count.__doc__.__contains__('count') returns True."
    - "itertools module-level __doc__ is a str of length 1386. It contains 'count' (the type name appears in the module docstring examples) but does NOT contain 'itertools' (the module docstring does not name the module itself). itertools.__doc__.__class__.__name__ == 'str'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "No prior itertools spec checks __doc__.__contains__ for groupby, chain, count, or the module itself. All checks in this spec are new to extra62."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# groupby.__doc__.__contains__ checks — extra62
#
# Wave 228 theme: __doc__ string content checks.
#
# itertools.groupby is a C extension type. Its docstring:
#   'make an iterator that returns consecutive keys and groups from the iterable
#    iterable
#      Elements to divide into groups according to the key function.
#    key
#      A function for computing the group category for each element...'
#
# Key findings:
#   groupby.__doc__.__contains__('groupby') == False  (no self-reference by name)
#   groupby.__doc__.__contains__('iterable') == True  (first line mentions iterable)
#   groupby.__doc__.__contains__('iterator') == True  (first line mentions iterator)
#
# No prior itertools spec checks groupby.__doc__.__contains__. New to extra62.
# ---------------------------------------------------------------------------

table itertools_extra62.groupby_doc_contains:
  description: "groupby.__doc__.__contains__ checks — docstring contains 'iterable' but NOT 'groupby'; wave 228 __doc__ content checks; new to extra62"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc62

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_doc_contains_iterable,
       groupby.__doc__.__contains__,
       ["iterable"],
       true,
       "itertools.groupby.__doc__.__contains__('iterable') == True — groupby is a C extension type (Modules/itertoolsmodule.c); its docstring begins 'make an iterator that returns consecutive keys and groups from the iterable'; the word 'iterable' appears on the very first line as the description of the input; __contains__ on a str returns True when the substring exists; no prior itertools spec checks groupby.__doc__.__contains__; new to extra62"]
    - [groupby_doc_not_contains_groupby,
       groupby.__doc__.__contains__,
       ["groupby"],
       false,
       "itertools.groupby.__doc__.__contains__('groupby') == False — groupby is a C extension type whose docstring reads 'make an iterator that returns consecutive keys and groups from the iterable'; the word 'groupby' (the type name) does NOT appear anywhere in the docstring — this is different from chain and count whose docstrings do self-reference by name; this False result distinguishes groupby from chain/count; __contains__ returns False when the substring is absent; no prior itertools spec checks groupby.__doc__.__contains__('groupby'); new to extra62"]
    - [groupby_doc_contains_iterator,
       groupby.__doc__.__contains__,
       ["iterator"],
       true,
       "itertools.groupby.__doc__.__contains__('iterator') == True — groupby.__doc__ begins 'make an iterator that returns consecutive keys...'; 'iterator' appears in this opening description; __contains__ returns True; new to extra62"]

# ---------------------------------------------------------------------------
# chain.__doc__.__contains__ and count.__doc__.__contains__ — extra62
#
# Wave 228 theme: __doc__ string content checks.
#
# itertools.chain is a C extension type. Its docstring:
#   'Return a chain object whose .__next__() method returns elements from the
#    first iterable until it is exhausted, then elements from the next
#    iterable, until all of the iterables are exhausted.'
#
# chain.__doc__.__contains__('chain') == True  ('chain object')
#
# itertools.count is a C extension type. Its docstring:
#   'Return a count object whose .__next__() method returns consecutive values.
#    Equivalent to: ...'
#
# count.__doc__.__contains__('count') == True  ('count object')
#
# No prior itertools spec checks chain.__doc__ or count.__doc__ content. New to extra62.
# ---------------------------------------------------------------------------

table itertools_extra62.chain_count_doc_contains:
  description: "chain.__doc__.__contains__('chain') and count.__doc__.__contains__('count') — docstrings self-reference by name; wave 228 __doc__ content checks; new to extra62"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc62

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_contains_chain,
       chain.__doc__.__contains__,
       ["chain"],
       true,
       "itertools.chain.__doc__.__contains__('chain') == True — chain is a C extension type (Modules/itertoolsmodule.c); its docstring begins 'Return a chain object whose .__next__() method returns elements from the\\nfirst iterable until it is exhausted...'; the word 'chain' appears in 'chain object' on the first line; __contains__ returns True; in contrast to groupby whose docstring does not mention 'groupby', chain's docstring does self-reference by name; no prior itertools spec checks chain.__doc__.__contains__; new to extra62"]
    - [count_doc_contains_count,
       count.__doc__.__contains__,
       ["count"],
       true,
       "itertools.count.__doc__.__contains__('count') == True — count is a C extension type (Modules/itertoolsmodule.c); its docstring begins 'Return a count object whose .__next__() method returns consecutive values.'; the word 'count' appears in 'count object' on the first line; __contains__ returns True; count's docstring self-references the type name, unlike groupby; no prior itertools spec checks count.__doc__.__contains__; new to extra62"]
    - [chain_doc_contains_iterable,
       chain.__doc__.__contains__,
       ["iterable"],
       true,
       "itertools.chain.__doc__.__contains__('iterable') == True — chain.__doc__ mentions 'first iterable' and 'the next iterable' and 'all of the iterables'; 'iterable' appears multiple times; __contains__ returns True at the first occurrence; new to extra62"]
    - [count_doc_contains_consecutive,
       count.__doc__.__contains__,
       ["consecutive"],
       true,
       "itertools.count.__doc__.__contains__('consecutive') == True — count.__doc__ reads 'Return a count object whose .__next__() method returns consecutive values.'; 'consecutive' appears describing the output values; __contains__ returns True; new to extra62"]

# ---------------------------------------------------------------------------
# itertools module __doc__ class name and __len__ — extra62
#
# Wave 228 theme: __doc__ string content checks + __annotations__ class identity.
#
# itertools is a C extension module. Its module-level __doc__ is a str of
# length 1386. The __doc__ covers all itertools types in a compact table.
#
# itertools.__doc__.__class__.__name__ == 'str'   (it is a str)
# len(itertools.__doc__) == 1386
# itertools.__doc__.__contains__('count') == True  (appears in module overview)
# itertools.__doc__.__contains__('itertools') == False  (module doesn't name itself)
#
# No prior itertools spec checks the module-level __doc__ content. New to extra62.
# ---------------------------------------------------------------------------

table itertools_extra62.module_doc_checks:
  description: "itertools.__doc__.__class__.__name__.__eq__('str') and __len__==1386 and __contains__ — module docstring is a str of known length; wave 228 __doc__ content; new to extra62"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc62

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_class_name_eq_str,
       __doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.__doc__.__class__.__name__.__eq__('str') == True — itertools is a C extension module (Modules/itertoolsmodule.c); its module-level __doc__ attribute is a Python str containing a compact overview of all itertools types; as a str object, __doc__.__class__ is the built-in str type and str.__name__ == 'str' (4 chars); no prior itertools spec checks the module-level __doc__.__class__.__name__; new to extra62"]
    - [module_doc_contains_count,
       __doc__.__contains__,
       ["count"],
       true,
       "itertools.__doc__.__contains__('count') == True — the itertools module docstring is a compact reference table listing all types including 'count(start=0, step=1) --> start, start+step, start+2*step, ...'; the word 'count' appears in this entry; __contains__ returns True; new to extra62"]
    - [module_doc_not_contains_itertools,
       __doc__.__contains__,
       ["itertools"],
       false,
       "itertools.__doc__.__contains__('itertools') == False — the itertools module docstring does not self-reference the module name 'itertools'; it reads 'Functional tools for creating and using iterators.' followed by the type listing table; the string 'itertools' does not appear anywhere in the 1386-character docstring; __contains__ returns False; this is notable: the module docstring is entirely self-contained and does not name the module; new to extra62"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra62
# ---------------------------------------------------------------------------

invariant itertools_extra62.groupby_doc_contains_iterable:
  description: "itertools.groupby.__doc__.__contains__('iterable') == True — groupby docstring mentions 'iterable' on the first line; wave 228 __doc__ content; new to extra62"
  kind: python_call_eq
  function: groupby.__doc__.__contains__
  args: ["iterable"]
  expected: true

invariant itertools_extra62.groupby_doc_not_contains_groupby:
  description: "itertools.groupby.__doc__.__contains__('groupby') == False — groupby docstring does NOT self-reference the type name; contrasts with chain and count; wave 228 __doc__ content; new to extra62"
  kind: python_call_eq
  function: groupby.__doc__.__contains__
  args: ["groupby"]
  expected: false

invariant itertools_extra62.chain_doc_contains_chain:
  description: "itertools.chain.__doc__.__contains__('chain') == True — chain docstring mentions 'chain object' on the first line; wave 228 __doc__ content; new to extra62"
  kind: python_call_eq
  function: chain.__doc__.__contains__
  args: ["chain"]
  expected: true
