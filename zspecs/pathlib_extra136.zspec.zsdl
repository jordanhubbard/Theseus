spec: pathlib_extra136
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.__all__ list identity and membership, and pathlib.PurePath property value types and lengths."
    - "pathlib.__all__.__class__.__name__ == 'list' — __all__ is a list."
    - "pathlib.__all__.__len__() == 7 — ['UnsupportedOperation', 'PurePath', 'PurePosixPath', 'PureWindowsPath', 'Path', 'PosixPath', 'WindowsPath']."
    - "pathlib.__all__.__contains__('UnsupportedOperation') == True — added to __all__ in Python 3.13+."
    - "pathlib.__all__.__contains__('Path') == True."
    - "pathlib.__all__.__contains__('PurePath') == True."
    - "pathlib.__all__.__contains__('PurePosixPath') == True."
    - "pathlib.__all__.__contains__('PureWindowsPath') == True."
    - "pathlib.__all__.__contains__('PosixPath') == True."
    - "pathlib.__all__.__contains__('WindowsPath') == True."
    - "PurePath('/usr/local/lib').parts is a tuple of length 4: ('/', 'usr', 'local', 'lib')."
    - "PurePath('/usr/local/lib').name == 'lib' (length 3)."
    - "PurePath('/usr/local/lib').stem == 'lib' (length 3, no suffix)."
    - "PurePath('/usr/local/lib').suffix == '' (length 0, no extension on a directory name)."
    - "PurePath('test.py').name == 'test.py' (length 7)."
    - "PurePath('test.py').stem == 'test' (length 4)."
    - "PurePath('test.py').suffix == '.py' (length 3)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.__all__ class name, length, and membership for all 7 entries
# __all__ == ['UnsupportedOperation', 'PurePath', 'PurePosixPath',
#             'PureWindowsPath', 'Path', 'PosixPath', 'WindowsPath']
# ---------------------------------------------------------------------------

table pathlib_extra136.module_all_identity:
  description: "pathlib.__all__ identity: class name ('list'), length (7), and membership for all 7 entries"
  kind: python_call_eq
  category: module_all
  id_prefix: pathlibmodall136

  columns: [id, function, args, expected]
  rows:
    - [all_cls_list,    __all__.__class__.__name__.__eq__, ["list"],                true]
    - [all_len_7,       __all__.__len__,                   [],                      7]
    - [has_purepath,    __all__.__contains__,              ["PurePath"],            true]
    - [has_path,        __all__.__contains__,              ["Path"],                true]
    - [has_unsupported, __all__.__contains__,              ["UnsupportedOperation"], true]
    - [has_posixpath,   __all__.__contains__,              ["PosixPath"],           true]
    - [has_winpath,     __all__.__contains__,              ["WindowsPath"],         true]
    - [not_purepath_lc, __all__.__contains__,              ["purepath"],            false]
    - [all_len_not_6,   __all__.__len__,                   [],                      7]

# ---------------------------------------------------------------------------
# pathlib.__all__ membership: Pure path variants
# PurePosixPath and PureWindowsPath are also in __all__.
# Not in __all__: 'pathlib', 'os', 'PurePath.name'.
# ---------------------------------------------------------------------------

table pathlib_extra136.module_all_pure_path_variants:
  description: "pathlib.__all__ contains PurePosixPath and PureWindowsPath; UnsupportedOperation is the 7th entry (index 0)"
  kind: python_call_eq
  category: module_all
  id_prefix: pathlibmodall136

  columns: [id, function, args, expected]
  rows:
    - [has_pureposix,   __all__.__contains__, ["PurePosixPath"],     true]
    - [has_purewin,     __all__.__contains__, ["PureWindowsPath"],   true]
    - [not_os,          __all__.__contains__, ["os"],                false]
    - [not_fnmatch,     __all__.__contains__, ["fnmatch"],           false]
    - [pureposix_len,   __all__.__contains__, ["PurePosixPath"],     true]
    - [all_len_7_xchk,  __all__.__len__,      [],                    7]

# ---------------------------------------------------------------------------
# pathlib.PurePath property values and types for '/usr/local/lib'
# parts: tuple of length 4; name: 'lib' (len 3); stem: 'lib' (len 3);
# suffix: '' (len 0, no extension).
# ---------------------------------------------------------------------------

table pathlib_extra136.PurePath_dir_properties:
  description: "pathlib.PurePath('/usr/local/lib') property types and values: parts is tuple (len 4), name='lib'(3), stem='lib'(3), suffix=''(0)"
  kind: python_call_eq
  category: path_properties
  id_prefix: pathlibmodall136

  columns: [id, function, args, expected]
  rows:
    - [parts_type,     "PurePath('/usr/local/lib').parts.__class__.__name__.__eq__", ["tuple"], true]
    - [parts_len,      "PurePath('/usr/local/lib').parts.__len__",                  [],         4]
    - [name_eq,        "PurePath('/usr/local/lib').name.__eq__",                    ["lib"],    true]
    - [name_len,       "PurePath('/usr/local/lib').name.__len__",                   [],         3]
    - [stem_eq,        "PurePath('/usr/local/lib').stem.__eq__",                    ["lib"],    true]
    - [suffix_eq,      "PurePath('/usr/local/lib').suffix.__eq__",                  [""],       true]
    - [suffix_len,     "PurePath('/usr/local/lib').suffix.__len__",                  [],        0]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra136.all.class_is_list:
  description: "pathlib.__all__.__class__.__name__ == 'list' (pathlib.__all__ is a Python list, not a tuple or frozenset)"
  category: module_all
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant pathlib_extra136.all.len_is_7:
  description: "pathlib.__all__.__len__() == 7 (pathlib exports exactly 7 public names: UnsupportedOperation, PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath)"
  category: module_all
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 7

invariant pathlib_extra136.all.has_UnsupportedOperation:
  description: "pathlib.__all__.__contains__('UnsupportedOperation') == True (UnsupportedOperation is raised when an unsupported operation is attempted on a path; it is the first entry in __all__)"
  category: module_all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["UnsupportedOperation"]
  expected: true

invariant pathlib_extra136.PurePath.dir_parts_len_4:
  description: "pathlib.PurePath('/usr/local/lib').parts.__len__() == 4 (the tuple ('/', 'usr', 'local', 'lib') has 4 elements)"
  category: path_properties
  kind: python_call_eq
  function: "PurePath('/usr/local/lib').parts.__len__"
  args: []
  expected: 4

invariant pathlib_extra136.PurePath.dir_suffix_is_empty:
  description: "pathlib.PurePath('/usr/local/lib').suffix == '' (a directory component with no dot has an empty suffix; suffix is the final component's last extension, or '' if none)"
  category: path_properties
  kind: python_call_eq
  function: "PurePath('/usr/local/lib').suffix.__eq__"
  args: [""]
  expected: true
