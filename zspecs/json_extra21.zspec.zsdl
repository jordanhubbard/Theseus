spec: json_extra21
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json.zspec.zsdl and prior extras through json_extra20.zspec.zsdl."
    - "json_extra20 covers: JSONEncoder/__bases__[0]/__qualname__; JSONDecoder/__bases__[0]/__qualname__; JSONDecodeError/__bases__[0]/__qualname__; encode/__module__ type axis; decode/__module__ type axis."
    - "json_extra19 covers: JSONEncoder.__init__/__qualname__; JSONDecoder.__init__/__qualname__; JSONEncoder.__init__/__module__; JSONDecoder.__init__/__module__."
    - "json_extra18 covers: encode/iterencode/default __module__ for JSONEncoder; decode/raw_decode __module__ for JSONDecoder."
    - "json_extra17 covers: encode/iterencode/default __qualname__ for JSONEncoder; decode/raw_decode __qualname__ for JSONDecoder."
    - "json_extra16 covers: JSONEncoder/__qualname__; JSONDecoder/__qualname__; JSONDecodeError/__qualname__."
    - "Focus: __qualname__ and __module__ for the four top-level json functions (loads, dumps, load, dump); JSONDecodeError.__init__.__qualname__ and __module__."
    - "No prior json spec checks loads.__qualname__."
    - "No prior json spec checks loads.__module__."
    - "No prior json spec checks dumps.__qualname__."
    - "No prior json spec checks dumps.__module__."
    - "No prior json spec checks load.__qualname__."
    - "No prior json spec checks load.__module__."
    - "No prior json spec checks dump.__qualname__."
    - "No prior json spec checks dump.__module__."
    - "No prior json spec checks JSONDecodeError.__init__.__qualname__."
    - "No prior json spec checks JSONDecodeError.__init__.__module__."
    - "json.loads.__qualname__ == 'loads' — top-level function qualname equals its bare name."
    - "json.loads.__module__ == 'json' — top-level functions live in the json package namespace."
    - "json.dumps.__qualname__ == 'dumps' — top-level function qualname equals its bare name."
    - "json.dumps.__module__ == 'json' — top-level functions live in the json package namespace."
    - "json.load.__qualname__ == 'load' — top-level function qualname equals its bare name."
    - "json.load.__module__ == 'json' — top-level functions live in the json package namespace."
    - "json.dump.__qualname__ == 'dump' — top-level function qualname equals its bare name."
    - "json.dump.__module__ == 'json' — top-level functions live in the json package namespace."
    - "json.JSONDecodeError.__init__.__qualname__ == 'JSONDecodeError.__init__' — compound dunder method qualname."
    - "json.JSONDecodeError.__init__.__module__ == 'json.decoder' — JSONDecodeError is defined in json/decoder.py."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Top-level function __qualname__ values
#
# json_extra17 checks __qualname__ for methods on JSONEncoder and JSONDecoder
# (encode, iterencode, default, decode, raw_decode).
# json_extra19 checks __qualname__ for JSONEncoder.__init__ and JSONDecoder.__init__.
# No prior json spec checks the __qualname__ of the four top-level functions:
# loads, dumps, load, dump.  For module-level functions the __qualname__ is
# always the bare function name (no dotted prefix).
# ---------------------------------------------------------------------------

invariant json_extra21.loads.qualname:
  description: "json.loads.__qualname__ == 'loads' — top-level function qualname is its bare name"
  category: function_attrs
  kind: python_call_eq
  function: loads.__qualname__.__eq__
  args: ["loads"]
  expected: true

invariant json_extra21.dumps.qualname:
  description: "json.dumps.__qualname__ == 'dumps' — top-level function qualname is its bare name"
  category: function_attrs
  kind: python_call_eq
  function: dumps.__qualname__.__eq__
  args: ["dumps"]
  expected: true

invariant json_extra21.load.qualname:
  description: "json.load.__qualname__ == 'load' — top-level function qualname is its bare name"
  category: function_attrs
  kind: python_call_eq
  function: load.__qualname__.__eq__
  args: ["load"]
  expected: true

invariant json_extra21.dump.qualname:
  description: "json.dump.__qualname__ == 'dump' — top-level function qualname is its bare name"
  category: function_attrs
  kind: python_call_eq
  function: dump.__qualname__.__eq__
  args: ["dump"]
  expected: true

# ---------------------------------------------------------------------------
# Top-level function __module__ values
#
# No prior json spec checks the __module__ of loads, dumps, load, or dump.
# All four are defined in json/__init__.py, so their __module__ is 'json'.
# ---------------------------------------------------------------------------

invariant json_extra21.loads.module:
  description: "json.loads.__module__ == 'json' — top-level function lives in the json package"
  category: function_attrs
  kind: python_call_eq
  function: loads.__module__.__eq__
  args: ["json"]
  expected: true

invariant json_extra21.dumps.module:
  description: "json.dumps.__module__ == 'json' — top-level function lives in the json package"
  category: function_attrs
  kind: python_call_eq
  function: dumps.__module__.__eq__
  args: ["json"]
  expected: true

invariant json_extra21.load.module:
  description: "json.load.__module__ == 'json' — top-level function lives in the json package"
  category: function_attrs
  kind: python_call_eq
  function: load.__module__.__eq__
  args: ["json"]
  expected: true

invariant json_extra21.dump.module:
  description: "json.dump.__module__ == 'json' — top-level function lives in the json package"
  category: function_attrs
  kind: python_call_eq
  function: dump.__module__.__eq__
  args: ["json"]
  expected: true

# ---------------------------------------------------------------------------
# JSONDecodeError.__init__ — __qualname__ and __module__
#
# json_extra19 checks __qualname__ and __module__ for JSONEncoder.__init__ and
# JSONDecoder.__init__.  No prior json spec checks these attributes for
# JSONDecodeError.__init__.  JSONDecodeError is defined in json/decoder.py, so
# its __init__.__module__ is 'json.decoder'.
# ---------------------------------------------------------------------------

invariant json_extra21.JSONDecodeError.__init__.qualname:
  description: "json.JSONDecodeError.__init__.__qualname__ == 'JSONDecodeError.__init__' — compound dunder method qualname"
  category: method_attrs
  kind: python_call_eq
  function: "JSONDecodeError.__init__.__qualname__.__eq__"
  args: ["JSONDecodeError.__init__"]
  expected: true

invariant json_extra21.JSONDecodeError.__init__.module:
  description: "json.JSONDecodeError.__init__.__module__ == 'json.decoder' — __init__ lives in json/decoder.py"
  category: method_attrs
  kind: python_call_eq
  function: "JSONDecodeError.__init__.__module__.__eq__"
  args: ["json.decoder"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all ten new invariants
#
# All ten are first covered in this spec (json_extra21).
# ---------------------------------------------------------------------------

table json_extra21.toplevel_func_attrs_and_decodeerror_init:
  description: "json top-level function __qualname__/__module__ and JSONDecodeError.__init__ attrs"
  kind: python_call_eq
  category: function_attrs
  id_prefix: jfa21

  columns: [id, function, args, expected]
  rows:
    - [loads_qn,             loads.__qualname__.__eq__,                      ["loads"],                   true]
    - [dumps_qn,             dumps.__qualname__.__eq__,                      ["dumps"],                   true]
    - [load_qn,              load.__qualname__.__eq__,                       ["load"],                    true]
    - [dump_qn,              dump.__qualname__.__eq__,                       ["dump"],                    true]
    - [loads_mod,            loads.__module__.__eq__,                        ["json"],                    true]
    - [dumps_mod,            dumps.__module__.__eq__,                        ["json"],                    true]
    - [load_mod,             load.__module__.__eq__,                         ["json"],                    true]
    - [dump_mod,             dump.__module__.__eq__,                         ["json"],                    true]
    - [decodeerr_init_qn,    "JSONDecodeError.__init__.__qualname__.__eq__", ["JSONDecodeError.__init__"], true]
    - [decodeerr_init_mod,   "JSONDecodeError.__init__.__module__.__eq__",   ["json.decoder"],             true]
