spec: inspect_extra1291
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra129.zspec.zsdl and prior extras."
    - "Wave 533 theme: __init__ and __new__ method presence and qualname checks for inspect classes."
    - "inspect.Parameter, inspect.Signature, inspect.BoundArguments are all Python classes defined in Lib/inspect.py."
    - "All three classes define __init__; none define __new__ (all inherit object.__new__)."
    - "inspect.Parameter.__init__.__qualname__ == 'Parameter.__init__' (len 18); __init__.__class__.__name__ == 'function'; '__init__' in Parameter.__dict__ == True. Verified with Python 3.12."
    - "inspect.Signature.__init__.__qualname__ == 'Signature.__init__' (len 18); __init__.__class__.__name__ == 'function'; '__init__' in Signature.__dict__ == True. Verified with Python 3.12."
    - "inspect.BoundArguments.__init__.__qualname__ == 'BoundArguments.__init__' (len 23); __init__.__class__.__name__ == 'function'; '__init__' in BoundArguments.__dict__ == True. Verified with Python 3.12."
    - "All three have __new__.__qualname__ == 'object.__new__' (len 14); __new__.__class__.__name__ == 'builtin_function_or_method'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter __init__ qualname, class name, and dict presence
#
# Wave 533 theme: inspect.Parameter is a Python class that defines __init__.
#
# Parameter.__init__.__qualname__ == 'Parameter.__init__' (len 18)
# Parameter.__init__.__class__.__name__ == 'function'
# '__init__' in Parameter.__dict__ == True
# Parameter.__new__.__qualname__ == 'object.__new__' (len 14)
# Parameter.__new__.__class__.__name__ == 'builtin_function_or_method'
#
# New to extra1291.
# ---------------------------------------------------------------------------

table inspect_extra1291.Parameter_init_new:
  description: "inspect.Parameter __init__.__qualname__=='Parameter.__init__'(18), class='function', in dict; __new__.__qualname__=='object.__new__'(14); Python class; wave 533; new to extra1291"
  kind: python_call_eq
  category: string_identity
  id_prefix: in1291pa

  columns: [id, function, args, expected, description]
  rows:
    - [in1291pa001,
       "Parameter.__init__.__qualname__.__eq__",
       ["Parameter.__init__"],
       true,
       "inspect.Parameter.__init__.__qualname__.__eq__('Parameter.__init__') == True — Parameter is a Python class defined in Lib/inspect.py that explicitly defines __init__; the method __qualname__ is 'Parameter.__init__' following the dotted class.method convention; str.__eq__('Parameter.__init__') returns True; new to extra1291"]
    - [in1291pa002,
       "Parameter.__init__.__qualname__.__len__",
       [],
       18,
       "inspect.Parameter.__init__.__qualname__.__len__() == 18 — 'Parameter.__init__' has 18 characters: 'Parameter' (9) + '.' (1) + '__init__' (8) = 18; same length as Signature.__init__.__qualname__; new to extra1291"]
    - [in1291pa003,
       "Parameter.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.Parameter.__init__.__class__.__name__.__eq__('function') == True — Parameter.__init__ is a Python function defined with def in Lib/inspect.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra1291"]
    - [in1291pa004,
       "Parameter.__dict__.__contains__",
       ["__init__"],
       true,
       "inspect.Parameter.__dict__.__contains__('__init__') == True — Parameter explicitly defines __init__ in its class body in Lib/inspect.py; dict.__contains__('__init__') returns True; new to extra1291"]
    - [in1291pa005,
       "Parameter.__new__.__qualname__.__eq__",
       ["object.__new__"],
       true,
       "inspect.Parameter.__new__.__qualname__.__eq__('object.__new__') == True — Parameter does not define __new__; it inherits object.__new__ whose __qualname__ is 'object.__new__'; str.__eq__('object.__new__') returns True; new to extra1291"]
    - [in1291pa006,
       "Parameter.__new__.__qualname__.__len__",
       [],
       14,
       "inspect.Parameter.__new__.__qualname__.__len__() == 14 — 'object.__new__' has 14 characters: 'object' (6) + '.' (1) + '__new__' (7) = 14; shorter than __init__.__qualname__ ('Parameter.__init__', len 18); new to extra1291"]
    - [in1291pa007,
       "Parameter.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "inspect.Parameter.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — object.__new__ is a builtin_function_or_method; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra1291"]

