spec: re_extra80
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra79."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; Pattern/Match method qualnames; re.error/__name__; re module-level function __code__ co_name and co_argcount; Pattern/Match method __qualname__ values and lengths; PatternError hierarchy; re.compile/__qualname__/__module__; re.match/sub/findall/split __qualname__; Match.start/end class name and qualname."
    - "This spec covers: re.match/__module__; re.search/__module__; re.sub/__module__; re.findall/__module__; re.split/__module__; re.fullmatch/__module__; re.purge/__module__; re.escape/__module__; Pattern.match/__doc__.__class__.__name__; Pattern.search/__doc__.__class__.__name__."
    - "re.match.__module__ == 're' — match is a Python function defined in the re package."
    - "re.search.__module__ == 're' — search is a Python function defined in the re package."
    - "re.sub.__module__ == 're' — sub is a Python function defined in the re package."
    - "re.findall.__module__ == 're' — findall is a Python function defined in the re package."
    - "re.split.__module__ == 're' — split is a Python function defined in the re package."
    - "re.fullmatch.__module__ == 're' — fullmatch is a Python function defined in the re package."
    - "re.purge.__module__ == 're' — purge is a Python function defined in the re package."
    - "re.escape.__module__ == 're' — escape is a Python function defined in the re package."
    - "re.Pattern.match.__doc__.__class__.__name__ == 'str' — the docstring of the C method_descriptor is a plain str."
    - "re.Pattern.search.__doc__.__class__.__name__ == 'str' — the docstring of the C method_descriptor is a plain str."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module function __module__ — group 1: match, search, sub, findall
# All are Python functions in the re package; __module__ == 're'.
# re.compile.__module__ was covered in re_extra79, so only new functions here.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra80.module_func_module_group1:
  description: "re.match, re.search, re.sub, re.findall __module__ == 're'"
  kind: python_call_eq
  category: func_identity
  id_prefix: remore80

  columns: [id, function, args, expected]
  rows:
    - [match_module,   match.__module__.__eq__,   ["re"], true]
    - [search_module,  search.__module__.__eq__,  ["re"], true]
    - [sub_module,     sub.__module__.__eq__,     ["re"], true]
    - [findall_module, findall.__module__.__eq__, ["re"], true]

# ---------------------------------------------------------------------------
# re module function __module__ — group 2: split, fullmatch, purge, escape
# All are Python functions in the re package; __module__ == 're'.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra80.module_func_module_group2:
  description: "re.split, re.fullmatch, re.purge, re.escape __module__ == 're'"
  kind: python_call_eq
  category: func_identity
  id_prefix: remore80

  columns: [id, function, args, expected]
  rows:
    - [split_module,    split.__module__.__eq__,    ["re"], true]
    - [fullmatch_module,fullmatch.__module__.__eq__,["re"], true]
    - [purge_module,    purge.__module__.__eq__,    ["re"], true]
    - [escape_module,   escape.__module__.__eq__,   ["re"], true]

# ---------------------------------------------------------------------------
# Pattern.match and Pattern.search __doc__.__class__.__name__
# These are C method_descriptors; their __doc__ is a plain Python str.
# __doc__.__class__.__name__ == 'str'.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra80.Pattern_method_doc_class:
  description: "Pattern.match and Pattern.search __doc__.__class__.__name__ == 'str'"
  kind: python_call_eq
  category: class_identity
  id_prefix: remore80

  columns: [id, function, args, expected]
  rows:
    - [pattern_match_doc_cls,  Pattern.match.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [pattern_search_doc_cls, Pattern.search.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# Combined module check: match + search + sub in a single table
# Reconfirms the module values via __eq__ chain.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra80.match_search_sub_module_check:
  description: "re.match, re.search, re.sub __module__ eq check"
  kind: python_call_eq
  category: func_identity
  id_prefix: remore80

  columns: [id, function, args, expected]
  rows:
    - [match_mod_check,  match.__module__.__eq__,  ["re"], true]
    - [search_mod_check, search.__module__.__eq__, ["re"], true]
    - [sub_mod_check,    sub.__module__.__eq__,    ["re"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra80.match.module:
  description: "re.match.__module__ == 're'"
  category: func_identity
  kind: python_call_eq
  function: match.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra80.search.module:
  description: "re.search.__module__ == 're'"
  category: func_identity
  kind: python_call_eq
  function: search.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra80.fullmatch.module:
  description: "re.fullmatch.__module__ == 're'"
  category: func_identity
  kind: python_call_eq
  function: fullmatch.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra80.purge.module:
  description: "re.purge.__module__ == 're'"
  category: func_identity
  kind: python_call_eq
  function: purge.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra80.Pattern_match_doc.class_name:
  description: "re.Pattern.match.__doc__.__class__.__name__ == 'str'"
  category: class_identity
  kind: python_call_eq
  function: Pattern.match.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
