spec: io_extra1876
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "io module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party io extensions"
  notes:
    - "Tests attribute access protocol membership in io types"
    - "io classes are mostly C types; __getattr__/__setattr__/__delattr__ are inherited from object, not defined in class __dict__"
    - "TextIOWrapper defines encoding, errors, line_buffering, write_through, buffer as properties in its __dict__"
  created_at: "2026-04-12"

table io_extra1876.attr_access_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["io1876-aa-001", "io.BytesIO.__dict__.__contains__", ["__getattr__"], false]
    - ["io1876-aa-002", "io.BytesIO.__dict__.__contains__", ["__setattr__"], false]
    - ["io1876-aa-003", "io.BytesIO.__dict__.__contains__", ["__delattr__"], false]
    - ["io1876-aa-004", "io.StringIO.__dict__.__contains__", ["__getattr__"], false]
    - ["io1876-aa-005", "io.FileIO.__dict__.__contains__", ["__getattr__"], false]
    - ["io1876-aa-006", "io.IOBase.__dict__.__contains__", ["__getattr__"], false]
    - ["io1876-aa-007", "io.TextIOWrapper.__dict__.__contains__", ["__getattr__"], false]
    - ["io1876-aa-008", "io.IOBase.__dict__.__contains__", ["__getattribute__"], false]

table io_extra1876.introspection_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["io1876-ip-001", "io.BytesIO.__dict__.__contains__", ["__dir__"], false]
    - ["io1876-ip-002", "io.BytesIO.__dict__.__contains__", ["__sizeof__"], false]
    - ["io1876-ip-003", "io.StringIO.__dict__.__contains__", ["__dir__"], false]
    - ["io1876-ip-004", "io.FileIO.__dict__.__contains__", ["__dir__"], false]
    - ["io1876-ip-005", "io.IOBase.__dict__.__contains__", ["__dir__"], false]
    - ["io1876-ip-006", "io.TextIOWrapper.__dict__.__contains__", ["__dir__"], false]
    - ["io1876-ip-007", "io.BytesIO.__dict__.__contains__", ["__slots__"], false]
    - ["io1876-ip-008", "io.StringIO.__dict__.__contains__", ["__slots__"], false]

table io_extra1876.textio_wrapper_attrs:
