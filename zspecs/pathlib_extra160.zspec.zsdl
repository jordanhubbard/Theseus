spec: pathlib_extra160
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path class method __qualname__ values for filesystem-mutating methods: stat, chmod, rename, replace, unlink, rmdir, symlink_to, touch, write_text."
    - "All Path method qualnames follow the 'Path.<method>' pattern (no underscore prefix, unlike io ABCs). pathlib is implemented in pure Python so method qualnames directly use the class name 'Path'."
    - "Qualname lengths: Path.stat (9), Path.chmod (10), Path.touch (10), Path.rmdir (10), Path.unlink (11), Path.rename (11), Path.write_text (15), Path.symlink_to (14)."
    - "Path.stat.__qualname__ == 'Path.stat' (len=9; 'Path.' (5) + 'stat' (4) = 9). Path.chmod.__qualname__ == 'Path.chmod' (len=10). Path.rename.__qualname__ == 'Path.rename' (len=11). Path.unlink.__qualname__ == 'Path.unlink' (len=11). Path.rmdir.__qualname__ == 'Path.rmdir' (len=10). Path.symlink_to.__qualname__ == 'Path.symlink_to' (len=15... wait: 'Path.' (5) + 'symlink_to' (10) = 15). Path.touch.__qualname__ == 'Path.touch' (len=10). Path.write_text.__qualname__ == 'Path.write_text' (len=15)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path filesystem-mutating method __qualname__ values (group 1)
# stat, chmod, unlink, rmdir, touch
# 'Path.' prefix = 5 chars.
# stat = 9, chmod = 10, touch = 10, rmdir = 10, unlink = 11
# ---------------------------------------------------------------------------

table pathlib_extra160.Path_mutating_qualnames_short:
  description: "pathlib.Path filesystem method __qualname__ values: stat=9, chmod/touch/rmdir=10, unlink=11; all 'Path.<method>' pure-Python qualnames (no underscore prefix, unlike io ABCs)"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibmut160

  columns: [id, function, args, expected, description]
  rows:
    - [stat_qeq,   Path.stat.__qualname__.__eq__,   ["Path.stat"],   true, "pathlib.Path.stat.__qualname__ == 'Path.stat' (len=9; 'Path.' (5) + 'stat' (4) = 9; stat() returns an os.stat_result for the path; follows symlinks by default; use stat(follow_symlinks=False) or lstat() for symlink itself; tied with Path.glob (9) as one of the shortest Path method qualnames)"]
    - [stat_qlen,  Path.stat.__qualname__.__len__,  [],              9,    "pathlib.Path.stat.__qualname__.__len__() == 9 ('Path.stat' has 9 characters; 'Path.' (5) + 'stat' (4) = 9; tied with Path.glob and Path.home at 9; stat is one of the most important Path methods for querying file metadata)"]
    - [chmod_qeq,  Path.chmod.__qualname__.__eq__,  ["Path.chmod"],  true, "pathlib.Path.chmod.__qualname__ == 'Path.chmod' (len=10; 'Path.' (5) + 'chmod' (5) = 10; chmod() changes the file mode and permissions; accepts an integer mode (e.g., 0o644) or a stat.S_* combination; tied with Path.mkdir, Path.touch, Path.rmdir at qualname length 10)"]
    - [touch_qeq,  Path.touch.__qualname__.__eq__,  ["Path.touch"],  true, "pathlib.Path.touch.__qualname__ == 'Path.touch' (len=10; 'Path.' (5) + 'touch' (5) = 10; touch() creates the file if it does not exist or updates the access and modification timestamps if it does; analogous to the Unix touch command; mode parameter defaults to 0o666 before umask)"]
    - [rmdir_qeq,  Path.rmdir.__qualname__.__eq__,  ["Path.rmdir"],  true, "pathlib.Path.rmdir.__qualname__ == 'Path.rmdir' (len=10; 'Path.' (5) + 'rmdir' (5) = 10; rmdir() removes this directory — it must be empty; raises OSError if not empty; for recursive deletion use shutil.rmtree(); tied with chmod and touch at qualname length 10)"]
    - [unlink_qeq, Path.unlink.__qualname__.__eq__,  ["Path.unlink"], true, "pathlib.Path.unlink.__qualname__ == 'Path.unlink' (len=11; 'Path.' (5) + 'unlink' (6) = 11; unlink() removes the file or symbolic link; use missing_ok=True to suppress FileNotFoundError when the file does not exist; tied with Path.rename and Path.exists at qualname length 11)"]
    - [rename_qeq, Path.rename.__qualname__.__eq__,  ["Path.rename"], true, "pathlib.Path.rename.__qualname__ == 'Path.rename' (len=11; 'Path.' (5) + 'rename' (6) = 11; rename() renames the file to target — on Unix, if target exists it is silently replaced if it is a file; returns a new Path instance pointing to the target; tied with Path.unlink at 11)"]

# ---------------------------------------------------------------------------
# pathlib.Path filesystem method __qualname__ values (group 2)
# write_text, symlink_to — longer method names
# write_text = 15, symlink_to = 15
# ---------------------------------------------------------------------------

table pathlib_extra160.Path_mutating_qualnames_long:
  description: "pathlib.Path longer method __qualname__ values: write_text=15, symlink_to=15; both 'Path.' (5) + 10-char method name = 15"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibmut160

  columns: [id, function, args, expected, description]
  rows:
    - [write_text_qeq,  Path.write_text.__qualname__.__eq__,  ["Path.write_text"],  true, "pathlib.Path.write_text.__qualname__ == 'Path.write_text' (len=15; 'Path.' (5) + 'write_text' (10) = 15; write_text() opens the file, writes the given text string (using encoding and errors arguments), and closes the file; a convenience wrapper over Path.open().write(); atomic alternative to open()/write())"]
    - [write_text_qlen, Path.write_text.__qualname__.__len__, [],                   15,   "pathlib.Path.write_text.__qualname__.__len__() == 15 ('Path.write_text' has 15 characters; 'Path.' (5) + 'write_text' (10) = 15; tied with Path.symlink_to (15) as one of the longer Path method qualnames; contrast with Path.stat (9) or Path.glob (9) at the short end)"]
    - [symlink_to_qeq,  Path.symlink_to.__qualname__.__eq__,  ["Path.symlink_to"],  true, "pathlib.Path.symlink_to.__qualname__ == 'Path.symlink_to' (len=15; 'Path.' (5) + 'symlink_to' (10) = 15; symlink_to() makes this path a symbolic link pointing to target; the target_is_directory parameter is used on Windows to indicate whether target is a directory symlink; tied with Path.write_text at 15)"]
    - [symlink_to_qlen, Path.symlink_to.__qualname__.__len__,[],                    15,   "pathlib.Path.symlink_to.__qualname__.__len__() == 15 ('Path.symlink_to' has 15 characters; 'Path.' (5) + 'symlink_to' (10) = 15; 'symlink_to' has 10 characters — the longest method name among the filesystem-mutating methods covered here; tied with write_text at 15)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra160.Path_stat_qualname_eq:
  description: "pathlib.Path.stat.__qualname__ == 'Path.stat' — stat() returns file system metadata for the path as an os.stat_result; its qualname is the shortest among the filesystem-mutating methods covered here (len=9, 'Path.' (5) + 'stat' (4) = 9); unlike io ABC methods that use private C type names in qualnames (e.g. '_IOBase.close'), pathlib methods use the clean public class name 'Path' because pathlib is pure Python"
  category: qualname
  kind: python_call_eq
  function: Path.stat.__qualname__.__eq__
  args: ["Path.stat"]
  expected: true

invariant pathlib_extra160.Path_unlink_qualname_eq:
  description: "pathlib.Path.unlink.__qualname__ == 'Path.unlink' — unlink() removes a file or symlink and has qualname length 11 ('Path.' (5) + 'unlink' (6) = 11); it accepts a missing_ok=True keyword argument (added in Python 3.8) to suppress FileNotFoundError; unlink() does NOT work on directories — use Path.rmdir() for empty directories or shutil.rmtree() for recursive removal"
  category: qualname
  kind: python_call_eq
  function: Path.unlink.__qualname__.__eq__
  args: ["Path.unlink"]
  expected: true

invariant pathlib_extra160.Path_write_text_qualname_len_15:
  description: "pathlib.Path.write_text.__qualname__.__len__() == 15 — 'Path.write_text' has 15 characters ('Path.' (5) + 'write_text' (10) = 15); write_text() is a convenience method that opens the path, writes a text string, and closes it; the 10-character method name 'write_text' makes it one of the longest Path method qualnames, tied with Path.symlink_to (15) and longer than Path.iterdir (12)"
  category: qualname
  kind: python_call_eq
  function: Path.write_text.__qualname__.__len__
  args: []
  expected: 15

invariant pathlib_extra160.Path_chmod_qualname_eq:
  description: "pathlib.Path.chmod.__qualname__ == 'Path.chmod' — chmod() changes the file mode and permissions; its qualname length is 10 ('Path.' (5) + 'chmod' (5) = 10); tied with Path.mkdir (10), Path.touch (10), and Path.rmdir (10); chmod() can follow symlinks (default) or operate on the symlink itself via follow_symlinks=False (equivalent to lchmod)"
  category: qualname
  kind: python_call_eq
  function: Path.chmod.__qualname__.__eq__
  args: ["Path.chmod"]
  expected: true

invariant pathlib_extra160.Path_rename_qualname_eq:
  description: "pathlib.Path.rename.__qualname__ == 'Path.rename' — rename() renames/moves the path to a target and returns a new Path pointing at target; its qualname length is 11 ('Path.' (5) + 'rename' (6) = 11); rename() differs from replace() in that on Windows, rename() raises FileExistsError if target exists, while replace() always replaces the target atomically"
  category: qualname
  kind: python_call_eq
  function: Path.rename.__qualname__.__eq__
  args: ["Path.rename"]
  expected: true
