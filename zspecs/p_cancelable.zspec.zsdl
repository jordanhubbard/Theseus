spec: p_cancelable
version: ">=4.0.0"
backend: node(p-cancelable)
esm: true

docs: https://github.com/sindresorhus/p-cancelable#readme

provenance:
  derived_from:
    - "p-cancelable README — https://github.com/sindresorhus/p-cancelable#readme"
    - "Test vectors verified with p-cancelable via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "p-cancelable source"
  notes:
    - "Promise subclass that supports cancellation via .cancel() — used by got and others."
    - "Install: npm install p-cancelable"
    - "v4 ESM only; default export IS the PCancelable class."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Cancellation rejects the promise unless the user opts to silence via shouldReject:false."
  stderr: "null"
  stickiness: "Each instance carries its own cancel state; cancel() is idempotent."
  codes: {}

invariant p_cancelable.default_export_is_class:
