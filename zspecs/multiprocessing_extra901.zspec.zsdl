spec: multiprocessing_extra901
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing primitives __module__ identity for Process, Queue, Pool, Pipe, Value, Array"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra901.process_module:
  description: "multiprocessing.Process __module__ identity"
  kind: python_call_eq
  category: process_module
  id_prefix: mp901pm
  columns: [id, function, args, expected]
  rows:
    - [mp901pm001, multiprocessing.Process.__module__.__eq__,            ["multiprocessing.process"], true]
    - [mp901pm002, multiprocessing.Process.__name__.__eq__,              ["Process"],                 true]
    - [mp901pm003, multiprocessing.Process.__qualname__.__eq__,          ["Process"],                 true]
    - [mp901pm004, multiprocessing.Process.__class__.__name__.__eq__,    ["type"],                    true]
    - [mp901pm005, multiprocessing.Process.start.__qualname__.__eq__,    ["Process.start"],           true]
    - [mp901pm006, multiprocessing.Process.run.__qualname__.__eq__,      ["Process.run"],             true]

table multiprocessing_extra901.queue_pool_pipe_modules:
  description: "multiprocessing.Queue, Pool, and Pipe __module__ identity"
  kind: python_call_eq
  category: queue_pool_pipe_modules
  id_prefix: mp901qp
  columns: [id, function, args, expected]
  rows:
    - [mp901qp001, multiprocessing.Queue.__module__.__eq__,              ["multiprocessing.queues"], true]
    - [mp901qp002, multiprocessing.Pool.__module__.__eq__,               ["multiprocessing.pool"],   true]
    - [mp901qp003, multiprocessing.Pipe.__module__.__eq__,               ["multiprocessing.connection"], true]
    - [mp901qp004, multiprocessing.Queue.__name__.__eq__,                ["Queue"],                  true]
    - [mp901qp005, multiprocessing.Pool.__name__.__eq__,                 ["Pool"],                   true]
    - [mp901qp006, multiprocessing.Pipe.__name__.__eq__,                 ["Pipe"],                   true]
    - [mp901qp007, multiprocessing.Queue.__qualname__.__eq__,            ["Queue"],                  true]

table multiprocessing_extra901.value_array_modules:
  description: "multiprocessing.Value and multiprocessing.Array __module__ identity"
  kind: python_call_eq
  category: value_array_modules
  id_prefix: mp901va
  columns: [id, function, args, expected]
  rows:
    - [mp901va001, multiprocessing.Value.__module__.__eq__,              ["multiprocessing.sharedctypes"], true]
    - [mp901va002, multiprocessing.Array.__module__.__eq__,              ["multiprocessing.sharedctypes"], true]
    - [mp901va003, multiprocessing.Value.__name__.__eq__,                ["Value"],                   true]
    - [mp901va004, multiprocessing.Array.__name__.__eq__,                ["Array"],                   true]
    - [mp901va005, multiprocessing.Value.__qualname__.__eq__,            ["Value"],                   true]
    - [mp901va006, multiprocessing.Array.__qualname__.__eq__,            ["Array"],                   true]
    - [mp901va007, multiprocessing.Pool.__qualname__.__eq__,             ["Pool"],                    true]
