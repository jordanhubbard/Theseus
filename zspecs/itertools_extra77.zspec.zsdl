spec: itertools_extra77
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra76.zspec.zsdl."
    - "This spec covers: itertools C type __doc__ for groupby/starmap/repeat/count (Wave 243)."
    - "groupby.__doc__.__class__.__name__ == 'str' — groupby is a C type with a string docstring. Verified with Python 3.14.3."
    - "groupby.__doc__.__contains__('iterable') == True — groupby docstring mentions 'iterable'. Verified with Python 3.14.3."
    - "starmap.__doc__.__class__.__name__ == 'str' — starmap is a C type with a string docstring. Verified with Python 3.14.3."
    - "starmap.__doc__.__contains__('function') == True — starmap docstring mentions 'function'. Verified with Python 3.14.3."
    - "repeat.__doc__.__class__.__name__ == 'str' — repeat is a C type with a string docstring. Verified with Python 3.14.3."
    - "repeat.__doc__.__contains__('repeat') == True — repeat docstring contains the word 'repeat'. Verified with Python 3.14.3."
    - "count.__doc__.__class__.__name__ == 'str' — count is a C type with a string docstring. Verified with Python 3.14.3."
    - "count.__doc__.__contains__('count') == True — count docstring contains the word 'count'. Verified with Python 3.14.3."
    - "zip_longest.__doc__.__contains__('fillvalue') == True — zip_longest docstring mentions 'fillvalue'. Verified with Python 3.14.3."
    - "filterfalse.__doc__.__contains__('function') == True — filterfalse docstring mentions 'function'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# groupby __doc__ class and content — extra77
#
# Wave 243 theme: groupby/starmap/repeat/count C type __doc__ strings.
#
# itertools.groupby.__doc__.__class__.__name__      == 'str'
# itertools.groupby.__doc__.__contains__('iterable') == True
#
# No prior itertools spec checks groupby.__doc__ attrs via itertmore77. New to extra77.
# ---------------------------------------------------------------------------

table itertools_extra77.groupby_doc:
  description: "groupby.__doc__.__class__.__name__=='str', __contains__('iterable')==True; wave 243 groupby __doc__ content; new to extra77"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertmore77

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_doc_class_name_eq_str,
       groupby.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.groupby.__doc__.__class__.__name__.__eq__('str') == True — groupby is a C extension type defined in Modules/itertoolsmodule.c; its __doc__ attribute is a Python str object containing the C-written docstring; __doc__.__class__.__name__ == 'str' (3 chars); str.__eq__('str') returns True; no prior itertools spec checks groupby.__doc__.__class__.__name__ via itertmore77; new to extra77"]
    - [groupby_doc_contains_iterable,
       groupby.__doc__.__contains__,
       ["iterable"],
       true,
       "itertools.groupby.__doc__.__contains__('iterable') == True — groupby's C-written docstring describes the 'iterable' parameter and mentions the word 'iterable' multiple times; str.__contains__('iterable') returns True; no prior itertools spec checks groupby.__doc__.__contains__('iterable') via itertmore77; new to extra77"]

# ---------------------------------------------------------------------------
# starmap and repeat __doc__ content — extra77
#
# Wave 243 theme: starmap/repeat C type __doc__ strings.
#
# itertools.starmap.__doc__.__class__.__name__       == 'str'
# itertools.starmap.__doc__.__contains__('function') == True
# itertools.repeat.__doc__.__class__.__name__        == 'str'
# itertools.repeat.__doc__.__contains__('repeat')    == True
#
# No prior itertools spec checks starmap/repeat __doc__ attrs via itertmore77. New to extra77.
# ---------------------------------------------------------------------------

table itertools_extra77.starmap_repeat_doc:
  description: "starmap.__doc__.__class__.__name__=='str', __contains__('function')==True; repeat same with 'repeat'; wave 243 starmap/repeat __doc__ content; new to extra77"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertmore77

  columns: [id, function, args, expected, description]
  rows:
    - [starmap_doc_class_name_eq_str,
       starmap.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.starmap.__doc__.__class__.__name__.__eq__('str') == True — starmap is a C extension type defined in Modules/itertoolsmodule.c; its __doc__ attribute is a Python str object; __doc__.__class__.__name__ == 'str' (3 chars); str.__eq__('str') returns True; no prior itertools spec checks starmap.__doc__.__class__.__name__ via itertmore77; new to extra77"]
    - [starmap_doc_contains_function,
       starmap.__doc__.__contains__,
       ["function"],
       true,
       "itertools.starmap.__doc__.__contains__('function') == True — starmap's C-written docstring describes it as returning an iterator whose values are returned from the function evaluated with argument tuples; the word 'function' appears in the docstring; str.__contains__('function') returns True; no prior itertools spec checks starmap.__doc__.__contains__('function') via itertmore77; new to extra77"]
    - [repeat_doc_class_name_eq_str,
       repeat.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.repeat.__doc__.__class__.__name__.__eq__('str') == True — repeat is a C extension type defined in Modules/itertoolsmodule.c; its __doc__ attribute is a Python str object; __doc__.__class__.__name__ == 'str' (3 chars); str.__eq__('str') returns True; no prior itertools spec checks repeat.__doc__.__class__.__name__ via itertmore77; new to extra77"]
    - [repeat_doc_contains_repeat,
       repeat.__doc__.__contains__,
       ["repeat"],
       true,
       "itertools.repeat.__doc__.__contains__('repeat') == True — repeat's C-written docstring starts with 'repeat(object [,times])' so the word 'repeat' appears at the very beginning of the docstring; str.__contains__('repeat') returns True; no prior itertools spec checks repeat.__doc__.__contains__('repeat') via itertmore77; new to extra77"]

# ---------------------------------------------------------------------------
# count __doc__ content — extra77
#
# Wave 243 theme: count C type __doc__ string.
#
# itertools.count.__doc__.__class__.__name__    == 'str'
# itertools.count.__doc__.__contains__('count') == True
#
# No prior itertools spec checks count __doc__ attrs via itertmore77. New to extra77.
# ---------------------------------------------------------------------------

table itertools_extra77.count_doc:
  description: "count.__doc__.__class__.__name__=='str', __contains__('count')==True; wave 243 count __doc__ content; new to extra77"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertmore77

  columns: [id, function, args, expected, description]
  rows:
    - [count_doc_class_name_eq_str,
       count.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.count.__doc__.__class__.__name__.__eq__('str') == True — count is a C extension type defined in Modules/itertoolsmodule.c; its __doc__ attribute is a Python str object containing the C-written docstring; __doc__.__class__.__name__ == 'str' (3 chars); str.__eq__('str') returns True; no prior itertools spec checks count.__doc__.__class__.__name__ via itertmore77; new to extra77"]
    - [count_doc_contains_count,
       count.__doc__.__contains__,
       ["count"],
       true,
       "itertools.count.__doc__.__contains__('count') == True — count's C-written docstring begins 'Return a count object whose .__next__() method returns consecutive values'; the word 'count' appears in that description; str.__contains__('count') returns True; no prior itertools spec checks count.__doc__.__contains__('count') via itertmore77; new to extra77"]

# ---------------------------------------------------------------------------
# zip_longest and filterfalse __doc__ content — extra77
#
# Wave 243 theme: zip_longest/filterfalse C type __doc__ strings.
#
# itertools.zip_longest.__doc__.__contains__('fillvalue') == True
# itertools.filterfalse.__doc__.__contains__('function') == True
#
# No prior itertools spec checks zip_longest/filterfalse __doc__ contains via itertmore77. New to extra77.
# ---------------------------------------------------------------------------

table itertools_extra77.zip_longest_filterfalse_doc:
  description: "zip_longest.__doc__.__contains__('fillvalue')==True, filterfalse.__doc__.__contains__('function')==True; wave 243 zip_longest/filterfalse __doc__ content; new to extra77"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertmore77

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_doc_contains_fillvalue,
       zip_longest.__doc__.__contains__,
       ["fillvalue"],
       true,
       "itertools.zip_longest.__doc__.__contains__('fillvalue') == True — zip_longest's C-written docstring describes the fillvalue parameter that is used to pad shorter iterables; the word 'fillvalue' appears in the docstring; str.__contains__('fillvalue') returns True; no prior itertools spec checks zip_longest.__doc__.__contains__('fillvalue') via itertmore77; new to extra77"]
    - [filterfalse_doc_contains_function,
       filterfalse.__doc__.__contains__,
       ["function"],
       true,
       "itertools.filterfalse.__doc__.__contains__('function') == True — filterfalse's C-written docstring reads 'Return those items of iterable for which function(item) is false'; the word 'function' appears in the docstring; str.__contains__('function') returns True; no prior itertools spec checks filterfalse.__doc__.__contains__('function') via itertmore77; new to extra77"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra77
# ---------------------------------------------------------------------------

invariant itertools_extra77.groupby_doc_class_name:
  description: "itertools.groupby.__doc__.__class__.__name__.__eq__('str') == True — groupby C type __doc__ is a str; wave 243 groupby __doc__ content; new to extra77"
  kind: python_call_eq
  function: groupby.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra77.groupby_doc_contains_iterable:
  description: "itertools.groupby.__doc__.__contains__('iterable') == True — groupby docstring mentions iterable; wave 243 groupby __doc__ content; new to extra77"
  kind: python_call_eq
  function: groupby.__doc__.__contains__
  args: ["iterable"]
  expected: true

invariant itertools_extra77.repeat_doc_contains_repeat:
  description: "itertools.repeat.__doc__.__contains__('repeat') == True — repeat docstring contains the word 'repeat'; wave 243 repeat __doc__ content; new to extra77"
  kind: python_call_eq
  function: repeat.__doc__.__contains__
  args: ["repeat"]
  expected: true

invariant itertools_extra77.count_doc_contains_count:
  description: "itertools.count.__doc__.__contains__('count') == True — count docstring contains the word 'count'; wave 243 count __doc__ content; new to extra77"
  kind: python_call_eq
  function: count.__doc__.__contains__
  args: ["count"]
  expected: true

invariant itertools_extra77.zip_longest_doc_contains_fillvalue:
  description: "itertools.zip_longest.__doc__.__contains__('fillvalue') == True — zip_longest docstring mentions fillvalue; wave 243 zip_longest __doc__ content; new to extra77"
  kind: python_call_eq
  function: zip_longest.__doc__.__contains__
  args: ["fillvalue"]
  expected: true
