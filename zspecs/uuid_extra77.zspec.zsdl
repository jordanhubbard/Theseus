spec: uuid_extra77
version: ">=3.9"
extends: uuid_extra76
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra76.zspec.zsdl — covers UUID/__init__/__str__/__repr__/__eq__/__hash__/__lt__/__setattr__/__class__/__name__=='function' / UUID.int/__class__.__name__=='member_descriptor' / UUID.hex/__class__.__name__=='property' / UUID/__init__/__str__/__eq__/__hash__/__qualname__/__eq__ (table + invariants)."
    - "uuid_extra75.zspec.zsdl — covers SafeUUID enum members __class__.__name__/'SafeUUID' / SafeUUID class __name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__() (table + invariants)."
    - "uuid_extra74.zspec.zsdl — covers UUID property descriptor __qualname__ identity and UUID.int member_descriptor __qualname__ (table + invariants)."
    - "uuid_extra73.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 qualname lengths / UUID.__dict__ special method membership / UUID.__dict__ property membership (table + invariants)."
    - "uuid_extra72.zspec.zsdl — covers NAMESPACE_DNS/URL/OID/X500 __class__/__name__/__module__/__qualname__ / UUID/__name__/__module__/__qualname__/__bases__[0].__name__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra76; it does NOT duplicate invariants present in those files."
    - "Wave 251 theme: uuid uuid1/uuid3/uuid4/uuid5 __qualname__ and __name__ string equality / UUID dunder method __qualname__.__len__() for __init__/__str__/__eq__/__hash__/__repr__/__setattr__."
    - "uuid.uuid1.__qualname__.__eq__('uuid1') == True — uuid1 is a module-level function; its __qualname__ is just 'uuid1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__qualname__.__eq__('uuid4') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__qualname__.__eq__('uuid3') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__qualname__.__eq__('uuid5') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__name__.__eq__('uuid1') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__name__.__eq__('uuid4') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__name__.__eq__('uuid3') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__name__.__eq__('uuid5') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__qualname__.__len__() == 13 — 'UUID.__init__' is 13 chars. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__qualname__.__len__() == 12 — 'UUID.__str__' is 12 chars. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__qualname__.__len__() == 11 — 'UUID.__eq__' is 11 chars. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__qualname__.__len__() == 13 — 'UUID.__hash__' is 13 chars. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__qualname__.__len__() == 13 — 'UUID.__repr__' is 13 chars. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__qualname__.__len__() == 16 — 'UUID.__setattr__' is 16 chars. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid1/__qualname__/__eq__('uuid1') / uuid4/__qualname__/__eq__('uuid4')
# uuid.uuid3/__qualname__/__eq__('uuid3') / uuid5/__qualname__/__eq__('uuid5')
#
# Wave 251 theme: uuid module-level function __qualname__ string equality.
#
# uuid1, uuid3, uuid4, uuid5 are all module-level functions with simple __qualname__.
# uuid_extra73 covers __qualname__.__len__() for these functions.
# No prior uuid spec checks __qualname__.__eq__ for uuid1/uuid3/uuid4/uuid5.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra77.uuid_func_qualname_eq:
  description: "uuid.uuid1/__qualname__/__eq__('uuid1')==True / uuid4/__qualname__/__eq__('uuid4')==True / uuid3/__qualname__/__eq__('uuid3')==True / uuid5/__qualname__/__eq__('uuid5')==True — uuid1/uuid3/uuid4/uuid5 are top-level functions with unqualified __qualname__ (no class prefix); uuid_extra73 anchors __qualname__.__len__(); this table anchors __qualname__.__eq__(); first __qualname__.__eq__ anchor for uuid.uuid1/uuid3/uuid4/uuid5"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra77

  columns: [id, function, args, expected]
  rows:
    - [uuid1_qualname_eq, uuid1.__qualname__.__eq__, ["uuid1"], true]
    - [uuid4_qualname_eq, uuid4.__qualname__.__eq__, ["uuid4"], true]
    - [uuid3_qualname_eq, uuid3.__qualname__.__eq__, ["uuid3"], true]
    - [uuid5_qualname_eq, uuid5.__qualname__.__eq__, ["uuid5"], true]

# ---------------------------------------------------------------------------
# uuid.uuid1/__name__/__eq__('uuid1') / uuid4/__name__/__eq__('uuid4')
# uuid.uuid3/__name__/__eq__('uuid3') / uuid5/__name__/__eq__('uuid5')
#
# Wave 251 theme: uuid module-level function __name__ string equality.
#
# uuid1, uuid3, uuid4, uuid5 __name__ equals their simple function name.
# No prior uuid spec checks __name__.__eq__ for uuid1/uuid3/uuid4/uuid5.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra77.uuid_func_name_eq:
  description: "uuid.uuid1/__name__/__eq__('uuid1')==True / uuid4/__name__/__eq__('uuid4')==True / uuid3/__name__/__eq__('uuid3')==True / uuid5/__name__/__eq__('uuid5')==True — __name__ for module-level functions equals the bare function name; no prior uuid spec checks __name__.__eq__ for uuid1/uuid3/uuid4/uuid5; first __name__.__eq__ anchor for uuid.uuid1/uuid3/uuid4/uuid5"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra77

  columns: [id, function, args, expected]
  rows:
    - [uuid1_name_eq, uuid1.__name__.__eq__, ["uuid1"], true]
    - [uuid4_name_eq, uuid4.__name__.__eq__, ["uuid4"], true]
    - [uuid3_name_eq, uuid3.__name__.__eq__, ["uuid3"], true]
    - [uuid5_name_eq, uuid5.__name__.__eq__, ["uuid5"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__/__qualname__/__len__() / UUID.__str__/__qualname__/__len__()
# uuid.UUID.__eq__/__qualname__/__len__() / UUID.__hash__/__qualname__/__len__()
#
# Wave 251 theme: UUID dunder method __qualname__ string lengths (group 1).
#
# UUID.__init__.__qualname__ == 'UUID.__init__' (len 13).
# UUID.__str__.__qualname__ == 'UUID.__str__' (len 12).
# UUID.__eq__.__qualname__ == 'UUID.__eq__' (len 11).
# UUID.__hash__.__qualname__ == 'UUID.__hash__' (len 13).
# uuid_extra76 anchors __qualname__.__eq__() for __init__/__str__/__eq__/__hash__.
# No prior uuid spec checks __qualname__.__len__() for UUID.__init__/__str__/__eq__/__hash__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra77.uuid_dunder_qualname_lengths_group1:
  description: "uuid.UUID/__init__/__qualname__/__len__()==13 / UUID/__str__/__qualname__/__len__()==12 / UUID/__eq__/__qualname__/__len__()==11 / UUID/__hash__/__qualname__/__len__()==13 — 'UUID.__init__' is 13 chars; 'UUID.__str__' is 12; 'UUID.__eq__' is 11; 'UUID.__hash__' is 13; uuid_extra76 anchors __qualname__.__eq__() for these methods; this table anchors __qualname__.__len__(); first __qualname__.__len__ anchor for UUID.__init__/__str__/__eq__/__hash__"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra77

  columns: [id, function, args, expected]
  rows:
    - [uuid_init_qualname_len_13,  "UUID.__init__.__qualname__.__len__",  [], 13]
    - [uuid_str_qualname_len_12,   "UUID.__str__.__qualname__.__len__",   [], 12]
    - [uuid_eq_qualname_len_11,    "UUID.__eq__.__qualname__.__len__",    [], 11]
    - [uuid_hash_qualname_len_13,  "UUID.__hash__.__qualname__.__len__",  [], 13]

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__/__qualname__/__len__() / UUID.__setattr__/__qualname__/__len__()
# uuid.uuid1/__qualname__/__eq__('uuid1') / uuid4/__name__/__eq__('uuid4')
#
# Wave 251 theme: UUID.__repr__/__setattr__ qualname lengths and cross-checks.
#
# UUID.__repr__.__qualname__ == 'UUID.__repr__' (len 13).
# UUID.__setattr__.__qualname__ == 'UUID.__setattr__' (len 16).
# Cross-check uuid1 __qualname__ and uuid4 __name__ equality.
# No prior uuid spec checks __qualname__.__len__() for UUID.__repr__/__setattr__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra77.uuid_dunder_qualname_lengths_group2:
  description: "uuid.UUID/__repr__/__qualname__/__len__()==13 / UUID/__setattr__/__qualname__/__len__()==16 / uuid1/__qualname__/__eq__('uuid1')==True / uuid4/__name__/__eq__('uuid4')==True — 'UUID.__repr__' is 13 chars; 'UUID.__setattr__' is 16 chars; uuid1/__qualname__/__eq__ and uuid4/__name__/__eq__ cross-anchor the module-level function strings; no prior uuid spec checks __qualname__.__len__() for UUID.__repr__/__setattr__; first __qualname__.__len__ anchor for uuid.UUID.__repr__/__setattr__"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra77

  columns: [id, function, args, expected]
  rows:
    - [uuid_repr_qualname_len_13,     "UUID.__repr__.__qualname__.__len__",     [], 13]
    - [uuid_setattr_qualname_len_16,  "UUID.__setattr__.__qualname__.__len__",  [], 16]
    - [uuid1_qualname_eq2,            uuid1.__qualname__.__eq__,                ["uuid1"], true]
    - [uuid4_name_eq2,                uuid4.__name__.__eq__,                    ["uuid4"], true]

# ---------------------------------------------------------------------------
# uuid.uuid1.__qualname__.__eq__('uuid1') — standalone
#
# uuid1.__qualname__ is 'uuid1'. No prior uuid spec checks
# uuid1.__qualname__.__eq__. First __qualname__.__eq__ standalone for
# uuid.uuid1. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra77.uuid1_qualname_eq:
  description: "uuid.uuid1.__qualname__.__eq__('uuid1') == True — uuid1 is a module-level function with a simple unqualified __qualname__; no prior uuid spec checks uuid1.__qualname__.__eq__; first __qualname__.__eq__ standalone for uuid.uuid1"
  category: class_attrs
  kind: python_call_eq
  function: uuid1.__qualname__.__eq__
  args: ["uuid1"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid4.__qualname__.__eq__('uuid4') — standalone
#
# uuid4.__qualname__ is 'uuid4'. No prior uuid spec checks
# uuid4.__qualname__.__eq__. First __qualname__.__eq__ standalone for
# uuid.uuid4. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra77.uuid4_qualname_eq:
  description: "uuid.uuid4.__qualname__.__eq__('uuid4') == True — uuid4 is a module-level function with a simple unqualified __qualname__; no prior uuid spec checks uuid4.__qualname__.__eq__; first __qualname__.__eq__ standalone for uuid.uuid4"
  category: class_attrs
  kind: python_call_eq
  function: uuid4.__qualname__.__eq__
  args: ["uuid4"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__.__len__() == 13 — standalone
#
# UUID.__init__.__qualname__ is 'UUID.__init__' (len 13). No prior uuid spec
# checks UUID.__init__.__qualname__.__len__(). First __qualname__.__len__()
# standalone for uuid.UUID.__init__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra77.uuid_init_qualname_len_13:
  description: "uuid.UUID.__init__.__qualname__.__len__() == 13 — 'UUID.__init__' is 13 characters; uuid_extra76 anchors __qualname__.__eq__; this standalone anchors __qualname__.__len__; first __qualname__.__len__ standalone for uuid.UUID.__init__"
  category: class_attrs
  kind: python_call_eq
  function: "UUID.__init__.__qualname__.__len__"
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# uuid.UUID.__setattr__.__qualname__.__len__() == 16 — standalone
#
# UUID.__setattr__.__qualname__ is 'UUID.__setattr__' (len 16). No prior uuid spec
# checks UUID.__setattr__.__qualname__.__len__(). First __qualname__.__len__()
# standalone for uuid.UUID.__setattr__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra77.uuid_setattr_qualname_len_16:
  description: "uuid.UUID.__setattr__.__qualname__.__len__() == 16 — 'UUID.__setattr__' is 16 characters; no prior uuid spec checks UUID.__setattr__.__qualname__.__len__; first __qualname__.__len__ standalone for uuid.UUID.__setattr__"
  category: class_attrs
  kind: python_call_eq
  function: "UUID.__setattr__.__qualname__.__len__"
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# uuid.uuid3.__name__.__eq__('uuid3') — standalone
#
# uuid3.__name__ is 'uuid3'. No prior uuid spec checks uuid3.__name__.__eq__.
# First __name__.__eq__ standalone for uuid.uuid3.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra77.uuid3_name_eq:
  description: "uuid.uuid3.__name__.__eq__('uuid3') == True — uuid3 is a module-level function; its __name__ is 'uuid3'; no prior uuid spec checks uuid3.__name__.__eq__; first __name__.__eq__ standalone for uuid.uuid3"
  category: class_attrs
  kind: python_call_eq
  function: uuid3.__name__.__eq__
  args: ["uuid3"]
