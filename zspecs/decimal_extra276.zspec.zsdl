spec: decimal_extra276
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification, Version 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "decimal_extra275 covers Decimal arithmetic result types (log10, exp, sqrt, from_float)."
    - "This spec focuses on Decimal comparison operator return values and NaN class identity."
    - "Decimal('1') < Decimal('2') is True — standard less-than comparison."
    - "Decimal('1') > Decimal('2') is False — standard greater-than comparison."
    - "Decimal('1.0') == Decimal('1') is True — decimal equality ignores trailing zeros in value."
    - "Decimal('2') <= Decimal('2') is True — less-than-or-equal holds when values are equal."
    - "Decimal('2') >= Decimal('1') is True — greater-than-or-equal holds when left side is larger."
    - "Decimal('NaN').__class__.__name__ == 'Decimal' — NaN is represented as a Decimal instance, not a float NaN."
    - "Decimal('1').__lt__(Decimal('2')) is True — explicit dunder call matches operator behavior."
    - "Decimal('1').__gt__(Decimal('2')) is False — explicit dunder call matches operator behavior."
    - "Decimal('1').__eq__(Decimal('1.0')) is True — value equality across different representations."
    - "Decimal('2').__le__(Decimal('2')) is True — le holds when operands are equal."
    - "Decimal('2').__ge__(Decimal('1')) is True — ge holds when left operand is larger."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal comparison operators via __lt__, __gt__, __le__, __ge__, __eq__
# Decimal('1').__lt__(Decimal('2')) == True
# Decimal('1').__gt__(Decimal('2')) == False
# Decimal('1.0').__eq__(Decimal('1')) == True
# Decimal('2').__le__(Decimal('2')) == True
# Decimal('2').__ge__(Decimal('1')) == True
# ---------------------------------------------------------------------------

table decimal_extra276.comparison_operators:
  description: "Decimal comparison operator dunder methods: __lt__, __gt__, __eq__, __le__, __ge__"
  kind: python_call_eq
  category: comparisons
  id_prefix: deccomp276

  columns: [id, function, args, expected, description]
  rows:
    - [lt_true,   Decimal.__lt__, ["1", "2"],   true,  "Decimal('1') < Decimal('2') is True"]
    - [lt_false,  Decimal.__lt__, ["2", "1"],   false, "Decimal('2') < Decimal('1') is False"]
    - [gt_true,   Decimal.__gt__, ["2", "1"],   true,  "Decimal('2') > Decimal('1') is True"]
    - [gt_false,  Decimal.__gt__, ["1", "2"],   false, "Decimal('1') > Decimal('2') is False"]
    - [eq_true,   Decimal.__eq__, ["1.0", "1"], true,  "Decimal('1.0') == Decimal('1') is True — value equality ignores trailing zeros"]
    - [eq_false,  Decimal.__eq__, ["1", "2"],   false, "Decimal('1') == Decimal('2') is False"]
    - [le_eq,     Decimal.__le__, ["2", "2"],   true,  "Decimal('2') <= Decimal('2') is True — holds when values are equal"]
    - [le_lt,     Decimal.__le__, ["1", "2"],   true,  "Decimal('1') <= Decimal('2') is True — holds when left is smaller"]
    - [ge_eq,     Decimal.__ge__, ["2", "2"],   true,  "Decimal('2') >= Decimal('2') is True — holds when values are equal"]
    - [ge_gt,     Decimal.__ge__, ["2", "1"],   true,  "Decimal('2') >= Decimal('1') is True — holds when left is larger"]

# ---------------------------------------------------------------------------
# Decimal NaN class identity
# Decimal('NaN') is a Decimal instance, not a float NaN.
# __class__.__name__ == 'Decimal'
# __class__.__module__ == 'decimal'
# ---------------------------------------------------------------------------

table decimal_extra276.nan_class_identity:
  description: "Decimal('NaN') class identity: __class__.__name__ == 'Decimal', __class__.__module__ == 'decimal'"
  kind: python_call_eq
  category: nan_identity
  id_prefix: decnan276

  columns: [id, function, args, expected, description]
  rows:
    - [nan_class,   Decimal.__new__, ["Decimal", "NaN"], "Decimal", "Decimal('NaN').__class__.__name__ == 'Decimal' — NaN is a Decimal, not a float"]
    - [nan_not_int, Decimal.__new__, ["Decimal", "NaN"], "Decimal", "Decimal('NaN').__class__.__name__ != 'float' — NaN is a Decimal instance"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra276.lt.one_lt_two:
  description: "Decimal('1').__lt__(Decimal('2')) is True — less-than comparison returns True when left operand is numerically smaller"
  category: comparisons
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: __lt__
  method_args: ["Decimal('2')"]
  expected: true

invariant decimal_extra276.gt.one_gt_two_is_false:
  description: "Decimal('1').__gt__(Decimal('2')) is False — greater-than returns False when left operand is numerically smaller"
  category: comparisons
  kind: python_call_eq
  function: Decimal.__gt__
  args: ["1", "2"]
  expected: false

invariant decimal_extra276.eq.one_point_zero_eq_one:
  description: "Decimal('1.0') == Decimal('1') is True — decimal equality is by value; trailing zeros after the decimal point do not affect equality"
  category: comparisons
  kind: python_call_eq
  function: Decimal.__eq__
  args: ["1.0", "1"]
  expected: true

invariant decimal_extra276.nan.class_name_is_Decimal:
  description: "Decimal('NaN').__class__.__name__ == 'Decimal' — the special NaN value is represented as an instance of Decimal, not as Python's float nan"
  category: nan_identity
  kind: python_call_eq
  function: Decimal
  args: ["NaN"]
  method: __class__.__name__.__eq__
  method_args: ["Decimal"]
  expected: true

invariant decimal_extra276.le.two_le_two:
  description: "Decimal('2').__le__(Decimal('2')) is True — less-than-or-equal holds when the two operands are equal"
  category: comparisons
  kind: python_call_eq
  function: Decimal.__le__
  args: ["2", "2"]
  expected: true

invariant decimal_extra276.ge.two_ge_one:
  description: "Decimal('2').__ge__(Decimal('1')) is True — greater-than-or-equal holds when left operand is numerically larger"
  category: comparisons
  kind: python_call_eq
  function: Decimal.__ge__
  args: ["2", "1"]
  expected: true
