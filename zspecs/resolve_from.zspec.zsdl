spec: resolve_from
version: ">=5.0.0"
backend: node(resolve-from)

docs: https://github.com/sindresorhus/resolve-from#readme

provenance:
  derived_from:
    - "resolve-from README — https://github.com/sindresorhus/resolve-from#readme"
    - "Node.js Module Resolution Algorithm — https://nodejs.org/api/modules.html#modules_all_together"
    - "Test vectors verified with resolve-from via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "resolve-from source"
  notes:
    - "Resolve a Node module path from a specific directory — like require.resolve but rooted elsewhere."
    - "Install: npm install resolve-from"
    - "v5 CJS; module export IS the function; .silent variant returns undefined instead of throwing."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws MODULE_NOT_FOUND on missing modules; .silent returns undefined."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant resolve_from.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant resolve_from.has_silent_variant:
  description: ".silent variant exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "silent.constructor.name"}
  expected: "Function"

invariant resolve_from.factory_arity:
  description: "Function takes (fromDir, moduleId) — function.length 2"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 2

invariant resolve_from.silent_arity:
  description: ".silent has same arity"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "silent.length"}
  expected: 2

invariant resolve_from.resolves_builtin_fs:
  description: "Built-in 'fs' resolves to 'fs'"
  category: resolve
  kind: node_chain_eq
  entry: module
  entry_args: ["/tmp", "fs"]
  chain: []
  expected: "fs"

invariant resolve_from.silent_returns_undefined_for_missing:
  description: "silent() on missing module returns undefined (null in JSON)"
  category: silent
  kind: node_chain_eq
  entry: named
  function: silent
  entry_args: ["/tmp", "this-module-definitely-does-not-exist-zxc"]
  chain: []
  expected: ~
