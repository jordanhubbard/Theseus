spec: decimal_extra211
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra210.zspec.zsdl — covers decimal class __doc__ string contains checks"
  notes:
    - "decimal.Decimal('not a number at all') raises decimal.InvalidOperation — InvalidOperation trap is enabled by default; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal('1') / decimal.Decimal('0') raises decimal.DivisionByZero — DivisionByZero trap is enabled by default; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal(None) raises TypeError: conversion from NoneType to Decimal is not supported; confirmed Python 3.14.3 macOS."
    - "decimal.InvalidOperation.__name__ == 'InvalidOperation'; decimal.InvalidOperation.__module__ == 'decimal'; confirmed Python 3.14.3 macOS."
    - "decimal.DivisionByZero.__name__ == 'DivisionByZero'; decimal.DivisionByZero.__module__ == 'decimal'; confirmed Python 3.14.3 macOS."
    - "decimal.InvalidOperation MRO: InvalidOperation -> DecimalException -> ArithmeticError -> Exception -> BaseException -> object; confirmed Python 3.14.3 macOS."
    - "decimal.DivisionByZero MRO: DivisionByZero -> DecimalException -> ZeroDivisionError -> ArithmeticError -> Exception -> BaseException -> object; confirmed Python 3.14.3 macOS."
    - "decimal.Overflow MRO: Overflow -> Inexact -> Rounded -> DecimalException -> ...; base is Inexact; confirmed Python 3.14.3 macOS."
    - "decimal.Underflow MRO: Underflow -> Inexact -> Rounded -> Subnormal -> DecimalException -> ...; base is Inexact; confirmed Python 3.14.3 macOS."
    - "decimal.Inexact base class is DecimalException; decimal.DecimalException base is ArithmeticError; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal constructor errors
# Invalid string and None argument raise signal exceptions and TypeError
# ---------------------------------------------------------------------------

table decimal_extra211.decimal_constructor_errors:
  description: "decimal.Decimal raises InvalidOperation for bad string input; raises TypeError for None"
  kind: python_call_raises
  category: errors
  id_prefix: decconstructerr211a

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_bad_string,   decimal.Decimal,  ["not a number at all"],  decimal.InvalidOperation,  "decimal.Decimal('not a number at all') raises InvalidOperation — default context traps this signal"]
    - [decimal_none_arg,     decimal.Decimal,  [~],                      TypeError,                 "decimal.Decimal(None) raises TypeError — conversion from NoneType to Decimal is not supported"]

# ---------------------------------------------------------------------------
# Table 2: decimal arithmetic signal exceptions
# Division by zero raises DivisionByZero with default context traps
# ---------------------------------------------------------------------------

table decimal_extra211.arithmetic_signal_errors:
  description: "decimal arithmetic operations raise signal exceptions when context traps are enabled (default)"
  kind: python_call_raises
  category: errors
  id_prefix: decaritherr211b

  columns: [id, function, args, expected, description]
  rows:
    - [divisionbyzero_one_zero,  decimal.Decimal.__truediv__,  ["1", "0"],  decimal.DivisionByZero,  "decimal.Decimal('1') / decimal.Decimal('0') raises DivisionByZero — trap enabled by default"]

# ---------------------------------------------------------------------------
# Table 3: decimal exception class identity — names and modules
# ---------------------------------------------------------------------------

table decimal_extra211.exception_class_names:
  description: "decimal exception class __name__ and __module__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: decexcnameid211c

  columns: [id, function, args, expected, description]
  rows:
    - [invalid_op_name,      decimal.InvalidOperation.__name__.__eq__,   ["InvalidOperation"],  true,  "decimal.InvalidOperation.__name__ == 'InvalidOperation'; confirmed Python 3.14.3 macOS"]
    - [invalid_op_module,    decimal.InvalidOperation.__module__.__eq__,  ["decimal"],           true,  "decimal.InvalidOperation.__module__ == 'decimal'; confirmed Python 3.14.3 macOS"]
    - [divbyzero_name,       decimal.DivisionByZero.__name__.__eq__,      ["DivisionByZero"],    true,  "decimal.DivisionByZero.__name__ == 'DivisionByZero'; confirmed Python 3.14.3 macOS"]
    - [divbyzero_module,     decimal.DivisionByZero.__module__.__eq__,    ["decimal"],           true,  "decimal.DivisionByZero.__module__ == 'decimal'; confirmed Python 3.14.3 macOS"]
    - [overflow_name,        decimal.Overflow.__name__.__eq__,            ["Overflow"],          true,  "decimal.Overflow.__name__ == 'Overflow'; confirmed Python 3.14.3 macOS"]
    - [underflow_name,       decimal.Underflow.__name__.__eq__,           ["Underflow"],         true,  "decimal.Underflow.__name__ == 'Underflow'; confirmed Python 3.14.3 macOS"]
    - [inexact_name,         decimal.Inexact.__name__.__eq__,             ["Inexact"],           true,  "decimal.Inexact.__name__ == 'Inexact'; confirmed Python 3.14.3 macOS"]
    - [decimalexc_name,      decimal.DecimalException.__name__.__eq__,    ["DecimalException"],  true,  "decimal.DecimalException.__name__ == 'DecimalException'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 4: decimal exception class hierarchy
# Base class identity checks via __bases__[0].__name__
# ---------------------------------------------------------------------------

table decimal_extra211.exception_class_hierarchy:
  description: "decimal exception class base class identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: decexchier211d

  columns: [id, function, args, expected, description]
  rows:
    - [invalid_op_base,    "decimal.InvalidOperation.__bases__[0].__name__.__eq__",  ["DecimalException"],  true,  "decimal.InvalidOperation base is DecimalException; confirmed Python 3.14.3 macOS"]
    - [divbyzero_base,     "decimal.DivisionByZero.__bases__[0].__name__.__eq__",    ["DecimalException"],  true,  "decimal.DivisionByZero base is DecimalException; confirmed Python 3.14.3 macOS"]
    - [overflow_base,      "decimal.Overflow.__bases__[0].__name__.__eq__",          ["Inexact"],           true,  "decimal.Overflow base is Inexact; confirmed Python 3.14.3 macOS"]
    - [underflow_base,     "decimal.Underflow.__bases__[0].__name__.__eq__",         ["Inexact"],           true,  "decimal.Underflow base is Inexact; confirmed Python 3.14.3 macOS"]
    - [inexact_base,       "decimal.Inexact.__bases__[0].__name__.__eq__",           ["DecimalException"],  true,  "decimal.Inexact base is DecimalException; confirmed Python 3.14.3 macOS"]
    - [decimalexc_base,    "decimal.DecimalException.__bases__[0].__name__.__eq__",  ["ArithmeticError"],   true,  "decimal.DecimalException base is ArithmeticError; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra211.decimal_bad_string:
  description: "decimal.Decimal('not a number at all') raises InvalidOperation — default context traps this signal; confirmed Python 3.14.3 macOS"
  category: errors
  kind: python_call_raises
  function: decimal.Decimal
  args: ["not a number at all"]
  expected: decimal.InvalidOperation

invariant decimal_extra211.decimal_none_arg:
  description: "decimal.Decimal(None) raises TypeError — NoneType cannot be converted to Decimal; confirmed Python 3.14.3 macOS"
  category: errors
  kind: python_call_raises
  function: decimal.Decimal
  args: [~]
  expected: TypeError

invariant decimal_extra211.invalid_operation_name:
  description: "decimal.InvalidOperation.__name__ == 'InvalidOperation'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.InvalidOperation.__name__.__eq__
  args: ["InvalidOperation"]
  expected: true

invariant decimal_extra211.divisionbyzero_name:
  description: "decimal.DivisionByZero.__name__ == 'DivisionByZero'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.DivisionByZero.__name__.__eq__
  args: ["DivisionByZero"]
  expected: true

invariant decimal_extra211.overflow_name:
  description: "decimal.Overflow.__name__ == 'Overflow'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Overflow.__name__.__eq__
  args: ["Overflow"]
  expected: true

invariant decimal_extra211.inexact_base:
  description: "decimal.Inexact.__bases__[0].__name__ == 'DecimalException' — Inexact inherits directly from DecimalException; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Inexact.__bases__[0].__name__.__eq__
  args: ["DecimalException"]
  expected: true

invariant decimal_extra211.decimalexception_base:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — DecimalException inherits from ArithmeticError; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.DecimalException.__bases__[0].__name__.__eq__
  args: ["ArithmeticError"]
  expected: true
