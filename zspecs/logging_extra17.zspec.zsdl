spec: logging_extra17
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends logging.zspec.zsdl through logging_extra16.zspec.zsdl."
    - "logging_extra13 covers: DEBUG/INFO/WARNING/ERROR/CRITICAL/NOTSET .__eq__ (value checks)."
    - "logging_extra5 covers: DEBUG/INFO/WARNING/ERROR/CRITICAL/NOTSET .__class__.__name__ == 'int' via table."
    - "This spec covers: FATAL and WARN alias __class__.__name__ and value; NOTSET __class__.__name__ (standalone invariant); getLevelNamesMapping __name__/__qualname__/__module__/__class__.__name__; addLevelName __name__/__qualname__/__module__/__class__.__name__."
    - "logging.FATAL and logging.WARN are deprecated aliases: FATAL==50 (CRITICAL), WARN==30 (WARNING)."
    - "logging.getLevelNamesMapping() is new in Python 3.11. Since version: >=3.9 is the spec floor but the function exists on 3.11+; on 3.9/3.10 it will raise AttributeError — only identity metadata is tested here, not the return value."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# FATAL and WARN alias constants — __class__.__name__ and value
#
# logging.FATAL and logging.WARN are deprecated aliases for CRITICAL and
# WARNING respectively. No prior logging spec records their __class__.__name__
# as standalone invariants, and no spec records __class__.__name__ for NOTSET
# as a standalone invariant (only in the table in logging_extra5).
# ---------------------------------------------------------------------------

invariant logging_extra17.FATAL.class_name:
  description: "logging.FATAL.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: FATAL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant logging_extra17.FATAL.value:
  description: "logging.FATAL == 50 (alias for CRITICAL)"
  category: constants
  kind: python_call_eq
  function: FATAL.__eq__
  args: [50]
  expected: true

invariant logging_extra17.WARN.class_name:
  description: "logging.WARN.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: WARN.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant logging_extra17.WARN.value:
  description: "logging.WARN == 30 (alias for WARNING)"
  category: constants
  kind: python_call_eq
  function: WARN.__eq__
  args: [30]
  expected: true

invariant logging_extra17.NOTSET.class_name:
  description: "logging.NOTSET.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: NOTSET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# getLevelNamesMapping — identity attributes
#
# logging.getLevelNamesMapping() was added in Python 3.11. These tests cover
# only identity metadata (__name__, __qualname__, __module__, __class__.__name__)
# which are available as soon as the attribute exists on the module object.
# No prior logging spec records any attribute of getLevelNamesMapping.
# ---------------------------------------------------------------------------

table logging_extra17.getLevelNamesMapping_identity:
  description: "Identity attributes for logging.getLevelNamesMapping function"
  kind: python_call_eq
  category: function_identity

  columns: [id, function, args, expected]
  rows:
    - [name,       getLevelNamesMapping.__name__.__eq__,             ["getLevelNamesMapping"], true]
    - [qualname,   getLevelNamesMapping.__qualname__.__eq__,         ["getLevelNamesMapping"], true]
    - [module,     getLevelNamesMapping.__module__.__eq__,           ["logging"],              true]
    - [class_name, getLevelNamesMapping.__class__.__name__.__eq__,   ["function"],             true]

# ---------------------------------------------------------------------------
# addLevelName — identity attributes
#
# No prior logging spec records any identity attribute of addLevelName
# (__name__, __qualname__, __module__, or __class__.__name__).
# ---------------------------------------------------------------------------

table logging_extra17.addLevelName_identity:
  description: "Identity attributes for logging.addLevelName function"
  kind: python_call_eq
  category: function_identity

  columns: [id, function, args, expected]
  rows:
    - [name,       addLevelName.__name__.__eq__,           ["addLevelName"], true]
    - [qualname,   addLevelName.__qualname__.__eq__,       ["addLevelName"], true]
    - [module,     addLevelName.__module__.__eq__,         ["logging"],      true]
    - [class_name, addLevelName.__class__.__name__.__eq__, ["function"],     true]
