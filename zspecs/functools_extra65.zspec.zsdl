spec: functools_extra65
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra64.zspec.zsdl."
    - "Wave 226 theme: __loader__ attribute chains (depth 2+): __loader__.__name__.__len__(), __loader__.__name__.__class__.__name__; __spec__.origin values; __spec__.submodule_search_locations checks; __version__ attribute presence/absence."
    - "functools is a pure-Python module (Lib/functools.py). Its __loader__ is an instance of SourceFileLoader from _frozen_importlib_external. SourceFileLoader instances are not classes and do not have a __name__ attribute; their class name is accessible via __loader__.__class__.__name__ == 'SourceFileLoader' (16 chars, verified extra64). The depth-2 chain new to wave 226 is __loader__.__class__.__name__.__len__() == 16."
    - "functools.__spec__.origin is a str (the absolute filesystem path to functools.py). Checked via __spec__.origin.__class__.__name__.__eq__('str') — new depth-2 chain not done in extra64 (extra64 checked __spec__.__class__.__name__, not origin's type)."
    - "functools.__spec__.submodule_search_locations is None — functools is not a package, so there are no subpackage search paths. The NoneType check uses __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType'). This is new to extra65."
    - "functools.__dict__.__contains__('__version__') is False — functools does not expose a __version__ attribute in its module namespace. Unlike third-party packages, CPython stdlib modules generally do not define __version__. This is new to extra65."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.__loader__.__class__.__name__.__len__() — depth-2 chain — extra65
#
# Wave 226 theme: __loader__ attribute chains (depth 2+).
#
# extra64 covered: __loader__.__class__.__name__.__eq__('SourceFileLoader') == True
# Wave 226 goes deeper: __loader__.__class__.__name__.__len__() == 16
#
# SourceFileLoader instances (functools.__loader__ is one) do not have a
# __name__ attribute directly. The loader class name is accessed via
# __loader__.__class__.__name__ == 'SourceFileLoader'.
# 'SourceFileLoader' has 16 characters: S-o-u-r-c-e-F-i-l-e-L-o-a-d-e-r.
#
# __len__() on a str returns the character count as an int.
# __loader__.__class__.__name__.__len__() == 16 is a depth-3 attribute chain
# terminating in a method call.
#
# No prior functools spec has a table row checking __loader__.__class__.__name__.__len__()==16.
# New to extra65.
# ---------------------------------------------------------------------------

table functools_extra65.loader_name_len:
  description: "functools.__loader__.__class__.__name__.__len__()==16 — 'SourceFileLoader' is 16 chars; depth-2 chain beyond the __eq__ check in extra64; wave 226 __loader__ depth-2 chain; new to extra65"
  kind: python_call_eq
  category: string_length
  id_prefix: functoolsspec65

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_name_len_eq_16,
       __loader__.__class__.__name__.__len__,
       [],
       16,
       "functools.__loader__.__class__.__name__.__len__() == 16 — functools.__loader__ is a SourceFileLoader instance; SourceFileLoader instances (unlike classes) do not expose __name__ directly, so the class name is reached via __loader__.__class__.__name__; the string 'SourceFileLoader' has exactly 16 characters (S-o-u-r-c-e-F-i-l-e-L-o-a-d-e-r); __len__() on a str returns the character count as a Python int; this is a depth-3 attribute chain (__loader__ → __class__ → __name__ → __len__()) probing the loader class name length; extra64 verified __eq__('SourceFileLoader') == True; wave 226 adds the __len__ depth check; no prior functools spec has a table row checking __loader__.__class__.__name__.__len__()==16; new to extra65"]

# ---------------------------------------------------------------------------
# functools.__spec__.origin type check — extra65
#
# Wave 226 theme: __spec__.origin values.
#
# functools.__spec__.origin is the filesystem path to functools.py — a str.
# For pure-Python stdlib modules loaded by SourceFileLoader, the ModuleSpec
# origin field is always a str containing the absolute path to the .py source
# file. Example: '/opt/homebrew/.../lib/python3.14/functools.py'
#
# The depth-2 check: __spec__.origin.__class__.__name__.__eq__('str')
# — origin is a str whose __class__ is str, and str.__name__ == 'str' (3 chars).
#
# extra64 checked __spec__.__class__.__name__.__eq__('ModuleSpec') (the spec
# object's class). Wave 226 goes one level deeper into the spec: checking the
# type of the origin field itself, not the spec object.
#
# Contrast with C builtin modules (itertools): itertools.__spec__.origin == 'built-in'
# (also a str, but with value 'built-in' rather than a file path).
#
# No prior functools spec has a table row checking __spec__.origin.__class__.__name__.__eq__('str').
# New to extra65.
# ---------------------------------------------------------------------------

table functools_extra65.spec_origin_type:
  description: "functools.__spec__.origin.__class__.__name__.__eq__('str')==true — spec origin is a str (file path) for pure-Python modules; wave 226 __spec__.origin depth check; no prior functools spec has table rows for __spec__.origin type; new to extra65"
  kind: python_call_eq
  category: class_identity
  id_prefix: functoolsspec65

  columns: [id, function, args, expected, description]
  rows:
    - [spec_origin_class_name_eq_str,
       __spec__.origin.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.__spec__.origin.__class__.__name__.__eq__('str') == True — functools.__spec__.origin is a Python str object containing the absolute filesystem path to the functools.py source file (e.g., '/opt/homebrew/.../lib/python3.14/functools.py'); for pure-Python stdlib modules loaded by SourceFileLoader, the ModuleSpec.origin field is always a str set to the source file path; the depth-2 chain (__spec__ → origin → __class__ → __name__ → __eq__) checks the type of the origin value itself; extra64 checked __spec__.__class__.__name__ (the ModuleSpec class); wave 226 checks __spec__.origin.__class__.__name__ (the origin value's type); contrast with C builtin modules (itertools) where __spec__.origin == 'built-in' — also a str, but a sentinel value rather than a file path; no prior functools spec has a table row checking __spec__.origin.__class__.__name__.__eq__('str'); new to extra65"]

# ---------------------------------------------------------------------------
# functools.__spec__.submodule_search_locations — NoneType check — extra65
#
# Wave 226 theme: __spec__.submodule_search_locations checks.
#
# functools is a regular module, not a package. Packages (directories with
# __init__.py, or namespace packages) have a non-None submodule_search_locations
# — a list-like object of filesystem paths where submodules can be found.
# Regular modules (like functools) have submodule_search_locations == None.
#
# The check: __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType')
# — None.__class__ is NoneType, and NoneType.__name__ == 'NoneType' (8 chars).
#
# This confirms that functools is not a package and has no submodule search paths.
#
# No prior functools spec has a table row checking __spec__.submodule_search_locations.
# New to extra65.
# ---------------------------------------------------------------------------

table functools_extra65.spec_submodule_search_locations:
  description: "functools.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType')==true — functools is not a package, so submodule_search_locations is None; wave 226 submodule_search_locations check; new to extra65"
  kind: python_call_eq
  category: class_identity
  id_prefix: functoolsspec65

  columns: [id, function, args, expected, description]
  rows:
    - [spec_submodule_search_locations_is_none,
       __spec__.submodule_search_locations.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "functools.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — functools is a regular Python module (not a package); packages (directories containing __init__.py or namespace packages) set submodule_search_locations to a list-like object of filesystem paths where submodules can be found; regular modules like functools have submodule_search_locations == None, indicating there are no subpackage search paths; None.__class__ is the built-in NoneType, and NoneType.__name__ == 'NoneType' (8 chars); the attribute chain traverses through the None object's class to its name; contrast with packages such as email, xml, or os.path's parent where submodule_search_locations is non-None; no prior functools spec has a table row checking __spec__.submodule_search_locations; new to extra65"]

# ---------------------------------------------------------------------------
# functools.__dict__.__contains__('__version__') — extra65
#
# Wave 226 theme: __version__ attribute presence/absence.
#
# functools does NOT define a __version__ attribute in its module namespace.
# Unlike many third-party packages that expose __version__ = 'x.y.z' for
# version introspection, CPython's stdlib modules generally do not define
# __version__. functools is one such module — it has no __version__ key in
# its __dict__.
#
# The check: functools.__dict__.__contains__('__version__') == False
# — the module's namespace dictionary does not contain the key '__version__'.
#
# Verified: functools.__dict__.__contains__('__version__') is False.
#
# No prior functools spec has a table row checking __dict__.__contains__('__version__').
# New to extra65.
# ---------------------------------------------------------------------------

table functools_extra65.version_absence:
  description: "functools.__dict__.__contains__('__version__')==false — functools has no __version__ attribute; CPython stdlib modules generally do not define __version__; wave 226 __version__ presence/absence check; new to extra65"
  kind: python_call_eq
  category: membership
  id_prefix: functoolsspec65

  columns: [id, function, args, expected, description]
  rows:
    - [dict_not_contains_version,
       __dict__.__contains__,
       ["__version__"],
       false,
       "functools.__dict__.__contains__('__version__') == False — functools does not define a __version__ attribute in its module namespace; third-party packages typically expose __version__ = 'x.y.z' in their top-level __init__.py or module to allow version introspection via importlib.metadata or direct attribute access; CPython stdlib modules like functools, inspect, threading, and itertools generally do not define __version__ — they are versioned with Python itself and their version is implicitly sys.version; '__version__' is not a key in functools.__dict__; no prior functools spec has a table row checking __dict__.__contains__('__version__'); new to extra65"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra65
# ---------------------------------------------------------------------------

invariant functools_extra65.loader_class_name_len_is_16:
  description: "functools.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 chars; depth-2 __loader__ chain beyond extra64's __eq__ check; wave 226; new to extra65"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__len__
  args: []
  expected: 16

invariant functools_extra65.spec_origin_is_str:
  description: "functools.__spec__.origin.__class__.__name__.__eq__('str') == True — spec origin is a str file path for pure-Python modules; wave 226 __spec__.origin depth check; new to extra65"
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra65.spec_submodule_search_locations_is_NoneType:
  description: "functools.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — functools is not a package, submodule_search_locations is None; wave 226; new to extra65"
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant functools_extra65.no_version_in_dict:
  description: "functools.__dict__.__contains__('__version__') == False — functools has no __version__; CPython stdlib modules are versioned with Python itself; wave 226; new to extra65"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["__version__"]
  expected: false
