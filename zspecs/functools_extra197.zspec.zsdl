spec: functools_extra197
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "functools.reduce.__name__ == 'reduce' (len=6); reduce is a C builtin_function_or_method from _functoolsmodule.c; verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' (len=10); reduce is implemented in the _functools C extension module; verified with Python 3.14.3."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' (len=26); reduce is a C builtin, not a Python function; verified with Python 3.14.3."
    - "functools.reduce.__qualname__ == 'reduce' (len=6); top-level name so __qualname__ equals __name__; verified with Python 3.14.3."
    - "functools.reduce.__doc__.__class__.__name__ == 'str'; the docstring is a plain Python str; verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'; WRAPPER_ASSIGNMENTS is a tuple of attribute name strings; verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__len__() == 6; six attribute names in WRAPPER_ASSIGNMENTS in Python 3.14 (__module__, __name__, __qualname__, __doc__, __annotate__, __type_params__); verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__len__() == 1; one attribute name in WRAPPER_UPDATES in Python 3.14 (__dict__); verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.reduce identity — __name__, __module__, __class__
#
# functools.reduce.__name__           == 'reduce' (len=6)
# functools.reduce.__module__         == '_functools' (len=10)
# functools.reduce.__class__.__name__ == 'builtin_function_or_method' (len=26)
#
# reduce is a C builtin_function_or_method implemented in _functoolsmodule.c.
# Its __module__ is '_functools' (the C extension), not 'functools' (the
# Python wrapper). Its __class__.__name__ distinguishes it from Python-level
# functions. New to extra197.
# ---------------------------------------------------------------------------

table functools_extra197.reduce_name_module_class:
  description: "functools.reduce identity: __name__=='reduce'(len=6); __module__=='_functools'(len=10); __class__.__name__=='builtin_function_or_method'(len=26); new to extra197"
  kind: python_call_eq
  category: identity
  id_prefix: functreduce197

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_name_eq,
       reduce.__name__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__name__.__eq__('reduce') == True — reduce is a C builtin_function_or_method from _functoolsmodule.c; __name__ is 'reduce' (len=6: r-e-d-u-c-e); str.__eq__('reduce') returns True; verified with Python 3.14.3; new to extra197"]
    - [reduce_name_len,
       reduce.__name__.__len__,
       [],
       6,
       "functools.reduce.__name__.__len__() == 6 — 'reduce' has 6 characters: r-e-d-u-c-e; str.__len__() returns 6; verified with Python 3.14.3; new to extra197"]
    - [reduce_module_eq,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is implemented in the _functools C extension module; __module__ is '_functools' (len=10: _-f-u-n-c-t-o-o-l-s); str.__eq__('_functools') returns True; verified with Python 3.14.3; new to extra197"]
    - [reduce_module_len,
       reduce.__module__.__len__,
       [],
       10,
       "functools.reduce.__module__.__len__() == 10 — '_functools' has 10 characters: _-f-u-n-c-t-o-o-l-s; str.__len__() returns 10; verified with Python 3.14.3; new to extra197"]
    - [reduce_class_name_eq,
       reduce.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C builtin, not a Python-level function; __class__.__name__ is 'builtin_function_or_method' (len=26); str.__eq__('builtin_function_or_method') returns True; verified with Python 3.14.3; new to extra197"]

# ---------------------------------------------------------------------------
# Table 2: functools.reduce __qualname__ and __doc__ identity
#
# functools.reduce.__qualname__              == 'reduce' (len=6)
# functools.reduce.__doc__.__class__.__name__ == 'str'
#
# As a top-level builtin, __qualname__ equals __name__ ('reduce').
# The docstring is a plain Python str (not bytes or NoneType).
# New to extra197.
# ---------------------------------------------------------------------------

table functools_extra197.reduce_qualname_doc:
  description: "functools.reduce qualname and doc identity: __qualname__=='reduce'(len=6); __doc__.__class__.__name__=='str'; new to extra197"
  kind: python_call_eq
  category: identity
  id_prefix: functreduce197

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_qualname_eq,
       reduce.__qualname__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — reduce is a top-level C builtin so __qualname__ equals __name__; __qualname__ is 'reduce' (len=6: r-e-d-u-c-e); str.__eq__('reduce') returns True; verified with Python 3.14.3; new to extra197"]
    - [reduce_qualname_len,
       reduce.__qualname__.__len__,
       [],
       6,
       "functools.reduce.__qualname__.__len__() == 6 — 'reduce' has 6 characters: r-e-d-u-c-e; __qualname__ equals __name__ for top-level builtins; str.__len__() returns 6; verified with Python 3.14.3; new to extra197"]
    - [reduce_doc_class_name,
       reduce.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — the reduce docstring is a plain Python str object; __class__.__name__ is 'str'; str.__eq__('str') returns True; verified with Python 3.14.3; new to extra197"]

# ---------------------------------------------------------------------------
# Table 3: functools.WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES identity
#
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
# functools.WRAPPER_ASSIGNMENTS.__len__()          == 6
# functools.WRAPPER_UPDATES.__len__()              == 1
#
# WRAPPER_ASSIGNMENTS is a tuple of 6 attribute names copied by functools.wraps
# in Python 3.14: __module__, __name__, __qualname__, __doc__, __annotate__,
# __type_params__. WRAPPER_UPDATES is a tuple of 1 name: __dict__.
# New to extra197.
# ---------------------------------------------------------------------------

table functools_extra197.wrapper_assignments_updates:
  description: "functools.WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES identity: WRAPPER_ASSIGNMENTS is a tuple of len 6; WRAPPER_UPDATES has len 1; new to extra197"
