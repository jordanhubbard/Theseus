  category: identity
  id_prefix: functreduce197

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_class_eq,
       WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level tuple of attribute name strings copied by functools.wraps; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; verified with Python 3.14.3; new to extra197"]
    - [wrapper_assignments_len,
       WRAPPER_ASSIGNMENTS.__len__,
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS has 6 elements in Python 3.14: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__; tuple.__len__() returns 6; verified with Python 3.14.3; new to extra197"]
    - [wrapper_updates_len,
       WRAPPER_UPDATES.__len__,
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES has 1 element in Python 3.14: __dict__; tuple.__len__() returns 1; verified with Python 3.14.3; new to extra197"]

