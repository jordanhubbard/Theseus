spec: re_extra213
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers re module-level functions and constants"
    - "re_extra212.zspec.zsdl — covers re.Pattern.__dict__ sub/split/find methods and re.error.__dict__ membership"
  notes:
    - "re.error.__dict__ contains exactly 6 entries: __module__, __firstlineno__, __doc__, __init__, __static_attributes__, __weakref__."
    - "re.error.__dict__.__len__() == 6; confirmed Python 3.14.3 macOS."
    - "re.IGNORECASE, re.MULTILINE, re.DOTALL, re.UNICODE are all instances of re.RegexFlag (an IntFlag enum)."
    - "type(re.IGNORECASE).__name__ == 'RegexFlag'; confirmed Python 3.14.3 macOS."
    - "type(re.MULTILINE).__name__ == 'RegexFlag'; confirmed Python 3.14.3 macOS."
    - "type(re.DOTALL).__name__ == 'RegexFlag'; confirmed Python 3.14.3 macOS."
    - "type(re.UNICODE).__name__ == 'RegexFlag'; confirmed Python 3.14.3 macOS."
    - "re.error.__dict__.__contains__('__module__') == True; confirmed Python 3.14.3 macOS."
    - "re.error.__dict__.__contains__('__weakref__') == True; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.error.__dict__ membership — class-level attributes
# re.error defines __init__, __module__, __doc__, __firstlineno__, __static_attributes__, __weakref__
# ---------------------------------------------------------------------------

table re_extra213.error_dict_class_attributes:
  description: "re.error.__dict__ contains exactly these class-level attributes"
  kind: python_call_eq
  category: dict_membership
  id_prefix: reerror213

  columns: [id, function, args, expected, description]
  rows:
    - [error_has_module,       "re.error.__dict__.__contains__",  ["__module__"],             true,   "re.error.__dict__.__contains__('__module__') == True; __module__ is a class attribute on re.error; confirmed Python 3.14.3 macOS"]
    - [error_has_weakref,      "re.error.__dict__.__contains__",  ["__weakref__"],            true,   "re.error.__dict__.__contains__('__weakref__') == True; __weakref__ is a class attribute on re.error; confirmed Python 3.14.3 macOS"]
    - [error_has_doc,          "re.error.__dict__.__contains__",  ["__doc__"],                true,   "re.error.__dict__.__contains__('__doc__') == True; __doc__ is a class attribute on re.error; confirmed Python 3.14.3 macOS"]
    - [error_has_firstlineno,  "re.error.__dict__.__contains__",  ["__firstlineno__"],        true,   "re.error.__dict__.__contains__('__firstlineno__') == True; __firstlineno__ is a class attribute on re.error; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.error.__dict__ additional attributes and dict length
# __init__, __static_attributes__ are present; dict has exactly 6 entries
# ---------------------------------------------------------------------------

table re_extra213.error_dict_extra_attributes:
  description: "re.error.__dict__ additional attributes: __init__, __static_attributes__, and dict length"
  kind: python_call_eq
  category: dict_membership
  id_prefix: reerror213

  columns: [id, function, args, expected, description]
  rows:
    - [error_has_init,               "re.error.__dict__.__contains__",  ["__init__"],               true,   "re.error.__dict__.__contains__('__init__') == True; __init__ is defined on re.error to set msg/pos/lineno/colno; confirmed Python 3.14.3 macOS"]
    - [error_has_static_attributes,  "re.error.__dict__.__contains__",  ["__static_attributes__"],  true,   "re.error.__dict__.__contains__('__static_attributes__') == True; __static_attributes__ is a class attribute on re.error; confirmed Python 3.14.3 macOS"]
    - [error_no_str,                 "re.error.__dict__.__contains__",  ["__str__"],                false,  "re.error.__dict__.__contains__('__str__') == False; __str__ is NOT defined on re.error (inherited from Exception); confirmed Python 3.14.3 macOS"]
    - [error_dict_len,               re.error.__dict__.__len__,         [],                         6,      "re.error.__dict__.__len__() == 6; re.error.__dict__ has exactly 6 entries; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re flag constants class name — IGNORECASE, MULTILINE, DOTALL, UNICODE
# All re flag constants are instances of re.RegexFlag (an IntFlag enum subclass)
# ---------------------------------------------------------------------------

table re_extra213.flag_constants_class_name:
  description: "re flag constants are instances of re.RegexFlag (IntFlag enum)"
  kind: python_call_eq
  category: constant_metadata
  id_prefix: reerror213

  columns: [id, function, args, expected, description]
  rows:
    - [ignorecase_class_name,  re.IGNORECASE.__class__.__name__,  [],  "RegexFlag",  "re.IGNORECASE.__class__.__name__ == 'RegexFlag'; IGNORECASE is a RegexFlag IntFlag enum member; confirmed Python 3.14.3 macOS"]
    - [multiline_class_name,   re.MULTILINE.__class__.__name__,   [],  "RegexFlag",  "re.MULTILINE.__class__.__name__ == 'RegexFlag'; MULTILINE is a RegexFlag IntFlag enum member; confirmed Python 3.14.3 macOS"]
    - [dotall_class_name,      re.DOTALL.__class__.__name__,      [],  "RegexFlag",  "re.DOTALL.__class__.__name__ == 'RegexFlag'; DOTALL is a RegexFlag IntFlag enum member; confirmed Python 3.14.3 macOS"]
    - [unicode_class_name,     re.UNICODE.__class__.__name__,     [],  "RegexFlag",  "re.UNICODE.__class__.__name__ == 'RegexFlag'; UNICODE is a RegexFlag IntFlag enum member; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra213.error_has_module:
  description: "re.error.__dict__.__contains__('__module__') == True — __module__ is a class attribute on re.error; confirmed Python 3.14.3 macOS"
  category: dict_membership
  kind: python_call_eq
  function: "re.error.__dict__.__contains__"
  args: ["__module__"]
  expected: true

invariant re_extra213.error_has_init:
  description: "re.error.__dict__.__contains__('__init__') == True — __init__ is defined on re.error for msg/pos/lineno/colno; confirmed Python 3.14.3 macOS"
  category: dict_membership
  kind: python_call_eq
  function: "re.error.__dict__.__contains__"
  args: ["__init__"]
  expected: true

invariant re_extra213.error_dict_len:
  description: "re.error.__dict__.__len__() == 6 — re.error.__dict__ has exactly 6 entries; confirmed Python 3.14.3 macOS"
  category: dict_membership
  kind: python_call_eq
  function: re.error.__dict__.__len__
  args: []
  expected: 6

invariant re_extra213.ignorecase_class_name:
  description: "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — IGNORECASE is a RegexFlag IntFlag enum member; confirmed Python 3.14.3 macOS"
  category: constant_metadata
  kind: python_call_eq
  function: re.IGNORECASE.__class__.__name__
  args: []
  expected: "RegexFlag"

invariant re_extra213.multiline_class_name:
  description: "re.MULTILINE.__class__.__name__ == 'RegexFlag' — MULTILINE is a RegexFlag IntFlag enum member; confirmed Python 3.14.3 macOS"
  category: constant_metadata
  kind: python_call_eq
  function: re.MULTILINE.__class__.__name__
  args: []
  expected: "RegexFlag"

invariant re_extra213.dotall_class_name:
  description: "re.DOTALL.__class__.__name__ == 'RegexFlag' — DOTALL is a RegexFlag IntFlag enum member; confirmed Python 3.14.3 macOS"
  category: constant_metadata
  kind: python_call_eq
  function: re.DOTALL.__class__.__name__
  args: []
  expected: "RegexFlag"

invariant re_extra213.unicode_class_name:
  description: "re.UNICODE.__class__.__name__ == 'RegexFlag' — UNICODE is a RegexFlag IntFlag enum member; confirmed Python 3.14.3 macOS"
  category: constant_metadata
  kind: python_call_eq
  function: re.UNICODE.__class__.__name__
  args: []
  expected: "RegexFlag"

invariant re_extra213.error_no_str:
  description: "re.error.__dict__.__contains__('__str__') == False — __str__ is NOT defined on re.error; it is inherited from Exception; confirmed Python 3.14.3 macOS"
  category: dict_membership
  kind: python_call_eq
  function: "re.error.__dict__.__contains__"
  args: ["__str__"]
  expected: false
