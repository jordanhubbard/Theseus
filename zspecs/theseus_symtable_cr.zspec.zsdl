spec: theseus_symtable_cr
version: ">=3.0"
backend: python_cleanroom(theseus_symtable_cr)
blocks: symtable

docs: https://docs.python.org/3/library/symtable.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/symtable.html"
  not_derived_from:
    - "CPython source: Lib/symtable.py"
  notes:
    - "Clean-room symtable module. Do NOT import symtable."

error_model: python_exceptions

invariant theseus_symtable_cr.symtable2_symtable:
  description: "symtable() returns a SymbolTable for valid code"
  category: behavior
  kind: python_call_eq
  function: symtable2_symtable
  args: []
  expected: true

invariant theseus_symtable_cr.symtable2_get_symbols:
  description: "SymbolTable.get_symbols() returns a list"
  category: behavior
  kind: python_call_eq
  function: symtable2_get_symbols
  args: []
  expected: true

invariant theseus_symtable_cr.symtable2_lookup:
  description: "SymbolTable.lookup() finds a symbol by name"
  category: behavior
  kind: python_call_eq
  function: symtable2_lookup
  args: []
  expected: true
