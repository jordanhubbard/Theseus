provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.shared_memory.html — SharedMemory and ShareableList class identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
