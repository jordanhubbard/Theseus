table multiprocessing_extra661.shared_memory_identity:
  description: "multiprocessing.shared_memory.SharedMemory class and method identity checks"
  kind: python_call_eq
  category: shared_memory_identity
  id_prefix: mp661sm
  columns: [id, function, args, expected]
  rows:
    - [mp661sm001, multiprocessing.shared_memory.SharedMemory.__qualname__.__eq__, ["SharedMemory"], true]
    - [mp661sm002, multiprocessing.shared_memory.SharedMemory.__module__.__eq__, ["multiprocessing.shared_memory"], true]
    - [mp661sm003, multiprocessing.shared_memory.SharedMemory.__class__.__name__.__eq__, ["type"], true]
    - [mp661sm004, multiprocessing.shared_memory.SharedMemory.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [mp661sm005, multiprocessing.shared_memory.SharedMemory.__init__.__qualname__.__eq__, ["SharedMemory.__init__"], true]
    - [mp661sm006, multiprocessing.shared_memory.SharedMemory.close.__qualname__.__eq__, ["SharedMemory.close"], true]
    - [mp661sm007, multiprocessing.shared_memory.SharedMemory.unlink.__qualname__.__eq__, ["SharedMemory.unlink"], true]

table multiprocessing_extra661.shareable_list_identity:
