spec: socket_extra1201
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket.socket __name__/__qualname__/__module__ identity and __init__ qualname/class attrs, socket.herror and socket.gaierror __name__/__qualname__/__module__/__bases__/__mro__ attrs, and socket.AddressFamily/__bases__ and socket.SocketKind/__bases__ lengths"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1201.socket_class_name_qualname_module:
  description: "socket.socket __name__/__qualname__/__module__ string identity and __init__ qualname/class attrs"
  kind: python_call_eq
  category: socket_class_name_qualname_module
  id_prefix: sk1201nm
  columns: [id, function, args, expected]
  rows:
    - [sk1201nm001, socket.socket.__name__.__eq__,                               ["socket"],          true]
    - [sk1201nm002, socket.socket.__qualname__.__eq__,                           ["socket"],          true]
    - [sk1201nm003, socket.socket.__module__.__eq__,                             ["socket"],          true]
    - [sk1201nm004, socket.socket.__init__.__qualname__.__eq__,                  ["socket.__init__"], true]
    - [sk1201nm005, socket.socket.__init__.__class__.__name__.__eq__,            ["function"],        true]
    - [sk1201nm006, socket.socket.__name__.__class__.__name__.__eq__,            ["str"],             true]
    - [sk1201nm007, socket.socket.__qualname__.__class__.__name__.__eq__,        ["str"],             true]
    - [sk1201nm008, socket.socket.__module__.__class__.__name__.__eq__,          ["str"],             true]
    - [sk1201nm009, socket.socket.__init__.__qualname__.__class__.__name__.__eq__, ["str"],           true]

