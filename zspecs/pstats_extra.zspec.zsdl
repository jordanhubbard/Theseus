spec: pstats_extra
version: ">=3.9"
backend: python_module(pstats)

docs: https://docs.python.org/3/library/profile.html#the-stats-class

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/profile.html#the-stats-class"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from: []
  notes:
    - "This spec extends pstats.zspec.zsdl with additional identity invariants."
    - "Stats.__name__ == 'Stats' and Stats.__module__ == 'pstats'."
    - "FunctionProfile and StatsProfile are dataclasses introduced in Python 3.9."
    - "SortKey is an enum.Enum subclass introduced in Python 3.7; __module__ == 'pstats'."
    - "All expected values verified by running Python 3.12 pstats module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name and module identity — Stats
# ---------------------------------------------------------------------------

invariant pstats_extra.classes.Stats_name:
  description: "pstats.Stats.__name__ == 'Stats'"
  category: classes
  kind: python_call_eq
  function: Stats.__name__.__eq__
  args: ["Stats"]
  expected: true

invariant pstats_extra.classes.Stats_module:
  description: "pstats.Stats.__module__ == 'pstats'"
  category: classes
  kind: python_call_eq
  function: Stats.__module__.__eq__
  args: ["pstats"]
  expected: true

# ---------------------------------------------------------------------------
# Class name identity — dataclasses introduced in Python 3.9
# ---------------------------------------------------------------------------

invariant pstats_extra.classes.FunctionProfile_name:
  description: "pstats.FunctionProfile.__name__ == 'FunctionProfile' (Python 3.9+)"
  category: classes
  kind: python_call_eq
  function: FunctionProfile.__name__.__eq__
  args: ["FunctionProfile"]
  expected: true

invariant pstats_extra.classes.StatsProfile_name:
  description: "pstats.StatsProfile.__name__ == 'StatsProfile' (Python 3.9+)"
  category: classes
  kind: python_call_eq
  function: StatsProfile.__name__.__eq__
  args: ["StatsProfile"]
  expected: true

# ---------------------------------------------------------------------------
# Class name and module identity — SortKey enum (Python 3.7+)
# ---------------------------------------------------------------------------

invariant pstats_extra.classes.SortKey_name:
  description: "pstats.SortKey.__name__ == 'SortKey' (Python 3.7+ enum)"
  category: classes
  kind: python_call_eq
  function: SortKey.__name__.__eq__
  args: ["SortKey"]
  expected: true

invariant pstats_extra.classes.SortKey_module:
  description: "pstats.SortKey.__module__ == 'pstats'"
  category: classes
  kind: python_call_eq
  function: SortKey.__module__.__eq__
  args: ["pstats"]
  expected: true
