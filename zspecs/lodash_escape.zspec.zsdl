spec: lodash_escape
version: ">=4.0.0"
backend: node(lodash.escape)

docs: https://lodash.com/docs/#escape

provenance:
  derived_from:
    - "lodash.escape README — https://www.npmjs.com/package/lodash.escape"
    - "Test vectors verified with lodash.escape@4.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.escape exports the _.escape function directly as module.exports."
    - "escape(string) converts &, <, >, \", ' to HTML entities."
    - "Single quotes use &#39;, ampersand uses &amp;."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns HTML-escaped string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_escape.escape:
  kind: node_module_call_eq
  function: ~
  category: escape
  id_prefix: lesc

  columns: [id, args, expected]
  rows:
    - [amp,      ["a&b"],      "a&amp;b"]
    - [lt,       ["a<b"],      "a&lt;b"]
    - [gt,       ["a>b"],      "a&gt;b"]
    - [dquote,   ['a"b'],      "a&quot;b"]
    - [squote,   ["a'b"],      "a&#39;b"]
    - [plain,    ["hello"],    "hello"]
