spec: socket_extra59
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra58.zspec.zsdl — covers socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "socket_extra57.zspec.zsdl — covers socket.__all__.__contains__ for gethostname/gethostbyname/getaddrinfo/timeout (table); socket.__dict__.__contains__ for socket/gethostname/AF_INET/herror (table); herror.__doc__.__class__.__name__.__eq__('NoneType') (invariant)."
    - "socket_extra56.zspec.zsdl — covers socket.__all__.__contains__ for AF_INET/SOCK_STREAM/socket/herror/gaierror (table); socket.socket/__eq__/__class__/__name__.__eq__('wrapper_descriptor'); herror/gaierror/timeout __eq__.__class__.__name__.__eq__('wrapper_descriptor')."
    - "socket_extra30.zspec.zsdl — covers socket.__all__.__len__()==238 and socket.__all__.__class__.__name__.__eq__('list')."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra58; it does NOT duplicate invariants present in those files."
    - "Wave 226 theme: __spec__.origin values + __spec__.submodule_search_locations + __loader__.__name__ length checks."
    - "socket in Python 3 is a Python wrapper module (Lib/socket.py) that imports the _socket C extension internally. The top-level 'socket' module is loaded from a single Python source file (socket.py). It is not a package: it has no sub-module directory, so __spec__.submodule_search_locations is None (NoneType). For Python source files, __spec__.has_location is True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 1: No prior socket spec checks socket.__loader__.__class__.__name__.__len__()==16 in a table row context alongside the new __spec__.origin checks. No prior socket spec checks __loader__.__class__.__name__.__len__() in any form (unlike hashlib/uuid/struct which have this in extra36/extra25/extra29 respectively). socket_extra58 covers __loader__.__class__.__name__.__eq__('SourceFileLoader'). This spec adds __loader__.__class__.__name__.__len__()==16 as both a table row and novel standalone invariant for socket. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__loader__.__class__.__name__.__len__() == 16. 'SourceFileLoader' has 16 characters. No prior socket spec checks socket.__loader__.__class__.__name__.__len__() in any form. Entirely novel loader class name length anchor for socket. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior socket spec checks socket.__spec__.origin.__class__.__name__.__eq__('str'). socket.__spec__.origin is the absolute file path to socket.py as a Python str. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__spec__.origin.__class__.__name__ == 'str'. The ModuleSpec.origin attribute is the path to the source file (e.g., '.../lib/python3.14/socket.py') stored as a Python str. No prior socket spec checks __spec__.origin.__class__.__name__ in any form. Entirely novel origin type anchor for socket. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior socket spec checks socket.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType'). socket is a single-file module (socket.py), not a package; therefore __spec__.submodule_search_locations is None. None.__class__.__name__ == 'NoneType'. This confirms socket is not a package. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__spec__.submodule_search_locations is None. For non-package modules, ModuleSpec.submodule_search_locations is None. The socket module presents as a flat single-file module from the import system's perspective, even though it internally imports the _socket C extension. No prior socket spec checks submodule_search_locations in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 4: No prior socket spec checks socket.__spec__.has_location. For Python source modules, ModuleSpec.has_location is True. has_location being True confirms socket is file-backed (the Python wrapper socket.py has a path). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__spec__.has_location == True. socket is loaded from a Python wrapper file (Lib/socket.py); its ModuleSpec.has_location is True. No prior socket spec checks __spec__.has_location. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket __spec__.origin + submodule_search_locations + has_location checks
#
# Wave 226 theme: __spec__.origin values + __spec__.submodule_search_locations +
# __loader__.__name__ length checks.
#
# socket is loaded as a Python wrapper (Lib/socket.py) that imports the _socket
# C extension. From the import system perspective it is a single-file module
# (not a package). Its ModuleSpec has:
#   - origin: str path to socket.py (the Python wrapper)
#   - submodule_search_locations: None (NoneType) — not a package
#   - has_location: True — file-backed module (socket.py has a path)
#
# Note: Unlike hashlib/uuid/struct which had __loader__.__class__.__name__.__len__()
# covered by prior specs (extra36/extra25/extra29), no prior socket spec checks
# __loader__.__class__.__name__.__len__(). The __len__==16 row is therefore
# doubly novel for socket.
# ---------------------------------------------------------------------------

table socket_extra59.spec_origin_submodule_location:
  description: "socket __loader__.__class__.__name__.__len__()==16 / __spec__.origin.__class__.__name__.__eq__('str') / __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') / __spec__.has_location==True — wave 226 theme: origin/submodule_search_locations/has_location checks for socket; socket is the Python wrapper Lib/socket.py (not a package); __len__==16 is novel for socket (no prior socket spec covers loader class name len); origin is a str path, submodule_search_locations is None (NoneType), has_location is True; all rows are novel for socket"
  kind: python_call_eq
  category: module_structure
  id_prefix: socketspec59

  columns: [id, function, args, expected]
  rows:
    - [loader_class_name_len,               __loader__.__class__.__name__.__len__,                             [], 16]
    - [spec_origin_class_name_eq,           __spec__.origin.__class__.__name__.__eq__,                         ["str"],      true]
    - [spec_submodule_search_class_name_eq, __spec__.submodule_search_locations.__class__.__name__.__eq__,      ["NoneType"], true]
    - [spec_has_location,                   __spec__.has_location.__eq__,                                       [true],       true]

# ---------------------------------------------------------------------------
# socket.__spec__.origin.__class__.__name__.__eq__('str') — standalone
#
# socket.__spec__.origin is the absolute file path to socket.py (the Python
# wrapper), stored as a Python str. No prior socket spec checks __spec__.origin
# in any form. Note: origin points to the Python wrapper file socket.py, not
# to the underlying C extension _socket. This is the primary origin type
# anchor for the socket module.
# ---------------------------------------------------------------------------

invariant socket_extra59.spec_origin_class_name_str:
  description: "socket.__spec__.origin.__class__.__name__.__eq__('str') == True — socket.__spec__.origin is the str path to the Python wrapper Lib/socket.py; ModuleSpec.origin is str for file-backed Python modules; no prior socket spec checks __spec__.origin in any form; primary origin type anchor for socket confirming the Python-wrapper loading path (not the _socket C extension)"
  category: module_structure
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType')
# — standalone
#
# socket is not a package: it is a single-file module (socket.py + _socket C
# extension internally). ModuleSpec.submodule_search_locations is None for
# non-package modules. None.__class__.__name__ == 'NoneType'. No prior socket
# spec checks submodule_search_locations in any form. This confirms socket
# presents as a flat single-file module from the import system's perspective.
# ---------------------------------------------------------------------------

invariant socket_extra59.spec_submodule_search_locations_nonetype:
  description: "socket.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — socket is a single-file module (not a package); ModuleSpec.submodule_search_locations is None for non-package modules; None.__class__.__name__ == 'NoneType'; no prior socket spec checks submodule_search_locations; confirms socket presents as flat single-file from the import system perspective"
  category: module_structure
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__loader__.__class__.__name__.__len__()==16 — standalone
#
# 'SourceFileLoader' has 16 characters. No prior socket spec checks
# socket.__loader__.__class__.__name__.__len__() in any form (unlike
# hashlib/uuid/struct which have this in extra36/extra25/extra29 respectively).
# This is an entirely novel loader class name length anchor for socket.
# ---------------------------------------------------------------------------

invariant socket_extra59.loader_class_name_len_16:
  description: "socket.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters; no prior socket spec checks socket.__loader__.__class__.__name__.__len__() in any form; entirely novel loader class name length anchor for socket; complements socket_extra58 which covers __loader__.__class__.__name__.__eq__('SourceFileLoader') (equality axis)"
  category: module_structure
  kind: python_call_eq
  function: __loader__.__class__.__name__.__len__
  args: []
  expected: 16
