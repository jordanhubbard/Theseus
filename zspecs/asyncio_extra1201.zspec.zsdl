table asyncio_extra1201.queue_task_future_bases_len:
  description: "asyncio.Queue, asyncio.Task, and asyncio.Future each have exactly one direct base class (__bases__.__len__() == 1)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: as1201ab
  columns: [id, function, args, expected]
  rows:
    - [as1201ab001, asyncio.Queue.__bases__.__len__,   [], 1]
    - [as1201ab002, asyncio.Task.__bases__.__len__,    [], 1]
    - [as1201ab003, asyncio.Future.__bases__.__len__,  [], 1]
    - [as1201ab004, asyncio.Queue.__bases__.__class__.__name__.__eq__,  ["tuple"], true]
    - [as1201ab005, asyncio.Task.__bases__.__class__.__name__.__eq__,   ["tuple"], true]
    - [as1201ab006, asyncio.Future.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [as1201ab007, asyncio.Queue.__mro__.__class__.__name__.__eq__,    ["tuple"], true]
    - [as1201ab008, asyncio.Task.__mro__.__class__.__name__.__eq__,     ["tuple"], true]

