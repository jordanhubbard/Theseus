spec: hashlib_extra1261
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra126.zspec.zsdl — covers HASH instance method qualname lengths / md5().digest_size/block_size/name class names / md5().digest_size==16 / sha256().digest_size==32 (table + invariants)."
    - "hashlib_extra125.zspec.zsdl — covers md5()/sha256()/sha1().__class__.__name__.__eq__('HASH') / md5().__class__.__module__/__qualname__ / HASH instance method qualname __eq__ values (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ / blake2b/blake2s class identity / algorithms_guaranteed length (table + invariants)."
  notes:
    - "Wave 531: hashlib has __all__ (a tuple, not a list). This spec checks hashlib.__all__.__contains__ for names in __all__ (true), names NOT in __all__ (false), and __all__.__class__.__name__.__eq__ identity. Also includes algorithms_guaranteed set membership checks as a complementary angle."
    - "hashlib.__all__.__class__.__name__ == 'tuple'. On this Python version hashlib.__all__ is a tuple, not a list. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__ contains: md5, sha1, sha224, sha256, sha384, sha512, blake2b, blake2s, sha3_224, sha3_256, sha3_384, sha3_512, shake_128, shake_256, new, algorithms_guaranteed, algorithms_available, file_digest, pbkdf2_hmac. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed is a frozenset of algorithm names guaranteed on all platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1261.all_contains_true:
  description: "hashlib.__all__.__contains__ returns true for names that are members of __all__"
  kind: python_call_eq
  category: all_membership_true
  id_prefix: hl1261at
  columns: [id, function, args, expected]
  rows:
    - [hl1261at001, hashlib.__all__.__contains__, ["md5"],                   true]
    - [hl1261at002, hashlib.__all__.__contains__, ["sha1"],                  true]
    - [hl1261at003, hashlib.__all__.__contains__, ["sha224"],                true]
    - [hl1261at004, hashlib.__all__.__contains__, ["sha256"],                true]
    - [hl1261at005, hashlib.__all__.__contains__, ["sha512"],                true]
    - [hl1261at006, hashlib.__all__.__contains__, ["blake2b"],               true]
    - [hl1261at007, hashlib.__all__.__contains__, ["blake2s"],               true]
    - [hl1261at008, hashlib.__all__.__contains__, ["sha3_256"],              true]
    - [hl1261at009, hashlib.__all__.__contains__, ["new"],                   true]
    - [hl1261at010, hashlib.__all__.__contains__, ["algorithms_guaranteed"], true]
    - [hl1261at011, hashlib.__all__.__contains__, ["algorithms_available"],  true]
    - [hl1261at012, hashlib.__all__.__contains__, ["pbkdf2_hmac"],           true]
    - [hl1261at013, hashlib.__all__.__contains__, ["file_digest"],           true]
    - [hl1261at014, hashlib.__all__.__contains__, ["sha384"],                true]
    - [hl1261at015, hashlib.__all__.__contains__, ["shake_256"],             true]

table hashlib_extra1261.all_contains_false:
  description: "hashlib.__all__.__contains__ returns false for names not in __all__ (private names, absent algorithms, unrelated symbols)"
  kind: python_call_eq
  category: all_membership_false
  id_prefix: hl1261af
  columns: [id, function, args, expected]
  rows:
    - [hl1261af001, hashlib.__all__.__contains__, ["md4"],       false]
    - [hl1261af002, hashlib.__all__.__contains__, ["sha999"],    false]
    - [hl1261af003, hashlib.__all__.__contains__, ["HASH"],      false]
    - [hl1261af004, hashlib.__all__.__contains__, ["open"],      false]
    - [hl1261af005, hashlib.__all__.__contains__, ["ripemd160"], false]
    - [hl1261af006, hashlib.__all__.__contains__, ["whirlpool"], false]
    - [hl1261af007, hashlib.__all__.__contains__, ["scrypt"],    false]
    - [hl1261af008, hashlib.__all__.__contains__, ["os"],        false]
    - [hl1261af009, hashlib.__all__.__contains__, ["_hashlib"],  false]
    - [hl1261af010, hashlib.__all__.__contains__, ["sys"],       false]
    - [hl1261af011, hashlib.__all__.__contains__, ["io"],        false]
    - [hl1261af012, hashlib.__all__.__contains__, [""],          false]

table hashlib_extra1261.all_class_and_type_checks:
  description: "hashlib.__all__ is a tuple (not list); class name identity checks and module name checks"
  kind: python_call_eq
  category: all_class_checks
  id_prefix: hl1261ac
  columns: [id, function, args, expected]
  rows:
    - [hl1261ac001, hashlib.__all__.__class__.__name__.__eq__,     ["tuple"],    true]
    - [hl1261ac002, hashlib.__all__.__class__.__name__.__eq__,     ["list"],     false]
    - [hl1261ac003, hashlib.__all__.__class__.__name__.__eq__,     ["set"],      false]
    - [hl1261ac004, hashlib.__all__.__class__.__name__.__eq__,     ["frozenset"],false]
    - [hl1261ac005, hashlib.__all__.__class__.__name__.__eq__,     ["dict"],     false]
    - [hl1261ac006, hashlib.__all__.__class__.__qualname__.__eq__, ["tuple"],    true]
    - [hl1261ac007, hashlib.__all__.__class__.__module__.__eq__,   ["builtins"], true]
    - [hl1261ac008, hashlib.__name__.__eq__,                       ["hashlib"],  true]
    - [hl1261ac009, hashlib.__spec__.name.__eq__,                  ["hashlib"],  true]
    - [hl1261ac010, hashlib.__all__.__len__.__class__.__name__.__eq__, ["method-wrapper"], true]

table hashlib_extra1261.algorithms_guaranteed_membership:
  description: "hashlib.algorithms_guaranteed.__contains__ membership checks — names guaranteed on all platforms (true) and names absent from guaranteed set (false)"
  kind: python_call_eq
  category: algorithms_guaranteed
  id_prefix: hl1261ag
  columns: [id, function, args, expected]
  rows:
    - [hl1261ag001, hashlib.algorithms_guaranteed.__contains__, ["sha256"],   true]
    - [hl1261ag002, hashlib.algorithms_guaranteed.__contains__, ["md5"],      true]
    - [hl1261ag003, hashlib.algorithms_guaranteed.__contains__, ["sha512"],   true]
    - [hl1261ag004, hashlib.algorithms_guaranteed.__contains__, ["sha1"],     true]
    - [hl1261ag005, hashlib.algorithms_guaranteed.__contains__, ["sha224"],   true]
    - [hl1261ag006, hashlib.algorithms_guaranteed.__contains__, ["sha3_256"], true]
    - [hl1261ag007, hashlib.algorithms_guaranteed.__contains__, ["blake2b"],  true]
    - [hl1261ag008, hashlib.algorithms_guaranteed.__contains__, ["md4"],      false]
    - [hl1261ag009, hashlib.algorithms_guaranteed.__contains__, ["sha999"],   false]
    - [hl1261ag010, hashlib.algorithms_guaranteed.__contains__, ["ripemd160"],false]
    - [hl1261ag011, hashlib.algorithms_guaranteed.__contains__, ["whirlpool"],false]
    - [hl1261ag012, hashlib.algorithms_guaranteed.__class__.__name__.__eq__, ["set"], true]
