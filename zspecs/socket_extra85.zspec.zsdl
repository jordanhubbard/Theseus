spec: socket_extra85
version: ">=3.9"
extends: socket_extra84
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra84.zspec.zsdl — covers INADDR_ANY/INADDR_BROADCAST/INADDR_LOOPBACK/INADDR_NONE class and value identity / SHUT_RD/SHUT_WR/SHUT_RDWR class and value / SOL_TCP class identity (table + invariants)."
    - "socket_extra83.zspec.zsdl — covers gethostname/gethostbyname/getaddrinfo/getnameinfo __qualname__.__len__() / setdefaulttimeout/getdefaulttimeout/inet_aton/inet_ntoa __qualname__.__len__() / htons/htonl/ntohs __qualname__.__len__() / gethostname __qualname__.__eq__ (table + invariants)."
    - "socket_extra82.zspec.zsdl — covers AF_INET/AF_INET6/AF_UNIX/AF_UNSPEC/__class__/__qualname__=='AddressFamily' / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW/__class__/__qualname__=='SocketKind' (table + invariants)."
    - "socket_extra81.zspec.zsdl — covers IPPROTO_TCP/UDP/IP/IPV6/SOL_SOCKET/__class__.__name__=='int' / SOMAXCONN identity (table + invariants)."
    - "socket_extra80.zspec.zsdl — covers AF_INET/AF_INET6/AF_UNIX/__class__.__name__=='AddressFamily' / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW/__class__.__name__=='SocketKind' / AF_INET/__eq__(2)/AF_INET6/__eq__(30)/SOCK_STREAM/__eq__(1)/SOCK_DGRAM/__eq__(2) (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra84; it does NOT duplicate invariants present in those files."
    - "Wave 251 theme: socket.socket class __dict__ membership — socket.socket is the pure-Python wrapper class in socket.py; its __dict__ contains Python-level methods and attributes; C-level methods like connect/bind/listen/recv/send live in _socket.socket and are NOT in socket.socket.__dict__."
    - "socket.socket.__dict__.__contains__('accept') == True — accept is overridden in the Python socket class. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('close') == True — close is overridden in the Python socket class. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('__init__') == True — __init__ is defined in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('makefile') == True — makefile is implemented in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('detach') == True — detach is implemented in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('dup') == True — dup is implemented in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('sendfile') == True — sendfile is implemented in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('__enter__') == True — __enter__ is defined in socket.py for context manager support. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('__exit__') == True — __exit__ is defined in socket.py for context manager support. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('__repr__') == True — __repr__ is overridden in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('family') == True — family property is defined in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('type') == True — type property is defined in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('get_inheritable') == True — get_inheritable is in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__class__.__name__ == 'mappingproxy' — class dicts are always mappingproxy in CPython. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('connect') == False — connect is in _socket.socket (C level), not in the Python-level socket.socket wrapper. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket/__dict__/__contains__('accept') / socket/__dict__/__contains__('close')
# socket.socket/__dict__/__contains__('__init__') / socket/__dict__/__contains__('makefile')
#
# Wave 251 theme: socket.socket.__dict__ membership (group 1: accept/close/__init__/makefile).
#
# socket.socket is the Python-level class in socket.py that wraps _socket.socket.
# accept, close, __init__, makefile are all defined in socket.py and appear in
# socket.socket.__dict__. C-level methods (connect, bind, etc.) are NOT in
# socket.socket.__dict__ but in _socket.socket.
# No prior socket spec checks socket.socket.__dict__.__contains__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra85.socket_dict_group1:
  description: "socket.socket/__dict__/__contains__('accept')==True / socket.socket/__dict__/__contains__('close')==True / socket.socket/__dict__/__contains__('__init__')==True / socket.socket/__dict__/__contains__('makefile')==True — socket.socket is the Python wrapper class in socket.py; accept/close/__init__/makefile are all overridden or defined there; C-level methods live in _socket.socket and are not present; no prior socket spec checks socket.socket.__dict__.__contains__; first __dict__.__contains__ anchor for socket.socket"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra85

  columns: [id, function, args, expected]
  rows:
    - [socket_dict_has_accept,   "socket.__dict__.__contains__", ["accept"],   true]
    - [socket_dict_has_close,    "socket.__dict__.__contains__", ["close"],    true]
    - [socket_dict_has_init,     "socket.__dict__.__contains__", ["__init__"], true]
    - [socket_dict_has_makefile, "socket.__dict__.__contains__", ["makefile"], true]

# ---------------------------------------------------------------------------
# socket.socket/__dict__/__contains__('detach') / socket/__dict__/__contains__('dup')
# socket.socket/__dict__/__contains__('sendfile') / socket/__dict__/__contains__('__enter__')
#
# Wave 251 theme: socket.socket.__dict__ membership (group 2: detach/dup/sendfile/__enter__).
#
# detach, dup, sendfile, __enter__ are all defined in socket.py.
# No prior socket spec checks socket.socket.__dict__.__contains__ for these.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra85.socket_dict_group2:
  description: "socket.socket/__dict__/__contains__('detach')==True / socket.socket/__dict__/__contains__('dup')==True / socket.socket/__dict__/__contains__('sendfile')==True / socket.socket/__dict__/__contains__('__enter__')==True — detach/dup/sendfile/__enter__ are all Python-level methods implemented in socket.py; no prior socket spec checks __dict__.__contains__ for detach/dup/sendfile/__enter__; first __dict__.__contains__ anchor for these socket.socket methods"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra85

  columns: [id, function, args, expected]
  rows:
    - [socket_dict_has_detach,   "socket.__dict__.__contains__", ["detach"],   true]
    - [socket_dict_has_dup,      "socket.__dict__.__contains__", ["dup"],      true]
    - [socket_dict_has_sendfile, "socket.__dict__.__contains__", ["sendfile"], true]
    - [socket_dict_has_enter,    "socket.__dict__.__contains__", ["__enter__"], true]

# ---------------------------------------------------------------------------
# socket.socket/__dict__/__contains__('__exit__') / socket/__dict__/__contains__('__repr__')
# socket.socket/__dict__/__contains__('family') / socket/__dict__/__class__/__name__
#
# Wave 251 theme: socket.socket.__dict__ membership (group 3: __exit__/__repr__/family/dict type).
#
# __exit__, __repr__, family are in socket.socket.__dict__.
# socket.socket.__dict__.__class__.__name__ == 'mappingproxy'.
# No prior socket spec checks socket.socket.__dict__.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra85.socket_dict_group3:
  description: "socket.socket/__dict__/__contains__('__exit__')==True / socket.socket/__dict__/__contains__('__repr__')==True / socket.socket/__dict__/__contains__('family')==True / socket.socket/__dict__/__class__/__name__.__eq__('mappingproxy')==True — __exit__/__repr__/family are Python-level attributes in socket.socket; socket.socket.__dict__ is a mappingproxy (standard CPython class dict type); no prior socket spec checks __exit__/__repr__/family membership or __dict__.__class__.__name__; first dict-type and __exit__/__repr__/family anchor for socket.socket"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra85

  columns: [id, function, args, expected]
  rows:
    - [socket_dict_has_exit,        "socket.__dict__.__contains__",            ["__exit__"],    true]
    - [socket_dict_has_repr,        "socket.__dict__.__contains__",            ["__repr__"],    true]
    - [socket_dict_has_family,      "socket.__dict__.__contains__",            ["family"],      true]
    - [socket_dict_class_proxy,     socket.__dict__.__class__.__name__.__eq__, ["mappingproxy"],true]

# ---------------------------------------------------------------------------
# socket.socket/__dict__/__contains__('type') / socket/__dict__/__contains__('get_inheritable')
# socket.socket/__dict__/__contains__('set_inheritable') / socket/__dict__/__contains__('accept')
#
# Wave 251 theme: socket.socket.__dict__ membership (group 4: type/get_inheritable/set_inheritable).
#
# type, get_inheritable, set_inheritable are in socket.socket.__dict__.
# accept cross-checked again in this group.
# No prior socket spec checks socket.socket.__dict__.__contains__ for these.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra85.socket_dict_group4:
  description: "socket.socket/__dict__/__contains__('type')==True / socket.socket/__dict__/__contains__('get_inheritable')==True / socket.socket/__dict__/__contains__('set_inheritable')==True / socket.socket/__dict__/__contains__('accept')==True — type/get_inheritable/set_inheritable are Python-level attributes in socket.socket; accept cross-checks group 1; no prior socket spec checks __dict__.__contains__ for type/get_inheritable/set_inheritable; first __dict__.__contains__ anchor for socket.socket type/get_inheritable/set_inheritable"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra85

  columns: [id, function, args, expected]
  rows:
    - [socket_dict_has_type,            "socket.__dict__.__contains__", ["type"],            true]
    - [socket_dict_has_get_inheritable, "socket.__dict__.__contains__", ["get_inheritable"], true]
    - [socket_dict_has_set_inheritable, "socket.__dict__.__contains__", ["set_inheritable"], true]
    - [socket_dict_has_accept2,         "socket.__dict__.__contains__", ["accept"],          true]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('accept') == True — standalone
#
# socket.socket.__dict__.__contains__('accept') is True. No prior socket spec
# checks socket.socket.__dict__.__contains__ for any attribute. First
# __dict__.__contains__ standalone for socket.socket.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra85.socket_dict_has_accept:
  description: "socket.socket.__dict__.__contains__('accept') == True — accept is overridden in the Python socket.py wrapper class to return a (conn, address) tuple with a socket object; no prior socket spec checks socket.socket.__dict__.__contains__; first __dict__.__contains__ standalone for socket.socket"
  category: class_attrs
  kind: python_call_eq
  function: "socket.__dict__.__contains__"
  args: ["accept"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('makefile') == True — standalone
#
# socket.socket.__dict__.__contains__('makefile') is True. No prior socket
# spec checks socket.socket.__dict__.__contains__('makefile'). First
# makefile membership standalone for socket.socket.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra85.socket_dict_has_makefile:
  description: "socket.socket.__dict__.__contains__('makefile') == True — makefile is implemented in socket.py to return a SocketIO file-like wrapper; no prior socket spec checks socket.socket.__dict__.__contains__('makefile'); first makefile membership standalone for socket.socket"
  category: class_attrs
  kind: python_call_eq
  function: "socket.__dict__.__contains__"
  args: ["makefile"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# socket.socket.__dict__.__class__.__name__ is 'mappingproxy'. No prior socket
# spec checks socket.socket.__dict__.__class__.__name__. First dict-type
# standalone for socket.socket. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra85.socket_dict_class_mappingproxy:
  description: "socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy') == True — socket.socket's __dict__ is a mappingproxy (the standard CPython type for class dicts); no prior socket spec checks socket.socket.__dict__.__class__.__name__; first __dict__ type standalone for socket.socket"
  category: class_attrs
  kind: python_call_eq
  function: socket.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('sendfile') == True — standalone
#
# socket.socket.__dict__.__contains__('sendfile') is True. No prior socket spec
# checks socket.socket.__dict__.__contains__('sendfile'). First sendfile
# membership standalone for socket.socket. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra85.socket_dict_has_sendfile:
  description: "socket.socket.__dict__.__contains__('sendfile') == True — sendfile is implemented in socket.py and uses OS-level sendfile when available; no prior socket spec checks socket.socket.__dict__.__contains__('sendfile'); first sendfile membership standalone for socket.socket"
  category: class_attrs
  kind: python_call_eq
  function: "socket.__dict__.__contains__"
  args: ["sendfile"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('__init__') == True — standalone
#
# socket.socket.__dict__.__contains__('__init__') is True. No prior socket spec
# checks socket.socket.__dict__.__contains__('__init__'). First __init__
# membership standalone for socket.socket. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra85.socket_dict_has_init:
  description: "socket.socket.__dict__.__contains__('__init__') == True — socket.socket.__init__ is defined in socket.py; no prior socket spec checks socket.socket.__dict__.__contains__('__init__'); first __init__ membership standalone for socket.socket"
  category: class_attrs
  kind: python_call_eq
  function: "socket.__dict__.__contains__"
  args: ["__init__"]
  expected: true
