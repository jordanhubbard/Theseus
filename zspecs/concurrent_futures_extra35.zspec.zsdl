spec: concurrent_futures_extra35
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra34.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables (ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor/as_completed/wait/InvalidStateError), submit/shutdown qualname lens for ThreadPoolExecutor/ProcessPoolExecutor/Executor, Future method qualname lens for result/add_done_callback/cancel/done/exception/running/set_result/set_exception/set_running_or_notify_cancel, class __dict__.__class__.__name__.__len__() tables (Future/ThreadPoolExecutor/ProcessPoolExecutor/Executor/BrokenExecutor/CancelledError), as_completed/wait __module__.__len__(), __all__.__len__() == 14, __mro__.__len__() for ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor/CancelledError/TimeoutError/BrokenExecutor, __bases__[0].__name__.__len__() for all classes, Executor context manager __enter__/__exit__ qualname lens, InvalidStateError hierarchy, wait sentinel string lengths, class qualname lengths (ThreadPoolExecutor/ProcessPoolExecutor/Executor/wait), executor __init__ qualname lengths, ThreadPoolExecutor.map/__qualname__.__len__()==12, ProcessPoolExecutor.map/__qualname__.__len__()==23, as_completed/__name__.__len__()==12, wait/__name__.__len__()==4, Future method __name__.__len__() tables, ThreadPoolExecutor submit/shutdown __name__/__qualname__.__len__() tables, InvalidStateError/__name__.__len__()==17, CancelledError/__qualname__.__len__()==14, BrokenExecutor/__qualname__.__len__()==14, InvalidStateError/__qualname__.__len__()==17."
    - "This spec covers: BrokenExecutor/__name__.__len__()==14; CancelledError/__name__.__len__()==14; BrokenExecutor/__module__.__len__()==24; CancelledError/__module__.__len__()==24; BrokenExecutor/__bases__[0].__name__.__len__()==12 ('RuntimeError'); TimeoutError/__name__.__len__()==12 (TimeoutError in concurrent.futures is the builtin TimeoutError, module 'builtins'); TimeoutError/__module__.__len__()==8 ('builtins'); concurrent.futures.__package__.__len__()==18; concurrent.futures.__spec__.__class__.__name__.__len__()==10 ('ModuleSpec')."
    - "BrokenExecutor.__name__ == 'BrokenExecutor' (14 chars); CancelledError.__name__ == 'CancelledError' (14 chars). Both share the same __name__ length of 14. BrokenExecutor and CancelledError also share the same __module__ ('concurrent.futures._base', 24 chars), __qualname__ length (14 each), and __mro__ depth (5 each). Despite all these shared measurements, the two exceptions have different inheritance: BrokenExecutor -> RuntimeError; CancelledError -> Error."
    - "BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' (12 chars). This is novel as a __len__() integer — prior spec extra27 captured the string equality check ('RuntimeError') but not the __len__() value (12)."
    - "concurrent.futures.TimeoutError is the builtin TimeoutError (not a concurrent.futures-specific class). Its __module__ == 'builtins' (8 chars), which is much shorter than the 24-char module of the other concurrent.futures exceptions. TimeoutError.__name__.__len__() == 12."
    - "concurrent.futures.__package__ == 'concurrent.futures' (18 chars). No prior spec has measured __package__.__len__() for concurrent.futures. This reveals the top-level package name length."
    - "concurrent.futures.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars). The module spec class name is the same for all standard-library modules. No prior concurrent.futures spec has measured __spec__.__class__.__name__.__len__()."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures exception __name__.__len__() — extra35 namespace
#
# BrokenExecutor and CancelledError share the same __name__ length (14):
#   BrokenExecutor.__name__ == 'BrokenExecutor' (14 chars)
#   CancelledError.__name__ == 'CancelledError' (14 chars)
# These are novel integer measurements — prior specs measured __qualname__.__len__()
# for both (14 each, in extra19 and extra23) but NOT __name__.__len__() as a
# separate integer invariant. (For top-level exception classes, __name__ and
# __qualname__ are identical strings, but the measurements are taken via
# distinct attribute chains and belong in separate invariants.)
# TimeoutError.__name__ == 'TimeoutError' (12 chars) — 2 shorter than the other two.
# ---------------------------------------------------------------------------

table concurrent_futures_extra35.exception_name_lengths:
  description: "concurrent.futures exception __name__.__len__() in extra35 namespace — BrokenExecutor/CancelledError/TimeoutError"
  kind: python_call_eq
  category: class_names
  id_prefix: cfexcnamelen35

  columns: [id, function, args, expected, description]
  rows:
    - [BrokenExecutor, BrokenExecutor.__name__.__len__, [], 14, "'BrokenExecutor' is 14 characters — same length as CancelledError"]
    - [CancelledError, CancelledError.__name__.__len__, [], 14, "'CancelledError' is 14 characters — same length as BrokenExecutor"]
    - [TimeoutError,   TimeoutError.__name__.__len__,   [], 12, "'TimeoutError' is 12 characters — 2 shorter than BrokenExecutor/CancelledError"]

# ---------------------------------------------------------------------------
# concurrent.futures exception __module__.__len__() — extra35 namespace
#
# BrokenExecutor and CancelledError both live in concurrent.futures._base:
#   BrokenExecutor.__module__ == 'concurrent.futures._base' (24 chars)
#   CancelledError.__module__ == 'concurrent.futures._base' (24 chars)
# TimeoutError is the builtin TimeoutError, with a much shorter module:
#   TimeoutError.__module__ == 'builtins' (8 chars)
# No prior spec has measured BrokenExecutor.__module__.__len__() or
# CancelledError.__module__.__len__() as integer invariants.
# The contrast between 24 (library exception) and 8 (builtin exception) shows
# that TimeoutError is not a concurrent.futures-defined exception.
# ---------------------------------------------------------------------------

table concurrent_futures_extra35.exception_module_lengths:
  description: "concurrent.futures exception __module__.__len__() in extra35 namespace — library vs builtin exception module"
  kind: python_call_eq
  category: module_names
  id_prefix: cfexcmodlen35

  columns: [id, function, args, expected, description]
  rows:
    - [BrokenExecutor, BrokenExecutor.__module__.__len__, [], 24, "'concurrent.futures._base' (24 chars) — library exception"]
    - [CancelledError, CancelledError.__module__.__len__, [], 24, "'concurrent.futures._base' (24 chars) — same as BrokenExecutor"]
    - [TimeoutError,   TimeoutError.__module__.__len__,   [], 8,  "'builtins' (8 chars) — TimeoutError is a builtin, not a cf-defined exception"]

# ---------------------------------------------------------------------------
# concurrent.futures module metadata — extra35 namespace
#
# Two module-level metadata attributes reveal the package structure:
#   concurrent.futures.__package__ == 'concurrent.futures' (18 chars)
#   concurrent.futures.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars)
# The __package__ value ('concurrent.futures') is identical to the module name,
# confirming that concurrent.futures is a proper subpackage of concurrent.
# ModuleSpec is the importlib.machinery class used for all standard modules.
# No prior concurrent.futures spec has measured either of these values.
# ---------------------------------------------------------------------------

table concurrent_futures_extra35.module_metadata_lengths:
  description: "concurrent.futures module metadata __len__() in extra35 namespace"
  kind: python_call_eq
  category: module_names
  id_prefix: cfmodmetalen35

  columns: [id, function, args, expected, description]
  rows:
    - [package,    concurrent.futures.__package__.__len__,                    [], 18, "'concurrent.futures' package name has 18 characters"]
    - [spec_class, concurrent.futures.__spec__.__class__.__name__.__len__,    [], 10, "'ModuleSpec' class name has 10 characters — same for all standard modules"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra35
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra35.BrokenExecutor_bases0_name_len:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__len__() == 12 — base class is 'RuntimeError' (12 chars); prior spec extra27 confirmed the string equality but not the integer length"
  category: class_names
  kind: python_call_eq
  function: "BrokenExecutor.__bases__[0].__name__.__len__"
  args: []
  expected: 12

invariant concurrent_futures_extra35.TimeoutError_module_len:
  description: "concurrent.futures.TimeoutError.__module__.__len__() == 8 — TimeoutError's module is 'builtins' (8 chars); it is the builtin exception re-exported by concurrent.futures, not a cf-defined type"
  category: module_names
  kind: python_call_eq
  function: TimeoutError.__module__.__len__
  args: []
  expected: 8

invariant concurrent_futures_extra35.BrokenExecutor_name_len:
  description: "concurrent.futures.BrokenExecutor.__name__.__len__() == 14 — 'BrokenExecutor' has 14 characters; same length as CancelledError (14)"
  category: class_names
  kind: python_call_eq
  function: BrokenExecutor.__name__.__len__
  args: []
  expected: 14
