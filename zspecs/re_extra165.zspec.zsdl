spec: re_extra165
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.Pattern.__copy__ and re.Match.__copy__ qualnames, re.Match method qualnames (group, groups, span, end), and re.PatternError class identity."
    - "re.Pattern.__copy__.__qualname__ == 'Pattern.__copy__' (len=16; 'Pattern.' (8) + '__copy__' (8) = 16)."
    - "re.Match.__copy__.__qualname__ == 'Match.__copy__' (len=14; 'Match.' (6) + '__copy__' (8) = 14)."
    - "re.Pattern.__deepcopy__.__qualname__ == 'Pattern.__deepcopy__' (len=20; 'Pattern.' (8) + '__deepcopy__' (12) = 20)."
    - "re.Match.__deepcopy__.__qualname__ == 'Match.__deepcopy__' (len=18; 'Match.' (6) + '__deepcopy__' (12) = 18)."
    - "re.Match.end.__qualname__ == 'Match.end' (len=9; 'Match.' (6) + 'end' (3) = 9)."
    - "re.Match.span.__qualname__ == 'Match.span' (len=10; 'Match.' (6) + 'span' (4) = 10)."
    - "re.Match.group.__qualname__ == 'Match.group' (len=11; 'Match.' (6) + 'group' (5) = 11)."
    - "re.Match.groups.__qualname__ == 'Match.groups' (len=12; 'Match.' (6) + 'groups' (6) = 12)."
    - "re.PatternError.__name__ == 'PatternError' (len=12; formerly known as re.error, renamed in Python 3.13)."
    - "re.PatternError.__module__ == 're' (len=2)."
    - "re.PatternError.__bases__[0].__name__ == 'Exception' (len=9)."
    - "re.error is re.PatternError: True — re.error is an alias for backward compatibility."
    - "re.Pattern.__name__ == 'Pattern' (len=7); re.Match.__name__ == 'Match' (len=5)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern and re.Match __copy__ / __deepcopy__ qualnames
# Pattern.__copy__ (len=16), Match.__copy__ (len=14)
# Pattern.__deepcopy__ (len=20), Match.__deepcopy__ (len=18)
# The 2-char difference between Pattern (7) and Match (5) prefixes propagates
# ---------------------------------------------------------------------------

table re_extra165.Pattern_Match_copy_qualnames:
  description: "re.Pattern and re.Match __copy__ and __deepcopy__ qualnames: Pattern.__copy__ (len=16), Match.__copy__ (len=14), Pattern.__deepcopy__ (len=20), Match.__deepcopy__ (len=18); Pattern prefix (8 chars) > Match prefix (6 chars) by 2 throughout"
  kind: python_call_eq
  category: qualname
  id_prefix: req165

  columns: [id, function, args, expected, description]
  rows:
    - [pat_copy_qeq,       "re.Pattern.__copy__.__qualname__.__eq__",      ["Pattern.__copy__"],      true, "re.Pattern.__copy__.__qualname__ == 'Pattern.__copy__' (Pattern.__copy__() is directly defined in re.Pattern.__dict__; it supports the copy.copy() protocol for shallow-copying compiled pattern objects; 'Pattern.__copy__' has 16 characters: 'Pattern.' (8) + '__copy__' (8) = 16; the prefix 'Pattern.' (8 chars) equals the dunder '__copy__' (8 chars) in length — a symmetric qualname; Pattern.__copy__ (16) is 2 characters longer than Match.__copy__ (14) because the 'Pattern.' prefix (8 chars) is 2 longer than the 'Match.' prefix (6 chars); __copy__ is one of only a few dunders defined directly on Pattern)"]
    - [match_copy_qeq,     "re.Match.__copy__.__qualname__.__eq__",        ["Match.__copy__"],        true, "re.Match.__copy__.__qualname__ == 'Match.__copy__' (Match.__copy__() is directly defined in re.Match.__dict__; it supports the copy.copy() protocol for Match objects; 'Match.__copy__' has 14 characters: 'Match.' (6) + '__copy__' (8) = 14; Match.__copy__ (14) is 2 characters shorter than Pattern.__copy__ (16) because 'Match.' (6 chars) < 'Pattern.' (8 chars) by 2; 'Match' (5 chars) < 'Pattern' (7 chars) by 2 — and this 2-character difference propagates to all corresponding qualname lengths: both copy and deepcopy qualnames are consistently 2 longer for Pattern than for Match)"]
    - [pat_deepcopy_qeq,   "re.Pattern.__deepcopy__.__qualname__.__eq__",  ["Pattern.__deepcopy__"],  true, "re.Pattern.__deepcopy__.__qualname__ == 'Pattern.__deepcopy__' (Pattern.__deepcopy__() supports the copy.deepcopy() protocol; 'Pattern.__deepcopy__' has 20 characters: 'Pattern.' (8) + '__deepcopy__' (12) = 20; length 20 matches the BufferedWriter.write qualname length from io_extra168 — a coincidental tie; Pattern.__deepcopy__ (20) is the longest qualname in this table; '__deepcopy__' (12 chars) is 4 characters longer than '__copy__' (8 chars) due to the 'deep' prefix (4 chars) inside the dunder name; the 2-char gap between Pattern and Match versions is maintained: Pattern.__deepcopy__ (20) vs Match.__deepcopy__ (18))"]
    - [match_deepcopy_qeq, "re.Match.__deepcopy__.__qualname__.__eq__",    ["Match.__deepcopy__"],    true, "re.Match.__deepcopy__.__qualname__ == 'Match.__deepcopy__' (Match.__deepcopy__() supports the copy.deepcopy() protocol for Match objects; 'Match.__deepcopy__' has 18 characters: 'Match.' (6) + '__deepcopy__' (12) = 18; Match.__deepcopy__ (18) is 2 shorter than Pattern.__deepcopy__ (20), consistent with the 2-character prefix length difference; the consistent 2-char gap arises because 'Pattern' (7 chars) and 'Match' (5 chars) differ by exactly 2, and all method qualnames add the '.' separator and method dunder equally; confirmed Python 3.14.3 macOS)"]

# ---------------------------------------------------------------------------
# re.Match method qualnames: end, span, group, groups
# end (len=9), span (len=10), group (len=11), groups (len=12)
# All ascending in length with the 'Match.' prefix (6 chars)
# ---------------------------------------------------------------------------

table re_extra165.Match_method_qualnames:
  description: "re.Match method qualnames: end='Match.end' (len=9), span='Match.span' (len=10), group='Match.group' (len=11), groups='Match.groups' (len=12); ascending lengths for 3/4/5/6-char method names under 'Match.' prefix (6 chars)"
  kind: python_call_eq
  category: qualname
  id_prefix: req165

  columns: [id, function, args, expected, description]
  rows:
    - [match_end_qeq,    re.Match.end.__qualname__.__eq__,    ["Match.end"],    true, "re.Match.end.__qualname__ == 'Match.end' (Match.end() returns the index of the end of the substring matched by the group; Match.end(0) or Match.end() returns the end of the entire match; 'Match.end' has 9 characters: 'Match.' (6) + 'end' (3) = 9; end (9) is the shortest Match method qualname in this table — 'end' is a 3-character method name; the complete ascending sequence in this table: end=9, span=10, group=11, groups=12; each adds one character to the method name; 'Match.end' (9) compares with 'Match.pos' (also 9) if pos were checked — both 3-char method names)"]
    - [match_span_qeq,   re.Match.span.__qualname__.__eq__,   ["Match.span"],   true, "re.Match.span.__qualname__ == 'Match.span' (Match.span() returns a 2-tuple (m.start(group), m.end(group)) for a group; Match.span(0) or Match.span() returns the span of the entire match; 'Match.span' has 10 characters: 'Match.' (6) + 'span' (4) = 10; span (10) sits between end (9) and group (11) in the ascending sequence; 'span' is a 4-character method name — one longer than 'end' (3) and one shorter than 'group' (5); the 10-character qualname 'Match.span' equals re.Match.__name__.__len__() (5) + len('.') (1) + len('span') (4) = 10)"]
    - [match_group_qeq,  re.Match.group.__qualname__.__eq__,  ["Match.group"],  true, "re.Match.group.__qualname__ == 'Match.group' (Match.group() is the primary method for extracting matched text; Match.group(0) returns the entire match; Match.group(1) returns the first captured group; 'Match.group' has 11 characters: 'Match.' (6) + 'group' (5) = 11; group (11) sits between span (10) and groups (12) in the ascending sequence; 'group' is a 5-character method name — one longer than 'span' (4) and one shorter than 'groups' (6); group() vs groups(): group returns one group, groups() returns all groups as a tuple; 'Match.group' (11) vs 'Match.groups' (12) differ by exactly one character — the final 's')"]
    - [match_groups_qeq, re.Match.groups.__qualname__.__eq__, ["Match.groups"], true, "re.Match.groups.__qualname__ == 'Match.groups' (Match.groups() returns a tuple of all matched groups; Match.groups(default=None) sets the value for groups that did not participate in the match; 'Match.groups' has 12 characters: 'Match.' (6) + 'groups' (6) = 12; groups (12) is the longest Match method qualname in this table; 'groups' is a 6-character method name — one longer than 'group' (5); the complete ascending sequence: end=9, span=10, group=11, groups=12 — four consecutive lengths differing by 1; the 'Match.' prefix (6 chars) equals the 'groups' method name (6 chars) in length — a symmetric qualname for Match.groups)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra165.PatternError_name_is_PatternError:
  description: "re.PatternError.__name__ == 'PatternError' — re.PatternError (the exception class for invalid patterns) was renamed from re.error to re.PatternError in Python 3.13; re.error is now an alias for backward compatibility (re.error is re.PatternError == True); 'PatternError' has 12 characters: 'Pattern' (7) + 'Error' (5) = 12; re.PatternError.__module__ == 're' (2 chars); re.PatternError.__bases__[0].__name__ == 'Exception'; 'PatternError' (12 chars) is longer than 'Pattern' (7 chars) — the error class name includes the 'Error' suffix; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.PatternError.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra165.Match_copy_qualname_len_14:
  description: "re.Match.__copy__.__qualname__.__len__() == 14 — 'Match.__copy__' has 14 characters: 'Match.' (6) + '__copy__' (8) = 14; Match.__copy__ (14) is 2 shorter than Pattern.__copy__ (16) because 'Match.' (6) < 'Pattern.' (8) by 2 characters; the 2-character gap between Pattern and Match qualname lengths is consistent across both __copy__ (14 vs 16) and __deepcopy__ (18 vs 20); __copy__ (14) is the shorter of the two copy-protocol dunders on Match; 'Match.__copy__' (14) equals io.FileIO.readall qualname length (also 14) — a coincidental cross-module tie; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "re.Match.__copy__.__qualname__.__len__"
  args: []
  expected: 14

invariant re_extra165.Pattern_deepcopy_qualname_len_20:
  description: "re.Pattern.__deepcopy__.__qualname__.__len__() == 20 — 'Pattern.__deepcopy__' has 20 characters: 'Pattern.' (8) + '__deepcopy__' (12) = 20; Pattern.__deepcopy__ (20) is the longest qualname in this spec; 20 also equals io.BufferedWriter.write qualname length (from io_extra168) — a coincidental cross-module tie at length 20; '__deepcopy__' (12 chars) is exactly 4 longer than '__copy__' (8 chars) because 'deep' (4 chars) is prepended inside the dunder; Pattern.__deepcopy__ (20) > Match.__deepcopy__ (18) > Pattern.__copy__ (16) > Match.__copy__ (14) — all four copy-protocol qualnames are even numbers separated by 2; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "re.Pattern.__deepcopy__.__qualname__.__len__"
  args: []
  expected: 20

invariant re_extra165.Match_end_span_group_groups_ascending:
  description: "re.Match.end.__qualname__.__len__() == 9 — 'Match.end' has 9 characters: 'Match.' (6) + 'end' (3) = 9; the four Match method qualnames in this spec form a strictly ascending sequence: end=9, span=10, group=11, groups=12; each successive method name is exactly one character longer ('end' 3, 'span' 4, 'group' 5, 'groups' 6) causing qualname lengths to increase by exactly 1 at each step; the four lengths 9, 10, 11, 12 are four consecutive integers — a rare arithmetic sequence of four distinct Match method qualname lengths; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: re.Match.end.__qualname__.__len__
  args: []
  expected: 9
