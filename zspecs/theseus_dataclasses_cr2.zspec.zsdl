spec: theseus_dataclasses_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_dataclasses_cr2)
blocks: dataclasses

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html"
  notes:
    - "Clean-room extended dataclass utilities. Do NOT import dataclasses."
    - "asdict(instance): recursively convert dataclass to dict."
    - "astuple(instance): recursively convert dataclass to tuple."
    - "replace(instance, **changes): create new instance with some fields replaced."
    - "dataclasses2_asdict(): asdict(Point(x=1,y=2)) == {'x':1,'y':2}."
    - "dataclasses2_astuple(): astuple(Point(x=1,y=2)) == (1,2)."
    - "dataclasses2_replace(): replace(Point(1,2), y=99).y == 99."
    - "Export: asdict, astuple, replace (extending theseus_dataclasses_utils)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_dataclasses_cr2.asdict:
  description: "asdict(Point(x=1,y=2)) == {'x':1,'y':2}"
  category: asdict
  kind: python_call_eq
  function: dataclasses2_asdict
  args: []
  expected: {"x": 1, "y": 2}

invariant theseus_dataclasses_cr2.astuple:
  description: "astuple(Point(x=1,y=2)) == (1,2)"
  category: astuple
  kind: python_call_eq
  function: dataclasses2_astuple
  args: []
  expected: [1, 2]

invariant theseus_dataclasses_cr2.replace:
  description: "replace(Point(1,2), y=99).y == 99"
  category: replace
  kind: python_call_eq
  function: dataclasses2_replace
  args: []
  expected: 99
