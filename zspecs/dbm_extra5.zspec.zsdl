spec: dbm_extra5
version: ">=3.9"
backend: python_module(dbm)

docs: https://docs.python.org/3/library/dbm.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dbm.html — Python dbm module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dbm/__init__.py"
  notes:
    - "This spec extends dbm.zspec.zsdl through dbm_extra4.zspec.zsdl with new, non-duplicate invariants."
    - "dbm.zspec.zsdl covers: open/__name__, whichdb/__name__, whichdb nonexistent returns None, error is tuple."
    - "dbm_extra covers: open/__name__; whichdb/__name__/__module__/is_function; error/__name__/__module__/is_type/base_is_OSError/bases_len; dumb/__name__/open_name/error_name."
    - "dbm_extra2 covers: dbm.__name__; dbm.__package__; open class is not None; dumb.open/__module__; dumb._Database/__name__/__module__; ndbm/__name__; attr_names table."
    - "dbm_extra3 covers: __qualname__ for open, whichdb, error; _names.__class__.__name__ == 'list'."
    - "dbm_extra4 covers: open/__module__; open/__doc__ type; dumb.error/__module__; _names[0] type; error/__mro__ length."
    - "This spec adds four new axes: dumb._Database.__bases__[0].__name__; dumb.__package__; _names.__len__; dumb.open.__qualname__."
    - "dbm.dumb._Database inherits from object; no prior spec checks _Database.__bases__[0].__name__."
    - "dbm.dumb.__package__ == 'dbm' — the dumb submodule belongs to the dbm package; not checked in any prior spec."
    - "len(dbm._names) >= 1 — _names is a non-empty list of backend module name strings; only type checked before."
    - "dbm.dumb.open.__qualname__ == 'open' — qualname for module-level dumb.open; not previously checked (dbm_extra checks __name__ only)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# dbm.dumb._Database.__bases__[0].__name__
#
# dbm_extra2 checks dumb._Database.__name__ == '_Database' and
# dumb._Database.__module__ == 'dbm.dumb'.
# No prior spec checks the base class of _Database.
# _Database inherits directly from object (pure Python class with no mixin).
# ---------------------------------------------------------------------------

invariant dbm_extra5.dumb._Database.base_is_object:
  description: "dbm.dumb._Database.__bases__[0].__name__ == 'object' — _Database inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: dumb._Database.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# dbm.dumb.__package__
#
# dbm_extra2 checks dbm.__package__ == 'dbm' (for the top-level module).
# No prior spec checks dumb.__package__.
# dbm.dumb is a submodule of dbm, so its __package__ == 'dbm'.
# ---------------------------------------------------------------------------

invariant dbm_extra5.dumb.package:
  description: "dbm.dumb.__package__ == 'dbm' — dumb belongs to the dbm package"
  category: submodules
  kind: python_call_eq
  function: dumb.__package__.__eq__
  args: ["dbm"]
  expected: true

# ---------------------------------------------------------------------------
# dbm._names.__len__
#
# dbm_extra3 checks _names.__class__.__name__ == 'list'.
# dbm_extra4 checks _names[0].__class__.__name__ == 'str'.
# No prior spec checks the length of _names.
# _names lists the backend module names tried in order; always >= 1 on
# any CPython build (at minimum 'dbm.sqlite3' or 'dbm.dumb' is present).
# ---------------------------------------------------------------------------

invariant dbm_extra5._names.len_ge_1:
  description: "len(dbm._names) >= 1 — _names is a non-empty list of backend strings"
  category: module_attrs
  kind: python_call_eq
  function: _names.__len__
  args: []
  method: __ge__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# dbm.dumb.open.__qualname__
#
# dbm_extra checks dumb.open.__name__ == 'open'.
# dbm_extra2 checks dumb.open.__module__ == 'dbm.dumb'.
# No prior spec checks dumb.open.__qualname__.
# For a module-level function, __qualname__ == __name__ == 'open'.
# ---------------------------------------------------------------------------

invariant dbm_extra5.dumb.open.qualname:
  description: "dbm.dumb.open.__qualname__ == 'open' — module-level function qualname"
  category: submodules
  kind: python_call_eq
  function: dumb.open.__qualname__.__eq__
  args: ["open"]
  expected: true
