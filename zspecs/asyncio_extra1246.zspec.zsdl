spec: asyncio_extra1246
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio __doc__ class checks for module, Queue, Task, Future, Lock, Event, Semaphore, BoundedSemaphore, StreamWriter, Barrier, TaskGroup, Runner"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks that asyncio module and key classes have str __doc__ attributes (not NoneType); asyncio.StreamReader.__doc__ is NoneType so it appears only in the false-NoneType table; distinct from extra1231 (__dict__.__contains__), extra1201 (__bases__/__mro__ lengths), extra1216 (__mro__.__len__ per class)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra1246.module_and_sync_class_doc_class:
  description: "asyncio module __doc__ and synchronization class __doc__ have class name 'str'"
  kind: python_call_eq
  category: doc_class
  id_prefix: as1246ms
  columns: [id, function, args, expected]
  rows:
    - [as1246ms001, asyncio.__doc__.__class__.__name__.__eq__,                ["str"], true]
    - [as1246ms002, asyncio.Queue.__doc__.__class__.__name__.__eq__,          ["str"], true]
    - [as1246ms003, asyncio.Task.__doc__.__class__.__name__.__eq__,           ["str"], true]
    - [as1246ms004, asyncio.Future.__doc__.__class__.__name__.__eq__,         ["str"], true]
    - [as1246ms005, asyncio.Lock.__doc__.__class__.__name__.__eq__,           ["str"], true]
    - [as1246ms006, asyncio.Event.__doc__.__class__.__name__.__eq__,          ["str"], true]
    - [as1246ms007, asyncio.Semaphore.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [as1246ms008, asyncio.BoundedSemaphore.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [as1246ms009, asyncio.Barrier.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [as1246ms010, asyncio.TaskGroup.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [as1246ms011, asyncio.Runner.__doc__.__class__.__name__.__eq__,         ["str"], true]
    - [as1246ms012, asyncio.StreamWriter.__doc__.__class__.__name__.__eq__,   ["str"], true]

table asyncio_extra1246.doc_class_not_nonetype:
  description: "asyncio module __doc__ and key classes __doc__ class name is NOT 'NoneType'"
  kind: python_call_eq
  category: doc_class
  id_prefix: as1246nn
  columns: [id, function, args, expected]
  rows:
    - [as1246nn001, asyncio.__doc__.__class__.__name__.__eq__,                ["NoneType"], false]
    - [as1246nn002, asyncio.Queue.__doc__.__class__.__name__.__eq__,          ["NoneType"], false]
    - [as1246nn003, asyncio.Task.__doc__.__class__.__name__.__eq__,           ["NoneType"], false]
    - [as1246nn004, asyncio.Future.__doc__.__class__.__name__.__eq__,         ["NoneType"], false]
    - [as1246nn005, asyncio.Lock.__doc__.__class__.__name__.__eq__,           ["NoneType"], false]
    - [as1246nn006, asyncio.Event.__doc__.__class__.__name__.__eq__,          ["NoneType"], false]
    - [as1246nn007, asyncio.Semaphore.__doc__.__class__.__name__.__eq__,      ["NoneType"], false]
    - [as1246nn008, asyncio.BoundedSemaphore.__doc__.__class__.__name__.__eq__, ["NoneType"], false]
    - [as1246nn009, asyncio.Barrier.__doc__.__class__.__name__.__eq__,        ["NoneType"], false]
    - [as1246nn010, asyncio.TaskGroup.__doc__.__class__.__name__.__eq__,      ["NoneType"], false]
    - [as1246nn011, asyncio.Runner.__doc__.__class__.__name__.__eq__,         ["NoneType"], false]
    - [as1246nn012, asyncio.StreamWriter.__doc__.__class__.__name__.__eq__,   ["NoneType"], false]

table asyncio_extra1246.streamreader_no_doc_and_doc_class_name:
  description: "asyncio.StreamReader.__doc__ is NoneType (no docstring); module and Queue __doc__ class name is not int or float"
  kind: python_call_eq
  category: doc_class
  id_prefix: as1246sr
  columns: [id, function, args, expected]
  rows:
    - [as1246sr001, asyncio.StreamReader.__doc__.__class__.__name__.__eq__, ["NoneType"], true]
    - [as1246sr002, asyncio.StreamReader.__doc__.__class__.__name__.__eq__, ["str"],      false]
    - [as1246sr003, asyncio.__doc__.__class__.__name__.__eq__,              ["int"],      false]
    - [as1246sr004, asyncio.__doc__.__class__.__name__.__eq__,              ["float"],    false]
    - [as1246sr005, asyncio.Queue.__doc__.__class__.__name__.__eq__,        ["int"],      false]
    - [as1246sr006, asyncio.Task.__doc__.__class__.__name__.__eq__,         ["int"],      false]
    - [as1246sr007, asyncio.Future.__doc__.__class__.__name__.__eq__,       ["int"],      false]
    - [as1246sr008, asyncio.Lock.__doc__.__class__.__name__.__eq__,         ["int"],      false]
    - [as1246sr009, asyncio.Event.__doc__.__class__.__name__.__eq__,        ["int"],      false]
    - [as1246sr010, asyncio.Semaphore.__doc__.__class__.__name__.__eq__,    ["int"],      false]
