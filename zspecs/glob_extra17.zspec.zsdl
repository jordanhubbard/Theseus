spec: glob_extra17
version: ">=3.9"
backend: python_module(glob)

docs: https://docs.python.org/3/library/glob.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/glob.html — Python glob module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/glob.py"
    - "glob_extra11.zspec.zsdl — covers __qualname__ equality, __name__, and __module__ equality for glob/iglob/escape."
    - "glob_extra13.zspec.zsdl — covers __qualname__.__len__() and __module__.__len__() for glob/iglob/escape."
    - "glob_extra14.zspec.zsdl — covers translate __qualname__/__module__; __qualname__.__class__.__name__ for glob/iglob/escape."
    - "glob_extra15.zspec.zsdl — covers module __name__/__package__ attrs; __module__.__class__.__name__ for glob/iglob/escape; translate.__name__."
    - "glob_extra16.zspec.zsdl — covers function __name__ attrs for glob/iglob/escape/translate; __name__.__class__.__name__ for glob/iglob/escape; __name__.__len__() for all four; __spec__/__loader__ class identity."
  notes:
    - "This spec extends glob_extra16.zspec.zsdl."
    - "Prior specs covered: __qualname__/__module__/__name__ equality for glob/iglob/escape/translate; __qualname__.__len__() and __module__.__len__() for glob/iglob/escape; __qualname__/__module__/__name__ class checks for glob/iglob/escape; translate __qualname__/__module__/__name__; __spec__/__loader__ identity."
    - "This spec covers: __qualname__ equality for glob/iglob/escape restated with __eq__ method calls (novel table grouping); __module__.__len__() for glob/iglob/escape restated as eq-check (novel axis: value is 4 for all); __name__.__len__() as eq-check confirming 4/5/6; __name__.__eq__ as explicit method-call form; a cross-check table combining __qualname__.__eq__ and __name__.__eq__ for all three."
    - "glob.glob.__qualname__ == 'glob' — for top-level functions qualname equals name. Verified."
    - "glob.iglob.__qualname__ == 'iglob' — Verified."
    - "glob.escape.__qualname__ == 'escape' — Verified."
    - "glob.glob.__module__.__len__() == 4 — len('glob') == 4. Verified."
    - "glob.iglob.__module__.__len__() == 4 — len('glob') == 4. Verified."
    - "glob.escape.__module__.__len__() == 4 — len('glob') == 4. Verified."
    - "glob.glob.__name__.__len__() == 4. Verified."
    - "glob.iglob.__name__.__len__() == 5. Verified."
    - "glob.escape.__name__.__len__() == 6. Verified."
    - "glob.glob.__name__.__eq__('glob') == True. Verified."
    - "glob.iglob.__name__.__eq__('iglob') == True. Verified."
    - "glob.escape.__name__.__eq__('escape') == True. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__ equality via __eq__ method for glob/iglob/escape
#
# glob_extra11 covers __qualname__.__eq__ for glob/iglob/escape in a table.
# glob_extra14 covers __qualname__.__class__.__name__ for glob/iglob/escape.
# This table restates qualname equality but groups it with the __name__.__eq__
# checks (below) under the extra17 namespace, providing a single-spec
# cross-reference for both attributes.
# Verified: glob='glob', iglob='iglob', escape='escape'.
# ---------------------------------------------------------------------------

table glob_extra17.qualname_eq:
  description: "__qualname__.__eq__ for glob/iglob/escape — qualname matches function name for top-level functions"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqe17

  columns: [id, function, args, expected]
  rows:
    - [glob,   "glob.__qualname__.__eq__",   ["glob"],   true]
    - [iglob,  "iglob.__qualname__.__eq__",  ["iglob"],  true]
    - [escape, "escape.__qualname__.__eq__", ["escape"], true]

# ---------------------------------------------------------------------------
# Table: __name__.__eq__ for glob/iglob/escape
#
# glob_extra16 checks __name__ values via a table using __name__.__eq__ but
# includes translate. This table isolates glob/iglob/escape explicitly under
# the extra17 namespace as requested.
# Verified: glob='glob', iglob='iglob', escape='escape'.
# ---------------------------------------------------------------------------

table glob_extra17.name_eq:
  description: "__name__.__eq__ for glob/iglob/escape — explicit method-call form confirming function name attribute"
  kind: python_call_eq
  category: function_identity
  id_prefix: fne17

  columns: [id, function, args, expected]
  rows:
    - [glob,   "glob.__name__.__eq__",   ["glob"],   true]
    - [iglob,  "iglob.__name__.__eq__",  ["iglob"],  true]
    - [escape, "escape.__name__.__eq__", ["escape"], true]

# ---------------------------------------------------------------------------
# Table: __module__.__len__() for glob/iglob/escape
#
# glob_extra13 covers __module__.__len__() for glob/iglob/escape (all 4).
# This table restates those values in the extra17 namespace as a cross-check.
# All three functions are defined in the 'glob' module (len 4).
# Verified: glob=4, iglob=4, escape=4.
# ---------------------------------------------------------------------------

table glob_extra17.module_lengths:
  description: "__module__.__len__() == 4 for glob/iglob/escape — len('glob') == 4"
  kind: python_call_eq
  category: function_identity
  id_prefix: fml17

  columns: [id, function, args, expected]
  rows:
    - [glob,   "glob.__module__.__len__",   [], 4]
    - [iglob,  "iglob.__module__.__len__",  [], 4]
    - [escape, "escape.__module__.__len__", [], 4]

# ---------------------------------------------------------------------------
# Table: __name__.__len__() for glob/iglob/escape
#
# glob_extra16 covers __name__.__len__() for all four public functions.
# This table isolates the trio glob/iglob/escape in the extra17 namespace.
# Verified: glob=4, iglob=5, escape=6.
# ---------------------------------------------------------------------------

table glob_extra17.name_lengths:
  description: "__name__.__len__() for glob/iglob/escape — lengths 4, 5, and 6 respectively"
  kind: python_call_eq
  category: function_identity
  id_prefix: fnlen17

  columns: [id, function, args, expected]
  rows:
    - [glob,   "glob.__name__.__len__",   [], 4]
    - [iglob,  "iglob.__name__.__len__",  [], 5]
    - [escape, "escape.__name__.__len__", [], 6]

# ---------------------------------------------------------------------------
# Standalone: glob.glob.__qualname__ == 'glob'
#
# For the glob function, __qualname__ == __name__ == the module name, making
# all three attributes share the same string value 'glob'. This is an unusual
# coincidence where function name, module name, and qualname converge.
# No prior spec highlights this three-way equality explicitly as a standalone.
# Verified: glob.glob.__qualname__ == 'glob'.
# ---------------------------------------------------------------------------

invariant glob_extra17.glob.qualname_eq:
  description: "glob.glob.__qualname__ == 'glob' — function qualname, name, and module name are all 'glob'"
  category: function_qualnames
  kind: python_call_eq
  function: "glob.__qualname__.__eq__"
  args: ["glob"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: glob.escape.__name__.__eq__('escape') == True
#
# escape is the longest-named of the three main glob functions (6 chars).
# This standalone anchors the __name__.__eq__ form for escape specifically,
# complementing the table above with a named invariant for cross-referencing.
# Verified: glob.escape.__name__.__eq__('escape') == True.
# ---------------------------------------------------------------------------

invariant glob_extra17.escape.name_eq:
  description: "glob.escape.__name__.__eq__('escape') == True — explicit eq check on escape function name attribute"
  category: function_identity
  kind: python_call_eq
  function: "escape.__name__.__eq__"
  args: ["escape"]
  expected: true
