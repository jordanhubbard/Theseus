  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.UUID.version.fget.__qualname__ == 'UUID.version' — property getter qualname."
    - "uuid.UUID.variant.fget.__qualname__ == 'UUID.variant' — property getter qualname."
    - "uuid.UUID.node.fget.__qualname__ == 'UUID.node' — property getter qualname."
    - "uuid.UUID.hex.fget.__qualname__ == 'UUID.hex' — property getter qualname."
    - "uuid.UUID.bytes.fget.__qualname__ == 'UUID.bytes' — property getter qualname."
    - "uuid.UUID.urn.fget.__qualname__ == 'UUID.urn' — property getter qualname."
    - "uuid.UUID.fields.fget.__qualname__ == 'UUID.fields' — property getter qualname."
    - "uuid.UUID.version.fget.__name__ == 'version' — property getter __name__ equals the property name."
    - "uuid.UUID.variant.fget.__name__ == 'variant' — property getter __name__ equals the property name."
    - "uuid.UUID.node.fget.__name__ == 'node' — property getter __name__ equals the property name."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID property fget qualname contracts — version/variant/node
#
# uuid.UUID.version.fget.__qualname__ == 'UUID.version'
# uuid.UUID.variant.fget.__qualname__ == 'UUID.variant'
# uuid.UUID.node.fget.__qualname__    == 'UUID.node'
#
# These are properties on the UUID class defined in Lib/uuid.py. Each
# property's fget attribute is the getter function. Its __qualname__
# uses the 'UUID.' class prefix. version reports the UUID version (1-5);
# variant reports the UUID variant (RESERVED_NCS, RFC_4122, etc.);
# node reports the 48-bit hardware address component of a version-1 UUID.
# ---------------------------------------------------------------------------

table uuid_extra224.uuid_property_qualnames_group1:
  description: "UUID.version.fget.__qualname__=='UUID.version'; UUID.variant.fget.__qualname__=='UUID.variant'; UUID.node.fget.__qualname__=='UUID.node'; property fget qualname contracts; new to extra224"
  kind: python_call_eq
  category: identity
  id_prefix: uuid224

  columns: [id, function, args, expected, description]
  rows:
    - [version_fget_qualname_eq,
       "UUID.version.fget.__qualname__.__eq__",
       ["UUID.version"],
       true,
       "uuid.UUID.version.fget.__qualname__.__eq__('UUID.version') == True — version reports the UUID version number (1-5); fget qualname is 'UUID.version' (11 characters); new anchor in extra224 namespace; verified Python 3.14.3"]
    - [variant_fget_qualname_eq,
       "UUID.variant.fget.__qualname__.__eq__",
       ["UUID.variant"],
       true,
       "uuid.UUID.variant.fget.__qualname__.__eq__('UUID.variant') == True — variant reports the UUID variant (RFC_4122, RESERVED_NCS, etc.); fget qualname is 'UUID.variant' (12 characters); new anchor in extra224 namespace; verified Python 3.14.3"]
    - [node_fget_qualname_eq,
       "UUID.node.fget.__qualname__.__eq__",
       ["UUID.node"],
       true,
       "uuid.UUID.node.fget.__qualname__.__eq__('UUID.node') == True — node holds the 48-bit hardware address component for version-1 UUIDs; fget qualname is 'UUID.node' (9 characters); new anchor in extra224 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid.UUID property fget qualname contracts — hex/bytes/urn/fields
#
# uuid.UUID.hex.fget.__qualname__    == 'UUID.hex'
# uuid.UUID.bytes.fget.__qualname__  == 'UUID.bytes'
# uuid.UUID.urn.fget.__qualname__    == 'UUID.urn'
# uuid.UUID.fields.fget.__qualname__ == 'UUID.fields'
#
# hex returns the 32-character hex string; bytes returns 16 raw bytes
# (big-endian); urn returns the RFC 4122 URN representation; fields
# returns a tuple of the six integer components.
# ---------------------------------------------------------------------------

table uuid_extra224.uuid_property_qualnames_group2:
  description: "UUID.hex.fget.__qualname__=='UUID.hex'; UUID.bytes.fget.__qualname__=='UUID.bytes'; UUID.urn.fget.__qualname__=='UUID.urn'; UUID.fields.fget.__qualname__=='UUID.fields'; property fget qualname contracts; new to extra224"
  kind: python_call_eq
  category: identity
  id_prefix: uuid224a

  columns: [id, function, args, expected, description]
  rows:
    - [hex_fget_qualname_eq,
       "UUID.hex.fget.__qualname__.__eq__",
       ["UUID.hex"],
       true,
       "uuid.UUID.hex.fget.__qualname__.__eq__('UUID.hex') == True — hex returns the UUID as a 32-character lowercase hexadecimal string; fget qualname is 'UUID.hex' (8 characters); new anchor in extra224 namespace; verified Python 3.14.3"]
    - [bytes_fget_qualname_eq,
       "UUID.bytes.fget.__qualname__.__eq__",
       ["UUID.bytes"],
       true,
       "uuid.UUID.bytes.fget.__qualname__.__eq__('UUID.bytes') == True — bytes returns the UUID as a 16-byte string in big-endian byte order; fget qualname is 'UUID.bytes' (10 characters); new anchor in extra224 namespace; verified Python 3.14.3"]
    - [urn_fget_qualname_eq,
       "UUID.urn.fget.__qualname__.__eq__",
       ["UUID.urn"],
       true,
       "uuid.UUID.urn.fget.__qualname__.__eq__('UUID.urn') == True — urn returns the RFC 4122 URN representation of the UUID; fget qualname is 'UUID.urn' (8 characters); same length as UUID.hex qualname; new anchor in extra224 namespace; verified Python 3.14.3"]
    - [fields_fget_qualname_eq,
       "UUID.fields.fget.__qualname__.__eq__",
       ["UUID.fields"],
       true,
       "uuid.UUID.fields.fget.__qualname__.__eq__('UUID.fields') == True — fields returns a tuple of the six UUID integer components; fget qualname is 'UUID.fields' (11 characters); new anchor in extra224 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid.UUID property fget __name__ contracts
#
# uuid.UUID.version.fget.__name__ == 'version'
# uuid.UUID.variant.fget.__name__ == 'variant'
# uuid.UUID.node.fget.__name__    == 'node'
# uuid.UUID.hex.fget.__name__     == 'hex'
#
# Each property getter's __name__ equals the property name itself (without
# the class prefix). This is because each getter is defined as a regular
# function named after the property it implements.
# ---------------------------------------------------------------------------

table uuid_extra224.uuid_property_fget_names:
  description: "UUID.version.fget.__name__=='version'; UUID.variant.fget.__name__=='variant'; UUID.node.fget.__name__=='node'; UUID.hex.fget.__name__=='hex'; property fget __name__ contracts; new to extra224"
  kind: python_call_eq
  category: identity
  id_prefix: uuid224b

  columns: [id, function, args, expected, description]
  rows:
    - [version_fget_name_eq,
       "UUID.version.fget.__name__.__eq__",
       ["version"],
       true,
       "uuid.UUID.version.fget.__name__.__eq__('version') == True — fget.__name__ equals the property name 'version' (7 characters) without the class prefix; new anchor in extra224 namespace; verified Python 3.14.3"]
    - [variant_fget_name_eq,
       "UUID.variant.fget.__name__.__eq__",
       ["variant"],
       true,
       "uuid.UUID.variant.fget.__name__.__eq__('variant') == True — fget.__name__ equals the property name 'variant' (7 characters); same length as 'version'; new anchor in extra224 namespace; verified Python 3.14.3"]
    - [node_fget_name_eq,
       "UUID.node.fget.__name__.__eq__",
       ["node"],
       true,
       "uuid.UUID.node.fget.__name__.__eq__('node') == True — fget.__name__ equals the property name 'node' (4 characters); new anchor in extra224 namespace; verified Python 3.14.3"]
    - [hex_fget_name_eq,
       "UUID.hex.fget.__name__.__eq__",
       ["hex"],
       true,
       "uuid.UUID.hex.fget.__name__.__eq__('hex') == True — fget.__name__ equals the property name 'hex' (3 characters); new anchor in extra224 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuid_extra224.version_fget_qualname_eq:
  description: "uuid.UUID.version.fget.__qualname__.__eq__('UUID.version') == True — the version property returns an integer (1–5) indicating the UUID version defined in RFC 4122; it is implemented as a property in Lib/uuid.py; accessing version.fget gives the underlying getter function; its __qualname__ is 'UUID.version' (12 characters: 'UUID.' (5) + 'version' (7)); the fget qualifier confirms this is a property, not a plain attribute; extra224 is the first namespace to anchor UUID.version.fget.__qualname__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "UUID.version.fget.__qualname__.__eq__"
  args: ["UUID.version"]
  expected: true

invariant uuid_extra224.node_fget_qualname_eq:
  description: "uuid.UUID.node.fget.__qualname__.__eq__('UUID.node') == True — the node property exposes the 48-bit hardware address component for version-1 UUIDs (bits 80–127 of the UUID integer); it is implemented as a property in Lib/uuid.py; fget.__qualname__ is 'UUID.node' (9 characters: 'UUID.' (5) + 'node' (4)); extra224 is the first namespace to anchor UUID.node.fget.__qualname__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "UUID.node.fget.__qualname__.__eq__"
  args: ["UUID.node"]
  expected: true

invariant uuid_extra224.hex_fget_qualname_eq:
  description: "uuid.UUID.hex.fget.__qualname__.__eq__('UUID.hex') == True — the hex property returns the UUID as a 32-character lowercase hexadecimal string without hyphens; fget.__qualname__ is 'UUID.hex' (8 characters: 'UUID.' (5) + 'hex' (3)); the hex representation is equivalent to the standard string form but without the four hyphens; extra224 is the first namespace to anchor UUID.hex.fget.__qualname__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "UUID.hex.fget.__qualname__.__eq__"
  args: ["UUID.hex"]
  expected: true
