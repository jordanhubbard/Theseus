spec: io_extra282
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "io.IncrementalNewlineDecoder is a C-level class; its __module__ is '_io', not 'io'."
    - "io.IncrementalNewlineDecoder.__bases__ == (object,) — it inherits directly from object, not from any IO ABC."
    - "io.open_code is a C-level built-in function; __module__ == '_io' and __name__ == 'open_code'."
    - "io.FileIO.read, write, seek, tell are all method_descriptor objects when accessed on the class."
    - "io.StringIO and io.BytesIO are C-level classes with __module__ == '_io'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IncrementalNewlineDecoder — class identity (name, module, base)
# ---------------------------------------------------------------------------

table io_extra282.incremental_newline_decoder_identity:
  description: "io.IncrementalNewlineDecoder __name__, __module__, and __bases__[0].__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: innd

  columns: [id, function, args, expected, description]
  rows:
    - [name,    IncrementalNewlineDecoder.__name__.__eq__,                ["IncrementalNewlineDecoder"], true, "io.IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder'"]
    - [module,  IncrementalNewlineDecoder.__module__.__eq__,              ["_io"],                       true, "io.IncrementalNewlineDecoder.__module__ == '_io' (C extension, not 'io')"]
    - [base,    "IncrementalNewlineDecoder.__bases__[0].__name__.__eq__", ["object"],                    true, "io.IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' — no IO base"]
    - [meta,    IncrementalNewlineDecoder.__class__.__name__.__eq__,      ["type"],                      true, "io.IncrementalNewlineDecoder.__class__.__name__ == 'type' — plain class object"]

# ---------------------------------------------------------------------------
# open_code — C-level function identity
# ---------------------------------------------------------------------------

table io_extra282.open_code_identity:
  description: "io.open_code __name__ and __module__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: oc

  columns: [id, function, args, expected, description]
  rows:
    - [name,    open_code.__name__.__eq__,   ["open_code"], true, "io.open_code.__name__ == 'open_code'"]
    - [module,  open_code.__module__.__eq__, ["_io"],       true, "io.open_code.__module__ == '_io' (C-level built-in)"]

# ---------------------------------------------------------------------------
# FileIO method types — read, write, seek, tell are method_descriptor at class level
# ---------------------------------------------------------------------------

invariant io_extra282.FileIO.read_is_method_descriptor:
  description: "io.FileIO.read.__class__.__name__ == 'method_descriptor' — C-level slot wrapper"
  category: method_types
  kind: python_call_eq
  function: FileIO.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra282.FileIO.write_is_method_descriptor:
  description: "io.FileIO.write.__class__.__name__ == 'method_descriptor' — C-level slot wrapper"
  category: method_types
  kind: python_call_eq
  function: FileIO.write.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra282.FileIO.seek_is_method_descriptor:
  description: "io.FileIO.seek.__class__.__name__ == 'method_descriptor' — C-level slot wrapper"
  category: method_types
  kind: python_call_eq
  function: FileIO.seek.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra282.FileIO.tell_is_method_descriptor:
  description: "io.FileIO.tell.__class__.__name__ == 'method_descriptor' — C-level slot wrapper"
  category: method_types
  kind: python_call_eq
  function: FileIO.tell.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# StringIO and BytesIO — __module__ is '_io' (C-level)
# ---------------------------------------------------------------------------

invariant io_extra282.StringIO.module_is_C:
  description: "io.StringIO.__module__ == '_io' — StringIO is implemented in the _io C extension"
  category: identity
  kind: python_call_eq
  function: StringIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra282.BytesIO.module_is_C:
  description: "io.BytesIO.__module__ == '_io' — BytesIO is implemented in the _io C extension"
  category: identity
  kind: python_call_eq
  function: BytesIO.__module__.__eq__
  args: ["_io"]
  expected: true
