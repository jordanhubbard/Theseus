spec: uuid_extra106
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra105.zspec.zsdl — covers UUID.__le__/__gt__/__ge__ qualname equality / UUID.__int__ qualname / UUID method co_argcount grouping (unary vs binary) / comparison operator type identity (table + invariants)."
    - "uuid_extra104.zspec.zsdl — covers UUID class __name__/__module__/__qualname__ equality and lengths / UUID property fget qualname lengths / uuid.getnode identity and NAMESPACE str lengths (table + invariants)."
    - "uuid_extra103.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __module__ equality / uuid module __name__/__package__/__spec__ identity / UUID.__new__ qualname 'object.__new__' (table + invariants)."
    - "uuid_extra102.zspec.zsdl — covers UUID.variant property vs UUID.is_safe member_descriptor / UUID.__reduce__/__hash__/__str__ type and qualname / UUID comparison method qualnames (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__str__/__repr__ qualname equality and lengths / UUID.__eq__/__hash__/__lt__ qualname equality and lengths / UUID.__init__ code attributes (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality / type(UUID.hex).__name__=='property' (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name / UUID.__module__/__class__/__qualname__ equality and length (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra105; it does NOT duplicate invariants present in those files."
    - "Wave 274 theme: uuid module-level function __name__ equality not yet individually anchored as __eq__ calls / uuid1/uuid3/uuid5 co_argcount==2 grouping / uuid4 co_argcount==0 uniqueness / getnode co_argcount==0 and co_name / uuid function __name__==__qualname__ for all module-level functions."
    - "uuid.uuid4.__name__ == 'uuid4'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__name__ == 'uuid1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__name__ == 'uuid3'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__name__ == 'uuid5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__qualname__ == 'uuid4'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_argcount == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__code__.co_argcount == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__code__.co_name == 'getnode'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__name__ == uuid.uuid4.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid1, uuid3, uuid5 each take 2 positional arguments (co_argcount==2): uuid1(node=None, clock_seq=None), uuid3(namespace, name), uuid5(namespace, name). uuid4() takes 0 arguments (co_argcount==0) — it generates a random UUID from os.urandom(). uuid_extra86 anchors uuid1/uuid4/uuid3/uuid5 co_argcount but through a single table; this spec anchors them with focus on the 0 vs 2 grouping contrast."
    - "Note: For all uuid module-level functions (uuid1, uuid3, uuid4, uuid5, getnode), __name__ == __qualname__ (they are module-level Python functions, not methods, so no class prefix in __qualname__). uuid_extra86 anchors __qualname__ for these functions; this spec anchors __name__ equality via __eq__ calls and the __name__==__qualname__ relationship."
    - "Note: getnode() takes 0 positional arguments (co_argcount==0) and returns the hardware MAC address as a 48-bit integer. Unlike uuid4 (also co_argcount==0) which uses random data, getnode sources its output from the network interfaces or generates a random node if no real MAC is available."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid4.__name__.__eq__('uuid4')
# uuid.uuid1.__name__.__eq__('uuid1')
# uuid.uuid3.__name__.__eq__('uuid3')
# uuid.uuid5.__name__.__eq__('uuid5')
# uuid.uuid4.__name__.__len__() == 5
#
# Wave 274 theme: uuid module-level function __name__ equality.
#
# uuid1, uuid3, uuid4, uuid5 are Python functions with 5-char __name__ values
# ('uuid1', 'uuid3', 'uuid4', 'uuid5'). uuid_extra86 anchors __qualname__ for
# these functions; uuid_extra103 anchors __module__ equality. This spec anchors
# __name__ equality via __eq__ calls for the first time as a grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra106.uuid_function_name_equality:
  description: "uuid4.__name__.__eq__('uuid4')==True / uuid1.__name__.__eq__('uuid1')==True / uuid3.__name__.__eq__('uuid3')==True / uuid5.__name__.__eq__('uuid5')==True / uuid4.__name__.__len__()==5 — all four uuid generator functions have 5-char __name__ values ('uuid' + digit); __name__==__qualname__ for all (module-level Python functions have no class prefix); extra86 anchors __qualname__; extra103 anchors __module__; first uuidfn106 anchor for __name__ equality"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidfn106

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_name_eq, "uuid4.__name__.__eq__", ["uuid4"], true, "uuid.uuid4.__name__ is 'uuid4' (5 chars; 'uuid'=4 + '4'=1; generates random UUID via os.urandom())"]
    - [uuid1_name_eq, "uuid1.__name__.__eq__", ["uuid1"], true, "uuid.uuid1.__name__ is 'uuid1' (5 chars; time-based UUID using MAC address and timestamp)"]
    - [uuid3_name_eq, "uuid3.__name__.__eq__", ["uuid3"], true, "uuid.uuid3.__name__ is 'uuid3' (5 chars; namespace-based UUID using MD5 hash)"]
    - [uuid5_name_eq, "uuid5.__name__.__eq__", ["uuid5"], true, "uuid.uuid5.__name__ is 'uuid5' (5 chars; namespace-based UUID using SHA-1 hash)"]
    - [uuid4_name_len, "uuid4.__name__.__len__", [],       5,    "uuid.uuid4.__name__.__len__() is 5 (same length for all four uuid generator function names)"]

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_argcount == 2
# uuid.uuid3.__code__.co_argcount == 2
# uuid.uuid5.__code__.co_argcount == 2
# uuid.uuid4.__code__.co_argcount == 0
# uuid.getnode.__code__.co_argcount == 0
#
# Wave 274 theme: uuid function co_argcount grouping — 0 vs 2.
#
# uuid1, uuid3, uuid5 have co_argcount==2 (take 2 positional arguments each).
# uuid4 and getnode have co_argcount==0 (take no positional arguments). uuid_extra86
# anchors co_argcount for uuid1/uuid4/uuid3/uuid5; this spec anchors the explicit
# grouping pattern and adds getnode co_argcount==0 for the first time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra106.uuid_function_co_argcount_grouping:
  description: "uuid1.__code__.co_argcount==2 / uuid3.__code__.co_argcount==2 / uuid5.__code__.co_argcount==2 / uuid4.__code__.co_argcount==0 / getnode.__code__.co_argcount==0 — uuid1/uuid3/uuid5 take 2 positional args (node/clock_seq for uuid1; namespace/name for uuid3/uuid5); uuid4 and getnode take 0 args; extra86 anchors co_argcount for uuid1/uuid4/uuid3/uuid5; first uuidfn106 anchor for getnode co_argcount and the 0-vs-2 grouping"
  kind: python_call_eq
  category: code_attr
  id_prefix: uuidfn106

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_co_argcount,   "uuid1.__code__.co_argcount",   [], 2, "uuid.uuid1.__code__.co_argcount is 2 (node=None, clock_seq=None; both optional; time-based UUID)"]
    - [uuid3_co_argcount,   "uuid3.__code__.co_argcount",   [], 2, "uuid.uuid3.__code__.co_argcount is 2 (namespace, name; both required; MD5-based namespace UUID)"]
    - [uuid5_co_argcount,   "uuid5.__code__.co_argcount",   [], 2, "uuid.uuid5.__code__.co_argcount is 2 (namespace, name; both required; SHA-1-based namespace UUID)"]
    - [uuid4_co_argcount,   "uuid4.__code__.co_argcount",   [], 0, "uuid.uuid4.__code__.co_argcount is 0 (no arguments; random UUID from os.urandom(); simplest generator)"]
    - [getnode_co_argcount, "getnode.__code__.co_argcount", [], 0, "uuid.getnode.__code__.co_argcount is 0 (no arguments; returns 48-bit MAC address or random node)"]

# ---------------------------------------------------------------------------
# uuid.uuid4.__qualname__.__eq__('uuid4')
# uuid.uuid1.__qualname__.__eq__('uuid1')
# uuid.getnode.__name__.__eq__('getnode')
# uuid.getnode.__code__.co_name.__eq__('getnode')
# uuid.uuid4.__module__.__eq__('uuid')
#
# Wave 274 theme: uuid function qualname equality and getnode identity.
#
# For all uuid module-level functions, __qualname__ == __name__ (no class prefix).
# uuid_extra86 anchors __qualname__ for uuid1/uuid4/uuid3/uuid5/getnode but as
# __qualname__.__eq__ calls in a table grouped by topic; this spec anchors uuid4
# and uuid1 __qualname__ equality and getnode identity attributes as a new grouping.
# uuid.getnode.__code__.co_name is 'getnode' (function name in its code object).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra106.uuid_function_qualname_and_getnode_identity:
  description: "uuid4.__qualname__.__eq__('uuid4')==True / uuid1.__qualname__.__eq__('uuid1')==True / getnode.__name__.__eq__('getnode')==True / getnode.__code__.co_name.__eq__('getnode')==True / uuid4.__module__.__eq__('uuid')==True — module-level Python functions have __qualname__==__name__ (no enclosing class); getnode.__name__=='getnode' and co_name=='getnode' (7 chars each); uuid4.__module__=='uuid' (same for all uuid generators); extra86 anchors __qualname__ for these functions; first uuidfn106 anchor for this grouping"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidfn106

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_qualname_eq,    "uuid4.__qualname__.__eq__",       ["uuid4"],   true, "uuid.uuid4.__qualname__ is 'uuid4' (same as __name__; module-level function with no class prefix)"]
    - [uuid1_qualname_eq,    "uuid1.__qualname__.__eq__",       ["uuid1"],   true, "uuid.uuid1.__qualname__ is 'uuid1' (same as __name__; module-level function; no nesting in any class)"]
    - [getnode_name_eq,      "getnode.__name__.__eq__",         ["getnode"], true, "uuid.getnode.__name__ is 'getnode' (7 chars; returns 48-bit node ID as integer for UUID version 1)"]
    - [getnode_co_name_eq,   "getnode.__code__.co_name.__eq__", ["getnode"], true, "uuid.getnode.__code__.co_name is 'getnode' (matches __name__; Python def statement name)"]
    - [uuid4_module_eq,      "uuid4.__module__.__eq__",         ["uuid"],    true, "uuid.uuid4.__module__ is 'uuid' (4 chars; all uuid generator functions defined in Lib/uuid.py)"]

# ---------------------------------------------------------------------------
# uuid.uuid4.__name__.__eq__('uuid4') — standalone
#
# uuid.uuid4.__name__ is 'uuid4' (5 chars: 'uuid'=4 + '4'=1). uuid4 is the
# simplest UUID generator: it uses os.urandom(16) to generate 16 random bytes,
# then sets the version bits (version 4) and variant bits (RFC 4122). It takes
# no arguments (co_argcount==0). Its __name__ is 'uuid4', the same as its
# __qualname__ and __code__.co_name. uuid_extra86 anchors __qualname__; this
# spec anchors __name__ equality as a standalone for the first time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra106.uuid4_name_eq:
  description: "uuid.uuid4.__name__.__eq__('uuid4') == True — __name__ is 'uuid4' (5 chars; 'uuid'=4 + '4'=1); generates random RFC 4122 UUID using os.urandom; co_argcount==0; __name__==__qualname__==co_name; extra86 anchors __qualname__; first standalone for __name__ equality under uuidfn106"
  category: function_identity
  kind: python_call_eq
  function: "uuid4.__name__.__eq__"
  args: ["uuid4"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_argcount == 2 — standalone
#
# uuid.uuid1.__code__.co_argcount is 2. uuid1 generates a UUID using the current
# time and MAC address. Its two positional parameters are: node (the hardware
# address as an integer; defaults to None which uses getnode()) and clock_seq
# (a random sequence number; defaults to None which generates one randomly).
# uuid_extra86 anchors uuid1 co_argcount in a table; this spec anchors it as
# a standalone for the first time under uuidfn106.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra106.uuid1_co_argcount_2:
  description: "uuid.uuid1.__code__.co_argcount == 2 — takes node (MAC address as int; default None) and clock_seq (random sequence; default None); co_argcount==2 is shared with uuid3 and uuid5; contrasts with uuid4/getnode at co_argcount==0; extra86 anchors uuid1 co_argcount; first standalone for uuid1 co_argcount under uuidfn106"
  category: code_attr
  kind: python_call_eq
  function: "uuid1.__code__.co_argcount"
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# uuid.uuid4.__code__.co_argcount == 0 — standalone
#
# uuid.uuid4.__code__.co_argcount is 0. uuid4 is the only uuid generator with
# no positional parameters — it sources all randomness from os.urandom(). The
# co_argcount==0 is unusual for a module-level function (most take at least one
# parameter). uuid_extra86 anchors uuid4 co_argcount; this spec anchors it as
# a standalone emphasizing the contrast with uuid1/uuid3/uuid5 (co_argcount==2).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra106.uuid4_co_argcount_0:
  description: "uuid.uuid4.__code__.co_argcount == 0 — takes no positional arguments; all randomness from os.urandom(16); only uuid generator with co_argcount==0 (uuid1/uuid3/uuid5 all have co_argcount==2); contrasts with getnode which also has co_argcount==0 but returns a node ID not a UUID; extra86 anchors uuid4 co_argcount; first standalone under uuidfn106"
  category: code_attr
  kind: python_call_eq
  function: "uuid4.__code__.co_argcount"
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# uuid.getnode.__code__.co_argcount == 0 — standalone
#
# uuid.getnode.__code__.co_argcount is 0. getnode takes no arguments and returns
# the hardware MAC address as a 48-bit integer (used as the 'node' field in
# UUID version 1). Like uuid4, getnode has co_argcount==0. uuid_extra86 anchors
# getnode qualname and module; uuid_extra104 anchors getnode identity in a table.
# This spec anchors getnode co_argcount==0 as a standalone for the first time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra106.getnode_co_argcount_0:
  description: "uuid.getnode.__code__.co_argcount == 0 — takes no arguments; returns 48-bit MAC address as integer; co_argcount==0 shared with uuid4; getnode is used internally by uuid1 when node=None; extra86 anchors getnode qualname; extra104 anchors getnode identity; first standalone for getnode co_argcount under uuidfn106"
  category: code_attr
  kind: python_call_eq
  function: "getnode.__code__.co_argcount"
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# uuid.uuid4.__qualname__.__eq__('uuid4') — standalone
#
# uuid.uuid4.__qualname__ is 'uuid4'. For module-level Python functions (not
# defined inside a class or another function), __qualname__ equals __name__.
# uuid4 is defined at the top level of Lib/uuid.py, so __qualname__ == 'uuid4'
# (no class prefix, no outer function prefix). uuid_extra86 anchors uuid4
# __qualname__ in a table; this spec anchors it as a standalone under uuidfn106.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra106.uuid4_qualname_eq:
  description: "uuid.uuid4.__qualname__.__eq__('uuid4') == True — __qualname__=='uuid4' (same as __name__; module-level function defined at top level of Lib/uuid.py; no class or outer function prefix); extra86 anchors uuid4 __qualname__ in table; first standalone for uuid4 __qualname__ equality under uuidfn106"
  category: function_identity
  kind: python_call_eq
  function: "uuid4.__qualname__.__eq__"
  args: ["uuid4"]
  expected: true
