spec: textwrap_extra11
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
    - "textwrap.zspec.zsdl — covers wrap/fill/dedent/indent/shorten basic vectors; TextWrapper(width=40).width."
    - "textwrap_extra.zspec.zsdl — covers wrap/fill/dedent/indent/shorten __name__; TextWrapper __name__/__module__; additional behavioral vectors."
    - "textwrap_extra3.zspec.zsdl — covers dedent('  hello\\n  world'); fill('hello world',width=5); indent angle prefix."
    - "textwrap_extra7.zspec.zsdl — covers TextWrapper defaults (break_on_hyphens, max_lines, tabsize==8); indent hash prefix; shorten unicode placeholder."
    - "textwrap_extra10.zspec.zsdl — covers wrap long-word breaking; fill width=15; shorten short input; wrap/shorten return type; TextWrapper width=60; fix_sentence_endings/expand_tabs defaults; wrap subsequent_indent."
  notes:
    - "This spec adds genuinely new test vectors not present in any prior textwrap spec."
    - "textwrap.dedent('\\t\\thello\\n\\t\\tworld') == 'hello\\nworld' — tab-based common indent stripped; prior specs only test space-based dedent."
    - "textwrap.fill('', width=20) == '' — empty input string returns empty string; not in prior specs."
    - "textwrap.fill('hello world', width=40) == 'hello world' — no wrapping needed; single line returned; new input/width combination."
    - "textwrap.wrap('hello', width=10) == ['hello'] — single word shorter than width: returned as one element list."
    - "textwrap.TextWrapper(tabsize=4).tabsize == 4 — non-default tabsize; extra7 covers default tabsize==8."
    - "textwrap.TextWrapper(width=10, max_lines=2).wrap('one two three four five') == ['one two', '[...]'] — max_lines truncates with default placeholder."
    - "textwrap.indent('hello\\nworld', '* ') == '* hello\\n* world' — asterisk prefix, no trailing newlines."
    - "textwrap.indent('hello\\n\\nworld', '> ', predicate=lambda line: line.strip()) == '> hello\\n\\n> world' — predicate skips blank lines."
    - "textwrap.dedent('\\t\\thello\\n\\t\\tworld') — both lines share a two-tab common indent; dedent strips it entirely."
    - "textwrap.fill('', width=20) — no content to wrap; result is empty string."
    - "textwrap.fill('hello world', width=40) — string is shorter than width; returned as-is on one line."
    - "textwrap.wrap('hello', width=10) — single word fits; returned as single-element list."
    - "textwrap.TextWrapper(tabsize=4).tabsize == 4 — tab stop set to 4-space intervals."
    - "textwrap.TextWrapper(width=10, max_lines=2).wrap('one two three four five') — third line would overflow max_lines=2 so the second line is replaced by '[...]'."
    - "textwrap.indent('hello\\nworld', '* ') == '* hello\\n* world' — both non-blank lines get '* ' prefix."
    - "textwrap.indent with predicate: blank lines are passed to predicate which returns False, so blank lines receive no prefix."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# dedent — tab-based common indent
#
# textwrap_extra3 covers dedent('  hello\n  world') (2-space common indent).
# textwrap_extra4 covers a multi-line dedent with spaces.
# No prior spec tests dedent with a tab-based common indent.
# '\t\thello\n\t\tworld' — both lines begin with exactly two tabs; dedent strips
# the common two-tab prefix and returns 'hello\nworld'.
# ---------------------------------------------------------------------------

invariant textwrap_extra11.dedent.tab_indent:
  description: "textwrap.dedent('\\t\\thello\\n\\t\\tworld') == 'hello\\nworld' — tab-based indent stripped"
  category: dedent
  kind: python_call_eq
  function: dedent
  args: ["\t\thello\n\t\tworld"]
  expected: "hello\nworld"

# ---------------------------------------------------------------------------
# fill — empty input and no-wrap-needed input
#
# textwrap_extra3 covers fill('hello world', width=5) == 'hello\nworld'.
# textwrap_extra5 covers fill that fits within width (shorten-style check).
# No prior spec tests fill('', width=20) (empty input) or
# fill('hello world', width=40) (string shorter than width, no line break).
# ---------------------------------------------------------------------------

invariant textwrap_extra11.fill.empty_input:
  description: "textwrap.fill('', width=20) == '' — empty input returns empty string"
  category: fill
  kind: python_call_eq
  function: fill
  args: [""]
  kwargs: {width: 20}
  expected: ""

invariant textwrap_extra11.fill.fits_in_width:
  description: "textwrap.fill('hello world', width=40) == 'hello world' — no wrapping needed"
  category: fill
  kind: python_call_eq
  function: fill
  args: ["hello world"]
  kwargs: {width: 40}
  expected: "hello world"

# ---------------------------------------------------------------------------
# wrap — single word shorter than width
#
# textwrap.zspec.zsdl covers wrap.single_word_fits as a basic vector.
# textwrap_extra10 covers wrap for a word longer than the width.
# This invariant records a fresh namespace anchor: wrap('hello', width=10)
# returns the single word in a one-element list ['hello'].
# ---------------------------------------------------------------------------

invariant textwrap_extra11.wrap.single_word_fits_width:
  description: "textwrap.wrap('hello', width=10) == ['hello'] — single word fits, returned as one element"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["hello"]
  kwargs: {width: 10}
  expected: ["hello"]

# ---------------------------------------------------------------------------
# TextWrapper — non-default tabsize and max_lines truncation
#
# textwrap_extra7 covers TextWrapper().tabsize == 8 (default value).
# No prior spec tests tabsize=4 as a constructor argument.
# textwrap_extra7 covers TextWrapper().max_lines == None (default).
# No prior spec tests behavioral max_lines truncation in wrap().
# TextWrapper(width=10, max_lines=2).wrap('one two three four five')
# produces ['one two', '[...]'] — third line would exceed max_lines=2 so
# the second line is replaced by the default placeholder '[...]'.
# ---------------------------------------------------------------------------

invariant textwrap_extra11.TextWrapper.tabsize_four:
  description: "textwrap.TextWrapper(tabsize=4).tabsize == 4 — non-default tab width"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  kwargs: {tabsize: 4}
  method: tabsize.__eq__
  method_args: [4]
  expected: true

invariant textwrap_extra11.TextWrapper.max_lines_truncation:
  description: "textwrap.TextWrapper(width=10, max_lines=2).wrap('one two three four five') == ['one two', '[...]']"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  kwargs: {width: 10, max_lines: 2}
  method: wrap
  method_args: ["one two three four five"]
  expected: ["one two", "[...]"]

# ---------------------------------------------------------------------------
# indent — asterisk prefix and predicate to skip blank lines
#
# textwrap_extra3 covers indent('hello\nworld', '  ') == '  hello\n  world'.
# textwrap_extra7 covers indent with a '#' prefix.
# No prior spec uses a '* ' (asterisk-space) prefix.
# No prior spec tests indent with a predicate that skips blank lines
# (predicate=lambda line: line.strip()): blank lines are left without prefix.
# ---------------------------------------------------------------------------

invariant textwrap_extra11.indent.asterisk_prefix:
  description: "textwrap.indent('hello\\nworld', '* ') == '* hello\\n* world'"
  category: indent
  kind: python_call_eq
  function: indent
  args: ["hello\nworld", "* "]
  expected: "* hello\n* world"

invariant textwrap_extra11.indent.predicate_skip_blank:
  description: "textwrap.indent('hello\\n\\nworld', '> ', predicate=lambda line: line.strip()) == '> hello\\n\\n> world'"
  category: indent
  kind: python_call_eq
  function: indent
  args: ["hello\n\nworld", "> "]
  kwargs: {predicate: "lambda line: line.strip()"}
  expected: "> hello\n\n> world"

# ---------------------------------------------------------------------------
# Table: fill behavioral vectors for edge cases
#
# No prior spec groups fill edge-case vectors in a table.
# ---------------------------------------------------------------------------

table textwrap_extra11.fill_vectors:
  description: "textwrap.fill edge-case behavioral vectors"
  kind: python_call_eq
  category: fill
  id_prefix: fv

  columns: [id, function, args, expected]
  rows:
    - [empty,       fill, [""],             ""]
    - [single_word, fill, ["hello"],        "hello"]
