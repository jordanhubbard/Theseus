spec: abc_extra270
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "collections.abc.Iterator.__module__ == 'collections.abc'; __bases__[0].__name__ == 'Iterable'."
    - "collections.abc.Iterator.__abstractmethods__ == frozenset({'__next__'}) — only __next__ must be implemented."
    - "collections.abc.Generator.__module__ == 'collections.abc'; __bases__[0].__name__ == 'Iterator'."
    - "collections.abc.Generator.__abstractmethods__ == frozenset({'send', 'throw'}) — send and throw are abstract."
    - "Generator.close is a concrete mixin method; its __qualname__ == 'Generator.close'."
    - "collections.abc.AsyncIterator.__module__ == 'collections.abc'; __bases__[0].__name__ == 'AsyncIterable'."
    - "collections.abc.AsyncIterator.__abstractmethods__ == frozenset({'__anext__'}) — only __anext__ must be implemented."
    - "collections.abc.AsyncGenerator.__bases__[0].__name__ == 'AsyncIterator'; __abstractmethods__ == frozenset({'athrow', 'asend'})."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# collections.abc.Iterator class identity — table
#
# Iterator inherits from Iterable and requires only __next__ to be abstract.
# ---------------------------------------------------------------------------

table abc_extra270.iterator_identity:
  description: "collections.abc.Iterator class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: itid

  columns: [id, function, args, expected, description]
  rows:
    - [it_name,    collections.abc.Iterator.__name__.__eq__,           ["Iterator"],       true, "collections.abc.Iterator.__name__ == 'Iterator'"]
    - [it_module,  collections.abc.Iterator.__module__.__eq__,         ["collections.abc"], true, "collections.abc.Iterator.__module__ == 'collections.abc'"]
    - [it_next,    collections.abc.Iterator.__next__.__name__.__eq__,  ["__next__"],        true, "collections.abc.Iterator.__next__.__name__ == '__next__'"]
    - [it_iter,    collections.abc.Iterator.__iter__.__name__.__eq__,  ["__iter__"],        true, "collections.abc.Iterator.__iter__.__name__ == '__iter__'"]

# ---------------------------------------------------------------------------
# collections.abc.Generator class identity — table
#
# Generator inherits from Iterator and adds send, throw, and close.
# send and throw are abstract; close is a concrete mixin method.
# ---------------------------------------------------------------------------

table abc_extra270.generator_identity:
  description: "collections.abc.Generator class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: genid

  columns: [id, function, args, expected, description]
  rows:
    - [gen_name,        collections.abc.Generator.__name__.__eq__,             ["Generator"],       true, "collections.abc.Generator.__name__ == 'Generator'"]
    - [gen_module,      collections.abc.Generator.__module__.__eq__,           ["collections.abc"], true, "collections.abc.Generator.__module__ == 'collections.abc'"]
    - [gen_send,        collections.abc.Generator.send.__name__.__eq__,        ["send"],             true, "collections.abc.Generator.send.__name__ == 'send'"]
    - [gen_send_qn,     collections.abc.Generator.send.__qualname__.__eq__,    ["Generator.send"],   true, "collections.abc.Generator.send.__qualname__ == 'Generator.send'"]
    - [gen_throw,       collections.abc.Generator.throw.__name__.__eq__,       ["throw"],            true, "collections.abc.Generator.throw.__name__ == 'throw'"]
    - [gen_throw_qn,    collections.abc.Generator.throw.__qualname__.__eq__,   ["Generator.throw"],  true, "collections.abc.Generator.throw.__qualname__ == 'Generator.throw'"]
    - [gen_close,       collections.abc.Generator.close.__name__.__eq__,       ["close"],            true, "collections.abc.Generator.close.__name__ == 'close'"]
    - [gen_close_qn,    collections.abc.Generator.close.__qualname__.__eq__,   ["Generator.close"],  true, "collections.abc.Generator.close.__qualname__ == 'Generator.close'"]

# ---------------------------------------------------------------------------
# collections.abc.Iterator base class — standalone invariant
#
# Iterator.__bases__[0].__name__ == 'Iterable'.
# ---------------------------------------------------------------------------

invariant abc_extra270.Iterator.bases0_name:
  description: "collections.abc.Iterator.__bases__[0].__name__ == 'Iterable'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Iterator.__bases__[0].__name__.__eq__"
  args: ["Iterable"]
  expected: true

# ---------------------------------------------------------------------------
# collections.abc.Iterator abstract methods — standalone invariant
#
# Only __next__ is abstract on Iterator; __iter__ is a concrete mixin.
# ---------------------------------------------------------------------------

invariant abc_extra270.Iterator.abstractmethods_next:
  description: "collections.abc.Iterator.__abstractmethods__ contains '__next__'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Iterator.__abstractmethods__.__contains__"
  args: ["__next__"]
  expected: true

# ---------------------------------------------------------------------------
# collections.abc.Generator base class — standalone invariant
#
# Generator.__bases__[0].__name__ == 'Iterator'.
# ---------------------------------------------------------------------------

invariant abc_extra270.Generator.bases0_name:
  description: "collections.abc.Generator.__bases__[0].__name__ == 'Iterator'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Generator.__bases__[0].__name__.__eq__"
  args: ["Iterator"]
  expected: true

# ---------------------------------------------------------------------------
# collections.abc.AsyncIterator class identity — standalone invariants
#
# AsyncIterator lives in collections.abc and inherits from AsyncIterable.
# Its only abstract method is __anext__.
# ---------------------------------------------------------------------------

invariant abc_extra270.AsyncIterator.name:
  description: "collections.abc.AsyncIterator.__name__ == 'AsyncIterator'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncIterator.__name__.__eq__
  args: ["AsyncIterator"]
  expected: true

invariant abc_extra270.AsyncIterator.module:
  description: "collections.abc.AsyncIterator.__module__ == 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncIterator.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra270.AsyncIterator.bases0_name:
  description: "collections.abc.AsyncIterator.__bases__[0].__name__ == 'AsyncIterable'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.AsyncIterator.__bases__[0].__name__.__eq__"
  args: ["AsyncIterable"]
  expected: true

invariant abc_extra270.AsyncIterator.anext_name:
  description: "collections.abc.AsyncIterator.__anext__.__name__ == '__anext__'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncIterator.__anext__.__name__.__eq__
  args: ["__anext__"]
  expected: true

invariant abc_extra270.AsyncIterator.anext_qualname:
  description: "collections.abc.AsyncIterator.__anext__.__qualname__ == 'AsyncIterator.__anext__'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncIterator.__anext__.__qualname__.__eq__
  args: ["AsyncIterator.__anext__"]
  expected: true

invariant abc_extra270.AsyncIterator.abstractmethods_anext:
  description: "collections.abc.AsyncIterator.__abstractmethods__ contains '__anext__'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.AsyncIterator.__abstractmethods__.__contains__"
  args: ["__anext__"]
  expected: true

# ---------------------------------------------------------------------------
# collections.abc.AsyncGenerator class identity — standalone invariants
#
# AsyncGenerator inherits from AsyncIterator; send and throw (athrow, asend)
# are abstract.
# ---------------------------------------------------------------------------

invariant abc_extra270.AsyncGenerator.name:
  description: "collections.abc.AsyncGenerator.__name__ == 'AsyncGenerator'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncGenerator.__name__.__eq__
  args: ["AsyncGenerator"]
  expected: true

invariant abc_extra270.AsyncGenerator.module:
  description: "collections.abc.AsyncGenerator.__module__ == 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncGenerator.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra270.AsyncGenerator.bases0_name:
  description: "collections.abc.AsyncGenerator.__bases__[0].__name__ == 'AsyncIterator'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.AsyncGenerator.__bases__[0].__name__.__eq__"
  args: ["AsyncIterator"]
  expected: true
