spec: tempfile_extra7
version: ">=3.9"
backend: python_module(tempfile)

docs: https://docs.python.org/3/library/tempfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tempfile.html — Python tempfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tempfile.py"
  notes:
    - "This spec extends tempfile.zspec.zsdl and all prior tempfile_extra specs."
    - "tempfile.zspec.zsdl covers: function_names table (NamedTemporaryFile/TemporaryFile/TemporaryDirectory/SpooledTemporaryFile/mkstemp/mkdtemp/gettempdir/gettempprefix/gettempdirb __name__); gettempdir_is_str/nonempty; gettempprefix_value; gettempdirb_is_bytes/nonempty."
    - "tempfile_extra through tempfile_extra6 cover: __module__, __qualname__, __class__.__name__, __bases__, __qualname__ standalones, mktemp/gettempprefixb attrs, gettempdirb qualname/module/class, TemporaryFile.__class__.__name__=='type', template class, gettempdirb starts_with_slash."
    - "This spec adds new axes: __name__ length checks for the four main class/callable names, and __name__ startswith checks for the prefix character — both are uncovered in all prior specs."
    - "TemporaryFile.__name__ has length 13 ('TemporaryFile')."
    - "NamedTemporaryFile.__name__ has length 18 ('NamedTemporaryFile')."
    - "TemporaryDirectory.__name__ has length 18 ('TemporaryDirectory')."
    - "SpooledTemporaryFile.__name__ has length 21 ('SpooledTemporaryFile')."
    - "All four names start with an uppercase letter — __name__[0] == the first character."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ length checks for the four primary class/callable names
# All prior specs verify __name__ via equality (__name__.__eq__(str) == True).
# This spec adds a distinct axis: the length of the __name__ string.
# None of the prior tempfile specs verify __name__ lengths.
# ---------------------------------------------------------------------------

table tempfile_extra7.name_lengths:
  description: "tempfile class/callable __name__ attribute lengths"
  kind: python_call_eq
  category: name_lengths
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [TemporaryFile,        TemporaryFile.__name__.__len__,        [], 13]
    - [NamedTemporaryFile,   NamedTemporaryFile.__name__.__len__,   [], 18]
    - [TemporaryDirectory,   TemporaryDirectory.__name__.__len__,   [], 18]
    - [SpooledTemporaryFile, SpooledTemporaryFile.__name__.__len__, [], 20]

# ---------------------------------------------------------------------------
# __name__ startswith checks — first character is 'T' or 'S'
# All four names begin with an uppercase letter; 'Temporary' names start with 'T',
# SpooledTemporaryFile starts with 'S'. This axis is not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant tempfile_extra7.TemporaryFile.name_starts_T:
  description: "tempfile.TemporaryFile.__name__[0] == 'T' — name begins with 'T'"
  category: name_prefix
  kind: python_call_eq
  function: TemporaryFile.__name__.__getitem__
  args: [0]
  expected: "T"

invariant tempfile_extra7.NamedTemporaryFile.name_starts_N:
  description: "tempfile.NamedTemporaryFile.__name__[0] == 'N' — name begins with 'N'"
  category: name_prefix
  kind: python_call_eq
  function: NamedTemporaryFile.__name__.__getitem__
  args: [0]
  expected: "N"

invariant tempfile_extra7.TemporaryDirectory.name_starts_T:
  description: "tempfile.TemporaryDirectory.__name__[0] == 'T' — name begins with 'T'"
  category: name_prefix
  kind: python_call_eq
  function: TemporaryDirectory.__name__.__getitem__
  args: [0]
  expected: "T"

invariant tempfile_extra7.SpooledTemporaryFile.name_starts_S:
  description: "tempfile.SpooledTemporaryFile.__name__[0] == 'S' — name begins with 'S'"
  category: name_prefix
  kind: python_call_eq
  function: SpooledTemporaryFile.__name__.__getitem__
  args: [0]
  expected: "S"

# ---------------------------------------------------------------------------
# __name__ is-str checks for the four primary class/callable names
# All prior specs verify __name__ values via str.__eq__; none verify that
# __name__ itself is an instance of str via __class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

table tempfile_extra7.name_is_str:
  description: "tempfile class/callable __name__ attributes are str objects"
  kind: python_call_eq
  category: name_types
  id_prefix: namestr

  columns: [id, function, args, expected]
  rows:
    - [TemporaryFile,        TemporaryFile.__name__.__class__.__name__.__eq__,        ["str"], true]
    - [NamedTemporaryFile,   NamedTemporaryFile.__name__.__class__.__name__.__eq__,   ["str"], true]
    - [TemporaryDirectory,   TemporaryDirectory.__name__.__class__.__name__.__eq__,   ["str"], true]
    - [SpooledTemporaryFile, SpooledTemporaryFile.__name__.__class__.__name__.__eq__, ["str"], true]
