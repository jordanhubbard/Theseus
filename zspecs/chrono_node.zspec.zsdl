spec: chrono_node
version: ">=2.0.0"
backend: node(chrono-node)

docs: https://github.com/wanasit/chrono#readme

provenance:
  derived_from:
    - "Chrono README — https://github.com/wanasit/chrono#readme"
    - "Test vectors verified with chrono-node via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "chrono-node source"
  notes:
    - "Natural-language date parser — handles 'tomorrow', 'next monday', 'January 15, 2024'."
    - "Install: npm install chrono-node"
    - "v2 CJS; named exports parse / parseDate / strict / casual."
    - "Tests use absolute-date phrases for determinism — relative phrases like 'tomorrow' need a refDate which the chain helper can't supply as Date."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Returns null when no date phrase is found."
  stderr: "null"
  stickiness: "N/A — each parse independent."
  codes: {}

invariant chrono_node.parseDate_jan_15_2024:
  description: "parseDate('January 15, 2024').toISOString().slice(0,10) is '2024-01-15'"
  category: parseDate
  kind: node_chain_eq
  entry: named
  function: parseDate
  entry_args: ["January 15, 2024"]
  chain:
    - {method: toISOString, args: []}
    - {method: slice, args: [0, 10]}
  expected: "2024-01-15"

invariant chrono_node.parseDate_iso_form:
  description: "parseDate('2024-03-15') yields 2024-03-15"
  category: parseDate
  kind: node_chain_eq
  entry: named
  function: parseDate
  entry_args: ["2024-03-15"]
  chain:
    - {method: toISOString, args: []}
    - {method: slice, args: [0, 10]}
  expected: "2024-03-15"

invariant chrono_node.parseDate_dec_25_2023:
  description: "parseDate('December 25, 2023') is Christmas Day"
  category: parseDate
  kind: node_chain_eq
  entry: named
  function: parseDate
  entry_args: ["December 25, 2023"]
  chain:
    - {method: toISOString, args: []}
    - {method: slice, args: [0, 10]}
  expected: "2023-12-25"

invariant chrono_node.parse_returns_array:
  description: "parse('We meet on January 15, 2024') returns array with one match"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["We meet on January 15, 2024"]
  chain:
    - {get: length}
  expected: 1

invariant chrono_node.parse_extracted_text:
  description: "parse(...) match[0].text contains the matched phrase"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["We meet on January 15, 2024"]
  chain:
    - {method: at, args: [0]}
    - {get: text}
  expected: "January 15, 2024"

invariant chrono_node.parse_no_date_returns_empty:
  description: "parse('hello world') returns []"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["hello world"]
  chain:
    - {get: length}
  expected: 0

invariant chrono_node.parseDate_returns_Date:
  description: "parseDate result.constructor.name is 'Date'"
  category: shape
  kind: node_chain_eq
  entry: named
  function: parseDate
  entry_args: ["January 15, 2024"]
  chain:
    - {get: "constructor.name"}
  expected: "Date"

invariant chrono_node.parseDate_no_match_returns_null:
  description: "parseDate('hello') returns null"
  category: parseDate
  kind: node_chain_eq
  entry: named
  function: parseDate
  entry_args: ["hello"]
  chain: []
  expected: ~

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:14:49Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
