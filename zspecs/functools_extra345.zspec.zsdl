spec: functools_extra345
version: ">=3.0"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.__name__ == 'functools' — the module name attribute."
    - "functools.__package__ == '' — functools is not a package; __package__ is the empty string."
    - "functools.__spec__.name == 'functools' — the ModuleSpec name matches the module name."
    - "functools.__doc__.__class__.__name__ == 'str' — the module docstring is a plain Python string."
    - "functools.__doc__.__len__() == 69 — docstring length verified on Python 3.14 macOS."
    - "functools.__all__.__class__.__name__ == 'list' — __all__ is a plain list."
    - "functools.__all__.__len__() == 15 — 15 public names exported by functools on Python 3.14."
    - "functools.__all__.__contains__('reduce') == True — reduce is in __all__."
    - "functools.__all__.__contains__('lru_cache') == True — lru_cache is in __all__."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module identity attributes: __name__, __package__, __spec__.name
# ---------------------------------------------------------------------------

invariant functools_extra345.module.name:
  description: "functools.__name__ == 'functools'"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra345.module.package:
  description: "functools.__package__ == '' — functools is not a package"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant functools_extra345.module.spec_name:
  description: "functools.__spec__.name == 'functools'"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["functools"]
  expected: true

# ---------------------------------------------------------------------------
# __doc__ — class name and length
# ---------------------------------------------------------------------------

invariant functools_extra345.doc.class_name:
  description: "functools.__doc__.__class__.__name__ == 'str'"
  category: doc
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra345.doc.length:
  description: "functools.__doc__.__len__() == 69"
  category: doc
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 69

# ---------------------------------------------------------------------------
# __all__ — class name, length, and membership
# ---------------------------------------------------------------------------

invariant functools_extra345.all.class_name:
  description: "functools.__all__.__class__.__name__ == 'list'"
  category: all_attr
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant functools_extra345.all.length:
  description: "functools.__all__.__len__() == 15 — 15 public names on Python 3.14"
  category: all_attr
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 15

invariant functools_extra345.all.contains_reduce:
  description: "functools.__all__.__contains__('reduce') == True"
  category: all_attr
  kind: python_call_eq
  function: __all__.__contains__
  args: ["reduce"]
  expected: true

invariant functools_extra345.all.contains_lru_cache:
  description: "functools.__all__.__contains__('lru_cache') == True"
  category: all_attr
  kind: python_call_eq
  function: __all__.__contains__
  args: ["lru_cache"]
  expected: true
