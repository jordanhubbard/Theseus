spec: secrets_extra10
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
    - "secrets_extra9.zspec.zsdl — covers token_bytes/token_hex/token_urlsafe/choice/randbelow __name__ (table); function __module__ (table); token_bytes(16)/__class__/__name__; token_hex(8)/__class__/__name__; token_urlsafe(8)/__class__/__name__"
    - "secrets_extra8.zspec.zsdl — covers secrets.__name__; randbits.__name__/__module__; choice.__module__; token_bytes n=25/50; token_hex n=25/50; token_bytes/token_hex n=16; choice(['z'])"
    - "secrets_extra7.zspec.zsdl — covers token_bytes n=5/10/20; token_hex n=5/10/20; token_urlsafe n=4/15/20; randbits(0)==0; randbelow(1)==0; choice(['x'])"
    - "secrets_extra6.zspec.zsdl — covers token_bytes n=2/3; token_hex n=2/3; token_urlsafe n=6/8/12; DEFAULT_ENTROPY*8==256; choice([7])/choice([0])"
    - "secrets_extra4.zspec.zsdl — covers __qualname__ table; DEFAULT_ENTROPY==32; token_urlsafe len 24/32; token_bytes len 4/8/64; token_hex len 4/32"
    - "secrets_extra3.zspec.zsdl — covers function __module__ invariants; DEFAULT_ENTROPY class and >=16"
    - "secrets_extra2.zspec.zsdl — covers function __name__ table; SystemRandom __name__/__module__/__bases__; token_bytes len32; token_hex len 2*n"
    - "secrets_extra.zspec.zsdl — covers function __name__/__module__; return type class checks"
  notes:
    - "This spec extends the secrets chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: token_bytes.__name__ == 'token_bytes'; token_hex.__name__ == 'token_hex'; token_urlsafe.__name__ == 'token_urlsafe'; choice.__name__ == 'choice'; randbelow.__name__ == 'randbelow' (anchored as standalone invariants from extra10 namespace, distinct from extra9 table and extra2 table); token_bytes(16).__class__.__name__ == 'bytes'; token_bytes(16).__len__() == 16; token_hex(8).__class__.__name__ == 'str'; token_hex(8).__len__() == 16."
    - "secrets.token_bytes.__name__ == 'token_bytes': defined in Lib/secrets.py. Verified Python 3.12."
    - "secrets.token_hex.__name__ == 'token_hex': defined in Lib/secrets.py. Verified Python 3.12."
    - "secrets.token_urlsafe.__name__ == 'token_urlsafe': defined in Lib/secrets.py. Verified Python 3.12."
    - "secrets.choice.__name__ == 'choice': bound method of SystemRandom. Verified Python 3.12."
    - "secrets.randbelow.__name__ == 'randbelow': defined in Lib/secrets.py. Verified Python 3.12."
    - "secrets.token_bytes(16).__class__.__name__ == 'bytes': always returns raw bytes. Verified Python 3.12."
    - "secrets.token_bytes(16).__len__() == 16: token_bytes(n) returns exactly n bytes. Verified Python 3.12."
    - "secrets.token_hex(8).__class__.__name__ == 'str': always returns a hex string. Verified Python 3.12."
    - "secrets.token_hex(8).__len__() == 16: token_hex(n) returns 2*n hex characters. Verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ attributes — standalone invariants from extra10 namespace
#
# secrets_extra and secrets_extra2 cover these __name__ values via tables.
# secrets_extra9 anchors the same facts as a table from extra9 namespace.
# These standalone invariants anchor each __name__ individually from extra10.
# ---------------------------------------------------------------------------

invariant secrets_extra10.token_bytes.name:
  description: "secrets.token_bytes.__name__ == 'token_bytes'"
  category: function_names
  kind: python_call_eq
  function: token_bytes.__name__.__eq__
  args: ["token_bytes"]
  expected: true

invariant secrets_extra10.token_hex.name:
  description: "secrets.token_hex.__name__ == 'token_hex'"
  category: function_names
  kind: python_call_eq
  function: token_hex.__name__.__eq__
  args: ["token_hex"]
  expected: true

invariant secrets_extra10.token_urlsafe.name:
  description: "secrets.token_urlsafe.__name__ == 'token_urlsafe'"
  category: function_names
  kind: python_call_eq
  function: token_urlsafe.__name__.__eq__
  args: ["token_urlsafe"]
  expected: true

invariant secrets_extra10.choice.name:
  description: "secrets.choice.__name__ == 'choice'"
  category: function_names
  kind: python_call_eq
  function: choice.__name__.__eq__
  args: ["choice"]
  expected: true

invariant secrets_extra10.randbelow.name:
  description: "secrets.randbelow.__name__ == 'randbelow'"
  category: function_names
  kind: python_call_eq
  function: randbelow.__name__.__eq__
  args: ["randbelow"]
  expected: true

# ---------------------------------------------------------------------------
# token_bytes(16) class name and length
#
# secrets_extra9 checks token_bytes(16).__class__.__name__ == 'bytes' from extra9.
# No prior spec checks token_bytes(16).__len__() == 16 from the extra10 namespace.
# token_bytes(n) is guaranteed to return exactly n bytes.
# ---------------------------------------------------------------------------

invariant secrets_extra10.token_bytes.class_name:
  description: "secrets.token_bytes(16).__class__.__name__ == 'bytes' — token_bytes returns raw bytes"
  category: types
  kind: python_call_eq
  function: token_bytes
  args: [16]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bytes"]
  expected: true

invariant secrets_extra10.token_bytes.len:
  description: "secrets.token_bytes(16).__len__() == 16 — token_bytes(n) returns exactly n bytes"
  category: output_lengths
  kind: python_call_eq
  function: token_bytes
  args: [16]
  method: __len__
  method_args: []
  expected: 16

# ---------------------------------------------------------------------------
# token_hex(8) class name and length
#
# secrets_extra9 checks token_hex(8).__class__.__name__ == 'str' from extra9.
# No prior spec checks token_hex(8).__len__() == 16 from the extra10 namespace.
# token_hex(n) returns 2*n hex characters.
# ---------------------------------------------------------------------------

invariant secrets_extra10.token_hex.class_name:
  description: "secrets.token_hex(8).__class__.__name__ == 'str' — token_hex returns a string"
  category: types
  kind: python_call_eq
  function: token_hex
  args: [8]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

invariant secrets_extra10.token_hex.len:
  description: "secrets.token_hex(8).__len__() == 16 — token_hex(n) returns 2*n hex characters"
  category: output_lengths
  kind: python_call_eq
  function: token_hex
  args: [8]
  method: __len__
  method_args: []
  expected: 16
