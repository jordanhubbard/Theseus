spec: operator_extra27
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator_extra26.zspec.zsdl."
    - "operator_extra26 covers: attrgetter/itemgetter/methodcaller __module__ and __bases__[0].__name__ tables; concat/getitem/setitem/delitem sequence qualnames; neg/pos/abs/pow unary qualnames."
    - "operator_extra25 covers: bitwise operator qualnames (and_/or_/xor/invert/lshift/rshift); length_hint qualname."
    - "operator_extra24 covers: attrgetter/itemgetter/methodcaller __call__ slot qualnames; not_/truth/is_/is_not/contains qualnames."
    - "operator_extra23 covers: arithmetic function qualnames (add/sub/mul/truediv/floordiv/mod); attrgetter/itemgetter/methodcaller class qualnames."
    - "No prior operator spec records __qualname__ for the six comparison operators (eq/ne/lt/le/gt/ge) together in the extra27 namespace."
    - "Focus: comparison operator qualnames (eq/ne/lt/le/gt/ge); __module__ for comparison operators; matmul/index/iconcat qualnames as additional novel items."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
    - "Note: all operator C-level functions have __module__ == '_operator', confirming C extension attribution."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — comparison operator function qualnames
#
# operator.eq, ne, lt, le, gt, and ge are C-level functions in _operator that
# implement the six standard comparison operations. Each has a simple qualname
# equal to its attribute name. No prior operator spec records all six comparison
# operator qualnames together in the extra27 namespace.
# ---------------------------------------------------------------------------

table operator_extra27.comparison_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra27.comparison_qualnames.eq,
       eq.__qualname__.__eq__,
       ["eq"],
       true,
       "operator.eq.__qualname__ == 'eq'"]
    - [operator_extra27.comparison_qualnames.ne,
       ne.__qualname__.__eq__,
       ["ne"],
       true,
       "operator.ne.__qualname__ == 'ne'"]
    - [operator_extra27.comparison_qualnames.lt,
       lt.__qualname__.__eq__,
       ["lt"],
       true,
       "operator.lt.__qualname__ == 'lt'"]
    - [operator_extra27.comparison_qualnames.le,
       le.__qualname__.__eq__,
       ["le"],
       true,
       "operator.le.__qualname__ == 'le'"]
    - [operator_extra27.comparison_qualnames.gt,
       gt.__qualname__.__eq__,
       ["gt"],
       true,
       "operator.gt.__qualname__ == 'gt'"]
    - [operator_extra27.comparison_qualnames.ge,
       ge.__qualname__.__eq__,
       ["ge"],
       true,
       "operator.ge.__qualname__ == 'ge'"]

# ---------------------------------------------------------------------------
# __module__.__eq__ table — comparison operator function module membership
#
# operator.eq, ne, lt, le, gt, and ge are C-level functions defined in the
# _operator C extension module. Their __module__ is '_operator', not 'operator',
# distinguishing them from the attrgetter/itemgetter/methodcaller C-level types
# which report 'operator' as their __module__. No prior operator spec records
# all six comparison operator __module__ values together in the extra27 namespace.
# ---------------------------------------------------------------------------

table operator_extra27.comparison_modules:
  kind: python_call_eq
  category: module_membership
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra27.comparison_modules.eq,
       eq.__module__.__eq__,
       ["_operator"],
       true,
       "operator.eq.__module__ == '_operator'"]
    - [operator_extra27.comparison_modules.ne,
       ne.__module__.__eq__,
       ["_operator"],
       true,
       "operator.ne.__module__ == '_operator'"]
    - [operator_extra27.comparison_modules.lt,
       lt.__module__.__eq__,
       ["_operator"],
       true,
       "operator.lt.__module__ == '_operator'"]
    - [operator_extra27.comparison_modules.le,
       le.__module__.__eq__,
       ["_operator"],
       true,
       "operator.le.__module__ == '_operator'"]
    - [operator_extra27.comparison_modules.gt,
       gt.__module__.__eq__,
       ["_operator"],
       true,
       "operator.gt.__module__ == '_operator'"]
    - [operator_extra27.comparison_modules.ge,
       ge.__module__.__eq__,
       ["_operator"],
       true,
       "operator.ge.__module__ == '_operator'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — matmul, index, and iconcat operator qualnames
#
# operator.matmul implements the @ matrix-multiplication operator (PEP 465).
# operator.index coerces an object to an integer index via __index__.
# operator.iconcat is the in-place concatenation operator. All three are
# C-level functions in _operator with simple qualnames equal to their names.
# No prior operator spec records these three qualnames together in the extra27
# namespace.
# ---------------------------------------------------------------------------

table operator_extra27.misc_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra27.misc_qualnames.matmul,
       matmul.__qualname__.__eq__,
       ["matmul"],
       true,
       "operator.matmul.__qualname__ == 'matmul'"]
    - [operator_extra27.misc_qualnames.index,
       index.__qualname__.__eq__,
       ["index"],
       true,
       "operator.index.__qualname__ == 'index'"]
    - [operator_extra27.misc_qualnames.iconcat,
       iconcat.__qualname__.__eq__,
       ["iconcat"],
       true,
       "operator.iconcat.__qualname__ == 'iconcat'"]

# ---------------------------------------------------------------------------
# eq.__qualname__.__eq__ — standalone comparison function qualname
#
# operator.eq is a C-level function that wraps the == comparison. Its qualname
# is 'eq', a simple name with no enclosing scope, confirming module-level
# definition in _operator. No prior operator spec records this standalone in
# the extra27 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra27.eq.qualname:
  description: "operator.eq.__qualname__ == 'eq'"
  category: qualnames
  kind: python_call_eq
  function: eq.__qualname__.__eq__
  args: ["eq"]
  expected: true

# ---------------------------------------------------------------------------
# eq.__module__.__eq__ — standalone comparison function module membership
#
# operator.eq is a C-level function. Its __module__ is '_operator', the C
# extension module name, not 'operator', the public module name. This records
# the module attribution pattern for comparison functions, contrasting with
# the callable classes (attrgetter etc.) which report 'operator'.
# No prior operator spec records this standalone in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra27.eq.module:
  description: "operator.eq.__module__ == '_operator'"
  category: module_membership
  kind: python_call_eq
  function: eq.__module__.__eq__
  args: ["_operator"]
  expected: true

# ---------------------------------------------------------------------------
# matmul.__qualname__.__eq__ — standalone matrix-multiplication operator qualname
#
# operator.matmul implements the @ binary operator for matrix multiplication.
# Its qualname is 'matmul', a simple name confirming it is defined at module
# scope in the _operator C extension. No prior operator spec records this
# standalone in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra27.matmul.qualname:
  description: "operator.matmul.__qualname__ == 'matmul'"
  category: qualnames
  kind: python_call_eq
  function: matmul.__qualname__.__eq__
  args: ["matmul"]
  expected: true
