spec: multiprocessing_extra394
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "multiprocessing.cpu_count.__name__ == 'cpu_count' and lives in multiprocessing.context"
    - "multiprocessing.freeze_support.__name__ == 'freeze_support' and lives in multiprocessing.context"
    - "multiprocessing.set_start_method.__name__ == 'set_start_method' and lives in multiprocessing.context"
    - "multiprocessing.get_start_method.__name__ == 'get_start_method' and lives in multiprocessing.context"
    - "multiprocessing.get_context.__name__ == 'get_context' and lives in multiprocessing.context"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra394.function_names:
  description: "Verify __name__ attribute of multiprocessing process-management functions"
  kind: python_call_eq
  category: identity
  id_prefix: mp394fn

  columns: [id, function, args, expected]
  rows:
    - [mp394fn001, multiprocessing.cpu_count.__name__.__eq__, ["cpu_count"], true]
    - [mp394fn002, multiprocessing.freeze_support.__name__.__eq__, ["freeze_support"], true]
    - [mp394fn003, multiprocessing.set_start_method.__name__.__eq__, ["set_start_method"], true]
    - [mp394fn004, multiprocessing.get_start_method.__name__.__eq__, ["get_start_method"], true]
    - [mp394fn005, multiprocessing.get_context.__name__.__eq__, ["get_context"], true]

table multiprocessing_extra394.function_modules:
  description: "Verify __module__ attribute of multiprocessing process-management functions"
  kind: python_call_eq
  category: identity
  id_prefix: mp394fm

  columns: [id, function, args, expected]
  rows:
    - [mp394fm001, multiprocessing.cpu_count.__module__.__eq__, ["multiprocessing.context"], true]
    - [mp394fm002, multiprocessing.freeze_support.__module__.__eq__, ["multiprocessing.context"], true]
    - [mp394fm003, multiprocessing.set_start_method.__module__.__eq__, ["multiprocessing.context"], true]
    - [mp394fm004, multiprocessing.get_start_method.__module__.__eq__, ["multiprocessing.context"], true]
    - [mp394fm005, multiprocessing.get_context.__module__.__eq__, ["multiprocessing.context"], true]
