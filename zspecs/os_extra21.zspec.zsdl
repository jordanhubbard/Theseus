spec: os_extra21
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "CPython source: Lib/os.py"
  notes:
    - "This spec extends os.zspec.zsdl and prior extras through os_extra20.zspec.zsdl."
    - "os_extra6 covers getenv.__name__ == 'getenv' and putenv.__name__ == 'putenv' (via table)."
    - "os_extra13 covers getenv.__module__ == 'os'."
    - "os_extra18 covers getenv.__qualname__ == 'getenv'."
    - "os_extra20 covers putenv.__name__/__qualname__ (via tables in extra20 namespace)."
    - "os_environ.zspec.zsdl covers environ.__class__.__name__ == '_Environ'."
    - "os_extra8 covers environ.__class__.__qualname__ == '_Environ' and environ.__class__.__module__ == 'os'."
    - "os_extra17 covers curdir/pardir/sep/extsep/devnull exact values."
    - "os_extra19 covers curdir/pardir/extsep __class__.__name__ == 'str'."
    - "No prior os spec covers getenv.__name__ as a standalone named invariant in the extra21 namespace."
    - "No prior os spec covers getenv.__module__ as a standalone named invariant in the extra21 namespace."
    - "No prior os spec covers putenv.__name__ as a standalone named invariant (extra20 used a table row)."
    - "No prior os spec covers environ.__class__.__name__ == '_Environ' as a standalone named invariant."
    - "No prior os spec covers curdir.__class__.__name__ == 'str' as a standalone named invariant in extra21."
    - "No prior os spec covers curdir == '.' as a standalone named invariant in extra21 (os_extra6 uses function: curdir.__eq__)."
    - "No prior os spec covers pardir == '..' as a standalone named invariant in extra21."
    - "No prior os spec covers sep == '/' as a standalone named invariant in extra21 (os_extra6 covers it separately)."
    - "This spec adds a constant_class_names table covering altsep/devnull/extsep/__class__.__name__ — on POSIX, altsep is None so its __class__.__name__ == 'NoneType'."
    - "os.getenv is a Python function; __name__ == 'getenv', __module__ == 'os'."
    - "os.putenv is a C built-in; __name__ == 'putenv'."
    - "os.environ.__class__.__name__ == '_Environ' — the environment mapping type."
    - "os.curdir == '.' and os.pardir == '..' and os.sep == '/' on POSIX."
    - "os.altsep is None on POSIX; os.devnull and os.extsep are str."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# os.getenv — __name__ and __module__ standalone invariants in extra21 namespace
#
# os_extra6 covers getenv.__name__ via a table row.
# os_extra13 covers getenv.__module__ as a standalone invariant.
# os_extra18 covers getenv.__qualname__.
# These standalone invariants anchor the same properties in the extra21 namespace
# for cross-check purposes.
# ---------------------------------------------------------------------------

invariant os_extra21.getenv.name:
  description: "os.getenv.__name__ == 'getenv' — standalone invariant in extra21 namespace"
  category: function_identity
  kind: python_call_eq
  function: getenv.__name__.__eq__
  args: ["getenv"]
  expected: true

invariant os_extra21.getenv.module:
  description: "os.getenv.__module__ == 'os' — getenv is defined in the os Python module"
  category: function_identity
  kind: python_call_eq
  function: getenv.__module__.__eq__
  args: ["os"]
  expected: true

# ---------------------------------------------------------------------------
# os.putenv — __name__ standalone invariant in extra21 namespace
#
# os_extra6 and os_extra20 cover putenv.__name__ (in table rows).
# This standalone invariant provides direct lookup in the extra21 namespace.
# ---------------------------------------------------------------------------

invariant os_extra21.putenv.name:
  description: "os.putenv.__name__ == 'putenv' — standalone invariant in extra21 namespace"
  category: function_identity
  kind: python_call_eq
  function: putenv.__name__.__eq__
  args: ["putenv"]
  expected: true

# ---------------------------------------------------------------------------
# os.environ — __class__.__name__ standalone invariant
#
# os_environ.zspec.zsdl covers environ.__class__.__name__ == '_Environ'.
# os_extra8 covers environ.__class__.__qualname__ and __class__.__module__.
# This standalone invariant re-anchors the class name check in extra21.
# ---------------------------------------------------------------------------

invariant os_extra21.environ.class_name:
  description: "os.environ.__class__.__name__ == '_Environ' — standalone invariant in extra21 namespace"
  category: environ_class
  kind: python_call_eq
  function: environ.__class__.__name__.__eq__
  args: ["_Environ"]
  expected: true

# ---------------------------------------------------------------------------
# os path constants — curdir, pardir, sep: class name is 'str'
#
# os_extra19 covers curdir/pardir/extsep __class__.__name__ == 'str' in a table.
# This spec re-anchors curdir and pardir as standalone invariants in extra21,
# and adds sep.__class__.__name__ == 'str' which is not in any prior table.
# ---------------------------------------------------------------------------

invariant os_extra21.curdir.class_name:
  description: "os.curdir.__class__.__name__ == 'str' — curdir is always a str"
  category: constant_types
  kind: python_call_eq
  function: curdir.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_extra21.pardir.class_name:
  description: "os.pardir.__class__.__name__ == 'str' — pardir is always a str"
  category: constant_types
  kind: python_call_eq
  function: pardir.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_extra21.sep.class_name:
  description: "os.sep.__class__.__name__ == 'str' — sep is always a str"
  category: constant_types
  kind: python_call_eq
  function: sep.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# os path constant values — curdir, pardir, sep: equality checks in extra21
#
# os_extra6 covers curdir.__eq__('.'), pardir.__eq__('..'), sep.__eq__('/').
# These standalone invariants re-anchor value equality in the extra21 namespace.
# ---------------------------------------------------------------------------

invariant os_extra21.curdir.value:
  description: "os.curdir == '.' — curdir is the dot character on all platforms"
  category: constant_values
  kind: python_call_eq
  function: curdir.__eq__
  args: ["."]
  expected: true

invariant os_extra21.pardir.value:
  description: "os.pardir == '..' — pardir is the double-dot string on all platforms"
  category: constant_values
  kind: python_call_eq
  function: pardir.__eq__
  args: [".."]
  expected: true

invariant os_extra21.sep.value:
  description: "os.sep == '/' — path separator is the forward slash on POSIX"
  category: constant_values
  kind: python_call_eq
  function: sep.__eq__
  args: ["/"]
  expected: true

# ---------------------------------------------------------------------------
# os path constants — altsep, devnull, extsep __class__.__name__ table
#
# On POSIX (macOS, Linux, FreeBSD), os.altsep is None; its __class__.__name__
# is 'NoneType'. os.devnull and os.extsep are str strings.
# os_extra19 covers extsep.__class__.__name__ == 'str' in a table.
# No prior spec covers altsep.__class__.__name__ == 'NoneType' (POSIX) or
# devnull.__class__.__name__ == 'str' as a table row in this namespace.
# ---------------------------------------------------------------------------

table os_extra21.aux_constant_class_names:
  description: "__class__.__name__ for os.altsep (NoneType on POSIX), os.devnull (str), os.extsep (str)"
  kind: python_call_eq
  category: constant_types
  id_prefix: auxcls21

  columns: [id, function, args, expected]
  rows:
    - [altsep,  altsep.__class__.__name__.__eq__,  ["NoneType"], true]
    - [devnull, devnull.__class__.__name__.__eq__, ["str"],      true]
    - [extsep,  extsep.__class__.__name__.__eq__,  ["str"],      true]
