# ---------------------------------------------------------------------------
# Table 1: functools.update_wrapper code object attributes
#
# Wave 292 theme: functools.update_wrapper function code attributes — argument
# count, code name, and varnames length.
#
# functools.update_wrapper.__code__.co_argcount == 4
# functools.update_wrapper.__code__.co_name == 'update_wrapper'
# functools.update_wrapper.__code__.co_varnames.__len__() == 6
# functools.update_wrapper.__module__ == 'functools'
#
# functools.update_wrapper(wrapper, wrapped, assigned=WRAPPER_ASSIGNMENTS,
# updated=WRAPPER_UPDATES) is the underlying function used by functools.wraps.
# It copies attributes from the wrapped function onto the wrapper function.
# It is a Python function defined in Lib/functools.py. It takes 4
# positional-or-keyword arguments: wrapper, wrapped, assigned, updated;
# co_argcount is therefore 4. Its code object's co_varnames tuple contains the
# 4 parameter names plus 2 loop variable names (attr, value), for a total of 6.
# New to extra168.
# ---------------------------------------------------------------------------

table functools_extra168.update_wrapper_code_attributes:
  description: "functools.update_wrapper: co_argcount 4, co_name 'update_wrapper', co_varnames len 6, __module__ 'functools'; wave 292; new to extra168"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsuwca168

  columns: [id, function, args, expected, description]
  rows:
    - [uw_argc_eq_4,
       "update_wrapper.__code__.co_argcount.__eq__",
       [4],
       true,
       "functools.update_wrapper.__code__.co_argcount.__eq__(4) == True — update_wrapper(wrapper, wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES) takes 4 positional-or-keyword arguments; co_argcount is 4; int.__eq__(4) returns True; new to extra168"]
    - [uw_co_name_eq,
       "update_wrapper.__code__.co_name.__eq__",
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__code__.co_name.__eq__('update_wrapper') == True — update_wrapper is a Python function in Lib/functools.py that copies attributes from the wrapped function onto the wrapper; its code object co_name is 'update_wrapper'; str.__eq__('update_wrapper') returns True; new to extra168"]
    - [uw_varnames_len_eq_6,
       "update_wrapper.__code__.co_varnames.__len__",
       [],
       6,
       "functools.update_wrapper.__code__.co_varnames.__len__() == 6 — co_varnames contains 6 entries: wrapper, wrapped, assigned, updated (4 parameters) plus attr and value (2 loop variables used when copying assigned/updated attributes); new to extra168"]
    - [uw_module_eq_functools,
       "update_wrapper.__module__.__eq__",
       ["functools"],
       true,
       "functools.update_wrapper.__module__.__eq__('functools') == True — update_wrapper is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra168"]

# ---------------------------------------------------------------------------
# Table 2: functools.WRAPPER_UPDATES constant identity
#
# Wave 292 theme: functools.WRAPPER_UPDATES constant — class and length — and
# update_wrapper class attribute.
#
# functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'
# functools.WRAPPER_UPDATES.__len__() == 1
# functools.update_wrapper.__class__.__name__ == 'function'
# functools.update_wrapper.__code__.co_argcount == 4 (cross-check)
#
# functools.WRAPPER_UPDATES is a tuple containing a single string: '__dict__'.
# It is the default value for the 'updated' parameter of update_wrapper and
# specifies which attributes on the wrapper object are themselves updated
# (rather than overwritten) from the wrapped object. Currently only '__dict__'
# is updated, meaning the wrapper's __dict__ gets the wrapped function's
# __dict__ entries merged into it. WRAPPER_UPDATES is a plain Python tuple;
# its __class__.__name__ is 'tuple' and len() is 1. New to extra168.
# ---------------------------------------------------------------------------

table functools_extra168.wrapper_updates_constant_identity:
  description: "functools.WRAPPER_UPDATES: __class__.__name__ 'tuple', __len__() 1; update_wrapper.__class__.__name__ 'function'; wave 292; new to extra168"
  kind: python_call_eq
  category: identity
  id_prefix: functoolswuci168

  columns: [id, function, args, expected, description]
  rows:
    - [wu_class_name_eq_tuple,
       "WRAPPER_UPDATES.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a Python tuple constant containing a single entry ('__dict__'); it is the default value for the 'updated' parameter of update_wrapper specifying which attributes are merged rather than overwritten; its __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra168"]
    - [wu_len_eq_1,
       "WRAPPER_UPDATES.__len__",
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES is a tuple containing exactly one element ('__dict__'); only the wrapper's __dict__ is merged from the wrapped function; tuple.__len__() returns 1; new to extra168"]
    - [uw_class_name_eq_function,
       "update_wrapper.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.update_wrapper.__class__.__name__.__eq__('function') == True — update_wrapper is a plain Python function defined in Lib/functools.py; it is NOT a class or C built-in; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra168"]
    - [wu_class_name_ne_list,
       "WRAPPER_UPDATES.__class__.__name__.__eq__",
       ["list"],
       false,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('list') == False — WRAPPER_UPDATES is a tuple (immutable), not a list; its __class__.__name__ is 'tuple' not 'list'; str.__eq__('list') returns False; new to extra168"]

