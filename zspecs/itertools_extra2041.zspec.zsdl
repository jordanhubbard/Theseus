spec: itertools_extra2041
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2041): __lshift__, __rshift__, __and__, __or__, __xor__, __invert__ dict-presence checks."
    - "itertools C-types are not bitwise types — none define bitwise operators."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

table itertools_extra2041.lshift_protocol:
  description: "itertools C-types __lshift__/__rlshift__/__ilshift__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2041
  columns: [id, function, args, expected]
  rows:
    - ["it2041001", "itertools.count.__dict__.__contains__",        ["__lshift__"],  false]
    - ["it2041002", "itertools.cycle.__dict__.__contains__",        ["__lshift__"],  false]
    - ["it2041003", "itertools.chain.__dict__.__contains__",        ["__lshift__"],  false]
