    - ["it2041007", "itertools.chain.__dict__.__contains__",        ["__rlshift__"], false]
    - ["it2041008", "itertools.islice.__dict__.__contains__",       ["__rlshift__"], false]
    - ["it2041009", "itertools.count.__dict__.__contains__",        ["__ilshift__"], false]
    - ["it2041010", "itertools.cycle.__dict__.__contains__",        ["__ilshift__"], false]
    - ["it2041011", "itertools.chain.__dict__.__contains__",        ["__ilshift__"], false]
