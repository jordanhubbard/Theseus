spec: statistics_extra6
version: ">=3.8"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics.zspec.zsdl and prior extras."
    - "statistics_extra2 covers: NormalDist.__name__, NormalDist.__module__, NormalDist.__bases__[0].__name__, NormalDist(0,1).mean, NormalDist(0,1).stdev, NormalDist(5,2).mean, NormalDist(5,2).stdev; StatisticsError.__name__, StatisticsError.__module__."
    - "statistics_extra4 covers: StatisticsError.__name__, StatisticsError.__module__, StatisticsError.__bases__[0].__name__; NormalDist(0,1).variance, NormalDist(5,2).variance, NormalDist(0,1).cdf(0.0); StatisticsError.__qualname__."
    - "statistics_extra5 covers: NormalDist.__qualname__, StatisticsError.__module__; function qualnames table; geometric_mean return type; multimode two-modes; harmonic_mean return type; quantiles quartiles."
    - "This spec adds: NormalDist(0,1).median, NormalDist(2,1) mean/stdev/variance/median, NormalDist.__bases__[0].__name__, NormalDist(0,1).__class__.__name__ via method_chain, StatisticsError.__qualname__ via __eq__ style."
    - "statistics.NormalDist(0, 1).median == 0.0 — for a symmetric normal distribution, median == mean."
    - "statistics.NormalDist(2, 1).mean == 2.0 — location parameter mu."
    - "statistics.NormalDist(2, 1).stdev == 1.0 — scale parameter sigma."
    - "statistics.NormalDist(2, 1).variance == 1.0 — variance == sigma**2 == 1.0."
    - "statistics.NormalDist(2, 1).median == 2.0 — median equals mean for normal distribution."
    - "statistics.NormalDist.__bases__[0].__name__ == 'object' — NormalDist inherits directly from object."
    - "statistics.StatisticsError.__qualname__ == 'StatisticsError' — already in extra4 but only via method; this spec adds __eq__ style."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NormalDist(0, 1) — median
# statistics_extra2 covers mean and stdev; statistics_extra4 covers variance.
# New here: median for the standard normal distribution.
# ---------------------------------------------------------------------------

invariant statistics_extra6.NormalDist_0_1.median:
  description: "statistics.NormalDist(0, 1).median == 0.0 — symmetric distribution: median equals mean"
  category: normal_dist
  kind: python_call_eq
  function: NormalDist
  args: [0, 1]
  method: median.__eq__
  method_args: [0.0]
  expected: true

# ---------------------------------------------------------------------------
# NormalDist(2, 1) — mean, stdev, variance, median
# statistics_extra2 covers NormalDist(5.0, 2.0) and NormalDist(0, 1).
# New input vector: NormalDist(2, 1) with distinct mu=2, sigma=1.
# ---------------------------------------------------------------------------

invariant statistics_extra6.NormalDist_2_1.mean:
  description: "statistics.NormalDist(2, 1).mean == 2.0 — location parameter mu"
  category: normal_dist
  kind: python_call_eq
  function: NormalDist
  args: [2, 1]
  method: mean.__eq__
  method_args: [2.0]
  expected: true

invariant statistics_extra6.NormalDist_2_1.stdev:
  description: "statistics.NormalDist(2, 1).stdev == 1.0 — scale parameter sigma"
  category: normal_dist
  kind: python_call_eq
  function: NormalDist
  args: [2, 1]
  method: stdev.__eq__
  method_args: [1.0]
  expected: true

invariant statistics_extra6.NormalDist_2_1.variance:
  description: "statistics.NormalDist(2, 1).variance == 1.0 — variance == sigma**2 == 1.0"
  category: normal_dist
  kind: python_call_eq
  function: NormalDist
  args: [2, 1]
  method: variance.__eq__
  method_args: [1.0]
  expected: true

invariant statistics_extra6.NormalDist_2_1.median:
  description: "statistics.NormalDist(2, 1).median == 2.0 — median equals mean for normal distribution"
  category: normal_dist
  kind: python_call_eq
  function: NormalDist
  args: [2, 1]
  method: median.__eq__
  method_args: [2.0]
  expected: true

# ---------------------------------------------------------------------------
# NormalDist class hierarchy
# statistics_extra2 covers NormalDist.__bases__[0].__name__ via method: __name__.
# This adds the same check via method: __name__.__eq__ style for orthogonality.
# ---------------------------------------------------------------------------

invariant statistics_extra6.NormalDist.base_is_object:
  description: "statistics.NormalDist.__bases__[0].__name__ == 'object' — NormalDist inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: NormalDist.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# StatisticsError — __qualname__ via __eq__ style
# statistics_extra4 covers StatisticsError.__qualname__ via method: __qualname__.
# This adds the check using function: StatisticsError.__qualname__.__eq__ style
# (different expression form, orthogonal invariant).
# ---------------------------------------------------------------------------

invariant statistics_extra6.StatisticsError.qualname_eq:
  description: "statistics.StatisticsError.__qualname__ == 'StatisticsError'"
  category: exceptions
  kind: python_call_eq
  function: StatisticsError.__qualname__.__eq__
  args: ["StatisticsError"]
  expected: true

# ---------------------------------------------------------------------------
# NormalDist(0, 1) — instance class name via method_chain
# statistics_extra2 covers NormalDist(0,1).__class__.__name__ indirectly.
# This adds it explicitly via method_chain pattern.
# ---------------------------------------------------------------------------

invariant statistics_extra6.NormalDist_0_1.class_name:
  description: "statistics.NormalDist(0, 1).__class__.__name__ == 'NormalDist'"
  category: normal_dist
  kind: python_call_eq
  function: NormalDist
  args: [0, 1]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["NormalDist"]
  expected: true
