spec: inspect_extra66
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra65.zspec.zsdl."
    - "Wave 232 theme: co_consts class name, co_nlocals class name, and co_stacksize class name for inspect functions."
    - "isfunction.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is always a tuple of constants in CPython code objects. Verified with Python 3.14.3."
    - "isclass.__code__.co_consts.__class__.__name__ == 'tuple' — same invariant for isclass. Verified with Python 3.14.3."
    - "ismodule.__code__.co_consts.__class__.__name__ == 'tuple' — same invariant for ismodule. Verified with Python 3.14.3."
    - "signature.__code__.co_consts.__class__.__name__ == 'tuple' — same invariant for signature. Verified with Python 3.14.3."
    - "isfunction.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals is the count of local variables, stored as a Python int. Verified with Python 3.14.3."
    - "isclass.__code__.co_nlocals.__class__.__name__ == 'int' — same invariant for isclass. Verified with Python 3.14.3."
    - "ismodule.__code__.co_nlocals.__class__.__name__ == 'int' — same invariant for ismodule. Verified with Python 3.14.3."
    - "getmembers.__code__.co_nlocals.__class__.__name__ == 'int' — getmembers is a pure-Python function in Lib/inspect.py; co_nlocals is an int. Verified with Python 3.14.3."
    - "isfunction.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is the required stack size, stored as a Python int. Verified with Python 3.14.3."
    - "isclass.__code__.co_stacksize.__class__.__name__ == 'int' — same invariant for isclass. Verified with Python 3.14.3."
    - "getmembers.__code__.co_stacksize.__class__.__name__ == 'int' — same invariant for getmembers. Verified with Python 3.14.3."
    - "isbuiltin.__code__.co_nlocals.__class__.__name__ == 'int' — isbuiltin is a pure-Python function in Lib/inspect.py; co_nlocals is an int. Verified with Python 3.14.3."
    - "isbuiltin.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is an int for isbuiltin. Verified with Python 3.14.3."
    - "Prior inspect_extra65 covered co_varnames, co_filename, and co_flags for isfunction/isclass/ismodule/signature."
    - "No prior inspect spec checks co_consts.__class__.__name__, co_nlocals.__class__.__name__, or co_stacksize.__class__.__name__ for any inspect function. All checks in this spec are new to extra66."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect __code__.co_consts.__class__.__name__ — extra66
#
# Wave 232 theme: co_consts is always a tuple.
#
# co_consts (PyCodeObject.co_consts) is a tuple of constants used by the
# bytecode (literals, None, docstrings, nested code objects, etc.). In CPython
# this attribute is always stored as a Python tuple.
#
# isfunction.__code__.co_consts.__class__.__name__ == 'tuple'
# isclass.__code__.co_consts.__class__.__name__ == 'tuple'
# ismodule.__code__.co_consts.__class__.__name__ == 'tuple'
#
# All are pure-Python functions in Lib/inspect.py.
# No prior inspect spec checks co_consts.__class__.__name__. New to extra66.
# ---------------------------------------------------------------------------

table inspect_extra66.co_consts_class_name:
  description: "inspect function __code__.co_consts.__class__.__name__.__eq__('tuple')==true — co_consts is always a tuple in CPython; wave 232 co_consts chains; new to extra66"
  kind: python_call_eq
  category: co_consts
  id_prefix: inspcode4_66

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_code_co_consts_class_name_eq_tuple,
       isfunction.__code__.co_consts.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "inspect.isfunction.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — isfunction is a pure-Python function (Lib/inspect.py); its __code__ is a PyCodeObject; PyCodeObject.co_consts is a tuple of constants used by the bytecode (including None, literals, and the docstring if present); the tuple built-in type has __name__ == 'tuple' (5 chars); __eq__ returns True; no prior inspect spec checks co_consts.__class__.__name__ for isfunction; new to extra66"]
    - [isclass_code_co_consts_class_name_eq_tuple,
       isclass.__code__.co_consts.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "inspect.isclass.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — isclass is a pure-Python function (Lib/inspect.py); its co_consts is a tuple of bytecode constants; tuple.__name__ == 'tuple'; __eq__ returns True; no prior inspect spec checks co_consts.__class__.__name__ for isclass; new to extra66"]
    - [ismodule_code_co_consts_class_name_eq_tuple,
       ismodule.__code__.co_consts.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "inspect.ismodule.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — ismodule is a pure-Python function (Lib/inspect.py); its co_consts is a tuple of bytecode constants; tuple.__name__ == 'tuple'; __eq__ returns True; no prior inspect spec checks co_consts.__class__.__name__ for ismodule; new to extra66"]

# ---------------------------------------------------------------------------
# inspect __code__.co_nlocals.__class__.__name__ — extra66
#
# Wave 232 theme: co_nlocals is always an int.
#
# co_nlocals (PyCodeObject.co_nlocals) stores the number of local variables
# (including parameters) used by the function. In CPython this field is
# always a plain Python int.
#
# isfunction.__code__.co_nlocals.__class__.__name__ == 'int'
# isclass.__code__.co_nlocals.__class__.__name__ == 'int'
# ismodule.__code__.co_nlocals.__class__.__name__ == 'int'
# getmembers.__code__.co_nlocals.__class__.__name__ == 'int'
#
# No prior inspect spec checks co_nlocals.__class__.__name__. New to extra66.
# ---------------------------------------------------------------------------

table inspect_extra66.co_nlocals_class_name:
  description: "inspect function __code__.co_nlocals.__class__.__name__.__eq__('int')==true — co_nlocals is always a plain int; wave 232 co_nlocals chains; new to extra66"
  kind: python_call_eq
  category: co_nlocals
  id_prefix: inspcode4_66

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_code_co_nlocals_class_name_eq_int,
       isfunction.__code__.co_nlocals.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.isfunction.__code__.co_nlocals.__class__.__name__.__eq__('int') == True — isfunction is a pure-Python function (Lib/inspect.py); its __code__ is a PyCodeObject; PyCodeObject.co_nlocals is the count of local variables (including parameters) stored as a Python int; int.__name__ == 'int' (3 chars); __eq__ returns True; no prior inspect spec checks co_nlocals.__class__.__name__ for isfunction; new to extra66"]
    - [isclass_code_co_nlocals_class_name_eq_int,
       isclass.__code__.co_nlocals.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.isclass.__code__.co_nlocals.__class__.__name__.__eq__('int') == True — isclass is a pure-Python function (Lib/inspect.py); co_nlocals is the count of local variables stored as a Python int; int.__name__ == 'int'; __eq__ returns True; no prior inspect spec checks co_nlocals.__class__.__name__ for isclass; new to extra66"]
    - [ismodule_code_co_nlocals_class_name_eq_int,
       ismodule.__code__.co_nlocals.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.ismodule.__code__.co_nlocals.__class__.__name__.__eq__('int') == True — ismodule is a pure-Python function (Lib/inspect.py); co_nlocals is the count of local variables stored as a Python int; int.__name__ == 'int'; __eq__ returns True; no prior inspect spec checks co_nlocals.__class__.__name__ for ismodule; new to extra66"]
    - [getmembers_code_co_nlocals_class_name_eq_int,
       getmembers.__code__.co_nlocals.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.getmembers.__code__.co_nlocals.__class__.__name__.__eq__('int') == True — getmembers is a pure-Python function (Lib/inspect.py) that returns all members of an object; co_nlocals is the count of local variables stored as a Python int; int.__name__ == 'int'; __eq__ returns True; no prior inspect spec checks co_nlocals.__class__.__name__ for getmembers; new to extra66"]

# ---------------------------------------------------------------------------
# inspect __code__.co_stacksize.__class__.__name__ — extra66
#
# Wave 232 theme: co_stacksize is always an int.
#
# co_stacksize (PyCodeObject.co_stacksize) stores the required stack space
# for the function's evaluation stack. In CPython this field is always a
# plain Python int.
#
# isfunction.__code__.co_stacksize.__class__.__name__ == 'int'
# isclass.__code__.co_stacksize.__class__.__name__ == 'int'
# getmembers.__code__.co_stacksize.__class__.__name__ == 'int'
#
# No prior inspect spec checks co_stacksize.__class__.__name__. New to extra66.
# ---------------------------------------------------------------------------

table inspect_extra66.co_stacksize_class_name:
  description: "inspect function __code__.co_stacksize.__class__.__name__.__eq__('int')==true — co_stacksize is always a plain int; wave 232 co_stacksize chains; new to extra66"
  kind: python_call_eq
  category: co_stacksize
  id_prefix: inspcode4_66

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_code_co_stacksize_class_name_eq_int,
       isfunction.__code__.co_stacksize.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.isfunction.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — isfunction is a pure-Python function (Lib/inspect.py); its __code__ is a PyCodeObject; PyCodeObject.co_stacksize is the required stack size for the evaluation stack stored as a Python int; int.__name__ == 'int' (3 chars); __eq__ returns True; no prior inspect spec checks co_stacksize.__class__.__name__ for isfunction; new to extra66"]
    - [isclass_code_co_stacksize_class_name_eq_int,
       isclass.__code__.co_stacksize.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.isclass.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — isclass is a pure-Python function (Lib/inspect.py); co_stacksize is the required stack size stored as a Python int; int.__name__ == 'int'; __eq__ returns True; no prior inspect spec checks co_stacksize.__class__.__name__ for isclass; new to extra66"]
    - [getmembers_code_co_stacksize_class_name_eq_int,
       getmembers.__code__.co_stacksize.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.getmembers.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — getmembers is a pure-Python function (Lib/inspect.py); co_stacksize is the required stack size stored as a Python int; int.__name__ == 'int'; __eq__ returns True; no prior inspect spec checks co_stacksize.__class__.__name__ for getmembers; new to extra66"]

# ---------------------------------------------------------------------------
# inspect.isbuiltin __code__ attributes — extra66
#
# Wave 232 theme: co_nlocals and co_stacksize for isbuiltin.
#
# isbuiltin is a pure-Python function in Lib/inspect.py. Therefore its
# __code__ attribute is a standard PyCodeObject with all the usual fields.
#
# isbuiltin.__code__.co_nlocals.__class__.__name__ == 'int'
# isbuiltin.__code__.co_stacksize.__class__.__name__ == 'int'
#
# No prior inspect spec checks isbuiltin co_nlocals or co_stacksize. New to extra66.
# ---------------------------------------------------------------------------

table inspect_extra66.inspect_function_attributes:
  description: "isbuiltin co_nlocals and co_stacksize are ints; wave 232 co_nlocals/co_stacksize chains; new to extra66"
  kind: python_call_eq
  category: co_nlocals
  id_prefix: inspcode4_66

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_code_co_nlocals_class_name_eq_int,
       isbuiltin.__code__.co_nlocals.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.isbuiltin.__code__.co_nlocals.__class__.__name__.__eq__('int') == True — isbuiltin is a pure-Python function (Lib/inspect.py) that returns True if the object is a built-in function or method; its __code__ is a PyCodeObject; co_nlocals is the count of local variables stored as a Python int; int.__name__ == 'int' (3 chars); __eq__ returns True; no prior inspect spec checks co_nlocals.__class__.__name__ for isbuiltin; new to extra66"]
    - [isbuiltin_code_co_stacksize_class_name_eq_int,
       isbuiltin.__code__.co_stacksize.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.isbuiltin.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — isbuiltin is a pure-Python function (Lib/inspect.py); co_stacksize is the required evaluation stack size stored as a Python int; int.__name__ == 'int' (3 chars); __eq__ returns True; no prior inspect spec checks co_stacksize.__class__.__name__ for isbuiltin; new to extra66"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra66
# ---------------------------------------------------------------------------

invariant inspect_extra66.isfunction_co_consts_tuple:
  description: "inspect.isfunction.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — co_consts is always a tuple in CPython; wave 232 co_consts chains; new to extra66"
  kind: python_call_eq
  function: isfunction.__code__.co_consts.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra66.isfunction_co_nlocals_int:
  description: "inspect.isfunction.__code__.co_nlocals.__class__.__name__.__eq__('int') == True — co_nlocals is always a plain int; wave 232 co_nlocals chains; new to extra66"
  kind: python_call_eq
  function: isfunction.__code__.co_nlocals.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant inspect_extra66.isfunction_co_stacksize_int:
  description: "inspect.isfunction.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — co_stacksize is always a plain int; wave 232 co_stacksize chains; new to extra66"
  kind: python_call_eq
  function: isfunction.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant inspect_extra66.getmembers_co_nlocals_int:
  description: "inspect.getmembers.__code__.co_nlocals.__class__.__name__.__eq__('int') == True — co_nlocals is always a plain int for getmembers; wave 232 co_nlocals chains; new to extra66"
  kind: python_call_eq
  function: getmembers.__code__.co_nlocals.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant inspect_extra66.isbuiltin_co_nlocals_int:
  description: "inspect.isbuiltin.__code__.co_nlocals.__class__.__name__.__eq__('int') == True — co_nlocals is always a plain int for isbuiltin; wave 232 co_nlocals chains; new to extra66"
  kind: python_call_eq
  function: isbuiltin.__code__.co_nlocals.__class__.__name__.__eq__
  args: ["int"]
  expected: true
