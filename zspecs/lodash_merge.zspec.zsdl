spec: lodash_merge
version: ">=4.0.0"
backend: node(lodash.merge)

docs: https://lodash.com/docs/#merge

provenance:
  derived_from:
    - "lodash.merge README — https://www.npmjs.com/package/lodash.merge"
    - "Test vectors verified with lodash.merge@4.6.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.merge exports the _.merge function directly as module.exports."
    - "merge(object, ...sources) recursively merges own enumerable properties."
    - "Unlike assign, merge recurses into nested objects."
    - "Arrays merge by index."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns merged object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_merge.merge:
  kind: node_module_call_eq
  function: ~
  category: merge
  id_prefix: lmrg

  columns: [id, args, expected]
  rows:
    - [shallow,  [{"a": 1}, {"b": 2}],                         {"a": 1, "b": 2}]
    - [deep,     [{"a": {"x": 1}}, {"a": {"y": 2}}],           {"a": {"x": 1, "y": 2}}]
    - [override, [{"a": 1, "b": 2}, {"b": 3}],                 {"a": 1, "b": 3}]
    - [multi,    [{"a": 1}, {"b": 2}, {"c": 3}],               {"a": 1, "b": 2, "c": 3}]

