spec: concurrent_futures_extra262
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.__all__ is a list (not a tuple) of 14 names on Python 3.14."
    - "Python 3.14 added InterpreterPoolExecutor to __all__."
    - "concurrent.futures has no top-level 'Error' attribute on Python 3.14; use BrokenExecutor instead."
    - "BrokenExecutor is the primary base for executor-specific errors; it inherits from RuntimeError."
    - "BrokenExecutor.__module__ is 'concurrent.futures._base' (private submodule, not the public package)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.__all__ — type and key member checks
#
# On Python 3.14, __all__ is a list of 14 names including executors,
# Future, Executor, wait, as_completed, and exception classes.
# Notable: 'Executor' is in __all__ even though it is abstract.
# Notable: InterpreterPoolExecutor was added in Python 3.14.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra262.all.type_is_list:
  description: "type(concurrent.futures.__all__).__name__ == 'list'"
  category: all
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant concurrent_futures_extra262.all.contains_ThreadPoolExecutor:
  description: "'ThreadPoolExecutor' in concurrent.futures.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["ThreadPoolExecutor"]
  expected: true

invariant concurrent_futures_extra262.all.contains_ProcessPoolExecutor:
  description: "'ProcessPoolExecutor' in concurrent.futures.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["ProcessPoolExecutor"]
  expected: true

invariant concurrent_futures_extra262.all.contains_Future:
  description: "'Future' in concurrent.futures.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Future"]
  expected: true

invariant concurrent_futures_extra262.all.contains_Executor:
  description: "'Executor' in concurrent.futures.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra262.all.contains_wait:
  description: "'wait' in concurrent.futures.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["wait"]
  expected: true

invariant concurrent_futures_extra262.all.contains_as_completed:
  description: "'as_completed' in concurrent.futures.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["as_completed"]
  expected: true

# ---------------------------------------------------------------------------
# BrokenExecutor — exception class identity
#
# BrokenExecutor is the public base exception for executor-specific errors.
# It inherits from RuntimeError. Its __module__ is 'concurrent.futures._base'
# (the private implementation submodule), not 'concurrent.futures'.
# BrokenExecutor.__qualname__ == 'BrokenExecutor' (no nesting).
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra262.BrokenExecutor.name:
  description: "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor'"
  category: BrokenExecutor
  kind: python_call_eq
  function: BrokenExecutor.__name__.__eq__
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra262.BrokenExecutor.module:
  description: "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'"
  category: BrokenExecutor
  kind: python_call_eq
  function: BrokenExecutor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra262.BrokenExecutor.base_class:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'"
  category: BrokenExecutor
  kind: python_call_eq
  function: BrokenExecutor.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "RuntimeError"

invariant concurrent_futures_extra262.BrokenExecutor.qualname:
  description: "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor'"
  category: BrokenExecutor
  kind: python_call_eq
  function: BrokenExecutor.__qualname__.__eq__
  args: ["BrokenExecutor"]
  expected: true
