spec: picocolors
version: ">=1.0.0"
backend: node(picocolors)

docs: https://github.com/alexeyraspopov/picocolors#readme

provenance:
  derived_from:
    - "picocolors README — https://github.com/alexeyraspopov/picocolors#readme"
    - "Test vectors verified with picocolors@1.1.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "picocolors source: picocolors.js"
  notes:
    - "picocolors exports an object with methods for each color/style (red, green, bold, dim, etc.)."
    - "When stdout is not a TTY (subprocess, Docker, CI), all methods return the input string unchanged."
    - "The verify harness runs node as a subprocess with piped stdout (not a TTY), so all invariants are in no-color mode."
    - "This spec documents the no-TTY passthrough contract, which is the invariant safe to verify programmatically."
    - "Color output can be forced with FORCE_COLOR=1 env var; no-color with NO_COLOR=1."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "All methods return the input string unchanged in no-TTY mode. No errors thrown."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table picocolors.no_tty:
  kind: node_module_call_eq
  category: no_tty
  id_prefix: pc

  columns: [id, function, args, expected]
  rows:
    - [red,    red,    ["hello"],   "hello"]
    - [green,  green,  ["hi"],      "hi"]
    - [blue,   blue,   ["test"],    "test"]
    - [bold,   bold,   ["strong"],  "strong"]
    - [dim,    dim,    ["faint"],   "faint"]
    - [yellow, yellow, ["warn"],    "warn"]
    - [cyan,   cyan,   ["info"],    "info"]
    - [white,  white,  ["text"],    "text"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:41:46Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
