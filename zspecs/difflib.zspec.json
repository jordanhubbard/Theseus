    "derived_from": [
      "Python 3 difflib documentation — https://docs.python.org/3/library/difflib.html",
      "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.3.0, 2026-04-02"
    ],
    "not_derived_from": ["CPython source: Lib/difflib.py"],
    "spec_authors": ["Theseus Z-layer"],
    "created_at": "2026-04-02T00:00:00Z",
    "notes": [
      "SequenceMatcher is a class; calling it via python_call_eq constructs an instance; 'method' chains to ratio(), quick_ratio(), etc.",
      "ratio() returns a float in [0.0, 1.0]. Only exact values (0.0, 1.0) are tested to avoid floating-point representation issues.",
      "get_close_matches() returns a plain list — compatible with python_call_eq expected array comparison.",
      "IS_CHARACTER_JUNK and IS_LINE_JUNK are module-level callable objects tested via python_call_eq.",
      "ndiff(), unified_diff(), and context_diff() return generators and are not tested here — they require list() wrapping which the current harness does not support.",
      "find_longest_match() returns a Match named-tuple; individual .a/.b/.size attributes are tested via method chaining.",
      "isjunk parameter is JSON null → Python None (no junk filter)."
    ]
  },

  "library": {
    "backend": "python_module",
    "module_name": "difflib",
    "soname_patterns": []
  },

  "constants": {},
  "types": {},
  "wire_formats": {},

  "functions": {
    "SequenceMatcher": {
      "description": "Flexible class for comparing pairs of sequences. Constructs a SequenceMatcher object.",
      "parameters": [
        {"name": "isjunk", "type": "callable|None", "direction": "in"},
        {"name": "a",      "type": "sequence",      "direction": "in"},
        {"name": "b",      "type": "sequence",      "direction": "in"}
      ],
      "return_type": "SequenceMatcher"
    },
    "get_close_matches": {
      "description": "Return a list of the best good-enough matches of word in the list of possibilities.",
      "parameters": [
        {"name": "word",          "type": "str",   "direction": "in"},
        {"name": "possibilities", "type": "list",  "direction": "in"},
        {"name": "n",             "type": "int",   "direction": "in"},
        {"name": "cutoff",        "type": "float", "direction": "in"}
      ],
      "return_type": "list"
    },
    "IS_CHARACTER_JUNK": {
      "description": "Return True if ch is a space or tab character. Used as the isjunk argument to SequenceMatcher.",
      "parameters": [{"name": "ch", "type": "str", "direction": "in"}],
      "return_type": "bool"
    },
    "IS_LINE_JUNK": {
      "description": "Return True if line is blank or starts with '#'. Used as the isjunk argument to SequenceMatcher.",
      "parameters": [{"name": "line", "type": "str", "direction": "in"}],
      "return_type": "bool"
    }
  },

