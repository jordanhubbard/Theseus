spec: json_extra3
version: ">=3.5"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html
rfcs:
  - "RFC 8259 — The JavaScript Object Notation (JSON) Data Interchange Format"

provenance:
  derived_from:
    - "RFC 8259 — The JavaScript Object Notation (JSON) Data Interchange Format, December 2017"
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "json.zspec.zsdl — covers loads/dumps primary behaviour"
    - "json_extra.zspec.zsdl — covers additional loads/dumps cases"
    - "json_extra2.zspec.zsdl — covers return-type class names and dumps primitives"
    - "json_encoder.zspec.zsdl — covers JSONEncoder"
    - "json_decoder.zspec.zsdl — covers JSONDecoder"
  notes:
    - "This spec covers json class and submodule metadata not in the other json specs."
    - "json.JSONDecodeError.__name__ == 'JSONDecodeError' — exception class name."
    - "json.JSONDecodeError.__base__.__name__ == 'ValueError' — inherits from ValueError."
    - "json.JSONEncoder.__name__ == 'JSONEncoder' — encoder class name."
    - "json.JSONDecoder.__name__ == 'JSONDecoder' — decoder class name."
    - "json.JSONEncoder.__module__ == 'json.encoder' — defined in the encoder submodule."
    - "json.JSONDecoder.__module__ == 'json.decoder' — defined in the decoder submodule."
    - "json.tool.__name__ == 'json.tool' — submodule's __name__ is its fully qualified name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ attributes — JSONDecodeError, JSONEncoder, JSONDecoder
# ---------------------------------------------------------------------------

table json_extra3.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, description, function, args, expected]
  rows:
    - [JSONDecodeError,  "JSONDecodeError.__name__ == 'JSONDecodeError'",  JSONDecodeError.__name__.__eq__,  ["JSONDecodeError"],  true]
    - [JSONEncoder,      "JSONEncoder.__name__ == 'JSONEncoder'",          JSONEncoder.__name__.__eq__,      ["JSONEncoder"],      true]
    - [JSONDecoder,      "JSONDecoder.__name__ == 'JSONDecoder'",          JSONDecoder.__name__.__eq__,      ["JSONDecoder"],      true]

# ---------------------------------------------------------------------------
# JSONDecodeError base class — inherits from ValueError
# ---------------------------------------------------------------------------

invariant json_extra3.JSONDecodeError.base_is_ValueError:
  description: "JSONDecodeError.__base__.__name__ == 'ValueError'"
  category: class_hierarchy
  kind: python_call_eq
  function: JSONDecodeError.__base__.__name__.__eq__
  args: ["ValueError"]
  expected: true

# ---------------------------------------------------------------------------
# Class __module__ attributes — JSONEncoder and JSONDecoder submodules
# ---------------------------------------------------------------------------

table json_extra3.class_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: mod

  columns: [id, description, function, args, expected]
  rows:
    - [JSONEncoder_module,  "JSONEncoder.__module__ == 'json.encoder'",  JSONEncoder.__module__.__eq__,  ["json.encoder"],  true]
    - [JSONDecoder_module,  "JSONDecoder.__module__ == 'json.decoder'",  JSONDecoder.__module__.__eq__,  ["json.decoder"],  true]

# ---------------------------------------------------------------------------
# json.tool submodule — __name__ is its fully qualified module name
# ---------------------------------------------------------------------------

invariant json_extra3.tool_name:
  description: "tool.__name__ == 'json.tool'"
  category: submodules
  kind: python_call_eq
  function: tool.__name__.__eq__
  args: ["json.tool"]
  expected: true
