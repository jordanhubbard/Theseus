spec: multiprocessing_extra59
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#qualname — Python __qualname__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra58.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__.__class__.__name__/__len__() tables, Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__name__=='function', ProcessError/AuthenticationError/__class__.__name__=='type' (extra45), Process/__class__.__module__=='builtins', current_process/__class__.__module__=='builtins', cpu_count/__class__.__module__=='builtins' (extra46), Pool/__doc__/__class__/__module__=='builtins' (extra50), Pool/__class__.__name__=='type', Pool/active_children/ProcessError/AuthenticationError __class__.__module__.__eq__('builtins') (extra53), Process/__init__.__class__.__name__.__eq__('function') (extra53), Process/Pool __repr__.__class__.__name__ (extra54), Process __weakref__.__class__.__name__ (extra54), ProcessError/AuthenticationError exception __repr__.__class__.__name__ (extra54), mp.__all__.__class__.__name__.__eq__('list') (extra55), mp.__all__.__len__()==37 (extra55), Process/ProcessError/AuthenticationError __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra55), mp.__all__.__contains__ membership checks (extra56), mp.__package__.__eq__('multiprocessing') (extra56), Queue/Pool __doc__.__class__.__name__.__eq__('str') (extra56), __loader__.__class__.__name__.__eq__('SourceFileLoader') (extra57), __spec__.__class__.__name__.__eq__('ModuleSpec') (extra57), __file__.__class__.__name__.__eq__('str') (extra57), __cached__.__class__.__name__.__eq__('str') (extra57), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__() (extra58). Process method __qualname__ string equality for start/run/join/terminate/kill/is_alive/close (extra10/extra21 — all == 'BaseProcess.<method>'). Process.__init__.__qualname__.__eq__('BaseProcess.__init__') (extra49). Process.__init__.__qualname__.__len__()==20 (extra33)."
    - "This spec covers (mpqual59 namespace): wave 227 theme — class method __qualname__ string equality checks for public methods not yet covered. IMPORTANT: multiprocessing.Process inherits ALL its methods from BaseProcess; therefore Process.start/run/join/terminate/kill/is_alive/close/__init__ qualnames all carry the 'BaseProcess.' prefix (not 'Process.'). All of these were covered in extra10/extra21/extra49. NOTE: mp.Pool is a bound method object (returned by context), not a plain class — Pool method qualnames cannot be accessed directly and are skipped. NEW in extra59: Process.interrupt.__qualname__.__eq__('BaseProcess.interrupt') — Process.interrupt is available in Python 3.14+ and has NOT been covered in any prior multiprocessing spec (extra10/extra21 only covered start/run/join/terminate/kill/is_alive/close). The process method table also includes start/run/join/terminate for wave 227 completeness alongside the novel interrupt check."
    - "multiprocessing.Process.interrupt.__qualname__ == 'BaseProcess.interrupt'. Process inherits interrupt from BaseProcess (Lib/multiprocessing/process.py). The qualname carries the defining class 'BaseProcess.' prefix followed by 'interrupt'. Available in Python 3.14+. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.start.__qualname__ == 'BaseProcess.start'. Process.run.__qualname__ == 'BaseProcess.run'. Process.join.__qualname__ == 'BaseProcess.join'. Process.terminate.__qualname__ == 'BaseProcess.terminate'. All defined on BaseProcess. All previously covered in extra10/extra21. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "NOTE on mp.Pool: mp.Pool is a bound method returned by the multiprocessing context object (DefaultContext.Pool), not a direct class. Its __qualname__ reflects the context-bound method, not a class qualname. Per task instructions, Pool method qualnames are skipped in this spec."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Process method __qualname__ string equality — extra59
#
# Wave 227 theme: class method __qualname__ string equality checks for public
# methods not yet covered.
#
# IMPORTANT: multiprocessing.Process inherits ALL its methods from BaseProcess.
# Therefore all Process method qualnames carry the 'BaseProcess.' prefix.
#
# NEW: Process.interrupt.__qualname__.__eq__('BaseProcess.interrupt')
#   — available in Python 3.14+
#   — NOT covered in any prior multiprocessing spec
#   — extra10/extra21 only covered start/run/join/terminate/kill/is_alive/close
#
# NOTE: mp.Pool is a bound method object (not a plain class) — Pool method
# qualnames are skipped as instructed.
# ---------------------------------------------------------------------------

table multiprocessing_extra59.process_method_qualnames:
  description: "multiprocessing Process method __qualname__ string equality checks in mpqual59 namespace — wave 227 theme: class method __qualname__ string equality; IMPORTANT: Process inherits all methods from BaseProcess so all qualnames carry 'BaseProcess.' prefix; Process.interrupt.__qualname__.__eq__('BaseProcess.interrupt') is NEW (not in extra10/extra21); also includes start/run/join/terminate for wave 227 completeness; all methods defined in Lib/multiprocessing/process.py on BaseProcess; Pool skipped (bound method, not a class); first interrupt qualname string equality check in any multiprocessing spec"
  kind: python_call_eq
  category: qualname
  id_prefix: mpqual59

  columns: [id, function, args, expected, description]
  rows:
    - [process_init,      "Process.__init__.__qualname__.__eq__",      ["BaseProcess.__init__"],      true,  "Process.__init__.__qualname__ == 'BaseProcess.__init__' — Process does NOT override __init__; inherits from BaseProcess (Lib/multiprocessing/process.py); qualname carries defining-class prefix 'BaseProcess.' not 'Process.'; previously covered in extra49 (string equality) and extra33 (len==20); wave 227 table entry"]
    - [process_start,     Process.start.__qualname__.__eq__,           ["BaseProcess.start"],         true,  "Process.start.__qualname__ == 'BaseProcess.start' — inherited from BaseProcess without override; qualname carries 'BaseProcess.' prefix; previously covered in extra10/extra21; wave 227 table entry"]
    - [process_join,      Process.join.__qualname__.__eq__,            ["BaseProcess.join"],          true,  "Process.join.__qualname__ == 'BaseProcess.join' — inherited from BaseProcess; blocks until the process terminates; qualname carries 'BaseProcess.' prefix; previously covered in extra10/extra21; wave 227 table entry"]
    - [process_terminate, Process.terminate.__qualname__.__eq__,       ["BaseProcess.terminate"],     true,  "Process.terminate.__qualname__ == 'BaseProcess.terminate' — inherited from BaseProcess; sends SIGTERM on Unix; qualname carries 'BaseProcess.' prefix; previously covered in extra10/extra21; wave 227 table entry"]
    - [process_run,       Process.run.__qualname__.__eq__,             ["BaseProcess.run"],           true,  "Process.run.__qualname__ == 'BaseProcess.run' — inherited from BaseProcess; invokes the callable passed to the constructor; qualname carries 'BaseProcess.' prefix; previously covered in extra10/extra21; wave 227 table entry"]
    - [process_interrupt, Process.interrupt.__qualname__.__eq__,       ["BaseProcess.interrupt"],     true,  "Process.interrupt.__qualname__ == 'BaseProcess.interrupt' — NEW in extra59: Process.interrupt is available in Python 3.14+; sends SIGINT signal to the process; NOT covered in any prior multiprocessing spec (extra10/extra21 did not include interrupt); qualname carries 'BaseProcess.' prefix because all Process methods are defined on BaseProcess; first interrupt qualname string equality check in any multiprocessing spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra59
# ---------------------------------------------------------------------------

invariant multiprocessing_extra59.process_interrupt_qualname_eq:
  description: "multiprocessing.Process.interrupt.__qualname__.__eq__('BaseProcess.interrupt') returns True — Process.interrupt is available in Python 3.14+ and is inherited from BaseProcess without override; qualname carries the defining-class prefix 'BaseProcess.' rather than 'Process.'; NEW in extra59: no prior multiprocessing spec has captured the Process.interrupt qualname string equality; wave 227 first interrupt qualname eq invariant in any multiprocessing spec; verified with Python 3.14.3"
  category: qualname
  kind: python_call_eq
  function: Process.interrupt.__qualname__.__eq__
  args: ["BaseProcess.interrupt"]
  expected: true

invariant multiprocessing_extra59.process_run_qualname_eq:
  description: "multiprocessing.Process.run.__qualname__.__eq__('BaseProcess.run') returns True — Process inherits run from BaseProcess; the method invokes the callable passed to the Process constructor; qualname records the defining class as 'BaseProcess.'; wave 227 invariant alongside novel interrupt check"
  category: qualname
  kind: python_call_eq
  function: Process.run.__qualname__.__eq__
  args: ["BaseProcess.run"]
  expected: true

invariant multiprocessing_extra59.process_start_qualname_eq:
  description: "multiprocessing.Process.start.__qualname__.__eq__('BaseProcess.start') returns True — Process inherits start from BaseProcess without override; qualname carries 'BaseProcess.' prefix; wave 227 invariant alongside novel interrupt check"
  category: qualname
  kind: python_call_eq
  function: Process.start.__qualname__.__eq__
  args: ["BaseProcess.start"]
  expected: true
