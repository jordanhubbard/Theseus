spec: _socket
version: ">=3.3"
backend: python_module(_socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "RFC 793 — Transmission Control Protocol (IPPROTO_TCP = 6)"
    - "RFC 768 — User Datagram Protocol (IPPROTO_UDP = 17)"
    - "POSIX.1-2017 — AF_INET = 2, SOCK_STREAM = 1 (universally stable across Linux/macOS/BSDs)"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "_socket source: Modules/socketmodule.c (CPython C extension)"
  not_derived_from:
    - "CPython source: Lib/socket.py (Python wrapper)"
  notes:
    - "_socket is the C extension that backs the socket module. It exposes the socket class, error hierarchy, address family constants, socket type constants, and protocol constants."
    - "AF_INET == 2 is stable and guaranteed by POSIX across all major platforms (Linux, macOS, BSDs, Windows)."
    - "SOCK_STREAM == 1 is stable and guaranteed by POSIX across all major platforms."
    - "IPPROTO_TCP == 6 and IPPROTO_UDP == 17 are defined by IANA and universally constant."
    - "socket.error is an alias for OSError in Python 3.3+; its __bases__[0].__name__ is 'OSError'."
    - "gethostname and getaddrinfo are module-level functions in the C extension."
    - "AF_INET6 is intentionally omitted from constant-value checks as its integer value differs between platforms (10 on Linux, 30 on macOS)."
    - "All expected values verified by running Python 3.12 _socket module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "_socket.error is an alias for OSError (since Python 3.3). Network errors raise OSError subclasses such as TimeoutError, ConnectionRefusedError, etc."
  stderr: "null"
  stickiness: "N/A — class and constant checks are stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant _socket.socket_name:
  description: "socket class __name__ == 'socket'"
  category: classnames
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

invariant _socket.error_name:
  description: "error class __name__ == 'error'"
  category: classnames
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant _socket.error_base:
  description: "error.__bases__[0].__name__ == 'OSError' — socket.error is a subclass of OSError since Python 3.3"
  category: classnames
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "OSError"

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant _socket.gethostname_name:
  description: "gethostname.__name__ == 'gethostname'"
  category: functions
  kind: python_call_eq
  function: gethostname.__name__.__eq__
  args: ["gethostname"]
  expected: true

invariant _socket.getaddrinfo_name:
  description: "getaddrinfo.__name__ == 'getaddrinfo'"
  category: functions
  kind: python_call_eq
  function: getaddrinfo.__name__.__eq__
  args: ["getaddrinfo"]
  expected: true

# ---------------------------------------------------------------------------
# Address family constants
# ---------------------------------------------------------------------------

invariant _socket.AF_INET_value:
  description: "AF_INET == 2 — universally stable POSIX constant"
  category: constants
  kind: python_call_eq
  function: AF_INET.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# Socket type constants
# ---------------------------------------------------------------------------

invariant _socket.SOCK_STREAM_value:
  description: "SOCK_STREAM == 1 — universally stable POSIX constant"
  category: constants
  kind: python_call_eq
  function: SOCK_STREAM.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# Protocol constants
# ---------------------------------------------------------------------------

invariant _socket.IPPROTO_TCP_value:
  description: "IPPROTO_TCP == 6 — IANA-assigned protocol number for TCP"
  category: constants
  kind: python_call_eq
  function: IPPROTO_TCP.__eq__
  args: [6]
  expected: true

invariant _socket.IPPROTO_UDP_value:
  description: "IPPROTO_UDP == 17 — IANA-assigned protocol number for UDP"
  category: constants
  kind: python_call_eq
  function: IPPROTO_UDP.__eq__
  args: [17]
  expected: true

# ---------------------------------------------------------------------------
# gethostname return type check
# ---------------------------------------------------------------------------

invariant _socket.gethostname_returns_str:
  description: "gethostname().__class__.__name__ == 'str'"
  category: functions
  kind: python_call_eq
  function: gethostname
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

