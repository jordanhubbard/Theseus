spec: ft3331
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 669 (ft3331): __iand__, __ior__, __ixor__ dict-presence checks for functools types."
    - "Theme: __iand__/__ior__/__ixor__ in-place bitwise logical dict-presence."
    - "In-place augmented assignment operators (&=, |=, ^=) fall back to __and__/__or__/__xor__ if not defined."
    - "All values False — callable/iterator/inspection/synchronization types have no in-place bitwise logical operators."
    - "None of the four functools types define __iand__, __ior__, or __ixor__ in their own __dict__."
    - "functools.partial and functools._lru_cache_wrapper are C-level types; functools.partialmethod and functools.cached_property are Python-level classes."
    - "type(functools.lru_cache(lambda: None)) accesses the internal _lru_cache_wrapper C type at runtime."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3331.iand:
  description: "functools types __iand__ dict-presence checks; wave 669"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3331
  columns: [id, function, args, expected]
  rows:
    - ["ft3331001", operator.contains, [functools.partial.__dict__,                              "__iand__"], false]
    - ["ft3331002", operator.contains, [functools.partialmethod.__dict__,                        "__iand__"], false]
    - ["ft3331003", operator.contains, [functools.cached_property.__dict__,                      "__iand__"], false]
    - ["ft3331004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__,        "__iand__"], false]

