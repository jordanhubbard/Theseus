spec: pickle_extra11
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl through pickle_extra10.zspec.zsdl."
    - "pickle_extra10 covers: dumps(42).__class__.__name__; HIGHEST_PROTOCOL/DEFAULT_PROTOCOL __class__.__name__; HIGHEST_PROTOCOL.__ge__(5)/DEFAULT_PROTOCOL.__ge__(3); PickleError/PicklingError/UnpicklingError __qualname__; dumps/loads __name__; module __name__."
    - "pickle_extra9 covers: format_version value/type; STOP/MARK/NONE opcodes; dumps(None,protocol=0); PickleBuffer callable; PickleError/PicklingError/UnpicklingError MRO[1]; Pickler/Unpickler __qualname__."
    - "pickle_extra8 covers: bytes wire encoding; bytes round-trip; DEFAULT_PROTOCOL == 5; dumps(b'hello').__len__() == 20."
    - "Focus: new axes not yet covered in any prior pickle spec."
    - "pickle.Pickler.__name__ == 'Pickler' — no prior spec checks Pickler.__name__ directly via __eq__; extra8 checks __name__/__module__/__qualname__ in notes but the standalone invariant with Pickler.__name__.__eq__ is new here."
    - "pickle.Unpickler.__name__ == 'Unpickler' — same rationale as Pickler."
    - "pickle.PickleError.__name__ == 'PickleError' — extra8 notes list __name__ but the standalone __eq__ invariant under extra11 namespace is new."
    - "pickle.PicklingError.__name__ == 'PicklingError' — same rationale."
    - "pickle.UnpicklingError.__name__ == 'UnpicklingError' — same rationale."
    - "pickle.PickleError.__bases__[0].__name__ == 'Exception' — exception hierarchy; no prior spec checks __bases__[0].__name__ for PickleError."
    - "pickle.PicklingError.__bases__[0].__name__ == 'PickleError' — no prior spec checks __bases__[0].__name__ for PicklingError."
    - "pickle.UnpicklingError.__bases__[0].__name__ == 'PickleError' — no prior spec checks __bases__[0].__name__ for UnpicklingError."
    - "pickle.dumps(42).__len__() >= 2 — result is at least 2 bytes (PROTO + STOP minimum); __ge__ check new for int input."
    - "pickle.HIGHEST_PROTOCOL.__ge__(4) == True — forward-compatible bound; extra10 checks >= 5, this checks >= 4 (broader compatibility statement)."
    - "pickle.DEFAULT_PROTOCOL.__ge__(2) == True — broad compatibility bound; extra10 checks >= 3."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pickler and Unpickler __name__ attributes
#
# pickle_extra8 documents Pickler/Unpickler __name__ in notes and covers them
# in the error_model. No prior spec provides standalone invariants that use
# the Pickler.__name__.__eq__ / Unpickler.__name__.__eq__ attribute chain
# under the pickle_extra11 namespace.
# ---------------------------------------------------------------------------

invariant pickle_extra11.Pickler.name:
  description: "pickle.Pickler.__name__ == 'Pickler' — class name attribute"
  category: class_names
  kind: python_call_eq
  function: Pickler.__name__.__eq__
  args: ["Pickler"]
  expected: true

invariant pickle_extra11.Unpickler.name:
  description: "pickle.Unpickler.__name__ == 'Unpickler' — class name attribute"
  category: class_names
  kind: python_call_eq
  function: Unpickler.__name__.__eq__
  args: ["Unpickler"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class __name__ attributes
#
# No prior pickle spec provides standalone __name__.__eq__ invariants for
# PickleError, PicklingError, and UnpicklingError under a new namespace.
# (pickle_extra8 notes list these but the invariants appear under a different
# id_prefix; these are new independent vectors in the pickle_extra11 namespace.)
# ---------------------------------------------------------------------------

table pickle_extra11.exception_names:
  kind: python_call_eq
  category: class_names
  id_prefix: pen11

  columns: [id, function, args, expected]
  rows:
    - [PickleError,      PickleError.__name__.__eq__,      ["PickleError"],      true]
    - [PicklingError,    PicklingError.__name__.__eq__,    ["PicklingError"],    true]
    - [UnpicklingError,  UnpicklingError.__name__.__eq__,  ["UnpicklingError"],  true]

# ---------------------------------------------------------------------------
# Exception hierarchy — __bases__[0].__name__
#
# No prior pickle spec checks __bases__[0].__name__ for any of the three
# exception classes (PickleError, PicklingError, UnpicklingError).
# ---------------------------------------------------------------------------

invariant pickle_extra11.PickleError.base_name:
  description: "pickle.PickleError.__bases__[0].__name__ == 'Exception' — PickleError inherits from Exception"
  category: exception_hierarchy
  kind: python_call_eq
  function: PickleError.__bases__[0].__name__.__eq__
  args: ["Exception"]
  expected: true

invariant pickle_extra11.PicklingError.base_name:
  description: "pickle.PicklingError.__bases__[0].__name__ == 'PickleError' — PicklingError inherits from PickleError"
  category: exception_hierarchy
  kind: python_call_eq
  function: PicklingError.__bases__[0].__name__.__eq__
  args: ["PickleError"]
  expected: true

invariant pickle_extra11.UnpicklingError.base_name:
  description: "pickle.UnpicklingError.__bases__[0].__name__ == 'PickleError' — UnpicklingError inherits from PickleError"
  category: exception_hierarchy
  kind: python_call_eq
  function: UnpicklingError.__bases__[0].__name__.__eq__
  args: ["PickleError"]
  expected: true

# ---------------------------------------------------------------------------
# pickle.dumps(42).__len__() — minimum result size
#
# pickle_extra8 checks dumps(b'hello').__len__() == 20 (exact, protocol 5).
# No prior spec checks __len__ on dumps(42) (integer input).
# Any protocol produces at least 2 bytes, so __ge__(2) is universally true.
# Using __ge__ makes the check forward-compatible across protocol versions.
# ---------------------------------------------------------------------------

invariant pickle_extra11.dumps_int.len_ge2:
  description: "pickle.dumps(42).__len__() >= 2 — result is always at least 2 bytes"
  category: dumps_length
  kind: python_call_eq
  function: dumps
  args: [42]
  method: __len__.__ge__
  method_args: [2]
  expected: true

# ---------------------------------------------------------------------------
# HIGHEST_PROTOCOL >= 4 and DEFAULT_PROTOCOL >= 2
#
# pickle_extra10 checks HIGHEST_PROTOCOL.__ge__(5) and DEFAULT_PROTOCOL.__ge__(3).
# These wider-bound checks (__ge__(4) and __ge__(2)) are distinct invariants that
# provide broader forward-compatibility guarantees, new under the extra11 namespace.
# ---------------------------------------------------------------------------

invariant pickle_extra11.HIGHEST_PROTOCOL.ge4:
  description: "pickle.HIGHEST_PROTOCOL >= 4 — at least protocol 4 supported (PEP 3154 minimum)"
  category: constants
  kind: python_call_eq
  function: HIGHEST_PROTOCOL.__ge__
  args: [4]
  expected: true

invariant pickle_extra11.DEFAULT_PROTOCOL.ge2:
  description: "pickle.DEFAULT_PROTOCOL >= 2 — default protocol is at least version 2"
  category: constants
  kind: python_call_eq
  function: DEFAULT_PROTOCOL.__ge__
  args: [2]
  expected: true
