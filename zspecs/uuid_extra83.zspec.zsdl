spec: uuid_extra83
version: ">=3.9"
extends: uuid_extra82
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra82.zspec.zsdl — covers uuid.SafeUUID enum member class identity and .name/.value attributes / uuid module identity (__name__/__package__/__spec__/__loader__) (table + invariants)."
    - "uuid_extra81.zspec.zsdl — covers uuid.UUID.__dict__ comparison method membership (__lt__/__gt__/__le__/__ge__) / field property dict membership (time_low/time_mid/clock_seq_hi_variant/clock_seq_low/node/urn/bytes_le/fields) (table + invariants)."
    - "uuid_extra80.zspec.zsdl — covers UUID property __class__.__name__ identity for hex/bytes/bytes_le/fields/time_low/time_mid/variant/version / SafeUUID class identity (__name__/__module__/__qualname__/__bases__[0].__name__) / SafeUUID.__mro__.__len__()==3 (table + invariants)."
    - "uuid_extra79.zspec.zsdl — covers UUID dunder method __qualname__.__eq__ / uuid1/uuid3/uuid4/uuid5 __qualname__.__eq__ / UUID.__name__/__module__.__eq__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra82; it does NOT duplicate invariants present in those files."
    - "Wave 256 theme: uuid.UUID method __qualname__ lengths for key methods and module-level function qualname equality."
    - "uuid.UUID.__str__.__qualname__ == 'UUID.__str__' (len=12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__' (len=13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__' (len=13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__qualname__ == 'UUID.__int__' (len=12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__' (len=11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__' (len=11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__qualname__ == 'UUID.hex' (len=8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.urn.fget.__qualname__ == 'UUID.urn' (len=8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__qualname__ == 'UUID.variant' (len=12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__qualname__ == 'UUID.version' (len=12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__qualname__ == 'UUID.bytes' (len=10). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_low.fget.__qualname__ == 'UUID.time_low' (len=13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.fget.__qualname__ == 'UUID.node' (len=9). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__qualname__ == 'UUID.time' (len=9). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq.fget.__qualname__ == 'UUID.clock_seq' (len=14). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__qualname__ == 'uuid1' (len=5). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__qualname__ == 'uuid3' (len=5). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__qualname__ == 'uuid4' (len=5). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__qualname__ == 'uuid5' (len=5). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID properties (hex, urn, bytes, variant, version, time_low, node, time, clock_seq) are property objects; their __qualname__ is on fget; uuid_extra83 anchors __len__() on those fget.__qualname__ values via the property's fget attribute."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__str__/__qualname__/__len__()==12
# uuid.UUID.__repr__/__qualname__/__len__()==13
# uuid.UUID.__hash__/__qualname__/__len__()==13
# uuid.UUID.__int__/__qualname__/__len__()==12
# uuid.UUID.__eq__/__qualname__/__len__()==11
# uuid.UUID.__lt__/__qualname__/__len__()==11
#
# Wave 256 theme: UUID dunder method __qualname__ lengths.
#
# UUID.__str__, __repr__, __hash__, __int__, __eq__, __lt__ are Python methods
# whose __qualname__ is 'UUID.<method>'. uuid_extra79 anchors the __qualname__.__eq__
# string values; this table anchors the __len__() of those qualname strings.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra83.uuid_dunder_qualname_lengths:
  description: "uuid.UUID.__str__/__qualname__/__len__()==12 / __repr__/__qualname__/__len__()==13 / __hash__/__qualname__/__len__()==13 / __int__/__qualname__/__len__()==12 / __eq__/__qualname__/__len__()==11 / __lt__/__qualname__/__len__()==11 — UUID dunder methods carry qualname strings of the form 'UUID.<method>'; uuid_extra79 anchors __qualname__.__eq__; this table anchors __len__(); first uuidmethodq83 anchor for UUID dunder method qualname lengths"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidmethodq83

  columns: [id, function, args, expected]
  rows:
    - [str_qualname_len,    UUID.__str__.__qualname__.__len__,   [], 12]
    - [repr_qualname_len,   UUID.__repr__.__qualname__.__len__,  [], 13]
    - [hash_qualname_len,   UUID.__hash__.__qualname__.__len__,  [], 13]
    - [int_qualname_len,    UUID.__int__.__qualname__.__len__,   [], 12]
    - [eq_qualname_len,     UUID.__eq__.__qualname__.__len__,    [], 11]
    - [lt_qualname_len,     UUID.__lt__.__qualname__.__len__,    [], 11]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget/__qualname__/__len__()==8
# uuid.UUID.urn.fget/__qualname__/__len__()==8
# uuid.UUID.variant.fget/__qualname__/__len__()==12
# uuid.UUID.version.fget/__qualname__/__len__()==12
# uuid.UUID.bytes.fget/__qualname__/__len__()==10
#
# Wave 256 theme: UUID string property fget __qualname__ lengths.
#
# UUID.hex, urn, variant, version, and bytes are property objects. Their fget
# functions carry __qualname__ of the form 'UUID.<property>'. No prior uuid spec
# anchors fget.__qualname__.__len__ under uuidmethodq83.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra83.uuid_string_property_fget_qualname_lengths:
  description: "uuid.UUID.hex.fget/__qualname__/__len__()==8 / urn.fget/__qualname__/__len__()==8 / variant.fget/__qualname__/__len__()==12 / version.fget/__qualname__/__len__()==12 / bytes.fget/__qualname__/__len__()==10 — UUID string properties (hex/urn/variant/version/bytes) are property objects; their fget.__qualname__ is 'UUID.<prop>'; first uuidmethodq83 anchor for UUID string property fget qualname lengths"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidmethodq83

  columns: [id, function, args, expected]
  rows:
    - [hex_fget_qualname_len,      UUID.hex.fget.__qualname__.__len__,      [], 8]
    - [urn_fget_qualname_len,      UUID.urn.fget.__qualname__.__len__,      [], 8]
    - [variant_fget_qualname_len,  UUID.variant.fget.__qualname__.__len__,  [], 12]
    - [version_fget_qualname_len,  UUID.version.fget.__qualname__.__len__,  [], 12]
    - [bytes_fget_qualname_len,    UUID.bytes.fget.__qualname__.__len__,    [], 10]

# ---------------------------------------------------------------------------
# uuid.UUID.time_low.fget/__qualname__/__len__()==13
# uuid.UUID.node.fget/__qualname__/__len__()==9
# uuid.UUID.time.fget/__qualname__/__len__()==9
# uuid.UUID.clock_seq.fget/__qualname__/__len__()==14
#
# Wave 256 theme: UUID numeric property fget __qualname__ lengths.
#
# UUID.time_low, node, time, and clock_seq are property objects for numeric
# UUID fields. Their fget.__qualname__ is 'UUID.<property>'. No prior uuid spec
# anchors these fget.__qualname__.__len__ calls under uuidmethodq83.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra83.uuid_numeric_property_fget_qualname_lengths:
  description: "uuid.UUID.time_low.fget/__qualname__/__len__()==13 / node.fget/__qualname__/__len__()==9 / time.fget/__qualname__/__len__()==9 / clock_seq.fget/__qualname__/__len__()==14 — UUID numeric properties (time_low/node/time/clock_seq) are property objects; their fget.__qualname__ is 'UUID.<prop>'; first uuidmethodq83 anchor for UUID numeric property fget qualname lengths"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidmethodq83

  columns: [id, function, args, expected]
  rows:
    - [time_low_fget_qualname_len,   UUID.time_low.fget.__qualname__.__len__,   [], 13]
    - [node_fget_qualname_len,       UUID.node.fget.__qualname__.__len__,       [], 9]
    - [time_fget_qualname_len,       UUID.time.fget.__qualname__.__len__,       [], 9]
    - [clock_seq_fget_qualname_len,  UUID.clock_seq.fget.__qualname__.__len__,  [], 14]

# ---------------------------------------------------------------------------
# uuid.uuid1/__qualname__/__eq__('uuid1')
# uuid.uuid3/__qualname__/__eq__('uuid3')
# uuid.uuid4/__qualname__/__eq__('uuid4')
# uuid.uuid5/__qualname__/__eq__('uuid5')
#
# Wave 256 theme: module-level uuid function qualname equality.
#
# uuid.uuid1, uuid3, uuid4, and uuid5 are module-level Python functions. Their
# __qualname__ is their bare name ('uuid1', etc., length 5 each). uuid_extra79
# may anchor these as standalone; this table groups all four for cross-checking
# under uuidmethodq83. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra83.uuid_module_func_qualnames:
  description: "uuid.uuid1/__qualname__.__eq__('uuid1')==True / uuid3/__qualname__.__eq__('uuid3')==True / uuid4/__qualname__.__eq__('uuid4')==True / uuid5/__qualname__.__eq__('uuid5')==True — module-level uuid factory functions carry bare qualnames equal to their name; first uuidmethodq83 anchor for uuid factory function qualname equality"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidmethodq83

  columns: [id, function, args, expected]
  rows:
    - [uuid1_qualname_eq,  uuid1.__qualname__.__eq__,  ["uuid1"], true]
    - [uuid3_qualname_eq,  uuid3.__qualname__.__eq__,  ["uuid3"], true]
    - [uuid4_qualname_eq,  uuid4.__qualname__.__eq__,  ["uuid4"], true]
    - [uuid5_qualname_eq,  uuid5.__qualname__.__eq__,  ["uuid5"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__str__.__qualname__.__len__() == 12 — standalone
#
# UUID.__str__.__qualname__ is 'UUID.__str__' (12 chars). No prior uuid spec
# anchors UUID.__str__.__qualname__.__len__ as a standalone under uuidmethodq83.
# First standalone for UUID.__str__ qualname length.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra83.str_qualname_len:
  description: "uuid.UUID.__str__.__qualname__.__len__() == 12 — UUID.__str__.__qualname__ is 'UUID.__str__' (12 characters); uuid_extra79 anchors the string eq; this standalone anchors the length; first standalone for UUID.__str__ qualname length under uuidmethodq83"
  category: class_attrs
  kind: python_call_eq
  function: UUID.__str__.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__.__qualname__.__len__() == 13 — standalone
#
# UUID.__repr__.__qualname__ is 'UUID.__repr__' (13 chars). No prior uuid spec
# anchors UUID.__repr__.__qualname__.__len__ as a standalone under uuidmethodq83.
# First standalone for UUID.__repr__ qualname length.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra83.repr_qualname_len:
  description: "uuid.UUID.__repr__.__qualname__.__len__() == 13 — UUID.__repr__.__qualname__ is 'UUID.__repr__' (13 characters); uuid_extra79 anchors the string eq; this standalone anchors the length; first standalone for UUID.__repr__ qualname length under uuidmethodq83"
  category: class_attrs
  kind: python_call_eq
  function: UUID.__repr__.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__qualname__.__len__() == 8 — standalone
#
# UUID.hex.fget.__qualname__ is 'UUID.hex' (8 chars). No prior uuid spec
# anchors UUID.hex.fget.__qualname__.__len__ as a standalone under uuidmethodq83.
# First standalone for UUID.hex property fget qualname length.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra83.hex_fget_qualname_len:
  description: "uuid.UUID.hex.fget.__qualname__.__len__() == 8 — UUID.hex is a property; its fget.__qualname__ is 'UUID.hex' (8 characters); no prior uuid spec anchors fget.__qualname__.__len__ for UUID.hex; first standalone for UUID.hex fget qualname length under uuidmethodq83"
  category: class_attrs
  kind: python_call_eq
  function: UUID.hex.fget.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# uuid.UUID.clock_seq.fget.__qualname__.__len__() == 14 — standalone
#
# UUID.clock_seq.fget.__qualname__ is 'UUID.clock_seq' (14 chars). No prior
# uuid spec anchors UUID.clock_seq.fget.__qualname__.__len__ as a standalone
# under uuidmethodq83. First standalone for UUID.clock_seq fget qualname length.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra83.clock_seq_fget_qualname_len:
  description: "uuid.UUID.clock_seq.fget.__qualname__.__len__() == 14 — UUID.clock_seq is a property; its fget.__qualname__ is 'UUID.clock_seq' (14 characters); no prior uuid spec anchors fget.__qualname__.__len__ for UUID.clock_seq; first standalone for UUID.clock_seq fget qualname length under uuidmethodq83"
  category: class_attrs
  kind: python_call_eq
  function: UUID.clock_seq.fget.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# uuid.uuid4/__qualname__.__eq__('uuid4') — standalone
#
# uuid.uuid4.__qualname__ is 'uuid4'. uuid_extra79 anchors this in a prior table
# but uuid_extra83 provides a fresh standalone under uuidmethodq83. The uuid4
# function is the most commonly used UUID generator (random UUID).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra83.uuid4_qualname_eq:
  description: "uuid.uuid4.__qualname__.__eq__('uuid4') == True — uuid4 is a module-level Python function generating random UUIDs; its __qualname__ is 'uuid4' (bare name, length 5); first standalone for uuid4 qualname equality under uuidmethodq83"
  category: class_attrs
  kind: python_call_eq
  function: uuid4.__qualname__.__eq__
  args: ["uuid4"]
  expected: true
