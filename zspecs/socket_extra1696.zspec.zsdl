spec: socket_extra1696
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "https://docs.python.org/3/library/pickle.html — Python pickle protocol documentation"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 560 (_extra1696): pickling protocol dict-presence checks."
    - "socket.socket holds a file descriptor and is NOT picklable.  It defines __getstate__ in its own __dict__ specifically to raise TypeError when pickling is attempted."
    - "socket.socket does not define __reduce__, __setstate__, __getnewargs__, __getnewargs_ex__, __copy__, or __deepcopy__ in its own __dict__."
    - "socket.socket is a Python-level class (socket.py) that inherits from _socket.socket (the C extension type).  _socket.socket defines none of the pickle dunders in its own __dict__ either."
    - "socket.SocketType is the C-level base class (_socket.socket) and is distinct from socket.socket — it defines none of the pickle or copy dunders in its own __dict__."
    - "socket.socket does define several Python-level API methods in its own __dict__: close, accept, makefile, sendfile, get_inheritable, set_inheritable, family, type, detach, __enter__, __exit__, and __getstate__ (the TypeError-raising one)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: Pickling protocol methods on socket.socket.__dict__
#
# socket.socket intentionally defines __getstate__ to raise TypeError,
# preventing accidental pickling of live file descriptors.  All other
# pickle protocol dunders are absent from socket.socket.__dict__.
# ---------------------------------------------------------------------------

table socket_extra1696.pickling_protocol:
  description: "socket.socket pickling protocol dict-presence checks — __getstate__ present (raises TypeError); all other pickle dunders absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1696

  columns: [id, function, args, expected]
  rows:
    - ["sk1696001", "socket.socket.__dict__.__contains__", ["__reduce__"],        false]
    - ["sk1696002", "socket.socket.__dict__.__contains__", ["__getstate__"],      true]
    - ["sk1696003", "socket.socket.__dict__.__contains__", ["__setstate__"],      false]
    - ["sk1696004", "socket.socket.__dict__.__contains__", ["__getnewargs__"],    false]
    - ["sk1696005", "socket.socket.__dict__.__contains__", ["__getnewargs_ex__"], false]

# ---------------------------------------------------------------------------
# Table 2: Copy protocol and pickling protocol on socket.SocketType and
#          _socket.socket (the C-level base class)
#
# socket.SocketType is the underlying C extension class (_socket.socket).
# Neither socket.socket nor socket.SocketType defines __copy__ or __deepcopy__.
# _socket.socket defines none of the pickle or copy dunders either.
# ---------------------------------------------------------------------------

table socket_extra1696.copy_and_base_protocol:
  description: "socket.socket and socket.SocketType copy protocol dict-presence checks — no copy dunders defined; _socket.socket also defines no pickle dunders"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1696

  columns: [id, function, args, expected]
  rows:
    - ["sk1696006", "socket.socket.__dict__.__contains__",     ["__copy__"],          false]
    - ["sk1696007", "socket.socket.__dict__.__contains__",     ["__deepcopy__"],      false]
    - ["sk1696008", "socket.SocketType.__dict__.__contains__", ["__reduce__"],        false]
    - ["sk1696009", "socket.SocketType.__dict__.__contains__", ["__getstate__"],      false]
    - ["sk1696010", "socket.SocketType.__dict__.__contains__", ["__setstate__"],      false]
    - ["sk1696011", "socket.SocketType.__dict__.__contains__", ["__getnewargs__"],    false]
    - ["sk1696012", "socket.SocketType.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["sk1696013", "socket.SocketType.__dict__.__contains__", ["__copy__"],          false]
    - ["sk1696014", "socket.SocketType.__dict__.__contains__", ["__deepcopy__"],      false]

# ---------------------------------------------------------------------------
# Table 3: Python-level API methods present in socket.socket.__dict__
#
# socket.socket adds several methods in pure Python on top of the C base
# class _socket.socket.  These are all present in socket.socket.__dict__:
# close, accept, makefile, sendfile, get_inheritable, set_inheritable,
# detach, family, type, __enter__, __exit__, and __getstate__ (the
# TypeError-raising sentinel, counted in Table 1 above).
# Methods that live only in the C base (_socket.socket) — such as fileno,
# connect, bind, listen, recv, send — are NOT in socket.socket.__dict__.
# ---------------------------------------------------------------------------

table socket_extra1696.python_api_dict_presence:
  description: "socket.socket Python-level API dict-presence checks — methods added in socket.py present; C-level methods absent from Python class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1696

  columns: [id, function, args, expected]
  rows:
    - ["sk1696015", "socket.socket.__dict__.__contains__", ["close"],            true]
    - ["sk1696016", "socket.socket.__dict__.__contains__", ["accept"],           true]
    - ["sk1696017", "socket.socket.__dict__.__contains__", ["makefile"],         true]
    - ["sk1696018", "socket.socket.__dict__.__contains__", ["sendfile"],         true]
    - ["sk1696019", "socket.socket.__dict__.__contains__", ["get_inheritable"],  true]
    - ["sk1696020", "socket.socket.__dict__.__contains__", ["set_inheritable"],  true]
    - ["sk1696021", "socket.socket.__dict__.__contains__", ["detach"],           true]
    - ["sk1696022", "socket.socket.__dict__.__contains__", ["family"],           true]
    - ["sk1696023", "socket.socket.__dict__.__contains__", ["type"],             true]
    - ["sk1696024", "socket.socket.__dict__.__contains__", ["__enter__"],        true]
    - ["sk1696025", "socket.socket.__dict__.__contains__", ["__exit__"],         true]
    - ["sk1696026", "socket.socket.__dict__.__contains__", ["fileno"],           false]
    - ["sk1696027", "socket.socket.__dict__.__contains__", ["connect"],          false]
    - ["sk1696028", "socket.socket.__dict__.__contains__", ["bind"],             false]
