spec: threading_extra263
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading.zspec.zsdl — covers Barrier, BoundedSemaphore, Condition classnames; function names; TIMEOUT_MAX; Lock, Event, Semaphore, current_thread.is_alive"
    - "threading_extra.zspec.zsdl — covers BoundedSemaphore/Condition/Semaphore/Event/RLock __module__; local; get_ident return type; TIMEOUT_MAX; stack_size return type"
    - "threading_extra262.zspec.zsdl — covers get_ident, get_native_id, settrace, setprofile, stack_size identity"
  notes:
    - "threading.TIMEOUT_MAX == 9223372036.0; type is float; TIMEOUT_MAX > 1e8 is True."
    - "threading.excepthook is a C-level builtin from _thread: __name__ == '_excepthook'; __qualname__ == '_excepthook'; __module__ == '_thread'; __class__.__name__ == 'builtin_function_or_method'."
    - "threading.__excepthook__ is the same object as threading.excepthook (identity check)."
    - "threading.ExceptHookArgs.__name__ == '_ExceptHookArgs'; __module__ == '_thread'; __bases__[0].__name__ == 'tuple'; __class__.__name__ == 'type'."
    - "ExceptHookArgs is a named tuple type whose base is tuple, defined in the _thread C extension."
    - "All values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TIMEOUT_MAX — constant value and type
#
# threading.TIMEOUT_MAX is 9223372036.0 (a float equal to 2^63/1e9 nanoseconds).
# It is the maximum value accepted by blocking calls with a timeout parameter.
# ---------------------------------------------------------------------------

invariant threading_extra263.TIMEOUT_MAX.class_name:
  description: "type(threading.TIMEOUT_MAX).__name__ == 'float'"
  category: identity
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra263.TIMEOUT_MAX.value:
  description: "threading.TIMEOUT_MAX == 9223372036.0"
  category: identity
  kind: python_call_eq
  function: TIMEOUT_MAX.__eq__
  args: [9223372036.0]
  expected: true

invariant threading_extra263.TIMEOUT_MAX.is_large:
  description: "threading.TIMEOUT_MAX > 1e8 — very large timeout ceiling"
  category: identity
  kind: python_call_eq
  function: TIMEOUT_MAX.__gt__
  args: [100000000.0]
  expected: true

# ---------------------------------------------------------------------------
# threading.excepthook — function identity
#
# excepthook is a C-level builtin re-exported from _thread.
# Its public name in threading is 'excepthook' but its __name__ is '_excepthook'.
# __module__ is '_thread' (the C extension), not 'threading'.
# ---------------------------------------------------------------------------

invariant threading_extra263.excepthook.name:
  description: "threading.excepthook.__name__ == '_excepthook'"
  category: identity
  kind: python_call_eq
  function: excepthook.__name__.__eq__
  args: ["_excepthook"]
  expected: true

invariant threading_extra263.excepthook.qualname:
  description: "threading.excepthook.__qualname__ == '_excepthook'"
  category: identity
  kind: python_call_eq
  function: excepthook.__qualname__.__eq__
  args: ["_excepthook"]
  expected: true

invariant threading_extra263.excepthook.module:
  description: "threading.excepthook.__module__ == '_thread' — C-level builtin from _thread"
  category: identity
  kind: python_call_eq
  function: excepthook.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra263.excepthook.class_name:
  description: "threading.excepthook.__class__.__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: excepthook.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# threading.__excepthook__ — same object as excepthook
#
# __excepthook__ is the original unmodified hook; threading allows replacing
# excepthook at runtime, but __excepthook__ always refers to the original.
# On a fresh import, both names refer to the same object.
# ---------------------------------------------------------------------------

invariant threading_extra263.__excepthook__.is_same_as_excepthook:
  description: "threading.__excepthook__ is threading.excepthook — same object on fresh import"
  category: identity
  kind: python_call_eq
  function: __excepthook__.__eq__
  args: [excepthook]
  expected: true

# ---------------------------------------------------------------------------
# threading.ExceptHookArgs — named tuple type identity
#
# ExceptHookArgs is a named tuple type defined in the _thread C extension.
# Its internal __name__ is '_ExceptHookArgs'; __module__ is '_thread';
# its sole base class is tuple (it is a named tuple subclass).
# ---------------------------------------------------------------------------

invariant threading_extra263.ExceptHookArgs.name:
  description: "threading.ExceptHookArgs.__name__ == '_ExceptHookArgs'"
  category: identity
  kind: python_call_eq
  function: ExceptHookArgs.__name__.__eq__
  args: ["_ExceptHookArgs"]
  expected: true

invariant threading_extra263.ExceptHookArgs.module:
  description: "threading.ExceptHookArgs.__module__ == '_thread'"
  category: identity
  kind: python_call_eq
  function: ExceptHookArgs.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra263.ExceptHookArgs.base_name:
  description: "threading.ExceptHookArgs.__bases__[0].__name__ == 'tuple' — named tuple subclass"
  category: identity
  kind: python_call_eq
  function: ExceptHookArgs.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["tuple"]
  expected: true

invariant threading_extra263.ExceptHookArgs.class_name:
  description: "threading.ExceptHookArgs.__class__.__name__ == 'type' — it is a class object"
  category: identity
  kind: python_call_eq
  function: ExceptHookArgs.__class__.__name__.__eq__
  args: ["type"]
  expected: true
