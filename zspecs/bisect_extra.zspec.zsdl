spec: bisect_extra
version: ">=3.2"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "Python bisect documentation — https://docs.python.org/3/library/bisect.html"
    - "Test vectors verified by running Python 3.14.3 bisect module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec covers identity and behavioral invariants not present in bisect.zspec.zsdl."
    - "bisect_left and bisect_right are C-implemented functions; their __module__ == '_bisect'."
    - "bisect is an alias for bisect_right; bisect.__name__ == 'bisect_right'."
    - "insort is an alias for insort_right; insort.__name__ == 'insort_right'."
    - "insort_left and insort_right mutate the list in-place; only __name__ is verified here."
    - "With duplicates, bisect_left returns the index of the first occurrence; bisect_right returns one past the last."
    - "All expected values verified by running Python 3.14.3 bisect module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name identity
# ---------------------------------------------------------------------------

invariant bisect_extra.bisect_left.name:
  description: "bisect_left.__name__ == 'bisect_left'"
  category: identity
  kind: python_call_eq
  function: bisect_left.__name__.__eq__
  args: ["bisect_left"]
  expected: true

invariant bisect_extra.bisect_left.module:
  description: "bisect_left.__module__ == '_bisect' — C implementation"
  category: identity
  kind: python_call_eq
  function: bisect_left.__module__.__eq__
  args: ["_bisect"]
  expected: true

invariant bisect_extra.bisect_right.name:
  description: "bisect_right.__name__ == 'bisect_right'"
  category: identity
  kind: python_call_eq
  function: bisect_right.__name__.__eq__
  args: ["bisect_right"]
  expected: true

invariant bisect_extra.insort_left.name:
  description: "insort_left.__name__ == 'insort_left'"
  category: identity
  kind: python_call_eq
  function: insort_left.__name__.__eq__
  args: ["insort_left"]
  expected: true

invariant bisect_extra.insort_right.name:
  description: "insort_right.__name__ == 'insort_right'"
  category: identity
  kind: python_call_eq
  function: insort_right.__name__.__eq__
  args: ["insort_right"]
  expected: true

invariant bisect_extra.bisect.alias_name:
  description: "bisect.__name__ == 'bisect_right' — bisect is an alias for bisect_right"
  category: identity
  kind: python_call_eq
  function: bisect.__name__.__eq__
  args: ["bisect_right"]
  expected: true

invariant bisect_extra.insort.alias_name:
  description: "insort.__name__ == 'insort_right' — insort is an alias for insort_right"
  category: identity
  kind: python_call_eq
  function: insort.__name__.__eq__
  args: ["insort_right"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral invariants — [1, 2, 3, 4, 5] (all distinct)
# ---------------------------------------------------------------------------

invariant bisect_extra.bisect_left.distinct_list:
  description: "bisect_left([1,2,3,4,5], 3) == 2 — left insertion point for 3"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[1, 2, 3, 4, 5], 3]
  expected: 2

invariant bisect_extra.bisect_right.distinct_list:
  description: "bisect_right([1,2,3,4,5], 3) == 3 — right insertion point for 3"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[1, 2, 3, 4, 5], 3]
  expected: 3

# ---------------------------------------------------------------------------
# Behavioral invariants — duplicates: [1, 2, 3, 3, 3, 4]
# bisect_left returns index of first occurrence; bisect_right returns one past last.
# ---------------------------------------------------------------------------

invariant bisect_extra.bisect_left.duplicates:
  description: "bisect_left([1,2,3,3,3,4], 3) == 2 — index of first 3"
  category: duplicates
  kind: python_call_eq
  function: bisect_left
  args: [[1, 2, 3, 3, 3, 4], 3]
  expected: 2

invariant bisect_extra.bisect_right.duplicates:
  description: "bisect_right([1,2,3,3,3,4], 3) == 5 — one past the last 3"
  category: duplicates
  kind: python_call_eq
  function: bisect_right
  args: [[1, 2, 3, 3, 3, 4], 3]
  expected: 5
