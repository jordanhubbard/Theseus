spec: lodash_clonedeep
version: ">=4.0.0"
backend: node(lodash.clonedeep)

docs: https://lodash.com/docs/#cloneDeep

provenance:
  derived_from:
    - "lodash.clonedeep README — https://www.npmjs.com/package/lodash.clonedeep"
    - "Test vectors verified with lodash.clonedeep@4.5.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.clonedeep exports the _.cloneDeep function directly as module.exports."
    - "cloneDeep(value) creates a deep clone with no shared references."
    - "The returned value is structurally equal to the input."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a deep clone of the input. No errors for valid inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_clonedeep.clone:
  kind: node_module_call_eq
  function: ~
  category: clone
  id_prefix: lcd

  columns: [id, args, expected]
  rows:
    - [object,  [{"a": {"b": [1, 2]}}],  {"a": {"b": [1, 2]}}]
    - [array,   [[1, [2, 3], 4]],        [1, [2, 3], 4]]
    - [string,  [{"s": "hello"}],        {"s": "hello"}]

