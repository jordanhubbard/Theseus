spec: re_extra264
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.Pattern instance methods (match, search, fullmatch, etc.) are C-level bound methods."
    - "p.match.__class__.__name__ == 'builtin_method'; p.findall.__class__.__name__ == 'builtin_function_or_method'."
    - "re.Match.start()/end()/span() return integers and a tuple respectively."
    - "re.match(r'(\\w+)', 'hello world').start() == 0, .end() == 5, .span() == (0, 5)."
    - "Passing group=0 explicitly to start(0)/end(0) returns the same result as start()/end()."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern instance method __name__ values
# ---------------------------------------------------------------------------

table re_extra264.match_positions:
  description: "re.match start/end positions for word match against 'hello world'"
  kind: python_call_eq
  category: match_positions
  id_prefix: pos

  columns: [id, function, args, expected, description]
  rows:
    - [start_default,  match, ["(\\w+)", "hello world"], 0, "match.start() == 0 — match begins at index 0"]
    - [end_default,    match, ["(\\w+)", "hello world"], 5, "match.end() == 5 — match ends at index 5"]

# ---------------------------------------------------------------------------
# re.Pattern instance methods — __name__ via standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra264.pattern.match.name:
  description: "re.compile(r'(\\w+)').match.__name__ == 'match'"
  category: identity
  kind: python_call_eq
  function: compile
  args: ["(\\w+)"]
  method: match
  method_chain: __name__
  expected: "match"

invariant re_extra264.pattern.match.class_name:
  description: "re.compile(r'(\\w+)').match.__class__.__name__ == 'builtin_method'"
  category: identity
  kind: python_call_eq
  function: compile
  args: ["(\\w+)"]
  method: match
  method_chain: __class__
  method_chain2: __name__
  expected: "builtin_method"

invariant re_extra264.pattern.search.name:
  description: "re.compile(r'(\\w+)').search.__name__ == 'search'"
  category: identity
  kind: python_call_eq
  function: compile
  args: ["(\\w+)"]
  method: search
  method_chain: __name__
  expected: "search"

invariant re_extra264.pattern.fullmatch.name:
  description: "re.compile(r'(\\w+)').fullmatch.__name__ == 'fullmatch'"
  category: identity
  kind: python_call_eq
  function: compile
  args: ["(\\w+)"]
  method: fullmatch
  method_chain: __name__
  expected: "fullmatch"

invariant re_extra264.pattern.findall.name:
  description: "re.compile(r'(\\w+)').findall.__name__ == 'findall'"
  category: identity
  kind: python_call_eq
  function: compile
  args: ["(\\w+)"]
  method: findall
  method_chain: __name__
  expected: "findall"

invariant re_extra264.pattern.findall.class_name:
  description: "re.compile(r'(\\w+)').findall.__class__.__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: compile
  args: ["(\\w+)"]
  method: findall
  method_chain: __class__
  method_chain2: __name__
  expected: "builtin_function_or_method"

invariant re_extra264.pattern.finditer.name:
  description: "re.compile(r'(\\w+)').finditer.__name__ == 'finditer'"
  category: identity
  kind: python_call_eq
  function: compile
  args: ["(\\w+)"]
  method: finditer
  method_chain: __name__
  expected: "finditer"

invariant re_extra264.pattern.sub.name:
  description: "re.compile(r'(\\w+)').sub.__name__ == 'sub'"
  category: identity
  kind: python_call_eq
  function: compile
  args: ["(\\w+)"]
  method: sub
  method_chain: __name__
  expected: "sub"

invariant re_extra264.pattern.subn.name:
  description: "re.compile(r'(\\w+)').subn.__name__ == 'subn'"
  category: identity
  kind: python_call_eq
  function: compile
  args: ["(\\w+)"]
  method: subn
  method_chain: __name__
  expected: "subn"

invariant re_extra264.pattern.split.name:
  description: "re.compile(r'(\\w+)').split.__name__ == 'split'"
  category: identity
  kind: python_call_eq
  function: compile
  args: ["(\\w+)"]
  method: split
  method_chain: __name__
  expected: "split"

# ---------------------------------------------------------------------------
# re.Match.start / end / span — integer and tuple results
# ---------------------------------------------------------------------------

invariant re_extra264.match.start:
  description: "re.match(r'(\\w+)', 'hello world').start() == 0"
  category: match_positions
  kind: python_call_eq
  function: match
  args: ["(\\w+)", "hello world"]
  method: start
  expected: 0

invariant re_extra264.match.end:
  description: "re.match(r'(\\w+)', 'hello world').end() == 5"
  category: match_positions
  kind: python_call_eq
  function: match
  args: ["(\\w+)", "hello world"]
  method: end
  expected: 5

invariant re_extra264.match.start_group0:
  description: "re.match(r'(\\w+)', 'hello world').start(0) == 0 — explicit group 0 same as default"
  category: match_positions
  kind: python_call_eq
  function: match
  args: ["(\\w+)", "hello world"]
  method: start
  method_args: [0]
  expected: 0

invariant re_extra264.match.end_group0:
  description: "re.match(r'(\\w+)', 'hello world').end(0) == 5 — explicit group 0 same as default"
  category: match_positions
  kind: python_call_eq
  function: match
  args: ["(\\w+)", "hello world"]
  method: end
  method_args: [0]
  expected: 5

invariant re_extra264.match.span_first:
  description: "re.match(r'(\\w+)', 'hello world').span()[0] == 0 — start of span"
  category: match_positions
  kind: python_call_eq
  function: match
  args: ["(\\w+)", "hello world"]
  method: span
  method_chain: __getitem__
  method_chain_args: [0]
  expected: 0

invariant re_extra264.match.span_second:
  description: "re.match(r'(\\w+)', 'hello world').span()[1] == 5 — end of span"
  category: match_positions
  kind: python_call_eq
  function: match
  args: ["(\\w+)", "hello world"]
  method: span
  method_chain: __getitem__
  method_chain_args: [1]
  expected: 5

invariant re_extra264.match.span_type:
  description: "type(re.match(r'(\\w+)', 'hello world').span()).__name__ == 'tuple'"
  category: match_positions
  kind: python_call_eq
  function: match
  args: ["(\\w+)", "hello world"]
  method: span
  method_chain: __class__
  method_chain2: __name__
  expected: "tuple"
