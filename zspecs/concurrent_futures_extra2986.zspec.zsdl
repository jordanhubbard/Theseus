spec: cf2986
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 646 — theme: __len__, __length_hint__, __contains__ dict-presence (container/sequence protocol)."
    - "Tests operator.contains(SomeClass.__dict__, '__len__') etc. for concurrent.futures classes."
    - "Classes covered: Future, ThreadPoolExecutor, ProcessPoolExecutor, CancelledError, TimeoutError, BrokenExecutor, InvalidStateError."
    - "None of these classes define __len__, __length_hint__, or __contains__ in their own __dict__."
    - "Executor classes manage work queues internally but do not expose container protocol to callers."
    - "Exception subclasses (CancelledError, TimeoutError, BrokenExecutor, InvalidStateError) inherit from standard exception hierarchy with no container slots."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __len__ dict-presence — operator.contains(Cls.__dict__, '__len__')
#
# None of the concurrent.futures classes define __len__; all results are false.
# ---------------------------------------------------------------------------

table cf2986.len:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: container_len
  id_prefix: len

  columns: [id, function, args, expected]
  rows:
    - ["len_Future",              operator.contains, [Future.__dict__,              "__len__"], false]
    - ["len_ThreadPoolExecutor",  operator.contains, [ThreadPoolExecutor.__dict__,  "__len__"], false]
    - ["len_ProcessPoolExecutor", operator.contains, [ProcessPoolExecutor.__dict__, "__len__"], false]
    - ["len_CancelledError",      operator.contains, [CancelledError.__dict__,      "__len__"], false]
    - ["len_TimeoutError",        operator.contains, [TimeoutError.__dict__,        "__len__"], false]
    - ["len_BrokenExecutor",      operator.contains, [BrokenExecutor.__dict__,      "__len__"], false]
    - ["len_InvalidStateError",   operator.contains, [InvalidStateError.__dict__,   "__len__"], false]

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — operator.contains(Cls.__dict__, '__length_hint__')
#
# None of the concurrent.futures classes define __length_hint__; all false.
# ---------------------------------------------------------------------------

table cf2986.length_hint:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: container_length_hint
  id_prefix: lh

  columns: [id, function, args, expected]
  rows:
    - ["lh_Future",              operator.contains, [Future.__dict__,              "__length_hint__"], false]
    - ["lh_ThreadPoolExecutor",  operator.contains, [ThreadPoolExecutor.__dict__,  "__length_hint__"], false]
    - ["lh_ProcessPoolExecutor", operator.contains, [ProcessPoolExecutor.__dict__, "__length_hint__"], false]
    - ["lh_CancelledError",      operator.contains, [CancelledError.__dict__,      "__length_hint__"], false]
    - ["lh_TimeoutError",        operator.contains, [TimeoutError.__dict__,        "__length_hint__"], false]
    - ["lh_BrokenExecutor",      operator.contains, [BrokenExecutor.__dict__,      "__length_hint__"], false]
    - ["lh_InvalidStateError",   operator.contains, [InvalidStateError.__dict__,   "__length_hint__"], false]

# ---------------------------------------------------------------------------
# __contains__ dict-presence — operator.contains(Cls.__dict__, '__contains__')
#
# None of the concurrent.futures classes define __contains__; all false.
# ---------------------------------------------------------------------------

table cf2986.contains:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: container_contains
  id_prefix: con

  columns: [id, function, args, expected]
  rows:
    - ["con_Future",              operator.contains, [Future.__dict__,              "__contains__"], false]
    - ["con_ThreadPoolExecutor",  operator.contains, [ThreadPoolExecutor.__dict__,  "__contains__"], false]
    - ["con_ProcessPoolExecutor", operator.contains, [ProcessPoolExecutor.__dict__, "__contains__"], false]
    - ["con_CancelledError",      operator.contains, [CancelledError.__dict__,      "__contains__"], false]
    - ["con_TimeoutError",        operator.contains, [TimeoutError.__dict__,        "__contains__"], false]
    - ["con_BrokenExecutor",      operator.contains, [BrokenExecutor.__dict__,      "__contains__"], false]
    - ["con_InvalidStateError",   operator.contains, [InvalidStateError.__dict__,   "__contains__"], false]

# ---------------------------------------------------------------------------
# combined — all three operators for a cross-class sample
#
# Spot-checks __len__, __length_hint__, __contains__ absence across
# concurrent.futures classes in a single table.
# 8 subjects x 3 operators = 24 rows (Future + 6 classes + repeated Future).
# ---------------------------------------------------------------------------

table cf2986.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: container_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_Future_len",              operator.contains, [Future.__dict__,              "__len__"],         false]
    - ["comb_Future_lh",               operator.contains, [Future.__dict__,              "__length_hint__"], false]
    - ["comb_Future_con",              operator.contains, [Future.__dict__,              "__contains__"],    false]
    - ["comb_ThreadPool_len",          operator.contains, [ThreadPoolExecutor.__dict__,  "__len__"],         false]
    - ["comb_ThreadPool_lh",           operator.contains, [ThreadPoolExecutor.__dict__,  "__length_hint__"], false]
    - ["comb_ThreadPool_con",          operator.contains, [ThreadPoolExecutor.__dict__,  "__contains__"],    false]
    - ["comb_ProcessPool_len",         operator.contains, [ProcessPoolExecutor.__dict__, "__len__"],         false]
    - ["comb_ProcessPool_lh",          operator.contains, [ProcessPoolExecutor.__dict__, "__length_hint__"], false]
    - ["comb_ProcessPool_con",         operator.contains, [ProcessPoolExecutor.__dict__, "__contains__"],    false]
    - ["comb_CancelledError_len",      operator.contains, [CancelledError.__dict__,      "__len__"],         false]
    - ["comb_CancelledError_lh",       operator.contains, [CancelledError.__dict__,      "__length_hint__"], false]
    - ["comb_CancelledError_con",      operator.contains, [CancelledError.__dict__,      "__contains__"],    false]
    - ["comb_TimeoutError_len",        operator.contains, [TimeoutError.__dict__,        "__len__"],         false]
    - ["comb_TimeoutError_lh",         operator.contains, [TimeoutError.__dict__,        "__length_hint__"], false]
    - ["comb_TimeoutError_con",        operator.contains, [TimeoutError.__dict__,        "__contains__"],    false]
    - ["comb_BrokenExecutor_len",      operator.contains, [BrokenExecutor.__dict__,      "__len__"],         false]
    - ["comb_BrokenExecutor_lh",       operator.contains, [BrokenExecutor.__dict__,      "__length_hint__"], false]
    - ["comb_BrokenExecutor_con",      operator.contains, [BrokenExecutor.__dict__,      "__contains__"],    false]
    - ["comb_InvalidStateError_len",   operator.contains, [InvalidStateError.__dict__,   "__len__"],         false]
    - ["comb_InvalidStateError_lh",    operator.contains, [InvalidStateError.__dict__,   "__length_hint__"], false]
    - ["comb_InvalidStateError_con",   operator.contains, [InvalidStateError.__dict__,   "__contains__"],    false]
    - ["comb_Future_len2",             operator.contains, [Future.__class__.__dict__,    "__len__"],         false]
    - ["comb_Future_lh2",              operator.contains, [Future.__class__.__dict__,    "__length_hint__"], false]
    - ["comb_Future_con2",             operator.contains, [Future.__class__.__dict__,    "__contains__"],    false]
