spec: io_extra264
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE, SEEK_* constants, TextIOWrapper/BufferedRandom/UnsupportedOperation class identity"
    - "io_extra263.zspec.zsdl — covers TextIOWrapper class identity and method qualnames"
  notes:
    - "io.StringIO.__name__ == 'StringIO' and __module__ == '_io' (C implementation)."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — immediate base in the C hierarchy."
    - "StringIO methods read/write/getvalue/seek/tell/truncate/readline are method_descriptor objects."
    - "io.BytesIO.__name__ == 'BytesIO' and __module__ == '_io' (C implementation)."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — immediate base in the C hierarchy."
    - "BytesIO methods getvalue/read/write are method_descriptor objects."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# StringIO — class identity: name, module, base
# ---------------------------------------------------------------------------

invariant io_extra264.StringIO.class_name:
  description: "io.StringIO.__name__ == 'StringIO'"
  category: identity
  kind: python_call_eq
  function: StringIO.__name__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra264.StringIO.module:
  description: "io.StringIO.__module__ == '_io'"
  category: identity
  kind: python_call_eq
  function: StringIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra264.StringIO.base_name:
  description: "io.StringIO.__bases__[0].__name__ == '_TextIOBase'"
  category: identity
  kind: python_call_eq
  function: StringIO.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_TextIOBase"

# ---------------------------------------------------------------------------
# StringIO — method qualnames: read, write, getvalue, seek, tell, truncate, readline
# ---------------------------------------------------------------------------

table io_extra264.StringIO.method_qualnames_rw:
  description: "read/write/getvalue qualnames are defined directly on StringIO"
  kind: python_call_eq
  category: identity
  id_prefix: method_qualname

  columns: [id, function, args, expected, description]
  rows:
    - [read_qualname,     StringIO.read.__qualname__.__eq__,     ["StringIO.read"],     true, "read qualname"]
    - [write_qualname,    StringIO.write.__qualname__.__eq__,    ["StringIO.write"],    true, "write qualname"]
    - [getvalue_qualname, StringIO.getvalue.__qualname__.__eq__, ["StringIO.getvalue"], true, "getvalue qualname"]

table io_extra264.StringIO.method_qualnames_seek:
  description: "seek/tell/truncate/readline qualnames are defined directly on StringIO"
  kind: python_call_eq
  category: identity
  id_prefix: method_qualname

  columns: [id, function, args, expected, description]
  rows:
    - [seek_qualname,     StringIO.seek.__qualname__.__eq__,     ["StringIO.seek"],     true, "seek qualname"]
    - [tell_qualname,     StringIO.tell.__qualname__.__eq__,     ["StringIO.tell"],     true, "tell qualname"]
    - [truncate_qualname, StringIO.truncate.__qualname__.__eq__, ["StringIO.truncate"], true, "truncate qualname"]
    - [readline_qualname, StringIO.readline.__qualname__.__eq__, ["StringIO.readline"], true, "readline qualname"]

# ---------------------------------------------------------------------------
# StringIO — method class name
# ---------------------------------------------------------------------------

invariant io_extra264.StringIO.read_class:
  description: "io.StringIO.read.__class__.__name__ == 'method_descriptor'"
  category: identity
  kind: python_call_eq
  function: StringIO.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# BytesIO — class identity: name, module, base
# ---------------------------------------------------------------------------

invariant io_extra264.BytesIO.class_name:
  description: "io.BytesIO.__name__ == 'BytesIO'"
  category: identity
  kind: python_call_eq
  function: BytesIO.__name__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra264.BytesIO.module:
  description: "io.BytesIO.__module__ == '_io'"
  category: identity
  kind: python_call_eq
  function: BytesIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra264.BytesIO.base_name:
  description: "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase'"
  category: identity
  kind: python_call_eq
  function: BytesIO.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_BufferedIOBase"

# ---------------------------------------------------------------------------
# BytesIO — method qualnames: getvalue, read, write
# ---------------------------------------------------------------------------

table io_extra264.BytesIO.method_qualnames:
  description: "getvalue/read/write qualnames are defined directly on BytesIO"
  kind: python_call_eq
  category: identity
  id_prefix: method_qualname

  columns: [id, function, args, expected, description]
  rows:
    - [getvalue_qualname, BytesIO.getvalue.__qualname__.__eq__, ["BytesIO.getvalue"], true, "getvalue qualname"]
    - [read_qualname,     BytesIO.read.__qualname__.__eq__,     ["BytesIO.read"],     true, "read qualname"]
    - [write_qualname,    BytesIO.write.__qualname__.__eq__,    ["BytesIO.write"],    true, "write qualname"]

# ---------------------------------------------------------------------------
# BytesIO — method class name
# ---------------------------------------------------------------------------

invariant io_extra264.BytesIO.read_class:
  description: "io.BytesIO.read.__class__.__name__ == 'method_descriptor'"
  category: identity
  kind: python_call_eq
  function: BytesIO.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true
