spec: inspect_extra260
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect.zspec.zsdl — covers isfunction, isbuiltin, isclass, ismodule, isroutine, isgeneratorfunction, iscoroutinefunction, isasyncgenfunction, signature, getmembers, getdoc classname checks"
    - "inspect_extra.zspec.zsdl — covers ismethod, isgenerator, iscoroutine, getsourcefile __name__/__module__; isclass/isbuiltin/isfunction behavioral checks"
  notes:
    - "inspect.stack.__name__ == 'stack'; __qualname__ == 'stack'; __module__ == 'inspect'; __class__.__name__ == 'function'."
    - "inspect.currentframe.__name__ == 'currentframe'; __qualname__ == 'currentframe'; __class__.__name__ == 'function'; __module__ == 'inspect'."
    - "On Python 3.14.4, currentframe.__class__.__name__ is 'function' (not 'builtin_function_or_method')."
    - "inspect.getframeinfo.__name__ == 'getframeinfo'; __qualname__ == 'getframeinfo'; __module__ == 'inspect'; __class__.__name__ == 'function'."
    - "inspect.FrameInfo.__name__ == 'FrameInfo'; __module__ == 'inspect'; __class__.__name__ == 'type'."
    - "inspect.iscoroutine.__name__ == 'iscoroutine'; __qualname__ == 'iscoroutine'; __module__ == 'inspect'."
    - "inspect.iscoroutinefunction.__name__ == 'iscoroutinefunction'; __qualname__ == 'iscoroutinefunction'; __module__ == 'inspect'."
    - "inspect.isawaitable.__name__ == 'isawaitable'; __qualname__ == 'isawaitable'; __module__ == 'inspect'."
    - "All values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.stack — function identity
# ---------------------------------------------------------------------------

invariant inspect_extra260.stack.name:
  description: "inspect.stack.__name__ == 'stack'"
  category: identity
  kind: python_call_eq
  function: stack.__name__.__eq__
  args: ["stack"]
  expected: true

invariant inspect_extra260.stack.qualname:
  description: "inspect.stack.__qualname__ == 'stack'"
  category: identity
  kind: python_call_eq
  function: stack.__qualname__.__eq__
  args: ["stack"]
  expected: true

invariant inspect_extra260.stack.module:
  description: "inspect.stack.__module__ == 'inspect'"
  category: identity
  kind: python_call_eq
  function: stack.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra260.stack.class_name:
  description: "inspect.stack.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: stack.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# inspect.currentframe — function identity
#
# On Python 3.14.4 currentframe.__class__.__name__ is 'function'
# (not 'builtin_function_or_method').
# ---------------------------------------------------------------------------

invariant inspect_extra260.currentframe.name:
  description: "inspect.currentframe.__name__ == 'currentframe'"
  category: identity
  kind: python_call_eq
  function: currentframe.__name__.__eq__
  args: ["currentframe"]
  expected: true

invariant inspect_extra260.currentframe.qualname:
  description: "inspect.currentframe.__qualname__ == 'currentframe'"
  category: identity
  kind: python_call_eq
  function: currentframe.__qualname__.__eq__
  args: ["currentframe"]
  expected: true

invariant inspect_extra260.currentframe.class_name:
  description: "inspect.currentframe.__class__.__name__ == 'function' on Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: currentframe.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# inspect.getframeinfo — function identity
# ---------------------------------------------------------------------------

invariant inspect_extra260.getframeinfo.name:
  description: "inspect.getframeinfo.__name__ == 'getframeinfo'"
  category: identity
  kind: python_call_eq
  function: getframeinfo.__name__.__eq__
  args: ["getframeinfo"]
  expected: true

invariant inspect_extra260.getframeinfo.qualname:
  description: "inspect.getframeinfo.__qualname__ == 'getframeinfo'"
  category: identity
  kind: python_call_eq
  function: getframeinfo.__qualname__.__eq__
  args: ["getframeinfo"]
  expected: true

invariant inspect_extra260.getframeinfo.module:
  description: "inspect.getframeinfo.__module__ == 'inspect'"
  category: identity
  kind: python_call_eq
  function: getframeinfo.__module__.__eq__
  args: ["inspect"]
  expected: true

# ---------------------------------------------------------------------------
# inspect.FrameInfo — class identity
# ---------------------------------------------------------------------------

invariant inspect_extra260.FrameInfo.name:
  description: "inspect.FrameInfo.__name__ == 'FrameInfo'"
  category: identity
  kind: python_call_eq
  function: FrameInfo.__name__.__eq__
  args: ["FrameInfo"]
  expected: true

invariant inspect_extra260.FrameInfo.module:
  description: "inspect.FrameInfo.__module__ == 'inspect'"
  category: identity
  kind: python_call_eq
  function: FrameInfo.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra260.FrameInfo.class_name:
  description: "inspect.FrameInfo.__class__.__name__ == 'type'"
  category: identity
  kind: python_call_eq
  function: FrameInfo.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# async-related predicates — iscoroutine, iscoroutinefunction, isawaitable
# ---------------------------------------------------------------------------

table inspect_extra260.async_function_names:
  description: "iscoroutine, iscoroutinefunction, isawaitable share expected __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: afname

  columns: [id, function, args, expected]
  rows:
    - [iscoroutine,         iscoroutine.__name__.__eq__,         ["iscoroutine"],         true]
    - [iscoroutinefunction, iscoroutinefunction.__name__.__eq__, ["iscoroutinefunction"], true]
    - [isawaitable,         isawaitable.__name__.__eq__,         ["isawaitable"],         true]

table inspect_extra260.async_function_modules:
  description: "iscoroutine, iscoroutinefunction, isawaitable all belong to the inspect module"
  kind: python_call_eq
  category: identity
  id_prefix: afmod

  columns: [id, function, args, expected]
  rows:
    - [iscoroutine,         iscoroutine.__module__.__eq__,         ["inspect"], true]
    - [iscoroutinefunction, iscoroutinefunction.__module__.__eq__, ["inspect"], true]
    - [isawaitable,         isawaitable.__module__.__eq__,         ["inspect"], true]
