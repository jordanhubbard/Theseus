spec: theseus_itertools_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_itertools_cr2)
blocks: itertools

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html"
  notes:
    - "Clean-room extended itertools. Do NOT import itertools."
    - "groupby(iterable, key=None): group consecutive elements with same key."
    - "zip_longest(*iterables, fillvalue=None): zip with fill for shorter iterables."
    - "starmap(fn, iterable): apply fn(*args) for each args in iterable."
    - "itertools2_groupby(): list(groupby([1,1,2,2])) has 2 groups."
    - "itertools2_zip_longest(): zip_longest([1,2],[3]) fills short with None."
    - "itertools2_starmap(): list(starmap(pow, [(2,3),(3,2)])) == [8,9]."
    - "Export: groupby, zip_longest, starmap, accumulate (extending theseus_itertools_cr)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_itertools_cr2.groupby:
  description: "list(groupby([1,1,2,2])) has 2 groups"
  category: groupby
  kind: python_call_eq
  function: itertools2_groupby
  args: []
  expected: 2

invariant theseus_itertools_cr2.zip_longest:
  description: "list(zip_longest([1,2],[3])) == [(1,3),(2,None)]"
  category: zip_longest
  kind: python_call_eq
  function: itertools2_zip_longest
  args: []
  expected: [[1, 3], [2, null]]

invariant theseus_itertools_cr2.starmap:
  description: "list(starmap(pow, [(2,3),(3,2)])) == [8,9]"
  category: starmap
  kind: python_call_eq
  function: itertools2_starmap
  args: []
  expected: [8, 9]
