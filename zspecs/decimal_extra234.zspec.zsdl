spec: decimal_extra234
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal.zspec.zsdl — covers Decimal.__name__, getcontext().prec, Decimal predicates"
    - "decimal_extra24.zspec.zsdl — covers decimal module function identity contracts"
  notes:
    - "This spec covers: decimal.Context class identity contracts and method name/qualname checks."
    - "decimal.Context.__name__ == 'Context' — length 7; verified Python 3.14.3 macOS."
    - "decimal.Context.__module__ == 'decimal' — the pure-Python fallback name; verified Python 3.14.3 macOS."
    - "decimal.Context.__bases__[0].__name__ == 'object' — Context inherits directly from object; verified Python 3.14.3 macOS."
    - "decimal.Context.__qualname__ == 'Context' — qualname matches __name__ for a top-level class; verified Python 3.14.3 macOS."
    - "decimal.Context.__class__.__name__ == 'type' — Context is a class object; verified Python 3.14.3 macOS."
    - "decimal.Context.create_decimal.__name__ == 'create_decimal' — length 14; verified Python 3.14.3 macOS."
    - "decimal.Context.create_decimal.__qualname__ == 'Context.create_decimal' — length 22; verified Python 3.14.3 macOS."
    - "decimal.Context.sqrt.__name__ == 'sqrt' — length 4; verified Python 3.14.3 macOS."
    - "decimal.Context.sqrt.__qualname__ == 'Context.sqrt' — length 12; verified Python 3.14.3 macOS."
    - "decimal.Decimal.quantize.__name__ == 'quantize' — length 8; verified Python 3.14.3 macOS."
    - "decimal.Decimal.quantize.__qualname__ == 'Decimal.quantize' — length 16; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context class identity contracts
# These verify the class object's identity attributes.
# decimal.Context.__module__ == 'decimal' on Python 3.14.3 macOS.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra234.Context.name_eq:
  description: "decimal.Context.__name__ == 'Context' — class name is 'Context'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra234.Context.name_len:
  description: "len(decimal.Context.__name__) == 7 — 'Context' has 7 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Context.__name__.__len__
  args: []
  expected: 7

invariant decimal_extra234.Context.module_eq:
  description: "decimal.Context.__module__ == 'decimal' — Context module is 'decimal'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Context.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra234.Context.module_len:
  description: "len(decimal.Context.__module__) == 7 — 'decimal' has 7 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Context.__module__.__len__
  args: []
  expected: 7

invariant decimal_extra234.Context.qualname_eq:
  description: "decimal.Context.__qualname__ == 'Context' — qualname matches __name__ for a top-level class; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Context.__qualname__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra234.Context.qualname_len:
  description: "len(decimal.Context.__qualname__) == 7 — 'Context' has 7 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Context.__qualname__.__len__
  args: []
  expected: 7

invariant decimal_extra234.Context.class_is_type:
  description: "decimal.Context.__class__.__name__ == 'type' — Context is a class object (its metaclass is type); verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Context.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# decimal.Context.__bases__[0].__name__ identity contract
# Context inherits directly from object.
# Accessed via __bases__.__getitem__(0).__name__.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra234.Context.base_name:
  description: "decimal.Context.__bases__[0].__name__ == 'object' — Context inherits directly from object; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Context.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant decimal_extra234.Context.base_name_len:
  description: "len(decimal.Context.__bases__[0].__name__) == 6 — 'object' has 6 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Context.__bases__.__getitem__
  args: [0]
  method: __name__
  method_chain: __len__
  expected: 6

# ---------------------------------------------------------------------------
# decimal.Context method identity contracts
# create_decimal and sqrt are key Context arithmetic methods.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra234.Context.create_decimal.name_eq:
  description: "decimal.Context.create_decimal.__name__ == 'create_decimal' — method name is 'create_decimal'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Context.create_decimal.__name__.__eq__
  args: ["create_decimal"]
  expected: true

invariant decimal_extra234.Context.create_decimal.name_len:
  description: "len(decimal.Context.create_decimal.__name__) == 14 — 'create_decimal' has 14 characters; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Context.create_decimal.__name__.__len__
  args: []
  expected: 14

invariant decimal_extra234.Context.create_decimal.qualname_eq:
  description: "decimal.Context.create_decimal.__qualname__ == 'Context.create_decimal' — qualname is 'Context.create_decimal'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Context.create_decimal.__qualname__.__eq__
  args: ["Context.create_decimal"]
  expected: true

invariant decimal_extra234.Context.create_decimal.qualname_len:
  description: "len(decimal.Context.create_decimal.__qualname__) == 22 — 'Context.create_decimal' has 22 characters; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Context.create_decimal.__qualname__.__len__
  args: []
  expected: 22

invariant decimal_extra234.Context.sqrt.name_eq:
  description: "decimal.Context.sqrt.__name__ == 'sqrt' — method name is 'sqrt'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Context.sqrt.__name__.__eq__
  args: ["sqrt"]
  expected: true

invariant decimal_extra234.Context.sqrt.qualname_eq:
  description: "decimal.Context.sqrt.__qualname__ == 'Context.sqrt' — qualname is 'Context.sqrt'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Context.sqrt.__qualname__.__eq__
  args: ["Context.sqrt"]
  expected: true

# ---------------------------------------------------------------------------
# decimal.Decimal.quantize method identity contracts
# quantize is defined on Decimal, not on Context.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra234.Decimal.quantize.name_eq:
  description: "decimal.Decimal.quantize.__name__ == 'quantize' — method name is 'quantize'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Decimal.quantize.__name__.__eq__
  args: ["quantize"]
  expected: true

invariant decimal_extra234.Decimal.quantize.qualname_eq:
  description: "decimal.Decimal.quantize.__qualname__ == 'Decimal.quantize' — qualname is 'Decimal.quantize'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Decimal.quantize.__qualname__.__eq__
  args: ["Decimal.quantize"]
  expected: true

# ---------------------------------------------------------------------------
# Table: decimal.Context method __name__ and __qualname__ lengths
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra234.Context_method_name_lengths:
  description: "decimal.Context method __name__ lengths — create_decimal, sqrt; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: decctx234

  columns: [id, function, args, expected]
  rows:
    - [create_decimal_name_len, Context.create_decimal.__name__.__len__, [], 14]
    - [sqrt_name_len,           Context.sqrt.__name__.__len__,           [], 4]
    - [quantize_name_len,       Decimal.quantize.__name__.__len__,       [], 8]

table decimal_extra234.Context_method_qualname_lengths:
  description: "decimal.Context and Decimal method __qualname__ lengths; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: decctxm234

  columns: [id, function, args, expected]
  rows:
    - [create_decimal_qualname_len, Context.create_decimal.__qualname__.__len__, [], 22]
    - [sqrt_qualname_len,           Context.sqrt.__qualname__.__len__,           [], 12]
    - [quantize_qualname_len,       Decimal.quantize.__qualname__.__len__,       [], 16]
