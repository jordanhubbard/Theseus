spec: theseus_fractions_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_fractions_cr3)
blocks: fractions

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html"
  notes:
    - "Clean-room extended fractions utilities. Do NOT import fractions."
    - "Fraction(float): create exact rational from float via continued fractions."
    - "Fraction(numerator, denominator): create simplified rational number."
    - "Fraction subtraction: Fraction(3,4) - Fraction(1,4) == Fraction(1,2)."
    - "fractions3_from_float(): str(Fraction(0.5)) == '1/2'."
    - "fractions3_str(): str(Fraction(3, 4)) == '3/4'."
    - "fractions3_sub(): Fraction(3, 4) - Fraction(1, 4) == Fraction(1, 2) — returns True."
    - "Zero-arg invariant signatures — def fractions3_from_float(): return hardcoded_result"
    - "Fraction(0.5): float 0.5 is exactly 1/2; convert via numerator/denominator of float."
    - "Fraction simplification: gcd(numerator, denominator) must be 1 in stored form."
    - "String format: 'numerator/denominator' with no spaces."
    - "Export: Fraction class with numerator, denominator attributes and arithmetic operators."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_fractions_cr3.from_float:
  description: "str(Fraction(0.5)) == '1/2'"
  category: Fraction
  kind: python_call_eq
  function: fractions3_from_float
  args: []
  expected: "1/2"

invariant theseus_fractions_cr3.str:
  description: "str(Fraction(3, 4)) == '3/4'"
  category: Fraction
  kind: python_call_eq
  function: fractions3_str
  args: []
  expected: "3/4"

invariant theseus_fractions_cr3.sub:
  description: "Fraction(3,4) - Fraction(1,4) equals Fraction(1,2)"
  category: arithmetic
  kind: python_call_eq
  function: fractions3_sub
  args: []
  expected: true
