spec: aiohttp_rust
version: ">=3.9"
backend: rust_module(aiohttp_rust)

docs: https://docs.aiohttp.org/en/stable/

provenance:
  derived_from:
    - "https://docs.aiohttp.org/en/stable/ — aiohttp documentation"
  not_derived_from:
    - "aiohttp source: aiohttp/client.py"
  notes:
    - "aiohttp provides async HTTP client/server for Python."
    - "aiohttp.ClientSession is available."
    - "aiohttp.__version__ is a non-empty string."
    - "aiohttp.web.Response(text='hello').text == 'hello'."
    - "aiohttp.web.Response(status=200).status == 200."
    - "aiohttp.web.Response(status=404).status == 404."
    - "Expose aiohttp_response_text(text) -> str: aiohttp.web.Response(text=text).text."
    - "Expose aiohttp_response_status(status) -> int: aiohttp.web.Response(status=status).status."
    - "Expose aiohttp_has_client_session() -> bool: hasattr(aiohttp, 'ClientSession')."
    - "All test vectors verified against aiohttp 3.11.14."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# aiohttp_response_text — web.Response text attribute
table aiohttp_rust.response.text:
  kind: python_call_eq
  category: response_text
  id_prefix: aio_txt
  function: aiohttp_response_text

  columns: [id, args, expected]
  rows:
    - [hello, ["hello"], "hello"]
    - [world, ["world"], "world"]
    - [empty, [""],      ""]

# aiohttp_response_status — web.Response status attribute
table aiohttp_rust.response.status:
  kind: python_call_eq
  category: response_status
  id_prefix: aio_sts
  function: aiohttp_response_status

  columns: [id, args, expected]
  rows:
    - [ok,        [200], 200]
    - [not_found, [404], 404]

# aiohttp_has_client_session — ClientSession exists
invariant aiohttp_rust.client.has_client_session:
  description: "aiohttp.ClientSession is available"
  category: client
  kind: python_call_eq
  function: aiohttp_has_client_session
  args: []
  expected: true

