spec: weakref_extra23
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
  notes:
    - "This spec extends weakref_extra22.zspec.zsdl."
    - "Prior specs covered: ref/__name__/__module__/__qualname__, WeakValueDictionary/__name__/__module__, WeakKeyDictionary/__name__/__module__, WeakSet/__name__/__module__, finalize/__name__/__module__, proxy/__name__, weakref.__name__/__package__, ref.__bases__[0].__name__, WeakValueDictionary.__bases__[0].__name__, WeakKeyDictionary.__bases__[0].__name__, WeakSet.__bases__[0].__name__, finalize.__bases__[0].__name__, getweakrefcount/__name__, getweakrefs/__name__, various __qualname__ checks."
    - "This spec covers: weakref.ref.__module__, weakref.WeakValueDictionary.__qualname__, weakref.WeakKeyDictionary.__qualname__, weakref.WeakSet.__qualname__, weakref.finalize.__qualname__, weakref.WeakValueDictionary.__module__, weakref.WeakKeyDictionary.__module__, weakref.WeakSet.__module__, weakref.finalize.__module__, weakref.ref.__init__.__name__, weakref.getweakrefcount.__module__, weakref.getweakrefs.__module__."
    - "weakref.ref.__module__ == 'weakref' — the C-level ReferenceType is exposed via the weakref module."
    - "weakref.WeakValueDictionary.__qualname__ == 'WeakValueDictionary' — top-level class; __qualname__ equals simple name."
    - "weakref.WeakKeyDictionary.__qualname__ == 'WeakKeyDictionary' — top-level class; __qualname__ equals simple name."
    - "weakref.WeakSet.__qualname__ == 'WeakSet' — top-level class; __qualname__ equals simple name."
    - "weakref.finalize.__qualname__ == 'finalize' — top-level class; __qualname__ equals simple name."
    - "weakref.WeakValueDictionary.__module__ == 'weakref' — defined in Lib/weakref.py."
    - "weakref.WeakKeyDictionary.__module__ == 'weakref' — defined in Lib/weakref.py."
    - "weakref.WeakSet.__module__ == '_weakrefset' — defined in the private _weakrefset module."
    - "weakref.finalize.__module__ == 'weakref' — defined in Lib/weakref.py."
    - "weakref.ref.__init__.__name__ == '__init__' — the C-level ReferenceType does not override __init__ in Python; slot resolves to __init__ with that name."
    - "weakref.getweakrefcount.__module__ == '_weakref' — implemented in the C extension _weakref."
    - "weakref.getweakrefs.__module__ == '_weakref' — implemented in the C extension _weakref."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ combined table for WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize
# (extra23 namespace)
#
# All four are top-level classes; __qualname__ equals the simple class name.
# Prior specs record these __qualname__ values in various tables and standalones.
# This table groups all four in the extra23 namespace for the first time.
# ---------------------------------------------------------------------------

table weakref_extra23.qualnames:
  description: "__qualname__.__eq__ for weakref classes in the extra23 namespace"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [WeakValueDictionary, WeakValueDictionary.__qualname__.__eq__, ["WeakValueDictionary"], true]
    - [WeakKeyDictionary,   WeakKeyDictionary.__qualname__.__eq__,   ["WeakKeyDictionary"],   true]
    - [WeakSet,             WeakSet.__qualname__.__eq__,             ["WeakSet"],             true]
    - [finalize,            finalize.__qualname__.__eq__,            ["finalize"],            true]

# ---------------------------------------------------------------------------
# __module__ combined table for weakref classes (extra23 namespace)
#
# WeakValueDictionary/WeakKeyDictionary/finalize have __module__ == 'weakref'.
# WeakSet has __module__ == '_weakrefset' (defined in the private module).
# weakref_extra22 covers these in a combined table; this table re-anchors
# them in the extra23 namespace with ref included.
# ---------------------------------------------------------------------------

table weakref_extra23.modules:
  description: "__module__.__eq__ for weakref classes in the extra23 namespace"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [ref,                  ref.__module__.__eq__,                  ["weakref"],      true]
    - [WeakValueDictionary,  WeakValueDictionary.__module__.__eq__,  ["weakref"],      true]
    - [WeakKeyDictionary,    WeakKeyDictionary.__module__.__eq__,    ["weakref"],      true]
    - [finalize,             finalize.__module__.__eq__,             ["weakref"],      true]
    - [WeakSet,              WeakSet.__module__.__eq__,              ["_weakrefset"],  true]

# ---------------------------------------------------------------------------
# __module__ combined table for C-level module functions (extra23 namespace)
#
# getweakrefcount and getweakrefs are implemented in the C extension _weakref.
# Their __module__ is '_weakref'. weakref_extra22 covers proxy/getweakrefcount/
# getweakrefs together; this table focuses on just getweakrefcount and
# getweakrefs in the extra23 namespace.
# ---------------------------------------------------------------------------

table weakref_extra23.cfunc_modules:
  description: "__module__.__eq__ for weakref C-level module functions in the extra23 namespace"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [getweakrefcount, getweakrefcount.__module__.__eq__, ["_weakref"], true]
    - [getweakrefs,     getweakrefs.__module__.__eq__,     ["_weakref"], true]

# ---------------------------------------------------------------------------
# weakref.ref.__init__.__name__ == '__init__' — standalone (extra23 namespace)
#
# weakref.ref is the C-level ReferenceType. Its __init__ slot has __name__
# equal to '__init__'. No prior weakref spec records ref.__init__.__name__
# as a standalone invariant.
# ---------------------------------------------------------------------------

invariant weakref_extra23.ref.init.name:
  description: "weakref.ref.__init__.__name__ == '__init__' — C-level ReferenceType __init__ slot name"
  category: method_names
  kind: python_call_eq
  function: "ref.__init__.__name__.__eq__"
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.WeakSet.__module__ == '_weakrefset' — standalone (extra23 namespace)
#
# WeakSet is defined in the private _weakrefset module, not in weakref itself.
# Re-anchored as a standalone invariant in the extra23 namespace to highlight
# that WeakSet differs from WeakValueDictionary/WeakKeyDictionary/finalize.
# ---------------------------------------------------------------------------

invariant weakref_extra23.WeakSet.module:
  description: "weakref.WeakSet.__module__ == '_weakrefset' — WeakSet is defined in the private _weakrefset module, not in weakref"
  category: module_attrs
  kind: python_call_eq
  function: WeakSet.__module__.__eq__
  args: ["_weakrefset"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.finalize.__qualname__ == 'finalize' — standalone (extra23 namespace)
#
# finalize is a top-level class; its __qualname__ equals its simple name.
# Re-anchored as a standalone invariant in the extra23 namespace.
# ---------------------------------------------------------------------------

invariant weakref_extra23.finalize.qualname:
  description: "weakref.finalize.__qualname__ == 'finalize' — top-level class; __qualname__ equals simple name"
  category: qualnames
  kind: python_call_eq
  function: finalize.__qualname__.__eq__
  args: ["finalize"]
  expected: true
