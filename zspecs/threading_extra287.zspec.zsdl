spec: threading_extra287
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module-level functions, __name__ and __module__ identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py, Modules/_threadmodule.c"
  notes:
    - "get_ident, get_native_id, and stack_size are C-level functions with __module__ == '_thread'"
    - "current_thread, main_thread, active_count, enumerate, settrace, setprofile are pure-Python functions with __module__ == 'threading'"
    - "threading.enumerate shadows the built-in enumerate; __module__ confirms it is the threading version"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table threading_extra287.function_names:
  description: "__name__ attribute for threading module-level functions"
  kind: python_call_eq
  category: identity
  id_prefix: tfn

  columns: [id, function, args, expected, description]
  rows:
    - [tfn001, threading.current_thread.__name__.__eq__, ["current_thread"], true, "current_thread.__name__ is 'current_thread'"]
    - [tfn002, threading.main_thread.__name__.__eq__, ["main_thread"], true, "main_thread.__name__ is 'main_thread'"]
    - [tfn003, threading.active_count.__name__.__eq__, ["active_count"], true, "active_count.__name__ is 'active_count'"]
    - [tfn004, threading.enumerate.__name__.__eq__, ["enumerate"], true, "threading.enumerate.__name__ is 'enumerate'"]
    - [tfn005, threading.settrace.__name__.__eq__, ["settrace"], true, "settrace.__name__ is 'settrace'"]
    - [tfn006, threading.setprofile.__name__.__eq__, ["setprofile"], true, "setprofile.__name__ is 'setprofile'"]
    - [tfn007, threading.stack_size.__name__.__eq__, ["stack_size"], true, "stack_size.__name__ is 'stack_size'"]
    - [tfn008, threading.get_ident.__name__.__eq__, ["get_ident"], true, "get_ident.__name__ is 'get_ident'"]
    - [tfn009, threading.get_native_id.__name__.__eq__, ["get_native_id"], true, "get_native_id.__name__ is 'get_native_id'"]

table threading_extra287.function_modules:
  description: "__module__ attribute for threading module-level functions"
  kind: python_call_eq
  category: identity
  id_prefix: tfm

  columns: [id, function, args, expected, description]
  rows:
    - [tfm001, threading.current_thread.__module__.__eq__, ["threading"], true, "current_thread.__module__ is 'threading'"]
    - [tfm002, threading.main_thread.__module__.__eq__, ["threading"], true, "main_thread.__module__ is 'threading'"]
    - [tfm003, threading.active_count.__module__.__eq__, ["threading"], true, "active_count.__module__ is 'threading'"]
    - [tfm004, threading.enumerate.__module__.__eq__, ["threading"], true, "threading.enumerate.__module__ is 'threading'"]
    - [tfm005, threading.settrace.__module__.__eq__, ["threading"], true, "settrace.__module__ is 'threading'"]
    - [tfm006, threading.setprofile.__module__.__eq__, ["threading"], true, "setprofile.__module__ is 'threading'"]
    - [tfm007, threading.stack_size.__module__.__eq__, ["_thread"], true, "stack_size.__module__ is '_thread' (C extension)"]
    - [tfm008, threading.get_ident.__module__.__eq__, ["_thread"], true, "get_ident.__module__ is '_thread' (C extension)"]
    - [tfm009, threading.get_native_id.__module__.__eq__, ["_thread"], true, "get_native_id.__module__ is '_thread' (C extension)"]

invariant threading_extra287.get_ident_module:
  description: "threading.get_ident is a C function from the _thread extension"
  category: identity
  kind: python_call_eq
  function: threading.get_ident.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra287.current_thread_module:
  description: "threading.current_thread is defined in the threading module"
  category: identity
  kind: python_call_eq
  function: threading.current_thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra287.main_thread_module:
  description: "threading.main_thread is defined in the threading module"
  category: identity
  kind: python_call_eq
  function: threading.main_thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra287.active_count_module:
  description: "threading.active_count is defined in the threading module"
  category: identity
  kind: python_call_eq
  function: threading.active_count.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra287.enumerate_module:
  description: "threading.enumerate is defined in the threading module (not built-in)"
  category: identity
  kind: python_call_eq
  function: threading.enumerate.__module__.__eq__
  args: ["threading"]
  expected: true
