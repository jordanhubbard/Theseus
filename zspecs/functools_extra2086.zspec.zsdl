spec: functools_extra2086
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2086 (_extra2086): __format__, __bytes__, __fspath__, __buffer__, __release_buffer__ dict-presence checks for functools types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "functools.partial is a C extension type; it does NOT define __format__, __bytes__, __fspath__, __buffer__, or __release_buffer__ in its own __dict__."
    - "functools.partialmethod is a pure-Python class; it defines none of the 5 target dunders in its __dict__."
    - "functools.cached_property is a pure-Python descriptor; it defines none of the 5 target dunders in its __dict__."
    - "functools._lru_cache_wrapper is a C extension type; it defines none of the 5 target dunders in its __dict__."
    - "None of the functools types implement the string formatting, bytes conversion, filesystem path, or buffer protocols in their own __dict__."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __format__ dict-presence for functools types
#
# None of partial, partialmethod, cached_property, or _lru_cache_wrapper
# define __format__ in their own __dict__. They inherit the default
# __format__ from object via the MRO.
# ---------------------------------------------------------------------------

table functools_extra2086.format_protocol:
  description: "functools types __format__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2086

  columns: [id, function, args, expected]
  rows:
    - ["ft2086001", "functools.partial.__dict__.__contains__", ["__format__"], false]
    - ["ft2086002", "functools.partialmethod.__dict__.__contains__", ["__format__"], false]
    - ["ft2086003", "functools.cached_property.__dict__.__contains__", ["__format__"], false]
    - ["ft2086004", "functools._lru_cache_wrapper.__dict__.__contains__", ["__format__"], false]

# ---------------------------------------------------------------------------
# Table 2: __bytes__ dict-presence for functools types
#
# None of the functools wrapper/partial types implement bytes conversion.
# __bytes__ is absent from the __dict__ of all four types.
# ---------------------------------------------------------------------------

table functools_extra2086.bytes_protocol:
  description: "functools types __bytes__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2086

  columns: [id, function, args, expected]
  rows:
    - ["ft2086005", "functools.partial.__dict__.__contains__", ["__bytes__"], false]
    - ["ft2086006", "functools.partialmethod.__dict__.__contains__", ["__bytes__"], false]
    - ["ft2086007", "functools.cached_property.__dict__.__contains__", ["__bytes__"], false]
    - ["ft2086008", "functools._lru_cache_wrapper.__dict__.__contains__", ["__bytes__"], false]

# ---------------------------------------------------------------------------
# Table 3: __fspath__ dict-presence for functools types
#
# functools types are callable wrappers, not path-like objects.
# None define __fspath__ in their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra2086.fspath_protocol:
  description: "functools types __fspath__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2086

  columns: [id, function, args, expected]
  rows:
    - ["ft2086009", "functools.partial.__dict__.__contains__", ["__fspath__"], false]
    - ["ft2086010", "functools.partialmethod.__dict__.__contains__", ["__fspath__"], false]
    - ["ft2086011", "functools.cached_property.__dict__.__contains__", ["__fspath__"], false]
    - ["ft2086012", "functools._lru_cache_wrapper.__dict__.__contains__", ["__fspath__"], false]

# ---------------------------------------------------------------------------
# Table 4: __buffer__ / __release_buffer__ dict-presence for functools types
#
# The buffer protocol (PEP 688) dunders __buffer__ and __release_buffer__
# are absent from all functools wrapper types. These types do not expose
# a memory buffer interface.
# ---------------------------------------------------------------------------

table functools_extra2086.buffer_protocol:
  description: "functools types __buffer__/__release_buffer__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2086

  columns: [id, function, args, expected]
  rows:
    - ["ft2086013", "functools.partial.__dict__.__contains__", ["__buffer__"], false]
    - ["ft2086014", "functools.partial.__dict__.__contains__", ["__release_buffer__"], false]
    - ["ft2086015", "functools.partialmethod.__dict__.__contains__", ["__buffer__"], false]
    - ["ft2086016", "functools.partialmethod.__dict__.__contains__", ["__release_buffer__"], false]
    - ["ft2086017", "functools.cached_property.__dict__.__contains__", ["__buffer__"], false]
    - ["ft2086018", "functools.cached_property.__dict__.__contains__", ["__release_buffer__"], false]
    - ["ft2086019", "functools._lru_cache_wrapper.__dict__.__contains__", ["__buffer__"], false]
    - ["ft2086020", "functools._lru_cache_wrapper.__dict__.__contains__", ["__release_buffer__"], false]

# ---------------------------------------------------------------------------
# Table 5: Cross-check — none of the 5 protocols present in partial.__dict__
#
# Confirms that functools.partial, despite being a C extension type with
# several dunder overrides (__reduce__, __getattribute__), does not claim
# any of the string-formatting, bytes, fspath, or buffer protocol dunders.
# ---------------------------------------------------------------------------

table functools_extra2086.partial_protocol_cross_check:
  description: "functools.partial does not define any of the 5 wave-2086 protocol dunders"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2086

  columns: [id, function, args, expected]
  rows:
    - ["ft2086021", "functools.partial.__dict__.__contains__", ["__format__"], false]
    - ["ft2086022", "functools.partial.__dict__.__contains__", ["__bytes__"], false]
    - ["ft2086023", "functools.partial.__dict__.__contains__", ["__fspath__"], false]
    - ["ft2086024", "functools.partial.__dict__.__contains__", ["__buffer__"], false]
    - ["ft2086025", "functools.partial.__dict__.__contains__", ["__release_buffer__"], false]
    - ["ft2086026", "functools.partialmethod.__dict__.__contains__", ["__format__"], false]
    - ["ft2086027", "functools.cached_property.__dict__.__contains__", ["__format__"], false]
    - ["ft2086028", "functools._lru_cache_wrapper.__dict__.__contains__", ["__buffer__"], false]
    - ["ft2086029", "functools._lru_cache_wrapper.__dict__.__contains__", ["__release_buffer__"], false]
