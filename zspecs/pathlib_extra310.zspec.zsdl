spec: pathlib_extra310
version: ">=3.10"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All invariants use PurePosixPath — a pure, platform-independent class requiring no filesystem access."
    - "All expected values verified by running Python 3.14.3 on macOS Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# name and stem attributes
# ---------------------------------------------------------------------------

invariant pathlib_extra310.purepath.name:
  description: "PurePosixPath('/usr/bin/python').name.__eq__('python') == True"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/bin/python"]
  method: name
  method_chain: __eq__
  method_chain_args: ["python"]
  expected: true

invariant pathlib_extra310.purepath.stem:
  description: "PurePosixPath('/usr/bin/python').stem.__eq__('python') == True"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/bin/python"]
  method: stem
  method_chain: __eq__
  method_chain_args: ["python"]
  expected: true

invariant pathlib_extra310.purepath.suffix_empty:
  description: "PurePosixPath('/usr/bin/python').suffix.__eq__('') == True — no extension"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/bin/python"]
  method: suffix
  method_chain: __eq__
  method_chain_args: [""]
  expected: true

invariant pathlib_extra310.purepath.suffix_exe:
  description: "PurePosixPath('/usr/bin/python.exe').suffix.__eq__('.exe') == True"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/bin/python.exe"]
  method: suffix
  method_chain: __eq__
  method_chain_args: [".exe"]
  expected: true

# ---------------------------------------------------------------------------
# parent — needs method_chain __str__ to get string form
# ---------------------------------------------------------------------------

invariant pathlib_extra310.purepath.parent:
  description: "PurePosixPath('/usr/bin/python').parent.__str__().__eq__('/usr/bin') == True"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/bin/python"]
  method: parent
  method_chain: __str__
  expected: "/usr/bin"

invariant pathlib_extra310.purepath.root_parent:
  description: "PurePosixPath('/').parent.__str__().__eq__('/') == True — root's parent is itself"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/"]
  method: parent
  method_chain: __str__
  expected: "/"

# ---------------------------------------------------------------------------
# parts length
# ---------------------------------------------------------------------------

invariant pathlib_extra310.purepath.parts_len:
  description: "PurePosixPath('/usr/bin').parts.__len__() == 3 — ('/', 'usr', 'bin')"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/bin"]
  method: parts
  method_chain: __len__
  expected: 3

# ---------------------------------------------------------------------------
# is_absolute predicate
# ---------------------------------------------------------------------------

invariant pathlib_extra310.purepath.is_absolute_false:
  description: "PurePosixPath('relative/path').is_absolute() == False"
  category: predicates
  kind: python_call_eq
  function: PurePosixPath
  args: ["relative/path"]
  method: is_absolute
  expected: false

invariant pathlib_extra310.purepath.is_absolute_true:
  description: "PurePosixPath('/absolute/path').is_absolute() == True"
  category: predicates
  kind: python_call_eq
  function: PurePosixPath
  args: ["/absolute/path"]
  method: is_absolute
  expected: true
