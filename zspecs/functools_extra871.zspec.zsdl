table functools_extra871.module_and_code_attrs:
  description: "functools module-level attributes and function code object checks"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: ft871xx
  columns: [id, function, args, expected]
  rows:
    - [ft871xx001, functools.__name__.__eq__, ["functools"], true]
    - [ft871xx002, functools.__package__.__eq__, ["functools"], true]
    - [ft871xx003, functools.__all__.__class__.__name__.__eq__, ["list"], true]
    - [ft871xx004, functools.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true]
    - [ft871xx005, functools.wraps.__code__.__class__.__name__.__eq__, ["code"], true]
    - [ft871xx006, functools.update_wrapper.__code__.__class__.__name__.__eq__, ["code"], true]
    - [ft871xx007, functools.singledispatch.__code__.__class__.__name__.__eq__, ["code"], true]
    - [ft871xx008, functools.total_ordering.__code__.__class__.__name__.__eq__, ["code"], true]
    - [ft871xx009, functools.lru_cache.__code__.__class__.__name__.__eq__, ["code"], true]
    - [ft871xx010, functools.cache.__code__.__class__.__name__.__eq__, ["code"], true]
    - [ft871xx011, functools.partial.__init__.__qualname__.__eq__, ["partial.__init__"], true]
    - [ft871xx012, functools.partial.__reduce__.__qualname__.__eq__, ["partial.__reduce__"], true]
