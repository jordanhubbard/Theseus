spec: pathlib_extra103
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra102

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec extends pathlib_extra102.zspec.zsdl."
    - "This spec covers: pathlib.PurePath method and property class names."
    - "PurePath is a pure Python class; all its methods are 'function' when accessed on the class."
    - "All dunder methods (__init__, __new__, __repr__, __str__, __hash__, __eq__, comparison dunders) are 'function'."
    - "Navigation/operator methods (__truediv__, __rtruediv__, __bytes__, __fspath__) are 'function'."
    - "Path manipulation methods (with_name, with_stem, with_suffix, joinpath, relative_to) are 'function'."
    - "Properties (parts, drive, root, anchor, stem, suffix, suffixes, name, parent, parents) are 'property'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath dunder method class names
# __init__, __new__, __repr__, __str__, __hash__, __eq__,
# __lt__, __gt__, __le__, __ge__ -> all 'function'
# ---------------------------------------------------------------------------

table pathlib_extra103.PurePath_dunder_methods_classname:
  description: "pathlib.PurePath dunder methods (__init__, __new__, __repr__, __str__, __hash__, __eq__, __lt__, __gt__, __le__, __ge__) __class__.__name__ == 'function'"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: pathlibpurepathmethod103

  columns: [id, function, args, expected]
  rows:
    - [pp_init_cls,  PurePath.__init__.__class__.__name__.__eq__, ["function"], true]
    - [pp_new_cls,   PurePath.__new__.__class__.__name__.__eq__,  ["function"], true]
    - [pp_repr_cls,  PurePath.__repr__.__class__.__name__.__eq__, ["function"], true]
    - [pp_str_cls,   PurePath.__str__.__class__.__name__.__eq__,  ["function"], true]
    - [pp_hash_cls,  PurePath.__hash__.__class__.__name__.__eq__, ["function"], true]
    - [pp_eq_cls,    PurePath.__eq__.__class__.__name__.__eq__,   ["function"], true]
    - [pp_lt_cls,    PurePath.__lt__.__class__.__name__.__eq__,   ["function"], true]
    - [pp_gt_cls,    PurePath.__gt__.__class__.__name__.__eq__,   ["function"], true]
    - [pp_le_cls,    PurePath.__le__.__class__.__name__.__eq__,   ["function"], true]
    - [pp_ge_cls,    PurePath.__ge__.__class__.__name__.__eq__,   ["function"], true]
    - [pp_init_not_meth, PurePath.__init__.__class__.__name__.__eq__, ["method_descriptor"], false]

# ---------------------------------------------------------------------------
# pathlib.PurePath navigation/operator method class names
# __truediv__, __rtruediv__, __bytes__, __fspath__ -> all 'function'
# ---------------------------------------------------------------------------

table pathlib_extra103.PurePath_navigation_methods_classname:
  description: "pathlib.PurePath navigation/operator methods (__truediv__, __rtruediv__, __bytes__, __fspath__) __class__.__name__ == 'function'"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: pathlibpurepathmethod103

  columns: [id, function, args, expected]
  rows:
    - [pp_truediv_cls,  PurePath.__truediv__.__class__.__name__.__eq__,  ["function"], true]
    - [pp_rtruediv_cls, PurePath.__rtruediv__.__class__.__name__.__eq__, ["function"], true]
    - [pp_bytes_cls,    PurePath.__bytes__.__class__.__name__.__eq__,    ["function"], true]
    - [pp_fspath_cls,   PurePath.__fspath__.__class__.__name__.__eq__,   ["function"], true]
    - [pp_truediv_not_builtin, PurePath.__truediv__.__class__.__name__.__eq__, ["builtin_function_or_method"], false]

# ---------------------------------------------------------------------------
# pathlib.PurePath path manipulation method class names
# with_name, with_stem, with_suffix, joinpath, relative_to -> all 'function'
# ---------------------------------------------------------------------------

table pathlib_extra103.PurePath_manipulation_methods_classname:
  description: "pathlib.PurePath path manipulation methods (with_name, with_stem, with_suffix, joinpath, relative_to) __class__.__name__ == 'function'"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: pathlibpurepathmethod103

  columns: [id, function, args, expected]
  rows:
    - [pp_withname_cls,   PurePath.with_name.__class__.__name__.__eq__,    ["function"], true]
    - [pp_withstem_cls,   PurePath.with_stem.__class__.__name__.__eq__,    ["function"], true]
    - [pp_withsuffix_cls, PurePath.with_suffix.__class__.__name__.__eq__,  ["function"], true]
    - [pp_joinpath_cls,   PurePath.joinpath.__class__.__name__.__eq__,     ["function"], true]
    - [pp_relto_cls,      PurePath.relative_to.__class__.__name__.__eq__,  ["function"], true]
    - [pp_withname_not_wr, PurePath.with_name.__class__.__name__.__eq__,   ["wrapper_descriptor"], false]

# ---------------------------------------------------------------------------
# pathlib.PurePath property class names
# parts, drive, root, anchor, stem, suffix, suffixes, name, parent, parents -> all 'property'
# ---------------------------------------------------------------------------

table pathlib_extra103.PurePath_property_classnames:
  description: "pathlib.PurePath properties (parts, drive, root, anchor, stem, suffix, suffixes, name, parent, parents) __class__.__name__ == 'property'"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: pathlibpurepathmethod103

  columns: [id, function, args, expected]
  rows:
    - [pp_parts_cls,    PurePath.parts.__class__.__name__.__eq__,    ["property"], true]
    - [pp_drive_cls,    PurePath.drive.__class__.__name__.__eq__,    ["property"], true]
    - [pp_root_cls,     PurePath.root.__class__.__name__.__eq__,     ["property"], true]
    - [pp_anchor_cls,   PurePath.anchor.__class__.__name__.__eq__,   ["property"], true]
    - [pp_stem_cls,     PurePath.stem.__class__.__name__.__eq__,     ["property"], true]
    - [pp_suffix_cls,   PurePath.suffix.__class__.__name__.__eq__,   ["property"], true]
    - [pp_suffixes_cls, PurePath.suffixes.__class__.__name__.__eq__, ["property"], true]
    - [pp_name_cls,     PurePath.name.__class__.__name__.__eq__,     ["property"], true]
    - [pp_parent_cls,   PurePath.parent.__class__.__name__.__eq__,   ["property"], true]
    - [pp_parents_cls,  PurePath.parents.__class__.__name__.__eq__,  ["property"], true]
    - [pp_parts_not_fn, PurePath.parts.__class__.__name__.__eq__,    ["function"], false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra103.PurePath.init_is_function:
  description: "pathlib.PurePath.__init__.__class__.__name__ == 'function' (PurePath is a pure Python class; its methods are regular functions on the class, not C extension descriptors)"
  category: method_descriptor
  kind: python_call_eq
  function: PurePath.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra103.PurePath.truediv_is_function:
  description: "pathlib.PurePath.__truediv__.__class__.__name__ == 'function' (the / operator for path joining is a regular Python function, not a C slot wrapper)"
  category: method_descriptor
  kind: python_call_eq
  function: PurePath.__truediv__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra103.PurePath.parts_is_property:
  description: "pathlib.PurePath.parts.__class__.__name__ == 'property' (PurePath attributes like parts, drive, root are Python property objects defined in pure Python)"
  category: method_descriptor
  kind: python_call_eq
  function: PurePath.parts.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra103.PurePath.with_name_is_function:
  description: "pathlib.PurePath.with_name.__class__.__name__ == 'function' (path manipulation methods like with_name, with_stem, with_suffix are regular Python functions)"
  category: method_descriptor
  kind: python_call_eq
  function: PurePath.with_name.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra103.PurePath.parents_is_property:
  description: "pathlib.PurePath.parents.__class__.__name__ == 'property' (parents is a Python property that returns a sequence of ancestor paths)"
  category: method_descriptor
  kind: python_call_eq
  function: PurePath.parents.__class__.__name__.__eq__
  args: ["property"]
  expected: true
