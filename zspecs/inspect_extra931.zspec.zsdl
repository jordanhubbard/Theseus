spec: inspect_extra931
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __doc__.__class__.__name__ for core inspect functions to confirm docstring type is str"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra931.member_and_doc_functions:
  description: "inspect.getmembers, getdoc, getsource, getsourcelines __doc__ class name"
  kind: python_call_eq
  category: doc_class_name
  id_prefix: ip931a
  columns: [id, function, args, expected]
  rows:
    - [ip931x001, inspect.getmembers.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [ip931x002, inspect.getdoc.__doc__.__class__.__name__.__eq__,         ["str"], true]
    - [ip931x003, inspect.getsource.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [ip931x004, inspect.getsourcelines.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ip931x005, inspect.getsourcefile.__doc__.__class__.__name__.__eq__,  ["str"], true]

