spec: ipaddress_extra5
version: ">=3.9"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html — Python ipaddress module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
    - "ipaddress.zspec.zsdl — covers IPv4/IPv6 address/network attributes and error cases"
    - "ipaddress_extra.zspec.zsdl — covers __name__ and __module__ for all 6 public classes (tables), packed_is_bytes, is_private, factory return types"
    - "ipaddress_extra2.zspec.zsdl — covers IPv4/IPv6/Network __name__ (table), ip_address/ip_network/ip_interface __name__ (table), loopback class name, packed_is_bytes"
    - "ipaddress_extra3.zspec.zsdl — covers ip_address/ip_network/ip_interface __module__, IPv4/IPv6Address __bases__[0].__name__, IPv4/IPv6Network __bases__[0].__name__, AddressValueError __name__/__bases__/__module__, NetmaskValueError __name__/__bases__/__module__/raises"
    - "ipaddress_extra4.zspec.zsdl — covers IPv4Address is_private/is_loopback/is_unspecified/packed type/packed len, IPv6Address is_loopback/packed len, IPv4Network num_addresses/prefixlen/network_address class, ip_address returns IPv4/IPv6, ip_network returns IPv4Network"
  notes:
    - "This spec extends the ipaddress chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: __qualname__ attributes for the six public ipaddress classes, three factory functions, and two exception classes."
    - "No prior spec covers __qualname__ for any ipaddress symbol — all prior specs use __name__ or __module__."
    - "ipaddress.IPv4Address.__qualname__ == 'IPv4Address' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "ipaddress.IPv6Address.__qualname__ == 'IPv6Address' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "ipaddress.IPv4Network.__qualname__ == 'IPv4Network' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "ipaddress.IPv6Network.__qualname__ == 'IPv6Network' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "ipaddress.IPv4Interface.__qualname__ == 'IPv4Interface' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "ipaddress.IPv6Interface.__qualname__ == 'IPv6Interface' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "ipaddress.ip_address.__qualname__ == 'ip_address' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "ipaddress.ip_network.__qualname__ == 'ip_network' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "ipaddress.ip_interface.__qualname__ == 'ip_interface' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "ipaddress.AddressValueError.__qualname__ == 'AddressValueError' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "ipaddress.NetmaskValueError.__qualname__ == 'NetmaskValueError' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for the six public ipaddress classes
#
# ipaddress_extra.zspec.zsdl and ipaddress_extra2.zspec.zsdl cover __name__;
# ipaddress_extra.zspec.zsdl covers __module__. No prior spec covers __qualname__.
# ---------------------------------------------------------------------------

table ipaddress_extra5.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [IPv4Address,   IPv4Address.__qualname__.__eq__,   ["IPv4Address"],   true]
    - [IPv6Address,   IPv6Address.__qualname__.__eq__,   ["IPv6Address"],   true]
    - [IPv4Network,   IPv4Network.__qualname__.__eq__,   ["IPv4Network"],   true]
    - [IPv6Network,   IPv6Network.__qualname__.__eq__,   ["IPv6Network"],   true]
    - [IPv4Interface, IPv4Interface.__qualname__.__eq__, ["IPv4Interface"], true]
    - [IPv6Interface, IPv6Interface.__qualname__.__eq__, ["IPv6Interface"], true]

# ---------------------------------------------------------------------------
# __qualname__ checks for factory functions and exception classes
#
# ipaddress_extra2.zspec.zsdl covers ip_address/ip_network/ip_interface __name__;
# ipaddress_extra3.zspec.zsdl covers AddressValueError/NetmaskValueError __name__.
# No prior spec covers __qualname__ for any of these.
# ---------------------------------------------------------------------------

table ipaddress_extra5.factory_and_exception_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [ip_address,          ip_address.__qualname__.__eq__,          ["ip_address"],          true]
    - [ip_network,          ip_network.__qualname__.__eq__,          ["ip_network"],          true]
    - [ip_interface,        ip_interface.__qualname__.__eq__,        ["ip_interface"],        true]
    - [AddressValueError,   AddressValueError.__qualname__.__eq__,   ["AddressValueError"],   true]
    - [NetmaskValueError,   NetmaskValueError.__qualname__.__eq__,   ["NetmaskValueError"],   true]
