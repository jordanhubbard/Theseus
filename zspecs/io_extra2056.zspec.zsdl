spec: io_extra2056
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 584 (_extra2056): __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__ dict-presence checks."
    - "io.IOBase, io.BytesIO, io.StringIO, io.FileIO, io.RawIOBase, io.BufferedReader, io.TextIOWrapper are I/O stream classes."
    - "None of these classes implements the sequence/mapping protocol (__getitem__, __setitem__, __delitem__, __len__)."
    - "None defines __getattr__, __setattr__, or __delattr__ in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __getitem__ / __setitem__ / __delitem__ — sequence/mapping protocol
# All False: io stream classes do not implement item access protocol
# ---------------------------------------------------------------------------

table io_extra2056.getitem_protocol:
  description: "io types __getitem__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2056

  columns: [id, function, args, expected]
  rows:
    - ["io2056001", "io.IOBase.__dict__.__contains__",         ["__getitem__"], false]
    - ["io2056002", "io.BytesIO.__dict__.__contains__",        ["__getitem__"], false]
    - ["io2056003", "io.StringIO.__dict__.__contains__",       ["__getitem__"], false]
    - ["io2056004", "io.FileIO.__dict__.__contains__",         ["__getitem__"], false]
