spec: psl
version: ">=1.1.0"
backend: node(psl)

docs: https://www.npmjs.com/package/psl

provenance:
  derived_from:
    - "psl README — https://www.npmjs.com/package/psl"
    - "Test vectors verified with psl via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "psl source"
  notes:
    - "psl is an npm package. Install: npm install psl"
    - "psl.get(domain) returns the eTLD+1 (registrable domain) for the given hostname."
    - "Uses the Mozilla Public Suffix List. Returns null for TLDs/invalid inputs."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns registrable domain string or null."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table psl.get:
  kind: node_module_call_eq
  function: get
  category: get
  id_prefix: pslget

  columns: [id, args, expected]
  rows:
    - [simple,    ["a.b.example.com"],        "example.com"]
    - [co_uk,     ["sub.blog.example.co.uk"], "example.co.uk"]
    - [no_sub,    ["example.com"],            "example.com"]
    - [github_io, ["user.github.io"],         "user.github.io"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:04:55Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
