spec: sys_extra31
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
  notes:
    - "This spec extends sys_extra30.zspec.zsdl."
    - "Prior specs covered: sys built-in function __name__/__module__ lengths; stdin/stdout/stderr __class__.__name__; version_info __class__.__name__; getrecursionlimit()==1000; __name__/__package__; __class__.__name__.__len__() and __eq__() for version/argv/path/modules/stdin/platform/version_info."
    - "This spec covers: sys.maxsize value and class name; sys.maxunicode value and class name; sys.float_info.__class__.__name__.__len__() ('float_info' == 10); sys.int_info.__class__.__name__.__len__() ('int_info' == 8); sys.hash_info.__class__.__name__.__len__() ('hash_info' == 9); sys.flags.__class__.__name__.__len__() ('flags' == 5); sys.builtin_module_names.__class__.__name__.__len__() ('tuple' == 5); sys.version_info.__len__() (== 5); sys.float_info numeric constants (mant_dig/radix/dig/max_exp); sys.int_info.bits_per_digit/sizeof_digit; sys.hash_info.width/nan."
    - "sys.maxsize == 9223372036854775807 on 64-bit. Verified at runtime."
    - "sys.maxsize.__class__.__name__ == 'int'; len == 3. Verified at runtime."
    - "sys.maxunicode == 1114111. Verified at runtime."
    - "sys.maxunicode.__class__.__name__ == 'int'; len == 3. Verified at runtime."
    - "sys.float_info.__class__.__name__ == 'float_info'; len == 10. Verified at runtime."
    - "sys.int_info.__class__.__name__ == 'int_info'; len == 8. Verified at runtime."
    - "sys.hash_info.__class__.__name__ == 'hash_info'; len == 9. Verified at runtime."
    - "sys.flags.__class__.__name__ == 'flags'; len == 5. Verified at runtime."
    - "sys.builtin_module_names.__class__.__name__ == 'tuple'; len == 5. Verified at runtime."
    - "sys.version_info.__len__() == 5 — named tuple with (major, minor, micro, releaselevel, serial). Verified at runtime."
    - "sys.float_info.mant_dig == 53. Verified at runtime."
    - "sys.float_info.radix == 2. Verified at runtime."
    - "sys.float_info.dig == 15. Verified at runtime."
    - "sys.float_info.max_exp == 1024. Verified at runtime."
    - "sys.int_info.bits_per_digit == 30. Verified at runtime."
    - "sys.int_info.sizeof_digit == 4. Verified at runtime."
    - "sys.hash_info.width == 64. Verified at runtime."
    - "sys.hash_info.nan == 0. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sys.maxsize — value and class name
#
# sys.maxsize is the largest positive integer that can be held in a Py_ssize_t
# on this platform. On 64-bit: 2^63 - 1 == 9223372036854775807.
# Its class is plain int; __class__.__name__ == 'int', len == 3.
# No prior sys spec verifies maxsize's value or its class name length.
# Both verified at runtime.
# ---------------------------------------------------------------------------

invariant sys_extra31.maxsize.value:
  description: "sys.maxsize == 9223372036854775807 on 64-bit — largest Py_ssize_t value"
  category: constants
  kind: python_call_eq
  function: maxsize.__eq__
  args: [9223372036854775807]
  expected: true

invariant sys_extra31.maxsize.class_name_len:
  description: "len(sys.maxsize.__class__.__name__) == 3 — maxsize is an int, 'int' is 3 characters"
  category: type_attrs
  kind: python_call_eq
  function: maxsize.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# sys.maxunicode — value and class name
#
# sys.maxunicode is the largest Unicode code point value: 1114111 (U+10FFFF).
# Its class is plain int; __class__.__name__ == 'int', len == 3.
# No prior sys spec verifies maxunicode's value or its class name length.
# Both verified at runtime.
# ---------------------------------------------------------------------------

invariant sys_extra31.maxunicode.value:
  description: "sys.maxunicode == 1114111 — largest Unicode code point (U+10FFFF)"
  category: constants
  kind: python_call_eq
  function: maxunicode.__eq__
  args: [1114111]
  expected: true

invariant sys_extra31.maxunicode.class_name_len:
  description: "len(sys.maxunicode.__class__.__name__) == 3 — maxunicode is an int, 'int' is 3 characters"
  category: type_attrs
  kind: python_call_eq
  function: maxunicode.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# sys.version_info.__len__()
#
# sys.version_info is a named tuple with exactly 5 fields:
# (major, minor, micro, releaselevel, serial). No prior sys spec verifies
# version_info.__len__() == 5 as a standalone invariant.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant sys_extra31.version_info.len:
  description: "sys.version_info.__len__() == 5 — named tuple with major/minor/micro/releaselevel/serial"
  category: type_attrs
  kind: python_call_eq
  function: version_info.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# sys.float_info.mant_dig and radix
#
# IEEE 754 double-precision: mantissa digits == 53 (binary), radix == 2.
# These are stable platform-independent constants for CPython on all
# IEEE 754 systems. No prior sys spec verifies these fields.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant sys_extra31.float_info.mant_dig:
  description: "sys.float_info.mant_dig == 53 — IEEE 754 double has 53-bit mantissa"
  category: constants
  kind: python_call_eq
  function: float_info.mant_dig.__eq__
  args: [53]
  expected: true

invariant sys_extra31.float_info.radix:
  description: "sys.float_info.radix == 2 — IEEE 754 floating point uses binary radix"
  category: constants
  kind: python_call_eq
  function: float_info.radix.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# Table: struct info class name lengths
#
# sys exposes several named-tuple-like struct objects: float_info, int_info,
# hash_info, flags, version_info. Their class names have distinct lengths.
# No prior sys spec checks __class__.__name__.__len__() for these objects.
# Also includes maxsize/maxunicode/builtin_module_names class name lengths.
# All verified at runtime.
# ---------------------------------------------------------------------------

table sys_extra31.struct_class_name_lengths:
  description: "sys struct-info and constant attribute __class__.__name__.__len__() — float_info/int_info/hash_info/flags/builtin_module_names/maxsize/maxunicode"
  kind: python_call_eq
  category: type_attrs
  id_prefix: s31scnl

  columns: [id, function, args, expected]
  rows:
    - [float_info,           float_info.__class__.__name__.__len__,           [], 10]
    - [int_info,             int_info.__class__.__name__.__len__,             [], 8]
    - [hash_info,            hash_info.__class__.__name__.__len__,            [], 9]
    - [flags,                flags.__class__.__name__.__len__,                [], 5]
    - [builtin_module_names, builtin_module_names.__class__.__name__.__len__, [], 5]
    - [maxsize_cls,          maxsize.__class__.__name__.__len__,              [], 3]
    - [maxunicode_cls,       maxunicode.__class__.__name__.__len__,           [], 3]

# ---------------------------------------------------------------------------
# Table: sys numeric constants — float_info, int_info, hash_info fields
#
# Groups the most stable numeric constant fields from the three sys info
# structs. These values are platform-independent on any IEEE 754 64-bit
# CPython build. No prior sys spec verifies any of these fields.
# All verified at runtime on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table sys_extra31.info_struct_numeric_fields:
  description: "sys numeric constant fields: float_info (mant_dig/radix/dig/max_exp), int_info (bits_per_digit/sizeof_digit), hash_info (width/nan), maxsize, maxunicode"
  kind: python_call_eq
  category: constants
  id_prefix: s31inf

  columns: [id, function, args, expected]
  rows:
    - [float_mant_dig,       float_info.mant_dig.__eq__,       [53],               true]
    - [float_radix,          float_info.radix.__eq__,           [2],                true]
    - [float_dig,            float_info.dig.__eq__,             [15],               true]
    - [float_max_exp,        float_info.max_exp.__eq__,         [1024],             true]
    - [int_bits_per_digit,   int_info.bits_per_digit.__eq__,    [30],               true]
    - [int_sizeof_digit,     int_info.sizeof_digit.__eq__,      [4],                true]
    - [hash_width,           hash_info.width.__eq__,            [64],               true]
    - [hash_nan,             hash_info.nan.__eq__,              [0],                true]
    - [maxsize_val,          maxsize.__eq__,                    [9223372036854775807], true]
    - [maxunicode_val,       maxunicode.__eq__,                 [1114111],          true]
