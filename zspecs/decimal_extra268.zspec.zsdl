spec: decimal_extra268
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "decimal.__package__ == '' — decimal is a top-level module, not a package."
    - "decimal.__loader__.__class__.__name__ == 'SourceFileLoader' — loaded from Lib/_pydecimal.py via decimal.py shim."
    - "_decimal is the C accelerator extension; _decimal.__loader__.__class__.__name__ == 'ExtensionFileLoader'."
    - "decimal.__version__ == '1.70' — a historic version string carried in the module."
    - "decimal.__libmpdec_version__ == '4.0.1' — the version of the underlying mpdecimal C library."
    - "Both decimal.__version__ and decimal.__libmpdec_version__ are str objects."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: decimal module __spec__ and loader identity
# ---------------------------------------------------------------------------

table decimal_extra268.decimal_module_spec_identity:
  description: "decimal module __name__, __package__, __spec__.name, __spec__.__class__.__name__, and __loader__.__class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: msi

  columns: [id, function, args, expected, description]
  rows:
    - [dec_name,     __name__.__eq__,                    ["decimal"],          true, "decimal.__name__ == 'decimal'"]
    - [dec_package,  __package__.__eq__,                 [""],                 true, "decimal.__package__ == '' — decimal is a top-level module"]
    - [spec_name,    __spec__.name.__eq__,               ["decimal"],          true, "decimal.__spec__.name == 'decimal'"]
    - [spec_class,   __spec__.__class__.__name__.__eq__, ["ModuleSpec"],       true, "decimal.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [loader_class, __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "decimal.__loader__.__class__.__name__ == 'SourceFileLoader'"]

# ---------------------------------------------------------------------------
# Table: decimal module version strings
# ---------------------------------------------------------------------------

table decimal_extra268.decimal_version_strings:
  description: "decimal.__version__ and decimal.__libmpdec_version__ value and type identity"
  kind: python_call_eq
  category: identity
  id_prefix: dvs

  columns: [id, function, args, expected, description]
  rows:
    - [version_val,        __version__.__eq__,                          ["1.70"],   true, "decimal.__version__ == '1.70'"]
    - [version_class,      __version__.__class__.__name__.__eq__,       ["str"],    true, "type(decimal.__version__).__name__ == 'str'"]
    - [libmpdec_val,       __libmpdec_version__.__eq__,                 ["4.0.1"],  true, "decimal.__libmpdec_version__ == '4.0.1'"]
    - [libmpdec_class,     __libmpdec_version__.__class__.__name__.__eq__, ["str"], true, "type(decimal.__libmpdec_version__).__name__ == 'str'"]

# ---------------------------------------------------------------------------
# Standalone invariants: decimal and _decimal spec metadata
# ---------------------------------------------------------------------------

invariant decimal_extra268.decimal.__spec__.name:
  description: "decimal.__spec__.name == 'decimal'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra268.decimal.__package__:
  description: "decimal.__package__ == '' — decimal is a top-level module, not a package"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant decimal_extra268.decimal.__loader__.class_name:
  description: "decimal.__loader__.__class__.__name__ == 'SourceFileLoader'"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant decimal_extra268.decimal.__version__:
  description: "decimal.__version__ == '1.70'"
  category: identity
  kind: python_call_eq
  function: __version__.__eq__
  args: ["1.70"]
  expected: true

invariant decimal_extra268.decimal.__version__.class_name:
  description: "decimal.__version__.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __version__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra268.decimal.__libmpdec_version__:
  description: "decimal.__libmpdec_version__ == '4.0.1'"
  category: identity
  kind: python_call_eq
  function: __libmpdec_version__.__eq__
  args: ["4.0.1"]
  expected: true

invariant decimal_extra268.decimal.__libmpdec_version__.class_name:
  description: "decimal.__libmpdec_version__.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __libmpdec_version__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
