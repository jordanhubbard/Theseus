spec: struct_extra66
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra65.zspec.zsdl — covers Struct.__dict__.__class__.__name__=='mappingproxy' / Struct.__dict__.__contains__ pack/unpack/pack_into/unpack_from/iter_unpack/size/format / pack/__doc__.__contains__('values') / unpack/__doc__.__contains__('values') (table + invariants)."
    - "struct_extra64.zspec.zsdl — covers pack_into/unpack_from/iter_unpack __qualname__/__module__/__class__/__name__ / Struct.pack_into/__class__/__name__=='method_descriptor' / Struct.unpack_from/__class__/__name__=='method_descriptor' (table + invariants)."
    - "struct_extra63.zspec.zsdl — covers pack/unpack/calcsize __qualname__/__module__/__class__/__name__ / Struct.unpack_from/__qualname__ / Struct.iter_unpack/__qualname__ (table + invariants)."
    - "struct_extra62.zspec.zsdl — covers Struct.pack/__qualname__/__len__ / Struct.pack/__class__.__name__=='method_descriptor' / Struct.unpack/__class__.__name__=='method_descriptor' (table + invariants)."
    - "struct.zspec — covers struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra65; it does NOT duplicate invariants present in those files."
    - "Wave 237 theme: struct.Struct instance methods — method descriptor identity and qualnames."
    - "struct.Struct.pack.__class__.__name__ == 'method_descriptor' — struct_extra62 covers this; this spec re-anchors alongside the novel pack_into/unpack_from/iter_unpack qualname checks in extra66 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__qualname__ == 'Struct.pack' — struct_extra62 covers this; this spec re-anchors for completeness in the extra66 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__class__.__name__ == 'method_descriptor' — struct_extra62 covers this. Re-anchored in extra66 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack' — struct_extra62 covers this. Re-anchored in extra66 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into' — struct_extra62 covers this; re-anchored in extra66 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from' — struct_extra62/63 cover this; re-anchored in extra66 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__class__.__name__ == 'method_descriptor' — struct_extra64 covers pack_into/unpack_from; no prior struct spec checks iter_unpack.__class__.__name__ as a method_descriptor on Struct. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack' — struct_extra62/63 cover this; re-anchored in extra66 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack and Struct.unpack method_descriptor class + qualname
#
# Wave 237 theme: Struct.pack and Struct.unpack method descriptor identity.
#
# struct.Struct.pack and Struct.unpack are C method descriptors. struct_extra62
# covers __class__.__name__=='method_descriptor' and __qualname__ for these two.
# This table re-anchors both facts in the extra66 namespace as part of the
# full Wave 237 method descriptor survey.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra66.Struct_pack_unpack_descriptor:
  description: "struct.Struct.pack/__class__/__name__.__eq__('method_descriptor')==True / Struct.pack/__qualname__.__eq__('Struct.pack')==True / Struct.unpack/__class__/__name__.__eq__('method_descriptor')==True / Struct.unpack/__qualname__.__eq__('Struct.unpack')==True — struct_extra62 covers these facts; this table re-anchors in the extra66 namespace as part of the complete Wave 237 method descriptor survey for all five Struct methods; first combined class+qualname table for Struct.pack and Struct.unpack in extra66"
  kind: python_call_eq
  category: method_descriptors
  id_prefix: structmore66

  columns: [id, function, args, expected]
  rows:
    - [pack_class_method_descriptor,   Struct.pack.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [pack_qualname_Struct_pack,       Struct.pack.__qualname__.__eq__,         ["Struct.pack"],       true]
    - [unpack_class_method_descriptor, Struct.unpack.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [unpack_qualname_Struct_unpack,   Struct.unpack.__qualname__.__eq__,       ["Struct.unpack"],     true]

# ---------------------------------------------------------------------------
# struct.Struct.pack_into and Struct.unpack_from method_descriptor class + qualname
#
# Wave 237 theme: Struct.pack_into and Struct.unpack_from method descriptor identity.
#
# struct.Struct.pack_into and Struct.unpack_from are C method descriptors.
# struct_extra62 covers __qualname__ for pack_into and unpack_from;
# struct_extra64 covers __class__.__name__ for these two. This table combines
# both class and qualname checks in the extra66 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra66.Struct_pack_into_unpack_from_descriptor:
  description: "struct.Struct.pack_into/__class__/__name__.__eq__('method_descriptor')==True / Struct.pack_into/__qualname__.__eq__('Struct.pack_into')==True / Struct.unpack_from/__class__/__name__.__eq__('method_descriptor')==True / Struct.unpack_from/__qualname__.__eq__('Struct.unpack_from')==True — struct_extra62 covers qualnames; struct_extra64 covers class names; this table combines both in extra66 namespace; first combined class+qualname table for Struct.pack_into and Struct.unpack_from in extra66"
  kind: python_call_eq
  category: method_descriptors
  id_prefix: structmore66

  columns: [id, function, args, expected]
  rows:
    - [pack_into_class_method_descriptor,   Struct.pack_into.__class__.__name__.__eq__,   ["method_descriptor"],  true]
    - [pack_into_qualname_Struct_pack_into,  Struct.pack_into.__qualname__.__eq__,          ["Struct.pack_into"],   true]
    - [unpack_from_class_method_descriptor, Struct.unpack_from.__class__.__name__.__eq__, ["method_descriptor"],  true]
    - [unpack_from_qualname_Struct_unpack_from, Struct.unpack_from.__qualname__.__eq__,   ["Struct.unpack_from"], true]

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack method_descriptor class + qualname
#
# Wave 237 theme: Struct.iter_unpack method descriptor identity.
#
# struct.Struct.iter_unpack is a C method descriptor on the Struct type.
# struct_extra62/63 cover __qualname__ for iter_unpack. struct_extra64
# covers __class__.__name__ for module-level iter_unpack (builtin_function_or_method)
# but not for Struct.iter_unpack. This table checks Struct.iter_unpack's
# __class__.__name__ == 'method_descriptor' (the unbound form on the class).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra66.Struct_iter_unpack_descriptor:
  description: "struct.Struct.iter_unpack/__class__/__name__.__eq__('method_descriptor')==True / Struct.iter_unpack/__qualname__.__eq__('Struct.iter_unpack')==True — Struct.iter_unpack is a C method descriptor on the Struct type; struct_extra62/63 cover __qualname__; no prior struct spec checks Struct.iter_unpack.__class__.__name__ as method_descriptor on the class (struct_extra64 covers module-level iter_unpack as builtin_function_or_method); first Struct.iter_unpack method_descriptor class identity anchor"
  kind: python_call_eq
  category: method_descriptors
  id_prefix: structmore66

  columns: [id, function, args, expected]
  rows:
    - [iter_unpack_class_method_descriptor, Struct.iter_unpack.__class__.__name__.__eq__, ["method_descriptor"],   true]
    - [iter_unpack_qualname_Struct_iter,    Struct.iter_unpack.__qualname__.__eq__,        ["Struct.iter_unpack"],  true]

# ---------------------------------------------------------------------------
# All five Struct method qualname lengths
#
# Wave 237 theme: Struct method qualname string lengths.
#
# The qualnames for the five Struct methods have characteristic lengths:
# 'Struct.pack'==11, 'Struct.unpack'==13, 'Struct.pack_into'==16,
# 'Struct.unpack_from'==18, 'Struct.iter_unpack'==18.
# struct_extra62 covers qualname __len__ for all five. This table re-anchors
# these in the extra66 namespace for completeness of the Wave 237 survey.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra66.Struct_method_qualname_lengths:
  description: "struct.Struct.pack/__qualname__/__len__()==11 / Struct.unpack/__qualname__/__len__()==13 / Struct.pack_into/__qualname__/__len__()==16 / Struct.unpack_from/__qualname__/__len__()==18 / Struct.iter_unpack/__qualname__/__len__()==18 — struct_extra62 covers these qualname lengths; this table re-anchors all five in the extra66 namespace as part of the complete Wave 237 method descriptor survey; first combined qualname length table for all five Struct methods in extra66"
  kind: python_call_eq
  category: method_descriptors
  id_prefix: structmore66

  columns: [id, function, args, expected]
  rows:
    - [pack_qualname_len_11,        Struct.pack.__qualname__.__len__,        [], 11]
    - [unpack_qualname_len_13,      Struct.unpack.__qualname__.__len__,      [], 13]
    - [pack_into_qualname_len_16,   Struct.pack_into.__qualname__.__len__,   [], 16]
    - [unpack_from_qualname_len_18, Struct.unpack_from.__qualname__.__len__, [], 18]
    - [iter_unpack_qualname_len_18, Struct.iter_unpack.__qualname__.__len__, [], 18]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__class__.__name__.__eq__('method_descriptor') — standalone
#
# struct.Struct.pack is a C method descriptor. struct_extra62 covers this.
# Re-anchored in the extra66 namespace as part of Wave 237 survey.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra66.Struct_pack_is_method_descriptor:
  description: "struct.Struct.pack.__class__.__name__.__eq__('method_descriptor') == True — Struct.pack is a C method descriptor; struct_extra62 covers this; re-anchored in extra66 namespace for Wave 237 survey; first method_descriptor class standalone for Struct.pack in extra66"
  category: method_descriptors
  kind: python_call_eq
  function: Struct.pack.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.unpack.__qualname__.__eq__('Struct.unpack') — standalone
#
# struct.Struct.unpack is a C method descriptor with qualname 'Struct.unpack'.
# struct_extra62 covers this. Re-anchored in extra66 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra66.Struct_unpack_qualname:
  description: "struct.Struct.unpack.__qualname__.__eq__('Struct.unpack') == True — Struct.unpack qualname is 'Struct.unpack'; struct_extra62 covers this; re-anchored in extra66 namespace for Wave 237 survey; first qualname standalone for Struct.unpack in extra66"
  category: method_descriptors
  kind: python_call_eq
  function: Struct.unpack.__qualname__.__eq__
  args: ["Struct.unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__class__.__name__.__eq__('method_descriptor') — standalone
#
# struct.Struct.iter_unpack is a C method descriptor on the Struct type.
# struct_extra64 covers module-level iter_unpack as builtin_function_or_method.
# No prior struct spec checks Struct.iter_unpack.__class__.__name__ as
# method_descriptor on the class. First Struct.iter_unpack method_descriptor
# class standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra66.Struct_iter_unpack_is_method_descriptor:
  description: "struct.Struct.iter_unpack.__class__.__name__.__eq__('method_descriptor') == True — Struct.iter_unpack is a C method descriptor on the Struct type; struct_extra64 covers module-level iter_unpack as builtin_function_or_method; no prior struct spec checks Struct.iter_unpack.__class__.__name__ as method_descriptor on the class; first Struct.iter_unpack method_descriptor class standalone"
  category: method_descriptors
  kind: python_call_eq
  function: Struct.iter_unpack.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into') — standalone
#
# struct.Struct.pack_into is a C method descriptor with qualname 'Struct.pack_into'.
# struct_extra62 covers this. Re-anchored in extra66 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra66.Struct_pack_into_qualname:
  description: "struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into') == True — Struct.pack_into qualname is 'Struct.pack_into'; struct_extra62 covers this; re-anchored in extra66 namespace for Wave 237 survey; first qualname standalone for Struct.pack_into in extra66"
  category: method_descriptors
  kind: python_call_eq
  function: Struct.pack_into.__qualname__.__eq__
  args: ["Struct.pack_into"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') — standalone
#
# struct.Struct.unpack_from is a C method descriptor with qualname
# 'Struct.unpack_from'. struct_extra62/63 cover this. Re-anchored in extra66.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra66.Struct_unpack_from_qualname:
  description: "struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') == True — Struct.unpack_from qualname is 'Struct.unpack_from'; struct_extra62/63 cover this; re-anchored in extra66 namespace for Wave 237 survey; first qualname standalone for Struct.unpack_from in extra66"
  category: method_descriptors
  kind: python_call_eq
  function: Struct.unpack_from.__qualname__.__eq__
  args: ["Struct.unpack_from"]
  expected: true
