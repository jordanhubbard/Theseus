spec: struct_extra145
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra144.zspec.zsdl — covers struct.__dict__.__contains__('pack'/'Struct'/'error'/'calcsize'/'unpack'/'pack_into'/'unpack_from'/'iter_unpack') / Struct.__dict__.__contains__('__init__'/'__sizeof__'/'__new__'/'__doc__') / struct.__dict__.__contains__ membership checks (table + invariants)."
    - "struct_extra143.zspec.zsdl — covers struct.Struct.__dict__.__contains__('pack'/'unpack'/'pack_into'/'format'/'size'/'iter_unpack'/'unpack_from'/'__repr__') / Struct.__dict__.__len__()==16 / struct.pack.__module__.__eq__('_struct') / struct.__package__.__eq__('') (table + invariants)."
    - "struct_extra142.zspec.zsdl — covers struct.__all__/__class__.__name__.__eq__('list') / __all__.__len__()==8 / __all__.__contains__('Struct'/'error'/'pack'/'calcsize') / __spec__.name.__eq__('struct') / __loader__.__class__.__name__.__eq__('SourceFileLoader') / Struct.__init__.__qualname__.__eq__('Struct.__init__') (table + invariants)."
    - "struct_extra141.zspec.zsdl — covers struct.Struct.__module__.__eq__('_struct') / Struct.__qualname__.__eq__('Struct') / Struct.__bases__[0].__name__.__eq__('object') / Struct.__mro__.__len__()==2 / Struct.__doc__.__len__()==40 / Struct.__dict__.__class__.__name__.__eq__('mappingproxy') / error.__qualname__.__eq__('error') (table + invariants)."
    - "struct_extra140.zspec.zsdl — covers struct.Struct.format/__class__.__name__.__eq__('getset_descriptor') / Struct.size/__class__.__name__.__eq__('getset_descriptor') / struct.__doc__.__len__()==1278 / struct.error/__doc__ is None (table + invariants)."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra144."
    - "Wave 327 theme: struct module and class __dict__.__len__() and __dict__.__class__.__name__ comparisons — struct.__dict__.__len__()==18 / struct.Struct.__dict__.__len__()==16 / struct.error.__dict__.__len__()==3 / struct.error.__dict__.__class__.__name__.__eq__('mappingproxy') / struct.__dict__.__class__.__name__.__eq__('dict')."
    - "struct.__dict__.__len__() == 18. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__len__() == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__dict__.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__dict__.__class__.__name__ == 'mappingproxy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__dict__.__class__.__name__ == 'dict'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.__dict__.__len__() == 18. The 18 module-level entries are: __name__, __doc__, __package__, __loader__, __spec__, __file__, __cached__, __builtins__ (8 metadata), __all__ (1), calcsize, iter_unpack, pack, pack_into, unpack, unpack_from (6 functions), Struct, error, _clearcache (3 class/helper names). The module-level dict is smaller than hashlib.__dict__ (33) because struct has only 6 module-level functions while hashlib has 14 hash constructor shortcuts."
    - "Note: struct.error.__dict__.__len__() == 3. The 3 entries in struct.error's class dict are: __module__ (str), __weakref__ (getset_descriptor), __doc__ (NoneType). struct.error.__doc__ is None (anchored in extra140). The minimal 3-entry class dict reflects that struct.error is a trivially-defined exception class (class error(Exception): pass) with no additional methods or attributes."
    - "Note: struct.error.__dict__.__class__.__name__ == 'mappingproxy' (12 chars). Like all class __dict__ objects, struct.error's class dict is a mappingproxy. This matches struct.Struct.__dict__.__class__.__name__ (also 'mappingproxy', anchored in extra141). Both contrast with struct.__dict__.__class__.__name__ == 'dict' (4 chars) since module dicts are plain mutable dicts."
    - "Note: Length ordering across the three struct dicts: struct.error.__dict__ (3 entries) < struct.Struct.__dict__ (16 entries) < struct.__dict__ (18 entries). The error class has the smallest dict (3 entries) because it is a minimal exception class. Struct has more (16) because it is a full C extension type with 5 methods, 2 descriptors, and several dunders. The module dict (18) is slightly larger than Struct (16) because it adds the function set plus class names."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__dict__.__len__()==18
# struct.__dict__.__class__.__name__.__eq__('dict')
# struct.Struct.__dict__.__len__()==16
# struct.error.__dict__.__len__()==3
#
# Wave 327 theme: struct dict sizes across the module and its two classes.
#
# The three struct dicts have sizes 18 (module), 16 (Struct class), and 3 (error class).
# extra143 anchors Struct.__dict__.__len__()==16 as a standalone; no prior struct spec
# anchors struct.__dict__.__len__()==18 or error.__dict__.__len__()==3, or the
# comparison of all three as a table under structlen145.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra145.struct_dict_sizes_comparison:
  description: "struct.__dict__.__len__()==18 / struct.__dict__.__class__.__name__.__eq__('dict')==True / struct.Struct.__dict__.__len__()==16 / struct.error.__dict__.__len__()==3 — three struct dict sizes: error(3) < Struct(16) < module(18); module dict is plain 'dict' (4 chars); class dicts are 'mappingproxy' (12 chars); error has minimal 3-entry dict (__module__/__weakref__/__doc__); extra143 anchors Struct dict len as standalone; first structlen145 anchor for module dict len and error dict len"
  kind: python_call_eq
  category: identity
  id_prefix: structlen145

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_len_18,   "__dict__.__len__",         [], 18, "struct.__dict__.__len__() is 18 (8 metadata + 6 functions + Struct + error + _clearcache + __all__)"]
    - [module_dict_class_dict, "__dict__.__class__.__name__.__eq__", ["dict"], true, "struct.__dict__.__class__.__name__ == 'dict' (4 chars; plain mutable dict, not mappingproxy like class dicts)"]
    - [Struct_dict_len_16,   "Struct.__dict__.__len__",  [], 16, "struct.Struct.__dict__.__len__() is 16 (5 method_descriptors + 2 getset_descriptors + dunders + __doc__ + __module__)"]
    - [error_dict_len_3,     "error.__dict__.__len__",   [],  3, "struct.error.__dict__.__len__() is 3 (__module__ + __weakref__ + __doc__; minimal exception class dict)"]

# ---------------------------------------------------------------------------
# struct.error.__dict__.__class__.__name__.__eq__('mappingproxy')
# struct.error.__dict__.__class__.__name__.__len__()==12
# struct.__dict__.__class__.__name__.__len__()==4
#
# Wave 327 theme: mappingproxy vs dict type names for struct dicts.
#
# struct.error.__dict__.__class__.__name__ is 'mappingproxy' (12 chars) — the same
# type as struct.Struct.__dict__ (anchored in extra141). The module-level
# struct.__dict__.__class__.__name__ is 'dict' (4 chars). The 8-char difference
# (12 - 4 = 8) between class dict type ('mappingproxy') and module dict type ('dict')
# is consistent across all four stdlib modules in the series (hashlib, uuid, struct, socket).
# No prior struct spec anchors struct.error.__dict__.__class__.__name__ as a table
# under structlen145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra145.error_dict_mappingproxy_and_module_dict_class_len:
  description: "struct.error.__dict__.__class__.__name__.__eq__('mappingproxy')==True / error.__dict__.__class__.__name__.__len__()==12 / struct.__dict__.__class__.__name__.__len__()==4 — error.__dict__ is a mappingproxy (12 chars) like Struct.__dict__ (extra141); module dict is 'dict' (4 chars); 8-char difference (12-4) between class and module dict type names; consistent pattern across hashlib/uuid/struct/socket; first structlen145 anchor for error dict class name"
  kind: python_call_eq
  category: identity
  id_prefix: structlen145

  columns: [id, function, args, expected, description]
  rows:
    - [error_dict_mappingproxy,      "error.__dict__.__class__.__name__.__eq__",  ["mappingproxy"], true, "struct.error.__dict__.__class__.__name__ == 'mappingproxy' (12 chars; class dict is read-only proxy)"]
    - [error_dict_class_len_12,      "error.__dict__.__class__.__name__.__len__", [],              12,   "struct.error.__dict__.__class__.__name__.__len__() is 12 ('mappingproxy' = 12 chars)"]
    - [module_dict_class_len_4,      "__dict__.__class__.__name__.__len__",       [],               4,   "struct.__dict__.__class__.__name__.__len__() is 4 ('dict' = 4 chars; 8 shorter than 'mappingproxy')"]

# ---------------------------------------------------------------------------
# struct.error.__dict__.__contains__('__module__')
# struct.error.__dict__.__contains__('__doc__')
# struct.error.__dict__.__contains__('__weakref__')
#
# Wave 327 theme: struct.error class __dict__ contains exactly 3 entries.
#
# struct.error.__dict__ has exactly 3 entries: __module__ ('struct'), __doc__ (None),
# and __weakref__ (getset_descriptor). These are the only direct class attributes of
# struct.error, reflecting its trivially-defined nature (class error(Exception): pass).
# extra140 anchors error.__doc__ is None; extra97 anchors error.__module__.__len__()==6;
# no prior struct spec anchors these as a table under structlen145.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra145.error_dict_contains_three_entries:
  description: "struct.error.__dict__.__contains__('__module__')==True / error.__dict__.__contains__('__doc__')==True / error.__dict__.__contains__('__weakref__')==True — exactly 3 entries in error.__dict__; __module__=='struct' (extra97 anchors len==6); __doc__==None (extra140); __weakref__ is a getset_descriptor; trivial exception class (class error(Exception): pass); no prior struct spec anchors these as a table under structlen145"
  kind: python_call_eq
  category: identity
  id_prefix: structlen145

  columns: [id, function, args, expected, description]
  rows:
    - [error_dict_module,    "error.__dict__.__contains__",  ["__module__"],   true, "struct.error.__dict__.__contains__('__module__') == True (str 'struct'; len 6, anchored in extra97)"]
    - [error_dict_doc,       "error.__dict__.__contains__",  ["__doc__"],      true, "struct.error.__dict__.__contains__('__doc__') == True (NoneType; error.__doc__ is None, anchored in extra140)"]
    - [error_dict_weakref,   "error.__dict__.__contains__",  ["__weakref__"],  true, "struct.error.__dict__.__contains__('__weakref__') == True (getset_descriptor; supports weak references to error instances)"]

# ---------------------------------------------------------------------------
# struct.__dict__.__len__()==18 — standalone
#
# struct.__dict__.__len__() is 18. The 18 entries are: __name__, __doc__, __package__,
# __loader__, __spec__, __file__, __cached__, __builtins__ (8 metadata), __all__ (1 list),
# calcsize, iter_unpack, pack, pack_into, unpack, unpack_from (6 functions), Struct
# (class), error (exception class), _clearcache (private helper). Comparing module dict
# sizes: struct (18) < hashlib (33) < uuid (75) << socket (267). The struct module dict
# is the smallest of the four in the series because struct exposes only 6 module-level
# functions (no individual algorithm shortcuts like hashlib's 14 hash constructors).
# No prior struct spec anchors struct.__dict__.__len__()==18 as a standalone under
# structlen145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra145.module_dict_len_18:
  description: "struct.__dict__.__len__() == 18 — 18 entries: 8 metadata + __all__ + 6 functions (pack/unpack/pack_into/unpack_from/calcsize/iter_unpack) + Struct + error + _clearcache; smallest module dict in the series: struct(18) < hashlib(33) < uuid(75) << socket(267); no prior struct spec anchors this as a standalone; first standalone under structlen145"
  category: identity
  kind: python_call_eq
  function: "__dict__.__len__"
  args: []
  expected: 18

# ---------------------------------------------------------------------------
# struct.error.__dict__.__len__()==3 — standalone
#
# struct.error.__dict__.__len__() is 3. The 3 entries are: __module__ ('struct',
# anchored in extra97), __doc__ (None, anchored in extra140), and __weakref__
# (getset_descriptor). struct.error is defined as 'class error(Exception): pass' in
# the struct wrapper code, giving it no additional methods or attributes beyond what
# it inherits from Exception. At 3 entries, error.__dict__ is the smallest class dict
# in the struct module (error=3 < Struct=16). No prior struct spec anchors
# struct.error.__dict__.__len__()==3 as a standalone under structlen145.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra145.error_dict_len_3:
  description: "struct.error.__dict__.__len__() == 3 — 3 entries: __module__ (str 'struct') + __doc__ (None) + __weakref__ (getset_descriptor); trivial 'class error(Exception): pass'; smallest class dict in struct module: error(3) < Struct(16); no prior struct spec anchors this as a standalone; first standalone under structlen145"
  category: identity
  kind: python_call_eq
  function: "error.__dict__.__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# struct.error.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# struct.error.__dict__.__class__.__name__ is 'mappingproxy' (12 chars). All class
# __dict__ objects in CPython are exposed as mappingproxy — a read-only proxy over
# the underlying dict. This applies to exception classes like struct.error just as
# it does to normal classes like struct.Struct (extra141) and uuid.UUID (extra137).
# The mappingproxy type name (12 chars) is consistent across all class __dict__
# objects in the stdlib series. No prior struct spec anchors
# struct.error.__dict__.__class__.__name__.__eq__('mappingproxy') as a standalone
# under structlen145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra145.error_dict_mappingproxy:
  description: "struct.error.__dict__.__class__.__name__.__eq__('mappingproxy') == True — 'mappingproxy' (12 chars); all CPython class __dict__ objects are mappingproxy (read-only proxy); matches Struct.__dict__ (extra141) and UUID.__dict__ (extra137); applies to exception classes same as regular classes; no prior struct spec anchors this as a standalone; first standalone under structlen145"
  category: identity
  kind: python_call_eq
  function: "error.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__dict__.__class__.__name__.__eq__('dict') — standalone
#
# struct.__dict__.__class__.__name__ is 'dict' (4 chars). Module-level __dict__
# objects in CPython are always plain mutable dicts — they can be written to (e.g.,
# by assignments at module scope). This contrasts with class __dict__ objects which
# are mappingproxy objects (read-only). The 'dict' type name (4 chars) vs 'mappingproxy'
# (12 chars) difference distinguishes module dicts from class dicts. This pattern holds
# for all four stdlib modules in the series: struct, hashlib, uuid, and socket all have
# module __dict__.__class__.__name__ == 'dict'. No prior struct spec anchors
# struct.__dict__.__class__.__name__.__eq__('dict') as a standalone under structlen145.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra145.module_dict_class_dict:
  description: "struct.__dict__.__class__.__name__.__eq__('dict') == True — 'dict' (4 chars); module __dict__ is a plain mutable dict (writable by module-scope assignments); contrasts with class __dict__ 'mappingproxy' (12 chars); pattern holds for all four stdlib modules (struct/hashlib/uuid/socket); no prior struct spec anchors this as a standalone; first standalone under structlen145"
  category: identity
  kind: python_call_eq
  function: "__dict__.__class__.__name__.__eq__"
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__class__.__name__.__len__()==12 — standalone
#
# struct.Struct.__dict__.__class__.__name__.__len__() is 12. The class dict type
# name 'mappingproxy' is 12 chars — established in extra141 for Struct.__dict__.
# This 12-char length ties with uuid.UUID.__dict__.__class__.__name__.__len__()
# (also 'mappingproxy', 12 chars), socket.socket.__dict__.__class__.__name__.__len__()
# (also 12), and struct.error.__dict__.__class__.__name__.__len__() (also 12).
# The 12-char 'mappingproxy' type name is the universal class dict type across all
# CPython class __dict__ objects in the stdlib module series. No prior struct spec
# anchors Struct.__dict__.__class__.__name__.__len__()==12 as a standalone under
# structlen145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra145.Struct_dict_class_name_len_12:
  description: "struct.Struct.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' = 12 chars; ties with uuid.UUID.__dict__ (extra137) and socket.socket.__dict__ (extra144) and struct.error.__dict__ (structlen145 table); universal class dict type name length in CPython; 8 chars longer than module dict type 'dict' (4 chars); no prior struct spec anchors this as a standalone; first standalone under structlen145"
  category: identity
  kind: python_call_eq
  function: "Struct.__dict__.__class__.__name__.__len__"
  args: []
  expected: 12

