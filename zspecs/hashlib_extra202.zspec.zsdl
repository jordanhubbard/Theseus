spec: hashlib_extra202
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/md5module.c"
  notes:
    - "hashlib.md5.__doc__.__class__.__name__ == 'str' (len=3) — md5 constructor has a docstring."
    - "hashlib.sha256.__doc__.__class__.__name__ == 'str' (len=3) — sha256 constructor has a docstring."
    - "hashlib.sha512.__doc__.__class__.__name__ == 'str' (len=3) — sha512 constructor has a docstring."
    - "hashlib.blake2b.__doc__.__class__.__name__ == 'str' (len=3) — blake2b constructor has a docstring."
    - "hashlib.blake2s.__doc__.__class__.__name__ == 'str' (len=3) — blake2s constructor has a docstring."
    - "hashlib.pbkdf2_hmac.__doc__.__class__.__name__ == 'str' (len=3) — pbkdf2_hmac function has a docstring."
    - "hashlib.new.__doc__.__class__.__name__ == 'str' (len=3) — new function has a docstring."
    - "hashlib.shake_256.__doc__.__class__.__name__ == 'str' (len=3) — shake_256 constructor has a docstring."
    - "All eight covered callables carry docstrings on Python 3.14.3 macOS/Darwin 25.4.0; __doc__.__class__.__name__ == 'str' for all."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib __doc__ class name identity — group A
# hashlib.md5, hashlib.sha256, hashlib.sha512
# ---------------------------------------------------------------------------

table hashliballdocs202.constructors_doc_class_a:
  kind: python_call_eq
  category: doc_identity
  id_prefix: hashliballdocs202

  columns: [id, function, args, expected, description]
  rows:
    - [md5_doc_class_len,    md5.__doc__.__class__.__name__.__len__,    [], 3, "hashlib.md5.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; md5 has a docstring)"]
    - [sha256_doc_class_len, sha256.__doc__.__class__.__name__.__len__, [], 3, "hashlib.sha256.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; sha256 has a docstring)"]
    - [sha512_doc_class_len, sha512.__doc__.__class__.__name__.__len__, [], 3, "hashlib.sha512.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; sha512 has a docstring)"]

# ---------------------------------------------------------------------------
# hashlib __doc__ class name identity — group B
# hashlib.blake2b, hashlib.blake2s, hashlib.pbkdf2_hmac
# ---------------------------------------------------------------------------

table hashliballdocs202.blake2_and_pbkdf2_doc_class_b:
  kind: python_call_eq
  category: doc_identity
  id_prefix: hashliballdocs202

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_doc_class_len,    blake2b.__doc__.__class__.__name__.__len__,    [], 3, "hashlib.blake2b.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; blake2b has a docstring)"]
    - [blake2s_doc_class_len,    blake2s.__doc__.__class__.__name__.__len__,    [], 3, "hashlib.blake2s.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; blake2s has a docstring)"]
    - [pbkdf2_doc_class_len,     pbkdf2_hmac.__doc__.__class__.__name__.__len__, [], 3, "hashlib.pbkdf2_hmac.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; pbkdf2_hmac has a docstring)"]

# ---------------------------------------------------------------------------
# hashlib __doc__ class name identity — group C
# hashlib.new, hashlib.shake_256 (+ equality check)
# ---------------------------------------------------------------------------

table hashliballdocs202.new_and_shake_doc_class_c:
  kind: python_call_eq
  category: doc_identity
  id_prefix: hashliballdocs202

  columns: [id, function, args, expected, description]
  rows:
    - [new_doc_class_len,       new.__doc__.__class__.__name__.__len__,       [], 3, "hashlib.new.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; new has a docstring)"]
    - [shake_256_doc_class_len, shake_256.__doc__.__class__.__name__.__len__, [], 3, "hashlib.shake_256.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; shake_256 has a docstring)"]
    - [md5_doc_class_eq,        md5.__doc__.__class__.__name__.__eq__,        ["str"], true, "hashlib.md5.__doc__.__class__.__name__ == 'str' — md5 constructor docstring is a plain Python str"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashliballdocs202.md5_doc_class_name_len:
  description: "hashlib.md5.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; md5 constructor carries a docstring"
  category: doc_identity
  kind: python_call_eq
  function: md5.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

