spec: io_extra2236
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io.zspec.zsdl"
    - "_io_extra.zspec.zsdl"
  notes:
    - "Wave _extra2236: __slots__ and slot descriptor protocol checks for io classes."
    - "Covers __slots__, __weakref__, __dict__, __abstractmethods__, __init__, __new__, __subclasshook__ presence in io class dicts."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase are C extension types; they define __abstractmethods__ but no __slots__, __weakref__, __dict__, __init__, __new__, or __subclasshook__."
    - "io.StringIO, io.BytesIO, io.FileIO are concrete C types; they define __init__ and __new__ but no __slots__, __weakref__, __dict__, or __abstractmethods__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table io_extra2236.IOBase_slot_protocol:
  description: "io.IOBase __slots__/__weakref__/__dict__/__abstractmethods__/__init__/__new__/__subclasshook__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2236

  columns: [id, function, args, expected]
  rows:
    - ["io2236001", "io.IOBase.__dict__.__contains__", ["__slots__"], false]
    - ["io2236002", "io.IOBase.__dict__.__contains__", ["__weakref__"], false]
    - ["io2236003", "io.IOBase.__dict__.__contains__", ["__dict__"], false]
    - ["io2236004", "io.IOBase.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["io2236005", "io.IOBase.__dict__.__contains__", ["__init__"], false]
    - ["io2236006", "io.IOBase.__dict__.__contains__", ["__new__"], false]
    - ["io2236007", "io.IOBase.__dict__.__contains__", ["__subclasshook__"], false]

