spec: inspect_extra40
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra39.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/iscode/isframe/istraceback __name__/__qualname__.__len__(); iscoroutinefunction/isgeneratorfunction/isasyncgenfunction __name__/__qualname__.__len__(); getmembers/getfile/getsource/getsourcelines/getmodule/signature/stack/currentframe/getfullargspec __qualname__.__len__(); Parameter/__mro__.__len__()==2; Signature/__mro__.__len__()==2; BoundArguments/__mro__.__len__()==2; Parameter.empty class/kind constants; inspect.__all__.__len__()==107; CO_OPTIMIZED==1; cleandoc/formatannotation/getattr_static/classify_class_attrs __name__ lengths; Signature/Parameter/BoundArguments method qualnames; getmembers/__module__.__len__(7); parameter kind integer values (0-4); Parameter.__name__/'Parameter'; Parameter.__module__/'inspect'; Signature.__name__/'Signature'; Signature.__module__/'inspect'."
    - "This spec covers: inspect.isfunction.__name__ == 'isfunction'; inspect.isfunction.__module__ == 'inspect'; inspect.isbuiltin.__name__ == 'isbuiltin'; inspect.isbuiltin.__module__ == 'inspect'; inspect.isclass.__name__ == 'isclass'; inspect.isclass.__module__ == 'inspect'; inspect.ismodule.__name__ == 'ismodule'; inspect.ismodule.__module__ == 'inspect'; inspect.ismethod.__name__ == 'ismethod'; inspect.ismethod.__module__ == 'inspect'; inspect.getcallargs.__name__ == 'getcallargs'; inspect.getcallargs.__module__ == 'inspect'; inspect.getfile.__name__ == 'getfile'; inspect.getfile.__module__ == 'inspect'."
    - "Key findings: All nine inspect predicate and utility functions have __module__ == 'inspect' (7 chars) — they are all pure-Python functions defined in Lib/inspect.py. The __name__ values are identical to the attribute names on the module: 'isfunction' (10 chars), 'isbuiltin' (9 chars), 'isclass' (7 chars), 'ismodule' (8 chars), 'ismethod' (8 chars), 'getcallargs' (11 chars), 'getfile' (7 chars). Notable length coincidences: isclass.__name__ (7 chars) == getfile.__name__ (7 chars) == __module__.__len__() (7 chars); ismodule and ismethod share __name__ length of 8 chars. Prior specs recorded __name__.__len__() and __module__.__len__()==7 for many of these, but not the string equality invariants for __name__ or the exact __module__ string. No prior inspect spec records these equality invariants in the extra40 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.isfunction and inspect.isbuiltin identity metadata — extra40 namespace
#
# inspect.isfunction.__name__ is 'isfunction' (10 chars) and inspect.isfunction.
# __module__ is 'inspect' (7 chars). inspect.isbuiltin.__name__ is 'isbuiltin'
# (9 chars) and inspect.isbuiltin.__module__ is 'inspect' (7 chars). Both are
# pure-Python functions in Lib/inspect.py. Prior specs recorded __name__.__len__
# () and __module__.__len__()==7 for both, but not the string equality invariants.
# These four equality invariants are new to the extra40 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra40.isfunction_name:
  description: "inspect.isfunction.__name__ == 'isfunction' — pure-Python predicate; 10-char name; returns True for Python functions created by def statements"
  category: identity
  kind: python_call_eq
  function: isfunction.__name__.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra40.isfunction_module:
  description: "inspect.isfunction.__module__ == 'inspect' — pure-Python function defined in Lib/inspect.py; 7-char module name"
  category: module_metadata
  kind: python_call_eq
  function: isfunction.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra40.isbuiltin_name:
  description: "inspect.isbuiltin.__name__ == 'isbuiltin' — pure-Python predicate; 9-char name; returns True for built-in functions and methods (C implementations)"
  category: identity
  kind: python_call_eq
  function: isbuiltin.__name__.__eq__
  args: ["isbuiltin"]
  expected: true

invariant inspect_extra40.isbuiltin_module:
  description: "inspect.isbuiltin.__module__ == 'inspect' — pure-Python function defined in Lib/inspect.py; 7-char module name; same as isfunction.__module__"
  category: module_metadata
  kind: python_call_eq
  function: isbuiltin.__module__.__eq__
  args: ["inspect"]
  expected: true

# ---------------------------------------------------------------------------
# inspect type-check predicate __name__ and __module__ — extra40 namespace
#
# inspect.isclass.__name__ is 'isclass' (7 chars), inspect.ismodule.__name__ is
# 'ismodule' (8 chars), inspect.ismethod.__name__ is 'ismethod' (8 chars). All
# three have __module__ == 'inspect' (7 chars). isclass and getfile share the
# 7-char __name__ length, which also matches the 7-char __module__ string.
# ismodule and ismethod share the 8-char __name__ length. Prior specs recorded
# __name__.__len__() for these but not the string equality invariants. These six
# equality invariants are new to the extra40 namespace.
# ---------------------------------------------------------------------------

table inspect_extra40.type_check_predicate_names:
  description: "inspect type-check predicate __name__ and __module__ equality: isclass, ismodule, ismethod"
  kind: python_call_eq
  category: identity
  id_prefix: tcpname40

  columns: [id, function, args, expected, description]
  rows:
    - [isclass_name,
       isclass.__name__.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__name__ == 'isclass' — pure-Python predicate; 7-char name; same length as getfile.__name__ and __module__ string length"]
    - [isclass_module,
       isclass.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isclass.__module__ == 'inspect' — pure-Python function in Lib/inspect.py; 7-char module name"]
    - [ismodule_name,
       ismodule.__name__.__eq__,
       ["ismodule"],
       true,
       "inspect.ismodule.__name__ == 'ismodule' — pure-Python predicate; 8-char name; same length as ismethod.__name__"]
    - [ismodule_module,
       ismodule.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ismodule.__module__ == 'inspect' — pure-Python function in Lib/inspect.py; 7-char module name"]
    - [ismethod_name,
       ismethod.__name__.__eq__,
       ["ismethod"],
       true,
       "inspect.ismethod.__name__ == 'ismethod' — pure-Python predicate; 8-char name; same length as ismodule.__name__; returns True for bound methods"]
    - [ismethod_module,
       ismethod.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ismethod.__module__ == 'inspect' — pure-Python function in Lib/inspect.py; 7-char module name"]

# ---------------------------------------------------------------------------
# inspect.getcallargs and inspect.getfile identity metadata — extra40 namespace
#
# inspect.getcallargs.__name__ is 'getcallargs' (11 chars) and inspect.getcallargs.
# __module__ is 'inspect' (7 chars). inspect.getfile.__name__ is 'getfile' (7 chars)
# and inspect.getfile.__module__ is 'inspect' (7 chars). Both are pure-Python
# functions in Lib/inspect.py. Note that getfile.__name__ (7 chars) coincidentally
# equals getfile.__module__.__len__() (7 chars). Prior specs recorded __qualname__
# .__len__() for getfile but not the string equality invariants for either function.
# These four equality invariants are new to the extra40 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra40.getcallargs_name:
  description: "inspect.getcallargs.__name__ == 'getcallargs' — pure-Python utility; 11-char name; longest __name__ among functions covered in this spec; maps args to parameters"
  category: identity
  kind: python_call_eq
  function: getcallargs.__name__.__eq__
  args: ["getcallargs"]
  expected: true

invariant inspect_extra40.getcallargs_module:
  description: "inspect.getcallargs.__module__ == 'inspect' — pure-Python function in Lib/inspect.py; 7-char module name"
  category: module_metadata
  kind: python_call_eq
  function: getcallargs.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra40.getfile_name:
  description: "inspect.getfile.__name__ == 'getfile' — pure-Python utility; 7-char name; same length as __module__ ('inspect'); returns the Python source file for an object"
  category: identity
  kind: python_call_eq
  function: getfile.__name__.__eq__
  args: ["getfile"]
  expected: true

invariant inspect_extra40.getfile_module:
  description: "inspect.getfile.__module__ == 'inspect' — pure-Python function in Lib/inspect.py; 7-char module name; same length as getfile.__name__"
  category: module_metadata
  kind: python_call_eq
  function: getfile.__module__.__eq__
  args: ["inspect"]
  expected: true
