spec: numbers
version: ">=3.0"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/numbers.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "numbers source: Lib/numbers.py (PSF; source inspection permitted)"
  not_derived_from:
    - "numbers source: internal C extension implementation details"
  notes:
    - "The numbers module defines an abstract numeric tower: Number > Complex > Real > Rational > Integral."
    - "Number has no abstract methods; it is a pure marker class."
    - "Complex has 16 abstract methods on Python 3.12 (Darwin 64-bit)."
    - "Real has 23 abstract methods on Python 3.12 (Darwin 64-bit)."
    - "Rational adds numerator and denominator abstract properties; 24 abstract methods total."
    - "Integral adds bitwise operations; 34 abstract methods total on Python 3.12."
    - "All classes have __module__ == 'numbers'."
    - "isinstance/issubclass checks for concrete types (int, float) are not exercised here because the harness cannot pass class objects as JSON args."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — the five abstract classes of the numeric tower
# ---------------------------------------------------------------------------

table numbers.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [number,   Number.__name__.__eq__,   ["Number"],   true]
    - [complex,  Complex.__name__.__eq__,  ["Complex"],  true]
    - [real,     Real.__name__.__eq__,     ["Real"],     true]
    - [rational, Rational.__name__.__eq__, ["Rational"], true]
    - [integral, Integral.__name__.__eq__, ["Integral"], true]

# ---------------------------------------------------------------------------
# Module membership — all five classes live in 'numbers'
# ---------------------------------------------------------------------------

table numbers.module_checks:
  kind: python_call_eq
  category: module_membership
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [number_mod,   Number.__module__.__eq__,   ["numbers"], true]
    - [complex_mod,  Complex.__module__.__eq__,  ["numbers"], true]
    - [real_mod,     Real.__module__.__eq__,     ["numbers"], true]
    - [rational_mod, Rational.__module__.__eq__, ["numbers"], true]
    - [integral_mod, Integral.__module__.__eq__, ["numbers"], true]

# ---------------------------------------------------------------------------
# Abstract method counts
#
# Each abstract class declares a frozenset of abstract methods.
# Number is a pure marker with no abstract methods.
# Counts verified on Python 3.12 Darwin 64-bit.
# ---------------------------------------------------------------------------

invariant numbers.abstract_methods.Number_count:
  description: "len(numbers.Number.__abstractmethods__) == 0 — Number is a pure marker class"
  category: abstract_methods
  kind: python_call_eq
  function: Number.__abstractmethods__.__len__
  args: []
  expected: 0

invariant numbers.abstract_methods.Complex_count:
  description: "len(numbers.Complex.__abstractmethods__) == 16 — Complex declares 16 abstract methods"
  category: abstract_methods
  kind: python_call_eq
  function: Complex.__abstractmethods__.__len__
  args: []
  expected: 16

invariant numbers.abstract_methods.Real_count:
  description: "len(numbers.Real.__abstractmethods__) == 23 — Real declares 23 abstract methods"
  category: abstract_methods
  kind: python_call_eq
  function: Real.__abstractmethods__.__len__
  args: []
  expected: 23

invariant numbers.abstract_methods.Rational_count:
  description: "len(numbers.Rational.__abstractmethods__) == 24 — Rational adds numerator/denominator"
  category: abstract_methods
  kind: python_call_eq
  function: Rational.__abstractmethods__.__len__
  args: []
  expected: 24

invariant numbers.abstract_methods.Integral_count:
  description: "len(numbers.Integral.__abstractmethods__) == 34 — Integral adds bitwise operations"
  category: abstract_methods
  kind: python_call_eq
  function: Integral.__abstractmethods__.__len__
  args: []
  expected: 34

# ---------------------------------------------------------------------------
# Abstract method membership — spot-check key methods
#
# These verify that specific well-known abstract methods are present in each
# class's __abstractmethods__ frozenset.
# ---------------------------------------------------------------------------

invariant numbers.abstract_methods.Complex_has_abs:
  description: "numbers.Complex.__abstractmethods__.__contains__('__abs__') == True"
  category: abstract_methods
  kind: python_call_eq
  function: Complex.__abstractmethods__.__contains__
  args: ["__abs__"]
  expected: true

invariant numbers.abstract_methods.Complex_has_conjugate:
  description: "numbers.Complex.__abstractmethods__.__contains__('conjugate') == True"
  category: abstract_methods
  kind: python_call_eq
  function: Complex.__abstractmethods__.__contains__
  args: ["conjugate"]
  expected: true

invariant numbers.abstract_methods.Rational_has_numerator:
  description: "numbers.Rational.__abstractmethods__.__contains__('numerator') == True"
  category: abstract_methods
  kind: python_call_eq
  function: Rational.__abstractmethods__.__contains__
  args: ["numerator"]
  expected: true

invariant numbers.abstract_methods.Rational_has_denominator:
  description: "numbers.Rational.__abstractmethods__.__contains__('denominator') == True"
  category: abstract_methods
  kind: python_call_eq
  function: Rational.__abstractmethods__.__contains__
  args: ["denominator"]
  expected: true

invariant numbers.abstract_methods.Integral_has_and:
  description: "numbers.Integral.__abstractmethods__.__contains__('__and__') == True — bitwise AND is Integral-only"
  category: abstract_methods
  kind: python_call_eq
  function: Integral.__abstractmethods__.__contains__
  args: ["__and__"]
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-04-15T08:54:19Z
  iterations: 1
  pass_count: 20
  fail_count: 0
  total_invariants: 20
  notes: Synthesis succeeded in 1 iteration(s). 20 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
