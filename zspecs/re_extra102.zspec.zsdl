spec: re_extra102
version: ">=3.9"
backend: python_module(re)
extends: re_extra99

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra99.zspec.zsdl."
    - "This spec covers: re module function __qualname__ values and lengths; re.Pattern method __qualname__ values and lengths."
    - "re.compile.__qualname__ = 'compile' (length 7)."
    - "re.match.__qualname__ = 'match' (length 5)."
    - "re.search.__qualname__ = 'search' (length 6)."
    - "re.fullmatch.__qualname__ = 'fullmatch' (length 9)."
    - "re.sub.__qualname__ = 'sub' (length 3)."
    - "re.subn.__qualname__ = 'subn' (length 4)."
    - "re.findall.__qualname__ = 'findall' (length 7)."
    - "re.finditer.__qualname__ = 'finditer' (length 8)."
    - "re.split.__qualname__ = 'split' (length 5)."
    - "re.escape.__qualname__ = 'escape' (length 6)."
    - "re.purge.__qualname__ = 'purge' (length 5)."
    - "re.Pattern.match.__qualname__ = 'Pattern.match' (length 13)."
    - "re.Pattern.search.__qualname__ = 'Pattern.search' (length 14)."
    - "re.Pattern.findall.__qualname__ = 'Pattern.findall' (length 15)."
    - "re.Pattern.finditer.__qualname__ = 'Pattern.finditer' (length 16)."
    - "re.Pattern.fullmatch.__qualname__ = 'Pattern.fullmatch' (length 17)."
    - "re.Pattern.sub.__qualname__ = 'Pattern.sub' (length 11)."
    - "re.Pattern.subn.__qualname__ = 'Pattern.subn' (length 12)."
    - "re.Pattern.split.__qualname__ = 'Pattern.split' (length 13)."
    - "re module functions are Python functions (qualname == bare name); re.Pattern methods are C method_descriptors."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module function __qualname__ values
# re module functions like compile, match, search etc. are Python functions
# defined in Lib/re/__init__.py. Their __qualname__ is just the bare function
# name (no class prefix), because they are module-level functions, not methods.
# ---------------------------------------------------------------------------

table re_extra102.module_function_qualnames:
  description: "re module function __qualname__ values: module-level functions have bare names as qualnames (no 'ClassName.' prefix)"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: refnqn102

  columns: [id, function, args, expected, description]
  rows:
    - [compile_qn,   compile.__qualname__.__eq__,   ["compile"],   true, "re.compile.__qualname__ == 'compile' (module-level function; qualname is just the bare name)"]
    - [match_qn,     match.__qualname__.__eq__,     ["match"],     true, "re.match.__qualname__ == 'match'"]
    - [search_qn,    search.__qualname__.__eq__,    ["search"],    true, "re.search.__qualname__ == 'search'"]
    - [fullmatch_qn, fullmatch.__qualname__.__eq__, ["fullmatch"], true, "re.fullmatch.__qualname__ == 'fullmatch'"]
    - [sub_qn,       sub.__qualname__.__eq__,       ["sub"],       true, "re.sub.__qualname__ == 'sub'"]
    - [subn_qn,      subn.__qualname__.__eq__,      ["subn"],      true, "re.subn.__qualname__ == 'subn'"]
    - [findall_qn,   findall.__qualname__.__eq__,   ["findall"],   true, "re.findall.__qualname__ == 'findall'"]
    - [finditer_qn,  finditer.__qualname__.__eq__,  ["finditer"],  true, "re.finditer.__qualname__ == 'finditer'"]
    - [split_qn,     split.__qualname__.__eq__,     ["split"],     true, "re.split.__qualname__ == 'split'"]
    - [escape_qn,    escape.__qualname__.__eq__,    ["escape"],    true, "re.escape.__qualname__ == 'escape'"]
    - [purge_qn,     purge.__qualname__.__eq__,     ["purge"],     true, "re.purge.__qualname__ == 'purge'"]
    - [compile_not_re_qn, compile.__qualname__.__eq__, ["re.compile"], false, "re.compile.__qualname__ is NOT 're.compile' (module-level functions do not include the module name in qualname)"]

# ---------------------------------------------------------------------------
# re module function __qualname__ lengths
# The lengths encode the exact character count of each function's bare name.
# ---------------------------------------------------------------------------

table re_extra102.module_function_qualname_lengths:
  description: "re module function __qualname__ length values: compile=7, match=5, search=6, fullmatch=9, sub=3, subn=4, findall=7, finditer=8, split=5, escape=6, purge=5"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: refnqn102

  columns: [id, function, args, expected, description]
  rows:
    - [compile_qn_len,   compile.__qualname__.__len__,   [], 7, "re.compile.__qualname__.__len__() == 7 ('compile' has 7 characters)"]
    - [match_qn_len,     match.__qualname__.__len__,     [], 5, "re.match.__qualname__.__len__() == 5 ('match' has 5 characters)"]
    - [search_qn_len,    search.__qualname__.__len__,    [], 6, "re.search.__qualname__.__len__() == 6 ('search' has 6 characters)"]
    - [fullmatch_qn_len, fullmatch.__qualname__.__len__, [], 9, "re.fullmatch.__qualname__.__len__() == 9 ('fullmatch' has 9 characters)"]
    - [sub_qn_len,       sub.__qualname__.__len__,       [], 3, "re.sub.__qualname__.__len__() == 3 ('sub' has 3 characters; shortest re function name)"]
    - [subn_qn_len,      subn.__qualname__.__len__,      [], 4, "re.subn.__qualname__.__len__() == 4 ('subn' has 4 characters)"]
    - [findall_qn_len,   findall.__qualname__.__len__,   [], 7, "re.findall.__qualname__.__len__() == 7 ('findall' has 7 characters; same as compile)"]
    - [finditer_qn_len,  finditer.__qualname__.__len__,  [], 8, "re.finditer.__qualname__.__len__() == 8 ('finditer' has 8 characters)"]
    - [split_qn_len,     split.__qualname__.__len__,     [], 5, "re.split.__qualname__.__len__() == 5 ('split' has 5 characters; same as match and purge)"]
    - [escape_qn_len,    escape.__qualname__.__len__,    [], 6, "re.escape.__qualname__.__len__() == 6 ('escape' has 6 characters; same as search)"]
    - [purge_qn_len,     purge.__qualname__.__len__,     [], 5, "re.purge.__qualname__.__len__() == 5 ('purge' has 5 characters)"]

# ---------------------------------------------------------------------------
# re.Pattern method __qualname__ values and lengths
# re.Pattern is a C extension type (_sre.SRE_Pattern or re.Pattern).
# Its methods are C-level method_descriptors. Their __qualname__ uses the
# 'Pattern.method_name' prefix (not 'SRE_Pattern.').
# ---------------------------------------------------------------------------

table re_extra102.Pattern_method_qualnames:
  description: "re.Pattern method __qualname__ values: 'Pattern.method_name' format for match(13), search(14), findall(15), finditer(16), fullmatch(17), sub(11), subn(12), split(13)"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: refnqn102

  columns: [id, function, args, expected, description]
  rows:
    - [pm_match_qn,      Pattern.match.__qualname__.__eq__,      ["Pattern.match"],      true, "Pattern.match.__qualname__ == 'Pattern.match'"]
    - [pm_match_len,     Pattern.match.__qualname__.__len__,     [],                     13,   "Pattern.match.__qualname__.__len__() == 13 ('Pattern.match' has 13 characters)"]
    - [pm_search_qn,     Pattern.search.__qualname__.__eq__,     ["Pattern.search"],     true, "Pattern.search.__qualname__ == 'Pattern.search'"]
    - [pm_search_len,    Pattern.search.__qualname__.__len__,    [],                     14,   "Pattern.search.__qualname__.__len__() == 14 ('Pattern.search' has 14 characters)"]
    - [pm_findall_qn,    Pattern.findall.__qualname__.__eq__,    ["Pattern.findall"],    true, "Pattern.findall.__qualname__ == 'Pattern.findall'"]
    - [pm_findall_len,   Pattern.findall.__qualname__.__len__,   [],                     15,   "Pattern.findall.__qualname__.__len__() == 15 ('Pattern.findall' has 15 characters)"]
    - [pm_finditer_qn,   Pattern.finditer.__qualname__.__eq__,   ["Pattern.finditer"],   true, "Pattern.finditer.__qualname__ == 'Pattern.finditer'"]
    - [pm_finditer_len,  Pattern.finditer.__qualname__.__len__,  [],                     16,   "Pattern.finditer.__qualname__.__len__() == 16 ('Pattern.finditer' has 16 characters)"]
    - [pm_fullmatch_qn,  Pattern.fullmatch.__qualname__.__eq__,  ["Pattern.fullmatch"],  true, "Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch'"]
    - [pm_fullmatch_len, Pattern.fullmatch.__qualname__.__len__, [],                     17,   "Pattern.fullmatch.__qualname__.__len__() == 17 ('Pattern.fullmatch' has 17 characters; longest Pattern method qualname in this spec)"]
    - [pm_sub_qn,        Pattern.sub.__qualname__.__eq__,        ["Pattern.sub"],        true, "Pattern.sub.__qualname__ == 'Pattern.sub'"]
    - [pm_sub_len,       Pattern.sub.__qualname__.__len__,       [],                     11,   "Pattern.sub.__qualname__.__len__() == 11 ('Pattern.sub' has 11 characters)"]
    - [pm_subn_qn,       Pattern.subn.__qualname__.__eq__,       ["Pattern.subn"],       true, "Pattern.subn.__qualname__ == 'Pattern.subn'"]
    - [pm_subn_len,      Pattern.subn.__qualname__.__len__,      [],                     12,   "Pattern.subn.__qualname__.__len__() == 12 ('Pattern.subn' has 12 characters)"]
    - [pm_split_qn,      Pattern.split.__qualname__.__eq__,      ["Pattern.split"],      true, "Pattern.split.__qualname__ == 'Pattern.split'"]
    - [pm_split_len,     Pattern.split.__qualname__.__len__,     [],                     13,   "Pattern.split.__qualname__.__len__() == 13 ('Pattern.split' has 13 characters; same as Pattern.match)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra102.compile.qualname_is_compile:
  description: "re.compile.__qualname__ == 'compile' (module-level functions have their bare name as qualname, unlike class methods which have 'ClassName.method' format)"
  category: function_qualnames
  kind: python_call_eq
  function: compile.__qualname__.__eq__
  args: ["compile"]
  expected: true

invariant re_extra102.sub.qualname_len_3:
  description: "re.sub.__qualname__.__len__() == 3 ('sub' is the shortest re module function name and qualname, at just 3 characters)"
  category: function_qualnames
  kind: python_call_eq
  function: sub.__qualname__.__len__
  args: []
  expected: 3

invariant re_extra102.Pattern.fullmatch_qualname_len:
  description: "re.Pattern.fullmatch.__qualname__.__len__() == 17 ('Pattern.fullmatch' is the longest Pattern method qualname covered in this spec at 17 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: Pattern.fullmatch.__qualname__.__len__
  args: []
  expected: 17

invariant re_extra102.Pattern.match_is_method_descriptor:
  description: "re.Pattern.match.__class__.__name__ == 'method_descriptor' (re.Pattern is a C extension type; its methods are C-level method_descriptors, not Python functions)"
  category: method_class_names
  kind: python_call_eq
  function: Pattern.match.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant re_extra102.findall.qualname_len_7:
  description: "re.findall.__qualname__.__len__() == 7 ('findall' has 7 characters; same as 'compile', showing the coincidence of name length)"
  category: function_qualnames
  kind: python_call_eq
  function: findall.__qualname__.__len__
  args: []
  expected: 7

