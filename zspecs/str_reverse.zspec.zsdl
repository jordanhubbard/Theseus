spec: str_reverse
version: ">=1.0.0"
backend: node(str-reverse)

docs: https://www.npmjs.com/package/str-reverse

provenance:
  derived_from:
    - "str-reverse README — https://www.npmjs.com/package/str-reverse"
    - "Test vectors verified with str-reverse via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "str-reverse source"
  notes:
    - "str-reverse is an npm package. Install: npm install str-reverse"
    - "Returns the string reversed."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the input string reversed."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table str_reverse.reverse:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: strrev

  columns: [id, args, expected]
  rows:
    - [hello,  ["hello"],  "olleh"]
    - [abcde,  ["abcde"],  "edcba"]
    - [single, ["a"],      "a"]

