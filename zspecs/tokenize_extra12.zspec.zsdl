spec: tokenize_extra12
version: ">=3.9"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tokenize.html — Python tokenize module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
    - "tokenize_extra11.zspec.zsdl — covers TokenInfo._fields items and length; Untokenizer __name__/__qualname__/__module__/base; TokenError base; open/__name__ and untokenize/__name__; cookie_re class"
    - "tokenize_extra9.zspec.zsdl — covers tokenize/__qualname__ and detect_encoding/__qualname__; untokenize/open __module__; TokenInfo._make/_asdict/_replace __qualname__"
    - "tokenize_extra10.zspec.zsdl — covers tokenize/__name__, generate_tokens/__name__, detect_encoding/__name__; TokenError/__name__/__module__; TokenInfo/__name__/__module__"
    - "tokenize_extra.zspec.zsdl — covers TokenInfo/__name__/__module__; TokenError/__name__/bases; function __name__ table"
  notes:
    - "This spec extends tokenize_extra11.zspec.zsdl."
    - "Focus: __qualname__ for tokenize module functions and classes not yet covered as standalone __eq__ invariants in their own namespace."
    - "tokenize.generate_tokens.__qualname__ == 'generate_tokens' — not covered in any prior tokenize spec as a standalone __eq__ invariant."
    - "tokenize.TokenInfo.__qualname__ == 'TokenInfo' — not covered in any prior tokenize spec as a standalone __eq__ invariant (extra covers __name__ and __module__)."
    - "tokenize.TokenError.__qualname__ == 'TokenError' — not covered in any prior tokenize spec as a standalone __eq__ invariant."
    - "tokenize.open.__qualname__ == 'open' — tokenize_extra9 covers open/__module__; tokenize_extra11 covers open/__name__; __qualname__ is new."
    - "tokenize.untokenize.__qualname__ == 'untokenize' — tokenize_extra9 covers untokenize/__module__; tokenize_extra11 covers untokenize/__name__; __qualname__ is new."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ — generate_tokens, open, untokenize
# (tokenize_extra12 namespace)
#
# tokenize_extra9 covers tokenize/__qualname__ and detect_encoding/__qualname__.
# generate_tokens/__qualname__, open/__qualname__, and untokenize/__qualname__
# are not covered in any prior tokenize spec as standalone __eq__ invariants.
# ---------------------------------------------------------------------------

table tokenize_extra12.function_qualnames:
  description: "__qualname__ for tokenize module functions"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqualname

  columns: [id, function, args, expected]
  rows:
    - [generate_tokens, generate_tokens.__qualname__.__eq__, ["generate_tokens"], true]
    - [open,            open.__qualname__.__eq__,            ["open"],            true]
    - [untokenize,      untokenize.__qualname__.__eq__,      ["untokenize"],      true]

# ---------------------------------------------------------------------------
# Class __qualname__ — TokenInfo, TokenError
# (tokenize_extra12 namespace)
#
# tokenize_extra covers TokenInfo/__name__/__module__ and TokenError/__name__/bases.
# tokenize_extra10 covers TokenInfo/__name__/__module__ and TokenError/__name__/__module__.
# No prior tokenize spec covers TokenInfo/__qualname__ or TokenError/__qualname__
# as standalone __eq__ invariants.
# ---------------------------------------------------------------------------

invariant tokenize_extra12.TokenInfo.qualname:
  description: "tokenize.TokenInfo.__qualname__ == 'TokenInfo'"
  category: class_qualnames
  kind: python_call_eq
  function: TokenInfo.__qualname__.__eq__
  args: ["TokenInfo"]
  expected: true

invariant tokenize_extra12.TokenError.qualname:
  description: "tokenize.TokenError.__qualname__ == 'TokenError'"
  category: class_qualnames
  kind: python_call_eq
  function: TokenError.__qualname__.__eq__
  args: ["TokenError"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__.__len__() — generate_tokens, open, untokenize,
# tokenize, detect_encoding
# (tokenize_extra12 namespace)
#
# No prior tokenize spec covers __qualname__.__len__() for any of these
# as standalone invariants in the tokenize_extra12 namespace.
# tokenize: len=8; generate_tokens: len=15; detect_encoding: len=15;
# open: len=4; untokenize: len=10.
# ---------------------------------------------------------------------------

table tokenize_extra12.function_qualname_lens:
  description: "__qualname__.__len__() for tokenize module functions"
  kind: python_call_eq
  category: function_qualname_lengths
  id_prefix: fqlen

  columns: [id, function, args, expected]
  rows:
    - [tokenize,          tokenize.__qualname__.__len__,          [], 8]
    - [generate_tokens,   generate_tokens.__qualname__.__len__,   [], 15]
    - [detect_encoding,   detect_encoding.__qualname__.__len__,   [], 15]
    - [open,              open.__qualname__.__len__,              [], 4]
    - [untokenize,        untokenize.__qualname__.__len__,        [], 10]
