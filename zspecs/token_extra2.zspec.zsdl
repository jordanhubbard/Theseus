spec: token_extra2
version: ">=3.9"
backend: python_module(token)

docs: https://docs.python.org/3/library/token.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/token.html — Python token module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/token.py"
    - "token.zspec.zsdl — covers exact integer values for core and extended constants, NT_OFFSET, tok_name lookups, and ISEOF/ISTERMINAL/ISNONTERMINAL predicates"
    - "token_extra.zspec.zsdl — covers __class__.__name__ type checks for NAME/NUMBER/STRING/OP/COMMENT/NEWLINE/ENDMARKER/INDENT/DEDENT/ERRORTOKEN, dict type checks for tok_name and EXACT_TOKEN_TYPES, and stable core constant values"
  notes:
    - "This spec covers token aspects not in token.zspec.zsdl or token_extra.zspec.zsdl."
    - "EXACT_TYPE is a constant added in Python 3.8; its value is version-dependent but is always an int."
    - "ENCODING is a tokenize-originated constant re-exported into token; it is an int."
    - "TYPE_COMMENT was added in Python 3.8 for type comment support; it is an int."
    - "ERRORTOKEN is the scanner error sentinel; it is an int regardless of exact value."
    - "tok_name is a dict; tok_name.__len__() >= 50 on Python 3.9+ as new token types have been added."
    - "tok_name.__getitem__(0) == 'ENDMARKER' — ENDMARKER is always token type 0, stable across all Python 3.x."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# EXACT_TYPE — Python 3.8+ constant for exact operator type matching
# ---------------------------------------------------------------------------

invariant token_extra2.EXACT_TYPE.is_int:
  description: "token.EXACT_TYPE.__class__.__name__ == 'int'"
  category: constant_types
  kind: python_call_eq
  function: EXACT_TYPE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# ERRORTOKEN — scanner error sentinel constant
# ---------------------------------------------------------------------------

invariant token_extra2.ERRORTOKEN.is_int:
  description: "token.ERRORTOKEN.__class__.__name__ == 'int'"
  category: constant_types
  kind: python_call_eq
  function: ERRORTOKEN.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# ENCODING — encoding pseudo-token constant
# ---------------------------------------------------------------------------

invariant token_extra2.ENCODING.is_int:
  description: "token.ENCODING.__class__.__name__ == 'int'"
  category: constant_types
  kind: python_call_eq
  function: ENCODING.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# TYPE_COMMENT — type comment token constant (Python 3.8+)
# ---------------------------------------------------------------------------

invariant token_extra2.TYPE_COMMENT.is_int:
  description: "token.TYPE_COMMENT.__class__.__name__ == 'int'"
  category: constant_types
  kind: python_call_eq
  function: TYPE_COMMENT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# tok_name — dict of token int → name string
# ---------------------------------------------------------------------------

invariant token_extra2.tok_name.is_dict:
  description: "token.tok_name.__class__.__name__ == 'dict'"
  category: tok_name
  kind: python_call_eq
  function: tok_name.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant token_extra2.tok_name.min_length:
  description: "len(token.tok_name) >= 50 — at least 50 token types defined on Python 3.9+"
  category: tok_name
  kind: python_call_eq
  function: tok_name.__len__
  args: []
  method: __ge__
  method_args: [50]
  expected: true

invariant token_extra2.tok_name.endmarker_at_zero:
  description: "token.tok_name.__getitem__(0) == 'ENDMARKER'"
  category: tok_name
  kind: python_call_eq
  function: tok_name.__getitem__
  args: [0]
  expected: "ENDMARKER"

invariant token_extra2.tok_name.name_at_one:
  description: "token.tok_name.__getitem__(1) == 'NAME'"
  category: tok_name
  kind: python_call_eq
  function: tok_name.__getitem__
  args: [1]
  expected: "NAME"

invariant token_extra2.tok_name.number_at_two:
  description: "token.tok_name.__getitem__(2) == 'NUMBER'"
  category: tok_name
  kind: python_call_eq
  function: tok_name.__getitem__
  args: [2]
  expected: "NUMBER"

invariant token_extra2.tok_name.string_at_three:
  description: "token.tok_name.__getitem__(3) == 'STRING'"
  category: tok_name
  kind: python_call_eq
  function: tok_name.__getitem__
  args: [3]
  expected: "STRING"

invariant token_extra2.tok_name.newline_at_four:
  description: "token.tok_name.__getitem__(4) == 'NEWLINE'"
  category: tok_name
  kind: python_call_eq
  function: tok_name.__getitem__
  args: [4]
  expected: "NEWLINE"

# ---------------------------------------------------------------------------
# ENDMARKER — stable value of 0 across all Python 3.x
# ---------------------------------------------------------------------------

invariant token_extra2.ENDMARKER.value_zero:
  description: "token.ENDMARKER == 0"
  category: constant_values
  kind: python_call_eq
  function: ENDMARKER.__eq__
  args: [0]
  expected: true
