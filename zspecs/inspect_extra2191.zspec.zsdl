spec: inspect_extra2191
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2191: context manager protocol dict-presence checks — __enter__, __exit__, __aenter__, __aexit__, acquire, release, __wrapped__, __closure__."
    - "inspect.Parameter, Signature, BoundArguments, FullArgSpec, ArgInfo, ClosureVars, Attribute, Traceback, and FrameInfo are all data-holding types; none implement context manager or lock protocols."
    - "None of the inspect public classes define __enter__, __exit__, __aenter__, __aexit__, acquire, release, __wrapped__, or __closure__ in their own __dict__."
    - "ClosureVars holds closure variable data but does NOT itself have a __closure__ attribute in its dict."
    - "inspect.BoundArguments defines args, kwargs, arguments, and apply_defaults but no context manager methods."
    - "inspect.Parameter defines POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD, empty, name, default, annotation, kind, replace but no context manager methods."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table inspect_extra2191.parameter_context_protocol:
  description: "inspect.Parameter dict-presence checks for context manager, lock, and wrapper protocol keys"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2191

  columns: [id, function, args, expected]
  rows:
    - ["in2191001", "inspect.Parameter.__dict__.__contains__", ["__enter__"], false]
    - ["in2191002", "inspect.Parameter.__dict__.__contains__", ["__exit__"], false]
    - ["in2191003", "inspect.Parameter.__dict__.__contains__", ["__aenter__"], false]
    - ["in2191004", "inspect.Parameter.__dict__.__contains__", ["__aexit__"], false]
    - ["in2191005", "inspect.Parameter.__dict__.__contains__", ["acquire"], false]
    - ["in2191006", "inspect.Parameter.__dict__.__contains__", ["release"], false]
    - ["in2191007", "inspect.Parameter.__dict__.__contains__", ["__wrapped__"], false]
    - ["in2191008", "inspect.Parameter.__dict__.__contains__", ["__closure__"], false]

