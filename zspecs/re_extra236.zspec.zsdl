spec: re_extra236
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.compile flags attribute behavioral contracts."
    - "re.compile('[a-z]+', re.IGNORECASE | re.MULTILINE).flags includes IGNORECASE(2) and MULTILINE(8); verified Python 3.14.3 macOS."
    - "re.compile('[a-z]+', 10).flags == 42 — IGNORECASE(2) + MULTILINE(8) + UNICODE(32) default = 42; verified Python 3.14.3 macOS."
    - "re.compile('[a-z]+', 10).flags & 2 != 0 — IGNORECASE bit set; verified Python 3.14.3 macOS."
    - "re.compile('[a-z]+', 10).flags & 8 != 0 — MULTILINE bit set; verified Python 3.14.3 macOS."
    - "re.compile('[a-z]+', 10).flags & 16 == 0 — DOTALL bit not set; verified Python 3.14.3 macOS."
    - "re.compile('[a-z]+').pattern == '[a-z]+' — .pattern stores the original pattern string; verified Python 3.14.3 macOS."
    - "re.compile('[a-z]+').groups == 0 — no capture groups; verified Python 3.14.3 macOS."
    - "re.compile('(a)(b)(c)').groups == 3 — three capture groups; verified Python 3.14.3 macOS."
    - "re.compile('([a-z]+)').groups == 1 — one capture group; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile flags attribute — combined flags integer value
# IGNORECASE(2) | MULTILINE(8) | UNICODE(32, default) = 42
# The UNICODE flag is always added by default in Python 3.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra236.compile.flags_ignorecase_multiline:
  description: "re.compile('[a-z]+', 10).flags == 42 — IGNORECASE(2)+MULTILINE(8)+UNICODE(32) = 42; verified Python 3.14.3 macOS"
  category: compile_flags
  kind: python_call_eq
  function: compile
  args: ["[a-z]+", 10]
  method: flags.__eq__
  method_args: [42]
  expected: true

# ---------------------------------------------------------------------------
# re.compile flags attribute — individual bit checks via __and__
# Verify IGNORECASE and MULTILINE bits are set; DOTALL bit is not set.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra236.compile.flags_ignorecase_bit:
  description: "re.compile('[a-z]+', 10).flags & 2 != 0 — IGNORECASE(2) bit is set; verified Python 3.14.3 macOS"
  category: compile_flags
  kind: python_call_eq
  function: compile
  args: ["[a-z]+", 10]
  method: flags.__and__
  method_args: [2]
  method_chain: __ne__
  method_chain_args: [0]
  expected: true

invariant re_extra236.compile.flags_multiline_bit:
  description: "re.compile('[a-z]+', 10).flags & 8 != 0 — MULTILINE(8) bit is set; verified Python 3.14.3 macOS"
  category: compile_flags
  kind: python_call_eq
  function: compile
  args: ["[a-z]+", 10]
  method: flags.__and__
  method_args: [8]
  method_chain: __ne__
  method_chain_args: [0]
  expected: true

invariant re_extra236.compile.flags_dotall_unset:
  description: "re.compile('[a-z]+', 10).flags & 16 == 0 — DOTALL(16) bit is not set; verified Python 3.14.3 macOS"
  category: compile_flags
  kind: python_call_eq
  function: compile
  args: ["[a-z]+", 10]
  method: flags.__and__
  method_args: [16]
  method_chain: __eq__
  method_chain_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# re.compile .pattern attribute — stores original pattern string
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra236.compile.pattern_attr:
  description: "re.compile('[a-z]+').pattern == '[a-z]+' — .pattern stores the original pattern string; verified Python 3.14.3 macOS"
  category: compile_flags
  kind: python_call_eq
  function: compile
  args: ["[a-z]+"]
  method: pattern.__eq__
  method_args: ["[a-z]+"]
  expected: true

# ---------------------------------------------------------------------------
# re.compile .groups attribute — number of capturing groups
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra236.compile.groups_zero:
  description: "re.compile('[a-z]+').groups == 0 — no capturing groups in plain character class pattern; verified Python 3.14.3 macOS"
  category: compile_flags
  kind: python_call_eq
  function: compile
  args: ["[a-z]+"]
  method: groups.__eq__
  method_args: [0]
  expected: true

invariant re_extra236.compile.groups_three:
  description: "re.compile('(a)(b)(c)').groups == 3 — three capturing groups; verified Python 3.14.3 macOS"
  category: compile_flags
  kind: python_call_eq
  function: compile
  args: ["(a)(b)(c)"]
  method: groups.__eq__
  method_args: [3]
  expected: true

invariant re_extra236.compile.groups_one:
  description: "re.compile('([a-z]+)').groups == 1 — one capturing group; verified Python 3.14.3 macOS"
  category: compile_flags
  kind: python_call_eq
  function: compile
  args: ["([a-z]+)"]
  method: groups.__eq__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# re.compile default flags — UNICODE bit (32) always set
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra236.compile.default_flags_unicode_bit:
  description: "re.compile('[a-z]+').flags & 32 != 0 — UNICODE(32) bit is set by default; verified Python 3.14.3 macOS"
  category: compile_flags
  kind: python_call_eq
  function: compile
  args: ["[a-z]+"]
  method: flags.__and__
  method_args: [32]
  method_chain: __ne__
  method_chain_args: [0]
  expected: true
