spec: shelve_extra5
version: ">=3.0"
backend: python_module(shelve)

docs: https://docs.python.org/3/library/shelve.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/shelve.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "shelve source: internal dbm backend implementation details"
  notes:
    - "This spec extends shelve.zspec.zsdl through shelve_extra4.zspec.zsdl."
    - "shelve.zspec.zsdl covers: open/__name__; class names table; class modules table; Shelf/__bases__[0]/__name__; DbfilenameShelf/__bases__[0]/__name__."
    - "shelve_extra.zspec.zsdl covers: Shelf/__name__/__module__; BsdDbShelf/__name__; DbfilenameShelf/__name__; open/__name__."
    - "shelve_extra2.zspec.zsdl covers: Shelf/__name__; BsdDbShelf/__name__; DbfilenameShelf/__name__; Shelf/__module__; Shelf.__bases__[0]; open/__name__/__module__."
    - "shelve_extra3.zspec.zsdl covers: BsdDbShelf/__module__; DbfilenameShelf/__module__; Shelf/__bases__/__len__; DbfilenameShelf/__bases__/__len__; open/__class__/__name__; class metatype table; BsdDbShelf/__bases__[0]/__name__."
    - "shelve_extra4.zspec.zsdl covers: __qualname__ for open, Shelf, BsdDbShelf, DbfilenameShelf."
    - "This spec adds: Shelf method name checks (keys, values, items, sync, close) — __name__ attribute of each method. No prior spec checks any Shelf method names."
    - "Shelf inherits dict-like iteration methods from MutableMapping; keys(), values(), and items() are defined on Shelf itself."
    - "Shelf.sync() flushes the persistent dict to disk; Shelf.close() calls sync() and closes the underlying dbm database."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Shelf method names — keys, values, items
# No prior shelve spec checks __name__ for any Shelf method.
# ---------------------------------------------------------------------------

table shelve_extra5.shelf_iteration_method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [keys,   Shelf.keys.__name__.__eq__,   ["keys"],   true]
    - [values, Shelf.values.__name__.__eq__, ["values"], true]
    - [items,  Shelf.items.__name__.__eq__,  ["items"],  true]

# ---------------------------------------------------------------------------
# Shelf lifecycle method names — sync and close
# No prior spec checks Shelf.sync or Shelf.close __name__.
# ---------------------------------------------------------------------------

invariant shelve_extra5.Shelf.sync_name:
  description: "shelve.Shelf.sync.__name__ == 'sync' — the method that flushes the shelf to disk"
  category: method_names
  kind: python_call_eq
  function: Shelf.sync.__name__.__eq__
  args: ["sync"]
  expected: true

invariant shelve_extra5.Shelf.close_name:
  description: "shelve.Shelf.close.__name__ == 'close' — the method that closes the underlying dbm file"
  category: method_names
  kind: python_call_eq
  function: Shelf.close.__name__.__eq__
  args: ["close"]
  expected: true

# ---------------------------------------------------------------------------
# Shelf.__dict__ is a mappingproxy
# No prior spec checks the type of the class __dict__ attribute.
# ---------------------------------------------------------------------------

invariant shelve_extra5.Shelf.dict_type:
  description: "shelve.Shelf.__dict__.__class__.__name__ == 'mappingproxy' — class namespace is a mappingproxy"
  category: classes
  kind: python_call_eq
  function: Shelf.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
