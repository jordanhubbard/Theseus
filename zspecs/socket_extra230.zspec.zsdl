spec: socket_extra230
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.socket.connect.__name__ == 'connect' — socket method name is 'connect' (7 characters)."
    - "socket.socket.bind.__name__ == 'bind' — socket method name is 'bind' (4 characters)."
    - "socket.socket.listen.__name__ == 'listen' — socket method name is 'listen' (6 characters)."
    - "socket.socket.send.__name__ == 'send' — socket method name is 'send' (4 characters)."
    - "socket.socket.recv.__name__ == 'recv' — socket method name is 'recv' (4 characters)."
    - "socket.socket.close.__name__ == 'close' — socket method name is 'close' (5 characters)."
    - "socket.socket.setsockopt.__name__ == 'setsockopt' — socket method name is 'setsockopt' (10 characters)."
    - "socket.socket.getsockopt.__name__ == 'getsockopt' — socket method name is 'getsockopt' (10 characters)."
    - "socket.socket.__name__ == 'socket' — the socket class name is 'socket' (6 characters)."
    - "socket.socket.__module__ == 'socket' — socket class module is 'socket' (the Python-level module)."
    - "socket.socket.connect.__qualname__ == 'socket.connect' — qualname includes socket class prefix."
    - "socket.socket.bind.__qualname__ == 'socket.bind' — qualname includes socket class prefix."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket method name contracts
#
# socket.socket.connect.__name__    == 'connect'
# socket.socket.bind.__name__       == 'bind'
# socket.socket.listen.__name__     == 'listen'
# socket.socket.send.__name__       == 'send'
# socket.socket.recv.__name__       == 'recv'
# socket.socket.close.__name__      == 'close'
# socket.socket.setsockopt.__name__ == 'setsockopt'
# socket.socket.getsockopt.__name__ == 'getsockopt'
#
# socket.socket is the primary socket class. connect() establishes a
# connection; bind() binds to an address; listen() marks as passive;
# send() transmits data; recv() receives data; close() releases the
# socket; setsockopt/getsockopt manage socket options.
# ---------------------------------------------------------------------------

table socket_extra230.socket_method_names:
  description: "socket.connect.__name__=='connect'; bind.__name__=='bind'; listen.__name__=='listen'; send.__name__=='send'; recv.__name__=='recv'; close.__name__=='close'; setsockopt.__name__=='setsockopt'; getsockopt.__name__=='getsockopt'; socket method name contracts; new to extra230"
  kind: python_call_eq
  category: identity
  id_prefix: socket230

  columns: [id, function, args, expected, description]
  rows:
    - [connect_name_eq,
       "socket.connect.__name__.__eq__",
       ["connect"],
       true,
       "socket.socket.connect.__name__.__eq__('connect') == True — connect establishes a connection to a remote address; __name__ is 'connect' (7 characters); new anchor in extra230 namespace; verified Python 3.14.3"]
    - [bind_name_eq,
       "socket.bind.__name__.__eq__",
       ["bind"],
       true,
       "socket.socket.bind.__name__.__eq__('bind') == True — bind assigns a local address to the socket; __name__ is 'bind' (4 characters); same length as send and recv; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [listen_name_eq,
       "socket.listen.__name__.__eq__",
       ["listen"],
       true,
       "socket.socket.listen.__name__.__eq__('listen') == True — listen marks the socket as passive for accepting connections; __name__ is 'listen' (6 characters); new anchor in extra230 namespace; verified Python 3.14.3"]
    - [send_name_eq,
       "socket.send.__name__.__eq__",
       ["send"],
       true,
       "socket.socket.send.__name__.__eq__('send') == True — send transmits data to a connected socket; __name__ is 'send' (4 characters); same length as bind and recv; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [recv_name_eq,
       "socket.recv.__name__.__eq__",
       ["recv"],
       true,
       "socket.socket.recv.__name__.__eq__('recv') == True — recv receives data from the socket; __name__ is 'recv' (4 characters); same length as bind and send; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [close_name_eq,
       "socket.close.__name__.__eq__",
       ["close"],
       true,
       "socket.socket.close.__name__.__eq__('close') == True — close releases the socket and its file descriptor; __name__ is 'close' (5 characters); new anchor in extra230 namespace; verified Python 3.14.3"]
    - [setsockopt_name_eq,
       "socket.setsockopt.__name__.__eq__",
       ["setsockopt"],
       true,
       "socket.socket.setsockopt.__name__.__eq__('setsockopt') == True — setsockopt sets a socket option value; __name__ is 'setsockopt' (10 characters); same length as getsockopt; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [getsockopt_name_eq,
       "socket.getsockopt.__name__.__eq__",
       ["getsockopt"],
       true,
       "socket.socket.getsockopt.__name__.__eq__('getsockopt') == True — getsockopt retrieves a socket option value; __name__ is 'getsockopt' (10 characters); same length as setsockopt; new anchor in extra230 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.socket class identity contracts
#
# socket.socket.__name__   == 'socket'
# socket.socket.__module__ == 'socket'
#
# The socket class is named 'socket' (lowercase, 6 characters). The module
# is also named 'socket'. The class is implemented in Lib/socket.py wrapping
# the _socket C extension type.
# ---------------------------------------------------------------------------

table socket_extra230.socket_class_identity:
  description: "socket.__name__=='socket'; socket.__module__=='socket'; socket class identity; new to extra230"
  kind: python_call_eq
  category: identity
  id_prefix: socket230a

  columns: [id, function, args, expected, description]
  rows:
    - [socket_class_name_eq,
       "socket.__name__.__eq__",
       ["socket"],
       true,
       "socket.socket.__name__.__eq__('socket') == True — the socket class is named 'socket' (6 characters); same name as the module; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [socket_class_module_eq,
       "socket.__module__.__eq__",
       ["socket"],
       true,
       "socket.socket.__module__.__eq__('socket') == True — socket class __module__ is 'socket' (the Python-level module); new anchor in extra230 namespace; verified Python 3.14.3"]
    - [socket_class_name_len_6,
       "socket.__name__.__len__",
       [],
       6,
       "socket.socket.__name__.__len__() == 6 — the string 'socket' has 6 characters; portable length anchor; new anchor in extra230 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.socket method name length contracts
#
# len('connect')    == 7
# len('setsockopt') == 10
# len('getsockopt') == 10
# len('listen')     == 6
# len('close')      == 5
#
# These length anchors verify correct method name string lengths.
# ---------------------------------------------------------------------------

table socket_extra230.socket_method_name_lengths:
  description: "connect len==7; setsockopt len==10; getsockopt len==10; listen len==6; close len==5; socket method name length contracts; new to extra230"
  kind: python_call_eq
  category: identity
  id_prefix: socket230b

  columns: [id, function, args, expected, description]
  rows:
    - [connect_name_len_7,
       "socket.connect.__name__.__len__",
       [],
       7,
       "socket.socket.connect.__name__.__len__() == 7 — the string 'connect' has 7 characters; portable length anchor; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [setsockopt_name_len_10,
       "socket.setsockopt.__name__.__len__",
       [],
       10,
       "socket.socket.setsockopt.__name__.__len__() == 10 — the string 'setsockopt' has 10 characters; same length as getsockopt; portable length anchor; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [getsockopt_name_len_10,
       "socket.getsockopt.__name__.__len__",
       [],
       10,
       "socket.socket.getsockopt.__name__.__len__() == 10 — the string 'getsockopt' has 10 characters; same length as setsockopt; portable length anchor; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [listen_name_len_6,
       "socket.listen.__name__.__len__",
       [],
       6,
       "socket.socket.listen.__name__.__len__() == 6 — the string 'listen' has 6 characters; portable length anchor; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [close_name_len_5,
       "socket.close.__name__.__len__",
       [],
       5,
       "socket.socket.close.__name__.__len__() == 5 — the string 'close' has 5 characters; portable length anchor; new anchor in extra230 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra230.connect_name_eq:
  description: "socket.socket.connect.__name__.__eq__('connect') == True — socket.connect establishes a connection to the address specified by the address argument; for TCP (SOCK_STREAM) sockets this initiates the TCP handshake; for UDP (SOCK_DGRAM) sockets it sets the default remote address; __name__ is 'connect' (7 characters); socket.socket.connect.__qualname__ is 'socket.connect'; extra230 is the first namespace to anchor socket.socket.connect.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "socket.connect.__name__.__eq__"
  args: ["connect"]
  expected: true

invariant socket_extra230.setsockopt_name_eq:
  description: "socket.socket.setsockopt.__name__.__eq__('setsockopt') == True — setsockopt sets the value of a socket option at the given level and optname; commonly used to set SO_REUSEADDR, SO_KEEPALIVE, TCP_NODELAY, etc.; __name__ is 'setsockopt' (10 characters); same length as getsockopt; extra230 is the first namespace to anchor socket.socket.setsockopt.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "socket.setsockopt.__name__.__eq__"
  args: ["setsockopt"]
  expected: true

invariant socket_extra230.socket_class_name_eq:
  description: "socket.socket.__name__.__eq__('socket') == True — the socket class has the same name as its module; __name__ is 'socket' (6 characters, all lowercase); socket.socket.__module__ is also 'socket'; the class is defined in Lib/socket.py and wraps the _socket C extension; extra230 is the first namespace to anchor socket.socket.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "socket.__name__.__eq__"
  args: ["socket"]
  expected: true
