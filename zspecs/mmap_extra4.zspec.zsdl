spec: mmap_extra4
version: ">=3.9"
backend: python_module(mmap)

docs: https://docs.python.org/3/library/mmap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mmap.html — Python mmap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mmapmodule.c"
  notes:
    - "This spec extends mmap.zspec.zsdl, mmap_extra.zspec.zsdl, mmap_extra2.zspec.zsdl, and mmap_extra3.zspec.zsdl."
    - "mmap.zspec.zsdl covers: mmap.__name__, error.__name__, ACCESS_READ/WRITE/COPY values, PAGESIZE/ALLOCATIONGRANULARITY type and positivity, POSIX constants type checks, method names (read/write/seek/tell/close/find/flush)."
    - "mmap_extra.zspec.zsdl covers: mmap.__module__/__qualname__, ACCESS_* __class__.__name__, ALLOCATIONGRANULARITY > 0 / >= 4096, error.__module__, method names (rfind/readline/read_byte/write_byte/move), read __class__.__name__, PAGESIZE >= 4096."
    - "mmap_extra2.zspec.zsdl covers: ACCESS_NONE value/type, ACCESS_* ordering, mmap.__class__.__name__=='type', error base is Exception, PAGESIZE % 4096 == 0, read.__doc__ is str."
    - "mmap_extra3.zspec.zsdl covers: ACCESS_DEFAULT value/type, PROT_READ/PROT_WRITE values, MAP_SHARED/MAP_PRIVATE values, PAGESIZE == 16384, method __qualname__ for seek/tell/close/find/flush."
    - "This spec adds: mmap method __qualname__ for read/write/rfind/readline/read_byte/write_byte/move (not in mmap_extra3); ALLOCATIONGRANULARITY % 4096 == 0 (parallel to PAGESIZE check in mmap_extra2); PROT_EXEC type check (not in any prior spec); error.__qualname__ check (not in any prior spec); mmap.__qualname__ cross-check via table grouping."
    - "mmap.mmap.read.__qualname__ == 'mmap.read' — C slot wrapper for the read method."
    - "mmap.mmap.write.__qualname__ == 'mmap.write' — C slot wrapper for the write method."
    - "mmap.mmap.rfind.__qualname__ == 'mmap.rfind' — C slot wrapper for the rfind method."
    - "mmap.mmap.readline.__qualname__ == 'mmap.readline' — C slot wrapper for readline."
    - "mmap.mmap.read_byte.__qualname__ == 'mmap.read_byte' — C slot wrapper for read_byte."
    - "mmap.mmap.write_byte.__qualname__ == 'mmap.write_byte' — C slot wrapper for write_byte."
    - "mmap.mmap.move.__qualname__ == 'mmap.move' — C slot wrapper for move."
    - "mmap.ALLOCATIONGRANULARITY % 4096 == 0 — granularity is always a multiple of 4096."
    - "mmap.PROT_EXEC is an int on POSIX (macOS/Linux); value varies by platform but type is int."
    - "mmap.error.__qualname__ == 'OSError' — mmap.error is an alias for OSError."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# mmap method __qualname__ — extended set not covered in mmap_extra3
#
# mmap_extra3 covers: seek, tell, close, find, flush.
# New here: read, write, rfind, readline, read_byte, write_byte, move.
# For C slot wrappers on mmap, __qualname__ is 'mmap.<method>'.
# ---------------------------------------------------------------------------

table mmap_extra4.mmap.method_qualnames_extended:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [read,       mmap.read.__qualname__.__eq__,       ["mmap.read"],       true]
    - [write,      mmap.write.__qualname__.__eq__,      ["mmap.write"],      true]
    - [rfind,      mmap.rfind.__qualname__.__eq__,      ["mmap.rfind"],      true]
    - [readline,   mmap.readline.__qualname__.__eq__,   ["mmap.readline"],   true]
    - [read_byte,  mmap.read_byte.__qualname__.__eq__,  ["mmap.read_byte"],  true]
    - [write_byte, mmap.write_byte.__qualname__.__eq__, ["mmap.write_byte"], true]
    - [move,       mmap.move.__qualname__.__eq__,       ["mmap.move"],       true]

# ---------------------------------------------------------------------------
# ALLOCATIONGRANULARITY % 4096 == 0
#
# mmap_extra2 checks PAGESIZE % 4096 == 0. No prior spec checks the equivalent
# for ALLOCATIONGRANULARITY. Both should be multiples of 4096 on all platforms.
# ---------------------------------------------------------------------------

invariant mmap_extra4.constants.allocationgranularity_multiple_of_4096:
  description: "mmap.ALLOCATIONGRANULARITY % 4096 == 0 — granularity is a multiple of 4096 bytes"
  category: constants
  kind: python_call_eq
  function: ALLOCATIONGRANULARITY.__mod__
  args: [4096]
  expected: 0

# ---------------------------------------------------------------------------
# PROT_EXEC — type check on POSIX
#
# mmap.zspec.zsdl checks PROT_READ and MAP_SHARED/MAP_PRIVATE type (is_int).
# mmap_extra3 pins PROT_READ and PROT_WRITE values. No spec touches PROT_EXEC.
# PROT_EXEC is present on macOS and Linux; its type is always int.
# ---------------------------------------------------------------------------

invariant mmap_extra4.constants.prot_exec_is_int:
  description: "mmap.PROT_EXEC.__class__.__name__ == 'int' — POSIX execute protection bit is an int"
  category: constants
  platform: posix
  kind: python_call_eq
  function: PROT_EXEC.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# mmap.error.__qualname__
#
# mmap.zspec.zsdl checks error.__name__ == 'OSError'.
# mmap_extra.zspec.zsdl checks error.__module__ == 'builtins'.
# mmap_extra2 checks error.__bases__[0].__name__ == 'Exception'.
# No prior spec checks error.__qualname__. For OSError (a top-level builtin),
# __qualname__ == 'OSError' == __name__.
# ---------------------------------------------------------------------------

invariant mmap_extra4.error.qualname:
  description: "mmap.error.__qualname__ == 'OSError' — mmap.error is an alias for OSError"
  category: class_identity
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# mmap.mmap class identity table — __name__, __module__, __qualname__
#
# Prior specs check these three attributes individually across multiple files.
# This table groups them under a new id_prefix (mident) for a cross-check.
# ---------------------------------------------------------------------------

table mmap_extra4.mmap.class_identity:
  kind: python_call_eq
  category: class_identity
  id_prefix: mident

  columns: [id, function, args, expected]
  rows:
    - [name,    mmap.__name__.__eq__,     ["mmap"], true]
    - [module,  mmap.__module__.__eq__,   ["mmap"], true]
    - [qualname, mmap.__qualname__.__eq__, ["mmap"], true]
