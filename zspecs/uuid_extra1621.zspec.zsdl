spec: uuid_extra1621
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __weakref__ and weak reference protocol"
    - "uuid.UUID is a pure Python class defined in Lib/uuid.py with __slots__ = ('int', 'is_safe', '__weakref__')"
    - "Because '__weakref__' is explicitly listed in __slots__, uuid.UUID.__dict__.__contains__('__weakref__') is True"
    - "The __weakref__ descriptor in UUID.__dict__ is a getset_descriptor (not member_descriptor)"
    - "The 'int' and 'is_safe' slots appear as member_descriptor in UUID.__dict__"
    - "uuid.UUID instances ARE weakly referenceable via the explicit __weakref__ slot"
    - "uuid.SafeUUID is an IntEnum subclass; enum metaclass does NOT add __weakref__ to SafeUUID.__dict__"
    - "uuid.UUID.__slots__ has exactly 3 entries: 'int', 'is_safe', '__weakref__'"
    - "uuid.UUID instances have no per-instance __dict__ because __slots__ suppresses it"
  created_at: "2026-04-12"
error_model: python_exceptions

table uuid_extra1621.uuid_has_weakref_slot:
  description: "uuid.UUID explicitly includes '__weakref__' in its __slots__; uuid.UUID.__dict__ therefore contains '__weakref__' as a getset_descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1621hw

  columns: [id, function, args, expected]
  rows:
    - ["uu1621hw001", "uuid.UUID.__dict__.__contains__",                    ["__weakref__"],  true]
    - ["uu1621hw002", "uuid.UUID.__dict__.__contains__",                    ["__slots__"],    true]
    - ["uu1621hw003", "uuid.UUID.__dict__.__contains__",                    ["__dict__"],     false]
    - ["uu1621hw004", "type(uuid.UUID.__dict__['__weakref__']).__name__.__eq__", ["getset_descriptor"], true]
    - ["uu1621hw005", "type(uuid.UUID.__dict__['__slots__']).__name__.__eq__",   ["tuple"],   true]
    - ["uu1621hw006", "uuid.UUID.__dict__.__contains__",                    ["int"],          true]
    - ["uu1621hw007", "uuid.UUID.__dict__.__contains__",                    ["is_safe"],      true]
    - ["uu1621hw008", "type(uuid.UUID.__dict__['int']).__name__.__eq__",    ["member_descriptor"],  true]
    - ["uu1621hw009", "type(uuid.UUID.__dict__['is_safe']).__name__.__eq__", ["member_descriptor"], true]
    - ["uu1621hw010", "uuid.UUID.__name__.__eq__",                          ["UUID"],         true]
    - ["uu1621hw011", "uuid.UUID.__module__.__eq__",                        ["uuid"],         true]
    - ["uu1621hw012", "uuid.UUID.__class__.__name__.__eq__",                ["type"],         true]
    - ["uu1621hw013", "uuid.UUID.__dict__.__class__.__name__.__eq__",       ["mappingproxy"], true]
    - ["uu1621hw014", "uuid.UUID.__dict__.__contains__",                    ["__init__"],     true]
    - ["uu1621hw015", "uuid.UUID.__dict__.__contains__",                    ["__repr__"],     true]
    - ["uu1621hw016", "uuid.UUID.__dict__.__contains__",                    ["__str__"],      true]
    - ["uu1621hw017", "uuid.UUID.__dict__.__contains__",                    ["__hash__"],     true]
    - ["uu1621hw018", "uuid.UUID.__dict__.__contains__",                    ["__eq__"],       true]
    - ["uu1621hw019", "uuid.UUID.__dict__.__contains__",                    ["hex"],          true]
    - ["uu1621hw020", "uuid.UUID.__dict__.__contains__",                    ["bytes"],        true]
    - ["uu1621hw021", "uuid.UUID.__dict__.__contains__",                    ["fields"],       true]
    - ["uu1621hw022", "uuid.UUID.__dict__.__contains__",                    ["version"],      true]
    - ["uu1621hw023", "uuid.UUID.__dict__.__contains__",                    ["__setattr__"],  true]
    - ["uu1621hw024", "uuid.UUID.__dict__.__contains__",                    ["__int__"],      true]
    - ["uu1621hw025", "uuid.UUID.__dict__.__contains__",                    ["__lt__"],       true]

table uuid_extra1621.uuid_slots_content:
  description: "uuid.UUID.__slots__ contains exactly 'int', 'is_safe', '__weakref__'; len is 3; no other entries"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1621sc

  columns: [id, function, args, expected]
  rows:
    - ["uu1621sc001", "uuid.UUID.__slots__.__contains__",    ["int"],          true]
    - ["uu1621sc002", "uuid.UUID.__slots__.__contains__",    ["is_safe"],      true]
    - ["uu1621sc003", "uuid.UUID.__slots__.__contains__",    ["__weakref__"],  true]
    - ["uu1621sc004", "uuid.UUID.__slots__.__len__",         [],               3]
    - ["uu1621sc005", "len(uuid.UUID.__slots__).__eq__",     [3],              true]
    - ["uu1621sc006", "uuid.UUID.__slots__.__contains__",    ["__dict__"],     false]
    - ["uu1621sc007", "uuid.UUID.__slots__.__contains__",    ["hex"],          false]
    - ["uu1621sc008", "uuid.UUID.__slots__.__contains__",    ["bytes"],        false]
    - ["uu1621sc009", "uuid.UUID.__slots__.__contains__",    ["version"],      false]
    - ["uu1621sc010", "type(uuid.UUID.__dict__['int']).__name__.__eq__",       ["member_descriptor"],  true]
    - ["uu1621sc011", "type(uuid.UUID.__dict__['is_safe']).__name__.__eq__",   ["member_descriptor"],  true]
    - ["uu1621sc012", "type(uuid.UUID.__dict__['__weakref__']).__name__.__eq__", ["getset_descriptor"], true]
    - ["uu1621sc013", "uuid.UUID.__dict__.__contains__",     ["__weakref__"],  true]
    - ["uu1621sc014", "uuid.UUID.__dict__.__contains__",     ["int"],          true]
    - ["uu1621sc015", "uuid.UUID.__dict__.__contains__",     ["is_safe"],      true]
    - ["uu1621sc016", "uuid.UUID.__bases__.__len__",         [],               1]
    - ["uu1621sc017", "uuid.UUID.__dict__.__contains__",     ["hex"],          true]
    - ["uu1621sc018", "type(uuid.UUID.__dict__['hex']).__name__.__eq__",       ["property"],  true]
    - ["uu1621sc019", "type(uuid.UUID.__dict__['bytes']).__name__.__eq__",     ["property"],  true]
    - ["uu1621sc020", "type(uuid.UUID.__dict__['version']).__name__.__eq__",   ["property"],  true]
    - ["uu1621sc021", "type(uuid.UUID.__dict__['fields']).__name__.__eq__",    ["property"],  true]
    - ["uu1621sc022", "uuid.SafeUUID.__dict__.__contains__", ["__weakref__"],  false]
    - ["uu1621sc023", "uuid.SafeUUID.__dict__.__contains__", ["__slots__"],    false]
    - ["uu1621sc024", "uuid.SafeUUID.__name__.__eq__",       ["SafeUUID"],     true]
    - ["uu1621sc025", "uuid.SafeUUID.__module__.__eq__",     ["uuid"],         true]

table uuid_extra1621.uuid_weakref_works:
  description: "uuid.UUID instances are weakly referenceable via the __weakref__ slot; verify structural properties that enable this"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1621ww

  columns: [id, function, args, expected]
  rows:
    - ["uu1621ww001", "uuid.UUID.__dict__.__contains__",                    ["__weakref__"],  true]
    - ["uu1621ww002", "uuid.UUID.__dict__.__contains__",                    ["__dict__"],     false]
    - ["uu1621ww003", "uuid.UUID.__slots__.__contains__",                   ["__weakref__"],  true]
    - ["uu1621ww004", "type(uuid.UUID.__dict__['__weakref__']).__name__.__eq__", ["getset_descriptor"], true]
    - ["uu1621ww005", "uuid.UUID.__dict__.__contains__",                    ["__slots__"],    true]
    - ["uu1621ww006", "uuid.UUID.__slots__.__contains__",                   ["int"],          true]
    - ["uu1621ww007", "uuid.UUID.__slots__.__contains__",                   ["is_safe"],      true]
    - ["uu1621ww008", "len(uuid.UUID.__slots__).__eq__",                    [3],              true]
    - ["uu1621ww009", "uuid.UUID.__dict__.__contains__",                    ["int"],          true]
    - ["uu1621ww010", "uuid.UUID.__dict__.__contains__",                    ["is_safe"],      true]
    - ["uu1621ww011", "uuid.UUID.__name__.__eq__",                          ["UUID"],         true]
    - ["uu1621ww012", "uuid.UUID.__module__.__eq__",                        ["uuid"],         true]
    - ["uu1621ww013", "uuid.UUID.__dict__.__contains__",                    ["__init__"],     true]
    - ["uu1621ww014", "uuid.UUID.__dict__.__contains__",                    ["__setattr__"],  true]
    - ["uu1621ww015", "uuid.UUID.__dict__.__contains__",                    ["__hash__"],     true]
    - ["uu1621ww016", "uuid.UUID.__dict__.__contains__",                    ["__eq__"],       true]
    - ["uu1621ww017", "uuid.UUID.__dict__.__contains__",                    ["__repr__"],     true]
    - ["uu1621ww018", "uuid.UUID.__dict__.__contains__",                    ["node"],         true]
    - ["uu1621ww019", "type(uuid.UUID.__dict__['node']).__name__.__eq__",   ["property"],     true]
    - ["uu1621ww020", "uuid.UUID.__dict__.__contains__",                    ["urn"],          true]
    - ["uu1621ww021", "type(uuid.UUID.__dict__['urn']).__name__.__eq__",    ["property"],     true]
    - ["uu1621ww022", "uuid.UUID.__dict__.__contains__",                    ["variant"],      true]
    - ["uu1621ww023", "type(uuid.UUID.__dict__['variant']).__name__.__eq__", ["property"],   true]
    - ["uu1621ww024", "uuid.UUID.__dict__.__contains__",                    ["time_low"],     true]
    - ["uu1621ww025", "type(uuid.UUID.__dict__['time_low']).__name__.__eq__", ["property"],  true]
