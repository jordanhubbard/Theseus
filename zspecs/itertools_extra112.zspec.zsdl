spec: itertools_extra112
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra111.zspec.zsdl."
    - "This spec covers: itertools module __name__/__package__/__spec__ attrs, and itertools.chain.from_iterable type and qualname; wave 263."
    - "itertools.__name__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.__package__ == '' (empty string). Verified with Python 3.14.3."
    - "type(itertools.__name__).__name__ == 'str'. Verified with Python 3.14.3."
    - "itertools.__spec__.__class__.__name__ == 'ModuleSpec'. Verified with Python 3.14.3."
    - "itertools.__spec__.name == 'itertools'. Verified with Python 3.14.3."
    - "itertools.__spec__.has_location == False — itertools is a built-in C extension module. Verified with Python 3.14.3."
    - "len(itertools.__name__) == 9. Verified with Python 3.14.3."
    - "len(itertools.__package__) == 0 (empty string). Verified with Python 3.14.3."
    - "itertools.__loader__.__class__.__name__ == 'type' — built-in module loader. Verified with Python 3.14.3."
    - "type(itertools.__spec__).__name__ == 'ModuleSpec'. Verified with Python 3.14.3."
    - "type(itertools.chain.from_iterable).__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'. Verified with Python 3.14.3."
    - "len(itertools.chain.from_iterable.__qualname__) == 19. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools module identity attributes — __name__, __package__, __spec__
#
# Wave 263 theme: itertools is a built-in C extension module (Modules/itertoolsmodule.c).
# Unlike pure-Python modules, it has has_location == False (no .py source file
# on disk in the standard path sense). Its __name__ is 'itertools' (9 chars).
# Its __package__ is '' (empty string) since it is a top-level module.
# __spec__.__class__.__name__ is 'ModuleSpec'. __spec__.has_location is False
# because itertools is compiled into the interpreter, not loaded from a file.
# __loader__.__class__.__name__ is 'type' (the built-in module loader).
#
# itertools.__name__ == 'itertools'
# len(itertools.__name__) == 9
# itertools.__package__ == ''
# len(itertools.__package__) == 0
# type(itertools.__name__).__name__ == 'str'
# itertools.__spec__.__class__.__name__ == 'ModuleSpec'
# itertools.__spec__.name == 'itertools'
# itertools.__spec__.has_location == False
#
# New to extra112.
# ---------------------------------------------------------------------------

table itertools_extra112.module_identity:
  description: "itertools module identity: __name__='itertools'(9), __package__=''(0), type str; __spec__ is ModuleSpec; has_location=False (built-in C extension); wave 263; new to extra112"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsmi112

  columns: [id, function, args, expected, description]
  rows:
    - [itertools_name_eq,
       "__name__.__eq__",
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — itertools is a top-level built-in C extension module (Modules/itertoolsmodule.c); its __name__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra112"]
    - [itertools_name_len_9,
       "__name__.__len__",
       [],
       9,
       "itertools.__name__.__len__() == 9 — 'itertools' has 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; int.__eq__(9) returns True; new to extra112"]
    - [itertools_package_empty,
       "__package__.__eq__",
       [""],
       true,
       "itertools.__package__.__eq__('') == True — itertools is a top-level module (not inside a package); its __package__ attribute is the empty string ''; str.__eq__('') returns True; new to extra112"]
    - [itertools_package_len_0,
       "__package__.__len__",
       [],
       0,
       "itertools.__package__.__len__() == 0 — itertools.__package__ is '' (empty string); len('') == 0; str.__len__() returns 0; int.__eq__(0) returns True; new to extra112"]
    - [itertools_name_type_str,
       "__name__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.__name__.__class__.__name__.__eq__('str') == True — itertools.__name__ is a plain Python string; type(itertools.__name__).__name__ is 'str'; str.__eq__('str') returns True; new to extra112"]
    - [itertools_spec_class_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — itertools.__spec__ is an instance of importlib.machinery.ModuleSpec; even for built-in C extension modules, the import system creates a ModuleSpec; str.__eq__('ModuleSpec') returns True; new to extra112"]
    - [itertools_spec_name_eq,
       "__spec__.name.__eq__",
       ["itertools"],
       true,
       "itertools.__spec__.name.__eq__('itertools') == True — the ModuleSpec for itertools has its .name attribute set to 'itertools'; str.__eq__('itertools') returns True; new to extra112"]
    - [itertools_spec_has_location_false,
       "__spec__.has_location.__eq__",
       [false],
       true,
       "itertools.__spec__.has_location.__eq__(False) == True — itertools is a built-in C extension module compiled into the interpreter; it has no separate file location on disk in the usual sense; ModuleSpec.has_location is False; bool.__eq__(False) returns True; new to extra112"]

# ---------------------------------------------------------------------------
# Table 2: itertools.chain.from_iterable type and qualname
#
# Wave 263 theme: itertools.chain.from_iterable is a class method of the
# itertools.chain C-extension type. Accessed from Python, it is a
# 'builtin_function_or_method' (not a classmethod descriptor or plain function).
# Its __qualname__ is 'chain.from_iterable' (len 19): 'chain' (5) + '.' (1)
# + 'from_iterable' (13) = 19. This is the alternative chain() constructor
# that takes a single iterable of iterables and chains them together.
#
# type(itertools.chain.from_iterable).__name__ == 'builtin_function_or_method'
# itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'
# len(itertools.chain.from_iterable.__qualname__) == 19
#
# New to extra112.
# ---------------------------------------------------------------------------

table itertools_extra112.chain_from_iterable:
  description: "itertools.chain.from_iterable: type 'builtin_function_or_method'; qualname 'chain.from_iterable'(19); C class method alternative constructor; wave 263; new to extra112"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertoolscfi112

  columns: [id, function, args, expected, description]
  rows:
    - [chain_from_iterable_type_builtin,
       "chain.from_iterable.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.chain.from_iterable.__class__.__name__.__eq__('builtin_function_or_method') == True — itertools.chain is a C-extension type; its from_iterable class method is exposed as a 'builtin_function_or_method' when accessed from Python; this is the type name for C-level methods accessed on a type or instance; str.__eq__('builtin_function_or_method') returns True; new to extra112"]
    - [chain_from_iterable_qualname_eq,
       "chain.from_iterable.__qualname__.__eq__",
       ["chain.from_iterable"],
       true,
       "itertools.chain.from_iterable.__qualname__.__eq__('chain.from_iterable') == True — itertools.chain.from_iterable is a C class method defined on the chain type; its __qualname__ follows the dotted 'chain.from_iterable' pattern; str.__eq__('chain.from_iterable') returns True; new to extra112"]
    - [chain_from_iterable_qualname_len_19,
       "chain.from_iterable.__qualname__.__len__",
       [],
       19,
       "itertools.chain.from_iterable.__qualname__.__len__() == 19 — 'chain.from_iterable' has 19 characters: c-h-a-i-n-.-f-r-o-m-_-i-t-e-r-a-b-l-e; str.__len__() returns 19; int.__eq__(19) returns True; new to extra112"]
    - [chain_from_iterable_type_vs_chain_type,
       "chain.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.chain.__class__.__name__.__eq__('type') == True — itertools.chain is a C-extension type (not an instance); type(itertools.chain).__name__ is 'type'; this contrasts with itertools.chain.from_iterable which is a 'builtin_function_or_method'; str.__eq__('type') returns True; new to extra112"]
    - [chain_iter_type_wrapper_contrast,
       "chain.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.chain.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.chain's tp_iter slot is a 'wrapper_descriptor' (slot wrapper on the type), contrasting with from_iterable which is a 'builtin_function_or_method' (C class method); both are C-level but exposed differently; str.__eq__('wrapper_descriptor') returns True; new to extra112"]

# ---------------------------------------------------------------------------
# Table 3: itertools module loader and spec type cross-checks
#
# Wave 263 theme: Because itertools is a built-in C extension module, its loader
# is the built-in module importer. itertools.__loader__.__class__.__name__ == 'type'
# (the loader for built-in modules is the BuiltinImporter, which is a class
# itself, hence type). type(itertools.__spec__).__name__ == 'ModuleSpec'
# (the spec wrapper type). The contrast with functools (which IS file-based,
# has_location=True) is instructive. Both modules have __package__ == '' and
# __name__ of length 9.
#
# itertools.__loader__.__class__.__name__ == 'type'
# type(itertools.__spec__).__name__ == 'ModuleSpec'
# len(itertools.__name__) == len(functools.__name__) == 9 (same length)
#
# New to extra112.
# ---------------------------------------------------------------------------

table itertools_extra112.loader_and_spec_type:
  description: "itertools loader and spec: __loader__.__class__.__name__='type' (BuiltinImporter); type(__spec__).__name__='ModuleSpec'; built-in vs file-based contrast; wave 263; new to extra112"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertoolslst112

  columns: [id, function, args, expected, description]
  rows:
    - [itertools_loader_class_type,
       "__loader__.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.__loader__.__class__.__name__.__eq__('type') == True — itertools is a built-in C extension module; its __loader__ is the BuiltinImporter (importlib._bootstrap.BuiltinImporter), which is a class (a 'type'); type(itertools.__loader__).__name__ is 'type'; str.__eq__('type') returns True; new to extra112"]
    - [itertools_spec_type_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — itertools.__spec__ is an instance of importlib.machinery.ModuleSpec; type(itertools.__spec__).__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra112"]
    - [itertools_name_same_len_as_functools,
       "__name__.__len__",
       [],
       9,
       "itertools.__name__.__len__() == 9 — 'itertools' has 9 characters, the same length as 'functools' (9); both are 9-character module names; str.__len__() returns 9; int.__eq__(9) returns True; new to extra112"]
    - [itertools_package_same_as_functools,
       "__package__.__len__",
       [],
       0,
       "itertools.__package__.__len__() == 0 — itertools.__package__ is '' (length 0); like functools, itertools is a top-level module with empty __package__; the key difference is itertools is built-in (has_location=False) while functools is file-based (has_location=True); str.__len__() returns 0; int.__eq__(0) returns True; new to extra112"]
    - [itertools_spec_name_9_chars,
       "__spec__.name.__len__",
       [],
       9,
       "itertools.__spec__.name.__len__() == 9 — itertools.__spec__.name is 'itertools' (9 characters); the ModuleSpec name matches __name__; str.__len__() returns 9; int.__eq__(9) returns True; new to extra112"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra112
# ---------------------------------------------------------------------------

invariant itertools_extra112.module_name_len:
  description: "len(itertools.__name__) == 9 — 'itertools' is 9 characters; same length as 'functools'; built-in C extension module identity; wave 263; new to extra112"
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 9

invariant itertools_extra112.module_package_empty:
  description: "itertools.__package__ == '' — empty string; itertools is a top-level built-in module not inside any package; wave 263; new to extra112"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant itertools_extra112.spec_has_location_false:
  description: "itertools.__spec__.has_location == False — built-in C extension module; no file location on disk; contrasts with functools (has_location=True); wave 263; new to extra112"
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [false]
  expected: true

invariant itertools_extra112.chain_from_iterable_qualname:
  description: "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — C class method alternative constructor; dotted qualname; len 19; wave 263; new to extra112"
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__eq__
  args: ["chain.from_iterable"]
  expected: true

invariant itertools_extra112.chain_from_iterable_type:
  description: "type(itertools.chain.from_iterable).__name__ == 'builtin_function_or_method' — C class method; contrasts with __iter__/__next__ which are 'wrapper_descriptor'; wave 263; new to extra112"
  kind: python_call_eq
  function: chain.from_iterable.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

