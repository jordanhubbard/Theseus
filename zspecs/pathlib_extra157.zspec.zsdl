spec: pathlib_extra157
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.__dict__.__len__()==154 and pathlib.__dict__.__class__.__name__=='dict'. Also pathlib.Path.__dict__.__len__()==62 vs pathlib.PurePath.__dict__.__len__()==61 — these are close in size (differ by only 1). Subclass dict sizes: PosixPath.__dict__.__len__()==5, WindowsPath.__dict__.__len__()==6, PurePosixPath.__dict__.__len__()==6, PureWindowsPath.__dict__.__len__()==6."
    - "pathlib.__dict__.__len__() == 154 is large because pathlib re-exports many errno constants (EACCES, ENOENT, EPERM, etc.), os module members, and internal helpers from submodules."
    - "Path.__dict__.__len__() == 62 (vs PurePath 61). Path adds one entry over PurePath: the from_uri classmethod (and has 'info' as a filesystem attribute). The closeness in size (62 vs 61) reflects how Path extends PurePath minimally in its own __dict__ — most filesystem methods are defined in Path.__dict__ directly."
    - "PosixPath.__dict__.__len__() == 5 (only dunder methods: __doc__, __firstlineno__, __module__, __slots__, __static_attributes__). PosixPath adds no new public methods over Path — it relies entirely on Path and PurePosixPath inheritance."
    - "WindowsPath.__dict__.__len__() == 6 (adds __new__ over PosixPath's 5). WindowsPath overrides __new__ to raise NotImplementedError on non-Windows systems."
    - "Path.__bases__ == ['PurePath']; PosixPath.__bases__ == ['Path', 'PurePosixPath']; WindowsPath.__bases__ == ['Path', 'PureWindowsPath']. The PosixPath/WindowsPath use multiple inheritance to combine Path (filesystem) with PurePosixPath/PureWindowsPath (OS-specific pure path behavior)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib module __dict__ size
# pathlib.__dict__.__len__() == 154 (already covered in pathlib_extra156).
# This spec focuses on class __dict__ sizes: Path=62, PurePath=61,
# PosixPath=5, WindowsPath=6, PurePosixPath=6, PureWindowsPath=6.
# ---------------------------------------------------------------------------

table pathlib_extra157.class_dict_sizes:
  description: "pathlib class __dict__ sizes: Path=62, PurePath=61 (differ by 1); PosixPath=5, WindowsPath=6, PurePosixPath=6, PureWindowsPath=6 (subclasses are small — most logic is in Path/PurePath)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibsizes157

  columns: [id, function, args, expected, description]
  rows:
    - [path_dict_len,          Path.__dict__.__len__,          [], 62, "pathlib.Path.__dict__.__len__() == 62 (Path defines 62 entries in its own __dict__; includes all filesystem methods: stat, open, read_text, write_text, mkdir, exists, glob, iterdir, rename, unlink, cwd, home, absolute, touch, rmdir, walk, rglob, resolve, chmod, symlink_to, hardlink_to, samefile, etc.)"]
    - [purepath_dict_len,      PurePath.__dict__.__len__,      [], 61, "pathlib.PurePath.__dict__.__len__() == 61 (PurePath defines 61 entries in its own __dict__; includes all pure path manipulation: parts, parent, parents, name, suffix, suffixes, stem, drive, root, anchor, joinpath, with_name, with_suffix, with_stem, with_segments, match, full_match, is_absolute, is_relative_to, relative_to, as_posix, as_uri, and internal helpers)"]
    - [posixpath_dict_len,     PosixPath.__dict__.__len__,     [],  5, "pathlib.PosixPath.__dict__.__len__() == 5 (PosixPath defines only 5 entries: __doc__, __firstlineno__, __module__, __slots__, __static_attributes__; it adds no new public methods — all filesystem behavior comes from Path, all POSIX path behavior from PurePosixPath via multiple inheritance)"]
    - [winpath_dict_len,       WindowsPath.__dict__.__len__,   [],  6, "pathlib.WindowsPath.__dict__.__len__() == 6 (WindowsPath defines 6 entries: the same 5 as PosixPath plus __new__; it overrides __new__ to raise NotImplementedError when instantiated on non-Windows systems)"]
    - [pureposix_dict_len,     PurePosixPath.__dict__.__len__, [],  6, "pathlib.PurePosixPath.__dict__.__len__() == 6 (PurePosixPath defines 6 entries: __doc__, __firstlineno__, __module__, __slots__, __static_attributes__, and parser; the parser attribute distinguishes POSIX parsing behavior from Windows)"]
    - [purewin_dict_len,       PureWindowsPath.__dict__.__len__,[], 6, "pathlib.PureWindowsPath.__dict__.__len__() == 6 (PureWindowsPath defines 6 entries: the same structure as PurePosixPath — __doc__, __firstlineno__, __module__, __slots__, __static_attributes__, and parser; parser implements Windows-specific path parsing with backslash and drive letter support)"]

# ---------------------------------------------------------------------------
# pathlib class inheritance bases
# Path.__bases__ == [PurePath]
# PosixPath.__bases__ == [Path, PurePosixPath]
# WindowsPath.__bases__ == [Path, PureWindowsPath]
# PurePosixPath.__bases__ == [PurePath]
# PureWindowsPath.__bases__ == [PurePath]
# ---------------------------------------------------------------------------

table pathlib_extra157.class_inheritance:
  description: "pathlib class inheritance: Path bases PurePath; PosixPath bases Path+PurePosixPath (MI); WindowsPath bases Path+PureWindowsPath (MI); PurePosixPath/PureWindowsPath base PurePath"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibsizes157

  columns: [id, function, args, expected, description]
  rows:
    - [path_base0_eq,       "Path.__bases__[0].__name__.__eq__",           ["PurePath"],       true, "pathlib.Path.__bases__[0].__name__ == 'PurePath' (Path's single direct base is PurePath; Path inherits all pure path manipulation from PurePath and adds filesystem operations)"]
    - [posixpath_base0_eq,  "PosixPath.__bases__[0].__name__.__eq__",      ["Path"],           true, "pathlib.PosixPath.__bases__[0].__name__ == 'Path' (PosixPath uses multiple inheritance; Path is the first base (filesystem ops), PurePosixPath is the second base (POSIX path parsing))"]
    - [posixpath_base1_eq,  "PosixPath.__bases__[1].__name__.__eq__",      ["PurePosixPath"],  true, "pathlib.PosixPath.__bases__[1].__name__ == 'PurePosixPath' (PosixPath's second base; provides POSIX-specific path string parsing with forward slash separator)"]
    - [winpath_base0_eq,    "WindowsPath.__bases__[0].__name__.__eq__",    ["Path"],           true, "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' (WindowsPath uses multiple inheritance; Path is first base for filesystem ops)"]
    - [winpath_base1_eq,    "WindowsPath.__bases__[1].__name__.__eq__",    ["PureWindowsPath"],true, "pathlib.WindowsPath.__bases__[1].__name__ == 'PureWindowsPath' (WindowsPath's second base; provides Windows-specific path parsing with backslash and drive letter support)"]
    - [pureposix_base0_eq,  "PurePosixPath.__bases__[0].__name__.__eq__",  ["PurePath"],       true, "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' (PurePosixPath's single direct base is PurePath; it specializes PurePath with POSIX case-sensitivity and separator rules)"]
    - [purewin_base0_eq,    "PureWindowsPath.__bases__[0].__name__.__eq__",["PurePath"],       true, "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' (PureWindowsPath's single direct base is PurePath; it specializes PurePath with Windows drive letters, UNC paths, and case-insensitive comparison)"]

# ---------------------------------------------------------------------------
# pathlib.Path method qualnames
# Path prefix = 5 chars ('Path.')
# Shortest: cwd/copy/glob/home/move/open/stat/walk (8-9)
# Longest: is_block_device (20)
# ---------------------------------------------------------------------------

table pathlib_extra157.Path_method_qualnames:
  description: "pathlib.Path method __qualname__ lengths: cwd/copy/glob/home/move/open/stat/walk=8-9; is_dir/is_file/lchmod/rename/unlink=10-11; is_block_device=20 (longest)"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibsizes157

  columns: [id, function, args, expected, description]
  rows:
    - [cwd_qeq,             Path.cwd.__qualname__.__eq__,             ["Path.cwd"],             true, "pathlib.Path.cwd.__qualname__ == 'Path.cwd' (len=8; 'Path.' (5) + 'cwd' (3) = 8; cwd is a classmethod returning the current working directory; one of the shortest Path method qualnames)"]
    - [cwd_qlen,            Path.cwd.__qualname__.__len__,            [],                        8,   "pathlib.Path.cwd.__qualname__.__len__() == 8 ('Path.cwd' has 8 characters; tied with home, copy, glob, move, open, stat, walk as one of the shortest Path method qualnames)"]
    - [stat_qeq,            Path.stat.__qualname__.__eq__,            ["Path.stat"],             true, "pathlib.Path.stat.__qualname__ == 'Path.stat' (len=9; 'Path.' (5) + 'stat' (4) = 9; stat() returns an os.stat_result with metadata; tied with copy, glob, home, move, open, walk)"]
    - [is_dir_qeq,          Path.is_dir.__qualname__.__eq__,          ["Path.is_dir"],           true, "pathlib.Path.is_dir.__qualname__ == 'Path.is_dir' (len=11; 'Path.' (5) + 'is_dir' (6) = 11; is_dir returns True if the path is a directory, following symlinks)"]
    - [is_dir_qlen,         Path.is_dir.__qualname__.__len__,         [],                        11,   "pathlib.Path.is_dir.__qualname__.__len__() == 11 ('Path.is_dir' has 11 characters; tied with is_file, lchmod, rename, unlink at 11)"]
    - [is_block_device_qeq, Path.is_block_device.__qualname__.__eq__, ["Path.is_block_device"], true, "pathlib.Path.is_block_device.__qualname__ == 'Path.is_block_device' (len=20; 'Path.' (5) + 'is_block_device' (15) = 20; the longest Path method qualname; is_block_device checks if the path is a block special device file)"]
    - [is_block_device_qlen,Path.is_block_device.__qualname__.__len__,[],                        20,   "pathlib.Path.is_block_device.__qualname__.__len__() == 20 ('Path.is_block_device' has 20 characters; the longest Path method qualname — longer than is_char_device (19), is_junction/hardlink_to (16), is_symlink/expanduser (15))"]

# ---------------------------------------------------------------------------
# pathlib.PurePath method qualnames
# PurePath prefix = 9 chars ('PurePath.')
# Shortest: match (14); longest: is_relative_to (23)
# ---------------------------------------------------------------------------

table pathlib_extra157.PurePath_method_qualnames:
  description: "pathlib.PurePath method __qualname__ lengths: match=14, as_uri/as_posix/joinpath=15-17, is_absolute/is_reserved/relative_to/with_suffix=20, with_segments=22, is_relative_to=23 (longest)"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibsizes157

  columns: [id, function, args, expected, description]
  rows:
    - [match_qeq,           PurePath.match.__qualname__.__eq__,           ["PurePath.match"],           true, "pathlib.PurePath.match.__qualname__ == 'PurePath.match' (len=14; 'PurePath.' (9) + 'match' (5) = 14; the shortest PurePath method qualname; match tests if the path matches a glob-style pattern)"]
    - [match_qlen,          PurePath.match.__qualname__.__len__,          [],                           14,   "pathlib.PurePath.match.__qualname__.__len__() == 14 ('PurePath.match' has 14 characters; the shortest PurePath method qualname)"]
    - [as_uri_qeq,          PurePath.as_uri.__qualname__.__eq__,          ["PurePath.as_uri"],          true, "pathlib.PurePath.as_uri.__qualname__ == 'PurePath.as_uri' (len=15; 'PurePath.' (9) + 'as_uri' (6) = 15)"]
    - [joinpath_qeq,        PurePath.joinpath.__qualname__.__eq__,        ["PurePath.joinpath"],        true, "pathlib.PurePath.joinpath.__qualname__ == 'PurePath.joinpath' (len=17; 'PurePath.' (9) + 'joinpath' (8) = 17; tied with as_posix at 17)"]
    - [is_relative_to_qeq,  PurePath.is_relative_to.__qualname__.__eq__,  ["PurePath.is_relative_to"],  true, "pathlib.PurePath.is_relative_to.__qualname__ == 'PurePath.is_relative_to' (len=23; 'PurePath.' (9) + 'is_relative_to' (14) = 23; the longest PurePath method qualname; is_relative_to tests if the path is relative to the other path)"]
    - [is_relative_to_qlen, PurePath.is_relative_to.__qualname__.__len__, [],                           23,   "pathlib.PurePath.is_relative_to.__qualname__.__len__() == 23 ('PurePath.is_relative_to' has 23 characters; the longest PurePath method qualname, one character longer than with_segments (22))"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra157.Path.dict_len_62:
  description: "pathlib.Path.__dict__.__len__() == 62 — Path defines 62 entries in its __dict__; this is 1 more than PurePath (61); the close size reflects that Path is a relatively thin layer over PurePath in terms of __dict__ entries, adding filesystem-access methods (stat, open, glob, mkdir, etc.) while inheriting all pure path logic from PurePath"
  category: identity
  kind: python_call_eq
  function: Path.__dict__.__len__
  args: []
  expected: 62

invariant pathlib_extra157.PurePath.dict_len_61:
  description: "pathlib.PurePath.__dict__.__len__() == 61 — PurePath defines 61 entries in its __dict__; this is 1 fewer than Path (62); PurePath holds all the core path parsing and manipulation logic (parts, parent, name, suffix, joinpath, with_name, etc.) plus many internal helpers (_parse_path, _format_parsed_parts, etc.); the 61 vs 62 split shows Path is nearly as implementation-rich as PurePath in its own __dict__"
  category: identity
  kind: python_call_eq
  function: PurePath.__dict__.__len__
  args: []
  expected: 61

invariant pathlib_extra157.PosixPath.dict_len_5:
  description: "pathlib.PosixPath.__dict__.__len__() == 5 — PosixPath defines only 5 entries (all dunders: __doc__, __firstlineno__, __module__, __slots__, __static_attributes__); it adds no new public methods beyond what it inherits from Path and PurePosixPath via multiple inheritance; PosixPath is essentially a marker class that combines Path's filesystem methods with PurePosixPath's POSIX path parsing"
  category: identity
  kind: python_call_eq
  function: PosixPath.__dict__.__len__
  args: []
  expected: 5

invariant pathlib_extra157.WindowsPath.dict_len_6:
  description: "pathlib.WindowsPath.__dict__.__len__() == 6 — WindowsPath defines 6 entries (5 dunders plus __new__); it overrides __new__ to raise NotImplementedError('cannot instantiate WindowsPath on a non-Windows system') when used on POSIX systems; this is 1 more than PosixPath (5) because PosixPath does not override __new__"
  category: identity
  kind: python_call_eq
  function: WindowsPath.__dict__.__len__
  args: []
  expected: 6

invariant pathlib_extra157.Path.is_block_device_qualname_len_20:
  description: "pathlib.Path.is_block_device.__qualname__.__len__() == 20 ('Path.is_block_device' has 20 characters; 'Path.' (5) + 'is_block_device' (15) = 20; the longest Path method qualname; is_block_device() returns True if the path points to a block special device file (e.g., /dev/disk0); longer than is_char_device (19), is_junction/hardlink_to (16)"
  category: qualname
  kind: python_call_eq
  function: Path.is_block_device.__qualname__.__len__
  args: []
  expected: 20

invariant pathlib_extra157.PurePath.is_relative_to_qualname_len_23:
  description: "pathlib.PurePath.is_relative_to.__qualname__.__len__() == 23 ('PurePath.is_relative_to' has 23 characters; 'PurePath.' (9) + 'is_relative_to' (14) = 23; the longest PurePath method qualname; is_relative_to(other) returns True if the path is a sub-path of other; added in Python 3.9 as a more readable alternative to try/except around relative_to())"
  category: qualname
  kind: python_call_eq
  function: PurePath.is_relative_to.__qualname__.__len__
  args: []
  expected: 23

invariant pathlib_extra157.PosixPath.base0_is_Path:
  description: "pathlib.PosixPath.__bases__[0].__name__ == 'Path' (PosixPath uses multiple inheritance with Path as its first base; this means PosixPath inherits all filesystem methods from Path; PosixPath.__bases__ == (Path, PurePosixPath) — on POSIX systems, Path() automatically instantiates a PosixPath; on Windows, attempting PosixPath() raises NotImplementedError)"
  category: identity
  kind: python_call_eq
  function: "PosixPath.__bases__[0].__name__.__eq__"
  args: ["Path"]
  expected: true
