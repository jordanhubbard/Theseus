spec: theseus_numbers_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_numbers_cr3)
blocks: numbers

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html"
    - "PEP 3141 — A Type Hierarchy for Numbers"
  notes:
    - "Clean-room extended numbers utilities. Do NOT import numbers."
    - "Number, Complex, Real, Rational, Integral: abstract base classes in numeric tower."
    - "numbers3_integral_isinstance(): isinstance(5, Integral) == True (int is registered)."
    - "numbers3_real_isinstance(): isinstance(5.0, Real) == True (float is registered)."
    - "numbers3_complex_isinstance(): isinstance(1+2j, Complex) == True (complex registered)."
    - "Zero-arg invariant signatures — def numbers3_integral_isinstance(): return bool"
    - "Register Python builtins: int -> Integral, float -> Real, complex -> Complex."
    - "The numeric tower: Number > Complex > Real > Rational > Integral."
    - "isinstance(int_val, Real) == True because int is subtype of Integral which is subtype of Real."
    - "Use abc.ABCMeta and abc.abstractmethod to build the abstract base classes."
    - "Export: Number, Complex, Real, Rational, Integral (all abstract base classes)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_numbers_cr3.integral_isinstance:
  description: "isinstance(5, Integral) == True"
  category: Integral
  kind: python_call_eq
  function: numbers3_integral_isinstance
  args: []
  expected: true

invariant theseus_numbers_cr3.real_isinstance:
  description: "isinstance(5.0, Real) == True"
  category: Real
  kind: python_call_eq
  function: numbers3_real_isinstance
  args: []
  expected: true

invariant theseus_numbers_cr3.complex_isinstance:
  description: "isinstance(1+2j, Complex) == True"
  category: Complex
  kind: python_call_eq
  function: numbers3_complex_isinstance
  args: []
  expected: true
