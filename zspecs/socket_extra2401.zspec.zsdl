spec: socket_extra2401
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "socket_extra2401: __hash__ and __eq__ implementation type classification for socket.socket, socket.error, socket.AddressFamily, and socket.SocketKind."
    - "socket.socket is a Python class. Its class-level __hash__ and __eq__ are both 'wrapper_descriptor' inherited from object — socket.socket does not override either."
    - "socket.error is an alias for OSError. Its class-level __hash__ and __eq__ are 'wrapper_descriptor' inherited from object."
    - "socket.AddressFamily is an IntEnum. Its __hash__ is 'wrapper_descriptor' (from int, not Enum.__hash__); its __eq__ is also 'wrapper_descriptor'."
    - "socket.SocketKind is an IntEnum. Its __hash__ and __eq__ are both 'wrapper_descriptor', matching AddressFamily."
    - "socket.gaierror and socket.timeout are exception subclasses — both inherit __hash__ and __eq__ as 'wrapper_descriptor' from object."
    - "None of these classes define __hash__ or __eq__ in their own __dict__ — all __dict__.__contains__ checks return False."
    - "All expected values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra2401.socket_hash_eq_class_name:
  description: "socket.socket class-level __hash__ and __eq__ are both 'wrapper_descriptor' — Python class inheriting from object, neither overridden"
  kind: python_call_eq
  category: hash_eq_classification
  id_prefix: sk2401so

  columns: [id, function, args, expected]
  rows:
    - ["sk2401001", "socket.socket.__hash__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["sk2401002", "socket.socket.__eq__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true]
    - ["sk2401003", "socket.socket.__hash__.__class__.__name__.__eq__", ["function"],           false]
    - ["sk2401004", "socket.socket.__eq__.__class__.__name__.__eq__",   ["function"],           false]

