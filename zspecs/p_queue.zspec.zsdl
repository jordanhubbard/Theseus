spec: p_queue
version: ">=9.0.0"
backend: node(p-queue)

docs: https://github.com/sindresorhus/p-queue#readme

provenance:
  derived_from:
    - "p-queue README — https://github.com/sindresorhus/p-queue#readme"
    - "Test vectors verified with p-queue via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "p-queue source"
  notes:
    - "Promise queue with concurrency control."
    - "Install: npm install p-queue"
    - "v9 ESM only; default export is the PQueue class."
    - "Constructor: new PQueue({concurrency, autoStart, timeout})"
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Constructor throws TypeError on invalid concurrency."
  stderr: "null"
  stickiness: "N/A — each instance independent."
  codes: {}

invariant p_queue.size_zero_initially:
  description: "New queue has size 0"
  category: properties
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: [{concurrency: 2}]
  chain:
    - {get: size}
  expected: 0

invariant p_queue.pending_zero_initially:
  description: "New queue has pending 0"
  category: properties
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: [{concurrency: 2}]
  chain:
    - {get: pending}
  expected: 0

invariant p_queue.concurrency_set:
  description: "Queue with concurrency: 5 reports 5"
  category: properties
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: [{concurrency: 5}]
  chain:
    - {get: concurrency}
  expected: 5

invariant p_queue.is_paused_when_autostart_false:
  description: "Queue with autoStart: false starts paused"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: [{concurrency: 2, autoStart: false}]
  chain:
    - {get: isPaused}
  expected: true

invariant p_queue.not_paused_default:
  description: "Queue is not paused by default (autoStart defaults true)"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: [{concurrency: 2}]
  chain:
    - {get: isPaused}
  expected: false

invariant p_queue.timeout_undefined_default:
  description: "Default queue has no timeout configured (undefined)"
  category: properties
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: [{concurrency: 2}]
  chain:
    - {get: timeout}
  expected: ~

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:20:56Z
  iterations: 2
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 2 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
