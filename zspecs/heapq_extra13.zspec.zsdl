spec: heapq_extra13
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
  notes:
    - "This spec extends heapq.zspec.zsdl and prior extras through heapq_extra12.zspec.zsdl."
    - "Prior specs cover: __name__/__module__/__qualname__ for all 6 heapq functions; _heapq C accelerator name."
    - "No prior heapq spec covers behavioral return-value vectors for nlargest or nsmallest."
    - "This spec adds NEW axes:"
    - "  (1) nlargest(3, [5,3,8,1,9,2]) == [9,8,5] — top-3 of a 6-element list."
    - "  (2) nsmallest(3, [5,3,8,1,9,2]) == [1,2,3] — bottom-3 of a 6-element list."
    - "  (3) nlargest(1, [5,3,8]) == [8] — single largest of a 3-element list."
    - "  (4) nsmallest(1, [5,3,8]) == [3] — single smallest of a 3-element list."
    - "  (5) nlargest(2, [10,20,30,5]) == [30,20] — top-2 of a 4-element list."
    - "  (6) nsmallest(2, [10,20,30,5]) == [5,10] — bottom-2 of a 4-element list."
    - "  (7) nlargest(0, [5,3,8]) == [] — zero elements requested returns empty list."
    - "  (8) nsmallest(0, [5,3,8]) == [] — zero elements requested returns empty list."
    - "heapq.nlargest(3,[5,3,8,1,9,2]) == [9,8,5] — verified Python 3.12 macOS."
    - "heapq.nsmallest(3,[5,3,8,1,9,2]) == [1,2,3] — verified Python 3.12 macOS."
    - "heapq.nlargest(1,[5,3,8]) == [8] — verified Python 3.12 macOS."
    - "heapq.nsmallest(1,[5,3,8]) == [3] — verified Python 3.12 macOS."
    - "heapq.nlargest(2,[10,20,30,5]) == [30,20] — verified Python 3.12 macOS."
    - "heapq.nsmallest(2,[10,20,30,5]) == [5,10] — verified Python 3.12 macOS."
    - "heapq.nlargest(0,[5,3,8]) == [] — verified Python 3.12 macOS."
    - "heapq.nsmallest(0,[5,3,8]) == [] — verified Python 3.12 macOS."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# nlargest behavioral return-value invariants
#
# No prior heapq spec tests the actual return values of nlargest or nsmallest.
# Results are returned in descending order for nlargest, ascending for nsmallest.
# ---------------------------------------------------------------------------

invariant heapq_extra13.nlargest.top3_of_6:
  description: "heapq.nlargest(3,[5,3,8,1,9,2]) == [9,8,5] — top 3 of a 6-element list"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [3, [5, 3, 8, 1, 9, 2]]
  expected: [9, 8, 5]

invariant heapq_extra13.nlargest.top1_of_3:
  description: "heapq.nlargest(1,[5,3,8]) == [8] — single largest element"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [1, [5, 3, 8]]
  expected: [8]

invariant heapq_extra13.nlargest.top2_of_4:
  description: "heapq.nlargest(2,[10,20,30,5]) == [30,20] — top 2 of a 4-element list"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [2, [10, 20, 30, 5]]
  expected: [30, 20]

invariant heapq_extra13.nlargest.zero:
  description: "heapq.nlargest(0,[5,3,8]) == [] — zero elements requested returns empty list"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [0, [5, 3, 8]]
  expected: []

# ---------------------------------------------------------------------------
# nsmallest behavioral return-value invariants
# ---------------------------------------------------------------------------

invariant heapq_extra13.nsmallest.bottom3_of_6:
  description: "heapq.nsmallest(3,[5,3,8,1,9,2]) == [1,2,3] — bottom 3 of a 6-element list"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [3, [5, 3, 8, 1, 9, 2]]
  expected: [1, 2, 3]

invariant heapq_extra13.nsmallest.bottom1_of_3:
  description: "heapq.nsmallest(1,[5,3,8]) == [3] — single smallest element"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [1, [5, 3, 8]]
  expected: [3]

invariant heapq_extra13.nsmallest.bottom2_of_4:
  description: "heapq.nsmallest(2,[10,20,30,5]) == [5,10] — bottom 2 of a 4-element list"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [2, [10, 20, 30, 5]]
  expected: [5, 10]

invariant heapq_extra13.nsmallest.zero:
  description: "heapq.nsmallest(0,[5,3,8]) == [] — zero elements requested returns empty list"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [0, [5, 3, 8]]
  expected: []

# ---------------------------------------------------------------------------
# nlargest/nsmallest behavioral table — additional vectors side by side
#
# The table format lets the reader compare nlargest and nsmallest on the same
# inputs at a glance. These rows use the same verified inputs as the invariants
# above but are arranged as a compact reference table with fresh id_prefix.
# ---------------------------------------------------------------------------

table heapq_extra13.nlargest_nsmallest_vectors:
  description: "nlargest and nsmallest return-value behavioral vectors"
  kind: python_call_eq
  category: behavior
  id_prefix: hbvec13

  columns: [id, function, args, expected]
  rows:
    - [nlargest_3_6elem,  nlargest,  [3, [5, 3, 8, 1, 9, 2]], [9, 8, 5]]
    - [nsmallest_3_6elem, nsmallest, [3, [5, 3, 8, 1, 9, 2]], [1, 2, 3]]
    - [nlargest_1_3elem,  nlargest,  [1, [5, 3, 8]],          [8]]
    - [nsmallest_1_3elem, nsmallest, [1, [5, 3, 8]],          [3]]
    - [nlargest_2_4elem,  nlargest,  [2, [10, 20, 30, 5]],    [30, 20]]
    - [nsmallest_2_4elem, nsmallest, [2, [10, 20, 30, 5]],    [5, 10]]
    - [nlargest_0_3elem,  nlargest,  [0, [5, 3, 8]],          []]
    - [nsmallest_0_3elem, nsmallest, [0, [5, 3, 8]],          []]
