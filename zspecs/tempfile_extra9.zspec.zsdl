spec: tempfile_extra9
version: ">=3.9"
backend: python_module(tempfile)

docs: https://docs.python.org/3/library/tempfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tempfile.html — Python tempfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tempfile.py"
  notes:
    - "This spec extends tempfile.zspec.zsdl and all prior tempfile_extra specs."
    - "tempfile_extra8 covers utility function __name__ lengths and last-char checks; module __name__; template value; gettempprefix/gettempdir return types."
    - "tempfile_extra7 covers __name__ length checks and is-str checks for TemporaryFile/NamedTemporaryFile/TemporaryDirectory/SpooledTemporaryFile class names."
    - "No prior tempfile spec covers __module__ for NamedTemporaryFile, SpooledTemporaryFile, or TemporaryDirectory as standalone invariants."
    - "No prior tempfile spec covers __qualname__ for NamedTemporaryFile, SpooledTemporaryFile, or TemporaryDirectory."
    - "No prior tempfile spec covers __module__ for utility functions mkstemp/mkdtemp/gettempdir/gettempprefix."
    - "tempfile.NamedTemporaryFile.__module__ == 'tempfile'."
    - "tempfile.SpooledTemporaryFile.__module__ == 'tempfile'."
    - "tempfile.TemporaryDirectory.__module__ == 'tempfile'."
    - "tempfile.NamedTemporaryFile.__qualname__ == 'NamedTemporaryFile'."
    - "tempfile.SpooledTemporaryFile.__qualname__ == 'SpooledTemporaryFile'."
    - "tempfile.TemporaryDirectory.__qualname__ == 'TemporaryDirectory'."
    - "tempfile.mkstemp.__module__ == 'tempfile'."
    - "tempfile.mkdtemp.__module__ == 'tempfile'."
    - "tempfile.gettempdir.__module__ == 'tempfile'."
    - "tempfile.gettempprefix.__module__ == 'tempfile'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for NamedTemporaryFile, SpooledTemporaryFile, TemporaryDirectory
#
# tempfile_extra and tempfile.zspec cover __module__ for TemporaryFile.
# No prior tempfile spec checks __module__ for the other three main classes.
# All three are defined in the tempfile module so __module__ == 'tempfile'.
# ---------------------------------------------------------------------------

table tempfile_extra9.class_modules:
  description: "tempfile public class __module__ attributes"
  kind: python_call_eq
  category: class_module
  id_prefix: clsmod9

  columns: [id, function, args, expected]
  rows:
    - [NamedTemporaryFile,   NamedTemporaryFile.__module__.__eq__,   ["tempfile"], true]
    - [SpooledTemporaryFile, SpooledTemporaryFile.__module__.__eq__, ["tempfile"], true]
    - [TemporaryDirectory,   TemporaryDirectory.__module__.__eq__,   ["tempfile"], true]

# ---------------------------------------------------------------------------
# __qualname__ for NamedTemporaryFile, SpooledTemporaryFile, TemporaryDirectory
#
# No prior tempfile spec records __qualname__ for any tempfile class.
# For top-level (non-nested) classes, __qualname__ == __name__.
# NamedTemporaryFile.__qualname__ == 'NamedTemporaryFile', etc.
# ---------------------------------------------------------------------------

table tempfile_extra9.class_qualnames:
  description: "tempfile public class __qualname__ attributes"
  kind: python_call_eq
  category: class_qualname
  id_prefix: clsqn9

  columns: [id, function, args, expected]
  rows:
    - [NamedTemporaryFile,   NamedTemporaryFile.__qualname__.__eq__,   ["NamedTemporaryFile"],   true]
    - [SpooledTemporaryFile, SpooledTemporaryFile.__qualname__.__eq__, ["SpooledTemporaryFile"], true]
    - [TemporaryDirectory,   TemporaryDirectory.__qualname__.__eq__,   ["TemporaryDirectory"],   true]

# ---------------------------------------------------------------------------
# __module__ for utility functions mkstemp, mkdtemp, gettempdir, gettempprefix
#
# No prior tempfile spec checks __module__ for any utility function.
# All are defined directly in the tempfile module so __module__ == 'tempfile'.
# ---------------------------------------------------------------------------

table tempfile_extra9.function_modules:
  description: "tempfile utility function __module__ attributes"
  kind: python_call_eq
  category: function_module
  id_prefix: fnmod9

  columns: [id, function, args, expected]
  rows:
    - [mkstemp,       mkstemp.__module__.__eq__,       ["tempfile"], true]
    - [mkdtemp,       mkdtemp.__module__.__eq__,       ["tempfile"], true]
    - [gettempdir,    gettempdir.__module__.__eq__,    ["tempfile"], true]
    - [gettempprefix, gettempprefix.__module__.__eq__, ["tempfile"], true]

# ---------------------------------------------------------------------------
# __qualname__ for utility functions mkstemp, mkdtemp, gettempdir, gettempprefix
#
# No prior tempfile spec checks __qualname__ for any utility function.
# For module-level functions, __qualname__ == __name__ (no class nesting).
# ---------------------------------------------------------------------------

invariant tempfile_extra9.mkstemp.qualname:
  description: "tempfile.mkstemp.__qualname__ == 'mkstemp'"
  category: function_qualname
  kind: python_call_eq
  function: mkstemp.__qualname__.__eq__
  args: ["mkstemp"]
  expected: true

invariant tempfile_extra9.gettempdir.qualname:
  description: "tempfile.gettempdir.__qualname__ == 'gettempdir'"
  category: function_qualname
  kind: python_call_eq
  function: gettempdir.__qualname__.__eq__
  args: ["gettempdir"]
  expected: true
