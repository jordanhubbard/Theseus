table multiprocessing_extra155.process_init_defaults_shape:
  description: "multiprocessing.Process.__init__.__defaults__ shape checks in mpdefaults155 namespace — __defaults__ is (None, None, None, (), None) (a 5-tuple); covers group=None, target=None, name=None, args=(), kwargs=None; __class__.__name__=='tuple'; __len__()==5; defaults[3].__class__.__name__=='tuple' (args defaults to empty tuple); defaults[3].__len__()==0 (empty); verified with Python 3.14.3"
  kind: python_call_eq
  category: process_init_defaults
  id_prefix: mpdefaults155

  columns: [id, function, args, expected, description]
  rows:
    - ["process_defaults_is_tuple",    "multiprocessing.Process.__init__.__defaults__.__class__.__name__.__eq__",               ["tuple"], true, "multiprocessing.Process.__init__.__defaults__.__class__.__name__ == 'tuple' — __defaults__ is a tuple when present; verified Python 3.14.3"]
    - ["process_defaults_len_5",       "multiprocessing.Process.__init__.__defaults__.__len__",                                  [],        5,    "multiprocessing.Process.__init__.__defaults__.__len__() == 5 — five defaults: group, target, name, args, kwargs; verified Python 3.14.3"]
    - ["process_defaults3_is_tuple",   "multiprocessing.Process.__init__.__defaults__.__getitem__(3).__class__.__name__.__eq__", ["tuple"], true, "multiprocessing.Process.__init__.__defaults__[3].__class__.__name__ == 'tuple' — args defaults to () (empty tuple); verified Python 3.14.3"]
    - ["process_defaults3_len_0",      "multiprocessing.Process.__init__.__defaults__.__getitem__(3).__len__",                   [],        0,    "multiprocessing.Process.__init__.__defaults__[3].__len__() == 0 — the args default () is an empty tuple; verified Python 3.14.3"]

