    - ["process_kwdefaults_len_1",           "multiprocessing.Process.__init__.__kwdefaults__.__len__",                    [],           1,    "multiprocessing.Process.__init__.__kwdefaults__.__len__() == 1 — exactly one keyword-only default: daemon=None; verified Python 3.14.3"]
    - ["process_kwdefaults_contains_daemon", "multiprocessing.Process.__init__.__kwdefaults__.__contains__",               ["daemon"],   true, "multiprocessing.Process.__init__.__kwdefaults__.__contains__('daemon') == True — daemon is the keyword-only parameter; verified Python 3.14.3"]
    - ["process_init_is_function",           "multiprocessing.Process.__init__.__class__.__name__.__eq__",                 ["function"], true, "multiprocessing.Process.__init__.__class__.__name__ == 'function' — __init__ is a Python function; verified Python 3.14.3"]

