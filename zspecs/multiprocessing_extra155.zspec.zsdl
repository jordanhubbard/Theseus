# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra155
# ---------------------------------------------------------------------------

invariant multiprocessing_extra155.process_defaults_is_tuple:
  description: "multiprocessing.Process.__init__.__defaults__.__class__.__name__.__eq__('tuple') == True — __defaults__ is (None, None, None, (), None); it covers group, target, name, args, kwargs; __defaults__ is always a tuple when non-None; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: process_init_defaults
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant multiprocessing_extra155.process_defaults_len_5:
  description: "multiprocessing.Process.__init__.__defaults__.__len__() == 5 — Process.__init__(self, group=None, target=None, name=None, args=(), kwargs=None, *, daemon=None) has five positional defaults and one keyword-only default; __defaults__ covers only the positional ones; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: process_init_defaults
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__defaults__.__len__
  args: []
  expected: 5

invariant multiprocessing_extra155.process_defaults3_is_tuple:
  description: "multiprocessing.Process.__init__.__defaults__[3].__class__.__name__.__eq__('tuple') == True — __defaults__[3] is the args default value (); args is a tuple of positional arguments to pass to the target function; the default is an empty tuple meaning no args are passed by default; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: process_init_defaults
  kind: python_call_eq
  function: "multiprocessing.Process.__init__.__defaults__.__getitem__(3).__class__.__name__.__eq__"
  args: ["tuple"]
  expected: true

invariant multiprocessing_extra155.process_defaults3_len_0:
  description: "multiprocessing.Process.__init__.__defaults__[3].__len__() == 0 — the args default () is an empty tuple of length 0; when Process is created without an args argument, no positional arguments are passed to the target; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: process_init_defaults
  kind: python_call_eq
  function: "multiprocessing.Process.__init__.__defaults__.__getitem__(3).__len__"
  args: []
  expected: 0

invariant multiprocessing_extra155.process_kwdefaults_is_dict:
  description: "multiprocessing.Process.__init__.__kwdefaults__.__class__.__name__.__eq__('dict') == True — __kwdefaults__ is {'daemon': None}; keyword-only defaults are stored as a dict (not a tuple); __kwdefaults__ is a dict when present, contrasting with __defaults__ which is always a tuple; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: process_init_kwdefaults
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__kwdefaults__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant multiprocessing_extra155.process_kwdefaults_len_1:
  description: "multiprocessing.Process.__init__.__kwdefaults__.__len__() == 1 — the only keyword-only parameter with a default is daemon=None; Process.__init__.__kwdefaults__.__len__(1) < Process.__init__.__defaults__.__len__(5) by 4 — there are more positional defaults than keyword-only defaults; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: process_init_kwdefaults
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__kwdefaults__.__len__
  args: []
  expected: 1

invariant multiprocessing_extra155.process_kwdefaults_contains_daemon:
  description: "multiprocessing.Process.__init__.__kwdefaults__.__contains__('daemon') == True — daemon is the keyword-only parameter stored in __kwdefaults__; when daemon=None the process inherits the daemon status of its parent; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: process_init_kwdefaults
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__kwdefaults__.__contains__
  args: ["daemon"]
  expected: true

invariant multiprocessing_extra155.process_is_type:
  description: "multiprocessing.Process.__class__.__name__.__eq__('type') == True — Process is a class object; its metaclass is 'type'; Process.__class__.__name__=='type' (len=4: t-y-p-e); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: process_class_identity
  kind: python_call_eq
  function: multiprocessing.Process.__class__.__name__.__eq__
  args: ["type"]
  expected: true
