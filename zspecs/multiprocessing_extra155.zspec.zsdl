spec: multiprocessing_extra155
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Process — Process class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "multiprocessing.Process.__init__.__defaults__ is (None, None, None, (), None) — a 5-tuple covering group, target, name, args, kwargs."
    - "multiprocessing.Process.__init__.__defaults__.__class__.__name__ == 'tuple' — __defaults__ is always a tuple when present."
    - "multiprocessing.Process.__init__.__defaults__.__len__() == 5 — five positional parameters have defaults."
    - "multiprocessing.Process.__init__.__defaults__[3] is () — args defaults to empty tuple (no positional arguments to the target function)."
    - "multiprocessing.Process.__init__.__defaults__[3].__class__.__name__ == 'tuple' — the args default value is itself a tuple."
    - "multiprocessing.Process.__init__.__kwdefaults__ is {'daemon': None} — daemon is a keyword-only parameter defaulting to None."
    - "multiprocessing.Process.__init__.__kwdefaults__.__class__.__name__ == 'dict' — __kwdefaults__ is always a dict when present."
    - "multiprocessing.Process.__init__.__kwdefaults__.__len__() == 1 — exactly one keyword-only default: daemon=None."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

