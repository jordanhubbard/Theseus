spec: multiprocessing_extra155
version: ">=3.9"
backend: python_module(multiprocessing.context)

docs: https://docs.python.org/3/library/multiprocessing.html#contexts-and-start-methods

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec covers: multiprocessing.context module class identity — BaseContext, DefaultContext, SpawnContext, and Process. multiprocessing.context.BaseContext.__name__=='BaseContext' (len=11); multiprocessing.context.BaseContext.__module__=='multiprocessing.context' (len=22); multiprocessing.context.BaseContext.__bases__[0].__name__=='object' (BaseContext inherits from object — root context class); multiprocessing.context.DefaultContext.__bases__[0].__name__=='BaseContext' (DefaultContext inherits from BaseContext); multiprocessing.context.Process.__bases__[0].__name__=='BaseProcess' (multiprocessing.context.Process inherits from BaseProcess, not from object directly); multiprocessing.context.SpawnContext.__name__=='SpawnContext' (len=12); multiprocessing.context.SpawnContext.__bases__[0].__name__=='BaseContext' (SpawnContext inherits from BaseContext). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.context.BaseContext.__module__=='multiprocessing.context' (len=22: 'multiprocessing'=15+'.'=1+'context'=7=23... wait: len('multiprocessing.context')='multiprocessing'=15+'.'=1+'context'=7=23); len('multiprocessing.context')==23; verified with Python 3.14.3. Compare: multiprocessing.managers.__name__=='multiprocessing.managers' (len=24; 1 char longer); multiprocessing.pool.__module__=='multiprocessing.pool' (len=20; shorter). The context module (len=23) sits between pool (len=20) and managers (len=24). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.context.Process.__bases__[0].__name__=='BaseProcess' — multiprocessing.context defines a Process class that inherits from multiprocessing.process.BaseProcess (the true base class for all Python multiprocessing Process classes); Process.__bases__[0].__name__=='BaseProcess' (len=11); this is different from BaseContext and SpawnContext which inherit from object or BaseContext respectively; BaseProcess is defined in Lib/multiprocessing/process.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing context class hierarchy — BaseContext (bases: object) is the abstract root; DefaultContext (bases: BaseContext) is the platform-appropriate default context; SpawnContext (bases: BaseContext) is the context for 'spawn' start method; ForkContext (bases: BaseContext) is for 'fork' (Unix only); ForkServerContext (bases: BaseContext) is for 'forkserver' (Unix only); DefaultContext wraps an underlying BaseContext instance and delegates to it; the start method controls how worker processes are created: 'spawn' (cross-platform), 'fork' (Unix fast but unsafe with threads), 'forkserver' (Unix, uses a server). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.context.BaseContext class identity — extra155
#
# multiprocessing.context.BaseContext.__name__.__eq__('BaseContext')                    == True
# multiprocessing.context.BaseContext.__module__.__eq__('multiprocessing.context')      == True
# multiprocessing.context.BaseContext.__bases__[0].__name__.__eq__('object')            == True
# ---------------------------------------------------------------------------

table multiprocessing_extra155.mp_context_base_context_identity:
  description: "multiprocessing.context.BaseContext class identity checks in mpbasectx155 namespace — multiprocessing.context.BaseContext.__name__=='BaseContext' (len=11: 'Base'=4+'Context'=7=11; the abstract root class for all multiprocessing context classes — provides the API for creating Process, Queue, Pipe, Lock, etc. using the context's start method); multiprocessing.context.BaseContext.__module__=='multiprocessing.context' (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23; defined in Lib/multiprocessing/context.py); multiprocessing.context.BaseContext.__bases__[0].__name__=='object' (len=6; BaseContext inherits directly from object — it is the root of the context class hierarchy); BaseContext.__name__.__len__()==11; compare: multiprocessing.managers.BaseManager.__name__.__len__()==11 (same length — 'Base'=4+'Manager'=7=11 vs 'Base'=4+'Context'=7=11); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbasectx155

  columns: [id, function, args, expected, description]
  rows:
    - [bctx_name_eq,   multiprocessing.context.BaseContext.__name__.__eq__,                ["BaseContext"],              true,  "multiprocessing.context.BaseContext.__name__ == 'BaseContext' (len=11); verified with Python 3.14.3"]
    - [bctx_mod_eq,    multiprocessing.context.BaseContext.__module__.__eq__,               ["multiprocessing.context"],  true,  "multiprocessing.context.BaseContext.__module__ == 'multiprocessing.context' (len=23); verified with Python 3.14.3"]
    - [bctx_base_eq,   "multiprocessing.context.BaseContext.__bases__[0].__name__.__eq__",  ["object"],                   true,  "multiprocessing.context.BaseContext.__bases__[0].__name__ == 'object' (root context class inheriting from object); verified with Python 3.14.3"]
    - [bctx_name_len,  multiprocessing.context.BaseContext.__name__.__len__,                [],                           11,    "multiprocessing.context.BaseContext.__name__.__len__() == 11 ('BaseContext'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.context.DefaultContext and SpawnContext inheritance — extra155
#
# multiprocessing.context.DefaultContext.__bases__[0].__name__.__eq__('BaseContext')  == True
# multiprocessing.context.SpawnContext.__name__.__eq__('SpawnContext')                == True
# multiprocessing.context.SpawnContext.__bases__[0].__name__.__eq__('BaseContext')    == True
# ---------------------------------------------------------------------------

table multiprocessing_extra155.mp_context_subclass_identity:
  description: "multiprocessing.context.DefaultContext and SpawnContext class identity checks in mpctxsub155 namespace — multiprocessing.context.DefaultContext.__bases__[0].__name__=='BaseContext' (len=11; DefaultContext inherits from BaseContext — it is the platform-appropriate default context that wraps an underlying start-method context); multiprocessing.context.SpawnContext.__name__=='SpawnContext' (len=12: 'Spawn'=5+'Context'=7=12; the context for the 'spawn' start method which creates a fresh interpreter process for each worker — the only portable start method across all platforms); multiprocessing.context.SpawnContext.__bases__[0].__name__=='BaseContext' (len=11; SpawnContext inherits from BaseContext); both DefaultContext and SpawnContext have __bases__[0].__name__=='BaseContext' confirming single inheritance from the root context class; SpawnContext.__name__.__len__()==12 (1 longer than BaseContext=11 because 'Spawn'=5 > 'Base'=4); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpctxsub155

  columns: [id, function, args, expected, description]
  rows:
    - [defctx_base_eq,   "multiprocessing.context.DefaultContext.__bases__[0].__name__.__eq__",  ["BaseContext"],   true,  "multiprocessing.context.DefaultContext.__bases__[0].__name__ == 'BaseContext' (inherits from BaseContext); verified with Python 3.14.3"]
    - [spawnctx_name_eq, multiprocessing.context.SpawnContext.__name__.__eq__,                    ["SpawnContext"],  true,  "multiprocessing.context.SpawnContext.__name__ == 'SpawnContext' (len=12); verified with Python 3.14.3"]
    - [spawnctx_base_eq, "multiprocessing.context.SpawnContext.__bases__[0].__name__.__eq__",     ["BaseContext"],   true,  "multiprocessing.context.SpawnContext.__bases__[0].__name__ == 'BaseContext' (inherits from BaseContext); verified with Python 3.14.3"]
    - [spawnctx_nmlen,   multiprocessing.context.SpawnContext.__name__.__len__,                   [],               12,    "multiprocessing.context.SpawnContext.__name__.__len__() == 12 ('SpawnContext'; 1 longer than BaseContext=11); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.context.Process base class — extra155
#
# multiprocessing.context.Process.__bases__[0].__name__.__eq__('BaseProcess')  == True
# ---------------------------------------------------------------------------

table multiprocessing_extra155.mp_context_process_identity:
  description: "multiprocessing.context.Process class identity checks in mpctxproc155 namespace — multiprocessing.context.Process.__bases__[0].__name__=='BaseProcess' (len=11: 'Base'=4+'Process'=7=11; multiprocessing.context.Process inherits from multiprocessing.process.BaseProcess — NOT from BaseContext or object directly; BaseProcess is the true base class for all Python multiprocessing Process classes defined in Lib/multiprocessing/process.py); this is different from BaseContext, DefaultContext, and SpawnContext which are all context classes (BaseContext.__bases__[0].__name__=='object'); Process.__bases__[0].__name__=='BaseProcess' confirms that context.Process is in the Process class hierarchy, not the Context hierarchy; len('BaseProcess')==11 (same as 'BaseContext'==11 and 'BaseManager'==11 — all 'Base'-prefixed classes with 7-char suffixes); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpctxproc155

  columns: [id, function, args, expected, description]
  rows:
    - [proc_base_eq,   "multiprocessing.context.Process.__bases__[0].__name__.__eq__",  ["BaseProcess"],  true,  "multiprocessing.context.Process.__bases__[0].__name__ == 'BaseProcess' (inherits from BaseProcess, not BaseContext); verified with Python 3.14.3"]
    - [proc_base_len,  "multiprocessing.context.Process.__bases__[0].__name__.__len__", [],               11,    "multiprocessing.context.Process.__bases__[0].__name__.__len__() == 11 ('BaseProcess'); verified with Python 3.14.3"]
    - [bctx_base_len,  "multiprocessing.context.BaseContext.__bases__[0].__name__.__len__", [],           6,     "multiprocessing.context.BaseContext.__bases__[0].__name__.__len__() == 6 ('object'; contrast with Process which bases on BaseProcess=11); verified with Python 3.14.3"]
    - [spawnctx_blen,  "multiprocessing.context.SpawnContext.__bases__[0].__name__.__len__", [],          11,    "multiprocessing.context.SpawnContext.__bases__[0].__name__.__len__() == 11 ('BaseContext'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra155
# ---------------------------------------------------------------------------

invariant multiprocessing_extra155.mp_BaseContext_name_eq:
  description: "multiprocessing.context.BaseContext.__name__.__eq__('BaseContext') returns True — multiprocessing.context.BaseContext is the abstract root class for all multiprocessing context classes; BaseContext.__name__=='BaseContext' (len=11: 'Base'=4+'Context'=7=11); BaseContext provides the API for creating multiprocessing primitives: Process, Queue, Pipe, Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Barrier, Value, Array, Manager, Pool, SimpleQueue; each context class overrides _start_method to declare which start method it uses ('spawn', 'fork', 'forkserver'); BaseContext.__module__=='multiprocessing.context' (len=23); BaseContext.__bases__[0].__name__=='object' (inherits from object); compare: multiprocessing.managers.BaseManager.__name__=='BaseManager' (len=11; same length — both 'Base'-prefixed with 7-char suffix); NEW in extra155: first standalone multiprocessing.context.BaseContext.__name__ identity invariant in mpbasectx155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.context.BaseContext.__name__.__eq__
  args: ["BaseContext"]
  expected: true

invariant multiprocessing_extra155.mp_BaseContext_module_eq:
  description: "multiprocessing.context.BaseContext.__module__.__eq__('multiprocessing.context') returns True — multiprocessing.context.BaseContext is defined in Lib/multiprocessing/context.py; its __module__ is 'multiprocessing.context' (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23); compare module name lengths: multiprocessing.pool (len=20) < multiprocessing.context (len=23) < multiprocessing.managers (len=24) < multiprocessing.shared_memory (len=29); context (len=23) is 3 chars longer than pool (len=20) and 1 char shorter than managers (len=24); NEW in extra155: first standalone multiprocessing.context.BaseContext.__module__ identity invariant in mpbasectx155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.context.BaseContext.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra155.mp_DefaultContext_bases0_is_BaseContext:
  description: "multiprocessing.context.DefaultContext.__bases__[0].__name__.__eq__('BaseContext') returns True — multiprocessing.context.DefaultContext inherits directly from BaseContext; DefaultContext.__bases__[0].__name__=='BaseContext' (len=11); DefaultContext is the context returned by multiprocessing.get_context() when no start method is specified; it wraps a start-method-specific context (_default_context attribute, typically the fork context on Unix or spawn on Windows/macOS); DefaultContext.__bases__[0].__name__=='BaseContext' confirms single inheritance from BaseContext; compare: SpawnContext.__bases__[0].__name__=='BaseContext' (SpawnContext also inherits from BaseContext); both DefaultContext and SpawnContext share the same parent class; NEW in extra155: first standalone multiprocessing.context.DefaultContext.__bases__[0] name identity invariant in mpctxsub155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.context.DefaultContext.__bases__[0].__name__.__eq__"
  args: ["BaseContext"]
  expected: true

invariant multiprocessing_extra155.mp_SpawnContext_name_eq:
  description: "multiprocessing.context.SpawnContext.__name__.__eq__('SpawnContext') returns True — multiprocessing.context.SpawnContext is the context class for the 'spawn' start method; SpawnContext.__name__=='SpawnContext' (len=12: 'Spawn'=5+'Context'=7=12; 1 char longer than BaseContext=11 because 'Spawn'=5 > 'Base'=4); the 'spawn' start method creates a fresh Python interpreter process for each worker, importing the main module from scratch — it is the only start method available on all platforms (Windows, macOS, Linux); SpawnContext.__bases__[0].__name__=='BaseContext' (inherits from BaseContext); SpawnContext.__module__=='multiprocessing.context' (same module as BaseContext); NEW in extra155: first standalone multiprocessing.context.SpawnContext.__name__ identity invariant in mpctxsub155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.context.SpawnContext.__name__.__eq__
  args: ["SpawnContext"]
  expected: true

invariant multiprocessing_extra155.mp_context_Process_bases0_is_BaseProcess:
  description: "multiprocessing.context.Process.__bases__[0].__name__.__eq__('BaseProcess') returns True — multiprocessing.context.Process inherits from multiprocessing.process.BaseProcess (NOT from BaseContext); Process.__bases__[0].__name__=='BaseProcess' (len=11: 'Base'=4+'Process'=7=11); BaseProcess is defined in Lib/multiprocessing/process.py and provides the core process creation, start, join, terminate, kill, and state-inspection APIs; context.Process is the specific Process subclass that uses the context's start method; this is in contrast to BaseContext.__bases__[0].__name__=='object' and SpawnContext.__bases__[0].__name__=='BaseContext' — Process sits in a different class hierarchy from the context classes; NEW in extra155: first standalone multiprocessing.context.Process.__bases__[0] name identity invariant in mpctxproc155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.context.Process.__bases__[0].__name__.__eq__"
  args: ["BaseProcess"]
  expected: true
