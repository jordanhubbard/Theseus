    - ["process_name_len_7",       "multiprocessing.Process.__name__.__len__",               [],       7,    "multiprocessing.Process.__name__.__len__() == 7 — 'Process' has 7 chars: P-r-o-c-e-s-s; verified Python 3.14.3"]
    - ["process_defaults_len_5",   "multiprocessing.Process.__init__.__defaults__.__len__",  [],       5,    "multiprocessing.Process.__init__.__defaults__.__len__() == 5 — five positional defaults; verified Python 3.14.3"]
