spec: theseus_math_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_math_cr3)
blocks: math

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html"
  notes:
    - "Clean-room extended math functions. Do NOT import math."
    - "isfinite(x): True if x is neither inf nor nan."
    - "isinf(x): True if x is infinite."
    - "isnan(x): True if x is NaN."
    - "prod(iterable, start=1): product of all elements."
    - "perm(n, k=None): number of permutations of n items taken k at a time."
    - "comb(n, k): number of combinations (n choose k)."
    - "math3_isfinite(): isfinite(1.0) == True."
    - "math3_prod(): prod([2, 3, 4]) == 24."
    - "math3_comb(): comb(5, 2) == 10."
    - "isfinite: return not (x != x or x == float('inf') or x == float('-inf'))."
    - "prod: multiply all elements starting from start."
    - "comb: n! / (k! * (n-k)!)."
    - "Export: isfinite, isinf, isnan, prod, perm, comb."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_math_cr3.isfinite:
  description: "isfinite(1.0) == True"
  category: classify
  kind: python_call_eq
  function: math3_isfinite
  args: []
  expected: true

invariant theseus_math_cr3.prod:
  description: "prod([2, 3, 4]) == 24"
  category: prod
  kind: python_call_eq
  function: math3_prod
  args: []
  expected: 24

invariant theseus_math_cr3.comb:
  description: "comb(5, 2) == 10"
  category: comb
  kind: python_call_eq
  function: math3_comb
  args: []
  expected: 10
