spec: re_extra73
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub, findall, split, escape vectors, compile error cases"
    - "re_extra.zspec.zsdl — covers Pattern/Match class name via instance, flag integer values"
    - "re_extra72.zspec.zsdl — covers module-level function __qualname__ and __code__ attributes"
  notes:
    - "This spec extends all prior re specs through re_extra72 and does NOT duplicate invariants in those files."
    - "This spec covers: re.Pattern and re.Match type object identity — __name__, __module__, __qualname__, __class__.__name__; Pattern and Match __dict__ membership checks for key C methods; compile function __class__.__name__."
    - "re.Pattern.__name__ == 'Pattern' — the compiled regex type."
    - "re.Pattern.__module__ == 're' — Pattern is exposed directly in the re module."
    - "re.Pattern.__qualname__ == 'Pattern' — no enclosing class."
    - "re.Match.__name__ == 'Match' — the match object type."
    - "re.Match.__module__ == 're' — Match is exposed directly in the re module."
    - "re.Match.__qualname__ == 'Match' — no enclosing class."
    - "re.Pattern.__class__.__name__ == 'type' — Pattern is a type object."
    - "re.Match.__class__.__name__ == 'type' — Match is a type object."
    - "re.compile.__class__.__name__ == 'function' — compile is a Python function."
    - "re.Pattern.__dict__.__contains__('match') == True — Pattern defines match as a C method."
    - "re.Pattern.__dict__.__contains__('search') == True — Pattern defines search as a C method."
    - "re.Match.__dict__.__contains__('group') == True — Match defines group as a C method."
    - "re.Match.__dict__.__contains__('span') == True — Match defines span as a C method."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pattern and Match type identity — __name__, __module__, __qualname__
# re_extra3 checks Pattern.__name__ and Match.__name__ as type objects.
# re_extra7 checks Pattern/Match __qualname__. No prior spec checks __module__
# for Pattern and Match in a table combining all three identity attributes.
# ---------------------------------------------------------------------------

table re_extra73.Pattern_Match_identity:
  description: "re.Pattern and re.Match type identity: __name__, __module__, __qualname__"
  kind: python_call_eq
  category: class_names
  id_prefix: recode73

  columns: [id, function, args, expected]
  rows:
    - [pattern_name,     Pattern.__name__.__eq__,     ["Pattern"], true]
    - [pattern_module,   Pattern.__module__.__eq__,   ["re"],      true]
    - [pattern_qualname, Pattern.__qualname__.__eq__,  ["Pattern"], true]
    - [match_name,       Match.__name__.__eq__,       ["Match"],   true]
    - [match_module,     Match.__module__.__eq__,     ["re"],      true]
    - [match_qualname,   Match.__qualname__.__eq__,    ["Match"],   true]

# ---------------------------------------------------------------------------
# Pattern and Match __class__.__name__ — both are 'type'
# No prior re spec checks Pattern.__class__.__name__ or Match.__class__.__name__.
# ---------------------------------------------------------------------------

table re_extra73.Pattern_Match_class_type:
  description: "re.Pattern and re.Match are type objects"
  kind: python_call_eq
  category: class_names
  id_prefix: recode73

  columns: [id, function, args, expected]
  rows:
    - [pattern_type, Pattern.__class__.__name__.__eq__, ["type"], true]
    - [match_type,   Match.__class__.__name__.__eq__,   ["type"], true]

# ---------------------------------------------------------------------------
# compile function __class__.__name__ — 'function'
# re_extra4 checks compile.__module__; re_extra72 checks compile.__qualname__.
# No prior spec checks compile.__class__.__name__ directly.
# ---------------------------------------------------------------------------

table re_extra73.compile_class_name:
  description: "re.compile is a plain Python function"
  kind: python_call_eq
  category: function_identity
  id_prefix: recode73

  columns: [id, function, args, expected]
  rows:
    - [class_name, compile.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# Pattern and Match __dict__ membership — C method presence
# Pattern and Match are C types; their methods are C method_descriptors
# stored in their __dict__. No prior re spec checks __dict__ membership.
# ---------------------------------------------------------------------------

table re_extra73.Pattern_Match_dict_contains:
  description: "re.Pattern and re.Match __dict__ contain their C method implementations"
  kind: python_call_eq
  category: class_dict
  id_prefix: recode73

  columns: [id, function, args, expected]
  rows:
    - [pattern_match,  "Pattern.__dict__.__contains__", ["match"],  true]
    - [pattern_search, "Pattern.__dict__.__contains__", ["search"], true]
    - [match_group,    "Match.__dict__.__contains__",   ["group"],  true]
    - [match_span,     "Match.__dict__.__contains__",   ["span"],   true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra73.Pattern.name_eq:
  description: "re.Pattern.__name__ == 'Pattern'"
  category: class_names
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra73.Match.name_eq:
  description: "re.Match.__name__ == 'Match'"
  category: class_names
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra73.Pattern.class_is_type:
  description: "re.Pattern.__class__.__name__ == 'type' — Pattern is a type object"
  category: class_names
  kind: python_call_eq
  function: Pattern.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant re_extra73.Match.class_is_type:
  description: "re.Match.__class__.__name__ == 'type' — Match is a type object"
  category: class_names
  kind: python_call_eq
  function: Match.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant re_extra73.compile.class_function:
  description: "re.compile.__class__.__name__ == 'function' — compile is a Python function"
  category: function_identity
  kind: python_call_eq
  function: compile.__class__.__name__.__eq__
  args: ["function"]
  expected: true
