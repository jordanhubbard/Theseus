spec: theseus_functools_cr5
version: ">=3.9"
backend: python_cleanroom(theseus_functools_cr5)
blocks: functools

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html"
  notes:
    - "Clean-room extended functools utilities. Do NOT import functools."
    - "total_ordering: class decorator to fill in missing comparison methods."
    - "singledispatch: register function implementations for different types."
    - "cached_property: descriptor that computes property value once and caches it."
    - "functools5_total_ordering(): class with __eq__ and __lt__ gets __gt__ via total_ordering — True."
    - "functools5_singledispatch(): singledispatch(str) dispatch works — True."
    - "functools5_cached_property(): cached_property computes once and caches — True."
    - "Zero-arg invariant signatures — def functools5_total_ordering(): return bool"
    - "total_ordering: fill in __le__, __ge__, __gt__ from __eq__ + one of __lt__/__le__/__gt__/__ge__."
    - "singledispatch: @singledispatch marks base; @f.register(type) overrides for that type."
    - "cached_property: on first access, compute and store in instance __dict__; reuse after."
    - "Export: total_ordering, singledispatch, singledispatchmethod, cached_property, reduce, partial, wraps."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_functools_cr5.total_ordering:
  description: "total_ordering fills in missing comparison methods"
  category: total_ordering
  kind: python_call_eq
  function: functools5_total_ordering
  args: []
  expected: true

invariant theseus_functools_cr5.singledispatch:
  description: "singledispatch dispatch works for registered types"
  category: singledispatch
  kind: python_call_eq
  function: functools5_singledispatch
  args: []
  expected: true

invariant theseus_functools_cr5.cached_property:
  description: "cached_property computes once and caches result"
  category: cached_property
  kind: python_call_eq
  function: functools5_cached_property
  args: []
  expected: true
