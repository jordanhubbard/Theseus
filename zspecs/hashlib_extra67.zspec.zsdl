spec: hashlib_extra67
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_blake2/blake2module.c"
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra66.zspec.zsdl — covers new.__code__.co_name ('__hash_new') / file_digest.__code__.co_name / new.__code__.co_argcount==1 / file_digest.__code__.co_argcount==2 / blake2b.__doc__.__contains__('object') / blake2s.__doc__.__contains__('object') (table + invariants)."
    - "hashlib_extra65.zspec.zsdl — covers new.__defaults__.__class__.__name__.__eq__('NoneType') / file_digest.__defaults__.__class__.__name__.__eq__('NoneType') / new.__code__.__class__.__name__.__eq__('code') / file_digest.__code__.__class__.__name__.__eq__('code') / blake2b.__doc__.__contains__('hash') (table + invariants)."
    - "hashlib_extra64.zspec.zsdl — covers hashlib.new and file_digest __annotations__.__class__.__name__.__eq__('dict') / __annotations__.__len__()==0 / new.__globals__.__class__.__name__.__eq__('dict') / new.__globals__.__contains__('new') / blake2b.__doc__.__contains__('BLAKE2b') (table + invariants)."
    - "hashlib_extra63.zspec.zsdl — covers blake2b/blake2s method descriptor __qualname__.__eq__ string values for update/digest/hexdigest/copy (blake2b) and update/digest/hexdigest (blake2s)."
    - "hashlib_extra62.zspec.zsdl — covers hashlib.__spec__.origin.__class__.__name__.__eq__('str') / __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') / __spec__.has_location==True / __loader__.__class__.__name__.__len__()==16 (table + invariants)."
    - "hashlib_extra61.zspec.zsdl — covers hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "hashlib_extra60.zspec.zsdl — covers hashlib.__all__.__contains__ for sha256/sha1/sha512/sha3_256 (table); blake2b/blake2s/md5/sha1 __doc__.__class__.__qualname__.__eq__('str'); __all__.__contains__('algorithms_guaranteed') (invariant)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra66; it does NOT duplicate invariants present in those files."
    - "Wave 231 theme: __code__.co_varnames / co_filename / co_flags chains for Python functions + algorithms_guaranteed membership checks."
    - "hashlib.new.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple of local variable names including parameters. new is a pure Python function in Lib/hashlib.py so co_varnames exists. No prior hashlib spec checks new.__code__.co_varnames in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_varnames.__class__.__name__ == 'tuple' — same reasoning as new. No prior hashlib spec checks file_digest.__code__.co_varnames. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__code__.co_varnames[0] == 'name' — new is defined as __hash_new(name, string=b'', **kwargs) in Lib/hashlib.py; the first element of co_varnames is the first parameter 'name'. No prior hashlib spec checks new.__code__.co_varnames[0]. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_varnames[0] == 'fileobj' — file_digest is defined as file_digest(fileobj, digest, /) in Lib/hashlib.py; co_varnames[0] is 'fileobj'. No prior hashlib spec checks file_digest.__code__.co_varnames[0]. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__code__.co_filename.__contains__('.py') == True — co_filename records the source file path for the code object; since new is defined in Lib/hashlib.py the filename ends in '.py'. No prior hashlib spec checks new.__code__.co_filename in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_filename.__contains__('.py') == True — same reasoning as new. No prior hashlib spec checks file_digest.__code__.co_filename. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'frozenset' — algorithms_guaranteed is documented as a frozenset of hash algorithm names that are always present regardless of platform. No prior hashlib spec checks algorithms_guaranteed.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha256') == True — sha256 is listed in the Python docs as one of the guaranteed algorithms. No prior hashlib spec checks algorithms_guaranteed.__contains__ for any algorithm name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('md5') / __contains__('sha1') / __contains__('sha512') == True — all three are in algorithms_guaranteed per the Python docs. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new and file_digest __code__.co_varnames class name
#
# Wave 231 theme: __code__.co_varnames chains for Python functions.
#
# co_varnames is a tuple containing parameter names followed by local variable
# names for a Python code object. Since new and file_digest are both pure
# Python functions in Lib/hashlib.py, their __code__ objects have co_varnames
# as a tuple. No prior hashlib spec checks co_varnames in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra67.python_func_code_co_varnames_class:
  description: "hashlib.new.__code__.co_varnames.__class__.__name__=='tuple' and file_digest.__code__.co_varnames.__class__.__name__=='tuple' — co_varnames is always a tuple of local variable names for a Python code object; both new and file_digest are pure Python functions in Lib/hashlib.py so co_varnames is a tuple; no prior hashlib spec checks co_varnames in any form; first co_varnames anchor for hashlib"
  kind: python_call_eq
  category: code_objects
  id_prefix: hashlibcode3_67

  columns: [id, function, args, expected]
  rows:
    - [new_co_varnames_class_name,         new.__code__.co_varnames.__class__.__name__.__eq__,         ["tuple"], true]
    - [file_digest_co_varnames_class_name, file_digest.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true]

# ---------------------------------------------------------------------------
# hashlib.new and file_digest __code__.co_varnames first element
#
# Wave 231 theme: __code__.co_varnames[0] for Python functions.
#
# new is internally defined as __hash_new(name, string=b'', **kwargs), so
# co_varnames[0] == 'name'. file_digest is defined as
# file_digest(fileobj, digest, /), so co_varnames[0] == 'fileobj'.
# The [0] subscript in the function attribute chain requires double-quoting
# in table rows per ZSDL rules. No prior hashlib spec checks co_varnames[0].
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra67.python_func_code_co_varnames_first_arg:
  description: "hashlib.new.__code__.co_varnames[0].__eq__('name') and file_digest.__code__.co_varnames[0].__eq__('fileobj') — new is defined as __hash_new(name, string=b'', **kwargs) so co_varnames[0]=='name'; file_digest is defined as file_digest(fileobj, digest, /) so co_varnames[0]=='fileobj'; no prior hashlib spec checks co_varnames[0] for any hashlib function; first co_varnames element anchor for hashlib"
  kind: python_call_eq
  category: code_objects
  id_prefix: hashlibcode3_67

  columns: [id, function, args, expected]
  rows:
    - [new_co_varnames_0_name,         "new.__code__.co_varnames[0].__eq__",         ["name"],    true]
    - [file_digest_co_varnames_0_fileobj, "file_digest.__code__.co_varnames[0].__eq__", ["fileobj"], true]

# ---------------------------------------------------------------------------
# hashlib.new and file_digest __code__.co_filename contains '.py'
#
# Wave 231 theme: __code__.co_filename chains for Python functions.
#
# co_filename records the source file path from which the code object was
# compiled. Since new and file_digest are both defined in Lib/hashlib.py,
# co_filename ends in '.py'. No prior hashlib spec checks co_filename for any
# hashlib function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra67.python_func_code_co_filename_contains_py:
  description: "hashlib.new.__code__.co_filename.__contains__('.py') and file_digest.__code__.co_filename.__contains__('.py') — co_filename records the source file path; both functions are defined in Lib/hashlib.py so co_filename ends in '.py'; no prior hashlib spec checks co_filename for any hashlib function; first co_filename anchor for hashlib"
  kind: python_call_eq
  category: code_objects
  id_prefix: hashlibcode3_67

  columns: [id, function, args, expected]
  rows:
    - [new_co_filename_contains_py,         new.__code__.co_filename.__contains__,         [".py"], true]
    - [file_digest_co_filename_contains_py, file_digest.__code__.co_filename.__contains__, [".py"], true]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed membership checks
#
# Wave 231 theme: module-level frozenset membership checks.
#
# hashlib.algorithms_guaranteed is a frozenset of hash algorithm names that
# are always available regardless of platform. sha256, md5, sha1, sha512 are
# all in the guaranteed set per the Python documentation. No prior hashlib spec
# checks algorithms_guaranteed.__contains__ for any algorithm name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra67.algorithms_guaranteed_contains:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256'/'md5'/'sha1'/'sha512') == True — algorithms_guaranteed is a frozenset of hash names always available regardless of platform; sha256, md5, sha1, and sha512 are all listed as guaranteed in the Python docs; no prior hashlib spec checks algorithms_guaranteed.__contains__ for any algorithm name; first membership anchor for algorithms_guaranteed"
  kind: python_call_eq
  category: module_constants
  id_prefix: hashlibcode3_67

  columns: [id, function, args, expected]
  rows:
    - [algorithms_guaranteed_sha256, algorithms_guaranteed.__contains__, ["sha256"], true]
    - [algorithms_guaranteed_md5,    algorithms_guaranteed.__contains__, ["md5"],    true]
    - [algorithms_guaranteed_sha1,   algorithms_guaranteed.__contains__, ["sha1"],   true]
    - [algorithms_guaranteed_sha512, algorithms_guaranteed.__contains__, ["sha512"], true]

# ---------------------------------------------------------------------------
# hashlib.new.__code__.co_varnames.__class__.__name__.__eq__('tuple') — standalone
#
# hashlib.new is a pure Python function in Lib/hashlib.py. The code object's
# co_varnames attribute is always a tuple for Python functions — it contains
# the names of parameters followed by local variable names. The tuple class
# identity for co_varnames confirms the code object structure. No prior hashlib
# spec checks new.__code__.co_varnames in any form. First co_varnames anchor
# for any hashlib function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra67.new_co_varnames_tuple:
  description: "hashlib.new.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is always a tuple for Python code objects containing parameter and local variable names; new is a pure Python function so co_varnames is a tuple; no prior hashlib spec checks new.__code__.co_varnames; first co_varnames anchor for any hashlib function"
  category: code_objects
  kind: python_call_eq
  function: new.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__code__.co_varnames[0] == 'name' — standalone
#
# hashlib.new is defined internally as __hash_new(name, string=b'', **kwargs).
# The first element of co_varnames is the first parameter 'name'. This anchors
# the first parameter name for hashlib.new via the co_varnames subscript chain.
# The function attribute path contains '[0]' so it uses the method_chain approach
# in invariant form; the standalone invariant uses the quoted function form for
# the table, but here we chain via method_chain_args.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra67.new_co_varnames_first_name:
  description: "hashlib.new.__code__.co_varnames[0].__eq__('name') == True — new is defined as __hash_new(name, string=b'', **kwargs) in Lib/hashlib.py; co_varnames[0] is the first parameter 'name'; no prior hashlib spec checks co_varnames[0] for any hashlib function; first co_varnames element anchor for hashlib.new"
  category: code_objects
  kind: python_call_eq
  function: new.__code__.co_varnames
  method_chain: ["__getitem__", "__eq__"]
  method_chain_args: [[0], ["name"]]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha256') — standalone
#
# hashlib.algorithms_guaranteed is documented as a frozenset of hash algorithm
# names guaranteed to be available on all Python platforms. sha256 is the most
# widely used hash function in the set and a reliable anchor for testing
# frozenset membership. No prior hashlib spec checks algorithms_guaranteed
# __contains__ for any keyword. First membership check for
# algorithms_guaranteed. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra67.algorithms_guaranteed_sha256:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256') == True — algorithms_guaranteed is a frozenset of hash names always available; sha256 is guaranteed per Python docs and is the most widely used member of the set; no prior hashlib spec checks algorithms_guaranteed.__contains__ for any name; first membership anchor for algorithms_guaranteed"
  category: module_constants
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__ == 'frozenset' — standalone
#
# hashlib.algorithms_guaranteed is a module-level attribute of type frozenset.
# The Python docs describe it as a frozenset. This verifies the type identity
# of algorithms_guaranteed, complementing the membership checks above.
# No prior hashlib spec checks algorithms_guaranteed.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra67.algorithms_guaranteed_class_frozenset:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('frozenset') == True — algorithms_guaranteed is documented as a frozenset of hash algorithm names; this verifies the type identity complementing the membership checks; no prior hashlib spec checks algorithms_guaranteed.__class__.__name__; first type identity anchor for algorithms_guaranteed"
  category: module_constants
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true
