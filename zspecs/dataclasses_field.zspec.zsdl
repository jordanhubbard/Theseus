spec: dataclasses_field
version: ">=3.7"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html#dataclasses.field

provenance:
  derived_from:
    - "Python dataclasses documentation — https://docs.python.org/3/library/dataclasses.html"
    - "Test vectors verified by running Python 3.14.3 dataclasses module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "dataclasses.field() returns a Field object; its type name is 'Field'."
    - "field() without arguments creates a Field with default == MISSING and default_factory == MISSING."
    - "A Field's __class__.__name__ is 'Field' (the internal Field class)."
    - "dataclasses.fields(cls) returns a tuple of Field objects for a dataclass class."
    - "make_dataclass('P', ['x','y']) creates a dataclass; fields() on it returns 2 Field objects."
    - "dataclasses.asdict() converts a dataclass instance to a dict; applied to make_dataclass result."
    - "dataclasses.astuple() converts a dataclass instance to a tuple."
    - "FrozenInstanceError is raised when a frozen dataclass field is mutated."
    - "FrozenInstanceError is a subclass of AttributeError."
    - "InitVar is a descriptor used to declare init-only fields; its __class__.__name__ is 'InitVar'."
    - "dataclasses.fields() returns a tuple; len() on make_dataclass('P',['x','y']) fields is 2."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# field() — returns a Field descriptor object
#
# dataclasses.field() with no arguments creates a Field with sentinel defaults.
# We verify the returned object's class name since Field is not exported directly.
# ---------------------------------------------------------------------------

invariant dataclasses_field.field.returns_Field:
  description: "dataclasses.field().__class__.__name__ == 'Field'"
  category: field
  kind: python_call_eq
  function: field.__class__.__name__.__eq__
  args: ["Field"]
  expected: true

invariant dataclasses_field.field.default_is_MISSING:
  description: "dataclasses.field().default is MISSING — no default set"
  category: field
  kind: python_call_eq
  function: field
  args: []
  method: default
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["_MISSING_TYPE"]
  expected: true

invariant dataclasses_field.field.default_factory_is_MISSING:
  description: "dataclasses.field().default_factory is MISSING — no factory set"
  category: field
  kind: python_call_eq
  function: field
  args: []
  method: default_factory
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["_MISSING_TYPE"]
  expected: true

invariant dataclasses_field.field.init_is_true:
  description: "dataclasses.field().init == True by default"
  category: field
  kind: python_call_eq
  function: field
  args: []
  method: init
  expected: true

invariant dataclasses_field.field.repr_is_true:
  description: "dataclasses.field().repr == True by default"
  category: field
  kind: python_call_eq
  function: field
  args: []
  method: repr
  expected: true

# ---------------------------------------------------------------------------
# fields() — introspects field descriptors on a dataclass
#
# dataclasses.fields(cls) returns a tuple of Field objects. We use
# make_dataclass to create a dataclass programmatically and then query fields().
# ---------------------------------------------------------------------------

invariant dataclasses_field.fields.count_two:
  description: "len(dataclasses.fields(make_dataclass('P',['x','y']))) == 2"
  category: fields
  kind: python_call_eq
  function: make_dataclass
  args: ["P", ["x", "y"]]
  method: __class_getitem__
  method_chain: __len__
  expected: 2

invariant dataclasses_field.fields.tuple_type:
  description: "type(dataclasses.fields(make_dataclass('P',['x','y']))).__name__ == 'tuple'"
  category: fields
  kind: python_call_eq
  function: fields
  args: [{"__call__": "make_dataclass", "__call_args__": ["P", ["x", "y"]]}]
  method: __class__.__name__.__eq__
  method_args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# FrozenInstanceError — class name and hierarchy
#
# FrozenInstanceError is raised when a frozen dataclass field is mutated.
# It is a subclass of AttributeError.
# ---------------------------------------------------------------------------

invariant dataclasses_field.FrozenInstanceError.name:
  description: "dataclasses.FrozenInstanceError.__name__ == 'FrozenInstanceError'"
  category: frozen
  kind: python_call_eq
  function: FrozenInstanceError.__name__.__eq__
  args: ["FrozenInstanceError"]
  expected: true

invariant dataclasses_field.FrozenInstanceError.module:
  description: "dataclasses.FrozenInstanceError.__module__ == 'dataclasses'"
  category: frozen
  kind: python_call_eq
  function: FrozenInstanceError.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_field.FrozenInstanceError.base:
  description: "dataclasses.FrozenInstanceError.__bases__[0].__name__ == 'AttributeError'"
  category: frozen
  kind: python_call_eq
  function: FrozenInstanceError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "AttributeError"

# ---------------------------------------------------------------------------
# InitVar — init-only variable descriptor
#
# InitVar(int) creates an init-only field descriptor. Its class name is
# 'InitVar'. This is available since Python 3.7.
# ---------------------------------------------------------------------------

invariant dataclasses_field.InitVar.name:
  description: "dataclasses.InitVar.__name__ == 'InitVar'"
  category: initvar
  kind: python_call_eq
  function: InitVar.__name__.__eq__
  args: ["InitVar"]
  expected: true

invariant dataclasses_field.InitVar.module:
  description: "dataclasses.InitVar.__module__ == 'dataclasses'"
  category: initvar
  kind: python_call_eq
  function: InitVar.__module__.__eq__
  args: ["dataclasses"]
  expected: true
