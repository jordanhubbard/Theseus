spec: io_extra285
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/textio.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "io_extra284 covers io.RawIOBase and io.BufferedIOBase method __qualname__ values."
    - "This spec focuses on io.TextIOWrapper class identity and method __qualname__ values."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' — the public class name."
    - "io.TextIOWrapper.__module__ == '_io' — TextIOWrapper is defined in the C extension module '_io'."
    - "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — simple top-level class, no nesting."
    - "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — C-level base class name."
    - "io.TextIOWrapper.read.__qualname__ == 'TextIOWrapper.read' — method qualname uses the class name."
    - "io.TextIOWrapper.readline.__qualname__ == 'TextIOWrapper.readline' — consistent qualname pattern."
    - "io.TextIOWrapper.write.__qualname__ == 'TextIOWrapper.write' — consistent qualname pattern."
    - "io.TextIOWrapper.seek.__qualname__ == 'TextIOWrapper.seek' — consistent qualname pattern."
    - "io.TextIOWrapper.__class__.__name__ == 'type' — TextIOWrapper is a plain type, not an ABC."
    - "io.TextIOWrapper.read is a method_descriptor at the class level (not a function)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.TextIOWrapper method __qualname__ — method_descriptor objects
# Qualnames follow 'TextIOWrapper.<method>' (using public class name, not C name)
# ---------------------------------------------------------------------------

table io_extra285.textiowrapper_method_qualnames:
  description: "io.TextIOWrapper method __qualname__ values — all follow 'TextIOWrapper.<method>'"
  kind: python_call_eq
  category: method_identity
  id_prefix: tw_qn

  columns: [id, function, args, expected, description]
  rows:
    - [read,     TextIOWrapper.read.__qualname__.__eq__,     ["TextIOWrapper.read"],     true, "io.TextIOWrapper.read.__qualname__ == 'TextIOWrapper.read'"]
    - [readline, TextIOWrapper.readline.__qualname__.__eq__, ["TextIOWrapper.readline"], true, "io.TextIOWrapper.readline.__qualname__ == 'TextIOWrapper.readline'"]
    - [write,    TextIOWrapper.write.__qualname__.__eq__,    ["TextIOWrapper.write"],    true, "io.TextIOWrapper.write.__qualname__ == 'TextIOWrapper.write'"]
    - [seek,     TextIOWrapper.seek.__qualname__.__eq__,     ["TextIOWrapper.seek"],     true, "io.TextIOWrapper.seek.__qualname__ == 'TextIOWrapper.seek'"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper method descriptor type — method_descriptor at class level
# ---------------------------------------------------------------------------

table io_extra285.textiowrapper_method_descriptor_type:
  description: "io.TextIOWrapper methods are method_descriptor objects when accessed on the class"
  kind: python_call_eq
  category: method_identity
  id_prefix: tw_desc

  columns: [id, function, args, expected, description]
  rows:
    - [read,     TextIOWrapper.read.__class__.__name__.__eq__,     ["method_descriptor"], true, "io.TextIOWrapper.read is a method_descriptor"]
    - [readline, TextIOWrapper.readline.__class__.__name__.__eq__, ["method_descriptor"], true, "io.TextIOWrapper.readline is a method_descriptor"]
    - [write,    TextIOWrapper.write.__class__.__name__.__eq__,    ["method_descriptor"], true, "io.TextIOWrapper.write is a method_descriptor"]
    - [seek,     TextIOWrapper.seek.__class__.__name__.__eq__,     ["method_descriptor"], true, "io.TextIOWrapper.seek is a method_descriptor"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper class identity — name, module, qualname
# ---------------------------------------------------------------------------

invariant io_extra285.TextIOWrapper.class_name:
  description: "io.TextIOWrapper.__name__ == 'TextIOWrapper' — public name of the concrete text I/O class"
  category: class_metadata
  kind: python_call_eq
  function: TextIOWrapper.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra285.TextIOWrapper.module:
  description: "io.TextIOWrapper.__module__ == '_io' — TextIOWrapper is defined in the C extension module '_io'"
  category: class_metadata
  kind: python_call_eq
  function: TextIOWrapper.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra285.TextIOWrapper.qualname:
  description: "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — simple top-level class name, no nesting"
  category: class_metadata
  kind: python_call_eq
  function: TextIOWrapper.__qualname__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra285.TextIOWrapper.base_class_name:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — C-level base class of TextIOWrapper"
  category: class_metadata
  kind: python_call_eq
  function: TextIOWrapper.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["_TextIOBase"]
  expected: true

invariant io_extra285.TextIOWrapper.metaclass:
  description: "io.TextIOWrapper.__class__.__name__ == 'type' — TextIOWrapper is a plain type, not an ABCMeta"
  category: class_metadata
  kind: python_call_eq
  function: TextIOWrapper.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra285.TextIOWrapper.base_module:
  description: "io.TextIOWrapper.__bases__[0].__module__ == '_io' — base class also lives in the C extension"
  category: class_metadata
  kind: python_call_eq
  function: TextIOWrapper.__bases__.__getitem__
  args: [0]
  method: __module__.__eq__
  method_args: ["_io"]
  expected: true
