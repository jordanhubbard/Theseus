spec: asyncio_extra2206
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-stream.html"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
    - "asyncio.zspec.zsdl"
    - "asyncio_extra.zspec.zsdl"
    - "asyncio_extra2.zspec.zsdl"
  notes:
    - "Wave _extra2206: rich comparison operator protocol dict-presence checks for asyncio classes."
    - "Covers __lt__, __le__, __gt__, __ge__, __eq__, __ne__ presence in Task, Future, Event, Lock, Queue, Semaphore, Condition, StreamReader, BoundedSemaphore class dicts."
    - "None of the asyncio synchronization or task classes define comparison operators in their own __dict__."
    - "asyncio.Task and asyncio.Future are coroutine/future primitives; they do not implement rich comparison."
    - "asyncio.Lock, asyncio.Event, asyncio.Semaphore, asyncio.Condition, asyncio.BoundedSemaphore are pure-Python sync primitives without comparison protocols."
    - "asyncio.Queue is a FIFO queue; it does not define comparison operators."
    - "asyncio.StreamReader is a bytes-stream reader; it does not define comparison operators."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table asyncio_extra2206.Task_comparison_protocol:
  description: "asyncio.Task __lt__/__le__/__gt__/__ge__/__eq__/__ne__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2206

  columns: [id, function, args, expected]
  rows:
    - ["as2206001", "asyncio.Task.__dict__.__contains__", ["__lt__"], false]
    - ["as2206002", "asyncio.Task.__dict__.__contains__", ["__le__"], false]
    - ["as2206003", "asyncio.Task.__dict__.__contains__", ["__gt__"], false]
    - ["as2206004", "asyncio.Task.__dict__.__contains__", ["__ge__"], false]
    - ["as2206005", "asyncio.Task.__dict__.__contains__", ["__eq__"], false]
    - ["as2206006", "asyncio.Task.__dict__.__contains__", ["__ne__"], false]

