spec: sys_extra28
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
    - "sys_extra7.zspec.zsdl — covers __qualname__ for exc_info/getsizeof/getrecursionlimit/setrecursionlimit/intern in a table; NOT their __module__ attributes."
    - "sys_extra27.zspec.zsdl — covers __module__ for exc_info/getsizeof/getrecursionlimit/setrecursionlimit/intern and __class__.__name__ for stdin/stdout/stderr; NOT __qualname__ for getdefaultencoding/getfilesystemencoding/getsizeof/intern/exc_info/exit/getrecursionlimit/setrecursionlimit."
  notes:
    - "This spec extends sys.zspec.zsdl through sys_extra27.zspec.zsdl."
    - "Prior specs covered: sys.__name__/__package__, sys.version/__class__.__name__, sys.platform/__class__.__name__, sys.path/__class__.__name__, sys.argv/__class__.__name__, sys.modules/__class__.__name__, sys.executable/__class__.__name__, sys.getrecursionlimit()==1000, sys.maxsize/__class__.__name__, sys.maxunicode/__class__.__name__, sys.byteorder/__class__.__name__, sys.getdefaultencoding/__name__, sys.getfilesystemencoding/__name__, sys.getsizeof/__name__, sys.intern/__name__, sys.exc_info/__name__, sys.exit/__name__, sys.stdin/__class__.__name__, sys.stdout/__class__.__name__, sys.stderr/__class__.__name__, sys.version_info/__class__.__name__, various __qualname__ and __module__ checks."
    - "This spec covers: __qualname__ for sys.getdefaultencoding, sys.getfilesystemencoding, sys.getsizeof, sys.intern, sys.exc_info, sys.exit, sys.getrecursionlimit, sys.setrecursionlimit; and __module__ for sys.getdefaultencoding, sys.getfilesystemencoding, sys.getsizeof, sys.exit."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sys built-in function __qualname__ attributes
#
# sys_extra7 covers __qualname__ for exc_info, getsizeof, getrecursionlimit,
# setrecursionlimit, and intern in a table. No prior sys spec covers __qualname__
# for getdefaultencoding, getfilesystemencoding, or exit. For built-in functions
# in sys, __qualname__ equals the bare function name (same as __name__).
# ---------------------------------------------------------------------------

table sys_extra28.builtin_function_qualnames:
  description: "__qualname__ for sys built-in functions equals the bare function name"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fnqn28

  columns: [id, function, args, expected]
  rows:
    - [getdefaultencoding,   getdefaultencoding.__qualname__.__eq__,   ["getdefaultencoding"],   true]
    - [getfilesystemencoding, getfilesystemencoding.__qualname__.__eq__, ["getfilesystemencoding"], true]
    - [getsizeof,            getsizeof.__qualname__.__eq__,            ["getsizeof"],            true]
    - [intern,               intern.__qualname__.__eq__,               ["intern"],               true]
    - [exc_info,             exc_info.__qualname__.__eq__,             ["exc_info"],             true]
    - [exit,                 exit.__qualname__.__eq__,                 ["exit"],                 true]
    - [getrecursionlimit,    getrecursionlimit.__qualname__.__eq__,    ["getrecursionlimit"],    true]
    - [setrecursionlimit,    setrecursionlimit.__qualname__.__eq__,    ["setrecursionlimit"],    true]

# ---------------------------------------------------------------------------
# sys built-in function __module__ attributes — getdefaultencoding, getfilesystemencoding,
# getsizeof, exit
#
# sys_extra27 covers __module__ for exc_info, getsizeof, getrecursionlimit,
# setrecursionlimit, and intern. No prior sys spec covers __module__ for
# getdefaultencoding, getfilesystemencoding, or exit. All are built-in functions
# attributed to the 'sys' module, so their __module__ is 'sys'.
# ---------------------------------------------------------------------------

table sys_extra28.extra_builtin_function_modules:
  description: "__module__ for additional sys built-in functions is 'sys'"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fnmod28

  columns: [id, function, args, expected]
  rows:
    - [getdefaultencoding,    getdefaultencoding.__module__.__eq__,    ["sys"], true]
    - [getfilesystemencoding, getfilesystemencoding.__module__.__eq__, ["sys"], true]
    - [getsizeof,             getsizeof.__module__.__eq__,             ["sys"], true]
    - [exit,                  exit.__module__.__eq__,                  ["sys"], true]

# ---------------------------------------------------------------------------
# Standalone invariants — __qualname__ for getdefaultencoding and getfilesystemencoding
# ---------------------------------------------------------------------------

invariant sys_extra28.getdefaultencoding.qualname:
  description: "sys.getdefaultencoding.__qualname__ == 'getdefaultencoding' — qualname equals bare function name"
  category: function_attrs
  kind: python_call_eq
  function: getdefaultencoding.__qualname__.__eq__
  args: ["getdefaultencoding"]
  expected: true

invariant sys_extra28.getfilesystemencoding.qualname:
  description: "sys.getfilesystemencoding.__qualname__ == 'getfilesystemencoding' — qualname equals bare function name"
  category: function_attrs
  kind: python_call_eq
  function: getfilesystemencoding.__qualname__.__eq__
  args: ["getfilesystemencoding"]
  expected: true

invariant sys_extra28.getsizeof.qualname:
  description: "sys.getsizeof.__qualname__ == 'getsizeof' — qualname equals bare function name"
  category: function_attrs
  kind: python_call_eq
  function: getsizeof.__qualname__.__eq__
  args: ["getsizeof"]
  expected: true

invariant sys_extra28.intern.qualname:
  description: "sys.intern.__qualname__ == 'intern' — qualname equals bare function name"
  category: function_attrs
  kind: python_call_eq
  function: intern.__qualname__.__eq__
  args: ["intern"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — __qualname__ for exc_info, exit, getrecursionlimit, setrecursionlimit
# ---------------------------------------------------------------------------

invariant sys_extra28.exc_info.qualname:
  description: "sys.exc_info.__qualname__ == 'exc_info' — qualname equals bare function name"
  category: function_attrs
  kind: python_call_eq
  function: exc_info.__qualname__.__eq__
  args: ["exc_info"]
  expected: true

invariant sys_extra28.exit.qualname:
  description: "sys.exit.__qualname__ == 'exit' — qualname equals bare function name"
  category: function_attrs
  kind: python_call_eq
  function: exit.__qualname__.__eq__
  args: ["exit"]
  expected: true

invariant sys_extra28.getrecursionlimit.qualname:
  description: "sys.getrecursionlimit.__qualname__ == 'getrecursionlimit' — qualname equals bare function name"
  category: function_attrs
  kind: python_call_eq
  function: getrecursionlimit.__qualname__.__eq__
  args: ["getrecursionlimit"]
  expected: true

invariant sys_extra28.setrecursionlimit.qualname:
  description: "sys.setrecursionlimit.__qualname__ == 'setrecursionlimit' — qualname equals bare function name"
  category: function_attrs
  kind: python_call_eq
  function: setrecursionlimit.__qualname__.__eq__
  args: ["setrecursionlimit"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — __module__ for additional built-in functions
# ---------------------------------------------------------------------------

invariant sys_extra28.getdefaultencoding.module:
  description: "sys.getdefaultencoding.__module__ == 'sys' — built-in function attributed to the sys module"
  category: function_attrs
  kind: python_call_eq
  function: getdefaultencoding.__module__.__eq__
  args: ["sys"]
  expected: true

invariant sys_extra28.getfilesystemencoding.module:
  description: "sys.getfilesystemencoding.__module__ == 'sys' — built-in function attributed to the sys module"
  category: function_attrs
  kind: python_call_eq
  function: getfilesystemencoding.__module__.__eq__
  args: ["sys"]
  expected: true

invariant sys_extra28.exit.module:
  description: "sys.exit.__module__ == 'sys' — built-in function attributed to the sys module"
  category: function_attrs
  kind: python_call_eq
  function: exit.__module__.__eq__
  args: ["sys"]
  expected: true
