error_model: python_exceptions

table itertools_extra520.doc_class_identity:
  description: "itertools class __doc__.__class__.__name__ == 'str' — all itertools C types have string docstrings"
  kind: python_call_eq
  category: doc_class
  id_prefix: it520dc

  columns: [id, function, args, expected]
  rows:
    - [it520dc001, chain.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [it520dc002, cycle.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [it520dc003, product.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [it520dc004, count.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [it520dc005, combinations.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [it520dc006, permutations.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [it520dc007, groupby.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [it520dc008, islice.__doc__.__class__.__name__.__eq__,       ["str"], true]
    - [it520dc009, compress.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [it520dc010, repeat.__doc__.__class__.__name__.__eq__,       ["str"], true]
    - [it520dc011, starmap.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [it520dc012, accumulate.__doc__.__class__.__name__.__eq__,   ["str"], true]
