spec: netrc_extra
version: ">=3.9"
backend: python_module(netrc)

docs: https://docs.python.org/3/library/netrc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/netrc.html — Python netrc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/netrc.py"
  notes:
    - "This spec covers netrc behaviors not in netrc.zspec.zsdl."
    - "netrc.netrc is the main class; it parses .netrc files and exposes hosts, macros attributes."
    - "netrc.netrc requires a valid file path argument; it cannot be called without I/O."
    - "netrc.NetrcParseError is raised on parse errors; it inherits directly from Exception."
    - "NetrcParseError carries msg, filename, and lineno attributes per the documented API."
    - "netrc.netrc.authenticators is an instance method accessible at class level with __name__ == 'authenticators'."
    - "netrc.netrc.hosts is an instance attribute (dict); it is not accessible at class level without an instance."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# netrc class — name and module affiliation
# ---------------------------------------------------------------------------

invariant netrc_extra.netrc.class_name:
  description: "netrc.netrc.__name__ == 'netrc'"
  category: classnames
  kind: python_call_eq
  function: netrc.__name__.__eq__
  args: ["netrc"]
  expected: true

invariant netrc_extra.netrc.module_name:
  description: "netrc.netrc.__module__ == 'netrc'"
  category: module
  kind: python_call_eq
  function: netrc.__module__.__eq__
  args: ["netrc"]
  expected: true

invariant netrc_extra.netrc.is_type:
  description: "type(netrc.netrc).__name__ == 'type' — netrc is a class"
  category: classnames
  kind: python_call_eq
  function: netrc.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# NetrcParseError class — name, module, and hierarchy
# ---------------------------------------------------------------------------

invariant netrc_extra.NetrcParseError.class_name:
  description: "netrc.NetrcParseError.__name__ == 'NetrcParseError'"
  category: classnames
  kind: python_call_eq
  function: NetrcParseError.__name__.__eq__
  args: ["NetrcParseError"]
  expected: true

invariant netrc_extra.NetrcParseError.module_name:
  description: "netrc.NetrcParseError.__module__ == 'netrc'"
  category: module
  kind: python_call_eq
  function: NetrcParseError.__module__.__eq__
  args: ["netrc"]
  expected: true

invariant netrc_extra.NetrcParseError.is_type:
  description: "type(netrc.NetrcParseError).__name__ == 'type' — NetrcParseError is a class"
  category: classnames
  kind: python_call_eq
  function: NetrcParseError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant netrc_extra.NetrcParseError.base_is_Exception:
  description: "netrc.NetrcParseError.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: NetrcParseError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# NetrcParseError.__bases__ length — exactly one base class
# ---------------------------------------------------------------------------

invariant netrc_extra.NetrcParseError.bases_len:
  description: "len(netrc.NetrcParseError.__bases__) == 1 — single direct base"
  category: hierarchy
  kind: python_call_eq
  function: NetrcParseError.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# netrc.netrc.authenticators — method name check
# ---------------------------------------------------------------------------

invariant netrc_extra.netrc.authenticators_name:
  description: "netrc.netrc.authenticators.__name__ == 'authenticators'"
  category: methods
  kind: python_call_eq
  function: netrc.authenticators.__name__.__eq__
  args: ["authenticators"]
  expected: true

# ---------------------------------------------------------------------------
# NetrcParseError standard exception methods
# ---------------------------------------------------------------------------

invariant netrc_extra.NetrcParseError.init_name:
  description: "netrc.NetrcParseError.__init__.__name__ == '__init__'"
  category: methods
  kind: python_call_eq
  function: NetrcParseError.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant netrc_extra.NetrcParseError.str_name:
  description: "netrc.NetrcParseError.__str__.__name__ == '__str__'"
  category: methods
  kind: python_call_eq
  function: NetrcParseError.__str__.__name__.__eq__
  args: ["__str__"]
  expected: true

# ---------------------------------------------------------------------------
# netrc module-level names
# ---------------------------------------------------------------------------

invariant netrc_extra.module.has_netrc_class:
  description: "netrc module exports a 'netrc' name that is a type"
  category: module
  kind: python_call_eq
  function: netrc.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant netrc_extra.module.has_NetrcParseError_class:
  description: "netrc module exports a 'NetrcParseError' name that is a type"
  category: module
  kind: python_call_eq
  function: NetrcParseError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Callable checks — both classes are callable (constructors)
# ---------------------------------------------------------------------------

invariant netrc_extra.netrc.netrc_callable:
  description: "netrc.netrc is callable (it is a class)"
  category: classnames
  kind: python_call_eq
  function: netrc.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant netrc_extra.NetrcParseError.callable:
  description: "netrc.NetrcParseError is callable (it is a class)"
  category: classnames
  kind: python_call_eq
  function: NetrcParseError.__class__.__name__.__eq__
  args: ["type"]
  expected: true
