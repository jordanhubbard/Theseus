spec: concurrent_futures_extra378
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All method __name__ values match the method's own identifier (no aliasing)"
    - "Verified: cancel, cancelled, running, done, result, exception, add_done_callback"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra378.future_method_names:
  description: "Verify __name__ attribute of concurrent.futures.Future state-related methods"
  kind: python_call_eq
  category: identity
  id_prefix: cf378n

  columns: [id, function, args, expected]
  rows:
    - [cf378n001, concurrent.futures.Future.cancel.__name__.__eq__, ["cancel"], true]
    - [cf378n002, concurrent.futures.Future.cancelled.__name__.__eq__, ["cancelled"], true]
    - [cf378n003, concurrent.futures.Future.running.__name__.__eq__, ["running"], true]
    - [cf378n004, concurrent.futures.Future.done.__name__.__eq__, ["done"], true]
    - [cf378n005, concurrent.futures.Future.result.__name__.__eq__, ["result"], true]
    - [cf378n006, concurrent.futures.Future.exception.__name__.__eq__, ["exception"], true]
    - [cf378n007, concurrent.futures.Future.add_done_callback.__name__.__eq__, ["add_done_callback"], true]
