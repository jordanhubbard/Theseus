spec: threading_extra62
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra61.zspec.zsdl."
    - "Wave 227 theme: class method __qualname__ equality checks — full string equality for methods not yet covered."
    - "Thread.start/run/join/is_alive __qualname__.__eq__ covered in extra11/24. Event.set/clear/wait/is_set __qualname__.__eq__ covered in extra12/24. Semaphore/__init__/acquire/release/Condition/__init__/enter/wait/notify/notify_all covered in extra11/25/52. Timer.run/cancel covered in extra14."
    - "NOT YET COVERED by __qualname__.__eq__: Thread.__init__ (extra36/51 covered __len__ only), Thread.__repr__ (extra36 covered __len__ only), Event.__init__ (no prior spec covers Event.__init__.__qualname__ at all), Timer.__init__ (no prior spec covers Timer.__init__.__qualname__)."
    - "Thread.__init__.__qualname__ == 'Thread.__init__' (15 chars). Thread.__repr__.__qualname__ == 'Thread.__repr__' (15 chars). Both have __len__ checked in extra36 and extra51, but __eq__ not yet done."
    - "Event.__init__.__qualname__ == 'Event.__init__' (15 chars). No prior threading spec checks Event.__init__.__qualname__ at all (not __eq__, not __len__)."
    - "Timer.__init__.__qualname__ == 'Timer.__init__' (14 chars). No prior threading spec checks Timer.__init__.__qualname__ at all (Timer.run and Timer.cancel qualnames were covered in extra14, but not Timer.__init__)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread.__init__ and __repr__ __qualname__.__eq__ checks — extra62
#
# Wave 227 theme: class method __qualname__ equality checks.
#
# threading.Thread is a pure-Python class (Lib/threading.py).
#   Thread.__init__.__qualname__ == 'Thread.__init__' (15 chars)
#   Thread.__repr__.__qualname__ == 'Thread.__repr__' (15 chars)
#
# Prior specs:
# - extra36 covered Thread.__init__.__qualname__.__len__()==15
# - extra36 covered Thread.__repr__.__qualname__.__len__()==15
# - extra51 covered Thread.__init__.__qualname__.__len__()==15 (again)
# - extra11/24 covered Thread.start/run/join/is_alive __qualname__.__eq__
# But NO prior threading spec checks Thread.__init__/__repr__ by __eq__.
# New to extra62.
# ---------------------------------------------------------------------------

table threading_extra62.thread_dunder_qualnames:
  description: "Thread.__init__/__repr__.__qualname__.__eq__ checks — __len__ covered in extra36/51 but __eq__ not yet done; wave 227 method qualname equality; new to extra62"
  kind: python_call_eq
  category: qualname_equality
  id_prefix: thrdqual62

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_qualname_eq,
       Thread.__init__.__qualname__.__eq__,
       ["Thread.__init__"],
       true,
       "threading.Thread.__init__.__qualname__.__eq__('Thread.__init__') == True — Thread is a pure-Python class defined in Lib/threading.py; its __init__ accepts group/target/name/args/kwargs/daemon parameters; the qualname follows the 'ClassName.method_name' pattern: 'Thread.__init__' is 15 chars (7-char 'Thread.' prefix + 8-char '__init__'); prior specs extra36 and extra51 confirmed __qualname__.__len__()==15 but no prior threading spec has checked Thread.__init__.__qualname__.__eq__('Thread.__init__'); new to extra62"]
    - [thread_repr_qualname_eq,
       Thread.__repr__.__qualname__.__eq__,
       ["Thread.__repr__"],
       true,
       "threading.Thread.__repr__.__qualname__.__eq__('Thread.__repr__') == True — Thread.__repr__ is a pure-Python method that produces a readable string representation including the thread name, ident, daemon status, and alive status; its qualname is 'Thread.__repr__' (15 chars = 7-char 'Thread.' prefix + 8-char '__repr__'); same length as Thread.__init__ because both have 8-char dunder method names; prior spec extra36 confirmed __qualname__.__len__()==15 but no prior threading spec has checked Thread.__repr__.__qualname__.__eq__('Thread.__repr__'); new to extra62"]

# ---------------------------------------------------------------------------
# Event.__init__ __qualname__.__eq__ check — extra62
#
# Wave 227 theme: class method __qualname__ equality checks.
#
# threading.Event is a pure-Python class (Lib/threading.py).
# Event.__init__.__qualname__ == 'Event.__init__' (15 chars)
#
# Prior specs covered Event methods by __eq__:
# - Event.set/clear/wait (extra12)
# - Event.is_set (extra24)
# But NO prior threading spec checks Event.__init__.__qualname__ at all —
# neither __eq__ nor __len__. New to extra62.
# ---------------------------------------------------------------------------

table threading_extra62.event_init_qualname:
  description: "Event.__init__.__qualname__.__eq__('Event.__init__')==true — no prior threading spec checks Event.__init__.__qualname__; wave 227 method qualname equality; new to extra62"
  kind: python_call_eq
  category: qualname_equality
  id_prefix: thrdqual62

  columns: [id, function, args, expected, description]
  rows:
    - [event_init_qualname_eq,
       Event.__init__.__qualname__.__eq__,
       ["Event.__init__"],
       true,
       "threading.Event.__init__.__qualname__.__eq__('Event.__init__') == True — Event is a pure-Python synchronization primitive in Lib/threading.py that wraps a Condition; its __init__ creates the internal Condition and initializes the flag to False; the qualname follows the 'ClassName.method_name' pattern: 'Event.__init__' is 14 chars (6-char 'Event.' prefix + 8-char '__init__'); verified: threading.Event.__init__.__qualname__ == 'Event.__init__' (14 chars: E-v-e-n-t-.-_-_-i-n-i-t-_-_); no prior threading spec has checked Event.__init__.__qualname__ via __eq__ or __len__; new to extra62"]

# ---------------------------------------------------------------------------
# Timer.__init__ __qualname__.__eq__ check — extra62
#
# Wave 227 theme: class method __qualname__ equality checks.
#
# threading.Timer is a pure-Python class (Lib/threading.py) that extends
# Thread. Timer.__init__.__qualname__ == 'Timer.__init__' (14 chars)
#
# Prior specs covered Timer methods by __eq__:
# - Timer.run (extra14)
# - Timer.cancel (extra14)
# But NO prior threading spec checks Timer.__init__.__qualname__. New to extra62.
# ---------------------------------------------------------------------------

table threading_extra62.timer_init_qualname:
  description: "Timer.__init__.__qualname__.__eq__('Timer.__init__')==true — no prior threading spec checks Timer.__init__.__qualname__; wave 227 method qualname equality; new to extra62"
  kind: python_call_eq
  category: qualname_equality
  id_prefix: thrdqual62

  columns: [id, function, args, expected, description]
  rows:
    - [timer_init_qualname_eq,
       Timer.__init__.__qualname__.__eq__,
       ["Timer.__init__"],
       true,
       "threading.Timer.__init__.__qualname__.__eq__('Timer.__init__') == True — Timer is a pure-Python class in Lib/threading.py that extends Thread to call a function after a delay; Timer.__init__ accepts interval/function/args/kwargs parameters and sets up the cancellation event; its qualname is 'Timer.__init__' (14 chars = 6-char 'Timer.' prefix + 8-char '__init__'); prior specs extra14 covered Timer.run.__qualname__.__eq__('Timer.run') and Timer.cancel.__qualname__.__eq__('Timer.cancel') but no prior threading spec covers Timer.__init__.__qualname__; new to extra62"]

# ---------------------------------------------------------------------------
# Thread/Event/Timer method __qualname__.__class__.__name__ == 'str' — extra62
#
# Wave 227 theme: class method __qualname__ equality (depth-2 chain).
#
# Every pure-Python method qualname is a str object. The depth-2 chain
# __qualname__.__class__.__name__.__eq__('str') confirms this for methods
# checked in this spec.
#
# No prior threading spec records __qualname__.__class__.__name__.__eq__('str')
# for Thread.__init__, Thread.__repr__, Event.__init__, or Timer.__init__.
# New to extra62.
# ---------------------------------------------------------------------------

table threading_extra62.method_qualname_class_name:
  description: "Thread/__repr__/Event/Timer __init__.__qualname__.__class__.__name__.__eq__('str')==true — every method qualname is a str; depth-2 chain; wave 227; new to extra62"
  kind: python_call_eq
  category: qualname_type
  id_prefix: thrdqual62

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_qualname_class_name_eq_str,
       Thread.__init__.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Thread.__init__.__qualname__.__class__.__name__.__eq__('str') == True — Thread.__init__.__qualname__ is the Python str 'Thread.__init__'; as a str object its __class__ is the built-in str type and str.__name__ == 'str' (3 chars); this depth-2 chain confirms the type of the qualname value; no prior threading spec records __qualname__.__class__.__name__ for Thread.__init__; new to extra62"]
    - [thread_repr_qualname_class_name_eq_str,
       Thread.__repr__.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Thread.__repr__.__qualname__.__class__.__name__.__eq__('str') == True — Thread.__repr__.__qualname__ is the Python str 'Thread.__repr__'; as a str object its __class__ is the built-in str type and str.__name__ == 'str' (3 chars); this depth-2 chain confirms the type of the qualname value; no prior threading spec records __qualname__.__class__.__name__ for Thread.__repr__; new to extra62"]
    - [event_init_qualname_class_name_eq_str,
       Event.__init__.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Event.__init__.__qualname__.__class__.__name__.__eq__('str') == True — Event.__init__.__qualname__ is the Python str 'Event.__init__'; as a str object its __class__ is the built-in str type and str.__name__ == 'str' (3 chars); this depth-2 chain confirms the type of the qualname value; no prior threading spec records __qualname__.__class__.__name__ for Event.__init__; new to extra62"]
    - [timer_init_qualname_class_name_eq_str,
       Timer.__init__.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Timer.__init__.__qualname__.__class__.__name__.__eq__('str') == True — Timer.__init__.__qualname__ is the Python str 'Timer.__init__'; as a str object its __class__ is the built-in str type and str.__name__ == 'str' (3 chars); this depth-2 chain confirms the type of the qualname value; no prior threading spec records __qualname__.__class__.__name__ for Timer.__init__; new to extra62"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra62
# ---------------------------------------------------------------------------

invariant threading_extra62.thread_init_qualname_eq:
  description: "threading.Thread.__init__.__qualname__.__eq__('Thread.__init__') == True — pure-Python method; qualname 15 chars; extra36/51 checked __len__; wave 227 adds __eq__; new to extra62"
  kind: python_call_eq
  function: Thread.__init__.__qualname__.__eq__
  args: ["Thread.__init__"]
  expected: true

invariant threading_extra62.thread_repr_qualname_eq:
  description: "threading.Thread.__repr__.__qualname__.__eq__('Thread.__repr__') == True — pure-Python method; qualname 15 chars (same as __init__); extra36 checked __len__; wave 227 adds __eq__; new to extra62"
  kind: python_call_eq
  function: Thread.__repr__.__qualname__.__eq__
  args: ["Thread.__repr__"]
  expected: true

invariant threading_extra62.timer_init_qualname_eq:
  description: "threading.Timer.__init__.__qualname__.__eq__('Timer.__init__') == True — pure-Python method; qualname 14 chars; no prior spec checked Timer.__init__.__qualname__; wave 227; new to extra62"
  kind: python_call_eq
  function: Timer.__init__.__qualname__.__eq__
  args: ["Timer.__init__"]
  expected: true
