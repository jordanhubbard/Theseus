spec: asyncio_extra215
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-exceptions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-exceptions.html — asyncio Exceptions documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/exceptions.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec covers asyncio exception class identity and exception-raising behavior."
    - "asyncio.InvalidStateError.__name__ == 'InvalidStateError'; __module__ == 'asyncio.exceptions'; base == Exception."
    - "asyncio.TimeoutError is builtins.TimeoutError — __module__ == 'builtins'; base class is OSError."
    - "asyncio.CancelledError.__module__ == 'asyncio.exceptions'; base == BaseException."
    - "asyncio.QueueEmpty and asyncio.QueueFull.__module__ == 'asyncio.queues'; both base Exception."
    - "asyncio.IncompleteReadError.__module__ == 'asyncio.exceptions'; base == EOFError."
    - "asyncio.LimitOverrunError.__module__ == 'asyncio.exceptions'; base == Exception."
    - "asyncio.Semaphore(-1) raises ValueError: 'Semaphore initial value must be >= 0'."
    - "asyncio.BoundedSemaphore(-1) raises ValueError: 'Semaphore initial value must be >= 0'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio exception class __name__ string equality — extra215 namespace
#
# Verifies the canonical __name__ attribute of each asyncio exception class.
# asyncio.TimeoutError is an alias for the built-in TimeoutError (since
# Python 3.11); its __name__ is still 'TimeoutError'.
# ---------------------------------------------------------------------------

table asyncio_extra215.exception_names:
  description: "asyncio exception class __name__ string equality in extra215 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioexcname215

  columns: [id, function, args, expected, description]
  rows:
    - [InvalidStateError_name, InvalidStateError.__name__.__eq__, ["InvalidStateError"], true, "asyncio.InvalidStateError.__name__ == 'InvalidStateError'"]
    - [TimeoutError_name,      TimeoutError.__name__.__eq__,      ["TimeoutError"],      true, "asyncio.TimeoutError.__name__ == 'TimeoutError' — alias for builtins.TimeoutError"]
    - [CancelledError_name,    CancelledError.__name__.__eq__,    ["CancelledError"],    true, "asyncio.CancelledError.__name__ == 'CancelledError'"]
    - [QueueEmpty_name,        QueueEmpty.__name__.__eq__,        ["QueueEmpty"],        true, "asyncio.QueueEmpty.__name__ == 'QueueEmpty'"]
    - [QueueFull_name,         QueueFull.__name__.__eq__,         ["QueueFull"],         true, "asyncio.QueueFull.__name__ == 'QueueFull'"]

# ---------------------------------------------------------------------------
# asyncio exception class __module__ string equality — extra215 namespace
#
# InvalidStateError and CancelledError live in asyncio.exceptions.
# TimeoutError is builtins.TimeoutError — __module__ == 'builtins'.
# QueueEmpty and QueueFull live in asyncio.queues.
# IncompleteReadError and LimitOverrunError live in asyncio.exceptions.
# ---------------------------------------------------------------------------

table asyncio_extra215.exception_modules:
  description: "asyncio exception class __module__ string equality in extra215 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioexcmod215

  columns: [id, function, args, expected, description]
  rows:
    - [InvalidStateError_module,   InvalidStateError.__module__.__eq__,   ["asyncio.exceptions"], true, "asyncio.InvalidStateError.__module__ == 'asyncio.exceptions'"]
    - [TimeoutError_module,        TimeoutError.__module__.__eq__,        ["builtins"],           true, "asyncio.TimeoutError.__module__ == 'builtins' — is the built-in TimeoutError"]
    - [CancelledError_module,      CancelledError.__module__.__eq__,      ["asyncio.exceptions"], true, "asyncio.CancelledError.__module__ == 'asyncio.exceptions'"]
    - [QueueEmpty_module,          QueueEmpty.__module__.__eq__,          ["asyncio.queues"],     true, "asyncio.QueueEmpty.__module__ == 'asyncio.queues'"]
    - [QueueFull_module,           QueueFull.__module__.__eq__,           ["asyncio.queues"],     true, "asyncio.QueueFull.__module__ == 'asyncio.queues'"]
    - [IncompleteReadError_module, IncompleteReadError.__module__.__eq__, ["asyncio.exceptions"], true, "asyncio.IncompleteReadError.__module__ == 'asyncio.exceptions'"]
    - [LimitOverrunError_module,   LimitOverrunError.__module__.__eq__,   ["asyncio.exceptions"], true, "asyncio.LimitOverrunError.__module__ == 'asyncio.exceptions'"]

# ---------------------------------------------------------------------------
# asyncio exception class base class __name__ — extra215 namespace
#
# Hierarchy:
#   InvalidStateError -> Exception
#   TimeoutError      -> OSError  (builtins.TimeoutError inherits from OSError)
#   CancelledError    -> BaseException
#   QueueEmpty        -> Exception
#   QueueFull         -> Exception
#   IncompleteReadError -> EOFError
#   LimitOverrunError   -> Exception
# ---------------------------------------------------------------------------

table asyncio_extra215.exception_bases:
  description: "asyncio exception class __bases__[0].__name__ string equality in extra215 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioexcbase215

  columns: [id, function, args, expected, description]
  rows:
    - [InvalidStateError_base,   "InvalidStateError.__bases__[0].__name__.__eq__",   ["Exception"],     true, "asyncio.InvalidStateError inherits from Exception"]
    - [TimeoutError_base,        "TimeoutError.__bases__[0].__name__.__eq__",        ["OSError"],       true, "asyncio.TimeoutError inherits from OSError (built-in hierarchy)"]
    - [CancelledError_base,      "CancelledError.__bases__[0].__name__.__eq__",      ["BaseException"], true, "asyncio.CancelledError inherits directly from BaseException"]
    - [QueueEmpty_base,          "QueueEmpty.__bases__[0].__name__.__eq__",          ["Exception"],     true, "asyncio.QueueEmpty inherits from Exception"]
    - [QueueFull_base,           "QueueFull.__bases__[0].__name__.__eq__",           ["Exception"],     true, "asyncio.QueueFull inherits from Exception"]
    - [IncompleteReadError_base, "IncompleteReadError.__bases__[0].__name__.__eq__", ["EOFError"],      true, "asyncio.IncompleteReadError inherits from EOFError"]
    - [LimitOverrunError_base,   "LimitOverrunError.__bases__[0].__name__.__eq__",   ["Exception"],     true, "asyncio.LimitOverrunError inherits from Exception"]

# ---------------------------------------------------------------------------
# asyncio.Semaphore(-1) raises ValueError — extra215 namespace
#
# asyncio.Semaphore enforces that the initial value is non-negative.
# Passing a negative integer raises ValueError at construction time.
# This is a sync-context check (no event loop required).
# ---------------------------------------------------------------------------

invariant asyncio_extra215.Semaphore.negative_raises:
  description: "asyncio.Semaphore(-1) raises ValueError — initial value must be >= 0"
  category: errors
  kind: python_call_raises
  function: Semaphore
  args: [-1]
  expected: ValueError

# ---------------------------------------------------------------------------
# asyncio.BoundedSemaphore(-1) raises ValueError — extra215 namespace
#
# BoundedSemaphore enforces the same non-negative constraint as Semaphore.
# Passing -1 raises ValueError at construction time.
# ---------------------------------------------------------------------------

invariant asyncio_extra215.BoundedSemaphore.negative_raises:
  description: "asyncio.BoundedSemaphore(-1) raises ValueError — initial value must be >= 0"
  category: errors
  kind: python_call_raises
  function: BoundedSemaphore
  args: [-1]
  expected: ValueError

