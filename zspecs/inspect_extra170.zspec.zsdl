spec: inspect_extra170
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getmembers.__name__ 'getmembers'; inspect.getmembers.__module__ 'inspect'; inspect.getdoc.__name__ 'getdoc'; inspect.getdoc.__module__ 'inspect'; inspect.getsource.__name__ 'getsource'; inspect.getsource.__module__ 'inspect'; inspect.getfile.__name__ 'getfile'; inspect.getfile.__module__ 'inspect'; inspect.getmodule.__name__ 'getmodule'; inspect.getmodule.__module__ 'inspect' (Wave 299)."
    - "inspect.getmembers.__name__ == 'getmembers' — inspect.getmembers is a Python function defined in Lib/inspect.py that returns all the members of an object in a list of (name, value) pairs sorted by name; its __name__ is 'getmembers'. Verified with Python 3.14.3."
    - "inspect.getmembers.__module__ == 'inspect' — getmembers is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.getdoc.__name__ == 'getdoc' — inspect.getdoc is a Python function defined in Lib/inspect.py that gets the documentation string for an object, cleaned up with cleandoc; its __name__ is 'getdoc'. Verified with Python 3.14.3."
    - "inspect.getdoc.__module__ == 'inspect' — getdoc is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.getsource.__name__ == 'getsource' — inspect.getsource is a Python function defined in Lib/inspect.py that returns the text of the source code for an object; its __name__ is 'getsource'. Verified with Python 3.14.3."
    - "inspect.getsource.__module__ == 'inspect' — getsource is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.getfile.__name__ == 'getfile' — inspect.getfile is a Python function defined in Lib/inspect.py that returns the name of the Python source file in which an object was defined; its __name__ is 'getfile'. Verified with Python 3.14.3."
    - "inspect.getfile.__module__ == 'inspect' — getfile is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.getmodule.__name__ == 'getmodule' — inspect.getmodule is a Python function defined in Lib/inspect.py that returns the name of the Python module in which an object was defined; its __name__ is 'getmodule'. Verified with Python 3.14.3."
    - "inspect.getmodule.__module__ == 'inspect' — getmodule is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getmembers Python function identity — __name__, __module__,
# __class__.__name__
#
# Wave 299 theme: inspect.getmembers Python function identity — __name__,
# __module__, and __class__.__name__.
#
# inspect.getmembers.__name__ == 'getmembers'
# inspect.getmembers.__module__ == 'inspect'
# inspect.getmembers.__class__.__name__ == 'function'
# inspect.getmembers.__name__ != 'getdoc'
#
# inspect.getmembers(object[, predicate]) returns all the members of an object
# in a list of (name, value) pairs sorted alphabetically by name. If the optional
# predicate argument is supplied, only members for which the predicate returns a
# true value are included. It is a Python function defined in Lib/inspect.py.
# New to extra170.
# ---------------------------------------------------------------------------

table inspect_extra170.getmembers_identity:
  description: "inspect.getmembers: __name__ 'getmembers', __module__ 'inspect', __class__.__name__ 'function'; wave 299; new to extra170"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgmi170

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_name_getmembers,
       "getmembers.__name__.__eq__",
       ["getmembers"],
       true,
       "inspect.getmembers.__name__.__eq__('getmembers') == True — inspect.getmembers is a Python function defined in Lib/inspect.py that returns all members of an object as a sorted list of (name, value) pairs, with optional predicate filtering; its __name__ attribute is 'getmembers'; str.__eq__('getmembers') returns True; new to extra170"]
    - [getmembers_module_inspect,
       "getmembers.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getmembers.__module__.__eq__('inspect') == True — inspect.getmembers is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra170"]
    - [getmembers_class_name_function,
       "getmembers.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.getmembers.__class__.__name__.__eq__('function') == True — inspect.getmembers is a regular Python function defined with def in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra170"]
    - [getmembers_name_ne_getdoc,
       "getmembers.__name__.__eq__",
       ["getdoc"],
       false,
       "inspect.getmembers.__name__.__eq__('getdoc') == False — getmembers.__name__ is 'getmembers', not 'getdoc'; getmembers retrieves all members of an object while getdoc retrieves its documentation string; they are distinct utility functions; str.__eq__('getdoc') returns False; new to extra170"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getdoc Python function identity — __name__, __module__,
# __class__.__name__
#
# Wave 299 theme: inspect.getdoc Python function identity — __name__,
# __module__, and __class__.__name__.
#
# inspect.getdoc.__name__ == 'getdoc'
# inspect.getdoc.__module__ == 'inspect'
# inspect.getdoc.__class__.__name__ == 'function'
# inspect.getdoc.__name__ != 'getsource'
#
# inspect.getdoc(object) returns the documentation string for an object, cleaned
# up with inspect.cleandoc. If the documentation string for an object is not set,
# it will try to obtain it from the inheritance hierarchy. It is a Python function
# defined in Lib/inspect.py. New to extra170.
# ---------------------------------------------------------------------------

table inspect_extra170.getdoc_identity:
  description: "inspect.getdoc: __name__ 'getdoc', __module__ 'inspect', __class__.__name__ 'function'; wave 299; new to extra170"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgdi170

  columns: [id, function, args, expected, description]
  rows:
    - [getdoc_name_getdoc,
       "getdoc.__name__.__eq__",
       ["getdoc"],
       true,
       "inspect.getdoc.__name__.__eq__('getdoc') == True — inspect.getdoc is a Python function defined in Lib/inspect.py that returns the documentation string for an object, cleaned up with cleandoc; its __name__ attribute is 'getdoc'; str.__eq__('getdoc') returns True; new to extra170"]
    - [getdoc_module_inspect,
       "getdoc.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getdoc.__module__.__eq__('inspect') == True — inspect.getdoc is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra170"]
    - [getdoc_class_name_function,
       "getdoc.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.getdoc.__class__.__name__.__eq__('function') == True — inspect.getdoc is a regular Python function defined with def in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra170"]
    - [getdoc_name_ne_getsource,
       "getdoc.__name__.__eq__",
       ["getsource"],
       false,
       "inspect.getdoc.__name__.__eq__('getsource') == False — getdoc.__name__ is 'getdoc', not 'getsource'; getdoc retrieves the cleaned documentation string while getsource retrieves the raw source code text; they are distinct utility functions; str.__eq__('getsource') returns False; new to extra170"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getsource and inspect.getfile Python function identity
#
# Wave 299 theme: inspect.getsource and inspect.getfile Python function
# identity — __name__, __module__, and __class__.__name__.
#
# inspect.getsource.__name__ == 'getsource'
# inspect.getsource.__module__ == 'inspect'
# inspect.getfile.__name__ == 'getfile'
# inspect.getfile.__module__ == 'inspect'
#
# inspect.getsource(object) returns the text of the source code for an object
# (function, method, class, module, etc.), raising OSError if the source cannot
# be retrieved. inspect.getfile(object) returns the name of the Python source
# file in which an object was defined (or the .pyc file if source is unavailable).
# Both are Python functions in Lib/inspect.py. New to extra170.
# ---------------------------------------------------------------------------

table inspect_extra170.getsource_getfile_identity:
  description: "inspect.getsource and getfile: __name__ 'getsource'/'getfile', __module__ 'inspect'; wave 299; new to extra170"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgsgi170

  columns: [id, function, args, expected, description]
  rows:
    - [getsource_name_getsource,
       "getsource.__name__.__eq__",
       ["getsource"],
       true,
       "inspect.getsource.__name__.__eq__('getsource') == True — inspect.getsource is a Python function defined in Lib/inspect.py that returns the text of the source code for an object (function, method, class, module, etc.); its __name__ attribute is 'getsource'; str.__eq__('getsource') returns True; new to extra170"]
    - [getsource_module_inspect,
       "getsource.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getsource.__module__.__eq__('inspect') == True — inspect.getsource is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra170"]
    - [getfile_name_getfile,
       "getfile.__name__.__eq__",
       ["getfile"],
       true,
       "inspect.getfile.__name__.__eq__('getfile') == True — inspect.getfile is a Python function defined in Lib/inspect.py that returns the name of the Python source file in which an object was defined; its __name__ attribute is 'getfile'; str.__eq__('getfile') returns True; new to extra170"]
    - [getfile_module_inspect,
       "getfile.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getfile.__module__.__eq__('inspect') == True — inspect.getfile is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra170"]

# ---------------------------------------------------------------------------
# Table 4: inspect.getmodule Python function identity — __name__, __module__,
# __class__.__name__; cross-checks with getsource and getfile
#
# Wave 299 theme: inspect.getmodule Python function identity — __name__,
# __module__, and __class__.__name__; plus cross-checks confirming getsource,
# getfile, and getmodule are distinct.
#
# inspect.getmodule.__name__ == 'getmodule'
# inspect.getmodule.__module__ == 'inspect'
# inspect.getmodule.__class__.__name__ == 'function'
# inspect.getmodule.__name__ != 'getfile'
#
# inspect.getmodule(object[, filename]) tries to guess the module in which an
# object was defined. Returns the module object if found, otherwise None. It is
# a Python function defined in Lib/inspect.py. New to extra170.
# ---------------------------------------------------------------------------

table inspect_extra170.getmodule_identity:
  description: "inspect.getmodule: __name__ 'getmodule', __module__ 'inspect', __class__.__name__ 'function'; cross-checks with getsource and getfile; wave 299; new to extra170"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgmi2170

  columns: [id, function, args, expected, description]
  rows:
    - [getmodule_name_getmodule,
       "getmodule.__name__.__eq__",
       ["getmodule"],
       true,
       "inspect.getmodule.__name__.__eq__('getmodule') == True — inspect.getmodule is a Python function defined in Lib/inspect.py that tries to guess the module in which an object was defined; its __name__ attribute is 'getmodule'; str.__eq__('getmodule') returns True; new to extra170"]
    - [getmodule_module_inspect,
       "getmodule.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getmodule.__module__.__eq__('inspect') == True — inspect.getmodule is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra170"]
    - [getmodule_class_name_function,
       "getmodule.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.getmodule.__class__.__name__.__eq__('function') == True — inspect.getmodule is a regular Python function defined with def in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra170"]
    - [getmodule_name_ne_getfile,
       "getmodule.__name__.__eq__",
       ["getfile"],
       false,
       "inspect.getmodule.__name__.__eq__('getfile') == False — getmodule.__name__ is 'getmodule', not 'getfile'; getmodule returns the module object in which an object was defined while getfile returns the filesystem path to the source file; they are distinct utility functions; str.__eq__('getfile') returns False; new to extra170"]

# ---------------------------------------------------------------------------
# Table 5: cross-checks — getmembers, getdoc, getsource, getfile, getmodule
# are all distinct; none has __module__ != 'inspect'
#
# Wave 299 theme: cross-checks confirming that getmembers, getdoc, getsource,
# getfile, and getmodule all have distinct __name__ values and all have
# __module__ 'inspect' (not 'builtins').
#
# inspect.getmembers.__name__ != 'getdoc'
# inspect.getsource.__name__ != 'getmodule'
# inspect.getfile.__module__ != 'builtins'
# inspect.getmembers.__class__.__name__ == 'function'
#
# All five are regular Python functions defined in Lib/inspect.py with distinct
# names. None lives in the builtins module. New to extra170.
# ---------------------------------------------------------------------------

table inspect_extra170.get_functions_cross_checks:
  description: "inspect: getmembers.__name__ != 'getdoc', getsource.__name__ != 'getmodule', getfile.__module__ != 'builtins', getmembers class 'function'; wave 299; new to extra170"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgfcc170

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_name_ne_getdoc,
       "getmembers.__name__.__eq__",
       ["getdoc"],
       false,
       "inspect.getmembers.__name__.__eq__('getdoc') == False — getmembers.__name__ is 'getmembers', not 'getdoc'; these are distinct functions with different purposes; str.__eq__('getdoc') returns False; new to extra170"]
    - [getsource_name_ne_getmodule,
       "getsource.__name__.__eq__",
       ["getmodule"],
       false,
       "inspect.getsource.__name__.__eq__('getmodule') == False — getsource.__name__ is 'getsource', not 'getmodule'; getsource returns the raw source text while getmodule returns the module object; they are distinct; str.__eq__('getmodule') returns False; new to extra170"]
    - [getfile_module_not_builtins,
       "getfile.__module__.__eq__",
       ["builtins"],
       false,
       "inspect.getfile.__module__.__eq__('builtins') == False — inspect.getfile is defined in Lib/inspect.py with __module__ 'inspect'; it is NOT in builtins; str.__eq__('builtins') returns False; new to extra170"]
    - [getmembers_class_name_function,
       "getmembers.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.getmembers.__class__.__name__.__eq__('function') == True — inspect.getmembers is a regular Python function defined in Lib/inspect.py; all five new functions (getmembers, getdoc, getsource, getfile, getmodule) share __class__.__name__ 'function'; cross-check via getmembers; str.__eq__('function') returns True; new to extra170"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra170
# ---------------------------------------------------------------------------

invariant inspect_extra170.getmembers_name_eq:
  description: "inspect.getmembers.__name__ == 'getmembers' — Python function returning all members of an object as sorted (name, value) pairs; wave 299; new to extra170"
  kind: python_call_eq
  function: getmembers.__name__.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra170.getmembers_module_inspect:
  description: "inspect.getmembers.__module__ == 'inspect' — getmembers is defined in Lib/inspect.py; wave 299; new to extra170"
  kind: python_call_eq
  function: getmembers.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra170.getdoc_name_eq:
  description: "inspect.getdoc.__name__ == 'getdoc' — Python function returning the cleaned documentation string for an object; wave 299; new to extra170"
  kind: python_call_eq
  function: getdoc.__name__.__eq__
  args: ["getdoc"]
  expected: true

invariant inspect_extra170.getdoc_module_inspect:
  description: "inspect.getdoc.__module__ == 'inspect' — getdoc is defined in Lib/inspect.py; wave 299; new to extra170"
  kind: python_call_eq
  function: getdoc.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra170.getsource_name_eq:
  description: "inspect.getsource.__name__ == 'getsource' — Python function returning the source code text for an object; wave 299; new to extra170"
  kind: python_call_eq
  function: getsource.__name__.__eq__
  args: ["getsource"]
  expected: true

invariant inspect_extra170.getsource_module_inspect:
  description: "inspect.getsource.__module__ == 'inspect' — getsource is defined in Lib/inspect.py; wave 299; new to extra170"
  kind: python_call_eq
  function: getsource.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra170.getfile_name_eq:
  description: "inspect.getfile.__name__ == 'getfile' — Python function returning the source file path for an object; wave 299; new to extra170"
  kind: python_call_eq
  function: getfile.__name__.__eq__
  args: ["getfile"]
  expected: true

invariant inspect_extra170.getmodule_name_eq:
  description: "inspect.getmodule.__name__ == 'getmodule' — Python function guessing the module in which an object was defined; wave 299; new to extra170"
  kind: python_call_eq
  function: getmodule.__name__.__eq__
  args: ["getmodule"]
  expected: true
