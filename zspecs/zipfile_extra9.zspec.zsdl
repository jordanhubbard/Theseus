spec: zipfile_extra9
version: ">=3.9"
backend: python_module(zipfile)

docs: https://docs.python.org/3/library/zipfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zipfile.html — Python zipfile documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zipfile/__init__.py"
  notes:
    - "This spec extends zipfile.zspec.zsdl through zipfile_extra8.zspec.zsdl."
    - "zipfile (base) covers: ZIP_STORED/ZIP_DEFLATED/ZIP_BZIP2/ZIP_LZMA values; limit constants; ZipFile/ZipInfo/BadZipFile/LargeZipFile/Path __name__; exception bases; ZipInfo construction (filename/compress_type/file_size); is_zipfile false; ZipFile raises BadZipFile."
    - "zipfile_extra through zipfile_extra8 cover: class __name__/__module__/__qualname__/__class__.__name__ for ZipFile/ZipInfo/BadZipFile/LargeZipFile/Path/ZipExtFile; is_zipfile __name__/__qualname__/__module__/__class__.__name__; compression and limit constant class names/values; ZipInfo filename vectors (hello.txt/test.txt/archive.zip/data.bin); exception base hierarchy; BadZipfile alias; ZipFile/ZipInfo __bases__[0] == 'object'; ZipExtFile base; is_zipfile TypeError."
    - "No prior spec covers: ZipInfo.date_time type == 'tuple'."
    - "No prior spec covers: ZipInfo.date_time[0] == 1980 — the default epoch year for ZIP."
    - "No prior spec covers: ZipInfo.create_system == 3 — default create_system (Unix/macOS)."
    - "No prior spec covers: zipfile.Path.__bases__[0].__name__ == 'object' — Path inherits directly from object."
    - "No prior spec covers: zipfile.BadZipFile.__mro__[1].__name__ == 'Exception' — second MRO entry."
    - "zipfile.ZipInfo.date_time default is (1980, 1, 1, 0, 0, 0) — the ZIP format epoch (January 1, 1980)."
    - "zipfile.ZipInfo.create_system == 3 on Unix/macOS systems (0 == Windows, 3 == Unix)."
    - "zipfile.BadZipFile.__mro__: [BadZipFile, Exception, BaseException, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ZipInfo.date_time — type and epoch year
# zipfile (base) covers filename, compress_type, file_size for ZipInfo.
# No prior spec checks date_time at all. date_time is a tuple (year, month, day,
# hour, minute, second) defaulting to (1980, 1, 1, 0, 0, 0) — the ZIP epoch.
# ---------------------------------------------------------------------------

invariant zipfile_extra9.ZipInfo.date_time_type:
  description: "zipfile.ZipInfo('test.txt').date_time.__class__.__name__ == 'tuple'"
  category: zipinfo
  kind: python_call_eq
  function: ZipInfo
  args: ["test.txt"]
  method: date_time
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["tuple"]
  expected: true

invariant zipfile_extra9.ZipInfo.date_time_year:
  description: "zipfile.ZipInfo('test.txt').date_time[0] == 1980 — ZIP epoch year"
  category: zipinfo
  kind: python_call_eq
  function: ZipInfo
  args: ["test.txt"]
  method: date_time
  method_chain: __getitem__
  method_chain_args: [0]
  expected: 1980

# ---------------------------------------------------------------------------
# ZipInfo.create_system — platform identifier
# No prior spec checks create_system. Default is 3 (Unix) on macOS/Linux;
# a platform-dependent but stable value on this test platform.
# ---------------------------------------------------------------------------

invariant zipfile_extra9.ZipInfo.create_system:
  description: "zipfile.ZipInfo('test.txt').create_system == 3 — Unix/macOS platform identifier"
  category: zipinfo
  kind: python_call_eq
  function: ZipInfo
  args: ["test.txt"]
  method: create_system
  expected: 3

# ---------------------------------------------------------------------------
# zipfile.Path.__bases__[0].__name__ == 'object'
# Prior specs confirm Path.__name__, __qualname__, __module__, and
# __class__.__name__. No prior spec checks Path.__bases__[0].__name__.
# Path has no custom base class; it inherits directly from object.
# ---------------------------------------------------------------------------

invariant zipfile_extra9.Path.base_name:
  description: "zipfile.Path.__bases__[0].__name__ == 'object' — Path inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: Path.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# BadZipFile MRO depth 1 — Exception
# Prior specs cover BadZipFile.__bases__[0].__name__ == 'Exception'.
# No prior spec checks BadZipFile.__mro__[1].__name__ — the MRO form is
# a distinct and complementary axis.
# BadZipFile.__mro__: [BadZipFile, Exception, BaseException, object]
# ---------------------------------------------------------------------------

invariant zipfile_extra9.BadZipFile.mro_index1:
  description: "zipfile.BadZipFile.__mro__[1].__name__ == 'Exception' — second MRO entry"
  category: class_hierarchy
  kind: python_call_eq
  function: BadZipFile.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# BadZipFile MRO depth 2 — BaseException
# mro[2] continues the hierarchy. No prior zipfile spec has checked any
# BadZipFile.__mro__[N].__name__ for any N.
# ---------------------------------------------------------------------------

invariant zipfile_extra9.BadZipFile.mro_index2:
  description: "zipfile.BadZipFile.__mro__[2].__name__ == 'BaseException' — third MRO entry"
  category: class_hierarchy
  kind: python_call_eq
  function: BadZipFile.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "BaseException"
