spec: itertools_extra2641
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 623 (_extra2641): __copy__, __deepcopy__, and __sizeof__ dict-presence checks for itertools types."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
    - "__copy__ supports copy.copy() shallow copying. None of the 18 itertools types define __copy__ in their class __dict__ — all False."
    - "__deepcopy__ supports copy.deepcopy() deep copying. None of the 18 itertools types define __deepcopy__ in their class __dict__ — all False."
    - "__sizeof__ is used by sys.getsizeof() for memory introspection. itertools.product, permutations, combinations, and combinations_with_replacement each define __sizeof__ in their class __dict__ (True). All other itertools types return False."
    - "The four combinatoric types (product, permutations, combinations, combinations_with_replacement) define __sizeof__ to account for their internal C-level pool and result arrays, whose sizes depend on constructor arguments."
    - "The 18 itertools types tested: chain, count, repeat, cycle, islice, compress, dropwhile, takewhile, starmap, groupby, filterfalse, accumulate, zip_longest, pairwise, product, permutations, combinations, combinations_with_replacement."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __copy__ dict-presence for itertools iterator types
#
# __copy__ is the hook for copy.copy() shallow copying. All 18 itertools
# C extension types (iterators and combinatorics) do not define __copy__
# in their own class __dict__ — all False.
# ---------------------------------------------------------------------------

table itertools_extra2641.copy_absent:
  description: "itertools types do not define __copy__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2641

  columns: [id, function, args, expected]
  rows:
    - ["it2641001", "itertools.chain.__dict__.__contains__",                         ["__copy__"], false]
    - ["it2641002", "itertools.count.__dict__.__contains__",                         ["__copy__"], false]
    - ["it2641003", "itertools.repeat.__dict__.__contains__",                        ["__copy__"], false]
    - ["it2641004", "itertools.cycle.__dict__.__contains__",                         ["__copy__"], false]
    - ["it2641005", "itertools.islice.__dict__.__contains__",                        ["__copy__"], false]
    - ["it2641006", "itertools.compress.__dict__.__contains__",                      ["__copy__"], false]
    - ["it2641007", "itertools.dropwhile.__dict__.__contains__",                     ["__copy__"], false]
    - ["it2641008", "itertools.takewhile.__dict__.__contains__",                     ["__copy__"], false]
    - ["it2641009", "itertools.starmap.__dict__.__contains__",                       ["__copy__"], false]
    - ["it2641010", "itertools.groupby.__dict__.__contains__",                       ["__copy__"], false]
    - ["it2641011", "itertools.filterfalse.__dict__.__contains__",                   ["__copy__"], false]
    - ["it2641012", "itertools.accumulate.__dict__.__contains__",                    ["__copy__"], false]
    - ["it2641013", "itertools.zip_longest.__dict__.__contains__",                   ["__copy__"], false]
    - ["it2641014", "itertools.pairwise.__dict__.__contains__",                      ["__copy__"], false]
    - ["it2641015", "itertools.product.__dict__.__contains__",                       ["__copy__"], false]
    - ["it2641016", "itertools.permutations.__dict__.__contains__",                  ["__copy__"], false]
    - ["it2641017", "itertools.combinations.__dict__.__contains__",                  ["__copy__"], false]
    - ["it2641018", "itertools.combinations_with_replacement.__dict__.__contains__", ["__copy__"], false]

# ---------------------------------------------------------------------------
# Table 2: __deepcopy__ dict-presence for itertools iterator types
#
# __deepcopy__ is the hook for copy.deepcopy() deep copying. None of the
# 18 itertools types define __deepcopy__ in their own class __dict__ —
# all False.
# ---------------------------------------------------------------------------

table itertools_extra2641.deepcopy_absent:
  description: "itertools types do not define __deepcopy__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2641

  columns: [id, function, args, expected]
  rows:
    - ["it2641019", "itertools.chain.__dict__.__contains__",                         ["__deepcopy__"], false]
    - ["it2641020", "itertools.count.__dict__.__contains__",                         ["__deepcopy__"], false]
    - ["it2641021", "itertools.repeat.__dict__.__contains__",                        ["__deepcopy__"], false]
    - ["it2641022", "itertools.cycle.__dict__.__contains__",                         ["__deepcopy__"], false]
    - ["it2641023", "itertools.islice.__dict__.__contains__",                        ["__deepcopy__"], false]
    - ["it2641024", "itertools.compress.__dict__.__contains__",                      ["__deepcopy__"], false]
    - ["it2641025", "itertools.dropwhile.__dict__.__contains__",                     ["__deepcopy__"], false]
    - ["it2641026", "itertools.takewhile.__dict__.__contains__",                     ["__deepcopy__"], false]
    - ["it2641027", "itertools.starmap.__dict__.__contains__",                       ["__deepcopy__"], false]
    - ["it2641028", "itertools.groupby.__dict__.__contains__",                       ["__deepcopy__"], false]
    - ["it2641029", "itertools.filterfalse.__dict__.__contains__",                   ["__deepcopy__"], false]
    - ["it2641030", "itertools.accumulate.__dict__.__contains__",                    ["__deepcopy__"], false]
    - ["it2641031", "itertools.zip_longest.__dict__.__contains__",                   ["__deepcopy__"], false]
    - ["it2641032", "itertools.pairwise.__dict__.__contains__",                      ["__deepcopy__"], false]
    - ["it2641033", "itertools.product.__dict__.__contains__",                       ["__deepcopy__"], false]
    - ["it2641034", "itertools.permutations.__dict__.__contains__",                  ["__deepcopy__"], false]
    - ["it2641035", "itertools.combinations.__dict__.__contains__",                  ["__deepcopy__"], false]
    - ["it2641036", "itertools.combinations_with_replacement.__dict__.__contains__", ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# Table 3: __sizeof__ dict-presence for itertools iterator types
#
# __sizeof__ is called by sys.getsizeof() for memory introspection.
# The four combinatoric types — product, permutations, combinations, and
# combinations_with_replacement — define __sizeof__ in their own class
# __dict__ (True) to account for their internal C-level pool and result
# arrays, whose sizes depend on constructor arguments. All other itertools
# types return False.
# ---------------------------------------------------------------------------

table itertools_extra2641.sizeof_checks:
  description: "itertools __sizeof__ dict-presence — product/permutations/combinations/combinations_with_replacement True, others False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2641

  columns: [id, function, args, expected]
  rows:
    - ["it2641037", "itertools.chain.__dict__.__contains__",                         ["__sizeof__"], false]
    - ["it2641038", "itertools.count.__dict__.__contains__",                         ["__sizeof__"], false]
    - ["it2641039", "itertools.repeat.__dict__.__contains__",                        ["__sizeof__"], false]
    - ["it2641040", "itertools.cycle.__dict__.__contains__",                         ["__sizeof__"], false]
    - ["it2641041", "itertools.islice.__dict__.__contains__",                        ["__sizeof__"], false]
    - ["it2641042", "itertools.compress.__dict__.__contains__",                      ["__sizeof__"], false]
    - ["it2641043", "itertools.dropwhile.__dict__.__contains__",                     ["__sizeof__"], false]
    - ["it2641044", "itertools.takewhile.__dict__.__contains__",                     ["__sizeof__"], false]
    - ["it2641045", "itertools.starmap.__dict__.__contains__",                       ["__sizeof__"], false]
    - ["it2641046", "itertools.groupby.__dict__.__contains__",                       ["__sizeof__"], false]
    - ["it2641047", "itertools.filterfalse.__dict__.__contains__",                   ["__sizeof__"], false]
    - ["it2641048", "itertools.accumulate.__dict__.__contains__",                    ["__sizeof__"], false]
    - ["it2641049", "itertools.zip_longest.__dict__.__contains__",                   ["__sizeof__"], false]
    - ["it2641050", "itertools.pairwise.__dict__.__contains__",                      ["__sizeof__"], false]
    - ["it2641051", "itertools.product.__dict__.__contains__",                       ["__sizeof__"], true]
    - ["it2641052", "itertools.permutations.__dict__.__contains__",                  ["__sizeof__"], true]
    - ["it2641053", "itertools.combinations.__dict__.__contains__",                  ["__sizeof__"], true]
    - ["it2641054", "itertools.combinations_with_replacement.__dict__.__contains__", ["__sizeof__"], true]

# ---------------------------------------------------------------------------
# Table 4: Combinatoric __sizeof__ detail and cross-checks
#
# The four combinatoric types all define __sizeof__ (True) while defining
# neither __copy__ nor __deepcopy__. This table confirms the pattern for each
# of the four types and cross-checks a representative non-combinatoric type
# (chain) to confirm the contrasting absence.
# ---------------------------------------------------------------------------

table itertools_extra2641.combinatoric_sizeof_detail:
  description: "combinatoric types define __sizeof__ but not __copy__ or __deepcopy__; chain confirms absence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2641

  columns: [id, function, args, expected]
  rows:
    - ["it2641055", "itertools.product.__dict__.__contains__",                       ["__sizeof__"],   true]
    - ["it2641056", "itertools.product.__dict__.__contains__",                       ["__copy__"],     false]
    - ["it2641057", "itertools.product.__dict__.__contains__",                       ["__deepcopy__"], false]
    - ["it2641058", "itertools.permutations.__dict__.__contains__",                  ["__sizeof__"],   true]
    - ["it2641059", "itertools.combinations.__dict__.__contains__",                  ["__sizeof__"],   true]
    - ["it2641060", "itertools.combinations_with_replacement.__dict__.__contains__", ["__sizeof__"],   true]
    - ["it2641061", "itertools.chain.__dict__.__contains__",                         ["__sizeof__"],   false]
    - ["it2641062", "itertools.chain.__dict__.__contains__",                         ["__copy__"],     false]
    - ["it2641063", "itertools.chain.__dict__.__contains__",                         ["__deepcopy__"], false]
