spec: threading_extra2611
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 621 (_extra2611): __init_subclass__, __subclasshook__, and __class_getitem__ dict-presence checks for threading module types."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
    - "__init_subclass__ is absent from all threading types' own __dict__ — all False."
    - "__subclasshook__ is an ABCMeta hook; no threading type is an ABC, so all return False."
    - "__class_getitem__ is absent from all threading types — none define generic alias support — all False."
    - "threading.Lock is actually _thread.lock at runtime (a C-implemented type from the _thread module). Its __dict__.__contains__ calls use threading.Lock which resolves to this type."
    - "threading.local is actually _thread._local at runtime; its __name__ is '_local' but threading.local is the canonical public reference."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __init_subclass__ dict-presence for threading synchronization types
#
# threading.Thread, Lock, Event, Condition, Semaphore, BoundedSemaphore,
# Timer, Barrier, and local are the core threading module types. None define
# __init_subclass__ in their own __dict__; the hook is accessible only
# through MRO inheritance from object.
# ---------------------------------------------------------------------------

table threading_extra2611.init_subclass_absent:
  description: "threading types do not define __init_subclass__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2611

  columns: [id, function, args, expected]
  rows:
    - ["th2611001", "threading.Thread.__dict__.__contains__",          ["__init_subclass__"], false]
    - ["th2611002", "threading.Lock.__dict__.__contains__",            ["__init_subclass__"], false]
    - ["th2611003", "threading.Event.__dict__.__contains__",           ["__init_subclass__"], false]
    - ["th2611004", "threading.Condition.__dict__.__contains__",       ["__init_subclass__"], false]
    - ["th2611005", "threading.Semaphore.__dict__.__contains__",       ["__init_subclass__"], false]
    - ["th2611006", "threading.BoundedSemaphore.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th2611007", "threading.Timer.__dict__.__contains__",           ["__init_subclass__"], false]
    - ["th2611008", "threading.Barrier.__dict__.__contains__",         ["__init_subclass__"], false]
    - ["th2611009", "threading.local.__dict__.__contains__",           ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Table 2: __subclasshook__ dict-presence for threading types
#
# __subclasshook__ is specific to classes using ABCMeta. None of the
# threading synchronization or utility types are abstract base classes,
# so none define __subclasshook__ in their own __dict__.
# ---------------------------------------------------------------------------

table threading_extra2611.subclasshook_absent:
  description: "threading types do not define __subclasshook__ in their own __dict__ — none are ABCs"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2611

  columns: [id, function, args, expected]
  rows:
    - ["th2611010", "threading.Thread.__dict__.__contains__",          ["__subclasshook__"], false]
    - ["th2611011", "threading.Lock.__dict__.__contains__",            ["__subclasshook__"], false]
    - ["th2611012", "threading.Event.__dict__.__contains__",           ["__subclasshook__"], false]
    - ["th2611013", "threading.Condition.__dict__.__contains__",       ["__subclasshook__"], false]
    - ["th2611014", "threading.Semaphore.__dict__.__contains__",       ["__subclasshook__"], false]
    - ["th2611015", "threading.BoundedSemaphore.__dict__.__contains__", ["__subclasshook__"], false]
    - ["th2611016", "threading.Timer.__dict__.__contains__",           ["__subclasshook__"], false]
    - ["th2611017", "threading.Barrier.__dict__.__contains__",         ["__subclasshook__"], false]
    - ["th2611018", "threading.local.__dict__.__contains__",           ["__subclasshook__"], false]

# ---------------------------------------------------------------------------
# Table 3: __class_getitem__ dict-presence for threading types
#
# __class_getitem__ enables generic alias syntax (e.g. Thread[int]).
# No threading type defines it in its own __dict__. The threading module
# predates PEP 585 and its types were not updated to support generic aliases
# via __class_getitem__.
# ---------------------------------------------------------------------------

table threading_extra2611.class_getitem_checks:
  description: "threading types do not define __class_getitem__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2611

  columns: [id, function, args, expected]
  rows:
    - ["th2611019", "threading.Thread.__dict__.__contains__",          ["__class_getitem__"], false]
    - ["th2611020", "threading.Lock.__dict__.__contains__",            ["__class_getitem__"], false]
    - ["th2611021", "threading.Event.__dict__.__contains__",           ["__class_getitem__"], false]
    - ["th2611022", "threading.Condition.__dict__.__contains__",       ["__class_getitem__"], false]
    - ["th2611023", "threading.Semaphore.__dict__.__contains__",       ["__class_getitem__"], false]
    - ["th2611024", "threading.BoundedSemaphore.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th2611025", "threading.Timer.__dict__.__contains__",           ["__class_getitem__"], false]
    - ["th2611026", "threading.Barrier.__dict__.__contains__",         ["__class_getitem__"], false]
    - ["th2611027", "threading.local.__dict__.__contains__",           ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Table 4: Inherited hook accessibility via __qualname__
#
# Although __init_subclass__ is absent from each threading type's own
# __dict__, it is accessible via normal attribute lookup (MRO inheritance).
# For C-implemented types (Lock, local) the bound classmethod __qualname__
# reflects the C type's __name__. For Python-defined types (Thread, Event,
# Condition, Semaphore, BoundedSemaphore, Timer, Barrier) the qualname
# reflects the Python class name. This confirms the hook is live and
# reachable despite being absent from the class's own dict.
# ---------------------------------------------------------------------------

table threading_extra2611.object_inherited_hooks:
  description: "threading types inherit __init_subclass__ via MRO — qualname reflects per-class binding"
  kind: python_call_eq
  category: qualname_eq
  id_prefix: th2611

  columns: [id, function, args, expected]
  rows:
    - ["th2611028", "threading.Thread.__init_subclass__.__qualname__.__eq__",          ["Thread.__init_subclass__"],          true]
    - ["th2611029", "threading.Lock.__init_subclass__.__qualname__.__eq__",            ["lock.__init_subclass__"],            true]
    - ["th2611030", "threading.Event.__init_subclass__.__qualname__.__eq__",           ["Event.__init_subclass__"],           true]
    - ["th2611031", "threading.Condition.__init_subclass__.__qualname__.__eq__",       ["Condition.__init_subclass__"],       true]
    - ["th2611032", "threading.Semaphore.__init_subclass__.__qualname__.__eq__",       ["Semaphore.__init_subclass__"],       true]
    - ["th2611033", "threading.BoundedSemaphore.__init_subclass__.__qualname__.__eq__", ["BoundedSemaphore.__init_subclass__"], true]
    - ["th2611034", "threading.Timer.__init_subclass__.__qualname__.__eq__",           ["Timer.__init_subclass__"],           true]
    - ["th2611035", "threading.Barrier.__init_subclass__.__qualname__.__eq__",         ["Barrier.__init_subclass__"],         true]
    - ["th2611036", "threading.local.__init_subclass__.__qualname__.__eq__",           ["_local.__init_subclass__"],          true]
