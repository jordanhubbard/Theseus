spec: in3046
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 650 (in3046): __enter__, __exit__, __aenter__ dict-presence checks for inspect types."
    - "None of the inspect types define __enter__, __exit__, or __aenter__ in their own __dict__."
    - "inspect.Parameter, inspect.Signature, inspect.BoundArguments are pure Python classes."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception classes."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3046.enter:
  description: "inspect types __enter__ dict-presence checks; wave 650"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in3046
  columns: [id, function, args, expected]
  rows:
    - ["in3046001", operator.contains, [inspect.Parameter.__dict__,           "__enter__"], false]
    - ["in3046002", operator.contains, [inspect.Signature.__dict__,           "__enter__"], false]
    - ["in3046003", operator.contains, [inspect.BoundArguments.__dict__,      "__enter__"], false]
    - ["in3046004", operator.contains, [inspect.FrameInfo.__dict__,           "__enter__"], false]
    - ["in3046005", operator.contains, [inspect.ArgInfo.__dict__,             "__enter__"], false]
    - ["in3046006", operator.contains, [inspect.FullArgSpec.__dict__,         "__enter__"], false]
    - ["in3046007", operator.contains, [inspect.Attribute.__dict__,           "__enter__"], false]
    - ["in3046008", operator.contains, [inspect.ClassFoundException.__dict__,  "__enter__"], false]
    - ["in3046009", operator.contains, [inspect.EndOfBlock.__dict__,           "__enter__"], false]

