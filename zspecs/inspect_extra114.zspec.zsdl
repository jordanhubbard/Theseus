spec: inspect_extra114
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra113.zspec.zsdl."
    - "This spec covers: inspect.Parameter and inspect.Signature class identity — __name__, __module__, __qualname__; Parameter kind sentinel __class__.__name__; Parameter.empty and Signature.empty class identity; wave 265."
    - "inspect.Parameter.__name__ == 'Parameter' (len 9). Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect' (len 7). Verified with Python 3.14.3."
    - "inspect.Parameter.__qualname__ == 'Parameter' (same as __name__, top-level class). Verified with Python 3.14.3."
    - "inspect.Signature.__name__ == 'Signature' (len 9). Verified with Python 3.14.3."
    - "inspect.Signature.__module__ == 'inspect' (len 7). Verified with Python 3.14.3."
    - "inspect.Signature.__qualname__ == 'Signature' (same as __name__). Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' (len 14). Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "inspect.Signature.empty.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "inspect.Parameter.__base__.__name__ == 'object'. Verified with Python 3.14.3."
    - "inspect.Signature.__base__.__name__ == 'object'. Verified with Python 3.14.3."
    - "len(Parameter.__name__) == len(Signature.__name__) == 9. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter class identity
#
# Wave 265 theme: inspect.Parameter is a pure-Python class defined in
# Lib/inspect.py. Its __name__ is 'Parameter' (length 9: P-a-r-a-m-e-t-e-r),
# its __module__ is 'inspect' (length 7), and its __qualname__ is 'Parameter'
# (equal to __name__ since it is a top-level class). Its sole base class is
# object. The POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL,
# KEYWORD_ONLY, and VAR_KEYWORD class attributes are instances of the private
# _ParameterKind enum, whose __class__.__name__ is '_ParameterKind' (len 14).
#
# inspect.Parameter.__name__ == 'Parameter'
# inspect.Parameter.__module__ == 'inspect'
# inspect.Parameter.__qualname__ == 'Parameter'
# inspect.Parameter.__base__.__name__ == 'object'
# inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'
#
# New to extra114.
# ---------------------------------------------------------------------------

table inspect_extra114.parameter_class_identity:
  description: "inspect.Parameter class identity: __name__='Parameter'(9), __module__='inspect'(7), __qualname__='Parameter', base='object'; POSITIONAL_ONLY kind class '_ParameterKind'(14); wave 265; new to extra114"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectpci114

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_name,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — inspect.Parameter is a pure-Python class at module scope in Lib/inspect.py; its __name__ is 'Parameter' (len 9); str.__eq__('Parameter') returns True; new to extra114"]
    - [parameter_name_len,
       "Parameter.__name__.__len__",
       [],
       9,
       "inspect.Parameter.__name__.__len__() == 9 — 'Parameter' has 9 characters: P-a-r-a-m-e-t-e-r; str.__len__() returns 9; new to extra114"]
    - [parameter_module,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — inspect.Parameter is defined in the inspect module; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra114"]
    - [parameter_module_len,
       "Parameter.__module__.__len__",
       [],
       7,
       "inspect.Parameter.__module__.__len__() == 7 — 'inspect' has 7 characters: i-n-s-p-e-c-t; str.__len__() returns 7; new to extra114"]
    - [parameter_qualname,
       "Parameter.__qualname__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__.__eq__('Parameter') == True — inspect.Parameter is a top-level class; __qualname__ equals __name__; str.__eq__('Parameter') returns True; new to extra114"]
    - [parameter_base_object,
       "Parameter.__base__.__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__base__.__name__.__eq__('object') == True — Parameter directly inherits from object; __base__ is the first base class; its __name__ is 'object'; str.__eq__('object') returns True; new to extra114"]
    - [parameter_positional_only_kind,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is an instance of the private _ParameterKind enum; its class name is '_ParameterKind' (len 14); str.__eq__('_ParameterKind') returns True; new to extra114"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature class identity
#
# Wave 265 theme: inspect.Signature is a pure-Python class defined in
# Lib/inspect.py alongside Parameter. Its __name__ is 'Signature' (length 9:
# S-i-g-n-a-t-u-r-e — same length as 'Parameter'), its __module__ is 'inspect',
# and its __qualname__ is 'Signature' (equal to __name__). Its sole base
# class is object. The Signature.empty sentinel is a class (type) used to
# indicate absence of a return annotation, so Signature.empty.__class__.__name__
# is 'type'. Notably, Parameter.empty and Signature.empty are the same object.
#
# inspect.Signature.__name__ == 'Signature'
# inspect.Signature.__module__ == 'inspect'
# inspect.Signature.__qualname__ == 'Signature'
# inspect.Signature.__base__.__name__ == 'object'
# inspect.Signature.empty.__class__.__name__ == 'type'
#
# New to extra114.
# ---------------------------------------------------------------------------

table inspect_extra114.signature_class_identity:
  description: "inspect.Signature class identity: __name__='Signature'(9), __module__='inspect'(7), __qualname__='Signature', base='object'; Signature.empty class is 'type'; wave 265; new to extra114"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectsci114

  columns: [id, function, args, expected, description]
  rows:
    - [signature_name,
       "Signature.__name__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — inspect.Signature is a pure-Python class at module scope in Lib/inspect.py; its __name__ is 'Signature' (len 9); str.__eq__('Signature') returns True; new to extra114"]
    - [signature_name_len,
       "Signature.__name__.__len__",
       [],
       9,
       "inspect.Signature.__name__.__len__() == 9 — 'Signature' has 9 characters: S-i-g-n-a-t-u-r-e; same length as 'Parameter'; str.__len__() returns 9; new to extra114"]
    - [signature_module,
       "Signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — inspect.Signature is defined in the inspect module; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra114"]
    - [signature_qualname,
       "Signature.__qualname__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__qualname__.__eq__('Signature') == True — inspect.Signature is a top-level class; __qualname__ equals __name__; str.__eq__('Signature') returns True; new to extra114"]
    - [signature_empty_class,
       "Signature.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Signature.empty.__class__.__name__.__eq__('type') == True — Signature.empty is a class (a sentinel type indicating missing return annotation); its __class__ is the built-in type metaclass; str.__eq__('type') returns True; new to extra114"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter kind sentinel __class__.__name__
#
# Wave 265 theme: inspect.Parameter exposes five kind sentinels as class
# attributes: POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL,
# KEYWORD_ONLY, VAR_KEYWORD. All five are instances of the private
# _ParameterKind enum class. Thus their __class__.__name__ is '_ParameterKind'
# (length 14: underscore + ParameterKind). inspect.Parameter.empty and
# inspect.Signature.empty are the same sentinel class whose __class__.__name__
# is 'type' (len 4), not '_ParameterKind'.
#
# inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind'
# len('_ParameterKind') == 14
#
# New to extra114.
# ---------------------------------------------------------------------------

table inspect_extra114.parameter_kind_class_names:
  description: "inspect.Parameter kind sentinels all have __class__.__name__=='_ParameterKind'(14): POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD; Parameter.empty class is 'type'(4); wave 265; new to extra114"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectpkc114

  columns: [id, function, args, expected, description]
  rows:
    - [positional_or_keyword_kind,
       "Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_OR_KEYWORD is the most common parameter kind; its class is the private _ParameterKind enum; str.__eq__('_ParameterKind') returns True; new to extra114"]
    - [var_positional_kind,
       "Parameter.VAR_POSITIONAL.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__('_ParameterKind') == True — VAR_POSITIONAL corresponds to *args parameters; its class is the private _ParameterKind enum; str.__eq__('_ParameterKind') returns True; new to extra114"]
    - [keyword_only_kind,
       "Parameter.KEYWORD_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — KEYWORD_ONLY corresponds to parameters after *args; its class is the private _ParameterKind enum; str.__eq__('_ParameterKind') returns True; new to extra114"]
    - [var_keyword_kind,
       "Parameter.VAR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — VAR_KEYWORD corresponds to **kwargs parameters; its class is the private _ParameterKind enum; str.__eq__('_ParameterKind') returns True; new to extra114"]
    - [parameter_kind_name_len,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__len__",
       [],
       14,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__len__() == 14 — '_ParameterKind' has 14 characters: underscore(1) + P-a-r-a-m-e-t-e-r-K-i-n-d(13); str.__len__() returns 14; new to extra114"]
    - [parameter_empty_class,
       "Parameter.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is a sentinel class (not a _ParameterKind instance); its __class__ is the built-in type; str.__eq__('type') returns True; new to extra114"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra114
# ---------------------------------------------------------------------------

invariant inspect_extra114.parameter_name:
  description: "inspect.Parameter.__name__ == 'Parameter' — pure-Python class at module scope; length 9; wave 265; new to extra114"
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra114.signature_name:
  description: "inspect.Signature.__name__ == 'Signature' — pure-Python class at module scope; length 9; same length as Parameter; wave 265; new to extra114"
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra114.parameter_module:
  description: "inspect.Parameter.__module__ == 'inspect' — defined in the inspect module; length 7; wave 265; new to extra114"
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra114.parameter_kind_class_len:
  description: "len(inspect.Parameter.POSITIONAL_ONLY.__class__.__name__) == 14 — '_ParameterKind' is 14 chars; all five kind sentinels share this class; wave 265; new to extra114"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__len__
  args: []
  expected: 14

invariant inspect_extra114.signature_empty_class:
  description: "inspect.Signature.empty.__class__.__name__ == 'type' — empty sentinel is a class; __class__ is the built-in type; wave 265; new to extra114"
  kind: python_call_eq
  function: Signature.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

