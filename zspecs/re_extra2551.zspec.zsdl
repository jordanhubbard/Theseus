spec: re_extra2551
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2551 (_extra2551): __reduce__, __reduce_ex__, __getnewargs__ dict-presence checks for re classes."
    - "re.Pattern defines __copy__ and __deepcopy__ in its class dict, but NOT __reduce__, __reduce_ex__, or __getnewargs__."
    - "re.Match defines __copy__ and __deepcopy__ but NOT __reduce__, __reduce_ex__, or __getnewargs__."
    - "re.Pattern is picklable but relies on object.__reduce_ex__ inherited from the base C type."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

table re_extra2551.reduce_protocol:
  description: "re.Pattern and re.Match __reduce__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2551

  columns: [id, function, args, expected]
  rows:
    - ["re2551001", "re.Pattern.__dict__.__contains__", ["__reduce__"],    false]
    - ["re2551002", "re.Pattern.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["re2551003", "re.Pattern.__dict__.__contains__", ["__getnewargs__"], false]
    - ["re2551004", "re.Match.__dict__.__contains__",   ["__reduce__"],    false]
    - ["re2551005", "re.Match.__dict__.__contains__",   ["__reduce_ex__"], false]
    - ["re2551006", "re.Match.__dict__.__contains__",   ["__getnewargs__"], false]

table re_extra2551.copy_protocol:
  description: "re.Pattern and re.Match __copy__/__deepcopy__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2551c

  columns: [id, function, args, expected]
  rows:
    - ["re2551c001", "re.Pattern.__dict__.__contains__", ["__copy__"],     true]
    - ["re2551c002", "re.Pattern.__dict__.__contains__", ["__deepcopy__"], true]
    - ["re2551c003", "re.Match.__dict__.__contains__",   ["__copy__"],     true]
    - ["re2551c004", "re.Match.__dict__.__contains__",   ["__deepcopy__"], true]

table re_extra2551.getstate_protocol:
  description: "re.Pattern and re.Match __getstate__/__setstate__/__getnewargs_ex__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2551s

  columns: [id, function, args, expected]
  rows:
    - ["re2551s001", "re.Pattern.__dict__.__contains__", ["__getstate__"],      false]
    - ["re2551s002", "re.Pattern.__dict__.__contains__", ["__setstate__"],      false]
    - ["re2551s003", "re.Pattern.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["re2551s004", "re.Match.__dict__.__contains__",   ["__getstate__"],      false]
    - ["re2551s005", "re.Match.__dict__.__contains__",   ["__setstate__"],      false]
    - ["re2551s006", "re.Match.__dict__.__contains__",   ["__getnewargs_ex__"], false]
