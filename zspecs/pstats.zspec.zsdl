spec: pstats
version: ">=3.9"
backend: python_module(pstats)

docs: https://docs.python.org/3/library/profile.html#the-stats-class

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/profile.html#the-stats-class"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from: []
  notes:
    - "FunctionProfile and StatsProfile are dataclasses introduced in Python 3.9."
    - "SortKey is an enum class introduced in Python 3.7; __name__ check verifies the class is present."
    - "Stats method names are checked via unbound method objects on the class."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Raises standard Python exceptions; constructing Stats with no data raises TypeError."
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# Class identity
# ---------------------------------------------------------------------------

invariant pstats.Stats.class_name:
  description: "pstats.Stats.__name__ == 'Stats'"
  category: classes
  kind: python_call_eq
  function: Stats.__name__.__eq__
  args: ["Stats"]
  expected: true

invariant pstats.Stats.class_module:
  description: "pstats.Stats.__module__ == 'pstats'"
  category: classes
  kind: python_call_eq
  function: Stats.__module__.__eq__
  args: ["pstats"]
  expected: true

invariant pstats.FunctionProfile.class_name:
  description: "pstats.FunctionProfile.__name__ == 'FunctionProfile' (Python 3.9+)"
  category: classes
  kind: python_call_eq
  function: FunctionProfile.__name__.__eq__
  args: ["FunctionProfile"]
  expected: true

invariant pstats.StatsProfile.class_name:
  description: "pstats.StatsProfile.__name__ == 'StatsProfile' (Python 3.9+)"
  category: classes
  kind: python_call_eq
  function: StatsProfile.__name__.__eq__
  args: ["StatsProfile"]
  expected: true

invariant pstats.SortKey.class_name:
  description: "pstats.SortKey.__name__ == 'SortKey' (Python 3.7+ enum)"
  category: classes
  kind: python_call_eq
  function: SortKey.__name__.__eq__
  args: ["SortKey"]
  expected: true

# ---------------------------------------------------------------------------
# Stats method names
# ---------------------------------------------------------------------------

invariant pstats.Stats.sort_stats.method_name:
  description: "pstats.Stats.sort_stats.__name__ == 'sort_stats'"
  category: methods
  kind: python_call_eq
  function: Stats.sort_stats.__name__.__eq__
  args: ["sort_stats"]
  expected: true

invariant pstats.Stats.print_stats.method_name:
  description: "pstats.Stats.print_stats.__name__ == 'print_stats'"
  category: methods
  kind: python_call_eq
  function: Stats.print_stats.__name__.__eq__
  args: ["print_stats"]
  expected: true

invariant pstats.Stats.print_callers.method_name:
  description: "pstats.Stats.print_callers.__name__ == 'print_callers'"
  category: methods
  kind: python_call_eq
  function: Stats.print_callers.__name__.__eq__
  args: ["print_callers"]
  expected: true

invariant pstats.Stats.print_callees.method_name:
  description: "pstats.Stats.print_callees.__name__ == 'print_callees'"
  category: methods
  kind: python_call_eq
  function: Stats.print_callees.__name__.__eq__
  args: ["print_callees"]
  expected: true

invariant pstats.Stats.strip_dirs.method_name:
  description: "pstats.Stats.strip_dirs.__name__ == 'strip_dirs'"
  category: methods
  kind: python_call_eq
  function: Stats.strip_dirs.__name__.__eq__
  args: ["strip_dirs"]
  expected: true
