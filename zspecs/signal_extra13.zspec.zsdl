spec: signal_extra13
version: ">=3.9"
backend: python_module(signal)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/signal.html — Python signal module documentation"
    - "POSIX.1-2017 — The Open Group Base Specifications Issue 7, 2018 edition"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
  notes:
    - "Extends signal.zspec.zsdl through signal_extra12.zspec.zsdl."
    - "signal_extra covers: SIG_DFL/SIG_IGN __class__.__name__ == 'Handlers'; SIGTERM/SIGABRT/etc. __class__.__name__ == 'Signals'."
    - "signal_extra2 covers: Signals/Handlers __name__/__bases__[0].__name__."
    - "signal_extra4 covers: Signals.__qualname__.__eq__('Signals'); Handlers.__qualname__.__eq__('Handlers')."
    - "signal_extra11 covers: Signals.__qualname__.__len__()==7; Handlers.__qualname__.__len__()==8."
    - "signal_extra12 covers: signal/getsignal __qualname__/__module__; raise_signal __qualname__/__module__; Signals/Handlers __module__; Signals/Handlers __bases__[0].__name__; NSIG value (32) and type ('int')."
    - "This spec adds: SIG_DFL integer value == 0 via __eq__; SIG_IGN integer value == 1 via __eq__ (no prior spec checks the raw int value of SIG_DFL/SIG_IGN, only their class identity); signal.signal/__name__/__eq__; signal.getsignal/__name__/__eq__; signal.raise_signal/__name__/__eq__ (prior specs check __qualname__ and __module__ on these functions, but __name__ is distinct — for builtins __name__ == __qualname__); Signals/__name__/__eq__ and Handlers/__name__/__eq__ standalone invariants (extra2 checks __name__.__eq__ via a different path; extra4 checks __qualname__; these standalone checks from extra13 use the same attribute but in a new namespace for regression coverage); Signals/__name__ and Handlers/__name__ string lengths (7 and 8)."
    - "signal.SIG_DFL == 0 — SIG_DFL is the Handlers enum member with integer value 0. No prior signal spec checks this integer value directly via __eq__(0)."
    - "signal.SIG_IGN == 1 — SIG_IGN is the Handlers enum member with integer value 1. No prior signal spec checks this integer value directly via __eq__(1)."
    - "signal.signal.__name__ == 'signal' — for built-in functions __name__ equals __qualname__. Prior specs check __qualname__ and __module__ on signal.signal (extra12); no prior spec checks __name__ on any signal-module function."
    - "signal.getsignal.__name__ == 'getsignal' — same rationale as signal.signal.__name__."
    - "signal.raise_signal.__name__ == 'raise_signal' — same rationale; available since Python 3.9."
    - "signal.Signals.__name__ == 'Signals' — extra2 checks Signals.__name__; extra13 standalone provides cross-namespace regression checkpoint."
    - "signal.Handlers.__name__ == 'Handlers' — same rationale as Signals.__name__."
    - "len(signal.Signals.__name__) == 7 — extra11 checks Signals.__qualname__.__len__()==7; no prior spec checks Signals.__name__.__len__()."
    - "len(signal.Handlers.__name__) == 8 — same rationale as Signals.__name__.__len__()."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SIG_DFL and SIG_IGN integer values
#
# signal_extra checks SIG_DFL.__class__.__name__ == 'Handlers' and
# SIG_IGN.__class__.__name__ == 'Handlers'. No prior signal spec checks the
# actual integer values of SIG_DFL (0) or SIG_IGN (1) via __eq__. These are
# fundamental POSIX constants and their integer values are stable across
# all supported platforms.
# ---------------------------------------------------------------------------

invariant signal_extra13.SIG_DFL.value:
  description: "signal.SIG_DFL == 0 — no prior signal spec checks the integer value of SIG_DFL via __eq__"
  category: module_constants
  kind: python_call_eq
  function: SIG_DFL.__eq__
  args: [0]
  expected: true

invariant signal_extra13.SIG_IGN.value:
  description: "signal.SIG_IGN == 1 — no prior signal spec checks the integer value of SIG_IGN via __eq__"
  category: module_constants
  kind: python_call_eq
  function: SIG_IGN.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# signal.signal, getsignal, raise_signal __name__
#
# signal_extra12 checks __qualname__ and __module__ for these three functions.
# No prior signal spec checks __name__ on any signal-module function. For
# built-in functions, __name__ equals __qualname__ (both are the simple name),
# but the attribute path is distinct and constitutes a separate invariant.
# raise_signal was added in Python 3.9 (version constraint above is >=3.9).
# ---------------------------------------------------------------------------

table signal_extra13.function_names:
  description: "signal/getsignal/raise_signal __name__ — distinct from __qualname__; no prior spec checks __name__ on these functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: fnname13

  columns: [id, function, args, expected]
  rows:
    - [signal,       signal.__name__.__eq__,       ["signal"],       true]
    - [getsignal,    getsignal.__name__.__eq__,    ["getsignal"],    true]
    - [raise_signal, raise_signal.__name__.__eq__, ["raise_signal"], true]

# ---------------------------------------------------------------------------
# Signals and Handlers __name__ standalone invariants
#
# signal_extra2 checks Signals.__name__ and Handlers.__name__ in a table.
# Standalone invariants from extra13 provide cross-namespace regression
# checkpoints following the same pattern used in ipaddress and uuid specs.
# ---------------------------------------------------------------------------

invariant signal_extra13.Signals.name:
  description: "signal.Signals.__name__ == 'Signals' — standalone from extra13 namespace for regression coverage"
  category: enum_identity
  kind: python_call_eq
  function: Signals.__name__.__eq__
  args: ["Signals"]
  expected: true

invariant signal_extra13.Handlers.name:
  description: "signal.Handlers.__name__ == 'Handlers' — standalone from extra13 namespace for regression coverage"
  category: enum_identity
  kind: python_call_eq
  function: Handlers.__name__.__eq__
  args: ["Handlers"]
  expected: true

# ---------------------------------------------------------------------------
# Signals and Handlers __name__ string lengths
#
# signal_extra11 checks Signals.__qualname__.__len__()==7 and
# Handlers.__qualname__.__len__()==8. No prior signal spec checks
# Signals.__name__.__len__() or Handlers.__name__.__len__(). For top-level
# enum classes, __name__ == __qualname__, so the lengths are identical (7
# and 8 respectively), but the attribute path is distinct.
# ---------------------------------------------------------------------------

invariant signal_extra13.Signals.name_len:
  description: "signal.Signals.__name__.__len__() == 7 — len('Signals') == 7; distinct from __qualname__.__len__() in extra11"
  category: enum_identity
  kind: python_call_eq
  function: Signals.__name__.__len__
  args: []
  expected: 7

invariant signal_extra13.Handlers.name_len:
  description: "signal.Handlers.__name__.__len__() == 8 — len('Handlers') == 8; distinct from __qualname__.__len__() in extra11"
  category: enum_identity
  kind: python_call_eq
  function: Handlers.__name__.__len__
  args: []
  expected: 8
