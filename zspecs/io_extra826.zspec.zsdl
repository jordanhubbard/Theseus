spec: io_extra826
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython/Lib/io.py"
    - "cpython/Modules/_io/_iomodule.c"
  not_derived_from:
    - "any third-party io library"
  notes:
    - "Covers __qualname__ values for io.IOBase instance methods"
    - "All qualnames follow the 'ClassName.method_name' pattern"
  created_at: "2026-04-12"

table io_extra826.iobase_qualnames:
