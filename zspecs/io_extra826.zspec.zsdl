    - [io826ib004, "io.IOBase.readline.__qualname__.__eq__", ["IOBase.readline"], true]
    - [io826ib005, "io.IOBase.readlines.__qualname__.__eq__", ["IOBase.readlines"], true]
    - [io826ib006, "io.IOBase.seek.__qualname__.__eq__", ["IOBase.seek"], true]
    - [io826ib007, "io.IOBase.seekable.__qualname__.__eq__", ["IOBase.seekable"], true]
    - [io826ib008, "io.IOBase.tell.__qualname__.__eq__", ["IOBase.tell"], true]
    - [io826ib009, "io.IOBase.truncate.__qualname__.__eq__", ["IOBase.truncate"], true]
    - [io826ib010, "io.IOBase.writable.__qualname__.__eq__", ["IOBase.writable"], true]
