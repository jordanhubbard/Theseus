spec: tornado
version: ">=6.0"
backend: python_module(tornado)

docs: https://www.tornadoweb.org/en/stable/

provenance:
  derived_from:
    - "Tornado documentation — https://www.tornadoweb.org/en/stable/"
    - "tornado.escape API — https://www.tornadoweb.org/en/stable/escape.html"
    - "tornado.web API — https://www.tornadoweb.org/en/stable/web.html"
    - "tornado.ioloop API — https://www.tornadoweb.org/en/stable/ioloop.html"
    - "tornado.httpclient API — https://www.tornadoweb.org/en/stable/httpclient.html"
    - "Test vectors verified with tornado 6.5.5 on Python 3.14 / macOS Darwin 25.4.0, 2026-04-05"
  not_derived_from:
    - "tornado source: tornado/escape.py"
    - "tornado source: tornado/web.py"
    - "tornado source: tornado/ioloop.py"
    - "tornado source: tornado/httpclient.py"
  notes:
    - "tornado does not expose __version__; it uses tornado.version (str) and tornado.version_info (tuple)."
    - "tornado.httpclient.HTTPError is an alias for HTTPClientError; __name__ returns 'HTTPClientError'."
    - "escape.xhtml_escape converts < and > to &lt; and &gt; HTML entities."
    - "escape.url_escape encodes spaces as '+' (form encoding) by default."
    - "escape.json_encode returns a compact JSON string with no extra whitespace."
    - "Submodules (tornado.web, tornado.ioloop, tornado.httpclient, tornado.escape) are preloaded so dotted paths resolve via getattr chain from the module root."
    - "Dotted function names (e.g. 'escape.xhtml_escape') are resolved by the harness via chained getattr from the module root."
  created_at: "2026-04-05T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version — tornado.version is a dotted version string; version_info[0] >= 6
# ---------------------------------------------------------------------------

invariant tornado.version.contains_dot:
  description: "tornado.version contains a dot separator between major and minor"
  category: version
  kind: python_call_eq
  function: version.__contains__
  args: ["."]
  expected: true

invariant tornado.version.info_major_ge_6:
  description: "tornado.version_info[0] == 6 (major version is 6)"
  category: version
  kind: python_call_eq
  function: version_info.__getitem__
  args: [0]
  expected: 6

invariant tornado.version.info_is_tuple:
  description: "tornado.version_info is a tuple (type name == 'tuple')"
  category: version
  kind: python_call_eq
  function: version_info.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# escape — HTML entity encoding and decoding
# ---------------------------------------------------------------------------

invariant tornado.escape.xhtml_escape_tag:
  description: "escape.xhtml_escape('<b>') == '&lt;b&gt;'"
  category: escape
  kind: python_call_eq
  function: escape.xhtml_escape
  args: ["<b>"]
  expected: "&lt;b&gt;"

invariant tornado.escape.xhtml_escape_full:
  description: "escape.xhtml_escape('<b>hello</b>') == '&lt;b&gt;hello&lt;/b&gt;'"
  category: escape
  kind: python_call_eq
  function: escape.xhtml_escape
  args: ["<b>hello</b>"]
  expected: "&lt;b&gt;hello&lt;/b&gt;"

invariant tornado.escape.xhtml_unescape_entities:
  description: "escape.xhtml_unescape('&lt;b&gt;') == '<b>'"
  category: escape
  kind: python_call_eq
  function: escape.xhtml_unescape
  args: ["&lt;b&gt;"]
  expected: "<b>"

invariant tornado.escape.url_escape_space:
  description: "escape.url_escape('hello world') encodes the space as '+' (form encoding)"
  category: escape
  kind: python_call_eq
  function: escape.url_escape
  args: ["hello world"]
  expected: "hello+world"

invariant tornado.escape.url_unescape_plus:
  description: "escape.url_unescape('hello+world') decodes '+' back to a space"
  category: escape
  kind: python_call_eq
  function: escape.url_unescape
  args: ["hello+world"]
  expected: "hello world"

# ---------------------------------------------------------------------------
# json — JSON encode and decode
# ---------------------------------------------------------------------------

invariant tornado.escape.json_decode_key:
  description: "escape.json_decode('{\"a\":1}')['a'] == 1"
  category: escape
  kind: python_call_eq
  function: escape.json_decode
  args: ['{"a":1}']
  method: __getitem__
  method_args: ["a"]
  expected: 1

invariant tornado.escape.json_encode_callable:
  description: "escape.json_encode is callable (json_encode.__name__ == 'json_encode')"
  category: escape
  kind: python_call_eq
  function: escape.json_encode.__name__.__eq__
  args: ["json_encode"]
  expected: true

# ---------------------------------------------------------------------------
# classes — core public classes exported by tornado submodules
# ---------------------------------------------------------------------------

invariant tornado.classes.request_handler_name:
  description: "web.RequestHandler.__name__ == 'RequestHandler'"
  category: classes
  kind: python_call_eq
  function: web.RequestHandler.__name__.__eq__
  args: ["RequestHandler"]
  expected: true

invariant tornado.classes.application_name:
  description: "web.Application.__name__ == 'Application'"
  category: classes
  kind: python_call_eq
  function: web.Application.__name__.__eq__
  args: ["Application"]
  expected: true

invariant tornado.classes.ioloop_name:
  description: "ioloop.IOLoop.__name__ == 'IOLoop'"
  category: classes
  kind: python_call_eq
  function: ioloop.IOLoop.__name__.__eq__
  args: ["IOLoop"]
  expected: true

invariant tornado.classes.httpclient_error_name:
  description: "httpclient.HTTPError.__name__ == 'HTTPClientError' (HTTPError is an alias)"
  category: classes
  kind: python_call_eq
  function: httpclient.HTTPError.__name__.__eq__
  args: ["HTTPClientError"]
  expected: true

invariant tornado.classes.httprequest_name:
  description: "httpclient.HTTPRequest.__name__ == 'HTTPRequest'"
  category: classes
  kind: python_call_eq
  function: httpclient.HTTPRequest.__name__.__eq__
  args: ["HTTPRequest"]
  expected: true
