spec: hashlib_extra300
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "hashlib.md5.__name__ == 'openssl_md5' — the constructor function is the OpenSSL-backed wrapper."
    - "hashlib.sha256.__name__ == 'openssl_sha256' — similarly backed by OpenSSL on macOS/Darwin."
    - "hashlib.md5(b'').__class__.__name__ == 'HASH' — all OpenSSL-backed hash objects share the HASH class."
    - "hashlib.sha256(b'').__class__.__name__ == 'HASH' — same HASH class for sha256."
    - "hashlib.sha512(b'').__class__.__name__ == 'HASH' — same HASH class for sha512."
    - "hashlib.sha1(b'').__class__.__name__ == 'HASH' — same HASH class for sha1."
    - "hashlib.sha3_256(b'').__class__.__name__ == 'HASH' — same HASH class for sha3_256."
    - "hashlib.blake2b(b'').__class__.__name__ == 'blake2b' — blake2b has its own dedicated class."
    - "hashlib.md5(b'').name == 'md5' — .name attribute returns the algorithm name string."
    - "hashlib.sha256(b'').name == 'sha256' — .name attribute returns the algorithm name string."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "hashlib raises ValueError for unknown algorithm names."
  stderr: "null"
  stickiness: "N/A — hash objects are independent; results are deterministic for fixed inputs."
  codes: {}

# ---------------------------------------------------------------------------
# Constructor function names — OpenSSL-backed on macOS
# ---------------------------------------------------------------------------

invariant hashlib_extra300.md5.function_name:
  description: "hashlib.md5.__name__ == 'openssl_md5' — the md5 constructor is the OpenSSL-backed wrapper on macOS/Darwin"
  category: function_identity
  kind: python_call_eq
  function: md5.__name__.__eq__
  args: ["openssl_md5"]
  expected: true

invariant hashlib_extra300.sha256.function_name:
  description: "hashlib.sha256.__name__ == 'openssl_sha256' — the sha256 constructor is the OpenSSL-backed wrapper on macOS/Darwin"
  category: function_identity
  kind: python_call_eq
  function: sha256.__name__.__eq__
  args: ["openssl_sha256"]
  expected: true

# ---------------------------------------------------------------------------
# Hash object class names — HASH for OpenSSL-backed, dedicated for blake2b
# ---------------------------------------------------------------------------

invariant hashlib_extra300.md5.class_name:
  description: "hashlib.md5(b'').__class__.__name__ == 'HASH' — OpenSSL-backed hash objects share the HASH class"
  category: class_identity
  kind: python_call_eq
  function: md5
  args: [""]
  method: __class__.__name__.__eq__
  method_args: ["HASH"]
  expected: true

invariant hashlib_extra300.sha256.class_name:
  description: "hashlib.sha256(b'').__class__.__name__ == 'HASH' — sha256 hash object is HASH class"
  category: class_identity
  kind: python_call_eq
  function: sha256
  args: [""]
  method: __class__.__name__.__eq__
  method_args: ["HASH"]
  expected: true

invariant hashlib_extra300.sha512.class_name:
  description: "hashlib.sha512(b'').__class__.__name__ == 'HASH' — sha512 hash object is HASH class"
  category: class_identity
  kind: python_call_eq
  function: sha512
  args: [""]
  method: __class__.__name__.__eq__
  method_args: ["HASH"]
  expected: true

invariant hashlib_extra300.sha1.class_name:
  description: "hashlib.sha1(b'').__class__.__name__ == 'HASH' — sha1 hash object is HASH class"
  category: class_identity
  kind: python_call_eq
  function: sha1
  args: [""]
  method: __class__.__name__.__eq__
  method_args: ["HASH"]
  expected: true

invariant hashlib_extra300.sha3_256.class_name:
  description: "hashlib.sha3_256(b'').__class__.__name__ == 'HASH' — sha3_256 hash object is HASH class"
  category: class_identity
  kind: python_call_eq
  function: sha3_256
  args: [""]
  method: __class__.__name__.__eq__
  method_args: ["HASH"]
  expected: true

invariant hashlib_extra300.blake2b.class_name:
  description: "hashlib.blake2b(b'').__class__.__name__ == 'blake2b' — blake2b has its own dedicated class, not HASH"
  category: class_identity
  kind: python_call_eq
  function: blake2b
  args: [""]
  method: __class__.__name__.__eq__
  method_args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# Hash object .name attribute — algorithm name strings
# ---------------------------------------------------------------------------

invariant hashlib_extra300.md5.name_attr:
  description: "hashlib.md5(b'').name == 'md5' — .name returns the canonical algorithm name string"
  category: name_identity
  kind: python_call_eq
  function: md5
  args: [""]
  method: name.__eq__
  method_args: ["md5"]
  expected: true

invariant hashlib_extra300.sha256.name_attr:
  description: "hashlib.sha256(b'').name == 'sha256' — .name returns the canonical algorithm name string"
  category: name_identity
  kind: python_call_eq
  function: sha256
  args: [""]
  method: name.__eq__
  method_args: ["sha256"]
  expected: true
