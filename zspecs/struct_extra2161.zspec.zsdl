spec: struct_extra2161
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/struct.html"
    - "CPython source: Modules/_struct.c"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2161: descriptor protocol dict-presence — __get__, __set__, __delete__, __set_name__, fget, fset, fdel, __objclass__, __func__."
    - "struct.Struct is a C extension type. It is NOT a descriptor class — it does not define __get__/__set__/__delete__ in its own __dict__."
    - "struct.error is a plain exception subclass. It defines none of the descriptor protocol attrs in its own __dict__."
    - "struct.Struct.__dict__ contains getset_descriptor objects (format, size) which are themselves descriptors, but Struct itself is not."
    - "struct.Struct.__dict__ contains the expected C-extension methods: pack, unpack, pack_into, unpack_from, iter_unpack, __sizeof__."
    - "struct.error.__dict__ contains __weakref__ (getset_descriptor), __doc__, and __module__ but no descriptor protocol attrs."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2161.struct_descriptor_protocol:
  description: "struct.Struct descriptor protocol dict-presence — Struct is a C extension type, not a descriptor class"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2161

  columns: [id, function, args, expected]
  rows:
    - ["st2161001", "struct.Struct.__dict__.__contains__", ["__get__"], false]
    - ["st2161002", "struct.Struct.__dict__.__contains__", ["__set__"], false]
    - ["st2161003", "struct.Struct.__dict__.__contains__", ["__delete__"], false]
    - ["st2161004", "struct.Struct.__dict__.__contains__", ["__set_name__"], false]
    - ["st2161005", "struct.Struct.__dict__.__contains__", ["fget"], false]
    - ["st2161006", "struct.Struct.__dict__.__contains__", ["fset"], false]
    - ["st2161007", "struct.Struct.__dict__.__contains__", ["fdel"], false]
    - ["st2161008", "struct.Struct.__dict__.__contains__", ["__objclass__"], false]
    - ["st2161009", "struct.Struct.__dict__.__contains__", ["__func__"], false]

table struct_extra2161.error_descriptor_protocol:
  description: "struct.error descriptor protocol dict-presence — error is a plain exception subclass, not a descriptor class"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2161

  columns: [id, function, args, expected]
  rows:
    - ["st2161010", "struct.error.__dict__.__contains__", ["__get__"], false]
    - ["st2161011", "struct.error.__dict__.__contains__", ["__set__"], false]
    - ["st2161012", "struct.error.__dict__.__contains__", ["__delete__"], false]
    - ["st2161013", "struct.error.__dict__.__contains__", ["__set_name__"], false]
    - ["st2161014", "struct.error.__dict__.__contains__", ["fget"], false]
    - ["st2161015", "struct.error.__dict__.__contains__", ["fset"], false]
    - ["st2161016", "struct.error.__dict__.__contains__", ["fdel"], false]
    - ["st2161017", "struct.error.__dict__.__contains__", ["__objclass__"], false]
    - ["st2161018", "struct.error.__dict__.__contains__", ["__func__"], false]

table struct_extra2161.struct_dict_keys:
  description: "struct.Struct.__dict__ contains the expected C-extension method and attribute keys"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2161

  columns: [id, function, args, expected]
  rows:
    - ["st2161019", "struct.Struct.__dict__.__contains__", ["format"], true]
    - ["st2161020", "struct.Struct.__dict__.__contains__", ["size"], true]
    - ["st2161021", "struct.Struct.__dict__.__contains__", ["pack"], true]
    - ["st2161022", "struct.Struct.__dict__.__contains__", ["unpack"], true]
    - ["st2161023", "struct.Struct.__dict__.__contains__", ["pack_into"], true]
    - ["st2161024", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st2161025", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st2161026", "struct.Struct.__dict__.__contains__", ["__sizeof__"], true]

table struct_extra2161.error_dict_keys:
  description: "struct.error.__dict__ contains its minimal set of keys; descriptor-protocol attrs absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2161

  columns: [id, function, args, expected]
  rows:
    - ["st2161027", "struct.error.__dict__.__contains__", ["__weakref__"], true]
    - ["st2161028", "struct.error.__dict__.__contains__", ["__doc__"], true]
    - ["st2161029", "struct.error.__dict__.__contains__", ["__module__"], true]
    - ["st2161030", "struct.error.__dict__.__contains__", ["__init__"], false]
