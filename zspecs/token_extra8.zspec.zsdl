spec: token_extra8
version: ">=3.12"
backend: python_module(token)

docs: https://docs.python.org/3/library/token.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/token.html — Python token module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/token.py"
    - "token.zspec.zsdl — covers ENDMARKER=0, NAME=1, NUMBER=2, STRING=3, NEWLINE=4, INDENT=5, DEDENT=6, OP=55, TYPE_COMMENT=57, SOFT_KEYWORD=58, COMMENT=65, NL=66, ERRORTOKEN=67, ENCODING=68 exact values; NT_OFFSET=256; tok_name lookups [0-6]; ISEOF/ISTERMINAL/ISNONTERMINAL predicates"
    - "token_extra.zspec.zsdl — covers int type checks for all major constants, tok_name/EXACT_TOKEN_TYPES is_dict, NAME/NUMBER/STRING/NEWLINE/ENDMARKER exact values"
    - "token_extra2.zspec.zsdl — covers EXACT_TYPE/ERRORTOKEN/ENCODING/TYPE_COMMENT is_int, tok_name is_dict, tok_name min_length>=50, tok_name[0-4], ENDMARKER==0"
    - "token_extra3.zspec.zsdl — covers int type checks via tables, tok_name/EXACT_TOKEN_TYPES is_dict, NAME>0/NUMBER>0/ENDMARKER==0, tok_name[1]=='NAME'"
    - "token_extra4.zspec.zsdl — covers INDENT==5, DEDENT==6, tok_name[2-6], EXACT_TOKEN_TYPES membership '='/'+'/':'"
    - "token_extra5.zspec.zsdl — covers SOFT_KEYWORD==58, FSTRING_START==59, FSTRING_END==61, tok_name[58/59], EXACT_TOKEN_TYPES len>=40 and membership '('/')'/'.'"
    - "token_extra6.zspec.zsdl — covers ISEOF(2)/ISEOF(255) false; ISTERMINAL(0)/ISTERMINAL(255) true/ISTERMINAL(256) false; ISNONTERMINAL(256) true/ISNONTERMINAL(255) false; tok_name.__contains__(0/1/65/66); EXACT_TOKEN_TYPES.__contains__('-'/'*'); EXACT_TOKEN_TYPES['='] is int"
    - "token_extra7.zspec.zsdl — covers ISEOF/ISTERMINAL/ISNONTERMINAL __module__=='token'; tok_name[65-68]; EXACT_TOKEN_TYPES.__contains__('/'/'%'/'**'/'//'); ISEOF(3/4/5/6) false; ISTERMINAL(3) true/ISTERMINAL(500) false"
  notes:
    - "This spec adds new axes not covered in any prior token spec."
    - "FSTRING_MIDDLE==60 — not tested in any prior spec (token_extra5 covers FSTRING_START=59 and FSTRING_END=61 but not FSTRING_MIDDLE)."
    - "TSTRING_START==62/TSTRING_MIDDLE==63/TSTRING_END==64 — not tested in any prior spec."
    - "N_TOKENS==69 — not tested in any prior spec."
    - "TYPE_IGNORE==56 — not tested in any prior spec."
    - "tok_name[7]=='LPAR' and tok_name[8]=='RPAR' — not tested in any prior spec (prior specs cover indices 0-6, 58, 59, 65-68)."
    - "EXACT_TOKEN_TYPES.__contains__('!=') == True — not tested in any prior spec."
    - "EXACT_TOKEN_TYPES.__contains__('==') == True — not tested in any prior spec."
    - "tok_name.__contains__(60) — FSTRING_MIDDLE key presence not tested in any prior spec."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# FSTRING_MIDDLE and TSTRING_ family constants — exact values
# token_extra5 covers FSTRING_START(59) and FSTRING_END(61); FSTRING_MIDDLE(60)
# and the entire TSTRING family (62/63/64) are not covered in any prior spec.
# ---------------------------------------------------------------------------

table token_extra8.fstring_tstring_constants:
  kind: python_call_eq
  category: constants
  id_prefix: fstrt_const

  columns: [id, function, args, expected]
  rows:
    - [fstring_middle,  FSTRING_MIDDLE.__eq__,  [60], true]
    - [tstring_start,   TSTRING_START.__eq__,   [62], true]
    - [tstring_middle,  TSTRING_MIDDLE.__eq__,  [63], true]
    - [tstring_end,     TSTRING_END.__eq__,     [64], true]

# ---------------------------------------------------------------------------
# N_TOKENS and TYPE_IGNORE exact values
# Neither is covered in any prior token spec.
# ---------------------------------------------------------------------------

invariant token_extra8.N_TOKENS.value:
  description: "token.N_TOKENS == 69 — number of token types in Python 3.14"
  category: constants
  kind: python_call_eq
  function: N_TOKENS.__eq__
  args: [69]
  expected: true

invariant token_extra8.TYPE_IGNORE.value:
  description: "token.TYPE_IGNORE == 56"
  category: constants
  kind: python_call_eq
  function: TYPE_IGNORE.__eq__
  args: [56]
  expected: true

# ---------------------------------------------------------------------------
# tok_name lookups for LPAR(7), RPAR(8), LSQB(9), RSQB(10)
# Prior specs cover indices 0-6, 58, 59, 65-68; indices 7-10 are new.
# ---------------------------------------------------------------------------

table token_extra8.tok_name_bracket_lookups:
  kind: python_call_eq
  category: tok_name
  id_prefix: tok_name_brk

  columns: [id, function, args, expected]
  rows:
    - [lpar, tok_name.__getitem__, [7],  "LPAR"]
    - [rpar, tok_name.__getitem__, [8],  "RPAR"]
    - [lsqb, tok_name.__getitem__, [9],  "LSQB"]
    - [rsqb, tok_name.__getitem__, [10], "RSQB"]

# ---------------------------------------------------------------------------
# tok_name.__contains__ for FSTRING_MIDDLE(60)
# token_extra6 checks __contains__ for indices 0, 1, 65, 66.
# Index 60 (FSTRING_MIDDLE) is not checked in any prior spec.
# ---------------------------------------------------------------------------

invariant token_extra8.tok_name.has_fstring_middle:
  description: "60 in token.tok_name == True — FSTRING_MIDDLE(60) is in tok_name"
  category: tok_name
  kind: python_call_eq
  function: tok_name.__contains__
  args: [60]
  expected: true

# ---------------------------------------------------------------------------
# EXACT_TOKEN_TYPES — comparison operator membership
# Prior specs cover '=', '+', ':', '-', '*', '/', '%', '**', '//', '(', ')', '.'.
# New here: '!=' and '==' which are two-char comparison operators.
# ---------------------------------------------------------------------------

invariant token_extra8.EXACT_TOKEN_TYPES.has_notequal:
  description: "token.EXACT_TOKEN_TYPES.__contains__('!=') == True"
  category: dict_contents
  kind: python_call_eq
  function: EXACT_TOKEN_TYPES.__contains__
  args: ["!="]
  expected: true

invariant token_extra8.EXACT_TOKEN_TYPES.has_eqequal:
  description: "token.EXACT_TOKEN_TYPES.__contains__('==') == True"
  category: dict_contents
  kind: python_call_eq
  function: EXACT_TOKEN_TYPES.__contains__
  args: ["=="]
  expected: true

# ---------------------------------------------------------------------------
# ISNONTERMINAL for additional values
# token_extra6 covers ISNONTERMINAL(256)==True and ISNONTERMINAL(255)==False.
# New here: ISNONTERMINAL(300)==True (well above NT_OFFSET).
# ---------------------------------------------------------------------------

invariant token_extra8.ISNONTERMINAL.above_nt_offset_true:
  description: "token.ISNONTERMINAL(300) == True — 300 > NT_OFFSET(256) so non-terminal"
  category: predicates
  kind: python_call_eq
  function: ISNONTERMINAL
  args: [300]
  expected: true
