spec: re_extra180
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.Pattern method names — match, search, fullmatch, findall, finditer, sub, subn, split — and re.Pattern.flags descriptor class."
    - "re.Pattern.match.__name__ == 'match' (len=5); re.Pattern.search.__name__ == 'search' (len=6)."
    - "re.Pattern.fullmatch.__name__ == 'fullmatch' (len=9); re.Pattern.findall.__name__ == 'findall' (len=7)."
    - "re.Pattern.finditer.__name__ == 'finditer' (len=8); re.Pattern.sub.__name__ == 'sub' (len=3)."
    - "re.Pattern.subn.__name__ == 'subn' (len=4); re.Pattern.split.__name__ == 'split' (len=5)."
    - "re.Pattern.flags.__class__.__name__ == 'getset_descriptor' — flags is a C-level attribute descriptor."
    - "Name length groupings: sub (3); subn (4); match==split (5); search (6); findall (7); finditer (8); fullmatch (9)."
    - "match==split (5): a 2-way tie at length 5."
    - "sub (3) is the shortest; fullmatch (9) is the longest method name covered."
    - "Length ordering: sub (3) < subn (4) < match==split (5) < search (6) < findall (7) < finditer (8) < fullmatch (9)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.Pattern short method names (sub, subn, match, split, search)
# sub (3) < subn (4) < match==split (5) < search (6)
# ---------------------------------------------------------------------------

table re_extra180.short_method_names:
  description: "re.Pattern short method names: sub.__name__=='sub' (len=3); subn.__name__=='subn' (len=4); match.__name__=='match' (len=5); split.__name__=='split' (len=5); search.__name__=='search' (len=6); sub (3) < subn (4) < match==split (5) < search (6)"
  kind: python_call_eq
  category: identity
  id_prefix: repatternmethods180

  columns: [id, function, args, expected, description]
  rows:
    - [sub_name,      Pattern.sub.__name__.__eq__,      ["sub"],    true, "re.Pattern.sub.__name__ == 'sub' — sub() replaces matches with a replacement string; 'sub' has 3 characters: s(1)u(2)b(3); sub (3) is the shortest re.Pattern method name covered; sub (3) < subn (4) < match==split (5): strict ascending order; confirmed Python 3.14.3 macOS"]
    - [sub_name_len,  Pattern.sub.__name__.__len__,     [],         3,    "re.Pattern.sub.__name__.__len__() == 3 — 'sub' has 3 characters; sub (3) is the minimum length among all covered Pattern method names; sub (3) < subn (4) < match==split (5) < search (6) < findall (7) < finditer (8) < fullmatch (9): the full ordering; confirmed Python 3.14.3 macOS"]
    - [subn_name,     Pattern.subn.__name__.__eq__,     ["subn"],   true, "re.Pattern.subn.__name__ == 'subn' — subn() is like sub() but also returns the substitution count; 'subn' has 4 characters: s(1)u(2)b(3)n(4); subn (4) > sub (3) by 1: the 'n' suffix adds one character; subn (4) < match==split (5); confirmed Python 3.14.3 macOS"]
    - [subn_name_len, Pattern.subn.__name__.__len__,    [],         4,    "re.Pattern.subn.__name__.__len__() == 4 — 'subn' has 4 characters; subn (4) is uniquely length 4 among covered Pattern method names; sub (3) < subn (4) < match==split (5): subn is strictly between sub and match in the length ordering; confirmed Python 3.14.3 macOS"]
    - [match_name,    Pattern.match.__name__.__eq__,    ["match"],  true, "re.Pattern.match.__name__ == 'match' — match() tries to match the pattern at the beginning of the string; 'match' has 5 characters: m(1)a(2)t(3)c(4)h(5); match (5) == split (5): a 2-way tie at length 5; confirmed Python 3.14.3 macOS"]
    - [match_name_len, Pattern.match.__name__.__len__,  [],         5,    "re.Pattern.match.__name__.__len__() == 5 — 'match' has 5 characters; match (5) == split (5): both share length 5; subn (4) < match==split (5) < search (6): match is in the middle of the short method group; confirmed Python 3.14.3 macOS"]
    - [split_name,    Pattern.split.__name__.__eq__,    ["split"],  true, "re.Pattern.split.__name__ == 'split' — split() splits the string by occurrences of the pattern; 'split' has 5 characters: s(1)p(2)l(3)i(4)t(5); split (5) == match (5): a 2-way tie at length 5; confirmed Python 3.14.3 macOS"]
    - [split_name_len, Pattern.split.__name__.__len__,  [],         5,    "re.Pattern.split.__name__.__len__() == 5 — 'split' has 5 characters; split (5) == match (5): both share length 5; subn (4) < split==match (5) < search (6); confirmed Python 3.14.3 macOS"]
    - [search_name,   Pattern.search.__name__.__eq__,   ["search"], true, "re.Pattern.search.__name__ == 'search' — search() scans through the string looking for the first match; 'search' has 6 characters: s(1)e(2)a(3)r(4)c(5)h(6); search (6) is uniquely length 6 among covered Pattern method names; match==split (5) < search (6) < findall (7); confirmed Python 3.14.3 macOS"]
    - [search_name_len, Pattern.search.__name__.__len__, [],        6,    "re.Pattern.search.__name__.__len__() == 6 — 'search' has 6 characters; search (6) is uniquely length 6; match==split (5) < search (6) < findall (7): search is strictly between the 5-character and 7-character groups; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.Pattern find* method names (findall, finditer)
# findall (7) < finditer (8): differ by 2 characters ('er' suffix)
# ---------------------------------------------------------------------------

table re_extra180.find_method_names:
  description: "re.Pattern find-family method names: findall.__name__=='findall' (len=7); finditer.__name__=='finditer' (len=8); search (6) < findall (7) < finditer (8) < fullmatch (9)"
  kind: python_call_eq
  category: identity
  id_prefix: repatternmethods180

  columns: [id, function, args, expected, description]
  rows:
    - [findall_name,      Pattern.findall.__name__.__eq__,      ["findall"],  true, "re.Pattern.findall.__name__ == 'findall' — findall() returns a list of all non-overlapping matches; 'findall' has 7 characters: f(1)i(2)n(3)d(4)a(5)l(6)l(7); findall (7) < finditer (8): findall is 1 character shorter than finditer; confirmed Python 3.14.3 macOS"]
    - [findall_name_len,  Pattern.findall.__name__.__len__,     [],           7,    "re.Pattern.findall.__name__.__len__() == 7 — 'findall' has 7 characters; search (6) < findall (7) < finditer (8) < fullmatch (9): findall is in the upper-middle of the length ordering; confirmed Python 3.14.3 macOS"]
    - [finditer_name,     Pattern.finditer.__name__.__eq__,     ["finditer"], true, "re.Pattern.finditer.__name__ == 'finditer' — finditer() returns an iterator of match objects for all non-overlapping matches; 'finditer' has 8 characters: f(1)i(2)n(3)d(4)i(5)t(6)e(7)r(8); finditer (8) > findall (7) by 1: the 'er' vs 'l' suffix makes finditer longer; confirmed Python 3.14.3 macOS"]
    - [finditer_name_len, Pattern.finditer.__name__.__len__,    [],           8,    "re.Pattern.finditer.__name__.__len__() == 8 — 'finditer' has 8 characters; findall (7) < finditer (8) < fullmatch (9): finditer is strictly between findall and fullmatch in the length ordering; confirmed Python 3.14.3 macOS"]
    - [findall_class,     Pattern.findall.__class__.__name__.__eq__, ["method_descriptor"], true, "re.Pattern.findall.__class__.__name__ == 'method_descriptor' — Pattern is a C-implemented type so its methods are method_descriptor objects; this holds for all Pattern methods: match, search, fullmatch, findall, finditer, sub, subn, split; confirmed Python 3.14.3 macOS"]
    - [finditer_class,    Pattern.finditer.__class__.__name__.__eq__, ["method_descriptor"], true, "re.Pattern.finditer.__class__.__name__ == 'method_descriptor' — finditer, like all Pattern methods, is a C method_descriptor; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.Pattern fullmatch method name and flags descriptor class
# fullmatch (9) is the longest; flags is a getset_descriptor
# ---------------------------------------------------------------------------

table re_extra180.fullmatch_and_flags:
  description: "re.Pattern fullmatch and flags: fullmatch.__name__=='fullmatch' (len=9); fullmatch (9) is the longest covered method name; Pattern.flags.__class__.__name__=='getset_descriptor' — flags is a C attribute descriptor"
  kind: python_call_eq
  category: identity
  id_prefix: repatternmethods180

  columns: [id, function, args, expected, description]
  rows:
    - [fullmatch_name,      Pattern.fullmatch.__name__.__eq__,                  ["fullmatch"],        true, "re.Pattern.fullmatch.__name__ == 'fullmatch' — fullmatch() tries to match the entire string against the pattern; 'fullmatch' has 9 characters: f(1)u(2)l(3)l(4)m(5)a(6)t(7)c(8)h(9); fullmatch (9) is the longest re.Pattern method name covered; finditer (8) < fullmatch (9); confirmed Python 3.14.3 macOS"]
    - [fullmatch_name_len,  Pattern.fullmatch.__name__.__len__,                 [],                   9,    "re.Pattern.fullmatch.__name__.__len__() == 9 — 'fullmatch' has 9 characters; fullmatch (9) is the maximum length in the ordering: sub (3) < subn (4) < match==split (5) < search (6) < findall (7) < finditer (8) < fullmatch (9); confirmed Python 3.14.3 macOS"]
    - [fullmatch_class,     Pattern.fullmatch.__class__.__name__.__eq__,        ["method_descriptor"], true, "re.Pattern.fullmatch.__class__.__name__ == 'method_descriptor' — fullmatch is a C method_descriptor; all Pattern methods (match, search, fullmatch, findall, finditer, sub, subn, split) are method_descriptor instances; confirmed Python 3.14.3 macOS"]
    - [flags_class,         Pattern.flags.__class__.__name__.__eq__,            ["getset_descriptor"],  true, "re.Pattern.flags.__class__.__name__ == 'getset_descriptor' — flags is a C-level attribute implemented as a getset_descriptor (using PyGetSetDef), not a method_descriptor; getset_descriptor objects provide computed read-only C attributes; confirmed Python 3.14.3 macOS"]
    - [sub_class,           Pattern.sub.__class__.__name__.__eq__,              ["method_descriptor"], true, "re.Pattern.sub.__class__.__name__ == 'method_descriptor' — sub, the shortest-named Pattern method (len=3), is a C method_descriptor; all Pattern methods share this descriptor class regardless of name length; confirmed Python 3.14.3 macOS"]
    - [subn_class,          Pattern.subn.__class__.__name__.__eq__,             ["method_descriptor"], true, "re.Pattern.subn.__class__.__name__ == 'method_descriptor' — subn is a C method_descriptor; sub (3) and subn (4) both have method_descriptor class; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra180.match_name_is_match:
  description: "re.Pattern.match.__name__ == 'match' — match() tries to match the pattern at the start of the string; len=5; match (5) == split (5): a 2-way tie at length 5; subn (4) < match==split (5) < search (6); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Pattern.match.__name__.__eq__
  args: ["match"]
  expected: true

invariant re_extra180.search_name_len_is_6:
  description: "re.Pattern.search.__name__.__len__() == 6 — 'search' has 6 characters; search (6) is uniquely length 6 among covered Pattern method names; match==split (5) < search (6) < findall (7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Pattern.search.__name__.__len__
  args: []
  expected: 6

invariant re_extra180.fullmatch_name_len_is_9:
  description: "re.Pattern.fullmatch.__name__.__len__() == 9 — 'fullmatch' has 9 characters; fullmatch (9) is the longest Pattern method name; finditer (8) < fullmatch (9); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Pattern.fullmatch.__name__.__len__
  args: []
  expected: 9

invariant re_extra180.findall_name_len_is_7:
  description: "re.Pattern.findall.__name__.__len__() == 7 — 'findall' has 7 characters; search (6) < findall (7) < finditer (8): findall is strictly in the middle of the find/search group; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Pattern.findall.__name__.__len__
  args: []
  expected: 7

invariant re_extra180.finditer_name_len_is_8:
  description: "re.Pattern.finditer.__name__.__len__() == 8 — 'finditer' has 8 characters; findall (7) < finditer (8) < fullmatch (9): finditer is strictly between findall and fullmatch in the length ordering; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Pattern.finditer.__name__.__len__
  args: []
  expected: 8

invariant re_extra180.sub_name_len_is_3:
  description: "re.Pattern.sub.__name__.__len__() == 3 — 'sub' has 3 characters; sub (3) is the shortest Pattern method name; sub (3) < subn (4) < match==split (5): sub is the minimum in the full length ordering; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Pattern.sub.__name__.__len__
  args: []
  expected: 3

invariant re_extra180.subn_name_is_subn:
  description: "re.Pattern.subn.__name__ == 'subn' — subn() substitutes and returns count; len=4; subn (4) > sub (3) by 1: the 'n' suffix for count adds one character; sub (3) < subn (4) < match==split (5); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Pattern.subn.__name__.__eq__
  args: ["subn"]
  expected: true

invariant re_extra180.flags_is_getset_descriptor:
  description: "re.Pattern.flags.__class__.__name__ == 'getset_descriptor' — Pattern.flags is a C-level getset_descriptor (not a method_descriptor); it provides the regex flags as a read-only integer attribute; all Pattern methods are method_descriptor, while flags is getset_descriptor; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Pattern.flags.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

