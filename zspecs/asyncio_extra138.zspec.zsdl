# asyncio.shield.__module__    == 'asyncio.tasks'  (len=13)
# ---------------------------------------------------------------------------

table asyncio_extra138.shield_identity:
  description: "asyncio.shield qualname and module identity checks — shield.__qualname__.__eq__('shield')==True (len=6: same length as 'gather'); shield.__module__.__eq__('asyncio.tasks')==True (len=13: same module as gather); both gather and shield are defined in Lib/asyncio/tasks.py; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioshield138

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,   asyncio.shield.__qualname__.__eq__,  ["shield"],        true, "asyncio.shield.__qualname__ == 'shield' (len=6); verified with Python 3.14.3"]
    - [qn_len,  asyncio.shield.__qualname__.__len__,  [],               6,    "asyncio.shield.__qualname__.__len__() == 6; verified with Python 3.14.3"]
    - [mod_eq,  asyncio.shield.__module__.__eq__,    ["asyncio.tasks"], true, "asyncio.shield.__module__ == 'asyncio.tasks' (len=13); verified with Python 3.14.3"]
    - [mod_len, asyncio.shield.__module__.__len__,    [],               13,   "asyncio.shield.__module__.__len__() == 13; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.shield code object attributes — extra138
#
# asyncio.shield.__code__.co_argcount   == 1
# asyncio.shield.__code__.co_varnames   has len 4
# 'arg' in asyncio.shield.__code__.co_varnames
# 'loop' in asyncio.shield.__code__.co_varnames
# ---------------------------------------------------------------------------

table asyncio_extra138.shield_code:
  description: "asyncio.shield code object attribute checks — co_argcount==1 (only 'arg' is positional; no keyword-only params, co_kwonlyargcount==0); co_varnames.__len__()==4 ('arg','loop','_clear_awaited_by_callback','_outer_done_callback'); 'arg' and 'loop' are in co_varnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioshieldcode138

  columns: [id, function, args, expected, description]
  rows:
    - [argc,         asyncio.shield.__code__.co_argcount.__eq__,           [1],     true, "asyncio.shield.__code__.co_argcount == 1 (arg is the only positional param); verified with Python 3.14.3"]
    - [varnames_len, asyncio.shield.__code__.co_varnames.__len__,           [],      4,    "asyncio.shield.__code__.co_varnames.__len__() == 4; verified with Python 3.14.3"]
    - [arg_in,       asyncio.shield.__code__.co_varnames.__contains__,     ["arg"], true, "asyncio.shield.__code__.co_varnames contains 'arg'; verified with Python 3.14.3"]
    - [loop_in,      asyncio.shield.__code__.co_varnames.__contains__,     ["loop"], true, "asyncio.shield.__code__.co_varnames contains 'loop'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra138
# ---------------------------------------------------------------------------

invariant asyncio_extra138.gather_qualname_len_6:
  description: "asyncio.gather.__qualname__.__len__() == 6 — asyncio.gather.__qualname__ is 'gather' (6 chars); same length as shield.__qualname__ ('shield' is also 6 chars); gather.__module__ is 'asyncio.tasks' (len=13); gather.__code__.co_argcount==0 (VAR_POSITIONAL input); gather.__code__.co_varnames.__len__()==9; NEW in extra138: first standalone gather qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.gather.__qualname__.__len__
  args: []
  expected: 6

invariant asyncio_extra138.gather_module_len_13:
  description: "asyncio.gather.__module__.__len__() == 13 — asyncio.gather.__module__ is 'asyncio.tasks' (13 chars: 'asyncio'=7+'.'=1+'tasks'=5=13); both gather and shield share this module; asyncio.tasks is defined in Lib/asyncio/tasks.py; co_argcount==0; co_varnames.__len__()==9; NEW in extra138: first standalone gather module length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.gather.__module__.__len__
  args: []
  expected: 13

invariant asyncio_extra138.gather_co_argcount_0:
  description: "asyncio.gather.__code__.co_argcount == 0 — gather takes *coros_or_futures as a VAR_POSITIONAL so there are no plain positional parameters (co_argcount==0); return_exceptions is keyword-only (co_kwonlyargcount==1); distinct from shield which has co_argcount==1; co_varnames.__len__()==9; NEW in extra138: first standalone gather co_argcount invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.gather.__code__.co_argcount
  args: []
  expected: 0

invariant asyncio_extra138.gather_co_varnames_len_9:
  description: "asyncio.gather.__code__.co_varnames.__len__() == 9 — asyncio.gather.__code__.co_varnames is ('return_exceptions','coros_or_futures','loop','cur_task','_done_callback','arg_to_fut','done_futs','arg','fut') (len=9); co_argcount==0; co_kwonlyargcount==1; this is the longest co_varnames of gather vs shield (shield has len=4); NEW in extra138: first standalone gather co_varnames length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.gather.__code__.co_varnames.__len__
  args: []
  expected: 9

invariant asyncio_extra138.shield_co_varnames_len_4:
  description: "asyncio.shield.__code__.co_varnames.__len__() == 4 — asyncio.shield.__code__.co_varnames is ('arg','loop','_clear_awaited_by_callback','_outer_done_callback') (len=4); co_argcount==1 (only 'arg' is positional); co_kwonlyargcount==0; contrast with gather co_varnames len==9; NEW in extra138: first standalone shield co_varnames length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.shield.__code__.co_varnames.__len__
  args: []
  expected: 4

