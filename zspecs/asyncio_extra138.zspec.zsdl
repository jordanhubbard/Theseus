spec: asyncio_extra138
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio task functions documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "This spec covers: asyncio.gather and asyncio.shield — module-level scheduling functions defined in asyncio.tasks. asyncio.gather.__qualname__=='gather' (len=6); asyncio.gather.__module__=='asyncio.tasks' (len=13); asyncio.gather.__code__.co_argcount==0 (gather takes *coros_or_futures — no positional args, return_exceptions is keyword-only, co_kwonlyargcount==1); asyncio.gather.__code__.co_varnames.__len__()==9 ('return_exceptions','coros_or_futures','loop','cur_task','_done_callback','arg_to_fut','done_futs','arg','fut'); asyncio.shield.__qualname__=='shield' (len=6); asyncio.shield.__module__=='asyncio.tasks' (len=13); asyncio.shield.__code__.co_argcount==1 (only 'arg'); asyncio.shield.__code__.co_varnames.__len__()==4 ('arg','loop','_clear_awaited_by_callback','_outer_done_callback'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Both gather and shield are regular Python functions (not coroutine functions in Python 3.14.3 — inspect.iscoroutinefunction returns False for both). gather.__code__.co_argcount==0 because all input is collected via *coros_or_futures (a VAR_POSITIONAL), so there are zero plain positional parameters; gather.__code__.co_kwonlyargcount==1 (return_exceptions is keyword-only). shield.__code__.co_argcount==1 and co_kwonlyargcount==0. Both live in asyncio.tasks (len=13). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.gather qualname and module — extra138
#
# asyncio.gather.__qualname__  == 'gather'        (len=6)
# asyncio.gather.__module__    == 'asyncio.tasks' (len=13)
# ---------------------------------------------------------------------------

table asyncio_extra138.gather_identity:
  description: "asyncio.gather qualname and module identity checks — gather.__qualname__.__eq__('gather')==True (len=6: 'gather' is 6 chars); gather.__module__.__eq__('asyncio.tasks')==True (len=13: 'asyncio'=7+'.'=1+'tasks'=5=13); gather and shield share the same module (both asyncio.tasks); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciogather138

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,   asyncio.gather.__qualname__.__eq__,  ["gather"],        true, "asyncio.gather.__qualname__ == 'gather' (len=6); verified with Python 3.14.3"]
    - [qn_len,  asyncio.gather.__qualname__.__len__,  [],               6,    "asyncio.gather.__qualname__.__len__() == 6; verified with Python 3.14.3"]
    - [mod_eq,  asyncio.gather.__module__.__eq__,    ["asyncio.tasks"], true, "asyncio.gather.__module__ == 'asyncio.tasks' (len=13); verified with Python 3.14.3"]
    - [mod_len, asyncio.gather.__module__.__len__,    [],               13,   "asyncio.gather.__module__.__len__() == 13; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.gather code object attributes — extra138
#
# asyncio.gather.__code__.co_argcount     == 0
# asyncio.gather.__code__.co_kwonlyargcount == 1
# asyncio.gather.__code__.co_varnames     has len 9
# 'return_exceptions' in asyncio.gather.__code__.co_varnames
# 'coros_or_futures' in asyncio.gather.__code__.co_varnames
# ---------------------------------------------------------------------------

table asyncio_extra138.gather_code:
  description: "asyncio.gather code object attribute checks — co_argcount==0 (all input collected via *coros_or_futures VAR_POSITIONAL, so no plain positional params); co_kwonlyargcount==1 (return_exceptions is keyword-only); co_varnames.__len__()==9 ('return_exceptions','coros_or_futures','loop','cur_task','_done_callback','arg_to_fut','done_futs','arg','fut'); 'return_exceptions' and 'coros_or_futures' are in co_varnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciogathercode138

  columns: [id, function, args, expected, description]
  rows:
    - [argc,           asyncio.gather.__code__.co_argcount.__eq__,              [0],                  true, "asyncio.gather.__code__.co_argcount == 0 (all input via *coros_or_futures, no plain positional args); verified with Python 3.14.3"]
    - [kwonly,         asyncio.gather.__code__.co_kwonlyargcount.__eq__,        [1],                  true, "asyncio.gather.__code__.co_kwonlyargcount == 1 (return_exceptions is keyword-only); verified with Python 3.14.3"]
    - [varnames_len,   asyncio.gather.__code__.co_varnames.__len__,              [],                  9,    "asyncio.gather.__code__.co_varnames.__len__() == 9; verified with Python 3.14.3"]
    - [retexc_in,      asyncio.gather.__code__.co_varnames.__contains__,        ["return_exceptions"], true, "asyncio.gather.__code__.co_varnames contains 'return_exceptions'; verified with Python 3.14.3"]
    - [cofs_in,        asyncio.gather.__code__.co_varnames.__contains__,        ["coros_or_futures"],  true, "asyncio.gather.__code__.co_varnames contains 'coros_or_futures'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
