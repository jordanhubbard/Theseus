spec: uuid_extra2356
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 604 (_extra2356): __init__ and __new__ implementation type classification."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID is a pure-Python class with a custom __init__; UUID.__init__.__class__.__name__ == 'function'."
    - "uuid.UUID.__new__.__class__.__name__ == 'builtin_function_or_method' (inherits object.__new__)."
    - "uuid.SafeUUID is an IntEnum subclass; SafeUUID.__init__.__class__.__name__ == 'wrapper_descriptor' (from int/Enum C layer)."
    - "uuid.SafeUUID.__new__.__class__.__name__ == 'function' (Enum meta defines a Python __new__)."
    - "Module-level uuid functions (uuid1, uuid3, uuid4, uuid5, uuid6, uuid8, getnode) are pure-Python: __class__.__name__ == 'function'."
    - "uuid.UUID.__class__.__name__ == 'type' (UUID is a class, metaclass is type)."
    - "uuid.SafeUUID.__class__.__name__ == 'EnumType' (Enum metaclass)."
    - "The key distinction: Python classes define __init__ as 'function'; C extension types define it as 'wrapper_descriptor'."
  created_at: "2026-04-12"

table uuid_extra2356.uuid_class_init_type:
  description: "uuid.UUID has a custom Python __init__ — classified as 'function', not wrapper_descriptor"
  kind: python_call_eq
  category: impl_type_classification
  id_prefix: uu2356
  columns: [id, function, args, expected]
  rows:
    - ["uu2356001", "uuid.UUID.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["uu2356002", "uuid.UUID.__new__.__class__.__name__.__eq__", ["builtin_function_or_method"], true]

table uuid_extra2356.safeuuid_init_type:
  description: "uuid.SafeUUID is an IntEnum — __init__ comes from C int/Enum layer (wrapper_descriptor), __new__ is Python function"
  kind: python_call_eq
  category: impl_type_classification
  id_prefix: uu2356
  columns: [id, function, args, expected]
  rows:
    - ["uu2356003", "uuid.SafeUUID.__init__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["uu2356004", "uuid.SafeUUID.__new__.__class__.__name__.__eq__", ["function"], true]

table uuid_extra2356.uuid_safeuuid_class_names:
  description: "uuid.UUID is a plain type; uuid.SafeUUID uses EnumType metaclass"
  kind: python_call_eq
  category: impl_type_classification
  id_prefix: uu2356
  columns: [id, function, args, expected]
  rows:
    - ["uu2356005", "uuid.UUID.__class__.__name__.__eq__", ["type"], true]
    - ["uu2356006", "uuid.SafeUUID.__class__.__name__.__eq__", ["EnumType"], true]

table uuid_extra2356.module_functions_class:
  description: "Module-level uuid generator functions are pure-Python: __class__.__name__ == 'function'"
  kind: python_call_eq
  category: impl_type_classification
  id_prefix: uu2356
  columns: [id, function, args, expected]
  rows:
    - ["uu2356007", "uuid.uuid1.__class__.__name__.__eq__", ["function"], true]
    - ["uu2356008", "uuid.uuid3.__class__.__name__.__eq__", ["function"], true]
    - ["uu2356009", "uuid.uuid4.__class__.__name__.__eq__", ["function"], true]
    - ["uu2356010", "uuid.uuid5.__class__.__name__.__eq__", ["function"], true]
    - ["uu2356011", "uuid.uuid6.__class__.__name__.__eq__", ["function"], true]
    - ["uu2356012", "uuid.uuid8.__class__.__name__.__eq__", ["function"], true]
    - ["uu2356013", "uuid.getnode.__class__.__name__.__eq__", ["function"], true]

table uuid_extra2356.init_type_contrast:
  description: "Contrast: UUID.__init__ is 'function' (Python), SafeUUID.__init__ is 'wrapper_descriptor' (C/Enum)"
  kind: python_call_eq
  category: impl_type_classification
  id_prefix: uu2356
  columns: [id, function, args, expected]
  rows:
    - ["uu2356014", "uuid.UUID.__init__.__class__.__name__.__eq__", ["wrapper_descriptor"], false]
    - ["uu2356015", "uuid.UUID.__init__.__class__.__name__.__eq__", ["builtin_function_or_method"], false]
    - ["uu2356016", "uuid.SafeUUID.__init__.__class__.__name__.__eq__", ["function"], false]
    - ["uu2356017", "uuid.SafeUUID.__new__.__class__.__name__.__eq__", ["wrapper_descriptor"], false]
    - ["uu2356018", "uuid.SafeUUID.__new__.__class__.__name__.__eq__", ["builtin_function_or_method"], false]
    - ["uu2356019", "uuid.UUID.__new__.__class__.__name__.__eq__", ["function"], false]
    - ["uu2356020", "uuid.uuid4.__class__.__name__.__eq__", ["builtin_function_or_method"], false]
