  notes:
    - "This spec extends multiprocessing_extra85.zspec.zsdl."
    - "This spec covers: wave 248 theme — multiprocessing.Pool method __qualname__ string equality. NEW in extra86: pool.Pool.map.__qualname__=='Pool.map'; pool.Pool.starmap.__qualname__=='Pool.starmap'; pool.Pool.apply.__qualname__=='Pool.apply'; pool.Pool.apply_async.__qualname__=='Pool.apply_async'; pool.Pool.map_async.__qualname__=='Pool.map_async'; pool.Pool.starmap_async.__qualname__=='Pool.starmap_async'; pool.Pool.close.__qualname__=='Pool.close'; pool.Pool.terminate.__qualname__=='Pool.terminate'; pool.Pool.join.__qualname__=='Pool.join'; pool.Pool.imap.__qualname__=='Pool.imap'; pool.Pool.imap_unordered.__qualname__=='Pool.imap_unordered'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.map.__qualname__ == 'Pool.map'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.starmap.__qualname__ == 'Pool.starmap'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.apply.__qualname__ == 'Pool.apply'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.apply_async.__qualname__ == 'Pool.apply_async'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.map_async.__qualname__ == 'Pool.map_async'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.starmap_async.__qualname__ == 'Pool.starmap_async'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.close.__qualname__ == 'Pool.close'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.terminate.__qualname__ == 'Pool.terminate'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.join.__qualname__ == 'Pool.join'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.imap.__qualname__ == 'Pool.imap'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.imap_unordered.__qualname__ == 'Pool.imap_unordered'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Pool sync methods __qualname__ — extra86
#
# Wave 248 theme: multiprocessing.Pool method __qualname__ string equality.
#
# pool.Pool.map.__qualname__ == 'Pool.map'
# pool.Pool.starmap.__qualname__ == 'Pool.starmap'
# pool.Pool.apply.__qualname__ == 'Pool.apply'
# ---------------------------------------------------------------------------

table multiprocessing_extra86.Pool_sync_method_qualnames:
  description: "multiprocessing Pool synchronous method __qualname__ equality checks in mpoolqualstr86 namespace — wave 248 theme: multiprocessing.Pool method __qualname__ string equality; pool.Pool.map.__qualname__=='Pool.map'; pool.Pool.starmap.__qualname__=='Pool.starmap'; pool.Pool.apply.__qualname__=='Pool.apply'; __qualname__ for class methods includes the class name as a prefix; accessed via pool submodule since multiprocessing.Pool is a factory bound method; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpoolqualstr86

  columns: [id, function, args, expected, description]
  rows:
    - [pool_map_qualname,     pool.Pool.map.__qualname__.__eq__,     ["Pool.map"],     true, "pool.Pool.map.__qualname__ == 'Pool.map' — includes class prefix; verified with Python 3.14.3"]
    - [pool_starmap_qualname, pool.Pool.starmap.__qualname__.__eq__, ["Pool.starmap"], true, "pool.Pool.starmap.__qualname__ == 'Pool.starmap' — includes class prefix; verified with Python 3.14.3"]
    - [pool_apply_qualname,   pool.Pool.apply.__qualname__.__eq__,   ["Pool.apply"],   true, "pool.Pool.apply.__qualname__ == 'Pool.apply' — includes class prefix; verified with Python 3.14.3"]

