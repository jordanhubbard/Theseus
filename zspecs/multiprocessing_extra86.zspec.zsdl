    - [pool_imap_cross,        pool.Pool.imap.__qualname__.__eq__,     ["Pool.imap"],     true, "pool.Pool.imap.__qualname__ == 'Pool.imap' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra86
# ---------------------------------------------------------------------------

invariant multiprocessing_extra86.Pool_map_qualname:
  description: "multiprocessing.pool.Pool.map.__qualname__.__eq__('Pool.map') returns True — __qualname__ for class methods includes the class name as a prefix; Pool.map is the primary synchronous parallel map method; NEW in extra86: first standalone __qualname__ equality invariant for Pool.map in mpoolqualstr86 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pool.Pool.map.__qualname__.__eq__
  args: ["Pool.map"]
  expected: true

invariant multiprocessing_extra86.Pool_apply_async_qualname:
  description: "multiprocessing.pool.Pool.apply_async.__qualname__.__eq__('Pool.apply_async') returns True — apply_async submits a single callable to the pool and returns an AsyncResult; __qualname__ includes class prefix; NEW in extra86: first standalone __qualname__ equality invariant for Pool.apply_async in mpoolqualstr86 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pool.Pool.apply_async.__qualname__.__eq__
  args: ["Pool.apply_async"]
  expected: true

invariant multiprocessing_extra86.Pool_imap_unordered_qualname:
  description: "multiprocessing.pool.Pool.imap_unordered.__qualname__.__eq__('Pool.imap_unordered') returns True — imap_unordered is a lazy iterator variant that may return results out of order for efficiency; __qualname__ includes class prefix; NEW in extra86: first standalone __qualname__ equality invariant for Pool.imap_unordered in mpoolqualstr86 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pool.Pool.imap_unordered.__qualname__.__eq__
  args: ["Pool.imap_unordered"]
  expected: true

invariant multiprocessing_extra86.Pool_close_qualname:
  description: "multiprocessing.pool.Pool.close.__qualname__.__eq__('Pool.close') returns True — close prevents any more tasks from being submitted to the pool; __qualname__ includes class prefix; NEW in extra86: first standalone __qualname__ equality invariant for Pool.close in mpoolqualstr86 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pool.Pool.close.__qualname__.__eq__
  args: ["Pool.close"]
  expected: true

invariant multiprocessing_extra86.Pool_starmap_qualname:
  description: "multiprocessing.pool.Pool.starmap.__qualname__.__eq__('Pool.starmap') returns True — starmap is like map except the iterable elements are expanded as arguments; __qualname__ includes class prefix; NEW in extra86: first standalone __qualname__ equality invariant for Pool.starmap in mpoolqualstr86 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pool.Pool.starmap.__qualname__.__eq__
  args: ["Pool.starmap"]
  expected: true
