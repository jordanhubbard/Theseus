    - [pool_map_async_qualname,     pool.Pool.map_async.__qualname__.__eq__,     ["Pool.map_async"],     true, "pool.Pool.map_async.__qualname__ == 'Pool.map_async' — includes class prefix; verified with Python 3.14.3"]
    - [pool_starmap_async_qualname, pool.Pool.starmap_async.__qualname__.__eq__, ["Pool.starmap_async"], true, "pool.Pool.starmap_async.__qualname__ == 'Pool.starmap_async' — includes class prefix; verified with Python 3.14.3"]

