table multiprocessing_extra86.Pool_lifecycle_method_qualnames:
  description: "multiprocessing Pool lifecycle method __qualname__ equality checks in mpoolqualstr86 namespace — wave 248 theme: multiprocessing.Pool method __qualname__ string equality; pool.Pool.close.__qualname__=='Pool.close'; pool.Pool.terminate.__qualname__=='Pool.terminate'; pool.Pool.join.__qualname__=='Pool.join'; pool.Pool.map.__qualname__=='Pool.map' (cross-check); pool.Pool.imap.__qualname__=='Pool.imap' (cross-check); close/terminate/join are the lifecycle control methods for orderly pool shutdown; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpoolqualstr86c

  columns: [id, function, args, expected, description]
  rows:
    - [pool_close_qualname,    pool.Pool.close.__qualname__.__eq__,    ["Pool.close"],    true, "pool.Pool.close.__qualname__ == 'Pool.close' — includes class prefix; verified with Python 3.14.3"]
    - [pool_terminate_qualname,pool.Pool.terminate.__qualname__.__eq__,["Pool.terminate"],true, "pool.Pool.terminate.__qualname__ == 'Pool.terminate' — includes class prefix; verified with Python 3.14.3"]
