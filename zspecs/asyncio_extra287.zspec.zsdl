spec: asyncio_extra287
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio event loop and coroutine functions"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py, Lib/asyncio/runners.py, Lib/asyncio/tasks.py, Modules/_asynciomodule.c"
  notes:
    - "get_event_loop and get_running_loop are C extensions with __module__ == '_asyncio'"
    - "set_event_loop and new_event_loop are defined in asyncio.events"
    - "run is defined in asyncio.runners"
    - "sleep, gather, wait, wait_for, create_task, ensure_future are defined in asyncio.tasks"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table asyncio_extra287.func_names:
  description: "__name__ attribute of asyncio event loop and coroutine functions"
  kind: python_call_eq
  category: identity
  id_prefix: aionames

  columns: [id, function, args, expected, description]
  rows:
    - [aionames001, asyncio.get_event_loop.__name__.__eq__, ["get_event_loop"], true, "get_event_loop __name__"]
    - [aionames002, asyncio.set_event_loop.__name__.__eq__, ["set_event_loop"], true, "set_event_loop __name__"]
    - [aionames003, asyncio.new_event_loop.__name__.__eq__, ["new_event_loop"], true, "new_event_loop __name__"]
    - [aionames004, asyncio.get_running_loop.__name__.__eq__, ["get_running_loop"], true, "get_running_loop __name__"]
    - [aionames005, asyncio.run.__name__.__eq__, ["run"], true, "run __name__"]
    - [aionames006, asyncio.create_task.__name__.__eq__, ["create_task"], true, "create_task __name__"]
    - [aionames007, asyncio.sleep.__name__.__eq__, ["sleep"], true, "sleep __name__"]
    - [aionames008, asyncio.gather.__name__.__eq__, ["gather"], true, "gather __name__"]
    - [aionames009, asyncio.wait.__name__.__eq__, ["wait"], true, "wait __name__"]
    - [aionames010, asyncio.wait_for.__name__.__eq__, ["wait_for"], true, "wait_for __name__"]

table asyncio_extra287.func_modules:
  description: "__module__ attribute of asyncio event loop and coroutine functions"
  kind: python_call_eq
  category: identity
  id_prefix: aiomods

  columns: [id, function, args, expected, description]
  rows:
    - [aiomods001, asyncio.get_event_loop.__module__.__eq__, ["_asyncio"], true, "get_event_loop __module__ is _asyncio (C extension)"]
    - [aiomods002, asyncio.set_event_loop.__module__.__eq__, ["asyncio.events"], true, "set_event_loop __module__ is asyncio.events"]
    - [aiomods003, asyncio.new_event_loop.__module__.__eq__, ["asyncio.events"], true, "new_event_loop __module__ is asyncio.events"]
    - [aiomods004, asyncio.get_running_loop.__module__.__eq__, ["_asyncio"], true, "get_running_loop __module__ is _asyncio (C extension)"]
    - [aiomods005, asyncio.run.__module__.__eq__, ["asyncio.runners"], true, "run __module__ is asyncio.runners"]
    - [aiomods006, asyncio.create_task.__module__.__eq__, ["asyncio.tasks"], true, "create_task __module__ is asyncio.tasks"]
    - [aiomods007, asyncio.sleep.__module__.__eq__, ["asyncio.tasks"], true, "sleep __module__ is asyncio.tasks"]
    - [aiomods008, asyncio.gather.__module__.__eq__, ["asyncio.tasks"], true, "gather __module__ is asyncio.tasks"]
    - [aiomods009, asyncio.wait.__module__.__eq__, ["asyncio.tasks"], true, "wait __module__ is asyncio.tasks"]
    - [aiomods010, asyncio.wait_for.__module__.__eq__, ["asyncio.tasks"], true, "wait_for __module__ is asyncio.tasks"]

invariant asyncio_extra287.get_running_loop_c_module:
  description: "get_running_loop is a C extension function with module '_asyncio'"
  category: identity
  kind: python_call_eq
  function: asyncio.get_running_loop.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra287.run_module:
  description: "asyncio.run is defined in asyncio.runners submodule"
  category: identity
  kind: python_call_eq
  function: asyncio.run.__module__.__eq__
  args: ["asyncio.runners"]
  expected: true

invariant asyncio_extra287.sleep_module:
  description: "asyncio.sleep is defined in asyncio.tasks submodule"
  category: identity
  kind: python_call_eq
  function: asyncio.sleep.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra287.gather_module:
  description: "asyncio.gather is defined in asyncio.tasks submodule"
  category: identity
  kind: python_call_eq
  function: asyncio.gather.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra287.ensure_future_name:
  description: "asyncio.ensure_future __name__ is 'ensure_future'"
  category: identity
  kind: python_call_eq
  function: asyncio.ensure_future.__name__.__eq__
  args: ["ensure_future"]
  expected: true
