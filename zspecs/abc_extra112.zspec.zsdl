spec: abc_extra112
version: ">=3.11"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra111.zspec.zsdl."
    - "This spec covers: wave 257 theme — ABCMeta method co_varnames lengths and abstractmethod co_varnames not previously covered as standalone invariants. Prior specs covered: extra100 covered ABC.__subclasshook__.__qualname__ equality and ABCMeta.__new__.__qualname__ existence; extra101 covered ABC.__init_subclass__.__qualname__ equality and abstractmethod co_qualname; extra102 covered ABCMeta.register/instancecheck/subclasscheck co_name and co_argcount; extra104 covered ABCMeta.__new__ co_argcount and qualname length. NOT previously covered: ABCMeta.__new__ co_varnames.__len__(); ABCMeta.register co_varnames.__len__(); ABCMeta.__instancecheck__ co_varnames.__len__(); ABCMeta.__subclasscheck__ co_varnames.__len__(); abstractmethod co_varnames.__len__(). NEW in extra112: ABCMeta.__new__.__code__.co_varnames.__len__()==6; ABCMeta.register.__code__.co_varnames.__len__()==2; ABCMeta.__instancecheck__.__code__.co_varnames.__len__()==2; ABCMeta.__subclasscheck__.__code__.co_varnames.__len__()==2; abstractmethod.__code__.co_varnames.__len__()==1. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__new__.__code__.co_varnames == ('mcls','name','bases','namespace','kwargs','cls') — len=6: 4 positional params (mcls, name, bases, namespace) plus 1 VAR_KEYWORD (**kwargs) plus 1 local 'cls'; most co_varnames in this spec. ABCMeta.__new__.__code__.co_argcount==4. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.register.__code__.co_varnames == ('cls','subclass') — len=2. ABCMeta.__instancecheck__.__code__.co_varnames == ('cls','instance') — len=2. ABCMeta.__subclasscheck__.__code__.co_varnames == ('cls','subclass') — len=2. All three share co_varnames len=2. abc.abstractmethod.__code__.co_varnames == ('funcobj',) — len=1 (fewest in spec). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta method co_varnames lengths — extra112
#
# Wave 257 theme: ABCMeta.__new__, register, __instancecheck__, __subclasscheck__ co_varnames.
#
# abc.ABCMeta.__new__.__code__.co_varnames.__len__()             == 6  (most: mcls+name+bases+ns+kwargs+cls)
# abc.ABCMeta.register.__code__.co_varnames.__len__()            == 2  (cls, subclass)
# abc.ABCMeta.__instancecheck__.__code__.co_varnames.__len__()   == 2  (cls, instance; tied)
# abc.ABCMeta.__subclasscheck__.__code__.co_varnames.__len__()   == 2  (cls, subclass; tied)
# ---------------------------------------------------------------------------

table abc_extra112.abc_abcmeta_co_varnames_len:
  description: "abc.ABCMeta method co_varnames length checks in abcvar112 namespace — wave 257 theme: ABCMeta.__new__.__code__.co_varnames.__len__()==6 (most in spec: co_varnames==('mcls','name','bases','namespace','kwargs','cls'): 4 positional params (mcls, name, bases, namespace) plus the **kwargs VAR_KEYWORD and 1 local 'cls' — which is the newly created class object; ABCMeta.__new__.__code__.co_argcount==4 but co_varnames has 6 entries because kwargs and cls are also stored); ABCMeta.__new__.__code__.co_qualname.__eq__('ABCMeta.__new__')==True (len=15: covered in extra104); ABCMeta.register.__code__.co_varnames.__len__()==2 (co_varnames==('cls','subclass'): register takes the ABCMeta class and the subclass to register as a virtual subclass; co_argcount==2, all params are in co_varnames); ABCMeta.register.__code__.co_qualname.__eq__('ABCMeta.register')==True (len=16); ABCMeta.__instancecheck__.__code__.co_varnames.__len__()==2 (co_varnames==('cls','instance'): __instancecheck__ takes the ABC class and the instance to test; tied with register and __subclasscheck__ at len=2); ABCMeta.__instancecheck__.__code__.co_qualname.__len__()==25 (covered in extra101); ABCMeta.__subclasscheck__.__code__.co_varnames.__len__()==2 (co_varnames==('cls','subclass'): __subclasscheck__ takes the ABC class and the candidate subclass; tied with register and __instancecheck__ at len=2); ABCMeta.__subclasscheck__.__code__.co_qualname.__len__()==25 (tied with __instancecheck__); compare co_varnames lengths: register==__instancecheck__==__subclasscheck__==2 (three-way tie; fewest for ABCMeta methods) < __new__==6 (most; __new__ has complexity from kwargs and local cls); compare co_argcount: register==__instancecheck__==__subclasscheck__==2 < __new__==4 (most); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcvar112

  columns: [id, function, args, expected, description]
  rows:
    - [new_vl,   abc.ABCMeta.__new__.__code__.co_varnames.__len__,             [], 6, "ABCMeta.__new__ co_varnames len=6 (most: mcls+name+bases+namespace+kwargs+cls); verified with Python 3.14.3"]
    - [new_argc, abc.ABCMeta.__new__.__code__.co_argcount.__eq__,              [4], true, "ABCMeta.__new__.__code__.co_argcount == 4 (mcls, name, bases, namespace; kwargs is VAR_KEYWORD); verified with Python 3.14.3"]
    - [reg_vl,   abc.ABCMeta.register.__code__.co_varnames.__len__,            [], 2, "ABCMeta.register co_varnames len=2 (('cls','subclass')); verified with Python 3.14.3"]
    - [reg_argc, abc.ABCMeta.register.__code__.co_argcount.__eq__,             [2], true, "ABCMeta.register.__code__.co_argcount == 2 (cls and subclass); verified with Python 3.14.3"]
    - [ic_vl,    abc.ABCMeta.__instancecheck__.__code__.co_varnames.__len__,   [], 2, "ABCMeta.__instancecheck__ co_varnames len=2 (('cls','instance'); tied with register); verified with Python 3.14.3"]
    - [ic_argc,  abc.ABCMeta.__instancecheck__.__code__.co_argcount.__eq__,    [2], true, "ABCMeta.__instancecheck__.__code__.co_argcount == 2 (cls and instance); verified with Python 3.14.3"]
    - [sc_vl,    abc.ABCMeta.__subclasscheck__.__code__.co_varnames.__len__,   [], 2, "ABCMeta.__subclasscheck__ co_varnames len=2 (('cls','subclass'); three-way tie at 2); verified with Python 3.14.3"]
    - [sc_argc,  abc.ABCMeta.__subclasscheck__.__code__.co_argcount.__eq__,    [2], true, "ABCMeta.__subclasscheck__.__code__.co_argcount == 2 (cls and subclass); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractmethod co_varnames and ABCMeta module identity — extra112
#
# Wave 257 theme: abstractmethod co_varnames length and ABCMeta module/name lengths.
#
# abc.abstractmethod.__code__.co_varnames.__len__()  == 1  (fewest: only funcobj)
# abc.ABCMeta.__name__.__len__()                     == 7
# abc.ABCMeta.__module__.__len__()                   == 3
# ---------------------------------------------------------------------------

table abc_extra112.abc_abstractmethod_co_varnames:
  description: "abc.abstractmethod co_varnames length and ABCMeta identity checks in abcvar112 namespace — wave 257 theme: abc.abstractmethod.__code__.co_varnames.__len__()==1 (fewest in spec: co_varnames==('funcobj',) — abstractmethod is a decorator taking a single function argument; the function stores funcobj.__isabstractmethod__ = True and returns funcobj; no additional locals; co_argcount==1; co_qualname=='abstractmethod' (len=14); __module__=='abc'); abc.abstractmethod.__code__.co_varnames.__len__()==1 is fewest vs ABCMeta.__new__ len=6 (most): difference=5; abc.ABCMeta.__name__.__eq__('ABCMeta')==True (len=7: 'ABCMeta'=7; compare: abstractmethod has __qualname__.__len__()==14 which is double ABCMeta.__name__ len=7); abc.ABCMeta.__name__.__len__()==7; abc.ABCMeta.__qualname__.__eq__('ABCMeta')==True (__qualname__==__name__ for top-level classes; ABCMeta is defined at module scope in abc.py); abc.ABCMeta.__qualname__.__len__()==7; abc.ABCMeta.__module__.__eq__('abc')==True (len=3: 'abc'=3; ABCMeta is defined in the abc module); abc.ABCMeta.__module__.__len__()==3; compare: ABCMeta.__name__.__len__()==7 > ABCMeta.__module__.__len__()==3 (module name is 4 chars shorter than class name); abstractmethod.__code__.co_qualname.__len__()==14 > ABCMeta.__name__.__len__()==7 (decorator name is double the metaclass class name len); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcvar112a

  columns: [id, function, args, expected, description]
  rows:
    - [am_vl,      abc.abstractmethod.__code__.co_varnames.__len__,   [], 1,    "abstractmethod co_varnames len=1 (fewest in spec: ('funcobj',)); verified with Python 3.14.3"]
    - [am_argc,    abc.abstractmethod.__code__.co_argcount.__eq__,    [1], true, "abstractmethod.__code__.co_argcount == 1 (funcobj only); verified with Python 3.14.3"]
    - [meta_name,  abc.ABCMeta.__name__.__eq__,                       ["ABCMeta"], true, "ABCMeta.__name__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]
    - [meta_nlen,  abc.ABCMeta.__name__.__len__,                      [], 7,    "ABCMeta.__name__.__len__() == 7 ('ABCMeta'=7); verified with Python 3.14.3"]
    - [meta_qn,    abc.ABCMeta.__qualname__.__eq__,                   ["ABCMeta"], true, "ABCMeta.__qualname__ == 'ABCMeta' (__qualname__==__name__ for top-level class); verified with Python 3.14.3"]
    - [meta_qnlen, abc.ABCMeta.__qualname__.__len__,                  [], 7,    "ABCMeta.__qualname__.__len__() == 7 (tied with __name__ len=7); verified with Python 3.14.3"]
    - [meta_mod,   abc.ABCMeta.__module__.__eq__,                     ["abc"], true, "ABCMeta.__module__ == 'abc' (len=3; defined in abc module); verified with Python 3.14.3"]
    - [meta_mlen,  abc.ABCMeta.__module__.__len__,                    [], 3,    "ABCMeta.__module__.__len__() == 3 ('abc'=3, shorter than ABCMeta name len=7 by 4); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta method co_varnames and co_qualname cross-checks — extra112
#
# Wave 257 theme: cross-attribute comparisons between ABCMeta methods and abstractmethod.
#
# abstractmethod co_varnames len=1 (fewest) vs ABCMeta.__new__ co_varnames len=6 (most)
# ABCMeta register/instancecheck/subclasscheck: co_varnames len=2 (middle)
# ABCMeta.__new__ co_qualname len=15 < ABCMeta.register co_qualname len=16
# ABCMeta.__instancecheck__ co_qualname len=25 tied with ABCMeta.__subclasscheck__ len=25
# ---------------------------------------------------------------------------

table abc_extra112.abc_meta_co_varnames_crosscheck:
  description: "abc.ABCMeta method co_varnames and co_qualname cross-check comparisons in abcvar112 namespace — wave 257 theme: confirming relative magnitude comparisons and known lengths; abstractmethod.__code__.co_varnames.__len__()==1 (fewest in spec); ABCMeta.__new__.__code__.co_varnames.__len__()==6 (most in spec; 5 more than abstractmethod); ABCMeta.register.__code__.co_varnames.__len__()==2 (middle; tied with __instancecheck__ and __subclasscheck__); ABCMeta.__new__.__code__.co_qualname.__len__()==15 (covered extra104; 'ABCMeta.__new__'=15); ABCMeta.register.__code__.co_qualname.__len__()==16 (covered extra102; 'ABCMeta.register'=16; 1 more than __new__=15); ABCMeta.__instancecheck__.__code__.co_qualname.__len__()==25 (covered extra101; 'ABCMeta.__instancecheck__'=25; tied with __subclasscheck__=25); ABCMeta.__subclasscheck__.__code__.co_qualname.__len__()==25 (covered extra102; tied with __instancecheck__=25); abstractmethod.__code__.co_qualname.__len__()==14 (covered extra101; module-level, no class prefix; shorter than all ABCMeta method qualnames: 14 < __new__=15 < register=16 < __instancecheck__==__subclasscheck__==25); ABCMeta.__new__.__code__.co_argcount.__eq__(4)==True (covered extra104; most co_argcount in spec); abstractmethod.__code__.co_argcount.__eq__(1)==True; compare co_varnames vs co_argcount discrepancy for ABCMeta.__new__: co_argcount=4 but co_varnames len=6 (2 extra locals: kwargs and cls); for register: co_argcount==co_varnames len==2 (no discrepancy); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcvar112b

  columns: [id, function, args, expected, description]
  rows:
    - [am_vl_1,    abc.abstractmethod.__code__.co_varnames.__len__,            [], 1,  "abstractmethod co_varnames len=1 (fewest in spec); verified with Python 3.14.3"]
    - [new_vl_6,   abc.ABCMeta.__new__.__code__.co_varnames.__len__,           [], 6,  "ABCMeta.__new__ co_varnames len=6 (most in spec; 5 more than abstractmethod=1); verified with Python 3.14.3"]
    - [reg_vl_2,   abc.ABCMeta.register.__code__.co_varnames.__len__,          [], 2,  "ABCMeta.register co_varnames len=2 (middle; tied with instancecheck and subclasscheck); verified with Python 3.14.3"]
    - [new_coq_15, abc.ABCMeta.__new__.__code__.co_qualname.__len__,           [], 15, "ABCMeta.__new__ co_qualname len=15 ('ABCMeta.__new__'=15; covered extra104); verified with Python 3.14.3"]
    - [reg_coq_16, abc.ABCMeta.register.__code__.co_qualname.__len__,          [], 16, "ABCMeta.register co_qualname len=16 ('ABCMeta.register'=16; 1 more than __new__=15); verified with Python 3.14.3"]
    - [ic_coq_25,  abc.ABCMeta.__instancecheck__.__code__.co_qualname.__len__, [], 25, "ABCMeta.__instancecheck__ co_qualname len=25 (tied with __subclasscheck__=25); verified with Python 3.14.3"]
    - [sc_coq_25,  abc.ABCMeta.__subclasscheck__.__code__.co_qualname.__len__, [], 25, "ABCMeta.__subclasscheck__ co_qualname len=25 (tied with __instancecheck__=25); verified with Python 3.14.3"]
    - [am_coq_14,  abc.abstractmethod.__code__.co_qualname.__len__,            [], 14, "abstractmethod co_qualname len=14 (shortest ABCMeta-related co_qualname; module-level, no class prefix); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra112
# ---------------------------------------------------------------------------

invariant abc_extra112.abstractmethod_co_varnames_len_1:
  description: "abc.abstractmethod.__code__.co_varnames.__len__() == 1 — co_varnames==('funcobj',): abstractmethod is a decorator function that takes a single argument funcobj (the function to decorate); it sets funcobj.__isabstractmethod__ = True and returns funcobj; no additional locals are needed; len=1 is the fewest co_varnames in this spec; abc.abstractmethod.__code__.co_argcount==1 (same value: 1 positional param); abc.abstractmethod.__code__.co_qualname=='abstractmethod' (len=14); abc.abstractmethod.__module__=='abc' (len=3); compare: ABCMeta.__new__ co_varnames len=6 (most in spec; 5 more than abstractmethod=1); ABCMeta.register co_varnames len=2 (1 more than abstractmethod); note: co_varnames len=1 == co_argcount==1 for abstractmethod (no discrepancy because there are no local vars beyond the parameter); first standalone abstractmethod co_varnames length invariant in abcvar112 namespace; wave 257; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_varnames.__len__
  args: []
  expected: 1

invariant abc_extra112.ABCMeta_new_co_varnames_len_6:
  description: "abc.ABCMeta.__new__.__code__.co_varnames.__len__() == 6 — co_varnames==('mcls','name','bases','namespace','kwargs','cls'): 4 positional params (mcls for the metaclass, name for the class name string, bases for the tuple of base classes, namespace for the class body dict) plus 1 VAR_KEYWORD capture (**kwargs, stored as 'kwargs' in co_varnames) plus 1 local variable 'cls' (the new class object created by type.__new__); len=6 is the most co_varnames in this spec; abc.ABCMeta.__new__.__code__.co_argcount==4 (only the 4 positional params; kwargs is VAR_KEYWORD not counted in co_argcount); abc.ABCMeta.__new__.__code__.co_qualname=='ABCMeta.__new__' (len=15); abc.ABCMeta.__module__=='abc'; compare: co_varnames len=6 > co_argcount=4 (difference=2 due to kwargs and cls locals); ABCMeta register/instancecheck/subclasscheck all have co_varnames len=2 (3 times shorter than __new__=6); first standalone ABCMeta.__new__ co_varnames length invariant in abcvar112 namespace; wave 257; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__code__.co_varnames.__len__
  args: []
  expected: 6

invariant abc_extra112.ABCMeta_register_co_varnames_len_2:
  description: "abc.ABCMeta.register.__code__.co_varnames.__len__() == 2 — co_varnames==('cls','subclass'): register takes cls (the ABCMeta class object, i.e. the abstract base class) and subclass (the class to register as a virtual subclass); 2 positional params, no additional locals; co_argcount==2 (same value: no discrepancy); abc.ABCMeta.register.__code__.co_qualname=='ABCMeta.register' (len=16); abc.ABCMeta.register.__module__=='abc'; compare: __instancecheck__ and __subclasscheck__ also have co_varnames len=2 (three-way tie: register==__instancecheck__==__subclasscheck__==2); ABCMeta.__new__ has co_varnames len=6 (3 times more complex); register allows a class to be recognized as a subclass of the ABC without inheriting from it (virtual subclassing, used for duck typing); first standalone ABCMeta.register co_varnames length invariant in abcvar112 namespace; wave 257; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abc.ABCMeta.register.__code__.co_varnames.__len__
  args: []
  expected: 2

invariant abc_extra112.ABCMeta_name_len_7:
  description: "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta'=7 chars: 'ABC'=3+'Meta'=4=7; abc.ABCMeta.__name__.__eq__('ABCMeta')==True; abc.ABCMeta.__qualname__.__eq__('ABCMeta')==True (__qualname__==__name__==7 for this top-level class); abc.ABCMeta.__module__=='abc' (len=3: 4 chars shorter than the class name len=7); compare: abc.abstractmethod.__qualname__.__len__()==14 (double ABCMeta.__name__ len=7: 'abstractmethod'=14=2*7); ABCMeta.__name__.__len__()==7 and ABC.__name__.__len__()==3 (ABC is 4 chars shorter than ABCMeta: 'ABC'=3 vs 'ABCMeta'=7, difference is the 'Meta' suffix=4); ABCMeta is the metaclass that implements the abstract base class protocol; it is named by combining 'ABC' (the abstract base class concept) with 'Meta' (indicating metaclass); first standalone ABCMeta.__name__ length invariant in abcvar112 namespace; wave 257; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__name__.__len__
  args: []
  expected: 7

invariant abc_extra112.ABCMeta_instancecheck_co_varnames_len_2:
  description: "abc.ABCMeta.__instancecheck__.__code__.co_varnames.__len__() == 2 — co_varnames==('cls','instance'): __instancecheck__ takes cls (the ABC) and instance (the object to test); returns True if instance should be considered an instance of the ABC; checks the MRO and registered virtual subclasses; 2 positional params, no additional locals; co_argcount==2; abc.ABCMeta.__instancecheck__.__code__.co_qualname=='ABCMeta.__instancecheck__' (len=25: covered in extra101); abc.ABCMeta.__instancecheck__.__module__=='abc'; compare: co_varnames len=2 (same as register and __subclasscheck__; three-way tie); co_qualname len=25 (much longer than register co_qualname len=16 by 9, because '__instancecheck__'=17 chars vs 'register'=8 chars); __instancecheck__ is called by isinstance() when the second argument has a custom metaclass; first standalone ABCMeta.__instancecheck__ co_varnames length invariant in abcvar112 namespace; wave 257; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__code__.co_varnames.__len__
  args: []
  expected: 2
