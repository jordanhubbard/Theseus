spec: hmac_extra30
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hmac_extra29.zspec.zsdl — covers HMAC.__module__.__len__()==4; HMAC.__name__.__len__()==4; HMAC.__qualname__.__len__()==4; new/digest/compare_digest __module__.__len__(); new/compare_digest/digest __name__.__len__(); HMAC.update/digest/hexdigest __name__.__len__()."
  notes:
    - "This spec extends hmac through hmac_extra29; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: HMAC/__name__/__module__/__qualname__/__bases__[0].__name__ (extra17, extra22, extra23, extra26, extra29); hmac.new/__name__/__module__/__len__ (extra17, extra28, extra29); compare_digest/__name__/__module__/__len__ (extra17, extra27, extra29); digest/__name__/__module__/__len__ (extra17, extra29); HMAC.__init__.__name__ (extra28); HMAC.update/digest/hexdigest/copy __name__ (extra24, extra28); HMAC.update/digest/hexdigest __name__.__len__() (extra29)."
    - "This spec covers: HMAC.copy.__name__.__len__() (NOVEL — extra29 covers update/digest/hexdigest __name__.__len__ but not copy); HMAC.update.__qualname__.__len__() (NOVEL — 'HMAC.update' has 11 characters); HMAC.digest.__qualname__.__len__() (NOVEL — 'HMAC.digest' has 11 characters); HMAC.hexdigest.__qualname__.__len__() (NOVEL — 'HMAC.hexdigest' has 14 characters); HMAC.copy.__qualname__.__len__() (NOVEL — 'HMAC.copy' has 9 characters); HMAC.__init__.__name__.__len__() (NOVEL — '__init__' has 8 characters); HMAC.__init__.__qualname__.__len__() (NOVEL — 'HMAC.__init__' has 13 characters); HMAC.update.__module__.__len__() (NOVEL — 'hmac' has 4 characters); HMAC.digest.__module__.__len__() (NOVEL); HMAC.hexdigest.__module__.__len__() (NOVEL); HMAC.copy.__module__.__len__() (NOVEL); HMAC.__init__.__module__.__len__() (NOVEL)."
    - "hmac.HMAC.copy.__name__.__len__() == 4: 'copy' has 4 characters. extra29 covers update/digest/hexdigest __name__.__len__() but not copy. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.update.__qualname__.__len__() == 11: 'HMAC.update' has 11 characters. No prior spec checks __qualname__.__len__() for HMAC instance methods. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.digest.__qualname__.__len__() == 11: 'HMAC.digest' has 11 characters. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.hexdigest.__qualname__.__len__() == 14: 'HMAC.hexdigest' has 14 characters. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.copy.__qualname__.__len__() == 9: 'HMAC.copy' has 9 characters. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__init__.__name__.__len__() == 8: '__init__' has 8 characters. extra28 covers __init__.__name__.__eq__; no prior spec checks __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__init__.__qualname__.__len__() == 13: 'HMAC.__init__' has 13 characters. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.update.__module__.__len__() == 4: 'hmac' has 4 characters. extra26 covers HMAC method __module__.__eq__; no prior spec checks __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HMAC.copy.__name__.__len__()
#
# extra29 covers HMAC.update/digest/hexdigest __name__.__len__() from
# extra29 namespace. No prior spec verifies HMAC.copy.__name__.__len__().
# HMAC.copy.__name__ == 'copy', len('copy') == 4. Novel.
# ---------------------------------------------------------------------------

invariant hmac_extra30.HMAC.copy.name_len:
  description: "hmac.HMAC.copy.__name__.__len__() == 4 — 'copy' has 4 characters, novel invariant"
  category: function_names
  kind: python_call_eq
  function: HMAC.copy.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# HMAC.__init__.__name__.__len__() and __qualname__.__len__()
#
# extra28 covers HMAC.__init__.__name__.__eq__('__init__').
# No prior spec verifies __init__.__name__.__len__() or __qualname__.__len__().
# '__init__' has 8 characters; 'HMAC.__init__' has 13 characters.
# ---------------------------------------------------------------------------

invariant hmac_extra30.HMAC.init.name_len:
  description: "hmac.HMAC.__init__.__name__.__len__() == 8 — '__init__' has 8 characters, novel invariant"
  category: function_names
  kind: python_call_eq
  function: HMAC.__init__.__name__.__len__
  args: []
  expected: 8

invariant hmac_extra30.HMAC.init.qualname_len:
  description: "hmac.HMAC.__init__.__qualname__.__len__() == 13 — 'HMAC.__init__' has 13 characters, novel invariant"
  category: function_names
  kind: python_call_eq
  function: HMAC.__init__.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# HMAC method __qualname__.__len__() — novel invariants
#
# No prior spec checks __qualname__.__len__() for any HMAC instance method.
# Qualnames include the class prefix 'HMAC.', so lengths differ from __name__:
# update: 'HMAC.update' (11), digest: 'HMAC.digest' (11),
# hexdigest: 'HMAC.hexdigest' (14), copy: 'HMAC.copy' (9).
# ---------------------------------------------------------------------------

invariant hmac_extra30.HMAC.update.qualname_len:
  description: "hmac.HMAC.update.__qualname__.__len__() == 11 — 'HMAC.update' has 11 characters, novel invariant"
  category: function_names
  kind: python_call_eq
  function: HMAC.update.__qualname__.__len__
  args: []
  expected: 11

invariant hmac_extra30.HMAC.hexdigest.qualname_len:
  description: "hmac.HMAC.hexdigest.__qualname__.__len__() == 14 — 'HMAC.hexdigest' has 14 characters, novel invariant"
  category: function_names
  kind: python_call_eq
  function: HMAC.hexdigest.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# Table: HMAC method __qualname__.__len__() — update/digest/hexdigest/copy
#
# Groups all four HMAC instance method __qualname__.__len__() checks.
# All are novel; no prior spec covers __qualname__.__len__() for any method.
# ---------------------------------------------------------------------------

table hmac_extra30.HMAC_method_qualname_lengths:
  description: "HMAC.update/digest/hexdigest/copy __qualname__.__len__() — novel invariants"
  kind: python_call_eq
  category: function_names
  id_prefix: hmacmql30

  columns: [id, function, args, expected]
  rows:
    - [update,    HMAC.update.__qualname__.__len__,    [], 11]
    - [digest,    HMAC.digest.__qualname__.__len__,    [], 11]
    - [hexdigest, HMAC.hexdigest.__qualname__.__len__, [], 14]
    - [copy,      HMAC.copy.__qualname__.__len__,      [], 9]

# ---------------------------------------------------------------------------
# Table: HMAC method __module__.__len__() — novel invariants
#
# extra26 covers HMAC method __module__.__eq__('hmac') for update/digest/
# hexdigest/copy. No prior spec checks __module__.__len__() for any of them.
# All four have __module__ == 'hmac', len('hmac') == 4.
# Also covers HMAC.__init__.__module__.__len__() which is novel.
# ---------------------------------------------------------------------------

table hmac_extra30.HMAC_method_module_lengths:
  description: "HMAC.update/digest/hexdigest/copy/__init__ __module__.__len__() == 4 — novel invariants"
  kind: python_call_eq
  category: module_metadata
  id_prefix: hmacmml30

  columns: [id, function, args, expected]
  rows:
    - [update,    HMAC.update.__module__.__len__,    [], 4]
    - [digest,    HMAC.digest.__module__.__len__,    [], 4]
    - [hexdigest, HMAC.hexdigest.__module__.__len__, [], 4]
    - [copy,      HMAC.copy.__module__.__len__,      [], 4]
    - [init,      HMAC.__init__.__module__.__len__,  [], 4]
