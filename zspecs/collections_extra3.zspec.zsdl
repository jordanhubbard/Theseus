spec: collections_extra3
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "Extends collections.zspec.zsdl, collections_extra.zspec.zsdl, collections_extra2.zspec.zsdl."
    - "collections_extra.zspec.zsdl covers: UserDict/UserList/UserString __name__/__module__, deque maxlen behavior, ChainMap/__module__, Counter/__module__."
    - "collections_extra2.zspec.zsdl covers: OrderedDict/Counter/defaultdict/ChainMap __name__, Counter.most_common."
    - "This spec covers __qualname__ for UserDict, UserList, UserString, ChainMap, deque; deque class __name__ check; deque.maxlen descriptor type; namedtuple factory __name__; and OrderedDict __module__."
    - "collections.UserDict.__qualname__ == 'UserDict' (top-level class)."
    - "collections.UserList.__qualname__ == 'UserList'."
    - "collections.UserString.__qualname__ == 'UserString'."
    - "collections.ChainMap.__qualname__ == 'ChainMap'."
    - "collections.deque.__name__ == 'deque' (C-accelerated, exposed via collections)."
    - "collections.deque.__qualname__ == 'deque'."
    - "collections.deque.maxlen is a getset_descriptor on the class, not a data value; collections.deque.maxlen.__class__.__name__ == 'getset_descriptor'."
    - "collections.namedtuple('Point', ['x', 'y']).__name__ == 'Point' — namedtuple factory returns a class with the given name."
    - "collections.OrderedDict.__module__ == 'collections'."
    - "collections.defaultdict.__qualname__ == 'defaultdict'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UserDict — __qualname__ check
#
# collections_extra.zspec.zsdl covers __name__ and __module__ for UserDict.
# This spec adds __qualname__ which equals __name__ for top-level classes.
# ---------------------------------------------------------------------------

invariant collections_extra3.UserDict.qualname:
  description: "collections.UserDict.__qualname__ == 'UserDict'"
  category: qualnames
  kind: python_call_eq
  function: UserDict.__qualname__.__eq__
  args: ["UserDict"]
  expected: true

# ---------------------------------------------------------------------------
# UserList — __qualname__ check
# ---------------------------------------------------------------------------

invariant collections_extra3.UserList.qualname:
  description: "collections.UserList.__qualname__ == 'UserList'"
  category: qualnames
  kind: python_call_eq
  function: UserList.__qualname__.__eq__
  args: ["UserList"]
  expected: true

# ---------------------------------------------------------------------------
# UserString — __qualname__ check
# ---------------------------------------------------------------------------

invariant collections_extra3.UserString.qualname:
  description: "collections.UserString.__qualname__ == 'UserString'"
  category: qualnames
  kind: python_call_eq
  function: UserString.__qualname__.__eq__
  args: ["UserString"]
  expected: true

# ---------------------------------------------------------------------------
# ChainMap — __qualname__ check
# ---------------------------------------------------------------------------

invariant collections_extra3.ChainMap.qualname:
  description: "collections.ChainMap.__qualname__ == 'ChainMap'"
  category: qualnames
  kind: python_call_eq
  function: ChainMap.__qualname__.__eq__
  args: ["ChainMap"]
  expected: true

# ---------------------------------------------------------------------------
# deque — class name and __qualname__
#
# collections.deque is a C-accelerated type re-exported by the collections
# module. Its __name__ and __qualname__ are both 'deque'.
# ---------------------------------------------------------------------------

invariant collections_extra3.deque.name:
  description: "collections.deque.__name__ == 'deque'"
  category: deque
  kind: python_call_eq
  function: deque.__name__.__eq__
  args: ["deque"]
  expected: true

invariant collections_extra3.deque.qualname:
  description: "collections.deque.__qualname__ == 'deque'"
  category: deque
  kind: python_call_eq
  function: deque.__qualname__.__eq__
  args: ["deque"]
  expected: true

# ---------------------------------------------------------------------------
# deque.maxlen — descriptor type at the class level
#
# On the deque *class* (not an instance), deque.maxlen is a getset_descriptor
# (a C-level data descriptor). This is distinct from accessing .maxlen on an
# instance (which returns an int or None). The descriptor type confirms that
# maxlen is implemented as a C-level slot, not a plain Python attribute.
# ---------------------------------------------------------------------------

invariant collections_extra3.deque.maxlen_descriptor_type:
  description: "collections.deque.maxlen.__class__.__name__ == 'getset_descriptor' — maxlen is a C descriptor on the class"
  category: deque
  kind: python_call_eq
  function: deque.maxlen.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# OrderedDict and defaultdict — __module__ and __qualname__
#
# collections_extra2 verified __name__ for both; this spec adds __module__
# for OrderedDict (not covered in extra/extra2) and __qualname__ for both.
# ---------------------------------------------------------------------------

invariant collections_extra3.OrderedDict.module:
  description: "collections.OrderedDict.__module__ == 'collections'"
  category: ordereddict
  kind: python_call_eq
  function: OrderedDict.__module__.__eq__
  args: ["collections"]
  expected: true

invariant collections_extra3.OrderedDict.qualname:
  description: "collections.OrderedDict.__qualname__ == 'OrderedDict'"
  category: qualnames
  kind: python_call_eq
  function: OrderedDict.__qualname__.__eq__
  args: ["OrderedDict"]
  expected: true

invariant collections_extra3.defaultdict.qualname:
  description: "collections.defaultdict.__qualname__ == 'defaultdict'"
  category: qualnames
  kind: python_call_eq
  function: defaultdict.__qualname__.__eq__
  args: ["defaultdict"]
  expected: true

# ---------------------------------------------------------------------------
# namedtuple factory — produced class __name__
#
# collections.namedtuple('Point', ['x', 'y']) returns a new class whose
# __name__ is 'Point'. The factory itself is a plain function named
# 'namedtuple'. This verifies the factory correctly stamps the class name.
# ---------------------------------------------------------------------------

invariant collections_extra3.namedtuple.factory_name:
  description: "collections.namedtuple.__name__ == 'namedtuple'"
  category: namedtuple
  kind: python_call_eq
  function: namedtuple.__name__.__eq__
  args: ["namedtuple"]
  expected: true

invariant collections_extra3.namedtuple.produced_class_name:
  description: "collections.namedtuple('Point', ['x', 'y']).__name__ == 'Point'"
  category: namedtuple
  kind: python_call_eq
  function: namedtuple
  args: ["Point", ["x", "y"]]
  method: __name__
  method_args: []
  expected: "Point"

invariant collections_extra3.namedtuple.produced_class_qualname:
  description: "collections.namedtuple('Point', ['x', 'y']).__qualname__ == 'Point'"
  category: namedtuple
  kind: python_call_eq
  function: namedtuple
  args: ["Point", ["x", "y"]]
  method: __qualname__
  method_args: []
  expected: "Point"
