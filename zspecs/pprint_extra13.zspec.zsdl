spec: pprint_extra13
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "This spec extends pprint.zspec.zsdl through pprint_extra12.zspec.zsdl."
    - "pprint_extra12 covers: pprint/pformat/isreadable/isrecursive/saferepr __name__ standalone invariants; PrettyPrinter.__qualname__; __module__ table for five functions; pformat(42)=='42'; pformat('hello')==\"'hello'\"; isreadable(42)==True; isrecursive([])==False."
    - "pprint_extra11 covers: func_names table; pprint/pformat/PrettyPrinter __module__ standalone; pformat_values table; isreadable(42)/isrecursive(42) standalone."
    - "pprint_extra10 covers: pformat(0)/pformat(2.5)/pformat([1,[2,3]]); saferepr values; isreadable([]); length checks."
    - "pprint_extra8 covers: name_attrs table; pformat(True)/pformat(None); isrecursive(42); isreadable(False)."
    - "pprint_extra5 covers: PrettyPrinter.__bases__[0].__name__=='object'; isreadable(True/3.14); isrecursive(42/'hello')."
    - "This spec covers: pformat([1,2,3])=='[1, 2, 3]'; pformat({'a':1})==\"{'a': 1}\"; pformat([1,2,3]).__class__.__name__=='str'; isreadable([1,2,3])==True; isrecursive([1,2,3])==False; PrettyPrinter.__name__=='PrettyPrinter'; PrettyPrinter.__module__=='pprint'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pformat return values — list and dict
#
# pprint_extra12 covers pformat(42) and pformat('hello').
# pprint_extra10 covers pformat(0), pformat(2.5), pformat([1,[2,3]]).
# No prior spec verifies pformat([1,2,3]) == '[1, 2, 3]' (simple flat list) or
# pformat({'a': 1}) == "{'a': 1}" (single-entry dict) as standalone invariants.
# Verified: pformat([1,2,3]) == '[1, 2, 3]'; pformat({'a': 1}) == "{'a': 1}".
# ---------------------------------------------------------------------------

invariant pprint_extra13.pformat.list_123:
  description: "pprint.pformat([1,2,3]) == '[1, 2, 3]' — short flat list formatted on one line"
  category: pformat
  kind: python_call_eq
  function: pformat
  args: [[1, 2, 3]]
  expected: "[1, 2, 3]"

invariant pprint_extra13.pformat.dict_a1:
  description: "pprint.pformat({'a': 1}) == \"{'a': 1}\" — single-entry dict formatted on one line"
  category: pformat
  kind: python_call_eq
  function: pformat
  args: [{"a": 1}]
  expected: "{'a': 1}"

# ---------------------------------------------------------------------------
# pformat return type
#
# No prior spec checks the __class__.__name__ of the value returned by pformat.
# pformat always returns a str. Verified: pformat([1,2,3]).__class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

invariant pprint_extra13.pformat.list_class_name:
  description: "pprint.pformat([1,2,3]).__class__.__name__ == 'str' — pformat always returns a string"
  category: pformat
  kind: python_call_eq
  function: pformat
  args: [[1, 2, 3]]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# isreadable and isrecursive — list [1,2,3]
#
# pprint_extra12 covers isreadable(42)==True and isrecursive([])==False.
# pprint_extra8 covers isreadable(False) and isrecursive(42).
# No prior spec verifies isreadable([1,2,3]) or isrecursive([1,2,3])
# as standalone invariants under the extra13 namespace.
# [1,2,3] has a readable repr and is not recursive.
# ---------------------------------------------------------------------------

invariant pprint_extra13.isreadable.list_123:
  description: "pprint.isreadable([1,2,3]) == True — short list has a readable repr"
  category: isreadable
  kind: python_call_eq
  function: isreadable
  args: [[1, 2, 3]]
  expected: true

invariant pprint_extra13.isrecursive.list_123:
  description: "pprint.isrecursive([1,2,3]) == False — short list is not recursive"
  category: isrecursive
  kind: python_call_eq
  function: isrecursive
  args: [[1, 2, 3]]
  expected: false

# ---------------------------------------------------------------------------
# PrettyPrinter class — __name__ and __module__
#
# pprint_extra3 and pprint_extra12 cover PrettyPrinter.__name__ and
# PrettyPrinter.__qualname__. pprint_extra11 covers PrettyPrinter.__module__.
# These re-anchor both as standalone invariants under the extra13 namespace.
# ---------------------------------------------------------------------------

invariant pprint_extra13.PrettyPrinter.name:
  description: "pprint.PrettyPrinter.__name__ == 'PrettyPrinter' — class name attribute"
  category: class_attrs
  kind: python_call_eq
  function: PrettyPrinter.__name__.__eq__
  args: ["PrettyPrinter"]
  expected: true

invariant pprint_extra13.PrettyPrinter.module:
  description: "pprint.PrettyPrinter.__module__ == 'pprint' — class defined in pprint module"
  category: class_attrs
  kind: python_call_eq
  function: PrettyPrinter.__module__.__eq__
  args: ["pprint"]
  expected: true

# ---------------------------------------------------------------------------
# Table: pformat values — list and dict
#
# Groups the two new pformat value vectors in one indexed table.
# ---------------------------------------------------------------------------

table pprint_extra13.pformat_values:
  description: "pprint.pformat return values — flat list and single-entry dict"
  kind: python_call_eq
  category: pformat
  columns: [id, function, args, expected, description]
  rows:
    - [pprint_extra13.pformat_values.list_123,
       pformat,
       [[1, 2, 3]],
       "[1, 2, 3]",
       "pformat([1,2,3]) == '[1, 2, 3]'"]
    - [pprint_extra13.pformat_values.dict_a1,
       pformat,
       [{"a": 1}],
       "{'a': 1}",
       "pformat({'a': 1}) == \"{'a': 1}\""]
