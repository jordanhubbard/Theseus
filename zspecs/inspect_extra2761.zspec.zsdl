spec: inspect_extra2761
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 631 theme: __matmul__, __truediv__, and __iadd__ dict-presence checks."
    - "inspect.Parameter, inspect.BoundArguments, inspect.Signature are pure-Python classes defined in Lib/inspect.py."
    - "inspect.FullArgSpec is a namedtuple subclass created via collections.namedtuple; its __dict__ is a mappingproxy."
    - "None of the four inspect types (Parameter, BoundArguments, Signature, FullArgSpec) define __matmul__, __truediv__, or __iadd__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.Parameter and inspect.BoundArguments — __matmul__/__truediv__/__iadd__
# dict-presence checks
#
# Both are pure-Python classes defined in Lib/inspect.py.
# Neither implements arithmetic operator dunders.
# All six checks return False.
# ---------------------------------------------------------------------------

table inspect_extra2761.parameter_boundarguments_operator_dict:
  description: "inspect.Parameter and BoundArguments __matmul__, __truediv__, __iadd__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: in2761pb

  columns: [id, function, args, expected]
  rows:
    - ["in2761pb_pa_mm",  Parameter.__dict__.__contains__,      ["__matmul__"],  false]
    - ["in2761pb_pa_td",  Parameter.__dict__.__contains__,      ["__truediv__"], false]
    - ["in2761pb_pa_ia",  Parameter.__dict__.__contains__,      ["__iadd__"],    false]
    - ["in2761pb_ba_mm",  BoundArguments.__dict__.__contains__,  ["__matmul__"],  false]
    - ["in2761pb_ba_td",  BoundArguments.__dict__.__contains__,  ["__truediv__"], false]
    - ["in2761pb_ba_ia",  BoundArguments.__dict__.__contains__,  ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# inspect.Signature — __matmul__/__truediv__/__iadd__ dict-presence checks
#
# Signature is a pure-Python class; its instances represent callable signatures.
# Signature does not define arithmetic or in-place operator dunders.
# All three checks return False.
# ---------------------------------------------------------------------------

table inspect_extra2761.signature_operator_dict:
  description: "inspect.Signature __matmul__, __truediv__, __iadd__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: in2761sg

  columns: [id, function, args, expected]
  rows:
    - ["in2761sg_mm",  Signature.__dict__.__contains__, ["__matmul__"],  false]
    - ["in2761sg_td",  Signature.__dict__.__contains__, ["__truediv__"], false]
    - ["in2761sg_ia",  Signature.__dict__.__contains__, ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# inspect.FullArgSpec — __matmul__/__truediv__/__iadd__ dict-presence checks
#
# FullArgSpec is a namedtuple subclass (collections.namedtuple).
# Its __dict__ is a mappingproxy that does not include arithmetic dunders.
# All three checks return False.
# ---------------------------------------------------------------------------

table inspect_extra2761.fullargspec_operator_dict:
  description: "inspect.FullArgSpec (namedtuple) __matmul__, __truediv__, __iadd__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: in2761fa

  columns: [id, function, args, expected]
  rows:
    - ["in2761fa_mm",  FullArgSpec.__dict__.__contains__, ["__matmul__"],  false]
    - ["in2761fa_td",  FullArgSpec.__dict__.__contains__, ["__truediv__"], false]
    - ["in2761fa_ia",  FullArgSpec.__dict__.__contains__, ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Cross-type summary — all four inspect types, all three operator dunders
#
# Consolidates the full 4×3 matrix confirming none of the inspect types
# define __matmul__, __truediv__, or __iadd__ in their __dict__.
# ---------------------------------------------------------------------------

table inspect_extra2761.all_types_operator_dict_matrix:
  description: "Full 4×3 dict-presence matrix for inspect types vs __matmul__/__truediv__/__iadd__ — all 12 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: in2761mx

  columns: [id, function, args, expected]
  rows:
    - ["in2761mx_pa_mm",  Parameter.__dict__.__contains__,      ["__matmul__"],  false]
    - ["in2761mx_pa_td",  Parameter.__dict__.__contains__,      ["__truediv__"], false]
    - ["in2761mx_pa_ia",  Parameter.__dict__.__contains__,      ["__iadd__"],    false]
    - ["in2761mx_ba_mm",  BoundArguments.__dict__.__contains__,  ["__matmul__"],  false]
    - ["in2761mx_ba_td",  BoundArguments.__dict__.__contains__,  ["__truediv__"], false]
    - ["in2761mx_ba_ia",  BoundArguments.__dict__.__contains__,  ["__iadd__"],    false]
    - ["in2761mx_sg_mm",  Signature.__dict__.__contains__,       ["__matmul__"],  false]
    - ["in2761mx_sg_td",  Signature.__dict__.__contains__,       ["__truediv__"], false]
    - ["in2761mx_sg_ia",  Signature.__dict__.__contains__,       ["__iadd__"],    false]
    - ["in2761mx_fa_mm",  FullArgSpec.__dict__.__contains__,     ["__matmul__"],  false]
    - ["in2761mx_fa_td",  FullArgSpec.__dict__.__contains__,     ["__truediv__"], false]
    - ["in2761mx_fa_ia",  FullArgSpec.__dict__.__contains__,     ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra2761
# ---------------------------------------------------------------------------

invariant inspect_extra2761.parameter_no_matmul:
  description: "'__matmul__' not in inspect.Parameter.__dict__ — Parameter is a descriptor class for callable parameters and does not implement @"
  category: behavior
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__matmul__"]
  expected: false

invariant inspect_extra2761.parameter_no_truediv:
  description: "'__truediv__' not in inspect.Parameter.__dict__ — Parameter does not implement the / operator"
  category: behavior
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__truediv__"]
  expected: false

invariant inspect_extra2761.parameter_no_iadd:
  description: "'__iadd__' not in inspect.Parameter.__dict__ — Parameter does not implement the += operator"
  category: behavior
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__iadd__"]
  expected: false

invariant inspect_extra2761.signature_no_matmul:
  description: "'__matmul__' not in inspect.Signature.__dict__ — Signature does not implement the @ operator"
  category: behavior
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["__matmul__"]
  expected: false

invariant inspect_extra2761.fullargspec_no_iadd:
  description: "'__iadd__' not in inspect.FullArgSpec.__dict__ — FullArgSpec is a namedtuple and does not implement the += operator"
  category: behavior
  kind: python_call_eq
  function: FullArgSpec.__dict__.__contains__
  args: ["__iadd__"]
  expected: false

invariant inspect_extra2761.boundarguments_no_truediv:
  description: "'__truediv__' not in inspect.BoundArguments.__dict__ — BoundArguments does not implement the / operator"
  category: behavior
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["__truediv__"]
  expected: false
