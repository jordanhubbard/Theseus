spec: re_extra251
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers re.Match and re.Pattern class identity, RegexFlag constants (IGNORECASE, MULTILINE, DOTALL, UNICODE), and re.error class identity."
    - "re.Match.__name__ == 'Match' and re.Match.__module__ == 're' — the Match class is the public type alias for the internal _sre.SRE_Match (C implementation); its public __name__ is 'Match' and __module__ is 're'."
    - "re.Match.__bases__[0].__name__ == 'object' — Match inherits directly from object (it is a C extension type)."
    - "re.Pattern.__bases__[0].__name__ == 'object' — Pattern inherits directly from object (it is a C extension type)."
    - "re.IGNORECASE, re.MULTILINE, re.DOTALL, re.UNICODE are RegexFlag enum members; their __class__.__name__ is 'RegexFlag'."
    - "re.IGNORECASE.__int__() == 2; re.MULTILINE.__int__() == 8; re.DOTALL.__int__() == 16; re.UNICODE.__int__() == 32 — these integer values are stable across Python versions."
    - "re.error.__name__ == 'PatternError' — in Python 3.13+ re.error was renamed PatternError; re.error remains as an alias. On Python 3.14.3 the canonical __name__ is 'PatternError'."
    - "re.error.__bases__[0].__name__ == 'Exception' — PatternError/re.error is a direct subclass of Exception."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.Match class identity
#
# re.Match is the public type for match objects returned by re.match(),
# re.search(), re.fullmatch(), and Pattern.match(). It is a C extension
# type with __module__ == 're' and __bases__[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

table re_extra251.match_class_identity:
  description: "re.Match class identity — __name__, __module__, __bases__[0].__name__; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: rexmc251

  columns: [id, function, args, expected, description]
  rows:
    - [match_name,
       "Match.__name__.__eq__",
       ["Match"],
       true,
       "re.Match.__name__.__eq__('Match') == True — Match is the public class name for regex match objects returned by re.match() and re.search(); its __name__ is 'Match'; str.__eq__('Match') returns True; new to extra251"]
    - [match_module,
       "Match.__module__.__eq__",
       ["re"],
       true,
       "re.Match.__module__.__eq__('re') == True — Match is exposed through the re module; its __module__ is 're'; str.__eq__('re') returns True; new to extra251"]
    - [match_base,
       "Match.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "re.Match.__bases__[0].__name__.__eq__('object') == True — Match is a C extension type that inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra251"]
    - [match_name_not_sre,
       "Match.__name__.__eq__",
       ["SRE_Match"],
       false,
       "re.Match.__name__.__eq__('SRE_Match') == False — in Python 3.8+ the internal SRE_Match name was replaced by the public name 'Match'; __name__ is 'Match', not 'SRE_Match'; str.__eq__('SRE_Match') returns False; new to extra251"]
    - [match_module_not_underscore_sre,
       "Match.__module__.__eq__",
       ["_sre"],
       false,
       "re.Match.__module__.__eq__('_sre') == False — re.Match is the public alias with __module__ == 're', not '_sre'; str.__eq__('_sre') returns False; new to extra251"]

# ---------------------------------------------------------------------------
# Table 2: re.Pattern class identity
#
# re.Pattern is the public type for compiled regex objects returned by
# re.compile(). It is a C extension type with __module__ == 're'.
# ---------------------------------------------------------------------------

table re_extra251.pattern_class_identity:
  description: "re.Pattern class identity — __name__, __module__, __bases__[0].__name__; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: rexpc251

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_name,
       "Pattern.__name__.__eq__",
       ["Pattern"],
       true,
       "re.Pattern.__name__.__eq__('Pattern') == True — Pattern is the public class name for compiled regex objects returned by re.compile(); its __name__ is 'Pattern'; str.__eq__('Pattern') returns True; new to extra251"]
    - [pattern_module,
       "Pattern.__module__.__eq__",
       ["re"],
       true,
       "re.Pattern.__module__.__eq__('re') == True — Pattern is exposed through the re module; its __module__ is 're'; str.__eq__('re') returns True; new to extra251"]
    - [pattern_base,
       "Pattern.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "re.Pattern.__bases__[0].__name__.__eq__('object') == True — Pattern is a C extension type that inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra251"]
    - [pattern_name_not_sre,
       "Pattern.__name__.__eq__",
       ["SRE_Pattern"],
       false,
       "re.Pattern.__name__.__eq__('SRE_Pattern') == False — in Python 3.8+ the internal SRE_Pattern name was replaced by the public name 'Pattern'; __name__ is 'Pattern', not 'SRE_Pattern'; str.__eq__('SRE_Pattern') returns False; new to extra251"]

# ---------------------------------------------------------------------------
# Table 3: re RegexFlag constants — __class__.__name__ == 'RegexFlag'
#
# IGNORECASE, MULTILINE, DOTALL, UNICODE are members of the RegexFlag enum
# (introduced in Python 3.6). Their __class__.__name__ is 'RegexFlag'.
# ---------------------------------------------------------------------------

table re_extra251.regexflag_class_names:
  description: "re RegexFlag constants __class__.__name__ == 'RegexFlag' — IGNORECASE, MULTILINE, DOTALL, UNICODE; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: rexrfc251

  columns: [id, function, args, expected, description]
  rows:
    - [ignorecase_class,
       "IGNORECASE.__class__.__name__.__eq__",
       ["RegexFlag"],
       true,
       "re.IGNORECASE.__class__.__name__.__eq__('RegexFlag') == True — re.IGNORECASE is a member of the RegexFlag IntFlag enum (case-insensitive matching); its __class__.__name__ is 'RegexFlag'; str.__eq__('RegexFlag') returns True; new to extra251"]
    - [multiline_class,
       "MULTILINE.__class__.__name__.__eq__",
       ["RegexFlag"],
       true,
       "re.MULTILINE.__class__.__name__.__eq__('RegexFlag') == True — re.MULTILINE is a member of the RegexFlag IntFlag enum (^ and $ match at line boundaries); its __class__.__name__ is 'RegexFlag'; str.__eq__('RegexFlag') returns True; new to extra251"]
    - [dotall_class,
       "DOTALL.__class__.__name__.__eq__",
       ["RegexFlag"],
       true,
       "re.DOTALL.__class__.__name__.__eq__('RegexFlag') == True — re.DOTALL is a member of the RegexFlag IntFlag enum (. matches any character including newline); its __class__.__name__ is 'RegexFlag'; str.__eq__('RegexFlag') returns True; new to extra251"]
    - [unicode_class,
       "UNICODE.__class__.__name__.__eq__",
       ["RegexFlag"],
       true,
       "re.UNICODE.__class__.__name__.__eq__('RegexFlag') == True — re.UNICODE is a member of the RegexFlag IntFlag enum (enables Unicode matching, default in Python 3); its __class__.__name__ is 'RegexFlag'; str.__eq__('RegexFlag') returns True; new to extra251"]

# ---------------------------------------------------------------------------
# Table 4: re RegexFlag constants — integer values via __int__()
#
# The integer values of IGNORECASE (2), MULTILINE (8), DOTALL (16), UNICODE (32)
# are stable across Python versions and form a power-of-two bitmask.
# ---------------------------------------------------------------------------

table re_extra251.regexflag_int_values:
  description: "re RegexFlag integer values — IGNORECASE=2, MULTILINE=8, DOTALL=16, UNICODE=32; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: rexrfv251

  columns: [id, function, args, expected, description]
  rows:
    - [ignorecase_int,
       "IGNORECASE.__int__",
       [],
       2,
       "re.IGNORECASE.__int__() == 2 — re.IGNORECASE has integer value 2 in the RegexFlag bitmask; this value is stable across Python versions; int.__int__() returns 2; new to extra251"]
    - [multiline_int,
       "MULTILINE.__int__",
       [],
       8,
       "re.MULTILINE.__int__() == 8 — re.MULTILINE has integer value 8 in the RegexFlag bitmask; this value is stable across Python versions; int.__int__() returns 8; new to extra251"]
    - [dotall_int,
       "DOTALL.__int__",
       [],
       16,
       "re.DOTALL.__int__() == 16 — re.DOTALL has integer value 16 in the RegexFlag bitmask; this value is stable across Python versions; int.__int__() returns 16; new to extra251"]
    - [unicode_int,
       "UNICODE.__int__",
       [],
       32,
       "re.UNICODE.__int__() == 32 — re.UNICODE has integer value 32 in the RegexFlag bitmask; this value is stable across Python versions; int.__int__() returns 32; new to extra251"]

# ---------------------------------------------------------------------------
# Table 5: re.error (PatternError) class identity
#
# In Python 3.13+ re.error was renamed PatternError; re.error remains as an
# alias. On Python 3.14.3 re.error.__name__ == 'PatternError'.
# re.error.__bases__[0].__name__ == 'Exception'.
# ---------------------------------------------------------------------------

table re_extra251.error_class_identity:
  description: "re.error class identity — __name__ 'PatternError', __module__ 're', __bases__[0] Exception; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: rexec251

  columns: [id, function, args, expected, description]
  rows:
    - [error_name,
       "error.__name__.__eq__",
       ["PatternError"],
       true,
       "re.error.__name__.__eq__('PatternError') == True — in Python 3.13+ re.error was renamed PatternError; re.error is an alias; on Python 3.14.3 the canonical __name__ is 'PatternError'; str.__eq__('PatternError') returns True; new to extra251"]
    - [error_module,
       "error.__module__.__eq__",
       ["re"],
       true,
       "re.error.__module__.__eq__('re') == True — re.error (PatternError) is defined in the re module; its __module__ is 're'; str.__eq__('re') returns True; new to extra251"]
    - [error_base,
       "error.__bases__[0].__name__.__eq__",
       ["Exception"],
       true,
       "re.error.__bases__[0].__name__.__eq__('Exception') == True — re.error/PatternError is a direct subclass of Exception; __bases__[0].__name__ is 'Exception'; str.__eq__('Exception') returns True; new to extra251"]
    - [error_name_not_error,
       "error.__name__.__eq__",
       ["error"],
       false,
       "re.error.__name__.__eq__('error') == False — the canonical __name__ is 'PatternError' (not 'error') since Python 3.13; re.error is a backward-compatibility alias; str.__eq__('error') returns False; new to extra251"]

# ---------------------------------------------------------------------------
# Standalone invariants — re_extra251
# ---------------------------------------------------------------------------

invariant re_extra251.match_class_name:
  description: "re.Match.__name__ == 'Match' — Match is the public C-type for regex match objects; new to extra251"
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra251.match_class_module:
  description: "re.Match.__module__ == 're' — Match is exposed through the re module; new to extra251"
  kind: python_call_eq
  function: Match.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra251.pattern_class_name:
  description: "re.Pattern.__name__ == 'Pattern' — Pattern is the public C-type for compiled regex objects; new to extra251"
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra251.ignorecase_int_value:
  description: "re.IGNORECASE.__int__() == 2 — IGNORECASE bitmask value is 2; new to extra251"
  kind: python_call_eq
  function: IGNORECASE.__int__
  args: []
  expected: 2

invariant re_extra251.error_base_exception:
  description: "re.error.__bases__[0].__name__ == 'Exception' — re.error/PatternError is a direct Exception subclass; new to extra251"
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true
