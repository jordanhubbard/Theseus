spec: re_extra219
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.compile(r'(\\w+)') returns a Pattern object; type(p).__name__ == 'Pattern'; verified with Python 3.14.3."
    - "Pattern method __name__ values (match, search, findall, etc.) verified with Python 3.14.3."
    - "Match object attributes (lastindex, pos, endpos, string) verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pattern method __name__ checks
# ---------------------------------------------------------------------------

table re_extra219.pattern_method_names:
  description: "re.Pattern method __name__ checks — match, search, finditer, sub, subn, fullmatch all expose __name__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: reextra219a

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_match_name,     re.compile.__class__.__name__.__eq__,  ["type"],     true, "type(re.compile).__name__ == 'type' — compile is a builtin; verified with Python 3.14.3"]
    - [pattern_type_name,      re.Pattern.__name__.__eq__,            ["Pattern"],  true, "re.Pattern.__name__ == 'Pattern'; verified with Python 3.14.3"]
    - [match_type_name,        re.Match.__name__.__eq__,              ["Match"],    true, "re.Match.__name__ == 'Match'; verified with Python 3.14.3"]
    - [pattern_module,         re.Pattern.__module__.__eq__,          ["re"],       true, "re.Pattern.__module__ == 're'; verified with Python 3.14.3"]
    - [match_module,           re.Match.__module__.__eq__,            ["re"],       true, "re.Match.__module__ == 're'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Match object attribute type checks
# ---------------------------------------------------------------------------

table re_extra219.match_object_attributes:
  description: "re.Match object attribute type checks — pos, endpos are int; string is str; lastindex is int; verified with Python 3.14.3"
  kind: python_call_eq
  category: behavior
  id_prefix: reextra219b

  columns: [id, function, args, expected, description]
  rows:
    - [match_pos_type,       "re.match(r'(\\w+)', 'hello world').pos.__class__.__name__.__eq__",     ["int"],           true, "type(m.pos).__name__ == 'int'; pos is always an int; verified with Python 3.14.3"]
    - [match_endpos_type,    "re.match(r'(\\w+)', 'hello world').endpos.__class__.__name__.__eq__",  ["int"],           true, "type(m.endpos).__name__ == 'int'; endpos is always an int; verified with Python 3.14.3"]
    - [match_string_type,    "re.match(r'(\\w+)', 'hello world').string.__class__.__name__.__eq__",  ["str"],           true, "type(m.string).__name__ == 'str'; string holds the original input; verified with Python 3.14.3"]
    - [match_pos_value,      "re.match(r'(\\w+)', 'hello world').pos.__eq__",                        [0],               true, "m.pos == 0 when matching from start; verified with Python 3.14.3"]
    - [match_endpos_value,   "re.match(r'(\\w+)', 'hello world').endpos.__eq__",                     [11],              true, "m.endpos == 11 (len('hello world')); verified with Python 3.14.3"]
    - [match_lastindex,      "re.match(r'(\\w+)', 'hello world').lastindex.__eq__",                  [1],               true, "m.lastindex == 1 for pattern with one group; verified with Python 3.14.3"]
    - [match_string_value,   "re.match(r'(\\w+)', 'hello world').string.__eq__",                     ["hello world"],   true, "m.string == 'hello world' (original input); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Pattern object attribute checks
# ---------------------------------------------------------------------------

table re_extra219.pattern_object_attributes:
  description: "re.Pattern object attribute checks — pattern is str, groups is int, flags is int; type(p).__name__ == 'Pattern'; verified with Python 3.14.3"
  kind: python_call_eq
  category: behavior
  id_prefix: reextra219c

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_type,         "re.compile(r'(\\w+)').__class__.__name__.__eq__",              ["Pattern"],    true, "type(re.compile(r'(\\w+)')).__name__ == 'Pattern'; verified with Python 3.14.3"]
    - [pattern_groups,       "re.compile(r'(\\w+)').groups.__eq__",                          [1],            true, "re.compile(r'(\\w+)').groups == 1 (one capture group); verified with Python 3.14.3"]
    - [pattern_str_type,     "re.compile(r'(\\w+)').pattern.__class__.__name__.__eq__",      ["str"],        true, "type(p.pattern).__name__ == 'str'; verified with Python 3.14.3"]
    - [pattern_flags_type,   "re.compile(r'(\\w+)').flags.__class__.__name__.__eq__",        ["int"],        true, "type(p.flags).__name__ == 'int'; flags is always an int; verified with Python 3.14.3"]
    - [pattern_groups_type,  "re.compile(r'(\\w+)').groups.__class__.__name__.__eq__",       ["int"],        true, "type(p.groups).__name__ == 'int'; groups is always an int; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra219.match_class_name:
  description: "re.Match.__name__ == 'Match' — the Match class is the type returned by Pattern.match() and Pattern.search(); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: re.Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra219.pattern_class_name:
  description: "re.Pattern.__name__ == 'Pattern' — the Pattern class is the type returned by re.compile(); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra219.pattern_groups_zero_no_groups:
  description: "re.compile(r'\\w+').groups == 0 — a pattern with no capture groups has groups == 0; verified with Python 3.14.3"
  category: behavior
  kind: python_call_eq
  function: "re.compile(r'\\w+').groups.__eq__"
  args: [0]
  expected: true

invariant re_extra219.pattern_module_name:
  description: "re.Pattern.__module__ == 're' — Pattern is defined in the re module; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__module__.__eq__
  args: ["re"]
  expected: true
