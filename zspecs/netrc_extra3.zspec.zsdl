spec: netrc_extra3
version: ">=3.9"
backend: python_module(netrc)

docs: https://docs.python.org/3/library/netrc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/netrc.html — Python netrc documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/netrc.py"
  notes:
    - "This spec extends netrc.zspec.zsdl and prior extras."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# netrc.netrc method __qualname__ — not covered in prior specs
# (netrc_extra2 covers authenticators.__qualname__; __init__ and __str__ qualnames are new)
# ---------------------------------------------------------------------------

invariant netrc_extra3.netrc.init_qualname:
  description: "netrc.netrc.__init__.__qualname__ == 'netrc.__init__'"
  category: methods
  kind: python_call_eq
  function: netrc.__init__.__qualname__.__eq__
  args: ["netrc.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# NetrcParseError method __qualname__ — not covered in prior specs
# ---------------------------------------------------------------------------

invariant netrc_extra3.NetrcParseError.init_qualname:
  description: "netrc.NetrcParseError.__init__.__qualname__ == 'NetrcParseError.__init__'"
  category: methods
  kind: python_call_eq
  function: NetrcParseError.__init__.__qualname__.__eq__
  args: ["NetrcParseError.__init__"]
  expected: true

invariant netrc_extra3.NetrcParseError.str_qualname:
  description: "netrc.NetrcParseError.__str__.__qualname__ is a str ending in '__str__'"
  category: methods
  kind: python_call_eq
  function: NetrcParseError.__str__.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# authenticators.__module__ — module affiliation of the method (new)
# ---------------------------------------------------------------------------

invariant netrc_extra3.netrc.authenticators_module:
  description: "netrc.netrc.authenticators.__module__ == 'netrc'"
  category: methods
  kind: python_call_eq
  function: netrc.authenticators.__module__.__eq__
  args: ["netrc"]
  expected: true

# ---------------------------------------------------------------------------
# NetrcParseError.__init__.__module__ — module affiliation (new)
# ---------------------------------------------------------------------------

invariant netrc_extra3.NetrcParseError.init_module:
  description: "netrc.NetrcParseError.__init__.__qualname__.__class__.__name__ == 'str'"
  category: methods
  kind: python_call_eq
  function: NetrcParseError.__init__.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Table: __qualname__ for both classes and authenticators in one place
# (adds __qualname__ perspective for both public classes; all new)
# ---------------------------------------------------------------------------

table netrc_extra3.public_names_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qn

  columns: [id, function, args, expected, description]
  rows:
    - [netrc_init_qn,           netrc.__init__.__qualname__.__eq__,           ["netrc.__init__"],          true, "netrc.netrc.__init__.__qualname__ == 'netrc.__init__'"]
    - [NetrcParseError_init_qn, NetrcParseError.__init__.__qualname__.__eq__,  ["NetrcParseError.__init__"], true, "netrc.NetrcParseError.__init__.__qualname__ == 'NetrcParseError.__init__'"]
    - [authenticators_module,   netrc.authenticators.__module__.__eq__,        ["netrc"],                   true, "netrc.netrc.authenticators.__module__ == 'netrc'"]
