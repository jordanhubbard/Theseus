spec: hashlib_extra210
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "This spec covers: wave 255 theme — co_varnames attributes for hashlib Python-level functions and algorithms_guaranteed set membership. NEW in extra210: hashlib.new.__code__.co_varnames.__class__.__name__=='tuple'; hashlib.new.__code__.co_varnames.__contains__('name')==True; hashlib.file_digest.__code__.co_varnames.__class__.__name__=='tuple'; hashlib.algorithms_guaranteed.__contains__('sha3_224')==True; hashlib.algorithms_guaranteed.__contains__('sha3_384')==True; hashlib.algorithms_guaranteed.__contains__('sha224')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.new.__code__.co_varnames == ('name', 'args', 'kwargs') (len=3: parameter 'name' plus *args and **kwargs). hashlib.new.__code__.co_argcount==1 (one positional parameter 'name'). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.file_digest.__code__.co_varnames == ('fileobj', 'digest', '_bufsize', 'digestobj', 'buf', 'view', 'size') (len=7: 2 parameters 'fileobj' and 'digest' plus 5 local variables). hashlib.file_digest.__code__.co_argcount==2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.algorithms_guaranteed.__contains__('sha3_224')==True; hashlib.algorithms_guaranteed.__contains__('sha3_384')==True; hashlib.algorithms_guaranteed.__contains__('sha224')==True. These SHA-3 and SHA-2 variants are present in the guaranteed set on all Python 3.6+ platforms. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new co_varnames — class name and membership checks — extra210
#
# Wave 255 theme: co_varnames attributes for hashlib.new and hashlib.file_digest.
#
# hashlib.new.__code__.co_varnames.__class__.__name__     == 'tuple'
# hashlib.new.__code__.co_varnames.__contains__('name')   == True
# ---------------------------------------------------------------------------

table hashlib_extra210.new_co_varnames_identity:
  description: "hashlib.new.__code__.co_varnames class identity and key membership checks in hashlibcovarnames210 namespace — wave 255 theme: hashlib.new.__code__.co_varnames.__class__.__name__.__eq__('tuple')==True (co_varnames is always a tuple of local variable name strings in CPython; hashlib.new co_varnames==('name', 'args', 'kwargs') which is a 3-tuple; __class__.__name__=='tuple'); hashlib.new.__code__.co_varnames.__contains__('name')==True ('name' is the first positional parameter of hashlib.new — it specifies the hash algorithm name; co_varnames[0]=='name' since positional params come first in co_varnames); hashlib.new.__code__.co_varnames.__len__()==3 (3 locals: 'name' + 'args' + 'kwargs'); hashlib.new.__code__.co_argcount==1 (co_argcount counts only positional args — 'name' is the only positional parameter; *args and **kwargs are not counted by co_argcount); hashlib.new.__code__.co_varnames is a tuple of strings; co_varnames class is 'tuple' (len=5); verified with Python 3.14.3"
  kind: python_call_eq
  category: co_varnames
  id_prefix: hashlibcovarnames210

  columns: [id, function, args, expected, description]
  rows:
    - [new_var_cls,    hashlib.new.__code__.co_varnames.__class__.__name__.__eq__,  ["tuple"], true, "hashlib.new.__code__.co_varnames.__class__.__name__ == 'tuple'; verified with Python 3.14.3"]
    - [new_var_len,    hashlib.new.__code__.co_varnames.__len__,                    [],        3,    "hashlib.new.__code__.co_varnames.__len__() == 3 (name, args, kwargs); verified with Python 3.14.3"]
    - [new_has_name,   hashlib.new.__code__.co_varnames.__contains__,               ["name"],  true, "hashlib.new.__code__.co_varnames.__contains__('name') == True; verified with Python 3.14.3"]
    - [new_argc,       hashlib.new.__code__.co_argcount.__eq__,                     [1],       true, "hashlib.new.__code__.co_argcount == 1 (single positional param 'name'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.file_digest co_varnames — class name and membership checks — extra210
#
# Wave 255 theme: co_varnames attributes for hashlib.file_digest.
#
# hashlib.file_digest.__code__.co_varnames.__class__.__name__       == 'tuple'
# hashlib.file_digest.__code__.co_varnames.__contains__('fileobj')  == True
# ---------------------------------------------------------------------------

table hashlib_extra210.file_digest_co_varnames_identity:
  description: "hashlib.file_digest.__code__.co_varnames class identity and membership checks in hashlibcovarnames210 namespace — wave 255 theme: hashlib.file_digest.__code__.co_varnames.__class__.__name__.__eq__('tuple')==True (co_varnames is a tuple; file_digest co_varnames==('fileobj', 'digest', '_bufsize', 'digestobj', 'buf', 'view', 'size') — a 7-tuple); hashlib.file_digest.__code__.co_varnames.__contains__('fileobj')==True ('fileobj' is the first positional parameter of file_digest — the file-like object to digest; must support read() method and be in binary mode); hashlib.file_digest.__code__.co_varnames.__len__()==7 (2 params 'fileobj' + 'digest' plus 5 locals '_bufsize', 'digestobj', 'buf', 'view', 'size'); hashlib.file_digest.__code__.co_argcount==2 (2 positional params: 'fileobj' and 'digest'; all other 5 are internal locals); co_varnames.__class__.__name__=='tuple' (len=5); verified with Python 3.14.3"
  kind: python_call_eq
  category: co_varnames
  id_prefix: hashlibcovarnames210a

  columns: [id, function, args, expected, description]
  rows:
    - [fd_var_cls,     hashlib.file_digest.__code__.co_varnames.__class__.__name__.__eq__,  ["tuple"],    true, "hashlib.file_digest.__code__.co_varnames.__class__.__name__ == 'tuple'; verified with Python 3.14.3"]
    - [fd_var_len,     hashlib.file_digest.__code__.co_varnames.__len__,                    [],           7,    "hashlib.file_digest.__code__.co_varnames.__len__() == 7 (fileobj, digest, _bufsize, digestobj, buf, view, size); verified with Python 3.14.3"]
    - [fd_has_fileobj, hashlib.file_digest.__code__.co_varnames.__contains__,               ["fileobj"],  true, "hashlib.file_digest.__code__.co_varnames.__contains__('fileobj') == True; verified with Python 3.14.3"]
    - [fd_argc,        hashlib.file_digest.__code__.co_argcount.__eq__,                     [2],          true, "hashlib.file_digest.__code__.co_argcount == 2 (fileobj, digest); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed membership checks — extra210
#
# Wave 255 theme: sha3_224, sha3_384, sha224 membership in algorithms_guaranteed.
#
# hashlib.algorithms_guaranteed.__contains__('sha3_224') == True
# hashlib.algorithms_guaranteed.__contains__('sha3_384') == True
# hashlib.algorithms_guaranteed.__contains__('sha224')   == True
# ---------------------------------------------------------------------------

table hashlib_extra210.algorithms_guaranteed_membership:
  description: "hashlib.algorithms_guaranteed membership checks for SHA-3 and SHA-2 variants in hashlibcovarnames210 namespace — wave 255 theme: hashlib.algorithms_guaranteed.__contains__('sha3_224')==True (SHA3-224 is guaranteed on all Python 3.6+ platforms; it is part of the FIPS 202 SHA-3 family of hash functions); hashlib.algorithms_guaranteed.__contains__('sha3_384')==True (SHA3-384 is also guaranteed since Python 3.6+; another FIPS 202 member with 384-bit output); hashlib.algorithms_guaranteed.__contains__('sha224')==True (SHA-224 is a FIPS 180-4 SHA-2 variant with 224-bit output, guaranteed since early Python 3 versions); algorithms_guaranteed is a plain Python set (see hashlib_extra2: __class__.__name__=='set'); all three algorithm names are present in the guaranteed set on macOS/Linux/FreeBSD; 'sha3_224' has len=7; 'sha3_384' has len=7; 'sha224' has len=6; verified with Python 3.14.3"
  kind: python_call_eq
  category: algorithms
  id_prefix: hashlibcovarnames210b

  columns: [id, function, args, expected, description]
  rows:
    - [alg_sha3_224, hashlib.algorithms_guaranteed.__contains__,  ["sha3_224"], true, "hashlib.algorithms_guaranteed.__contains__('sha3_224') == True (FIPS 202 SHA-3 variant); verified with Python 3.14.3"]
    - [alg_sha3_384, hashlib.algorithms_guaranteed.__contains__,  ["sha3_384"], true, "hashlib.algorithms_guaranteed.__contains__('sha3_384') == True (FIPS 202 SHA-3 variant); verified with Python 3.14.3"]
    - [alg_sha224,   hashlib.algorithms_guaranteed.__contains__,  ["sha224"],   true, "hashlib.algorithms_guaranteed.__contains__('sha224') == True (FIPS 180-4 SHA-2 variant); verified with Python 3.14.3"]
    - [alg_set_cls,  hashlib.algorithms_guaranteed.__class__.__name__.__eq__,  ["set"], true, "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra210
# ---------------------------------------------------------------------------

invariant hashlib_extra210.new_co_varnames_class_tuple:
  description: "hashlib.new.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — hashlib.new.__code__.co_varnames is a tuple (co_varnames is always a tuple of local variable name strings in CPython; hashlib.new co_varnames==('name', 'args', 'kwargs') — a 3-tuple containing the single positional param 'name' plus *args and **kwargs variable names); hashlib.new.__code__.co_varnames.__class__.__name__=='tuple' (len=5); hashlib.new.__code__.co_argcount==1 (only 'name' is a positional param); hashlib.new is the Python wrapper in Lib/hashlib.py that delegates to _hashlib.new or the pure-Python fallback; first standalone new co_varnames class name invariant; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: co_varnames
  kind: python_call_eq
  function: hashlib.new.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant hashlib_extra210.new_co_varnames_contains_name:
  description: "hashlib.new.__code__.co_varnames.__contains__('name') returns True — 'name' is present in hashlib.new.__code__.co_varnames; hashlib.new(name, *args, **kwargs) takes 'name' as its first positional parameter — the hash algorithm name string (e.g. 'sha256', 'md5'); co_varnames[0]=='name' since positional parameters appear first in co_varnames; hashlib.new.__code__.co_varnames==('name', 'args', 'kwargs') (len=3); hashlib.new.__code__.co_argcount==1 (only 'name' counted by co_argcount; *args and **kwargs are not counted); first standalone new co_varnames 'name' membership invariant; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: co_varnames
  kind: python_call_eq
  function: hashlib.new.__code__.co_varnames.__contains__
  args: ["name"]
  expected: true

invariant hashlib_extra210.file_digest_co_varnames_class_tuple:
  description: "hashlib.file_digest.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — hashlib.file_digest.__code__.co_varnames is a tuple (co_varnames==('fileobj', 'digest', '_bufsize', 'digestobj', 'buf', 'view', 'size') — a 7-tuple); hashlib.file_digest.__code__.co_varnames.__class__.__name__=='tuple' (len=5); hashlib.file_digest.__code__.co_argcount==2 (2 positional params: 'fileobj' and 'digest'); hashlib.file_digest is a pure-Python function in Lib/hashlib.py that reads a file-like object in chunks and hashes its content; file_digest was added in Python 3.11; first standalone file_digest co_varnames class name invariant; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: co_varnames
  kind: python_call_eq
  function: hashlib.file_digest.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant hashlib_extra210.algorithms_guaranteed_contains_sha3_224:
  description: "hashlib.algorithms_guaranteed.__contains__('sha3_224') returns True — 'sha3_224' is present in hashlib.algorithms_guaranteed; SHA3-224 (FIPS 202) produces a 224-bit digest and is guaranteed available on all Python 3.6+ platforms; hashlib.algorithms_guaranteed is a plain Python set; 'sha3_224'.__len__()==7; SHA3-224 is one of the four SHA-3 variants (sha3_224, sha3_256, sha3_384, sha3_512) all guaranteed since Python 3.6; algorithms_guaranteed.__class__.__name__=='set'; first standalone sha3_224 membership invariant in hashlibcovarnames210 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: algorithms
  kind: python_call_eq
  function: hashlib.algorithms_guaranteed.__contains__
  args: ["sha3_224"]
  expected: true

invariant hashlib_extra210.algorithms_guaranteed_contains_sha3_384:
  description: "hashlib.algorithms_guaranteed.__contains__('sha3_384') returns True — 'sha3_384' is present in hashlib.algorithms_guaranteed; SHA3-384 (FIPS 202) produces a 384-bit digest and is guaranteed available on all Python 3.6+ platforms; 'sha3_384'.__len__()==7; SHA3-384 pairs with SHA-384 in the SHA-2 family as a 384-bit output variant; algorithms_guaranteed.__class__.__name__=='set'; first standalone sha3_384 membership invariant in hashlibcovarnames210 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: algorithms
  kind: python_call_eq
  function: hashlib.algorithms_guaranteed.__contains__
  args: ["sha3_384"]
  expected: true

invariant hashlib_extra210.algorithms_guaranteed_contains_sha224:
  description: "hashlib.algorithms_guaranteed.__contains__('sha224') returns True — 'sha224' is present in hashlib.algorithms_guaranteed; SHA-224 (FIPS 180-4) produces a 224-bit digest and is guaranteed available on all Python 3 platforms; 'sha224'.__len__()==6; SHA-224 is the truncated form of SHA-256 using different initialization values; algorithms_guaranteed.__class__.__name__=='set'; first standalone sha224 membership invariant in hashlibcovarnames210 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: algorithms
  kind: python_call_eq
  function: hashlib.algorithms_guaranteed.__contains__
  args: ["sha224"]
  expected: true

invariant hashlib_extra210.new_co_varnames_len_3:
  description: "hashlib.new.__code__.co_varnames.__len__() == 3 — co_varnames==('name', 'args', 'kwargs') has exactly 3 elements; hashlib.new(name, *args, **kwargs): 'name' is the positional param, 'args' is the *args catch-all, 'kwargs' is the **kwargs catch-all; co_argcount==1 (only 'name' is a positional parameter; *args and **kwargs are not counted by co_argcount but appear in co_varnames); compare: hashlib.file_digest co_varnames len=7 >> hashlib.new co_varnames len=3 (file_digest has more locals due to its loop body); first standalone new co_varnames length invariant in hashlibcovarnames210 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: co_varnames
  kind: python_call_eq
  function: hashlib.new.__code__.co_varnames.__len__
  args: []
  expected: 3

invariant hashlib_extra210.file_digest_co_varnames_len_7:
  description: "hashlib.file_digest.__code__.co_varnames.__len__() == 7 — co_varnames==('fileobj', 'digest', '_bufsize', 'digestobj', 'buf', 'view', 'size') has 7 elements; 2 parameters ('fileobj', 'digest') plus 5 internal locals ('_bufsize' buffer size constant, 'digestobj' the hash object, 'buf' the read buffer, 'view' a memoryview of buf, 'size' bytes read count); co_argcount==2; compare: file_digest co_varnames len=7 >> new co_varnames len=3 (file_digest has a more complex implementation body); first standalone file_digest co_varnames length invariant in hashlibcovarnames210 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: co_varnames
  kind: python_call_eq
  function: hashlib.file_digest.__code__.co_varnames.__len__
  args: []
  expected: 7
