spec: theseus_platform_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_platform_cr2)
blocks: platform

docs: https://docs.python.org/3/library/platform.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/platform.html"
  notes:
    - "Clean-room extended platform utilities. Do NOT import platform."
    - "python_version(): return current Python version as string 'X.Y.Z'."
    - "machine(): return machine type string (e.g. 'x86_64', 'arm64')."
    - "python_version_tuple(): return (major, minor, micro) as strings."
    - "platform2_version_type(): isinstance(python_version(), str) == True."
    - "platform2_version_format(): len(python_version().split('.')) == 3."
    - "platform2_machine_str(): isinstance(machine(), str) == True."
    - "Zero-arg invariant signatures — def platform2_version_type(): return bool"
    - "Use sys.version_info for version, os.uname() or sys.platform for machine info."
    - "python_version() format: '{major}.{minor}.{micro}'."
    - "Export: python_version() -> str, machine() -> str, python_version_tuple() -> tuple."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_platform_cr2.version_type:
  description: "python_version() returns a string"
  category: python_version
  kind: python_call_eq
  function: platform2_version_type
  args: []
  expected: true

invariant theseus_platform_cr2.version_format:
  description: "python_version() has 3 dot-separated components"
  category: python_version
  kind: python_call_eq
  function: platform2_version_format
  args: []
  expected: true

invariant theseus_platform_cr2.machine_str:
  description: "machine() returns a string"
  category: machine
  kind: python_call_eq
  function: platform2_machine_str
  args: []
  expected: true
