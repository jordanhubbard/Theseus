spec: concurrent_futures_extra93
version: ">=3.9"
backend: python_module(concurrent.futures)
extends: concurrent_futures_extra92

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra92.zspec.zsdl."
    - "This spec covers: wave 254 theme — concurrent.futures as_completed and wait function code attrs + FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values. NEW in extra93: as_completed.__qualname__=='as_completed'; as_completed.__code__.co_argcount==2; as_completed.__module__=='concurrent.futures._base'; wait.__qualname__=='wait'; wait.__code__.co_argcount==3; wait.__module__=='concurrent.futures._base'; FIRST_COMPLETED=='FIRST_COMPLETED' (str); FIRST_EXCEPTION=='FIRST_EXCEPTION' (str); ALL_COMPLETED=='ALL_COMPLETED' (str); concurrent.futures.__all__.__len__()==14 (list). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "as_completed.__qualname__ == 'as_completed'. as_completed is a module-level generator function; its __qualname__ equals its __name__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "as_completed.__code__.co_argcount == 2. Parameters: fs, timeout. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "as_completed.__module__ == 'concurrent.futures._base'. Defined in the _base submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "wait.__qualname__ == 'wait'. wait is a module-level function; __qualname__ equals __name__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "wait.__code__.co_argcount == 3. Parameters: fs, timeout, return_when. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "wait.__module__ == 'concurrent.futures._base'. Defined in the _base submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "FIRST_COMPLETED == 'FIRST_COMPLETED'. The constant is a plain str, not an enum. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "FIRST_EXCEPTION == 'FIRST_EXCEPTION'. Plain str constant. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ALL_COMPLETED == 'ALL_COMPLETED'. Plain str constant. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__all__.__len__() == 14. List of 14 public names including FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED, wait, as_completed, Future, Executor, ProcessPoolExecutor, ThreadPoolExecutor, InterpreterPoolExecutor, and error classes. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# as_completed code attrs — extra93
#
# Wave 254 theme: concurrent.futures as_completed and wait code attrs
# + FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values.
#
# as_completed.__qualname__ == 'as_completed'
# as_completed.__code__.co_argcount == 2
# as_completed.__module__ == 'concurrent.futures._base'
# ---------------------------------------------------------------------------

table concurrent_futures_extra93.as_completed_code_attrs:
  description: "as_completed code attribute checks in cfascompwait93 namespace — wave 254 theme: concurrent.futures as_completed and wait code attrs; as_completed is a module-level generator function (uses 'yield from' internally); as_completed.__qualname__.__eq__('as_completed')==True (module-level function, qualname equals name); as_completed.__code__.co_argcount==2 (parameters: fs, timeout); as_completed.__module__.__eq__('concurrent.futures._base')==True (defined in _base submodule, re-exported from concurrent.futures); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfascompwait93

  columns: [id, function, args, expected, description]
  rows:
    - [asc_qualname_eq,  as_completed.__qualname__.__eq__,          ["as_completed"],               true, "as_completed.__qualname__ == 'as_completed' — module-level function; verified with Python 3.14.3"]
    - [asc_co_argcount,  as_completed.__code__.co_argcount.__eq__,  [2],                            true, "as_completed.__code__.co_argcount == 2 — parameters: fs, timeout; verified with Python 3.14.3"]
    - [asc_module_eq,    as_completed.__module__.__eq__,            ["concurrent.futures._base"],   true, "as_completed.__module__ == 'concurrent.futures._base' — defined in _base submodule; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# wait code attrs — extra93
#
# wait.__qualname__ == 'wait'
# wait.__code__.co_argcount == 3
# wait.__module__ == 'concurrent.futures._base'
# ---------------------------------------------------------------------------

table concurrent_futures_extra93.wait_code_attrs:
  description: "wait code attribute checks in cfascompwait93 namespace — wave 254 theme: concurrent.futures wait code attrs; wait is a module-level function; wait.__qualname__.__eq__('wait')==True (shortest qualname in concurrent.futures module-level functions — only 4 chars); wait.__code__.co_argcount==3 (parameters: fs, timeout, return_when); wait.__module__.__eq__('concurrent.futures._base')==True (defined in _base submodule alongside as_completed); wait has one more arg than as_completed (3 vs 2) due to the return_when parameter; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfascompwait93a

  columns: [id, function, args, expected, description]
  rows:
    - [wait_qualname_eq,  wait.__qualname__.__eq__,         ["wait"],                       true, "wait.__qualname__ == 'wait' — module-level function, qualname equals name; verified with Python 3.14.3"]
    - [wait_co_argcount,  wait.__code__.co_argcount.__eq__,  [3],                            true, "wait.__code__.co_argcount == 3 — parameters: fs, timeout, return_when; verified with Python 3.14.3"]
    - [wait_module_eq,    wait.__module__.__eq__,            ["concurrent.futures._base"],   true, "wait.__module__ == 'concurrent.futures._base' — defined in _base submodule; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED values and class names — extra93
#
# FIRST_COMPLETED == 'FIRST_COMPLETED' (str)
# FIRST_EXCEPTION == 'FIRST_EXCEPTION' (str)
# ALL_COMPLETED == 'ALL_COMPLETED' (str)
# ---------------------------------------------------------------------------

table concurrent_futures_extra93.return_when_constants:
  description: "FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED constant checks in cfascompwait93 namespace — wave 254 theme: concurrent.futures wait return_when constants; all three constants are plain str objects (not enum members); FIRST_COMPLETED.__eq__('FIRST_COMPLETED')==True; FIRST_COMPLETED.__class__.__name__.__eq__('str')==True; FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION')==True; FIRST_EXCEPTION.__class__.__name__.__eq__('str')==True; ALL_COMPLETED.__eq__('ALL_COMPLETED')==True; ALL_COMPLETED.__class__.__name__.__eq__('str')==True; these string constants are passed as the return_when parameter to wait(); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfascompwait93b

  columns: [id, function, args, expected, description]
  rows:
    - [first_comp_val,    FIRST_COMPLETED.__eq__,                     ["FIRST_COMPLETED"], true, "FIRST_COMPLETED == 'FIRST_COMPLETED' — plain str constant; verified with Python 3.14.3"]
    - [first_comp_class,  FIRST_COMPLETED.__class__.__name__.__eq__,  ["str"],             true, "FIRST_COMPLETED.__class__.__name__ == 'str' — not an enum, just a str; verified with Python 3.14.3"]
    - [first_exc_val,     FIRST_EXCEPTION.__eq__,                     ["FIRST_EXCEPTION"], true, "FIRST_EXCEPTION == 'FIRST_EXCEPTION' — plain str constant; verified with Python 3.14.3"]
    - [first_exc_class,   FIRST_EXCEPTION.__class__.__name__.__eq__,  ["str"],             true, "FIRST_EXCEPTION.__class__.__name__ == 'str' — plain str; verified with Python 3.14.3"]
    - [all_comp_val,      ALL_COMPLETED.__eq__,                       ["ALL_COMPLETED"],   true, "ALL_COMPLETED == 'ALL_COMPLETED' — plain str constant; verified with Python 3.14.3"]
    - [all_comp_class,    ALL_COMPLETED.__class__.__name__.__eq__,    ["str"],             true, "ALL_COMPLETED.__class__.__name__ == 'str' — plain str; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.__all__ class name and length — extra93
#
# concurrent.futures.__all__.__class__.__name__ == 'list'
# concurrent.futures.__all__.__len__() == 14
# ---------------------------------------------------------------------------

table concurrent_futures_extra93.all_list_attrs:
  description: "__all__ class name and length checks for concurrent.futures in cfascompwait93 namespace — wave 254 theme: concurrent.futures module __all__ metadata; concurrent.futures.__all__.__class__.__name__.__eq__('list')==True (it is a list, not a tuple); concurrent.futures.__all__.__len__()==14 (14 public names: FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED, CancelledError, TimeoutError, InvalidStateError, BrokenExecutor, Future, Executor, wait, as_completed, ProcessPoolExecutor, ThreadPoolExecutor, InterpreterPoolExecutor); InterpreterPoolExecutor was added in Python 3.14; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfascompwait93c

  columns: [id, function, args, expected, description]
  rows:
    - [all_class,  "__all__.__class__.__name__.__eq__", ["list"], true, "concurrent.futures.__all__.__class__.__name__ == 'list' — __all__ is a list; verified with Python 3.14.3"]
    - [all_len,    "__all__.__len__",                   [],        14,   "concurrent.futures.__all__.__len__() == 14 — 14 public names including InterpreterPoolExecutor (added 3.14); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra93
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra93.as_completed_qualname_eq:
  description: "concurrent.futures.as_completed.__qualname__.__eq__('as_completed') returns True — as_completed is a module-level generator function; its __qualname__ is identical to its __name__ (no class prefix); it takes 2 positional arguments (fs, timeout) as confirmed by __code__.co_argcount==2; its __module__ is 'concurrent.futures._base' (the private submodule where it is defined); NEW in extra93: first standalone __qualname__.__eq__ invariant for as_completed in cfascompwait93 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: as_completed.__qualname__.__eq__
  args: ["as_completed"]
  expected: true

invariant concurrent_futures_extra93.wait_co_argcount_eq_3:
  description: "concurrent.futures.wait.__code__.co_argcount.__eq__(3) returns True — wait() takes 3 positional parameters (fs, timeout, return_when); it has one more positional arg than as_completed (which has 2); the return_when parameter accepts FIRST_COMPLETED, FIRST_EXCEPTION, or ALL_COMPLETED; wait().__module__ is 'concurrent.futures._base'; NEW in extra93: first standalone co_argcount invariant for wait in cfascompwait93 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: wait.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant concurrent_futures_extra93.FIRST_COMPLETED_is_str:
  description: "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__('str') returns True — FIRST_COMPLETED is a plain str constant ('FIRST_COMPLETED'), not an enum member; all three return_when constants (FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED) are plain str objects; this is by design so they can be compared with == in wait(); NEW in extra93: first standalone class name invariant for FIRST_COMPLETED in cfascompwait93 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: FIRST_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra93.ALL_COMPLETED_eq:
  description: "concurrent.futures.ALL_COMPLETED.__eq__('ALL_COMPLETED') returns True — ALL_COMPLETED is a str constant equal to its own name; alongside FIRST_COMPLETED and FIRST_EXCEPTION, these three constants serve as the allowed values for the return_when parameter of wait(); the value of ALL_COMPLETED is the string 'ALL_COMPLETED'; NEW in extra93: first standalone value invariant for ALL_COMPLETED in cfascompwait93 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ALL_COMPLETED.__eq__
  args: ["ALL_COMPLETED"]
  expected: true

invariant concurrent_futures_extra93.all_list_len_14:
  description: "concurrent.futures.__all__.__len__() == 14 — the concurrent.futures module exports 14 public names in Python 3.14.3; InterpreterPoolExecutor was added in Python 3.14 and accounts for the count of 14 (up from 13 in earlier versions); the list includes the three return_when constants, error classes, Future, Executor, the pool executors, wait, and as_completed; NEW in extra93: first standalone __all__ length invariant in cfascompwait93 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 14
