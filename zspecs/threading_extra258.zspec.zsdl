spec: threading_extra258
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading.Event and threading.Timer class identity contracts."
    - "threading.Event.__name__ == 'Event' — class name. Verified with Python 3.14.3."
    - "threading.Event.__module__ == 'threading' — defined in threading. Verified with Python 3.14.3."
    - "threading.Event.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.3."
    - "threading.Event.set.__qualname__ == 'Event.set' — set method qualname. Verified with Python 3.14.3."
    - "threading.Event.clear.__qualname__ == 'Event.clear' — clear method qualname. Verified with Python 3.14.3."
    - "threading.Event.wait.__qualname__ == 'Event.wait' — wait method qualname. Verified with Python 3.14.3."
    - "threading.Event.is_set.__qualname__ == 'Event.is_set' — is_set method qualname. Verified with Python 3.14.3."
    - "threading.Timer.__name__ == 'Timer' — class name. Verified with Python 3.14.3."
    - "threading.Timer.__module__ == 'threading' — defined in threading. Verified with Python 3.14.3."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer inherits from Thread. Verified with Python 3.14.3."
    - "threading.Timer.__init__.__qualname__ == 'Timer.__init__' — initializer qualname. Verified with Python 3.14.3."
    - "threading.Timer.run.__qualname__ == 'Timer.run' — run method qualname. Verified with Python 3.14.3."
    - "threading.Timer.cancel.__qualname__ == 'Timer.cancel' — cancel method qualname. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Event class identity contracts
#
# threading.Event.__name__              == 'Event'
# threading.Event.__module__            == 'threading'
# threading.Event.__bases__[0].__name__ == 'object'
# threading.Event.__class__.__name__    == 'type'
# threading.Event.__qualname__          == 'Event'
#
# Event is a pure-Python synchronization primitive. New to extra258.
# ---------------------------------------------------------------------------

table threading_extra258.event_identity:
  description: "threading.Event name, module, base, class, qualname contracts; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: tev258

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_eq,
       Event.__name__.__eq__,
       ["Event"],
       true,
       "threading.Event.__name__.__eq__('Event') == True — class name; new to extra258"]
    - [event_module_eq,
       Event.__module__.__eq__,
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — defined in threading module; new to extra258"]
    - [event_base_name_eq,
       "Event.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Event.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra258"]
    - [event_class_name_eq,
       Event.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Event.__class__.__name__.__eq__('type') == True — it is a class; metaclass is type; new to extra258"]
    - [event_qualname_eq,
       Event.__qualname__.__eq__,
       ["Event"],
       true,
       "threading.Event.__qualname__.__eq__('Event') == True — top-level class; qualname equals name; new to extra258"]

# ---------------------------------------------------------------------------
# Table 2: threading.Event method qualname contracts
#
# threading.Event.set.__qualname__    == 'Event.set'
# threading.Event.clear.__qualname__  == 'Event.clear'
# threading.Event.wait.__qualname__   == 'Event.wait'
# threading.Event.is_set.__qualname__ == 'Event.is_set'
# threading.Event.set.__name__        == 'set'
#
# Event synchronization methods. New to extra258.
# ---------------------------------------------------------------------------

table threading_extra258.event_methods:
  description: "threading.Event set, clear, wait, is_set qualname, and set name contracts; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: tevm258

  columns: [id, function, args, expected, description]
  rows:
    - [event_set_qualname_eq,
       Event.set.__qualname__.__eq__,
       ["Event.set"],
       true,
       "threading.Event.set.__qualname__.__eq__('Event.set') == True — set method qualname; new to extra258"]
    - [event_clear_qualname_eq,
       Event.clear.__qualname__.__eq__,
       ["Event.clear"],
       true,
       "threading.Event.clear.__qualname__.__eq__('Event.clear') == True — clear method qualname; new to extra258"]
    - [event_wait_qualname_eq,
       Event.wait.__qualname__.__eq__,
       ["Event.wait"],
       true,
       "threading.Event.wait.__qualname__.__eq__('Event.wait') == True — wait method qualname; new to extra258"]
    - [event_is_set_qualname_eq,
       Event.is_set.__qualname__.__eq__,
       ["Event.is_set"],
       true,
       "threading.Event.is_set.__qualname__.__eq__('Event.is_set') == True — is_set method qualname; new to extra258"]
    - [event_set_name_eq,
       Event.set.__name__.__eq__,
       ["set"],
       true,
       "threading.Event.set.__name__.__eq__('set') == True — set method name; new to extra258"]

# ---------------------------------------------------------------------------
# Table 3: threading.Timer class identity contracts
#
# threading.Timer.__name__              == 'Timer'
# threading.Timer.__module__            == 'threading'
# threading.Timer.__bases__[0].__name__ == 'Thread'
# threading.Timer.__class__.__name__    == 'type'
# threading.Timer.__qualname__          == 'Timer'
#
# Timer is a Thread subclass. New to extra258.
# ---------------------------------------------------------------------------

table threading_extra258.timer_identity:
  description: "threading.Timer name, module, base, class, qualname contracts; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: ttim258

  columns: [id, function, args, expected, description]
  rows:
    - [timer_name_eq,
       Timer.__name__.__eq__,
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — class name; new to extra258"]
    - [timer_module_eq,
       Timer.__module__.__eq__,
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — defined in threading module; new to extra258"]
    - [timer_base_name_eq,
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer inherits from Thread; new to extra258"]
    - [timer_class_name_eq,
       Timer.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Timer.__class__.__name__.__eq__('type') == True — it is a class; metaclass is type; new to extra258"]
    - [timer_qualname_eq,
       Timer.__qualname__.__eq__,
       ["Timer"],
       true,
       "threading.Timer.__qualname__.__eq__('Timer') == True — top-level class; qualname equals name; new to extra258"]

# ---------------------------------------------------------------------------
# Table 4: threading.Timer method qualname and name contracts
#
# threading.Timer.__init__.__qualname__ == 'Timer.__init__'
# threading.Timer.run.__qualname__      == 'Timer.run'
# threading.Timer.cancel.__qualname__   == 'Timer.cancel'
# threading.Timer.__init__.__name__     == '__init__'
# threading.Timer.run.__name__          == 'run'
#
# Timer lifecycle methods. New to extra258.
# ---------------------------------------------------------------------------

table threading_extra258.timer_methods:
  description: "threading.Timer __init__, run, cancel qualname, and __init__, run name contracts; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: ttimm258

  columns: [id, function, args, expected, description]
  rows:
    - [timer_init_qualname_eq,
       Timer.__init__.__qualname__.__eq__,
       ["Timer.__init__"],
       true,
       "threading.Timer.__init__.__qualname__.__eq__('Timer.__init__') == True — initializer qualname; new to extra258"]
    - [timer_run_qualname_eq,
       Timer.run.__qualname__.__eq__,
       ["Timer.run"],
       true,
       "threading.Timer.run.__qualname__.__eq__('Timer.run') == True — run method qualname; new to extra258"]
    - [timer_cancel_qualname_eq,
       Timer.cancel.__qualname__.__eq__,
       ["Timer.cancel"],
       true,
       "threading.Timer.cancel.__qualname__.__eq__('Timer.cancel') == True — cancel method qualname; new to extra258"]
    - [timer_init_name_eq,
       Timer.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "threading.Timer.__init__.__name__.__eq__('__init__') == True — initializer method name; new to extra258"]
    - [timer_run_name_eq,
       Timer.run.__name__.__eq__,
       ["run"],
       true,
       "threading.Timer.run.__name__.__eq__('run') == True — run method name; new to extra258"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra258
# ---------------------------------------------------------------------------

invariant threading_extra258.Event.name_eq:
  description: "threading.Event.__name__ == 'Event' — class name; new to extra258"
  category: identity
  kind: python_call_eq
  function: Event.__name__.__eq__
  args: ["Event"]
  expected: true

invariant threading_extra258.Event.module_eq:
  description: "threading.Event.__module__ == 'threading' — defined in threading; new to extra258"
  category: identity
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra258.Event.base_is_object:
  description: "threading.Event.__bases__[0].__name__ == 'object' — inherits directly from object; new to extra258"
  category: identity
  kind: python_call_eq
  function: "Event.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra258.Event.class_is_type:
  description: "threading.Event.__class__.__name__ == 'type' — it is a class; metaclass is type; new to extra258"
  category: identity
  kind: python_call_eq
  function: Event.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra258.Event.set_qualname:
  description: "threading.Event.set.__qualname__ == 'Event.set' — set method qualname; new to extra258"
  category: identity
  kind: python_call_eq
  function: Event.set.__qualname__.__eq__
  args: ["Event.set"]
  expected: true

invariant threading_extra258.Event.clear_qualname:
  description: "threading.Event.clear.__qualname__ == 'Event.clear' — clear method qualname; new to extra258"
  category: identity
  kind: python_call_eq
  function: Event.clear.__qualname__.__eq__
  args: ["Event.clear"]
  expected: true

invariant threading_extra258.Event.wait_qualname:
  description: "threading.Event.wait.__qualname__ == 'Event.wait' — wait method qualname; new to extra258"
  category: identity
  kind: python_call_eq
  function: Event.wait.__qualname__.__eq__
  args: ["Event.wait"]
  expected: true

invariant threading_extra258.Event.is_set_qualname:
  description: "threading.Event.is_set.__qualname__ == 'Event.is_set' — is_set method qualname; new to extra258"
  category: identity
  kind: python_call_eq
  function: Event.is_set.__qualname__.__eq__
  args: ["Event.is_set"]
  expected: true

invariant threading_extra258.Timer.name_eq:
  description: "threading.Timer.__name__ == 'Timer' — class name; new to extra258"
  category: identity
  kind: python_call_eq
  function: Timer.__name__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra258.Timer.module_eq:
  description: "threading.Timer.__module__ == 'threading' — defined in threading; new to extra258"
  category: identity
  kind: python_call_eq
  function: Timer.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra258.Timer.base_is_thread:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer inherits from Thread; new to extra258"
  category: identity
  kind: python_call_eq
  function: "Timer.__bases__[0].__name__.__eq__"
  args: ["Thread"]
  expected: true

invariant threading_extra258.Timer.init_qualname:
  description: "threading.Timer.__init__.__qualname__ == 'Timer.__init__' — initializer qualname; new to extra258"
  category: identity
  kind: python_call_eq
  function: Timer.__init__.__qualname__.__eq__
  args: ["Timer.__init__"]
  expected: true

invariant threading_extra258.Timer.run_qualname:
  description: "threading.Timer.run.__qualname__ == 'Timer.run' — run method qualname; new to extra258"
  category: identity
  kind: python_call_eq
  function: Timer.run.__qualname__.__eq__
  args: ["Timer.run"]
  expected: true

invariant threading_extra258.Timer.cancel_qualname:
  description: "threading.Timer.cancel.__qualname__ == 'Timer.cancel' — cancel method qualname; new to extra258"
  category: identity
  kind: python_call_eq
  function: Timer.cancel.__qualname__.__eq__
  args: ["Timer.cancel"]
  expected: true
