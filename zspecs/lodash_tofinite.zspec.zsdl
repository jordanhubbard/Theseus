spec: lodash_tofinite
version: ">=4.0.0"
backend: node(lodash.tofinite)

docs: https://lodash.com/docs/#toFinite

provenance:
  derived_from:
    - "lodash.tofinite README — https://www.npmjs.com/package/lodash.tofinite"
    - "Test vectors verified with lodash.tofinite@4.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.tofinite exports the _.toFinite function directly as module.exports."
    - "toFinite converts value to a finite primitive number."
    - "Clamps Infinity to Number.MAX_VALUE."
    - "JSON cannot represent Infinity so only string/null/boolean coercions are tested."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns finite number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_tofinite.tofinite:
  kind: node_module_call_eq
  function: ~
  category: tofinite
  id_prefix: ltofin

  columns: [id, args, expected]
  rows:
    - [float,   [3.2],   3.2]
    - [string,  ["3"],   3]
    - [empty,   [""],    0]
    - [null_v,  [null],  0]
    - [bool,    [true],  1]
