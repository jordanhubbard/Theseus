spec: abc_extra102
version: ">=3.11"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra101.zspec.zsdl."
    - "This spec covers: wave 254 theme — ABCMeta method code attributes for Python-defined methods (register, __instancecheck__, __subclasscheck__) and __subclasshook__ type. NEW in extra102: type(abc.ABCMeta.register).__name__=='function' (Python-defined); ABCMeta.register.__qualname__=='ABCMeta.register' (len=16); ABCMeta.register.__code__.co_name=='register' (co_argcount=2: self and subclass); type(abc.ABCMeta.__instancecheck__).__name__=='function'; ABCMeta.__instancecheck__.__code__.co_name=='__instancecheck__' (co_argcount=2: self and instance); type(abc.ABCMeta.__subclasscheck__).__name__=='function'; ABCMeta.__subclasscheck__.__code__.co_name=='__subclasscheck__' (co_argcount=2: self and subclass); ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25, tied with __instancecheck__); type(abc.ABCMeta.__subclasshook__).__name__=='builtin_function_or_method' (C-level — unlike register/__instancecheck__/__subclasscheck__ which are Python-defined). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.register.__code__.co_argcount == 2. The two parameters are self (the ABCMeta class object) and subclass (the class to register). ABCMeta.register.__qualname__=='ABCMeta.register' (len=16). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__instancecheck__ and ABCMeta.__subclasscheck__ both have co_argcount==2 and qualname length==25. __instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25: 'ABCMeta.'=8+'__instancecheck__'=17=25). __subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25: 'ABCMeta.'=8+'__subclasscheck__'=17=25). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "type(abc.ABCMeta.__subclasshook__).__name__ == 'builtin_function_or_method'. Unlike register, __instancecheck__, and __subclasscheck__ which are Python functions (have __code__), __subclasshook__ is C-level and has no __code__ attribute. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABCMeta.register code attributes — extra102
#
# Wave 254 theme: ABCMeta.register as Python-defined method.
#
# type(abc.ABCMeta.register).__name__      == 'function'  (Python-defined)
# abc.ABCMeta.register.__qualname__        == 'ABCMeta.register'  (len=16)
# abc.ABCMeta.register.__code__.co_name    == 'register'  (co_argcount=2)
# ---------------------------------------------------------------------------

table abc_extra102.abc_register_code_attrs:
  description: "abc.ABCMeta.register code attribute checks in abcmeta102 namespace — wave 254 theme: type(ABCMeta.register).__name__.__eq__('function')==True (Python-defined in Lib/abc.py, not C-level); ABCMeta.register.__qualname__.__eq__('ABCMeta.register')==True (len=16: 'ABCMeta.'=8+'register'=8=16); ABCMeta.register.__code__.co_name.__eq__('register')==True (co_name is the unqualified function name); ABCMeta.register.__code__.co_argcount.__eq__(2)==True (params: self and subclass — the class to register as a virtual subclass); ABCMeta.register.__qualname__.__len__()==16; ABCMeta.register.__module__.__eq__('abc')==True (Python-defined in Lib/abc.py); compare: ABCMeta.__instancecheck__.__qualname__.__len__()==25 (longer — 'ABCMeta.'=8+'__instancecheck__'=17=25); ABCMeta.register is the method that registers a class as a virtual subclass of an ABC without requiring inheritance; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcmeta102

  columns: [id, function, args, expected, description]
  rows:
    - [reg_type_eq,    abc.ABCMeta.register.__class__.__name__.__eq__,          ["function"],       true, "type(ABCMeta.register).__name__ == 'function' (Python-defined); verified with Python 3.14.3"]
    - [reg_qn_eq,      abc.ABCMeta.register.__qualname__.__eq__,                ["ABCMeta.register"], true, "ABCMeta.register.__qualname__ == 'ABCMeta.register' (len=16); verified with Python 3.14.3"]
    - [reg_qn_len,     abc.ABCMeta.register.__qualname__.__len__,               [],                 16,   "ABCMeta.register.__qualname__.__len__() == 16 ('ABCMeta.register'=16); verified with Python 3.14.3"]
    - [reg_co_name,    abc.ABCMeta.register.__code__.co_name.__eq__,            ["register"],       true, "ABCMeta.register.__code__.co_name == 'register'; verified with Python 3.14.3"]
    - [reg_co_argc,    abc.ABCMeta.register.__code__.co_argcount.__eq__,        [2],                true, "ABCMeta.register.__code__.co_argcount == 2 (self and subclass); verified with Python 3.14.3"]
    - [reg_module,     abc.ABCMeta.register.__module__.__eq__,                  ["abc"],            true, "ABCMeta.register.__module__ == 'abc' (Python-defined in Lib/abc.py); verified with Python 3.14.3"]
    - [ssh_type_eq,    abc.ABCMeta.__subclasshook__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true, "type(ABCMeta.__subclasshook__).__name__ == 'builtin_function_or_method' (C-level, unlike register/__instancecheck__/__subclasscheck__); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABCMeta.__instancecheck__ and __subclasscheck__ code attributes — extra102
#
# Wave 254 theme: ABCMeta check methods as Python-defined functions.
#
# ABCMeta.__instancecheck__.__code__.co_name    == '__instancecheck__' (co_argcount=2)
# ABCMeta.__subclasscheck__.__code__.co_name    == '__subclasscheck__' (co_argcount=2)
# both have __qualname__ len == 25
# ---------------------------------------------------------------------------

table abc_extra102.abc_instancecheck_subclasscheck_code_attrs:
  description: "abc.ABCMeta.__instancecheck__ and __subclasscheck__ code attribute checks in abcmeta102 namespace — wave 254 theme: type(ABCMeta.__instancecheck__).__name__.__eq__('function')==True (Python-defined in Lib/abc.py); ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__')==True (len=25: 'ABCMeta.'=8+'__instancecheck__'=17=25); ABCMeta.__instancecheck__.__code__.co_name.__eq__('__instancecheck__')==True; ABCMeta.__instancecheck__.__code__.co_argcount.__eq__(2)==True (params: self and instance); type(ABCMeta.__subclasscheck__).__name__.__eq__('function')==True (also Python-defined); ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__')==True (len=25, tied with __instancecheck__); ABCMeta.__subclasscheck__.__code__.co_name.__eq__('__subclasscheck__')==True; ABCMeta.__subclasscheck__.__code__.co_argcount.__eq__(2)==True (params: self and subclass); both check methods have the same qualname length (25) and co_argcount (2); compare: ABCMeta.register.__qualname__.__len__()==16 (shorter); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcmeta102a

  columns: [id, function, args, expected, description]
  rows:
    - [ic_type_eq,    abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__,        ["function"],                  true, "type(ABCMeta.__instancecheck__).__name__ == 'function' (Python-defined); verified with Python 3.14.3"]
    - [ic_qn_eq,      abc.ABCMeta.__instancecheck__.__qualname__.__eq__,              ["ABCMeta.__instancecheck__"], true, "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (len=25); verified with Python 3.14.3"]
    - [ic_qn_len,     abc.ABCMeta.__instancecheck__.__qualname__.__len__,             [],                            25,   "ABCMeta.__instancecheck__.__qualname__.__len__() == 25 ('ABCMeta.__instancecheck__'=25); verified with Python 3.14.3"]
    - [ic_co_name,    abc.ABCMeta.__instancecheck__.__code__.co_name.__eq__,          ["__instancecheck__"],         true, "ABCMeta.__instancecheck__.__code__.co_name == '__instancecheck__'; verified with Python 3.14.3"]
    - [ic_co_argc,    abc.ABCMeta.__instancecheck__.__code__.co_argcount.__eq__,      [2],                           true, "ABCMeta.__instancecheck__.__code__.co_argcount == 2 (self and instance); verified with Python 3.14.3"]
    - [sc_type_eq,    abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__,        ["function"],                  true, "type(ABCMeta.__subclasscheck__).__name__ == 'function' (Python-defined); verified with Python 3.14.3"]
    - [sc_qn_eq,      abc.ABCMeta.__subclasscheck__.__qualname__.__eq__,              ["ABCMeta.__subclasscheck__"], true, "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (len=25, tied with __instancecheck__); verified with Python 3.14.3"]
    - [sc_qn_len,     abc.ABCMeta.__subclasscheck__.__qualname__.__len__,             [],                            25,   "ABCMeta.__subclasscheck__.__qualname__.__len__() == 25 ('ABCMeta.__subclasscheck__'=25); verified with Python 3.14.3"]
    - [sc_co_name,    abc.ABCMeta.__subclasscheck__.__code__.co_name.__eq__,          ["__subclasscheck__"],         true, "ABCMeta.__subclasscheck__.__code__.co_name == '__subclasscheck__'; verified with Python 3.14.3"]
    - [sc_co_argc,    abc.ABCMeta.__subclasscheck__.__code__.co_argcount.__eq__,      [2],                           true, "ABCMeta.__subclasscheck__.__code__.co_argcount == 2 (self and subclass); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABCMeta Python vs C-level method contrast — extra102
#
# Wave 254 theme: contrasting Python-defined vs C-level ABCMeta methods.
#
# Python-defined (type='function'): register, __instancecheck__, __subclasscheck__
# C-level (type='builtin_function_or_method'): __subclasshook__
# ---------------------------------------------------------------------------

table abc_extra102.abc_abcmeta_method_type_contrast:
  description: "abc.ABCMeta method type contrast checks in abcmeta102 namespace — wave 254 theme: three ABCMeta methods are Python-defined (type='function') while __subclasshook__ is C-level (type='builtin_function_or_method'); ABCMeta.register.__class__.__name__.__eq__('function')==True (Python-defined, has __code__); ABCMeta.__instancecheck__.__class__.__name__.__eq__('function')==True (Python-defined, has __code__); ABCMeta.__subclasscheck__.__class__.__name__.__eq__('function')==True (Python-defined, has __code__); ABCMeta.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method')==True (C-level, no __code__); all three Python-defined methods have __module__.__eq__('abc')==True; all three Python-defined methods have co_argcount==2; ABCMeta.register.__qualname__.__len__()==16 (shortest of the Python methods); ABCMeta.__instancecheck__.__qualname__.__len__()==25 (tied longest); ABCMeta.__subclasscheck__.__qualname__.__len__()==25 (tied longest); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta102b

  columns: [id, function, args, expected, description]
  rows:
    - [reg_is_func,   abc.ABCMeta.register.__class__.__name__.__eq__,           ["function"],                   true, "ABCMeta.register type == 'function' (Python-defined); verified with Python 3.14.3"]
    - [ic_is_func,    abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__,  ["function"],                   true, "ABCMeta.__instancecheck__ type == 'function' (Python-defined); verified with Python 3.14.3"]
    - [sc_is_func,    abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__,  ["function"],                   true, "ABCMeta.__subclasscheck__ type == 'function' (Python-defined); verified with Python 3.14.3"]
    - [ssh_is_builtin, abc.ABCMeta.__subclasshook__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true, "ABCMeta.__subclasshook__ type == 'builtin_function_or_method' (C-level, no __code__); verified with Python 3.14.3"]
    - [reg_module,    abc.ABCMeta.register.__module__.__eq__,                   ["abc"],                        true, "ABCMeta.register.__module__ == 'abc' (Python-defined in Lib/abc.py); verified with Python 3.14.3"]
    - [ic_module,     abc.ABCMeta.__instancecheck__.__module__.__eq__,          ["abc"],                        true, "ABCMeta.__instancecheck__.__module__ == 'abc' (Python-defined); verified with Python 3.14.3"]
    - [sc_module,     abc.ABCMeta.__subclasscheck__.__module__.__eq__,          ["abc"],                        true, "ABCMeta.__subclasscheck__.__module__ == 'abc' (Python-defined); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra102
# ---------------------------------------------------------------------------

invariant abc_extra102.ABCMeta_register_co_argcount_2:
  description: "abc.ABCMeta.register.__code__.co_argcount == 2 — register takes self and subclass (the class to register as a virtual subclass of the ABC); ABCMeta.register.__qualname__=='ABCMeta.register' (len=16, shortest Python-method qualname in this spec); type(ABCMeta.register).__name__=='function' (Python-defined, has __code__); ABCMeta.register.__code__.co_name=='register'; ABCMeta.register.__module__=='abc'; compare: ABCMeta.__instancecheck__.__code__.co_argcount==2 (same), ABCMeta.__subclasscheck__.__code__.co_argcount==2 (same) — all three Python-defined ABCMeta methods take exactly 2 arguments; register allows registering virtual subclasses without inheritance; NEW in extra102: first standalone ABCMeta.register argcount invariant in abcmeta102 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: abc.ABCMeta.register.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant abc_extra102.ABCMeta_instancecheck_co_argcount_2:
  description: "abc.ABCMeta.__instancecheck__.__code__.co_argcount == 2 — __instancecheck__ takes self and instance (the object being tested with isinstance()); ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25: 'ABCMeta.'=8+'__instancecheck__'=17=25); type(ABCMeta.__instancecheck__).__name__=='function' (Python-defined in Lib/abc.py); __instancecheck__ is called by isinstance() when the second argument has an ABCMeta metaclass; compare: ABCMeta.__subclasscheck__.__code__.co_argcount==2 (same — both check methods share the same co_argcount); ABCMeta.register.__code__.co_argcount==2 (same); all three Python-defined ABCMeta methods have the same co_argcount (2); NEW in extra102: first standalone ABCMeta.__instancecheck__ argcount invariant in abcmeta102 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant abc_extra102.ABCMeta_subclasscheck_qualname_len_25:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__.__len__() == 25 — 'ABCMeta.__subclasscheck__' = 'ABCMeta.'=8 + '__subclasscheck__'=17 = 25; tied with ABCMeta.__instancecheck__.__qualname__.__len__()==25 ('ABCMeta.'=8+'__instancecheck__'=17=25) for longest method qualname in this spec; compare: ABCMeta.register.__qualname__.__len__()==16 (shorter, 'register'=8 vs '__subclasscheck__'=17); ABCMeta.__subclasscheck__.__code__.co_name=='__subclasscheck__'; ABCMeta.__subclasscheck__.__code__.co_argcount==2; type(ABCMeta.__subclasscheck__).__name__=='function' (Python-defined); __subclasscheck__ is called by issubclass() when ABCMeta is in play; NEW in extra102: first standalone ABCMeta.__subclasscheck__ qualname length invariant in abcmeta102 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: abc.ABCMeta.__subclasscheck__.__qualname__.__len__
  args: []
  expected: 25

invariant abc_extra102.ABCMeta_subclasshook_is_builtin:
  description: "abc.ABCMeta.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') returns True — __subclasshook__ is C-level (Modules/_abc.c) unlike register, __instancecheck__, and __subclasscheck__ which are Python-defined (type='function' with __code__ attributes); __subclasshook__ has no __code__ attribute; compare the four ABCMeta methods: register=function, __instancecheck__=function, __subclasscheck__=function (all Python-defined, all co_argcount==2), __subclasshook__=builtin_function_or_method (C-level); __subclasshook__ is called by __subclasscheck__ to allow customization of issubclass() behavior — it is a class method that can return True, False, or NotImplemented; NEW in extra102: first standalone ABCMeta.__subclasshook__ type invariant in abcmeta102 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__subclasshook__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra102.ABCMeta_register_qualname_len_16:
  description: "abc.ABCMeta.register.__qualname__.__len__() == 16 — 'ABCMeta.register' = 'ABCMeta.'=8 + 'register'=8 = 16; this is the shortest Python-defined method qualname in this spec (compare: __instancecheck__=25 and __subclasscheck__=25, both longer); ABCMeta.register.__code__.co_name=='register' (len=8, the unqualified name); ABCMeta.register.__code__.co_argcount==2; type(ABCMeta.register).__name__=='function' (Python-defined); the difference in qualname length (register=16 vs __instancecheck__/__subclasscheck__=25) comes from 'register'=8 chars vs '__instancecheck__'/'__subclasscheck__'=17 chars each; ABCMeta.register allows registering virtual subclasses without actual inheritance; NEW in extra102: first standalone ABCMeta.register qualname length invariant in abcmeta102 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.register.__qualname__.__len__
  args: []
  expected: 16
