spec: re_extra158
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.Pattern class identity and method qualnames — re.compile() return type (Pattern class) attributes."
    - "re.Pattern.__name__ == 'Pattern'; re.Pattern.__module__ == 're' (established in re_extra155)."
    - "re.Pattern.__bases__[0].__name__ == 'object' — Pattern inherits directly from object (not from any intermediate ABC); same for re.Match.__bases__[0].__name__ == 'object'."
    - "re.Pattern.__dict__.__len__() == 26 — Pattern's class __dict__ has 26 entries covering match, search, sub, subn, split, findall, finditer, fullmatch, flags, groupindex, groups, pattern, and special methods."
    - "re.Pattern.__doc__.__class__.__name__ == 'str' — Pattern's docstring is a plain Python str."
    - "re.Pattern.match.__qualname__ == 'Pattern.match'; re.Pattern.search.__qualname__ == 'Pattern.search'; re.Pattern.sub.__qualname__ == 'Pattern.sub'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern and re.Match class identity
# Pattern.__name__ == 'Pattern', Pattern.__module__ == 're'
# Pattern.__bases__[0].__name__ == 'object' (inherits directly from object)
# Match.__bases__[0].__name__ == 'object'
# Pattern.__doc__.__class__.__name__ == 'str'
# Pattern.__dict__.__len__() == 26
# ---------------------------------------------------------------------------

table re_extra158.Pattern_Match_identity:
  description: "re.Pattern and re.Match class identity: both inherit directly from object; Pattern.__dict__ has 26 entries; Pattern.__doc__ is a str"
  kind: python_call_eq
  category: identity
  id_prefix: repatid158

  columns: [id, function, args, expected, description]
  rows:
    - [pat_name_eq,       Pattern.__name__.__eq__,                    ["Pattern"], true, "re.Pattern.__name__ == 'Pattern' (the compiled regular expression class, made public in Python 3.7; __name__ is the bare class name 'Pattern'; re.Pattern is the type returned by re.compile() — type(re.compile('')) is re.Pattern; 'Pattern' has 7 characters)"]
    - [pat_module_eq,     Pattern.__module__.__eq__,                  ["re"],      true, "re.Pattern.__module__ == 're' (Pattern's __module__ is 're', the public module; this is notable because Pattern is implemented in C (_sre extension) yet reports __module__ == 're' — the public module name — rather than '_sre'; this correct public attribution was established in re_extra155 and confirmed in re_extra157)"]
    - [pat_base_eq,       "Pattern.__bases__[0].__name__.__eq__",     ["object"],  true, "re.Pattern.__bases__[0].__name__ == 'object' (Pattern inherits directly from the Python root class 'object'; there is no intermediate ABC between object and Pattern; this differs from many standard library classes that inherit from a domain-specific ABC; re.Pattern was added as a proper public class in Python 3.7 and implemented directly as a C type inheriting object)"]
    - [mat_base_eq,       "Match.__bases__[0].__name__.__eq__",       ["object"],  true, "re.Match.__bases__[0].__name__ == 'object' (Match also inherits directly from object; like Pattern, there is no intermediate ABC; Match is the type returned by re.match(), re.search(), and re.fullmatch() when they succeed — type(re.match('x', 'x')) is re.Match; both Pattern and Match share the same simple inheritance from object)"]
    - [pat_dict_len,      "Pattern.__dict__.__len__",                  [],         26,   "re.Pattern.__dict__.__len__() == 26 (Pattern's class __dict__ has 26 entries; this includes instance methods: match, search, fullmatch, sub, subn, split, findall, finditer; read-only properties: flags, groupindex, groups, pattern; special methods: __copy__, __deepcopy__, __repr__, __eq__, __hash__, __class_getitem__ and others; 26 entries gives Pattern a moderately sized interface)"]
    - [pat_doc_class_eq,  "Pattern.__doc__.__class__.__name__.__eq__", ["str"],    true, "re.Pattern.__doc__.__class__.__name__ == 'str' (Pattern's docstring is a plain Python str; the __doc__ attribute is set by the C implementation to describe the compiled pattern type; being a str (not None or bytes) confirms Pattern has a non-empty docstring accessible via help(re.Pattern); the docstring describes Pattern as a type of compiled regular expression)"]

# ---------------------------------------------------------------------------
# re.Pattern method __qualname__ values
# Pattern.match.__qualname__ == 'Pattern.match'
# Pattern.search.__qualname__ == 'Pattern.search'
# Pattern.sub.__qualname__ == 'Pattern.sub'
# Pattern method qualnames use the public class name 'Pattern' (no underscore prefix).
# ---------------------------------------------------------------------------

table re_extra158.Pattern_method_qualnames:
  description: "re.Pattern method __qualname__ values: match='Pattern.match', search='Pattern.search', sub='Pattern.sub'; all use public 'Pattern.' prefix (not '_sre.' private prefix)"
  kind: python_call_eq
  category: qualname
  id_prefix: repatid158

  columns: [id, function, args, expected, description]
  rows:
    - [match_qeq,   "Pattern.match.__qualname__.__eq__",   ["Pattern.match"],   true, "re.Pattern.match.__qualname__ == 'Pattern.match' (the match method on compiled Pattern objects; Pattern.match() attempts to apply the pattern at the start of the string, returning a Match object or None; its qualname uses the public class name 'Pattern' — not the private C implementation name '_sre' — confirming that re.Pattern presents a clean public interface; 'Pattern.match' has 13 characters)"]
    - [search_qeq,  "Pattern.search.__qualname__.__eq__",  ["Pattern.search"],  true, "re.Pattern.search.__qualname__ == 'Pattern.search' (the search method on compiled Pattern objects; Pattern.search() scans through the string looking for a match anywhere, returning Match or None; qualname uses the public 'Pattern.' prefix (14 chars); 'Pattern.search' has 14 characters, one more than 'Pattern.match' (13))"]
    - [sub_qeq,     "Pattern.sub.__qualname__.__eq__",     ["Pattern.sub"],     true, "re.Pattern.sub.__qualname__ == 'Pattern.sub' (the substitution method on compiled Pattern objects; Pattern.sub() replaces occurrences of the pattern with a replacement string or function; 'Pattern.sub' has 11 characters — the shortest Pattern method qualname among match/search/sub; 'Pattern.' (8) + 'sub' (3) = 11)"]
    - [match_qlen,  "Pattern.match.__qualname__.__len__",  [],                  13,   "re.Pattern.match.__qualname__.__len__() == 13 ('Pattern.match' has 13 characters; 'Pattern.' (8) + 'match' (5) = 13; Pattern.match is the anchored matching method — it only matches at the start of the string; its qualname length 13 is shorter than Pattern.search (14) and longer than Pattern.sub (11))"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra158.Pattern_base_is_object:
  description: "re.Pattern.__bases__[0].__name__ == 'object' — Pattern inherits directly from object with no intermediate ABC; this contrasts with many standard library types that form ABC hierarchies (e.g. io classes all inherit from private C ABCs like _IOBase, _RawIOBase, etc.); re.Pattern is a C type (_sre.SRE_Pattern under the hood) that presents as a simple Python class inheriting object; the lack of an ABC parent means Pattern is not registered in any ABC hierarchy"
  category: identity
  kind: python_call_eq
  function: "Pattern.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant re_extra158.Match_base_is_object:
  description: "re.Match.__bases__[0].__name__ == 'object' — Match (the type returned by successful regex matching operations) also inherits directly from object; both Pattern and Match are fundamental C types with no intermediate ABC; Match objects provide access to captured groups (.group(), .groups(), .groupdict()), match span (.start(), .end(), .span()), and the input string (.string) and pattern (.re); Match inheriting directly from object makes isinstance checks simple: isinstance(m, re.Match)"
  category: identity
  kind: python_call_eq
  function: "Match.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant re_extra158.Pattern_match_qualname_eq:
  description: "re.Pattern.match.__qualname__ == 'Pattern.match' — Pattern.match() is the anchored match method that attempts to apply the compiled pattern at the start of the string; its qualname uses the public class name 'Pattern' (not the private C type '_sre'); this is analogous to how pathlib methods use 'Path.' prefix in qualnames — public class names in qualnames vs private C type names seen in io ABCs; 'Pattern.match' has 13 characters ('Pattern.' (8) + 'match' (5) = 13)"
  category: qualname
  kind: python_call_eq
  function: "Pattern.match.__qualname__.__eq__"
  args: ["Pattern.match"]
  expected: true

invariant re_extra158.Pattern_search_qualname_eq:
  description: "re.Pattern.search.__qualname__ == 'Pattern.search' — Pattern.search() scans the entire string for the first location where the pattern produces a match; its qualname 'Pattern.search' has 14 characters ('Pattern.' (8) + 'search' (6) = 14); search() is the most commonly used Pattern method for general-purpose matching (as opposed to match() for prefix matching or fullmatch() for whole-string matching); qualname length 14 > match (13) > sub (11)"
  category: qualname
  kind: python_call_eq
  function: "Pattern.search.__qualname__.__eq__"
  args: ["Pattern.search"]
  expected: true

invariant re_extra158.Pattern_dict_len_is_26:
  description: "re.Pattern.__dict__.__len__() == 26 — Pattern's class __dict__ has 26 entries; this includes the main matching methods (match, search, fullmatch, sub, subn, split, findall, finditer), read-only properties (flags, groupindex, groups, pattern), copy support (__copy__, __deepcopy__), and general special methods (__repr__, __eq__, __hash__, __class_getitem__, etc.); 26 entries is a moderate-sized __dict__ for a C extension type; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Pattern.__dict__.__len__"
  args: []
  expected: 26
