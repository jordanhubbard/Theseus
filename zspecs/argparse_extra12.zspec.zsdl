spec: argparse_extra12
version: ">=3.9"
backend: python_module(argparse)

docs: https://docs.python.org/3/library/argparse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/argparse.html — Python argparse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/argparse.py"
    - "argparse_extra11.zspec.zsdl — covers SUPPRESS.__len__()==12; ArgumentParser().formatter_class.__name__=='HelpFormatter'; Action.__bases__[0].__name__=='_AttributeHolder' via __getitem__; ArgumentParser.__name__.__class__.__name__=='str'"
    - "argparse_extra10.zspec.zsdl — covers __bases__.__len__()==1 for RawText*/MetavarType*/ArgumentDefaults*/BooleanOptionalAction/FileType/ArgumentError/ArgumentTypeError; HelpFormatter method names start_section/end_section/add_text/format_help; ArgumentParser.add_subparsers.__name__; BooleanOptionalAction.__bases__[0].__name__=='Action'"
    - "argparse_extra9.zspec.zsdl — covers FileType/ArgumentError/ArgumentTypeError metaclasses; ArgumentParser method names parse_intermixed_args/parse_known_intermixed_args/add_argument_group/add_mutually_exclusive_group/get_default"
    - "argparse_extra8.zspec.zsdl — covers __bases__.__len__()==1 for ArgumentParser/Namespace/Action/HelpFormatter; ArgumentParser method names print_usage/print_help/convert_arg_line_to_args/exit/error"
    - "argparse_extra6.zspec.zsdl — covers Namespace/__bases__[0].__name__, ArgumentParser/__bases__[0].__name__"
  notes:
    - "This spec extends the argparse chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: argparse.__all__.__len__()==18 and __all__.__class__.__name__=='list' (len 4); __dict__.__class__.__name__.__len__()==12 for ArgumentParser/Namespace/Action/ArgumentError; ArgumentParser.__mro__.__len__()==4; Namespace.__mro__.__len__()==3; Namespace/__bases__[0].__name__.__len__()==16 ('_AttributeHolder'); ArgumentParser.parse_args/__qualname__.__len__()==25 and __name__.__len__()==10; ArgumentParser.add_subparsers/__qualname__.__len__()==29 and __name__.__len__()==14; ArgumentError.__mro__.__len__()==4."
    - "argparse.__all__.__len__() == 18 on Python 3.12. __all__ is a plain list. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "argparse.ArgumentParser.__mro__.__len__() == 4 — (ArgumentParser, _AttributeHolder, _ActionsContainer, object). NOT 2 as suggested in task brief. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "argparse.Namespace.__mro__.__len__() == 3 — (Namespace, _AttributeHolder, object). NOT 2 as suggested in task brief. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "argparse.Namespace.__bases__[0].__name__ == '_AttributeHolder' — len 16. NOT 'object'/len-6 as suggested in task brief. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "argparse.ArgumentParser.add_argument.__qualname__ == '_ActionsContainer.add_argument' — inherited from _ActionsContainer; not checked here to avoid confusion with extra11 coverage."
    - "argparse.ArgumentParser.parse_args.__qualname__ == 'ArgumentParser.parse_args' (len 25); __name__ == 'parse_args' (len 10). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "argparse.ArgumentParser.add_subparsers.__qualname__ == 'ArgumentParser.add_subparsers' (len 29); __name__ == 'add_subparsers' (len 14). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "argparse.ArgumentError.__mro__.__len__() == 4 — (ArgumentError, Exception, BaseException, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# argparse.__all__.__len__() and __all__.__class__.__name__
#
# No prior spec checks __all__.__len__() or __all__.__class__.__name__.
# argparse.__all__ is a list of 18 public names on Python 3.12.
# ---------------------------------------------------------------------------

invariant argparse_extra12.all_len:
  description: "argparse.__all__.__len__() == 18 — 18 public names exported"
  category: module_structure
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 18

invariant argparse_extra12.all_class_name:
  description: "argparse.__all__.__class__.__name__ == 'list' — __all__ is a plain list"
  category: module_structure
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() == 12 for core classes
#
# No prior spec checks __dict__.__class__.__name__.__len__() for argparse classes.
# Class __dict__ is a mappingproxy; len('mappingproxy') == 12.
# ---------------------------------------------------------------------------

table argparse_extra12.class_dict_proxy_name_lens:
  description: "ArgumentParser/Namespace/Action/ArgumentError __dict__.__class__.__name__.__len__() == 12"
  kind: python_call_eq
  category: class_structure
  id_prefix: apdpnl12

  columns: [id, function, args, expected, description]
  rows:
    - [ArgumentParser_dict_class_len,
       "ArgumentParser.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len(argparse.ArgumentParser.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"]
    - [Namespace_dict_class_len,
       "Namespace.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len(argparse.Namespace.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"]
    - [Action_dict_class_len,
       "Action.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len(argparse.Action.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"]
    - [ArgumentError_dict_class_len,
       "ArgumentError.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len(argparse.ArgumentError.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"]

# ---------------------------------------------------------------------------
# MRO lengths for ArgumentParser, Namespace, ArgumentError
#
# ArgumentParser.__mro__.__len__() == 4 — (ArgumentParser, _AttributeHolder, _ActionsContainer, object).
# Namespace.__mro__.__len__() == 3 — (Namespace, _AttributeHolder, object).
# ArgumentError.__mro__.__len__() == 4 — (ArgumentError, Exception, BaseException, object).
# No prior spec checks __mro__.__len__() for these classes.
# ---------------------------------------------------------------------------

table argparse_extra12.mro_lengths:
  description: "ArgumentParser/Namespace/ArgumentError __mro__.__len__()"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: apmrol12

  columns: [id, function, args, expected, description]
  rows:
    - [ArgumentParser_mro_len,
       "ArgumentParser.__mro__.__len__",
       [],
       4,
       "argparse.ArgumentParser.__mro__.__len__() == 4 — (ArgumentParser, _AttributeHolder, _ActionsContainer, object)"]
    - [Namespace_mro_len,
       "Namespace.__mro__.__len__",
       [],
       3,
       "argparse.Namespace.__mro__.__len__() == 3 — (Namespace, _AttributeHolder, object)"]
    - [ArgumentError_mro_len,
       "ArgumentError.__mro__.__len__",
       [],
       4,
       "argparse.ArgumentError.__mro__.__len__() == 4 — (ArgumentError, Exception, BaseException, object)"]

# ---------------------------------------------------------------------------
# Namespace.__bases__[0].__name__.__len__() == 16
#
# argparse_extra6 checks Namespace/__bases__[0].__name__ == '_AttributeHolder' as an equality.
# No prior spec checks the string length.
# '_AttributeHolder' has 16 characters.
# NOTE: The task brief suggested len==6/'object' — actual Python 3.12 value is 16/'_AttributeHolder'.
# ---------------------------------------------------------------------------

invariant argparse_extra12.Namespace.base_name_len:
  description: "argparse.Namespace.__bases__[0].__name__.__len__() == 16 — len('_AttributeHolder') == 16"
  category: class_hierarchy
  kind: python_call_eq
  function: Namespace.__bases__.__getitem__
  args: [0]
  method_chain: __name__.__len__
  method_chain_args: []
  expected: 16

# ---------------------------------------------------------------------------
# ArgumentParser.parse_args and add_subparsers __qualname__/__name__ lengths
#
# No prior spec checks __qualname__.__len__() or __name__.__len__() for these methods.
# parse_args.__qualname__ == 'ArgumentParser.parse_args' (len 25); __name__ == 'parse_args' (len 10).
# add_subparsers.__qualname__ == 'ArgumentParser.add_subparsers' (len 29); __name__ == 'add_subparsers' (len 14).
# ---------------------------------------------------------------------------

table argparse_extra12.method_qualname_lens:
  description: "ArgumentParser.parse_args and add_subparsers __qualname__.__len__() and __name__.__len__()"
  kind: python_call_eq
  category: function_attrs
  id_prefix: apmql12

  columns: [id, function, args, expected, description]
  rows:
    - [parse_args_qualname_len,
       ArgumentParser.parse_args.__qualname__.__len__,
       [],
       25,
       "len('ArgumentParser.parse_args') == 25"]
    - [parse_args_name_len,
       ArgumentParser.parse_args.__name__.__len__,
       [],
       10,
       "len('parse_args') == 10"]
    - [add_subparsers_qualname_len,
       ArgumentParser.add_subparsers.__qualname__.__len__,
       [],
       29,
       "len('ArgumentParser.add_subparsers') == 29"]
    - [add_subparsers_name_len,
       ArgumentParser.add_subparsers.__name__.__len__,
       [],
       14,
       "len('add_subparsers') == 14"]

# ---------------------------------------------------------------------------
# ArgumentError.__bases__[0].__name__.__len__() == 9
#
# argparse_extra2 and extra11 check ArgumentError.__bases__[0].__name__ == 'Exception'.
# No prior spec checks the length of that name string.
# 'Exception' has 9 characters.
# ---------------------------------------------------------------------------

invariant argparse_extra12.ArgumentError.base_name_len:
  description: "argparse.ArgumentError.__bases__[0].__name__.__len__() == 9 — len('Exception') == 9"
  category: class_hierarchy
  kind: python_call_eq
  function: ArgumentError.__bases__.__getitem__
  args: [0]
  method_chain: __name__.__len__
  method_chain_args: []
  expected: 9
