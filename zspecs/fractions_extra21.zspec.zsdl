spec: fractions_extra21
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions_extra through fractions_extra20."
    - "fractions_extra20 covers utility/comparison method qualnames and property fget qualnames (numerator, denominator)."
    - "No prior spec covers Fraction.__module__ or Fraction.__bases__[0].__name__."
    - "No prior spec covers Fraction.__init__.__qualname__ (delegates to object.__init__)."
    - "No prior spec covers Fraction.__repr__.__qualname__ or Fraction.__str__.__qualname__."
    - "No prior spec covers Fraction.__format__.__qualname__."
    - "No prior spec covers Fraction.limit_denominator.__qualname__."
    - "No prior spec covers Fraction.from_decimal.__qualname__ or Fraction.from_float.__qualname__."
    - "Fraction.__bases__[0].__name__ == 'Rational' — Fraction subclasses numbers.Rational."
    - "Fraction.__init__.__qualname__ == 'object.__init__' — Fraction uses __new__ for construction; __init__ is inherited from object."
    - "from_decimal and from_float are classmethods defined directly on Fraction."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Fraction class identity: __module__ and base class name
#
# No prior spec records Fraction.__module__ or Fraction.__bases__[0].__name__.
# Fraction lives in the fractions module and inherits from numbers.Rational.
# ---------------------------------------------------------------------------

invariant fractions_extra21.Fraction.module:
  description: "fractions.Fraction.__module__ == 'fractions'"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__module__.__eq__
  args: ["fractions"]
  expected: true

invariant fractions_extra21.Fraction.module_len:
  description: "len(fractions.Fraction.__module__) == 9 — 'fractions' is 9 chars"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__module__.__len__
  args: []
  expected: 9

invariant fractions_extra21.Fraction.base_name:
  description: "fractions.Fraction.__bases__[0].__name__ == 'Rational' — Fraction subclasses numbers.Rational"
  category: class_identity
  kind: python_call_eq
  function: "Fraction.__bases__[0].__name__.__eq__"
  args: ["Rational"]
  expected: true

invariant fractions_extra21.Fraction.base_name_len:
  description: "len(fractions.Fraction.__bases__[0].__name__) == 8 — 'Rational' is 8 chars"
  category: class_identity
  kind: python_call_eq
  function: "Fraction.__bases__[0].__name__.__len__"
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Fraction.__init__.__qualname__
#
# No prior spec records this.  Fraction relies on __new__ for construction
# and does not define its own __init__; the __init__ attribute resolves to
# object.__init__, whose __qualname__ is 'object.__init__'.
# ---------------------------------------------------------------------------

invariant fractions_extra21.Fraction.init_qualname:
  description: "fractions.Fraction.__init__.__qualname__ == 'object.__init__' — Fraction uses __new__; __init__ is inherited from object"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__init__.__qualname__.__eq__
  args: ["object.__init__"]
  expected: true

invariant fractions_extra21.Fraction.init_qualname_len:
  description: "len(fractions.Fraction.__init__.__qualname__) == 15 — 'object.__init__' is 15 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__init__.__qualname__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# String representation method __qualname__ values
#
# No prior spec records __qualname__ for __repr__, __str__, or __format__.
# All three are defined directly on Fraction.
# ---------------------------------------------------------------------------

table fractions_extra21.repr_str_format_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [repr,   Fraction.__repr__.__qualname__.__eq__,   ["Fraction.__repr__"],   true, "Fraction.__repr__.__qualname__ == 'Fraction.__repr__'"]
    - [str,    Fraction.__str__.__qualname__.__eq__,    ["Fraction.__str__"],    true, "Fraction.__str__.__qualname__ == 'Fraction.__str__'"]
    - [format, Fraction.__format__.__qualname__.__eq__, ["Fraction.__format__"], true, "Fraction.__format__.__qualname__ == 'Fraction.__format__'"]

# ---------------------------------------------------------------------------
# String representation method __qualname__ length invariants
# ---------------------------------------------------------------------------

invariant fractions_extra21.repr.qualname_len:
  description: "len(fractions.Fraction.__repr__.__qualname__) == 17 — 'Fraction.__repr__' is 17 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__repr__.__qualname__.__len__
  args: []
  expected: 17

invariant fractions_extra21.str.qualname_len:
  description: "len(fractions.Fraction.__str__.__qualname__) == 16 — 'Fraction.__str__' is 16 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__str__.__qualname__.__len__
  args: []
  expected: 16

invariant fractions_extra21.format.qualname_len:
  description: "len(fractions.Fraction.__format__.__qualname__) == 19 — 'Fraction.__format__' is 19 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__format__.__qualname__.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# Conversion and utility classmethod __qualname__ values
#
# No prior spec records __qualname__ for limit_denominator, from_decimal,
# or from_float.  All are classmethods defined directly on Fraction.
# ---------------------------------------------------------------------------

table fractions_extra21.classmethod_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [limit_denominator, Fraction.limit_denominator.__qualname__.__eq__, ["Fraction.limit_denominator"], true, "Fraction.limit_denominator.__qualname__ == 'Fraction.limit_denominator'"]
    - [from_decimal,      Fraction.from_decimal.__qualname__.__eq__,      ["Fraction.from_decimal"],      true, "Fraction.from_decimal.__qualname__ == 'Fraction.from_decimal'"]
    - [from_float,        Fraction.from_float.__qualname__.__eq__,        ["Fraction.from_float"],        true, "Fraction.from_float.__qualname__ == 'Fraction.from_float'"]

# ---------------------------------------------------------------------------
# Classmethod __qualname__ length invariants
# ---------------------------------------------------------------------------

invariant fractions_extra21.limit_denominator.qualname_len:
  description: "len(fractions.Fraction.limit_denominator.__qualname__) == 26 — 'Fraction.limit_denominator' is 26 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.limit_denominator.__qualname__.__len__
  args: []
  expected: 26

invariant fractions_extra21.from_decimal.qualname_len:
  description: "len(fractions.Fraction.from_decimal.__qualname__) == 21 — 'Fraction.from_decimal' is 21 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.from_decimal.__qualname__.__len__
  args: []
  expected: 21

invariant fractions_extra21.from_float.qualname_len:
  description: "len(fractions.Fraction.from_float.__qualname__) == 19 — 'Fraction.from_float' is 19 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.from_float.__qualname__.__len__
  args: []
  expected: 19
