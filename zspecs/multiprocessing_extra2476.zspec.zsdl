spec: multiprocessing_extra2476
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Queue — Queue"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Theme: __contains__ and __getitem__ dict-presence — checking whether multiprocessing classes define membership test and item access protocol in their class __dict__."
    - "multiprocessing.Process.__dict__.__contains__('__contains__') == False — Process does not define __contains__; verified Python 3.14.4."
    - "multiprocessing.queues.Queue.__dict__.__contains__('__contains__') == False — Queue does not define __contains__; verified Python 3.14.4."
    - "multiprocessing.queues.JoinableQueue.__dict__.__contains__('__contains__') == False — JoinableQueue does not define __contains__; verified Python 3.14.4."
    - "multiprocessing.queues.SimpleQueue.__dict__.__contains__('__contains__') == False — SimpleQueue does not define __contains__; verified Python 3.14.4."
    - "multiprocessing.queues.Queue defines put, get, qsize, empty, full, close, join_thread; none are __contains__ or __getitem__; verified Python 3.14.4."
    - "Accessing a missing key via __dict__.__getitem__ raises KeyError for all multiprocessing classes; verified Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing class __dict__ __contains__ checks
#
# None of Process, queues.Queue, queues.JoinableQueue, or queues.SimpleQueue
# define __contains__ or __getitem__ in their class __dict__. They define
# IPC primitives like put, get, close, join_thread, task_done, join.
# ---------------------------------------------------------------------------

table multiprocessing_extra2476.process_dict_contains:
  description: "multiprocessing.Process.__dict__.__contains__ checks — Process defines __doc__ but NOT __contains__ or __getitem__; verified Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: mp2476

  columns: [id, function, args, expected]
  rows:
    - ["mp2476001", multiprocessing.Process.__dict__.__contains__, ["__doc__"],       true]
    - ["mp2476002", multiprocessing.Process.__dict__.__contains__, ["__contains__"],  false]
    - ["mp2476003", multiprocessing.Process.__dict__.__contains__, ["__getitem__"],   false]

table multiprocessing_extra2476.queue_dict_contains:
  description: "multiprocessing.queues.Queue.__dict__.__contains__ checks — defines put, get, qsize, empty, close, join_thread but NOT __contains__ or __getitem__; verified Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: mp2476

  columns: [id, function, args, expected]
  rows:
    - ["mp2476004", multiprocessing.queues.Queue.__dict__.__contains__, ["__init__"],      true]
    - ["mp2476005", multiprocessing.queues.Queue.__dict__.__contains__, ["put"],           true]
    - ["mp2476006", multiprocessing.queues.Queue.__dict__.__contains__, ["get"],           true]
    - ["mp2476007", multiprocessing.queues.Queue.__dict__.__contains__, ["close"],         true]
    - ["mp2476008", multiprocessing.queues.Queue.__dict__.__contains__, ["join_thread"],   true]
    - ["mp2476009", multiprocessing.queues.Queue.__dict__.__contains__, ["__contains__"],  false]
    - ["mp2476010", multiprocessing.queues.Queue.__dict__.__contains__, ["__getitem__"],   false]

