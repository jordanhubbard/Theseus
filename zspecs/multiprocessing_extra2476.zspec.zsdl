    - ["mp2476011", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["__init__"],      true]
    - ["mp2476012", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["put"],           true]
    - ["mp2476013", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["task_done"],     true]
    - ["mp2476014", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["join"],          true]
    - ["mp2476015", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["__contains__"],  false]
    - ["mp2476016", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["__getitem__"],   false]

table multiprocessing_extra2476.simple_queue_dict_contains:
  description: "multiprocessing.queues.SimpleQueue.__dict__.__contains__ checks — defines get, put, empty, close but NOT __contains__ or __getitem__; verified Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: mp2476

  columns: [id, function, args, expected]
  rows:
    - ["mp2476017", multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["__init__"],      true]
    - ["mp2476018", multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["get"],           true]
    - ["mp2476019", multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["put"],           true]
