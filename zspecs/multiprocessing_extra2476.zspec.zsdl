# ---------------------------------------------------------------------------
# __getitem__ on class __dict__ raises KeyError for missing keys
# ---------------------------------------------------------------------------

table multiprocessing_extra2476.dict_getitem_raises:
  description: "multiprocessing class __dict__.__getitem__ raises KeyError for absent __contains__ and __getitem__ keys; verified Python 3.14.4"
  kind: python_call_raises
  category: dict_presence
  id_prefix: mp2476

  columns: [id, function, args, raises]
  rows:
    - ["mp2476023", multiprocessing.Process.__dict__.__getitem__,                 ["__contains__"],  KeyError]
    - ["mp2476024", multiprocessing.queues.Queue.__dict__.__getitem__,            ["__contains__"],  KeyError]
    - ["mp2476025", multiprocessing.queues.Queue.__dict__.__getitem__,            ["__getitem__"],   KeyError]
    - ["mp2476026", multiprocessing.queues.JoinableQueue.__dict__.__getitem__,    ["__getitem__"],   KeyError]
    - ["mp2476027", multiprocessing.queues.SimpleQueue.__dict__.__getitem__,      ["__nonexistent__"], KeyError]
