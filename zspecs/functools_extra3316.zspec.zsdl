spec: ft3316
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 668 (ft3316): __ipow__, __ilshift__, __irshift__ dict-presence checks for functools types."
    - "Theme: __ipow__/__ilshift__/__irshift__ in-place power/shift dict-presence."
    - "In-place augmented assignment operators (**=, <<=, >>=) fall back to __pow__/__lshift__/__rshift__ if not defined."
    - "All values False — callable/iterator/inspection/synchronization types have no in-place power/shift operators."
    - "None of the four functools types define __ipow__, __ilshift__, or __irshift__ in their own __dict__."
    - "functools.partial and functools._lru_cache_wrapper are C-level types; functools.partialmethod and functools.cached_property are Python-level classes."
    - "type(functools.lru_cache(lambda: None)) accesses the internal _lru_cache_wrapper C type at runtime."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3316.ipow:
  description: "functools types __ipow__ dict-presence checks; wave 668"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3316
  columns: [id, function, args, expected]
  rows:
    - ["ft3316001", operator.contains, [functools.partial.__dict__,                              "__ipow__"], false]
    - ["ft3316002", operator.contains, [functools.partialmethod.__dict__,                        "__ipow__"], false]
    - ["ft3316003", operator.contains, [functools.cached_property.__dict__,                      "__ipow__"], false]
    - ["ft3316004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__,        "__ipow__"], false]

