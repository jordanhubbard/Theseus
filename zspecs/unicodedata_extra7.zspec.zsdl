spec: unicodedata_extra7
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends unicodedata.zspec.zsdl and prior extras through unicodedata_extra6.zspec.zsdl."
    - "unicodedata_extra6 covers: name() for 'Z'/'9'; lookup('EURO SIGN'); east_asian_width fullwidth-0; mirrored ')'/not-'A'; decimal '1'/'7'; ucd_3_2_0.name('A'); category '€'/'\\n'."
    - "unicodedata_extra5 covers: lookup small-a/digit-five; decimal '5'; digit 0/7/9; numeric '9'; normalize NFKC/NFKD; category '\\t'/'+'; bidirectional space; combining U+0301; decomposition e-acute; ucd_3_2_0.category('A')."
    - "unicodedata_extra4 covers: __name__ table for all major functions; unidata_version type; category A/a/0; bidirectional A; combining A; east_asian_width A; mirrored '('."
    - "No prior spec covers unicodedata.name('!') == 'EXCLAMATION MARK'."
    - "No prior spec covers unicodedata.name(' ') == 'SPACE'."
    - "No prior spec covers unicodedata.lookup('LATIN CAPITAL LETTER Z') == 'Z'."
    - "No prior spec covers unicodedata.lookup('DIGIT NINE') == '9'."
    - "No prior spec covers unicodedata.bidirectional('!') == 'ON' (other neutral)."
    - "No prior spec covers unicodedata.bidirectional('1') == 'EN' (wait: base spec covers '0'->EN; '1' is new)."
    - "No prior spec covers unicodedata.east_asian_width(' ') == 'Na' (space is narrow)."
    - "No prior spec covers unicodedata.east_asian_width('!') == 'Na' (exclamation is narrow)."
    - "No prior spec covers unicodedata.numeric('½') type being float — base spec checks value; here we check type."
    - "No prior spec covers unicodedata.category('Z') == 'Lu' (uppercase letter)."
    - "No prior spec covers unicodedata.category('z') == 'Ll' (lowercase letter)."
    - "No prior spec covers unicodedata.digit('1') == 1 (extra5 covers 0/7/9)."
    - "No prior spec covers unicodedata.ucd_3_2_0.decimal('0') == 0."
    - "unicodedata.name('!') == 'EXCLAMATION MARK'."
    - "unicodedata.name(' ') == 'SPACE'."
    - "unicodedata.lookup('LATIN CAPITAL LETTER Z') == 'Z'."
    - "unicodedata.lookup('DIGIT NINE') == '9'."
    - "unicodedata.bidirectional('!') == 'ON' — exclamation is other neutral bidi class."
    - "unicodedata.bidirectional('1') == 'EN' — digit 1 is european number bidi class."
    - "unicodedata.east_asian_width(' ') == 'Na' — space has narrow east Asian width."
    - "unicodedata.east_asian_width('!') == 'Na' — exclamation mark has narrow east Asian width."
    - "unicodedata.category('Z') == 'Lu' and category('z') == 'Ll'."
    - "unicodedata.digit('1') == 1."
    - "unicodedata.ucd_3_2_0.decimal('0') == 0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# name() — new vectors not in unicodedata.zspec.zsdl or prior extras
#
# Base spec covers: 'A', 'a', '0', '€'.
# extra6 covers: 'Z', '9'.
# We add: '!' -> 'EXCLAMATION MARK', ' ' -> 'SPACE'.
# ---------------------------------------------------------------------------

table unicodedata_extra7.name.new_vectors:
  kind: python_call_eq
  category: name
  id_prefix: name
  function: name

  columns: [id, args, expected]
  rows:
    - [exclamation, ["!"], "EXCLAMATION MARK"]
    - [space,       [" "], "SPACE"]

# ---------------------------------------------------------------------------
# lookup() — additional vectors
#
# Base spec covers: 'LATIN CAPITAL LETTER A', 'DIGIT ZERO'.
# extra5 covers: 'LATIN SMALL LETTER A', 'DIGIT FIVE'.
# extra6 covers: 'EURO SIGN'.
# We add: 'LATIN CAPITAL LETTER Z', 'DIGIT NINE'.
# ---------------------------------------------------------------------------

table unicodedata_extra7.lookup.new_vectors:
  kind: python_call_eq
  category: lookup
  id_prefix: lookup
  function: lookup

  columns: [id, args, expected]
  rows:
    - [capital_z,  ["LATIN CAPITAL LETTER Z"], "Z"]
    - [digit_nine, ["DIGIT NINE"],             "9"]

# ---------------------------------------------------------------------------
# bidirectional() — new vectors
#
# Base spec covers: 'A' -> 'L', '0' -> 'EN'.
# extra5 covers: ' ' -> 'WS'.
# We add: '!' -> 'ON' (other neutral), '1' -> 'EN' (new digit).
# ---------------------------------------------------------------------------

table unicodedata_extra7.bidirectional.new_vectors:
  kind: python_call_eq
  category: bidirectional
  id_prefix: bidi
  function: bidirectional

  columns: [id, args, expected]
  rows:
    - [exclamation, ["!"], "ON"]
    - [digit_one,   ["1"], "EN"]

# ---------------------------------------------------------------------------
# east_asian_width() — narrow characters
#
# Base spec covers: 'A' -> 'Na', '中' -> 'W'.
# extra6 covers: '０' -> 'F'.
# We add: ' ' -> 'Na' (space is narrow), '!' -> 'Na' (exclamation narrow).
# ---------------------------------------------------------------------------

table unicodedata_extra7.east_asian_width.narrow_vectors:
  kind: python_call_eq
  category: east_asian_width
  id_prefix: eaw
  function: east_asian_width

  columns: [id, args, expected]
  rows:
    - [space,       [" "], "Na"]
    - [exclamation, ["!"], "Na"]

# ---------------------------------------------------------------------------
# category() — uppercase and lowercase letters not in prior specs
#
# Base spec and extra4 cover: 'A'->Lu, 'a'->Ll, '0'->Nd.
# extra5 covers: '\t'->Cc, '+'->Sm.
# extra6 covers: '€'->Sc, '\n'->Cc.
# We add: 'Z'->Lu (uppercase letter), 'z'->Ll (lowercase letter).
# ---------------------------------------------------------------------------

table unicodedata_extra7.category.new_vectors:
  kind: python_call_eq
  category: category
  id_prefix: cat
  function: category

  columns: [id, args, expected]
  rows:
    - [upper_Z, ["Z"], "Lu"]
    - [lower_z, ["z"], "Ll"]

# ---------------------------------------------------------------------------
# digit() — value for '1' not in prior specs
#
# extra5 covers: '0'->0, '7'->7, '9'->9.
# We add: '1' -> 1.
# ---------------------------------------------------------------------------

invariant unicodedata_extra7.digit.one:
  description: "unicodedata.digit('1') == 1"
  category: digit
  kind: python_call_eq
  function: digit
  args: ["1"]
  expected: 1

# ---------------------------------------------------------------------------
# numeric() — type check for a fraction
#
# Base spec covers numeric('½') == 0.5 and numeric('5') == 5.0.
# extra5 covers numeric('9') == 9.0.
# We add: numeric('½') returns a float (type check rather than value check).
# This is a new dimension — verifying the return type.
# ---------------------------------------------------------------------------

invariant unicodedata_extra7.numeric.half_type:
  description: "unicodedata.numeric('½').__class__.__name__ == 'float' — numeric returns float"
  category: numeric
  kind: python_call_eq
  function: numeric
  args: ["\u00bd"]
  method: __class__.__name__.__eq__
  method_args: ["float"]
  expected: true

# ---------------------------------------------------------------------------
# ucd_3_2_0 — decimal() vector via legacy UCD object
#
# extra5 covers ucd_3_2_0.category('A'); extra6 covers ucd_3_2_0.name('A').
# We add: ucd_3_2_0.decimal('0') == 0.
# ---------------------------------------------------------------------------

invariant unicodedata_extra7.ucd_3_2_0.decimal_zero:
  description: "unicodedata.ucd_3_2_0.decimal('0') == 0"
  category: ucd_object
  kind: python_call_eq
  function: ucd_3_2_0.decimal
  args: ["0"]
  expected: 0

# ---------------------------------------------------------------------------
# is_normalized() — vectors not in prior specs
#
# Prior specs cover __name__ and __module__ for is_normalized.
# No prior spec covers actual behavioral vectors for is_normalized.
# is_normalized(form, string) returns True/False.
# 'A' is already NFC/NFD/NFKC/NFKD — no composition/decomposition required.
# ---------------------------------------------------------------------------

table unicodedata_extra7.is_normalized.ascii_vectors:
  kind: python_call_eq
  category: is_normalized
  id_prefix: isnorm
  function: is_normalized

  columns: [id, args, expected]
  rows:
    - [nfc_ascii,  ["NFC",  "A"], true]
    - [nfkc_ascii, ["NFKC", "A"], true]
