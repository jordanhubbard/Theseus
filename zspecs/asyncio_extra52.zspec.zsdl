spec: asyncio_extra52
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio queues documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio coroutines and tasks"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec extends asyncio_extra51.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__() (extra30: Queue.put/get/put_nowait/get_nowait/join/task_done; Lock.acquire/release), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, QueueFull/__name__.__len__()==9, QueueEmpty/QueueFull __qualname__.__len__(), Runner method __name__/__qualname__.__len__() tables, MRO depths, AbstractEventLoop/__name__/__len__() tables, BaseEventLoop/Handle/TimerHandle/Protocol/StreamReader lengths, Event/Semaphore method __qualname__ string values, BoundedSemaphore/Condition/TaskGroup/Runner identity, shield/ensure_future/create_task/get_event_loop/get_running_loop/new_event_loop/run/iscoroutine/iscoroutinefunction qualname/module, class/function __qualname__ string equality tables, Task/Future/Runner __qualname__.__len__(), Task/Future __name__/__module__/__qualname__, Task/__bases__[0].__name__=='Future', Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/TaskGroup/Runner/Task/Future __class__.__name__=='type', gather/sleep/run __class__.__name__=='function', class/function __class__.__name__.__len__() tables (extra47), Queue/Lock/Event/Semaphore/Task/Future __class__.__qualname__=='type', gather/sleep/run __class__.__qualname__=='function', class/function __class__.__qualname__.__len__() tables (extra48), QueueEmpty/QueueFull __class__.__name__=='type', QueueEmpty/QueueFull __bases__[0].__name__=='Exception', QueueEmpty/QueueFull __mro__.__len__()==4, exception __module__ string equality for QueueEmpty/QueueFull/InvalidStateError/TimeoutError/CancelledError (extra49), Queue/__doc__/__class__/__name__=='str' through asyncio module __doc__/__class__/__name__=='str', Queue/__doc__/__class__/__qualname__=='str', Lock/__doc__/__class__/__qualname__=='str', module __doc__/__class__/__qualname__=='str' (extra50). Queue.put/get/get_nowait/join/task_done/put_nowait and Lock.acquire/release qualname string equality, asyncio.__all__.__class__.__name__=='list' (extra51). Task/__module__.__len__()==8, Future/__module__.__len__()==8 (extra46). Task/__module__=='_asyncio', Future/__module__=='_asyncio' (extra46). QueueEmpty/__module__=='asyncio.queues', QueueFull/__module__=='asyncio.queues', InvalidStateError/__module__=='asyncio.exceptions', CancelledError/__module__=='asyncio.exceptions', TimeoutError/__module__=='builtins' (extra49)."
    - "This spec covers: asyncio.Queue.__module__.__eq__('asyncio.queues'); asyncio.Lock/__module__.__eq__('asyncio.locks'); asyncio.Event/__module__.__eq__('asyncio.locks'); asyncio.Semaphore/__module__.__eq__('asyncio.locks'); asyncio.gather/__module__.__eq__('asyncio.tasks'); asyncio.sleep/__module__.__eq__('asyncio.tasks'). Also: asyncio.Queue.__module__.__len__()==14; asyncio.Lock/__module__.__len__()==13; asyncio.gather/__module__.__len__()==13. Note: Task/__module__=='_asyncio' and Future/__module__=='_asyncio' were covered in extra46; QueueEmpty/QueueFull exception __module__ was covered in extra49."
    - "asyncio.Queue.__module__ == 'asyncio.queues'. Queue is defined in Lib/asyncio/queues.py; its __module__ attribute reports the submodule where the class is defined: 'asyncio.queues'. 'asyncio.queues' is 14 characters: a-s-y-n-c-i-o-.-q-u-e-u-e-s = 14. This is a novel string-equality check; prior specs captured only the __len__ (14) of this string. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__module__ == 'asyncio.locks'. Lock is defined in Lib/asyncio/locks.py; its __module__ reports 'asyncio.locks'. 'asyncio.locks' is 13 characters: a-s-y-n-c-i-o-.-l-o-c-k-s = 13. Prior specs captured the __len__ (13) of this string. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__module__ == 'asyncio.locks'. Event is defined in Lib/asyncio/locks.py alongside Lock; its __module__ also reports 'asyncio.locks'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__module__ == 'asyncio.locks'. Semaphore is defined in Lib/asyncio/locks.py; its __module__ reports 'asyncio.locks'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__module__ == 'asyncio.tasks'. gather is defined in Lib/asyncio/tasks.py; its __module__ reports 'asyncio.tasks'. 'asyncio.tasks' is 13 characters: a-s-y-n-c-i-o-.-t-a-s-k-s = 13. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__module__ == 'asyncio.tasks'. sleep is defined in Lib/asyncio/tasks.py alongside gather; its __module__ also reports 'asyncio.tasks'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__module__.__len__() == 14. 'asyncio.queues' has 14 characters. This is distinct from 'asyncio.locks' (13 chars) and 'asyncio.tasks' (13 chars); the queues submodule name is one character longer. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__module__.__len__() == 13. 'asyncio.locks' has 13 characters. This equals 'asyncio.tasks' (13 chars) — both synchronization and task submodules have the same module name length. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__module__.__len__() == 13. 'asyncio.tasks' has 13 characters. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio class __module__ string equality — extra52
#
# Each asyncio class is defined in a specific submodule of the asyncio package.
# The __module__ attribute records the defining submodule at class-definition
# time; it is NOT overridden by asyncio/__init__.py re-exports. This spec
# captures the string equality checks for the main non-exception classes:
#
#   Queue      — Lib/asyncio/queues.py    → 'asyncio.queues'  (14 chars)
#   Lock       — Lib/asyncio/locks.py     → 'asyncio.locks'   (13 chars)
#   Event      — Lib/asyncio/locks.py     → 'asyncio.locks'   (13 chars)
#   Semaphore  — Lib/asyncio/locks.py     → 'asyncio.locks'   (13 chars)
#
# Task and Future report __module__ == '_asyncio' (covered in extra46).
# QueueEmpty/QueueFull report __module__ == 'asyncio.queues' (covered in extra49).
# InvalidStateError/CancelledError report 'asyncio.exceptions' (covered in extra49).
#
# Prior specs captured __len__() for these module strings but not the full
# string equality. Extra52 supplies the complementary string equality checks.
# ---------------------------------------------------------------------------

table asyncio_extra52.class_module_eq:
  description: "asyncio class __module__ string equality in extra52 namespace — Queue in asyncio.queues, Lock/Event/Semaphore in asyncio.locks"
  kind: python_call_eq
  category: module_identity
  id_prefix: asynciomod52clsmod

  columns: [id, function, args, expected, description]
  rows:
    - [Queue,     Queue.__module__.__eq__,     ["asyncio.queues"], true, "Queue.__module__ == 'asyncio.queues' — Queue is defined in Lib/asyncio/queues.py (14 chars)"]
    - [Lock,      Lock.__module__.__eq__,      ["asyncio.locks"],  true, "Lock.__module__ == 'asyncio.locks' — Lock is defined in Lib/asyncio/locks.py (13 chars)"]
    - [Event,     Event.__module__.__eq__,     ["asyncio.locks"],  true, "Event.__module__ == 'asyncio.locks' — Event is defined in Lib/asyncio/locks.py alongside Lock (13 chars)"]
    - [Semaphore, Semaphore.__module__.__eq__, ["asyncio.locks"],  true, "Semaphore.__module__ == 'asyncio.locks' — Semaphore is defined in Lib/asyncio/locks.py (13 chars)"]

# ---------------------------------------------------------------------------
# asyncio function __module__ string equality — extra52
#
# The primary public coroutine functions in asyncio are defined in
# Lib/asyncio/tasks.py:
#   gather — consolidates multiple coroutines into a single awaitable
#   sleep  — coroutine that completes after a given delay
#
# Both report __module__ == 'asyncio.tasks' (13 chars).
# Prior specs captured the __len__() for gather/__module__ (13) and
# sleep/__module__ (13), but not the full string equality values.
# ---------------------------------------------------------------------------

table asyncio_extra52.func_module_eq:
  description: "asyncio function __module__ string equality in extra52 namespace — gather and sleep both defined in asyncio.tasks"
  kind: python_call_eq
  category: module_identity
  id_prefix: asynciomod52funcmod

  columns: [id, function, args, expected, description]
  rows:
    - [gather, gather.__module__.__eq__, ["asyncio.tasks"], true, "gather.__module__ == 'asyncio.tasks' — gather is defined in Lib/asyncio/tasks.py (13 chars)"]
    - [sleep,  sleep.__module__.__eq__,  ["asyncio.tasks"], true, "sleep.__module__ == 'asyncio.tasks' — sleep is defined in Lib/asyncio/tasks.py (13 chars)"]

# ---------------------------------------------------------------------------
# asyncio class and function __module__.__len__() — extra52
#
# The module name lengths in this spec are:
#   'asyncio.queues' — 14 chars (Queue)
#   'asyncio.locks'  — 13 chars (Lock, Event, Semaphore)
#   'asyncio.tasks'  — 13 chars (gather, sleep)
#
# The queues submodule name is one character longer than locks and tasks.
# These __len__() values cross-check the string equality values above in a
# complementary fashion.
# ---------------------------------------------------------------------------

table asyncio_extra52.module_len:
  description: "asyncio class and function __module__.__len__() in extra52 namespace — 'asyncio.queues'==14, 'asyncio.locks'==13, 'asyncio.tasks'==13"
  kind: python_call_eq
  category: module_identity
  id_prefix: asynciomod52modlen

  columns: [id, function, args, expected, description]
  rows:
    - [Queue,     Queue.__module__.__len__,     [], 14, "Queue.__module__.__len__() == 14 — 'asyncio.queues' has 14 characters (longer than locks/tasks at 13)"]
    - [Lock,      Lock.__module__.__len__,      [], 13, "Lock.__module__.__len__() == 13 — 'asyncio.locks' has 13 characters"]
    - [Event,     Event.__module__.__len__,     [], 13, "Event.__module__.__len__() == 13 — 'asyncio.locks' has 13 characters"]
    - [Semaphore, Semaphore.__module__.__len__, [], 13, "Semaphore.__module__.__len__() == 13 — 'asyncio.locks' has 13 characters"]
    - [gather,    gather.__module__.__len__,    [], 13, "gather.__module__.__len__() == 13 — 'asyncio.tasks' has 13 characters"]
    - [sleep,     sleep.__module__.__len__,     [], 13, "sleep.__module__.__len__() == 13 — 'asyncio.tasks' has 13 characters"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra52
# ---------------------------------------------------------------------------

invariant asyncio_extra52.Queue_module_eq:
  description: "asyncio.Queue.__module__ == 'asyncio.queues' — Queue is defined in Lib/asyncio/queues.py; __module__ reports the defining submodule (14 chars: 'asyncio.'(8) + 'queues'(6))"
  category: module_identity
  kind: python_call_eq
  function: Queue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra52.Lock_module_eq:
  description: "asyncio.Lock.__module__ == 'asyncio.locks' — Lock is defined in Lib/asyncio/locks.py; __module__ reports the defining submodule (13 chars: 'asyncio.'(8) + 'locks'(5))"
  category: module_identity
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra52.Event_module_eq:
  description: "asyncio.Event.__module__ == 'asyncio.locks' — Event is defined in Lib/asyncio/locks.py alongside Lock; __module__ reports 'asyncio.locks' (13 chars)"
  category: module_identity
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra52.Semaphore_module_eq:
  description: "asyncio.Semaphore.__module__ == 'asyncio.locks' — Semaphore is defined in Lib/asyncio/locks.py; __module__ reports 'asyncio.locks' (13 chars)"
  category: module_identity
  kind: python_call_eq
  function: Semaphore.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra52.gather_module_eq:
  description: "asyncio.gather.__module__ == 'asyncio.tasks' — gather is defined in Lib/asyncio/tasks.py; __module__ reports 'asyncio.tasks' (13 chars: 'asyncio.'(8) + 'tasks'(5))"
  category: module_identity
  kind: python_call_eq
  function: gather.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra52.sleep_module_eq:
  description: "asyncio.sleep.__module__ == 'asyncio.tasks' — sleep is defined in Lib/asyncio/tasks.py alongside gather; __module__ reports 'asyncio.tasks' (13 chars)"
  category: module_identity
  kind: python_call_eq
  function: sleep.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra52.Queue_module_len:
  description: "asyncio.Queue.__module__.__len__() == 14 — 'asyncio.queues' has 14 characters; the queues submodule name is one character longer than locks/tasks (13 chars each)"
  category: module_identity
  kind: python_call_eq
  function: Queue.__module__.__len__
  args: []
  expected: 14

invariant asyncio_extra52.Lock_module_len:
  description: "asyncio.Lock.__module__.__len__() == 13 — 'asyncio.locks' has 13 characters; same length as 'asyncio.tasks'"
  category: module_identity
  kind: python_call_eq
  function: Lock.__module__.__len__
  args: []
  expected: 13

invariant asyncio_extra52.gather_module_len:
  description: "asyncio.gather.__module__.__len__() == 13 — 'asyncio.tasks' has 13 characters; same length as 'asyncio.locks'"
  category: module_identity
  kind: python_call_eq
  function: gather.__module__.__len__
  args: []
  expected: 13
