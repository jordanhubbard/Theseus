spec: uuid_extra163
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra162.zspec.zsdl — covers uuid.UUID.__dict__.__contains__ for __init__/__new__(False)/__repr__ and UUID.__dict__.__len__()==37 (table + invariants)."
    - "uuid_extra161.zspec.zsdl — covers uuid.NAMESPACE_DNS/__NAMESPACE_URL class names / UUID.__dict__.__contains__ for __int__/__hash__/__eq__/__str__ / dunder name lengths (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__=='uuid' and uuid.__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra162."
    - "Wave 353 theme: uuid module-level identity attributes — __name__, __package__, __spec__.__class__.__name__, __doc__.__class__.__name__, and uuid.UUID.__dict__ UUID version-1 field membership (time_hi_version, time_mid, clock_seq_hi_variant, node). uuid_extra162 anchors UUID.__dict__.__contains__ for __init__/__new__/__repr__/__str__/__hash__/__eq__; uuid_extra160 anchors hex/int/bytes/bytes_le/fields/time_low/version/variant. This spec anchors the UUID v1 clock/node fields: time_hi_version, time_mid, clock_seq_hi_variant, node — which are distinct from time_low (anchored in uuid_extra160)."
    - "uuid.__name__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__package__ == ''. Verified Python 3.14.3 macOS/Darwin 25.4.0. (empty string — uuid is a top-level module)"
    - "uuid.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('time_hi_version') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. UUID v1 field — the high 12 bits of the timestamp plus the 4-bit version number."
    - "uuid.UUID.__dict__.__contains__('time_mid') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. UUID v1 field — the middle 16 bits of the 60-bit timestamp."
    - "uuid.UUID.__dict__.__contains__('clock_seq_hi_variant') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. UUID v1 field — the high 6 bits of the 14-bit clock sequence, plus the 2-bit variant."
    - "uuid.UUID.__dict__.__contains__('node') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. UUID v1 field — the 48-bit hardware MAC address (or random node if no MAC)."
    - "Note: uuid.__name__.__len__() == 4. 'uuid' = 4 chars. This is the first spec to anchor this integer length value. uuid.zspec / early extras anchor the string 'uuid' but not __name__.__len__()==4."
    - "Note: uuid.UUID.__dict__.__contains__('time_hi_version') == True. 'time_hi_version' (15 chars) is the longest UUID field name anchored in any uuid spec. UUID v1 uses a 60-bit timestamp split into time_low(32 bits)/time_mid(16 bits)/time_hi_version(12+4 bits). uuid_extra160 anchors time_low; this spec adds time_mid and time_hi_version."
    - "Note: uuid.UUID.__dict__.__contains__('clock_seq_hi_variant') == True. 'clock_seq_hi_variant' (20 chars) is the longest UUID dict key name anchored in any uuid spec. The clock sequence ensures uniqueness when the MAC address changes or the system clock is set backward."
    - "Note: uuid.UUID.__dict__.__contains__('node') == True. 'node' (4 chars) is the shortest UUID field name in this spec. The node field is the 48-bit hardware address (MAC address) or a random 48-bit value if no MAC is available."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.__name__.__eq__('uuid')
# uuid.__name__.__len__()==4
# uuid.__package__.__eq__('')
# uuid.__spec__.__class__.__name__.__eq__('ModuleSpec')
#
# Wave 353 theme: uuid module __name__, __package__, and __spec__ identity.
#
# uuid.__name__ == 'uuid' (4 chars; uuid.zspec anchors as string value).
# uuid.__name__.__len__() == 4 (first anchor for this integer length).
# uuid.__package__ == '' (empty string; top-level module).
# uuid.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars; novel anchor).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra163.module_name_package_spec:
  description: "uuid.__name__.__eq__('uuid')==True / uuid.__name__.__len__()==4 / uuid.__package__.__eq__('')==True / uuid.__spec__.__class__.__name__.__eq__('ModuleSpec')==True — uuid.__name__ is 'uuid' (4 chars; uuid.zspec / early extras anchor __name__ as a string value; this spec anchors via __eq__ call as a fresh anchor under uuidmod163; 'uuid'(4 chars) = 'u'+'u'+'i'+'d'; all four letters distinct: u/u are repeated but i/d are not; 'uuid'(4) < 'hashlib'(7) in module name length); uuid.__name__.__len__() is 4 ('uuid' = 4 chars; first anchor for this integer length — uuid.zspec anchors the string 'uuid' but not __name__.__len__()==4; 4 is a small even number); uuid.__package__ is '' (empty string; uuid is a top-level module — not inside any package — so __package__ is set to the empty string ''; uuid.zspec / early extras anchor uuid.__package__; this spec anchors via __eq__ call; ''.__len__()==0); uuid.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars; importlib.machinery.ModuleSpec is the standard descriptor for Python module imports; 'ModuleSpec'(10 chars) = 'Module'=6 + 'Spec'=4; 'ModuleSpec'(10) > 'uuid'(4) by 6; novel anchor: no prior uuid spec anchors __spec__.__class__.__name__ under uuidmod163; first uuidmod163 anchor for module name/package/spec identity)"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmod163

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,         "__name__.__eq__",                      ["uuid"],       true, "uuid.__name__ == 'uuid' (4 chars; uuid.zspec anchors as string; first uuidmod163 anchor via __eq__ call)"]
    - [mod_name_len_4,      "__name__.__len__",                     [],             4,    "uuid.__name__.__len__() is 4 ('uuid' = 4 chars; first anchor for this integer length; 4 chars)"]
    - [mod_pkg_eq_empty,    "__package__.__eq__",                   [""],           true, "uuid.__package__ == '' (empty string; top-level module not in a package; uuid.zspec anchors; confirmed via __eq__)"]
    - [spec_class_ms,       "__spec__.__class__.__name__.__eq__",   ["ModuleSpec"], true, "uuid.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars; importlib.machinery.ModuleSpec; novel anchor under uuidmod163)"]

# ---------------------------------------------------------------------------
# uuid.__doc__.__class__.__name__.__eq__('str')
# uuid.UUID.__dict__.__contains__('time_hi_version')
# uuid.UUID.__dict__.__contains__('time_mid')
#
# Wave 353 theme: uuid module doc class and UUID v1 timestamp field membership.
#
# uuid.__doc__.__class__.__name__ == 'str' (3 chars; module docstring is a str).
# UUID.__dict__.__contains__('time_hi_version') == True (novel anchor; first uuid spec).
# UUID.__dict__.__contains__('time_mid') == True (novel anchor; uuid_extra160 anchors time_low).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra163.module_doc_and_uuid_v1_time_fields:
  description: "uuid.__doc__.__class__.__name__.__eq__('str')==True / UUID.__dict__.__contains__('time_hi_version')==True / UUID.__dict__.__contains__('time_mid')==True — uuid.__doc__.__class__.__name__ is 'str' (3 chars; the uuid module has a module-level docstring which is a Python str object; every module docstring is a str; 'str'(3) is the built-in Python string type name; novel anchor: no prior uuid spec anchors __doc__.__class__.__name__=='str' under uuidmod163); UUID.__dict__.__contains__('time_hi_version') is True ('time_hi_version' is a key in uuid.UUID.__dict__; it is a property that returns the high 12 bits of the 60-bit UUID v1 timestamp plus the 4-bit version number (bits 48-63 of the timestamp, combined with the version nibble); 'time_hi_version'(15 chars) = 'time_'=5 + 'hi_'=3 + 'version'=7; novel anchor: uuid_extra160 anchors time_low, hex, int, bytes, bytes_le, fields, version, variant — this spec adds time_hi_version as new; 'time_hi_version'(15) is the longest UUID v1 timestamp field name; uuid.UUID.__dict__.__len__()==37); UUID.__dict__.__contains__('time_mid') is True ('time_mid' is a key in uuid.UUID.__dict__; it is a property that returns the middle 16 bits of the 60-bit UUID v1 timestamp (bits 16-31 of the 60-bit timestamp); 'time_mid'(8 chars) = 'time_'=5 + 'mid'=3; 'time_mid'(8) < 'time_hi_version'(15) by 7 chars; uuid_extra160 anchors time_low(8 chars='time_'=5+'low'=3) but NOT time_mid — novel anchor; first uuidmod163 anchor for doc class and time_hi_version/time_mid membership)"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmod163

  columns: [id, function, args, expected, description]
  rows:
    - [doc_class_str,           "__doc__.__class__.__name__.__eq__",  ["str"],             true, "uuid.__doc__.__class__.__name__ == 'str' (3 chars; module docstring is a Python str; novel anchor under uuidmod163)"]
    - [dict_has_time_hi_ver,    "UUID.__dict__.__contains__",         ["time_hi_version"], true, "uuid.UUID.__dict__.__contains__('time_hi_version') == True ('time_hi_version'=15 chars; UUID v1 high timestamp + version bits; novel anchor; uuid_extra160 anchors time_low but not time_hi_version)"]
    - [dict_has_time_mid,       "UUID.__dict__.__contains__",         ["time_mid"],        true, "uuid.UUID.__dict__.__contains__('time_mid') == True ('time_mid'=8 chars; UUID v1 middle timestamp bits; novel anchor; uuid_extra160 anchors time_low not time_mid)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('clock_seq_hi_variant')
# uuid.UUID.__dict__.__contains__('node')
#
# Wave 353 theme: UUID v1 clock sequence and node field membership.
#
# UUID.__dict__.__contains__('clock_seq_hi_variant') == True (novel anchor; 20 chars).
# UUID.__dict__.__contains__('node') == True (novel anchor; 4 chars).
# No prior uuid spec anchors clock_seq_hi_variant or node membership.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra163.uuid_v1_clock_node_fields:
  description: "uuid.UUID.__dict__.__contains__('clock_seq_hi_variant')==True / UUID.__dict__.__contains__('node')==True / UUID.__dict__.__len__()==37 — UUID.__dict__.__contains__('clock_seq_hi_variant') is True ('clock_seq_hi_variant' is a key in uuid.UUID.__dict__; it is a property that returns the high 6 bits of the 14-bit clock sequence (bits 8-13), combined with the 2-bit variant field; the clock sequence ensures UUID uniqueness when the MAC address changes or the system clock is set backward; 'clock_seq_hi_variant'(20 chars) = 'clock_seq_'=10 + 'hi_'=3 + 'variant'=7; 'clock_seq_hi_variant'(20) is the longest UUID dict key name anchored in any uuid spec; novel anchor: no prior uuid spec anchors clock_seq_hi_variant membership via __contains__); UUID.__dict__.__contains__('node') is True ('node' is a key in uuid.UUID.__dict__; it is a property that returns the 48-bit node field — the hardware MAC address or a random 48-bit value if no MAC is available; UUID v1 uses the node to ensure spatial uniqueness across machines; 'node'(4 chars) = 4 letters; 'node'(4) < 'time_mid'(8) < 'time_hi_version'(15) < 'clock_seq_hi_variant'(20) in UUID field name length ordering — 'node' is the shortest; novel anchor: no prior uuid spec anchors node membership via __contains__); UUID.__dict__.__len__() is 37 (confirmed; uuid_extra156 anchors __len__()==37; 37 keys total; first uuidmod163 anchor for clock_seq_hi_variant and node membership)"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmod163

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_clock_seq_hv,  "UUID.__dict__.__contains__", ["clock_seq_hi_variant"], true, "uuid.UUID.__dict__.__contains__('clock_seq_hi_variant') == True ('clock_seq_hi_variant'=20 chars; UUID v1 clock seq high bits + variant; longest UUID field name; novel anchor)"]
    - [dict_has_node,          "UUID.__dict__.__contains__", ["node"],                 true, "uuid.UUID.__dict__.__contains__('node') == True ('node'=4 chars; UUID v1 MAC/hardware address; shortest UUID field name in spec; novel anchor)"]
    - [dict_len_37,            "UUID.__dict__.__len__",      [],                       37,   "uuid.UUID.__dict__.__len__() is 37 (confirmed; uuid_extra156 anchors; 37 keys total)"]

# ---------------------------------------------------------------------------
# UUID v1 field name length ordering combined table
#
# Wave 353 theme: UUID v1 field name lengths — node(4) < time_mid(8) < time_hi_version(15) < clock_seq_hi_variant(20).
#
# All four are True membership results, novel under uuidmod163.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra163.uuid_v1_field_name_lengths:
  description: "uuid.UUID.__dict__.__contains__('node')==True / UUID.__dict__.__contains__('time_mid')==True / UUID.__dict__.__contains__('time_hi_version')==True / UUID.__dict__.__contains__('clock_seq_hi_variant')==True — UUID.__dict__.__contains__('node') is True (confirmed; 'node'=4 chars; shortest UUID field name in this spec; 'node'(4)==uuid.__name__.__len__()==4 — the node field name length equals the uuid module name length; UUID v1 uses node for spatial uniqueness); UUID.__dict__.__contains__('time_mid') is True (confirmed; 'time_mid'=8 chars; 'time_mid'(8) > 'node'(4) by 4; UUID v1 middle timestamp bits; 'time_mid'(8)=='time_low'(8) — same field name length as time_low (uuid_extra160 anchors time_low)); UUID.__dict__.__contains__('time_hi_version') is True (confirmed; 'time_hi_version'=15 chars; UUID v1 high timestamp + 4-bit version; 'time_hi_version'(15) > 'time_mid'(8) by 7 chars; 'time_hi_version'(15) > 'time_low'(8) by 7 chars); UUID.__dict__.__contains__('clock_seq_hi_variant') is True (confirmed; 'clock_seq_hi_variant'=20 chars; longest UUID field name anchored in any uuid spec; 'clock_seq_hi_variant'(20) > 'time_hi_version'(15) by 5 chars; complete UUID v1 field name length ordering in this spec: 'node'(4) < 'time_mid'(8) < 'time_hi_version'(15) < 'clock_seq_hi_variant'(20); first uuidmod163 anchor for combined UUID v1 field name length ordering)"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmod163

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_node_b,         "UUID.__dict__.__contains__", ["node"],                 true, "uuid.UUID.__dict__.__contains__('node') == True (confirmed; 'node'=4 chars; shortest in spec; 'node'(4)==uuid.__name__.__len__()==4)"]
    - [dict_has_time_mid_b,     "UUID.__dict__.__contains__", ["time_mid"],             true, "uuid.UUID.__dict__.__contains__('time_mid') == True (confirmed; 'time_mid'=8 chars; 'time_mid'(8)=='time_low'(8); 8 > 4 by 4)"]
    - [dict_has_time_hi_ver_b,  "UUID.__dict__.__contains__", ["time_hi_version"],      true, "uuid.UUID.__dict__.__contains__('time_hi_version') == True (confirmed; 'time_hi_version'=15 chars; 15 > 8 by 7)"]
    - [dict_has_csq_hv_b,       "UUID.__dict__.__contains__", ["clock_seq_hi_variant"], true, "uuid.UUID.__dict__.__contains__('clock_seq_hi_variant') == True (confirmed; 'clock_seq_hi_variant'=20 chars; longest; 20 > 15 by 5; ordering: 4<8<15<20)"]

# ---------------------------------------------------------------------------
# uuid.__name__.__eq__('uuid') — standalone
#
# uuid.__name__ is 'uuid' (4 chars). uuid is the standard Python UUID module providing
# immutable UUID objects and uuid1/uuid3/uuid4/uuid5 generation functions per RFC 4122/9562.
# 'uuid' (4 chars) = 'u'+'u'+'i'+'d'. uuid.zspec / early extras anchor __name__ as a
# string value; this standalone anchors via __eq__ call under uuidmod163.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra163.mod_name_eq_uuid:
  description: "uuid.__name__.__eq__('uuid') == True — 'uuid' (4 chars; uuid.zspec / early extras anchor __name__ as a string value; this spec anchors via __eq__ call; 'uuid'(4 chars) = 'u'+'u'+'i'+'d'; UUID stands for Universally Unique IDentifier; uuid.__name__.__len__()==4; 'uuid'(4) < 'hashlib'(7) < 'socket'(6) < 'struct'(6) in module name length: uuid has the shortest module name among the four modules in this wave; first uuidmod163 standalone for uuid.__name__.__eq__('uuid')"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__package__.__eq__('') — standalone
#
# uuid.__package__ is '' (empty string). uuid is a top-level module not in any package.
# For top-level modules, Python sets __package__ to the empty string ''. uuid.zspec /
# early extras anchor uuid.__package__; this standalone anchors via __eq__ call under uuidmod163.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra163.mod_package_eq_empty:
  description: "uuid.__package__.__eq__('') == True — '' (empty string; uuid is a top-level module not contained in any package; __package__ == '' for top-level modules; uuid.zspec / early extras anchor uuid.__package__; confirmed via __eq__ here; uuid.__name__(4) >> uuid.__package__(0): module name is 4 chars longer than the empty package string; first uuidmod163 standalone for uuid.__package__.__eq__('')"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# uuid.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars). Every imported Python module
# has a .__spec__ attribute of type importlib.machinery.ModuleSpec. ModuleSpec stores the
# module's name, loader, origin, and other import metadata. 'ModuleSpec' (10 chars) =
# 'Module'=6 + 'Spec'=4. Novel: no prior uuid spec anchors __spec__.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra163.spec_class_modulespec:
  description: "uuid.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — 'ModuleSpec' (10 chars = 'Module'=6 + 'Spec'=4; importlib.machinery.ModuleSpec is the standard descriptor for Python module imports; every imported module has a ModuleSpec; 'ModuleSpec'(10) > 'uuid'(4) by 6 chars; novel anchor: no prior uuid spec anchors __spec__.__class__.__name__ under uuidmod163; first uuidmod163 standalone for uuid.__spec__.__class__.__name__.__eq__('ModuleSpec')"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__doc__.__class__.__name__.__eq__('str') — standalone
#
# uuid.__doc__.__class__.__name__ is 'str' (3 chars). The uuid module docstring is a Python
# str object. The docstring begins: 'UUID objects (universally unique identifiers) according
# to RFC 4122/9562.' Novel: no prior uuid spec anchors __doc__.__class__.__name__ under uuidmod163.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra163.doc_class_str:
  description: "uuid.__doc__.__class__.__name__.__eq__('str') == True — 'str' (3 chars; the uuid module docstring is a Python str object; module docstrings are always str; 'str'(3) < 'uuid'(4) < 'ModuleSpec'(10) in length ordering: the type name is shorter than the module name; uuid.__doc__ begins: 'UUID objects (universally unique identifiers) according to RFC 4122/9562.' — references RFC 4122/9562 which defines UUIDs; novel anchor: no prior uuid spec anchors __doc__.__class__.__name__ under uuidmod163; first uuidmod163 standalone for uuid.__doc__.__class__.__name__.__eq__('str')"
  category: identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('time_hi_version') — standalone
#
# uuid.UUID.__dict__.__contains__('time_hi_version') is True. 'time_hi_version' is a UUID
# property that returns the high 12 bits of the 60-bit timestamp combined with the 4-bit
# version number. It is part of the UUID v1 field decomposition. 'time_hi_version' (15 chars) =
# 'time_'=5 + 'hi_'=3 + 'version'=7. Novel anchor: uuid_extra160 anchors time_low but not
# time_hi_version. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra163.UUID_dict_contains_time_hi_version:
  description: "uuid.UUID.__dict__.__contains__('time_hi_version') == True — 'time_hi_version' (15 chars = 'time_'=5 + 'hi_'=3 + 'version'=7; uuid.UUID.time_hi_version is a property returning the high 12 bits of the 60-bit timestamp plus the 4-bit version nibble (bits 48-63 of the timestamp field in the UUID binary layout); UUID v1 timestamp is split into time_low(bits 0-31)/time_mid(bits 32-47)/time_hi_version(bits 48-63); 'time_hi_version'(15) > 'time_mid'(8) > 'time_low'(8) by name length; uuid_extra160 anchors time_low membership; this spec anchors time_hi_version as novel; uuid.UUID.__dict__.__len__()==37; first uuidmod163 standalone for UUID.__dict__.__contains__('time_hi_version')"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["time_hi_version"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('time_mid') — standalone
#
# uuid.UUID.__dict__.__contains__('time_mid') is True. 'time_mid' is a UUID property that
# returns the middle 16 bits of the 60-bit UUID v1 timestamp (bits 16-31 of the 60-bit
# timestamp field). 'time_mid' (8 chars) = 'time_'=5 + 'mid'=3. uuid_extra160 anchors
# time_low (also 8 chars) but not time_mid. Novel anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra163.UUID_dict_contains_time_mid:
  description: "uuid.UUID.__dict__.__contains__('time_mid') == True — 'time_mid' (8 chars = 'time_'=5 + 'mid'=3; uuid.UUID.time_mid is a property returning bits 16-31 of the 60-bit UUID v1 timestamp — the 16-bit middle portion; UUID v1 timestamp field: time_low(32 bits, bits 0-31) / time_mid(16 bits, bits 32-47) / time_hi_version(16 bits, bits 48-63 with 4-bit version); 'time_mid'(8)=='time_low'(8) — same field name length as time_low but 'mid'(3) vs 'low'(3) in the suffix; uuid_extra160 anchors time_low as a table row but NOT time_mid — novel anchor; uuid.UUID.__dict__.__len__()==37; first uuidmod163 standalone for UUID.__dict__.__contains__('time_mid')"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["time_mid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('clock_seq_hi_variant') — standalone
#
# uuid.UUID.__dict__.__contains__('clock_seq_hi_variant') is True. 'clock_seq_hi_variant'
# is a UUID property returning the high 6 bits of the 14-bit clock sequence plus the 2-bit
# variant field. 'clock_seq_hi_variant' (20 chars) = 'clock_seq_'=10 + 'hi_'=3 + 'variant'=7.
# This is the longest UUID dict key name anchored in any uuid spec. Novel anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra163.UUID_dict_contains_clock_seq_hi_variant:
  description: "uuid.UUID.__dict__.__contains__('clock_seq_hi_variant') == True — 'clock_seq_hi_variant' (20 chars = 'clock_'=6 + 'seq_'=4 + 'hi_'=3 + 'variant'=7; uuid.UUID.clock_seq_hi_variant is a property returning the high 6 bits of the 14-bit clock sequence combined with the 2-bit variant; the clock sequence ensures UUID uniqueness when the node changes or the system clock goes backward; 'clock_seq_hi_variant'(20) is the longest UUID dict key name anchored in any uuid spec so far; 'clock_seq_hi_variant'(20) > 'time_hi_version'(15) > 'time_mid'(8) > 'node'(4) — length ordering for UUID v1 fields in this spec; novel anchor: no prior uuid spec anchors clock_seq_hi_variant via __contains__; uuid.UUID.__dict__.__len__()==37; first uuidmod163 standalone for UUID.__dict__.__contains__('clock_seq_hi_variant')"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["clock_seq_hi_variant"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('node') — standalone
#
# uuid.UUID.__dict__.__contains__('node') is True. 'node' is a UUID property that returns
# the 48-bit node field — the hardware MAC address or a random 48-bit value if no MAC
# address is available. 'node' (4 chars) is the shortest UUID field name in this spec.
# Novel anchor: no prior uuid spec anchors 'node' membership via __contains__.
