spec: multiprocessing_extra109
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra108.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing.Process method code attributes: start, join, terminate, kill, is_alive, run, close co_argcounts. NEW in extra109: multiprocessing.Process.start.__qualname__=='BaseProcess.start' (len=17, co_argcount=1: self only); multiprocessing.Process.join.__qualname__=='BaseProcess.join' (len=16, co_argcount=2: self and timeout); multiprocessing.Process.terminate.__qualname__=='BaseProcess.terminate' (len=21, co_argcount=1: self only); multiprocessing.Process.kill.__qualname__=='BaseProcess.kill' (len=16, co_argcount=1: self only; same len as join); multiprocessing.Process.is_alive.__qualname__=='BaseProcess.is_alive' (len=20, co_argcount=1: self only); multiprocessing.Process.run.__qualname__=='BaseProcess.run' (len=15, co_argcount=1: self only; shortest method qualname); multiprocessing.Process.close.__qualname__=='BaseProcess.close' (len=17, co_argcount=1: self only; tied with start). All methods are defined on BaseProcess and inherited by Process. Process.__bases__[0].__name__=='BaseProcess', __mro__.__len__()==3. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.start.__qualname__ == 'BaseProcess.start' (len=17). All Process methods are actually defined on BaseProcess (Process is a thin wrapper). The qualname prefix 'BaseProcess.'=12 chars appears on every method. Process.__mro__ == [Process, BaseProcess, object] (length=3). Process.__module__=='multiprocessing.context'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.join.__qualname__ == 'BaseProcess.join' (len=16). join has co_argcount=2 (self and timeout) — it is the only process lifecycle method that takes an argument beyond self. kill and join have the same qualname length=16 but different co_argcount values (kill=1, join=2). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process start, run, join method code attributes — extra109
#
# Wave 254 theme: Process lifecycle method qualnames and co_argcounts.
#
# Process.start.__qualname__  == 'BaseProcess.start'  (len=17, co_argcount=1)
# Process.run.__qualname__    == 'BaseProcess.run'    (len=15, co_argcount=1, shortest)
# Process.join.__qualname__   == 'BaseProcess.join'   (len=16, co_argcount=2)
# ---------------------------------------------------------------------------

table multiprocessing_extra109.mp_process_start_run_join_attrs:
  description: "multiprocessing.Process.start, run, join method code attribute checks in mpprocess109 namespace — wave 254 theme: multiprocessing.Process.start.__qualname__.__eq__('BaseProcess.start')==True (len=17: 'BaseProcess.'=12+'start'=5=17; all Process methods inherit qualnames from BaseProcess); type(multiprocessing.Process.start).__name__.__eq__('function')==True; multiprocessing.Process.start.__code__.co_argcount==1 (self only — start() spawns a new process running the run() method); multiprocessing.Process.run.__qualname__.__eq__('BaseProcess.run')==True (len=15: 'BaseProcess.'=12+'run'=3=15; shortest method qualname in spec); type(multiprocessing.Process.run).__name__.__eq__('function')==True; multiprocessing.Process.run.__code__.co_argcount==1 (self only — run() contains the target callable invocation); multiprocessing.Process.join.__qualname__.__eq__('BaseProcess.join')==True (len=16: 'BaseProcess.'=12+'join'=4=16); type(multiprocessing.Process.join).__name__.__eq__('function')==True; multiprocessing.Process.join.__code__.co_argcount==2 (self and timeout — join is the only lifecycle method taking a timeout parameter); compare co_argcount: start=run=1 (self only) < join=2 (takes timeout); compare qualname lengths: run=15 (shortest) < join=16 < start=17; 'BaseProcess.'=12 prefix common to all method qualnames in spec; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: mpprocess109

