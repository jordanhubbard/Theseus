invariant multiprocessing_extra109.Process_terminate_qualname_len_21:
  description: "multiprocessing.Process.terminate.__qualname__.__len__() == 21 — 'BaseProcess.terminate' = 'BaseProcess.'=12 + 'terminate'=9 = 21; this is the longest method qualname in this spec; compare all method qualname lengths: run=15 (shortest) < join=kill=16 < start=close=17 (tied) < is_alive=20 < terminate=21 (longest); Process.terminate.__code__.co_argcount==1 (self only — sends SIGTERM to the child process on Unix); Process.terminate.__qualname__=='BaseProcess.terminate' (inherited from BaseProcess, not defined on Process itself); all method qualnames use 'BaseProcess.' prefix (len=12); 'terminate'=9 chars is the longest method name in this spec; compare method name lengths: run=3 < join=kill=4 < start=close=5 < is_alive=8 < terminate=9 (longest); NEW in extra109: first standalone Process.terminate qualname length invariant in mpprocess109 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: multiprocessing.Process.terminate.__qualname__.__len__
  args: []
  expected: 21

invariant multiprocessing_extra109.Process_join_co_argcount_2:
  description: "multiprocessing.Process.join.__code__.co_argcount == 2 — join takes self and timeout (timeout is the only extra positional parameter among all Process lifecycle methods); Process.join.__qualname__=='BaseProcess.join' (len=16); type(multiprocessing.Process.join).__name__=='function' (Python-defined); compare co_argcount: join=2 (takes timeout) > all other process methods=1 (self only: start, run, terminate, kill, is_alive, close all have co_argcount=1); join blocks until the process terminates (or until timeout seconds); if timeout is not None and join times out, the process is still alive; join is the only lifecycle method that takes a time parameter; join and kill have the same qualname len=16 but different co_argcount (join=2 vs kill=1); NEW in extra109: first standalone Process.join argcount invariant in mpprocess109 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: multiprocessing.Process.join.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant multiprocessing_extra109.Process_run_qualname_len_15:
  description: "multiprocessing.Process.run.__qualname__.__len__() == 15 — 'BaseProcess.run' = 'BaseProcess.'=12 + 'run'=3 = 15; this is the shortest method qualname in this spec; compare: run=15 (shortest) < join=kill=16 < start=close=17 (tied) < is_alive=20 < terminate=21 (longest); Process.run.__code__.co_argcount==1 (self only); Process.run() is the method that executes in the child process — it calls the target callable with the given arguments; when subclassing Process, override run() to define process behavior; Process.run.__qualname__=='BaseProcess.run' (inherited from BaseProcess); 'run'=3 chars is the shortest method name in this spec; NEW in extra109: first standalone Process.run qualname length invariant in mpprocess109 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: multiprocessing.Process.run.__qualname__.__len__
  args: []
  expected: 15

invariant multiprocessing_extra109.Process_base_is_BaseProcess:
  description: "multiprocessing.Process.__bases__[0].__name__.__eq__('BaseProcess') returns True — Process inherits from BaseProcess (MRO=[Process, BaseProcess, object], length=3); all Process methods (start, join, terminate, kill, is_alive, run, close) are actually defined on BaseProcess — their qualnames use 'BaseProcess.' prefix; multiprocessing.Process.__name__=='Process' (len=7); multiprocessing.Process.__module__=='multiprocessing.context'; compare: multiprocessing.Process.__mro__.__len__()==3 (has BaseProcess layer) vs multiprocessing.queues.Queue.__mro__.__len__()==2 (from prior specs — Queue inherits directly from object); Process.__bases__[0].__name__=='BaseProcess' distinguishes Process from the queue classes; BaseProcess contains all the core process lifecycle logic; Process is a thin concrete class that adapts to the platform start method; NEW in extra109: first standalone Process base invariant in mpprocess109 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.Process.__bases__[0].__name__.__eq__"
  args: ["BaseProcess"]
  expected: true

invariant multiprocessing_extra109.Process_is_alive_qualname_len_20:
  description: "multiprocessing.Process.is_alive.__qualname__.__len__() == 20 — 'BaseProcess.is_alive' = 'BaseProcess.'=12 + 'is_alive'=8 = 20; compare: run=15 (shortest) < join=kill=16 < start=close=17 < is_alive=20 < terminate=21 (longest); Process.is_alive.__code__.co_argcount==1 (self only); Process.is_alive returns True if the process is alive (started and not yet terminated); is_alive qualname len=20 is the second longest after terminate=21; 'is_alive'=8 chars is the second longest method name (after 'terminate'=9); Process.kill has same qualname len=16 as join but different co_argcount (kill=1, join=2); asyncio.Condition.notify_all qualname len=20 from extra110 — coincidental tie with Process.is_alive=20; NEW in extra109: first standalone Process.is_alive qualname length invariant in mpprocess109 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: multiprocessing.Process.is_alive.__qualname__.__len__
  args: []
  expected: 20

