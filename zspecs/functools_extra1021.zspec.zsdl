spec: functools_extra1021
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks functools class __weakref__ descriptor identity, reduce __self__ class, and module-level attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1021.weakref_descriptor_classes:
  description: "functools class __weakref__.__class__.__name__ is 'getset_descriptor'"
  kind: python_call_eq
  category: weakref_descriptor
  id_prefix: ft1021wd
  columns: [id, function, args, expected]
  rows:
    - [ft1021wd001, functools.partial.__weakref__.__class__.__name__.__eq__,         ["getset_descriptor"], true]
    - [ft1021wd002, functools.partialmethod.__weakref__.__class__.__name__.__eq__,   ["getset_descriptor"], true]
    - [ft1021wd003, functools.cached_property.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [ft1021wd004, functools.singledispatch.__weakref__.__class__.__name__.__eq__,  ["getset_descriptor"], true]
    - [ft1021wd005, functools.lru_cache.__weakref__.__class__.__name__.__eq__,       ["getset_descriptor"], true]

table functools_extra1021.reduce_self_class:
  description: "functools.reduce is a builtin; __self__.__class__.__name__ == 'module'"
  kind: python_call_eq
  category: reduce_self
  id_prefix: ft1021rs
  columns: [id, function, args, expected]
  rows:
    - [ft1021rs001, functools.reduce.__self__.__class__.__name__.__eq__, ["module"], true]
    - [ft1021rs002, functools.reduce.__module__.__eq__,                  ["_functools"], true]
    - [ft1021rs003, functools.reduce.__class__.__name__.__eq__,          ["builtin_function_or_method"], true]
    - [ft1021rs004, functools.reduce.__name__.__eq__,                    ["reduce"], true]
    - [ft1021rs005, functools.reduce.__qualname__.__eq__,                ["reduce"], true]

table functools_extra1021.module_builtins:
  description: "functools module __builtins__ and top-level attribute class names"
  kind: python_call_eq
  category: module_builtins
  id_prefix: ft1021mb
  columns: [id, function, args, expected]
  rows:
    - [ft1021mb001, functools.__builtins__.__class__.__name__.__eq__,          ["dict"],  true]
    - [ft1021mb002, functools.__name__.__eq__,                                 ["functools"], true]
    - [ft1021mb003, functools.__spec__.__class__.__name__.__eq__,              ["ModuleSpec"], true]
    - [ft1021mb004, functools.__loader__.__class__.__name__.__eq__,            ["SourceFileLoader"], true]
    - [ft1021mb005, functools.partial.__class__.__name__.__eq__,               ["type"], true]
    - [ft1021mb006, functools.cached_property.__class__.__name__.__eq__,       ["type"], true]
    - [ft1021mb007, functools.singledispatch.__class__.__name__.__eq__,        ["function"], true]
