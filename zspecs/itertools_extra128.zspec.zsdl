invariant itertools_extra128.islice_iter_qualname:
  description: "itertools.islice.__iter__.__qualname__ == 'islice.__iter__' — wrapper_descriptor slot qualname (len 15); wave 260; new to extra128"
  kind: python_call_eq
  function: islice.__iter__.__qualname__.__eq__
  args: ["islice.__iter__"]
  expected: true

invariant itertools_extra128.islice_next_qualname:
  description: "itertools.islice.__next__.__qualname__ == 'islice.__next__' — wrapper_descriptor slot qualname (len 15); wave 260; new to extra128"
  kind: python_call_eq
  function: islice.__next__.__qualname__.__eq__
  args: ["islice.__next__"]
  expected: true

invariant itertools_extra128.islice_new_class_name:
  description: "itertools.islice.__new__.__class__.__name__ == 'builtin_function_or_method' — __new__ is builtin_function_or_method on C types; wave 260; new to extra128"
  kind: python_call_eq
  function: islice.__new__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra128.islice_mro_len:
  description: "len(itertools.islice.__mro__) == 2 — MRO is [islice, object]; wave 260; new to extra128"
  kind: python_call_eq
  function: islice.__mro__.__len__
  args: []
  expected: 2

invariant itertools_extra128.islice_name:
  description: "itertools.islice.__name__ == 'islice' — C extension type name from PyTypeObject; wave 260; new to extra128"
  kind: python_call_eq
  function: islice.__name__.__eq__
  args: ["islice"]
  expected: true

