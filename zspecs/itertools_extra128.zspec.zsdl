# ---------------------------------------------------------------------------
# Table 1: itertools.islice iterator protocol slot qualnames
#
# Wave 260 theme: itertools.islice __iter__ and __next__ slot qualnames.
#
# itertools.islice.__iter__.__qualname__.__eq__('islice.__iter__') == True
# len(itertools.islice.__iter__.__qualname__) == 15
# itertools.islice.__next__.__qualname__.__eq__('islice.__next__') == True
# len(itertools.islice.__next__.__qualname__) == 15
# itertools.islice.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True
# itertools.islice.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True
#
# islice is a C extension type implementing the iterator protocol.
# __iter__ and __next__ are wrapper_descriptor objects; their __qualname__
# is 'islice.__iter__' and 'islice.__next__' respectively (both length 15).
# New to extra128.
# ---------------------------------------------------------------------------

table itertools_extra128.islice_iter_next_qualnames:
  description: "itertools.islice __iter__/__next__ __qualname__ (len 15) and __class__.__name__ == 'wrapper_descriptor'; wave 260; new to extra128"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsislice128

  columns: [id, function, args, expected, description]
  rows:
    - [islice_iter_qualname_eq,
       "islice.__iter__.__qualname__.__eq__",
       ["islice.__iter__"],
       true,
       "itertools.islice.__iter__.__qualname__.__eq__('islice.__iter__') == True — islice is a C extension type; __iter__ is a wrapper_descriptor slot whose __qualname__ includes the type name as a dotted prefix; str.__eq__('islice.__iter__') returns True; new to extra128"]
    - [islice_iter_qualname_len_eq_15,
       "islice.__iter__.__qualname__.__len__",
       [],
       15,
       "itertools.islice.__iter__.__qualname__.__len__() == 15 — __qualname__ is 'islice.__iter__' which has 15 characters; len('islice.__iter__') == 15; new to extra128"]
    - [islice_next_qualname_eq,
       "islice.__next__.__qualname__.__eq__",
       ["islice.__next__"],
       true,
       "itertools.islice.__next__.__qualname__.__eq__('islice.__next__') == True — __next__ is a wrapper_descriptor slot on the C extension type; its __qualname__ is 'islice.__next__'; str.__eq__('islice.__next__') returns True; new to extra128"]
    - [islice_next_qualname_len_eq_15,
       "islice.__next__.__qualname__.__len__",
       [],
       15,
       "itertools.islice.__next__.__qualname__.__len__() == 15 — __qualname__ is 'islice.__next__' which has 15 characters; len('islice.__next__') == 15; new to extra128"]
    - [islice_iter_class_name_eq_wrapper_descriptor,
       "islice.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.islice.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — when accessed on the C extension type, __iter__ is a wrapper_descriptor (the CPython internal type for C-level tp_iter slots); __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra128"]
    - [islice_next_class_name_eq_wrapper_descriptor,
       "islice.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.islice.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — __next__ accessed on the C extension type is a wrapper_descriptor (CPython internal type for tp_iternext slots); __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra128"]

# ---------------------------------------------------------------------------
# Table 2: itertools.islice __new__ qualname and class identity
#
# Wave 260 theme: itertools.islice __new__ slot identity.
#
# itertools.islice.__new__.__qualname__.__eq__('islice.__new__') == True
# len(itertools.islice.__new__.__qualname__) == 14
# itertools.islice.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True
# itertools.islice.__class__.__name__.__eq__('type') == True
# itertools.islice.__module__.__eq__('itertools') == True
#
# __new__ on a C extension type is a builtin_function_or_method (not a
# wrapper_descriptor); its qualname is 'islice.__new__' (len 14).
# New to extra128.
# ---------------------------------------------------------------------------

table itertools_extra128.islice_new_identity:
  description: "itertools.islice __new__ qualname (len 14) and __class__.__name__ 'builtin_function_or_method'; type identity __class__.__name__ and __module__; wave 260; new to extra128"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsislice128

  columns: [id, function, args, expected, description]
  rows:
    - [islice_new_qualname_eq,
       "islice.__new__.__qualname__.__eq__",
       ["islice.__new__"],
       true,
       "itertools.islice.__new__.__qualname__.__eq__('islice.__new__') == True — __new__ on the C extension type has a __qualname__ of 'islice.__new__'; str.__eq__('islice.__new__') returns True; new to extra128"]
    - [islice_new_qualname_len_eq_14,
       "islice.__new__.__qualname__.__len__",
       [],
       14,
       "itertools.islice.__new__.__qualname__.__len__() == 14 — __qualname__ is 'islice.__new__' which has 14 characters; len('islice.__new__') == 14; new to extra128"]
    - [islice_new_class_name_eq_builtin,
       "islice.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.islice.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — unlike __iter__ and __next__ which are wrapper_descriptors, __new__ on a C extension type is a builtin_function_or_method; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra128"]
    - [islice_class_name_eq_type,
       "islice.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.islice.__class__.__name__.__eq__('type') == True — itertools.islice is a C extension type defined in Modules/itertoolsmodule.c; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra128"]
    - [islice_module_eq_itertools,
       "islice.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.islice.__module__.__eq__('itertools') == True — islice is a C extension type in Modules/itertoolsmodule.c; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra128"]

# ---------------------------------------------------------------------------
# Table 3: itertools.islice __name__, __qualname__, and __mro__ length
#
# Wave 260 theme: itertools.islice class name and MRO identity.
#
# itertools.islice.__name__.__eq__('islice') == True
# len(itertools.islice.__name__) == 6
# itertools.islice.__qualname__.__eq__('islice') == True
# len(itertools.islice.__qualname__) == 6
# len(itertools.islice.__mro__) == 2
#
# islice is a C extension type; its __name__ and __qualname__ are both
# 'islice'; MRO is [islice, object] (length 2). New to extra128.
# ---------------------------------------------------------------------------

table itertools_extra128.islice_name_mro:
  description: "itertools.islice __name__=='islice' (len 6), __qualname__=='islice' (len 6), __mro__ len==2; wave 260; new to extra128"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsislice128

  columns: [id, function, args, expected, description]
  rows:
    - [islice_name_eq,
       "islice.__name__.__eq__",
       ["islice"],
       true,
       "itertools.islice.__name__.__eq__('islice') == True — the __name__ attribute of the C extension type is 'islice', matching the tp_name field in the PyTypeObject; str.__eq__('islice') returns True; new to extra128"]
    - [islice_name_len_eq_6,
       "islice.__name__.__len__",
       [],
       6,
       "itertools.islice.__name__.__len__() == 6 — __name__ is 'islice' which has 6 characters; len('islice') == 6; new to extra128"]
    - [islice_qualname_eq,
       "islice.__qualname__.__eq__",
       ["islice"],
       true,
       "itertools.islice.__qualname__.__eq__('islice') == True — islice is a top-level C extension type; __qualname__ equals the simple type name 'islice'; str.__eq__('islice') returns True; new to extra128"]
    - [islice_qualname_len_eq_6,
       "islice.__qualname__.__len__",
       [],
       6,
       "itertools.islice.__qualname__.__len__() == 6 — __qualname__ is 'islice' which has 6 characters; len('islice') == 6; new to extra128"]
    - [islice_mro_len_eq_2,
       "islice.__mro__.__len__",
       [],
       2,
       "itertools.islice.__mro__.__len__() == 2 — the MRO of islice is [islice, object]; as a C extension type inheriting directly from object it has exactly two MRO entries; len(__mro__) is 2; new to extra128"]

