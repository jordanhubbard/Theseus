spec: multiprocessing_extra2506
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Theme: __add__, __sub__, __mul__ arithmetic operator dict-presence checks."
    - "multiprocessing.Process and multiprocessing.Queue define no arithmetic operators."
    - "__dict__.__contains__ returns False for __add__, __sub__, __mul__ on both classes."
    - "multiprocessing.Queue is actually multiprocessing.queues.Queue; accessed via multiprocessing.Queue."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process — arithmetic operator dict-presence
# ---------------------------------------------------------------------------

table multiprocessing_extra2506.process_arith_ops:
  description: "multiprocessing.Process.__dict__ contains no arithmetic operators (__add__, __sub__, __mul__); all __dict__.__contains__ calls return False; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_presence
  id_prefix: mp2506

  columns: [id, function, args, expected]
  rows:
    - ["mp2506001", multiprocessing.Process.__dict__.__contains__, ["__add__"], false]
    - ["mp2506002", multiprocessing.Process.__dict__.__contains__, ["__sub__"], false]
    - ["mp2506003", multiprocessing.Process.__dict__.__contains__, ["__mul__"], false]

