spec: socket_extra187
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra186.zspec.zsdl — prior extras."
  notes:
    - "socket.__name__ == 'socket' — len=6; the module's own __name__."
    - "socket.__package__ == '' — empty string; socket is a top-level module, no package."
    - "socket.create_connection.__name__ == 'create_connection' — len=17; pure Python in Lib/socket.py."
    - "socket.create_connection.__module__ == 'socket' — defined in the socket module."
    - "socket.create_server.__name__ == 'create_server' — len=13; added in Python 3.8; pure Python."
    - "socket.create_server.__module__ == 'socket' — defined in the socket module."
    - "socket.getfqdn.__name__ == 'getfqdn' — len=7; fully qualified domain name lookup."
    - "socket.getfqdn.__module__ == 'socket' — defined in the socket module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket module-level name and package identity
#
# socket.__name__    == 'socket'   (len=6)
# socket.__package__ == ''         (empty string; top-level module)
#
# The socket module is a mixed C/Python module: the Python layer lives in
# Lib/socket.py and imports _socket (C extension).  Its __name__ is 'socket'
# and __package__ is the empty string, not None, because socket is a pure
# top-level module with no sub-package hierarchy.
# ---------------------------------------------------------------------------

table socket_extra187.module_name_package:
  description: "socket module __name__ and __package__ identity; new to extra187"
  kind: python_call_eq
  category: identity
  id_prefix: socketmodule187

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,
       socket.__name__.__eq__,
       ["socket"],
       true,
       "socket.__name__.__eq__('socket') == True — module name; len=6; new to extra187"]
    - [mod_name_len,
       socket.__name__.__len__,
       [],
       6,
       "socket.__name__.__len__() == 6 — 'socket' has 6 characters; new to extra187"]
    - [mod_pkg_eq,
       socket.__package__.__eq__,
       [""],
       true,
       "socket.__package__.__eq__('') == True — top-level module; __package__ is empty string; new to extra187"]
    - [mod_pkg_len,
       socket.__package__.__len__,
       [],
       0,
       "socket.__package__.__len__() == 0 — empty string has 0 characters; new to extra187"]

# ---------------------------------------------------------------------------
# Table 2: socket.create_connection and socket.create_server name identity
#
# socket.create_connection.__name__   == 'create_connection'  (len=17)
# socket.create_connection.__module__ == 'socket'             (len=6)
# socket.create_server.__name__       == 'create_server'      (len=13)
# socket.create_server.__module__     == 'socket'             (len=6)
#
# Both are pure Python convenience functions defined in Lib/socket.py.
# create_connection has been present since Python 2.6; create_server was
# added in Python 3.8 to simplify server socket setup.
# ---------------------------------------------------------------------------

table socket_extra187.create_functions_identity:
  description: "socket.create_connection and create_server name and module identity; new to extra187"
  kind: python_call_eq
  category: identity
  id_prefix: socketmodule187

  columns: [id, function, args, expected, description]
  rows:
    - [create_conn_name_eq,
       socket.create_connection.__name__.__eq__,
       ["create_connection"],
       true,
       "socket.create_connection.__name__.__eq__('create_connection') == True — convenience function name; len=17; new to extra187"]
    - [create_conn_name_len,
       socket.create_connection.__name__.__len__,
       [],
       17,
       "socket.create_connection.__name__.__len__() == 17 — 'create_connection' has 17 characters; new to extra187"]
    - [create_conn_module_eq,
       socket.create_connection.__module__.__eq__,
       ["socket"],
       true,
       "socket.create_connection.__module__.__eq__('socket') == True — defined in Lib/socket.py; new to extra187"]
    - [create_serv_name_eq,
       socket.create_server.__name__.__eq__,
       ["create_server"],
       true,
       "socket.create_server.__name__.__eq__('create_server') == True — convenience function name; len=13; Python 3.8+; new to extra187"]
    - [create_serv_name_len,
       socket.create_server.__name__.__len__,
       [],
       13,
       "socket.create_server.__name__.__len__() == 13 — 'create_server' has 13 characters; new to extra187"]
    - [create_serv_module_eq,
       socket.create_server.__module__.__eq__,
       ["socket"],
       true,
       "socket.create_server.__module__.__eq__('socket') == True — defined in Lib/socket.py; new to extra187"]

# ---------------------------------------------------------------------------
# Table 3: socket.getfqdn name and module identity
#
# socket.getfqdn.__name__   == 'getfqdn'   (len=7)
# socket.getfqdn.__module__ == 'socket'    (len=6)
#
# getfqdn returns the fully qualified domain name for the given host.
# It is a pure Python function in Lib/socket.py.  The name 'getfqdn'
# is 7 characters — shorter than create_server (13) and create_connection (17).
# ---------------------------------------------------------------------------

table socket_extra187.getfqdn_identity:
  description: "socket.getfqdn name and module identity; new to extra187"
  kind: python_call_eq
  category: identity
  id_prefix: socketmodule187

  columns: [id, function, args, expected, description]
  rows:
    - [getfqdn_name_eq,
       socket.getfqdn.__name__.__eq__,
       ["getfqdn"],
       true,
       "socket.getfqdn.__name__.__eq__('getfqdn') == True — FQDN lookup function name; len=7; new to extra187"]
    - [getfqdn_name_len,
       socket.getfqdn.__name__.__len__,
       [],
       7,
       "socket.getfqdn.__name__.__len__() == 7 — 'getfqdn' has 7 characters; new to extra187"]
    - [getfqdn_module_eq,
       socket.getfqdn.__module__.__eq__,
       ["socket"],
       true,
       "socket.getfqdn.__module__.__eq__('socket') == True — defined in Lib/socket.py; len=6; new to extra187"]
    - [getfqdn_module_len,
       socket.getfqdn.__module__.__len__,
       [],
       6,
       "socket.getfqdn.__module__.__len__() == 6 — 'socket' has 6 characters; new to extra187"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra187
# ---------------------------------------------------------------------------

invariant socket_extra187.module_name_is_socket:
  description: "socket.__name__ == 'socket' — module name; len=6; new to extra187"
  category: identity
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra187.module_package_is_empty:
  description: "socket.__package__ == '' — top-level module; empty string not None; new to extra187"
  category: identity
  kind: python_call_eq
  function: socket.__package__.__eq__
  args: [""]
  expected: true

invariant socket_extra187.create_connection_name:
  description: "socket.create_connection.__name__ == 'create_connection' — convenience function; len=17; new to extra187"
  category: identity
  kind: python_call_eq
  function: socket.create_connection.__name__.__eq__
  args: ["create_connection"]
  expected: true

invariant socket_extra187.create_connection_module:
  description: "socket.create_connection.__module__ == 'socket' — defined in Lib/socket.py; new to extra187"
  category: identity
  kind: python_call_eq
  function: socket.create_connection.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra187.create_server_name:
  description: "socket.create_server.__name__ == 'create_server' — Python 3.8+ convenience function; len=13; new to extra187"
  category: identity
  kind: python_call_eq
  function: socket.create_server.__name__.__eq__
  args: ["create_server"]
  expected: true

invariant socket_extra187.create_server_module:
  description: "socket.create_server.__module__ == 'socket' — defined in Lib/socket.py; new to extra187"
  category: identity
  kind: python_call_eq
  function: socket.create_server.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra187.getfqdn_name:
  description: "socket.getfqdn.__name__ == 'getfqdn' — FQDN lookup function; len=7; new to extra187"
  category: identity
  kind: python_call_eq
  function: socket.getfqdn.__name__.__eq__
  args: ["getfqdn"]
  expected: true

invariant socket_extra187.getfqdn_module:
  description: "socket.getfqdn.__module__ == 'socket' — defined in Lib/socket.py; len=6; new to extra187"
  category: identity
  kind: python_call_eq
  function: socket.getfqdn.__module__.__eq__
  args: ["socket"]
  expected: true
