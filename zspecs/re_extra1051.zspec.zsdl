spec: re_extra1051
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module class and flag documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.Pattern, re.Match, re.error __init_subclass__ qualnames, RegexFlag module identity, and flag __int__ qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1051.init_subclass_qualnames:
  description: "re class __init_subclass__.__qualname__ identity (should equal object.__init_subclass__)"
  kind: python_call_eq
  category: init_subclass_qualnames
  id_prefix: re1051x
  columns: [id, function, args, expected]
  rows:
    - [re1051x001, re.Pattern.__init_subclass__.__qualname__.__eq__, ["object.__init_subclass__"], true]
    - [re1051x002, re.Match.__init_subclass__.__qualname__.__eq__,   ["object.__init_subclass__"], true]
    - [re1051x003, re.error.__init_subclass__.__qualname__.__eq__,   ["object.__init_subclass__"], true]

table re_extra1051.regexflag_module_identity:
  description: "re.RegexFlag module identity and flag __int__ qualname checks"
  kind: python_call_eq
  category: regexflag_module_identity
  id_prefix: re1051f
  columns: [id, function, args, expected]
  rows:
    - [re1051f001, re.RegexFlag.__module__.__eq__,                 ["re"],                  true]
    - [re1051f002, re.IGNORECASE.__int__.__qualname__.__eq__,      ["int.__int__"],          true]
    - [re1051f003, re.MULTILINE.__int__.__qualname__.__eq__,       ["int.__int__"],          true]
    - [re1051f004, re.DOTALL.__int__.__qualname__.__eq__,          ["int.__int__"],          true]
    - [re1051f005, re.VERBOSE.__int__.__qualname__.__eq__,         ["int.__int__"],          true]
    - [re1051f006, re.UNICODE.__int__.__qualname__.__eq__,         ["int.__int__"],          true]
    - [re1051f007, re.ASCII.__int__.__qualname__.__eq__,           ["int.__int__"],          true]

table re_extra1051.class_name_identity:
  description: "re class __name__ and __module__ identity checks"
  kind: python_call_eq
  category: class_name_identity
  id_prefix: re1051n
  columns: [id, function, args, expected]
  rows:
    - [re1051n001, re.Pattern.__name__.__eq__,         ["Pattern"],   true]
    - [re1051n002, re.Match.__name__.__eq__,           ["Match"],     true]
    - [re1051n003, re.error.__name__.__eq__,           ["error"],     true]
    - [re1051n004, re.RegexFlag.__name__.__eq__,       ["RegexFlag"], true]
    - [re1051n005, re.error.__module__.__eq__,         ["re"],        true]
    - [re1051n006, re.RegexFlag.__qualname__.__eq__,   ["RegexFlag"], true]
    - [re1051n007, re.error.__qualname__.__eq__,       ["error"],     true]
