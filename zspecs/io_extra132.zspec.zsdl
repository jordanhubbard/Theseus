spec: io_extra132
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bufferedio.c"
  notes:
    - "This spec covers: io module-level constants and open()/open_code() function identity."
    - "io.DEFAULT_BUFFER_SIZE is an int. On this system its value is 131072 (128 KiB), not 8192."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — it is a plain Python int."
    - "io.open.__class__.__name__ == 'builtin_function_or_method' — open() is a C builtin, not a Python function."
    - "io.open.__module__ == '_io' — open is defined in the private C extension module _io."
    - "io.open.__qualname__ == 'open' — the qualname is just 'open' (no class prefix)."
    - "io.open_code.__class__.__name__ == 'builtin_function_or_method' — open_code() is also a C builtin."
    - "io.open_code.__module__ == '_io' — open_code is defined in _io."
    - "io.open_code.__qualname__ == 'open_code' — qualname is 'open_code'."
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2 — standard POSIX seek mode constants."
    - "io.SEEK_SET.__class__.__name__ == 'int' — all three SEEK constants are plain ints."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io module-level integer constants: DEFAULT_BUFFER_SIZE and SEEK_* values
# DEFAULT_BUFFER_SIZE is a plain int (value 131072 on this system).
# SEEK_SET == 0, SEEK_CUR == 1, SEEK_END == 2; all are plain ints.
# ---------------------------------------------------------------------------

table io_extra132.integer_constants:
  description: "io module integer constants: DEFAULT_BUFFER_SIZE class name, SEEK_SET/SEEK_CUR/SEEK_END values and class names"
  kind: python_call_eq
  category: module_constants
  id_prefix: ioconstants132

  columns: [id, function, args, expected, description]
  rows:
    - [dbs_cls_int,    DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"], true,  "DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' (it is a plain Python integer)"]
    - [dbs_val_eq,     DEFAULT_BUFFER_SIZE.__eq__,                   [131072], true, "DEFAULT_BUFFER_SIZE == 131072 on this system (128 KiB)"]
    - [dbs_not_8192,   DEFAULT_BUFFER_SIZE.__eq__,                   [8192],  false, "DEFAULT_BUFFER_SIZE != 8192 on this system"]
    - [seek_set_eq_0,  SEEK_SET.__eq__,                              [0],     true,  "io.SEEK_SET == 0 (standard POSIX seek-from-start constant)"]
    - [seek_cur_eq_1,  SEEK_CUR.__eq__,                              [1],     true,  "io.SEEK_CUR == 1 (seek relative to current position)"]
    - [seek_end_eq_2,  SEEK_END.__eq__,                              [2],     true,  "io.SEEK_END == 2 (seek relative to end of file)"]
    - [seek_set_cls,   SEEK_SET.__class__.__name__.__eq__,           ["int"], true,  "io.SEEK_SET.__class__.__name__ == 'int'"]
    - [seek_cur_cls,   SEEK_CUR.__class__.__name__.__eq__,           ["int"], true,  "io.SEEK_CUR.__class__.__name__ == 'int'"]
    - [seek_end_cls,   SEEK_END.__class__.__name__.__eq__,           ["int"], true,  "io.SEEK_END.__class__.__name__ == 'int'"]

# ---------------------------------------------------------------------------
# io.open() function identity: class name, __module__, __qualname__
# io.open is a builtin from _io (the C extension module).
# __class__.__name__ == 'builtin_function_or_method'.
# __module__ == '_io' (not 'io').
# __qualname__ == 'open'.
# ---------------------------------------------------------------------------

table io_extra132.open_function_identity:
  description: "io.open function identity: __class__.__name__, __module__, __qualname__"
  kind: python_call_eq
  category: function_identity
  id_prefix: ioconstants132

  columns: [id, function, args, expected, description]
  rows:
    - [open_cls_eq,      open.__class__.__name__.__eq__, ["builtin_function_or_method"], true,  "io.open.__class__.__name__ == 'builtin_function_or_method' (it is a C builtin)"]
    - [open_cls_not_fn,  open.__class__.__name__.__eq__, ["function"],                  false, "io.open.__class__.__name__ != 'function' (not a Python-level function)"]
    - [open_mod_eq,      open.__module__.__eq__,         ["_io"],                       true,  "io.open.__module__ == '_io' (defined in the private C extension module)"]
    - [open_mod_not_io,  open.__module__.__eq__,         ["io"],                        false, "io.open.__module__ != 'io' (the Python wrapper module)"]
    - [open_qname_eq,    open.__qualname__.__eq__,       ["open"],                      true,  "io.open.__qualname__ == 'open' (bare name, no class prefix)"]
    - [open_qname_len,   open.__qualname__.__len__,      [],                            4,     "io.open.__qualname__.__len__() == 4 ('open' has 4 characters)"]

# ---------------------------------------------------------------------------
# io.open_code() function identity: class name, __module__, __qualname__
# Like io.open, open_code is a C builtin from _io.
# __qualname__ == 'open_code'.
# ---------------------------------------------------------------------------

table io_extra132.open_code_function_identity:
  description: "io.open_code function identity: __class__.__name__, __module__, __qualname__"
  kind: python_call_eq
  category: function_identity
  id_prefix: ioconstants132

  columns: [id, function, args, expected, description]
  rows:
    - [opc_cls_eq,      open_code.__class__.__name__.__eq__, ["builtin_function_or_method"], true,  "io.open_code.__class__.__name__ == 'builtin_function_or_method'"]
    - [opc_cls_not_fn,  open_code.__class__.__name__.__eq__, ["function"],                  false, "io.open_code is not a Python-level function"]
    - [opc_mod_eq,      open_code.__module__.__eq__,         ["_io"],                       true,  "io.open_code.__module__ == '_io'"]
    - [opc_qname_eq,    open_code.__qualname__.__eq__,       ["open_code"],                 true,  "io.open_code.__qualname__ == 'open_code'"]
    - [opc_qname_len,   open_code.__qualname__.__len__,      [],                            9,     "io.open_code.__qualname__.__len__() == 9 ('open_code' has 9 characters)"]
    - [opc_qname_neq,   open_code.__qualname__.__eq__,       ["open"],                      false, "io.open_code.__qualname__ != 'open' (different from io.open)"]
    - [opc_mod_neq,     open_code.__module__.__eq__,         ["io"],                        false, "io.open_code.__module__ != 'io'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra132.DEFAULT_BUFFER_SIZE.class_is_int:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' (the buffer size constant is a plain Python integer, not a C-level enum or named type)"
  category: module_constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra132.SEEK_SET.equals_zero:
  description: "io.SEEK_SET == 0 (SEEK_SET is the standard POSIX seek-from-beginning-of-file constant, numerically 0)"
  category: module_constants
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra132.SEEK_END.equals_two:
  description: "io.SEEK_END == 2 (SEEK_END is the seek-from-end-of-file constant, numerically 2)"
  category: module_constants
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true

invariant io_extra132.open.module_is_underscore_io:
  description: "io.open.__module__ == '_io' (open() is a C builtin implemented in the private _io extension module, not in the public Python io wrapper)"
  category: function_identity
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra132.open_code.qualname_is_open_code:
  description: "io.open_code.__qualname__ == 'open_code' (the qualname is the bare function name 'open_code', length 9)"
  category: function_identity
  kind: python_call_eq
  function: open_code.__qualname__.__eq__
  args: ["open_code"]
  expected: true

