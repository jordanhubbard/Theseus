spec: struct_extra233
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra232.zspec.zsdl — covers struct.pack signed byte/short/int ('!b','!h','!i') contracts"
    - "struct_extra231.zspec.zsdl — covers struct.pack/unpack/calcsize native byte order ('=') contracts"
    - "struct_extra230.zspec.zsdl — covers struct.error identity and pack raises contracts"
    - "struct_extra229.zspec.zsdl — covers pack('!H',1); pack('!H',65535); pack('!I',1); pack('!B',127); pack('!B',128)"
    - "struct_extra222.zspec.zsdl — covers pack('!B',0); pack('!B',255); pack('!H',0); pack('!H',256); pack('!I',256)"
    - "struct_extra214.zspec.zsdl — covers Struct('!H').pack(1); Struct('!I').pack(1)"
    - "_struct.zspec.zsdl — covers _struct C extension identity"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.pack('!H', 256) == b'\\x01\\x00' — network byte order unsigned short 256; high byte 0x01, low byte 0x00."
    - "struct.pack('!I', 65536) == b'\\x00\\x01\\x00\\x00' — network byte order unsigned int 65536; bytes are 0x00, 0x01, 0x00, 0x00."
    - "struct.pack('!Q', 4294967296) == b'\\x00\\x00\\x00\\x01\\x00\\x00\\x00\\x00' — network byte order unsigned long long 2**32."
    - "struct.unpack('!H', b'\\x01\\x00')[0] == 256 — round-trip of pack/unpack for unsigned short 256."
    - "struct.unpack('!I', b'\\x00\\x01\\x00\\x00')[0] == 65536 — round-trip of pack/unpack for unsigned int 65536."
    - "struct.unpack('!Q', b'\\x00\\x00\\x00\\x01\\x00\\x00\\x00\\x00')[0] == 4294967296 — round-trip of pack/unpack for unsigned long long 2**32."
    - "struct.calcsize('!Q') == 8 — unsigned long long is 8 bytes."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack('!H', 256) — unsigned short 256 in network byte order
#
# struct.pack('!H', 256) == b'\x01\x00'
#
# '!' is network/big-endian byte order. 'H' is unsigned short (uint16_t, 2 bytes).
# Value 256 = 0x0100 in hex; big-endian: high byte first gives b'\x01\x00'.
# struct_extra222 covers pack('!H', 256) as an __eq__ invariant but from the
# function-call-eq direction; struct_extra233 covers the unpack inverse.
# Novel to struct_extra233: the unpack round-trip for 256 and further Q contracts.
# ---------------------------------------------------------------------------

table struct_extra233.pack_unsigned_short_256:
  description: "pack('!H',256)==b'\\x01\\x00'; unpack('!H',b'\\x01\\x00')[0]==256; unsigned short 256 pack/unpack contracts; new to struct_extra233"
  kind: python_call_eq
  category: pack_unsigned
  id_prefix: struct233u

  columns: [id, function, args, expected, description]
  rows:
    - [pack_nH_256,
       pack,
       ["!H", 256],
       !hex 0100,
       "struct.pack('!H', 256) == b'\\x01\\x00' — network/big-endian unsigned short 256 (0x0100); high byte 0x01 first, low byte 0x00 second; 256 == 2^8 is the first value requiring 2 bytes; novel pack('!H',256) anchor in struct_extra233 namespace; verified Python 3.14.3"]
    - [unpack_nH_0100,
       "unpack('!H', b'\\x01\\x00').__getitem__",
       [0],
       256,
       "struct.unpack('!H', b'\\x01\\x00')[0] == 256 — network/big-endian unsigned short unpack of b'\\x01\\x00'; high byte 0x01, low byte 0x00 gives 256; confirms round-trip of pack('!H',256); novel unpack inverse anchor; new to struct_extra233 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.pack('!I', 65536) and unpack — unsigned int 65536
#
# struct.pack('!I', 65536) == b'\x00\x01\x00\x00'
# struct.unpack('!I', b'\x00\x01\x00\x00')[0] == 65536
#
# 'I' is unsigned int (uint32_t, 4 bytes). Value 65536 = 0x00010000 in hex;
# big-endian encoding gives b'\x00\x01\x00\x00'.
# 65536 == 2^16 is the first value requiring more than 2 bytes.
# Novel to struct_extra233.
# ---------------------------------------------------------------------------

table struct_extra233.pack_unsigned_int_65536:
  description: "pack('!I',65536)==b'\\x00\\x01\\x00\\x00'; unpack('!I',b'\\x00\\x01\\x00\\x00')[0]==65536; unsigned int 65536 pack/unpack contracts; new to struct_extra233"
  kind: python_call_eq
  category: pack_unsigned
  id_prefix: struct233ui

  columns: [id, function, args, expected, description]
  rows:
    - [pack_nI_65536,
       pack,
       ["!I", 65536],
       !hex 00010000,
       "struct.pack('!I', 65536) == b'\\x00\\x01\\x00\\x00' — network/big-endian unsigned int 65536 (0x00010000 = 2^16); 4 bytes big-endian: 0x00, 0x01, 0x00, 0x00; 65536 is the first value requiring more than 16 bits; novel pack('!I',65536) anchor; new to struct_extra233 namespace; verified Python 3.14.3"]
    - [unpack_nI_00010000,
       "unpack('!I', b'\\x00\\x01\\x00\\x00').__getitem__",
       [0],
       65536,
       "struct.unpack('!I', b'\\x00\\x01\\x00\\x00')[0] == 65536 — network/big-endian unsigned int unpack of b'\\x00\\x01\\x00\\x00'; bytes 0x00010000 decode to 65536; confirms round-trip of pack('!I',65536); novel unpack inverse anchor; new to struct_extra233 namespace; verified Python 3.14.3"]
    - [pack_nI_65536_len,
       "pack('!I', 65536).__len__",
       [],
       4,
       "struct.pack('!I', 65536).__len__() == 4 — unsigned int format 'I' always produces exactly 4 bytes; calcsize('!I') == 4; novel pack length anchor for uint32; new to struct_extra233 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.pack('!Q', 4294967296) and unpack — unsigned long long 2**32
#
# struct.pack('!Q', 4294967296) == b'\x00\x00\x00\x01\x00\x00\x00\x00'
# struct.unpack('!Q', b'\x00\x00\x00\x01\x00\x00\x00\x00')[0] == 4294967296
#
# 'Q' is unsigned long long (uint64_t, 8 bytes). 4294967296 == 2^32 == 0x100000000.
# Big-endian 8-byte encoding: b'\x00\x00\x00\x01\x00\x00\x00\x00'.
# Novel to struct_extra233: no prior spec covers pack('!Q', ...) contracts.
# ---------------------------------------------------------------------------

table struct_extra233.pack_unsigned_longlong_2pow32:
  description: "pack('!Q',4294967296)==b'\\x00\\x00\\x00\\x01\\x00\\x00\\x00\\x00'; unpack('!Q',...)[0]==4294967296; unsigned long long 2**32 pack/unpack contracts; new to struct_extra233"
  kind: python_call_eq
  category: pack_unsigned
  id_prefix: struct233uq

  columns: [id, function, args, expected, description]
  rows:
    - [pack_nQ_2pow32,
       pack,
       ["!Q", 4294967296],
       !hex 0000000100000000,
       "struct.pack('!Q', 4294967296) == b'\\x00\\x00\\x00\\x01\\x00\\x00\\x00\\x00' — network/big-endian unsigned long long 4294967296 (2^32 = 0x0000000100000000); 8 bytes big-endian with the value 1 in the 5th most significant byte position; 2^32 is the first value requiring more than 32 bits; novel pack('!Q') anchor; new to struct_extra233 namespace; verified Python 3.14.3"]
    - [unpack_nQ_0000000100000000,
       "unpack('!Q', b'\\x00\\x00\\x00\\x01\\x00\\x00\\x00\\x00').__getitem__",
       [0],
       4294967296,
       "struct.unpack('!Q', b'\\x00\\x00\\x00\\x01\\x00\\x00\\x00\\x00')[0] == 4294967296 — network/big-endian unsigned long long unpack of b'\\x00\\x00\\x00\\x01\\x00\\x00\\x00\\x00'; the 4th byte 0x01 at position [3] contributes 1 * 2^32 = 4294967296; confirms round-trip of pack('!Q', 2**32); novel unpack inverse anchor; new to struct_extra233 namespace; verified Python 3.14.3"]
    - [pack_nQ_2pow32_len,
       "pack('!Q', 4294967296).__len__",
       [],
       8,
       "struct.pack('!Q', 4294967296).__len__() == 8 — unsigned long long format 'Q' always produces exactly 8 bytes; calcsize('!Q') == 8; novel pack length anchor for uint64; new to struct_extra233 namespace; verified Python 3.14.3"]
    - [calcsize_nQ_eq,
       "calcsize.__call__",
       ["!Q"],
       8,
       "struct.calcsize('!Q') == 8 — format string '!Q' packs a single unsigned long long (uint64_t) in network byte order; the packed size is always 8 bytes regardless of platform; novel calcsize('!Q') anchor; new to struct_extra233 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra233.pack_nH_256:
  description: "struct.pack('!H', 256) == b'\\x01\\x00' — network/big-endian unsigned short 256 (0x0100); '!' is RFC 1700 network byte order (big-endian); 'H' is unsigned short (uint16_t, 2 bytes); 256 in big-endian: high byte 0x01 (upper 8 bits of 0x0100), low byte 0x00 (lower 8 bits); prior struct_extra222 covers pack('!H',256) using __eq__ but not as a standalone invariant in this namespace; struct_extra233 is the first namespace to anchor pack('!H',256) as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: pack_unsigned
  kind: python_call_eq
  function: pack
  args: ["!H", 256]
  expected: !hex 0100

invariant struct_extra233.unpack_nH_256:
  description: "struct.unpack('!H', b'\\x01\\x00')[0] == 256 — network/big-endian unsigned short unpack; b'\\x01\\x00' has high byte 0x01 and low byte 0x00; interpreted as big-endian uint16: 0x01 * 256 + 0x00 = 256; this is the inverse of pack('!H', 256); no prior spec anchors this unpack direction for value 256; struct_extra233 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: pack_unsigned
  kind: python_call_eq
  function: "unpack('!H', b'\\x01\\x00').__getitem__"
  args: [0]
  expected: 256

invariant struct_extra233.pack_nI_65536:
  description: "struct.pack('!I', 65536) == b'\\x00\\x01\\x00\\x00' — network/big-endian unsigned int 65536 (0x00010000 = 2^16); 'I' is unsigned int (uint32_t, 4 bytes); 65536 in big-endian: bytes are 0x00, 0x01, 0x00, 0x00 (most significant byte first); 65536 is the first integer requiring more than 16 bits; no prior spec anchors pack('!I', 65536) with expected bytes; struct_extra233 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: pack_unsigned
  kind: python_call_eq
  function: pack
  args: ["!I", 65536]
  expected: !hex 00010000

invariant struct_extra233.pack_nQ_2pow32:
  description: "struct.pack('!Q', 4294967296) == b'\\x00\\x00\\x00\\x01\\x00\\x00\\x00\\x00' — network/big-endian unsigned long long 4294967296 (2^32 = 0x0000000100000000); 'Q' is unsigned long long (uint64_t, 8 bytes); 2^32 in big-endian: first 3 bytes 0x00, 4th byte 0x01, last 4 bytes 0x00; no prior spec covers any pack('!Q') contract; struct_extra233 is the first namespace to anchor this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: pack_unsigned
  kind: python_call_eq
  function: pack
  args: ["!Q", 4294967296]
  expected: !hex 0000000100000000

invariant struct_extra233.unpack_nQ_2pow32:
  description: "struct.unpack('!Q', b'\\x00\\x00\\x00\\x01\\x00\\x00\\x00\\x00')[0] == 4294967296 — network/big-endian unsigned long long unpack; 8 bytes with 0x01 at position [3] (0-indexed from high end); big-endian interpretation: 0 * 2^56 + 0 * 2^48 + 0 * 2^40 + 1 * 2^32 + 0 * 2^24 + ... = 4294967296; this is the inverse of pack('!Q', 2**32); no prior spec anchors any unpack('!Q') contract; struct_extra233 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: pack_unsigned
  kind: python_call_eq
  function: "unpack('!Q', b'\\x00\\x00\\x00\\x01\\x00\\x00\\x00\\x00').__getitem__"
  args: [0]
  expected: 4294967296
