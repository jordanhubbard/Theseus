spec: mri
version: ">=1.0.0"
backend: node(mri)

docs: https://github.com/lukeed/mri#readme

provenance:
  derived_from:
    - "mri README — https://github.com/lukeed/mri#readme"
    - "Test vectors verified with mri via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "mri source"
  notes:
    - "Quick CLI argument parser — alternative to minimist with similar API but ~10x smaller."
    - "Install: npm install mri"
    - "v1 CJS; module export IS the parse function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string array input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant mri.module_is_function:
  description: "Module export is the parse function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant mri.long_flag_with_value:
  description: "mri(['--foo', 'bar']) yields {foo: 'bar'}"
  category: parse
  kind: node_chain_eq
  entry: module
  entry_args: [["--foo", "bar"]]
  chain:
    - {get: foo}
  expected: "bar"

invariant mri.short_flag_boolean:
  description: "mri(['-x']) yields {x: true}"
  category: parse
  kind: node_chain_eq
  entry: module
  entry_args: [["-x"]]
  chain:
    - {get: x}
  expected: true

invariant mri.no_flag_negation:
  description: "mri(['--no-y']) yields {y: false}"
  category: parse
  kind: node_chain_eq
  entry: module
  entry_args: [["--no-y"]]
  chain:
    - {get: y}
  expected: false

invariant mri.positional_in_underscore:
  description: "Positional args go to ._ array"
  category: parse
  kind: node_chain_eq
  entry: module
  entry_args: [["arg1", "arg2"]]
  chain:
    - {get: _}
  expected: ["arg1", "arg2"]

invariant mri.empty_returns_empty_underscore:
  description: "mri([]) yields {_: []}"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [[]]
  chain:
    - {get: _}
  expected: []

invariant mri.combined_args:
  description: "Mixed flags + positional"
  category: parse
  kind: node_chain_eq
  entry: module
  entry_args: [["--foo", "bar", "-x", "--no-y", "arg1"]]
  chain:
    - {get: x}
  expected: true
