spec: heapq_extra24
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
  notes:
    - "This spec extends heapq_extra23.zspec.zsdl."
    - "Prior specs covered: heapq.__name__/__package__, heappush/heappop/heapify/heapreplace/heappushpop/nlargest/nsmallest/merge __name__/__module__, name/qualname/module length tables, __qualname__.__eq__ table (extra21), __module__.__len__() for all 8 classic functions (extra22), __all__.__len__() == 13 (extra23), __qualname__.__len__() table for 8 classics (extra23), __spec__/__loader__ class name lengths (extra23), max-heap variant __name__.__len__() (extra23)."
    - "This spec covers: max-heap variant __qualname__.__len__() table (heappush_max=12, heappop_max=11, heapify_max=11, heapreplace_max=15, heappushpop_max=15); __class__.__name__.__len__() distinguishing C builtins (26) from pure-Python (8); nlargest/__class__.__name__ (function len 8) vs heappush/__class__.__name__ (builtin_function_or_method len 26); heapq.__all__.__class__.__name__.__len__() == 4 ('list'); heapq.__doc__.__class__.__name__.__len__() == 3 ('str')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "heapq.heappush_max.__qualname__.__len__() == 12. Verified."
    - "heapq.heappop_max.__qualname__.__len__() == 11. Verified."
    - "heapq.heapify_max.__qualname__.__len__() == 11. Verified."
    - "heapq.heapreplace_max.__qualname__.__len__() == 15. Verified."
    - "heapq.heappushpop_max.__qualname__.__len__() == 15. Verified."
    - "heapq.heappush.__class__.__name__ == 'builtin_function_or_method', len == 26. Verified."
    - "heapq.nlargest.__class__.__name__ == 'function', len == 8. Verified."
    - "heapq.__all__.__class__.__name__ == 'list', len == 4. Verified."
    - "heapq.__doc__.__class__.__name__ == 'str', len == 3. Verified."
    - "All five max-heap variants satisfy __qualname__ == __name__ (top-level C builtins). Verified."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for the 5 max-heap variants — extra24
#
# Python 3.14 adds heappush_max, heappop_max, heapify_max, heapreplace_max,
# heappushpop_max. All are C builtins from _heapq. For C builtins at module
# level, __qualname__ == __name__, so __qualname__.__len__() == __name__.__len__().
# heapq_extra23 covers __name__.__len__() for these five; this table anchors
# __qualname__.__len__() for the same five in the extra24 namespace.
# Verified: heappush_max=12, heappop_max=11, heapify_max=11,
#           heapreplace_max=15, heappushpop_max=15.
# id_prefix hqmxql24 is novel.
# ---------------------------------------------------------------------------

table heapq_extra24.max_heap_qualname_lens:
  description: "__qualname__.__len__() for the 5 max-heap variant functions — C builtins, qualname equals name"
  kind: python_call_eq
  category: function_qualname
  id_prefix: hqmxql24

  columns: [id, function, method, method_args, expected]
  rows:
    - [heappush_max_ql,    heappush_max.__qualname__,    __len__, [], 12]
    - [heappop_max_ql,     heappop_max.__qualname__,     __len__, [], 11]
    - [heapify_max_ql,     heapify_max.__qualname__,     __len__, [], 11]
    - [heapreplace_max_ql, heapreplace_max.__qualname__, __len__, [], 15]
    - [heappushpop_max_ql, heappushpop_max.__qualname__, __len__, [], 15]

# ---------------------------------------------------------------------------
# Table: __class__.__name__.__len__() — C builtins vs pure-Python callables
#
# C builtins (heappush, heappop, heapify, heapreplace, heappushpop, and all
# max-heap variants) have __class__.__name__ == 'builtin_function_or_method'
# (len 26). Pure-Python callables (nlargest, nsmallest, merge) have
# __class__.__name__ == 'function' (len 8). This table uses representative
# samples from each category to anchor the type-length distinction.
# No prior heapq spec covers __class__.__name__.__len__() for any callable.
# id_prefix hqcnl24 is novel.
# ---------------------------------------------------------------------------

table heapq_extra24.callable_class_name_lens:
  description: "__class__.__name__.__len__() for heapq callables — C builtins give 26, pure-Python give 8"
  kind: python_call_eq
  category: function_type
  id_prefix: hqcnl24

  columns: [id, function, method, method_args, expected]
  rows:
    - [heappush_cn,     heappush.__class__.__name__,     __len__, [], 26]
    - [heappop_cn,      heappop.__class__.__name__,      __len__, [], 26]
    - [heapify_cn,      heapify.__class__.__name__,      __len__, [], 26]
    - [heapreplace_cn,  heapreplace.__class__.__name__,  __len__, [], 26]
    - [heappushpop_cn,  heappushpop.__class__.__name__,  __len__, [], 26]
    - [nlargest_cn,     nlargest.__class__.__name__,     __len__, [], 8]
    - [nsmallest_cn,    nsmallest.__class__.__name__,    __len__, [], 8]
    - [merge_cn,        merge.__class__.__name__,        __len__, [], 8]

# ---------------------------------------------------------------------------
# heapq.__all__.__class__.__name__.__len__() == 4 — len('list') == 4
#
# heapq.__all__ is a list. Its class name 'list' has length 4. No prior heapq
# spec checks __all__.__class__.__name__.__len__(). Complements the
# __all__.__len__() == 13 invariant from heapq_extra23.
# ---------------------------------------------------------------------------

invariant heapq_extra24.all.class_name_len:
  description: "heapq.__all__.__class__.__name__.__len__() == 4 — __all__ is a list; len('list') == 4"
  category: module_all
  kind: python_call_eq
  function: "__all__.__class__.__name__.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# heapq.__doc__.__class__.__name__.__len__() == 3 — len('str') == 3
#
# heapq.__doc__ is a string. Its class name 'str' has length 3. No prior heapq
# spec covers __doc__.__class__.__name__.__len__(). Provides a cross-module
# comparable anchor (the same is true for every Python module with a docstring).
# ---------------------------------------------------------------------------

invariant heapq_extra24.doc.class_name_len:
  description: "heapq.__doc__.__class__.__name__.__len__() == 3 — __doc__ is a str; len('str') == 3"
  category: module_metadata
  kind: python_call_eq
  function: "__doc__.__class__.__name__.__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# heapq.heapreplace_max.__qualname__.__len__() == 15 — standalone anchor
#
# 'heapreplace_max' has 15 characters — the longest qualname among the 5
# max-heap variants (tied with heappushpop_max). Standalone invariant in the
# extra24 namespace. Verified: heapq.heapreplace_max.__qualname__ == 'heapreplace_max'.
# ---------------------------------------------------------------------------

invariant heapq_extra24.heapreplace_max.qualname_len:
  description: "heapq.heapreplace_max.__qualname__.__len__() == 15 — 'heapreplace_max' has 15 characters"
  category: function_qualname
  kind: python_call_eq
  function: heapreplace_max.__qualname__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# heapq.heappushpop_max.__qualname__.__len__() == 15 — standalone anchor
#
# 'heappushpop_max' has 15 characters — tied with heapreplace_max for the
# longest among the max-heap variants. Both names append '_max' (4 chars) to
# 11-character base names (heapreplace, heappushpop). Standalone invariant in
# the extra24 namespace.
# ---------------------------------------------------------------------------

invariant heapq_extra24.heappushpop_max.qualname_len:
  description: "heapq.heappushpop_max.__qualname__.__len__() == 15 — 'heappushpop_max' has 15 characters"
  category: function_qualname
  kind: python_call_eq
  function: heappushpop_max.__qualname__.__len__
  args: []
  expected: 15
