spec: abc_extra1666
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc: Abstract Base Classes"
    - "PEP 3119 — Introducing Abstract Base Classes"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Theme: __new__ — object construction protocol; ABCMeta is the stdlib class that most prominently overrides __new__."
    - "abc.ABCMeta.__dict__.__contains__('__new__') is True — ABCMeta overrides __new__ to collect __abstractmethods__ at class-creation time."
    - "ABCMeta.__new__(mcs, name, bases, namespace) builds the set of abstract method names and stores it as cls.__abstractmethods__; this fires at class definition, not instance construction."
    - "abc.ABCMeta.__dict__.__contains__('__init__') is False — ABCMeta only overrides __new__, not __init__; type.__init__ is used for the metaclass __init__ step."
    - "abc.ABC.__dict__.__contains__('__new__') is False — ABC is a simple helper class with ABCMeta as its metaclass; ABC itself defines no __new__."
    - "abc.ABC.__dict__.__contains__('__init__') is False — ABC defines no __init__; it has no instance state."
    - "abc.abstractmethod.__dict__.__contains__('__new__') is False — abstractmethod is a plain function-wrapping descriptor class with no custom __new__."
    - "object.__dict__.__contains__('__new__') is True — object.__new__ is the root allocator; all Python objects ultimately reach it."
    - "object.__dict__.__contains__('__init__') is True — object.__init__ is the root initialiser."
    - "type.__dict__.__contains__('__new__') is True — type.__new__ creates new type objects; it is the metaclass allocator called when class statements are executed."
    - "type.__dict__.__contains__('__init__') is True — type.__init__ completes type object construction after type.__new__."
    - "ABCMeta inherits from type; ABCMeta.__new__ intercepts class creation to process abstract method markers before delegating to type.__new__."
    - "abc.ABCMeta.__name__ == 'ABCMeta' (len=7); abc.ABC.__name__ == 'ABC' (len=3)."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta is a direct subclass of type."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc_extra1666.abcmeta_has_new
#
# ABCMeta is the key class in the abc module that defines a custom __new__.
# This table verifies __new__ is present and __init__ is absent from ABCMeta.__dict__,
# plus identity and base class checks.
# ---------------------------------------------------------------------------

table abc_extra1666.abcmeta_has_new:
  description: "abc.ABCMeta overrides __new__ to collect abstract method names at class-creation time: ABCMeta.__dict__.__contains__('__new__') is True; ABCMeta.__dict__.__contains__('__init__') is False (only __new__ is customised; type.__init__ handles the __init__ step); ABCMeta.__bases__[0].__name__ == 'type' (ABCMeta is a direct subclass of type); ABCMeta.__name__ == 'ABCMeta' (len=7); verified with Python 3.14.4"
  kind: python_call_eq
  category: abcmeta_new
  id_prefix: ab1666am

  columns: [id, function, args, expected]
  rows:
    - ["ab1666am001", abc.ABCMeta.__dict__.__contains__,                        ["__new__"],    true]
    - ["ab1666am002", abc.ABCMeta.__dict__.__contains__,                        ["__init__"],   false]
    - ["ab1666am003", abc.ABCMeta.__name__.__eq__,                              ["ABCMeta"],    true]
    - ["ab1666am004", abc.ABCMeta.__name__.__len__,                             [],             7]
    - ["ab1666am005", "abc.ABCMeta.__bases__.__getitem__",                      [0],            null]
    - ["ab1666am006", abc.ABCMeta.__dict__.__contains__,                        ["register"],   true]
    - ["ab1666am007", abc.ABCMeta.__dict__.__contains__,                        ["__subclasshook__"], true]
    - ["ab1666am008", abc.ABCMeta.__dict__.__contains__,                        ["__instancecheck__"], true]
    - ["ab1666am009", abc.ABCMeta.__dict__.__contains__,                        ["__subclasscheck__"], true]
    - ["ab1666am010", abc.ABCMeta.__dict__.__contains__,                        ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 2: abc_extra1666.abc_no_new
#
# abc.ABC is the helper class (uses ABCMeta as its metaclass) but defines no
# __new__, no __init__, and no __abstractmethods__ in its own __dict__.
# abc.abstractmethod is a descriptor class with no custom __new__.
# ---------------------------------------------------------------------------

table abc_extra1666.abc_no_new:
  description: "abc.ABC and abc.abstractmethod — no custom __new__ or __init__: ABC is a convenience class that uses ABCMeta as its metaclass; it defines neither __new__ nor __init__ in its own __dict__; abstractmethod is a decorator/descriptor class that stores __isabstractmethod__=True on the wrapped function; neither class needs to customise allocation; verified with Python 3.14.4"
  kind: python_call_eq
  category: abc_no_new
  id_prefix: ab1666an

  columns: [id, function, args, expected]
  rows:
    - ["ab1666an001", abc.ABC.__dict__.__contains__,              ["__new__"],             false]
    - ["ab1666an002", abc.ABC.__dict__.__contains__,              ["__init__"],            false]
    - ["ab1666an003", abc.ABC.__name__.__eq__,                    ["ABC"],                 true]
    - ["ab1666an004", abc.ABC.__name__.__len__,                   [],                      3]
    - ["ab1666an005", abc.abstractmethod.__dict__.__contains__,   ["__new__"],             false]
    - ["ab1666an006", abc.abstractmethod.__dict__.__contains__,   ["__init__"],            true]
    - ["ab1666an007", abc.abstractmethod.__name__.__eq__,         ["abstractmethod"],      true]
    - ["ab1666an008", abc.abstractmethod.__name__.__len__,        [],                      14]
    - ["ab1666an009", abc.ABC.__dict__.__contains__,              ["__doc__"],             true]
    - ["ab1666an010", abc.abstractmethod.__dict__.__contains__,   ["__isabstractmethod__"], false]
    - ["ab1666an011", abc.abstractmethod.__dict__.__contains__,   ["__call__"],            false]
    - ["ab1666an012", abc.abstractmethod.__dict__.__contains__,   ["__get__"],             false]

# ---------------------------------------------------------------------------
# Table 3: abc_extra1666.builtin_type_new_init
#
# object and type are the roots of the Python type hierarchy.
# Both define __new__ and __init__ in their own __dict__.
# These establish the baseline that all custom __new__/__init__ implementations
# ultimately delegate to.
# ---------------------------------------------------------------------------

table abc_extra1666.builtin_type_new_init:
  description: "object and type both define __new__ and __init__ in their own __dict__: object.__new__ is the root allocator (tp_new); object.__init__ is the root initialiser; type.__new__ creates new type objects when class statements are executed; type.__init__ completes type construction; ABCMeta.__new__ overrides type.__new__ in the ABCMeta subclass; all four attributes are True; verified with Python 3.14.4"
  kind: python_call_eq
  category: builtin_type_new_init
  id_prefix: ab1666bt

  columns: [id, function, args, expected]
  rows:
    - ["ab1666bt001", object.__dict__.__contains__,   ["__new__"],    true]
    - ["ab1666bt002", object.__dict__.__contains__,   ["__init__"],   true]
    - ["ab1666bt003", type.__dict__.__contains__,     ["__new__"],    true]
    - ["ab1666bt004", type.__dict__.__contains__,     ["__init__"],   true]
    - ["ab1666bt005", object.__name__.__eq__,         ["object"],     true]
    - ["ab1666bt006", object.__name__.__len__,        [],             6]
    - ["ab1666bt007", type.__name__.__eq__,           ["type"],       true]
    - ["ab1666bt008", type.__name__.__len__,          [],             4]
    - ["ab1666bt009", object.__dict__.__contains__,   ["__doc__"],    true]
    - ["ab1666bt010", type.__dict__.__contains__,     ["__doc__"],    true]
    - ["ab1666bt011", object.__dict__.__contains__,   ["__repr__"],   true]
    - ["ab1666bt012", type.__dict__.__contains__,     ["__repr__"],   true]
    - ["ab1666bt013", object.__dict__.__contains__,   ["__class__"],  true]
    - ["ab1666bt014", type.__dict__.__contains__,     ["__bases__"],  true]
    - ["ab1666bt015", type.__dict__.__contains__,     ["__mro__"],    true]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra1666
# ---------------------------------------------------------------------------

invariant abc_extra1666.abcmeta_new_is_present:
  description: "abc.ABCMeta.__dict__.__contains__('__new__') returns True — ABCMeta overrides __new__(mcs, name, bases, namespace, **kwargs) to process the class namespace before the type is created; it iterates the namespace looking for callables marked with __isabstractmethod__=True, collects them into cls.__abstractmethods__, and then calls super().__new__ (which is type.__new__); the presence of __new__ in ABCMeta.__dict__ is the distinguishing feature of ABCMeta in the stdlib abc module; verified with Python 3.14.4"
  category: abcmeta_new
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__new__"]
  expected: true

invariant abc_extra1666.abcmeta_init_is_absent:
  description: "abc.ABCMeta.__dict__.__contains__('__init__') returns False — ABCMeta only overrides __new__, not __init__; the type.__init__ from its base class handles the metaclass __init__ step; this is the canonical pattern when a metaclass only needs to intercept class creation (which happens in __new__) rather than also intercepting the metaclass instance initialisation (which would require __init__); verified with Python 3.14.4"
  category: abcmeta_init
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__init__"]
  expected: false

invariant abc_extra1666.abc_no_new_helper_class:
  description: "abc.ABC.__dict__.__contains__('__new__') returns False — abc.ABC is a convenience class equivalent to 'class MyABC(metaclass=ABCMeta): pass'; ABC itself defines no __new__; when a user subclasses ABC, the ABCMeta.__new__ fires because ABCMeta is the metaclass, not because ABC defines __new__; this distinction is important: the __new__ that matters is on ABCMeta (the metaclass), not on ABC (the base class); verified with Python 3.14.4"
  category: abc_no_new
  kind: python_call_eq
  function: abc.ABC.__dict__.__contains__
  args: ["__new__"]
  expected: false

invariant abc_extra1666.object_has_new:
  description: "object.__dict__.__contains__('__new__') returns True — object.__new__ is the root allocator in the CPython object model; it is implemented as tp_new in C and exposed as a staticmethod in object.__dict__; all Python classes that do not define __new__ ultimately use object.__new__ for memory allocation; object.__new__ accepts the class as its first argument and returns a fresh, uninitialised instance; verified with Python 3.14.4"
  category: builtin_type_new_init
  kind: python_call_eq
  function: object.__dict__.__contains__
  args: ["__new__"]
  expected: true

invariant abc_extra1666.type_has_new:
  description: "type.__dict__.__contains__('__new__') returns True — type.__new__(mcs, name, bases, namespace) is the metaclass allocator; it fires when a class statement is evaluated; ABCMeta.__new__ intercepts this process in the ABCMeta subclass and calls super().__new__ (i.e. type.__new__) after collecting abstract method names; both type.__new__ and object.__new__ are present in their respective __dict__s; verified with Python 3.14.4"
  category: builtin_type_new_init
  kind: python_call_eq
  function: type.__dict__.__contains__
  args: ["__new__"]
  expected: true

invariant abc_extra1666.abcmeta_is_subclass_of_type:
  description: "abc.ABCMeta.__bases__[0].__name__.__eq__('type') — ABCMeta is a direct subclass of type (not of object); ABCMeta.__bases__ == (<class 'type'>,); ABCMeta inherits the full metaclass protocol from type and overrides __new__ to add abstract method tracking; this MRO ensures that ABCMeta.__new__ can call super().__new__ which reaches type.__new__ to complete normal class object creation; verified with Python 3.14.4"
  category: abcmeta_identity
  kind: python_call_eq
  function: "abc.ABCMeta.__bases__.__getitem__"
  args: [0]
  method: __name__
  expected: "type"
