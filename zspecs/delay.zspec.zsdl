spec: delay
version: ">=7.0.0"
backend: node(delay)

docs: https://github.com/sindresorhus/delay#readme

provenance:
  derived_from:
    - "delay README — https://github.com/sindresorhus/delay#readme"
    - "Test vectors verified with delay via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "delay source"
  notes:
    - "Promise that resolves after a given milliseconds."
    - "Install: npm install delay"
    - "v7 ESM only; default export is the delay function."
    - "Synchronous shape-only invariants here — actual timing tested at runtime by callers."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws (negative ms is treated as 0)."
  stderr: "null"
  stickiness: "N/A — each call returns a fresh promise."
  codes: {}

invariant delay.default_export_arity:
  description: "Default export delay has function.length 1 (the ms argument)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 1

invariant delay.returns_promise:
  description: "delay(0) returns a Promise (constructor.name === 'Promise')"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [0]
  chain:
    - {get: "constructor.name"}
  expected: "Promise"

invariant delay.returns_thenable:
  description: "delay(0).then is a function (typeof check via constructor.name on .then)"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [0]
  chain:
    - {get: then}
    - {get: "constructor.name"}
  expected: "Function"

invariant delay.has_catch:
  description: "delay(0).catch is a function"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [0]
  chain:
    - {get: catch}
    - {get: "constructor.name"}
  expected: "Function"

invariant delay.has_finally:
  description: "delay(0).finally is a function"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [0]
  chain:
    - {get: finally}
    - {get: "constructor.name"}
  expected: "Function"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:13:29Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
