spec: decimal_extra140
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal method __qualname__ values and lengths — new territory not covered in decimal_extra99 (which covered class __qualname__ values)."
    - "All Decimal method __qualname__ values follow the 'Decimal.<method>' pattern."
    - "Decimal method qualname lengths by group: fma/max/min=11, sqrt=12, __lt__/__le__/__eq__/__ne__/__gt__/__ge__=14, __add__/__mul__/__str__/__sub__/__pow__/__neg__/__abs__/__int__=15, __repr__/quantize/copy_abs/__hash__/__bool__=16, normalize/__float__=17, __format__/copy_negate=18 or 19."
    - "Decimal.__add__.__qualname__ == 'Decimal.__add__' (len=15)."
    - "Decimal.__mul__.__qualname__ == 'Decimal.__mul__' (len=15)."
    - "Decimal.__str__.__qualname__ == 'Decimal.__str__' (len=15)."
    - "Decimal.__repr__.__qualname__ == 'Decimal.__repr__' (len=16)."
    - "Decimal.quantize.__qualname__ == 'Decimal.quantize' (len=16)."
    - "Decimal.normalize.__qualname__ == 'Decimal.normalize' (len=17)."
    - "Decimal.__lt__/__le__/__eq__/__ne__/__gt__/__ge__ all have qualname len=14."
    - "Decimal.__truediv__.__qualname__ == 'Decimal.__truediv__' (len=19)."
    - "Decimal.fma.__qualname__ == 'Decimal.fma' (len=11; shortest Decimal method qualname)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal arithmetic operator method __qualname__ values
# __add__, __mul__, __str__, __sub__, __pow__, __neg__, __abs__: all len=15.
# __repr__: len=16. __truediv__: len=19.
# All follow the 'Decimal.<method>' pattern.
# ---------------------------------------------------------------------------

table decimal_extra140.Decimal_arithmetic_qualnames:
  description: "decimal.Decimal arithmetic method __qualname__ values: __add__/__mul__/__str__/__sub__/__pow__/__neg__/__abs__=len15, __repr__=len16, __truediv__=len19"
  kind: python_call_eq
  category: qualname
  id_prefix: decmethqname140

  columns: [id, function, args, expected, description]
  rows:
    - [add_qeq,      Decimal.__add__.__qualname__.__eq__,      ["Decimal.__add__"],      true, "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (all Decimal method qualnames use the public class name 'Decimal', not a C-extension private name)"]
    - [add_qlen,     Decimal.__add__.__qualname__.__len__,     [],                        15,   "decimal.Decimal.__add__.__qualname__.__len__() == 15 ('Decimal.__add__' has 15 characters)"]
    - [mul_qeq,      Decimal.__mul__.__qualname__.__eq__,      ["Decimal.__mul__"],      true, "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__'"]
    - [mul_qlen,     Decimal.__mul__.__qualname__.__len__,     [],                        15,   "decimal.Decimal.__mul__.__qualname__.__len__() == 15 (tied with __add__, __str__, __sub__, __pow__, __neg__, __abs__)"]
    - [str_qeq,      Decimal.__str__.__qualname__.__eq__,      ["Decimal.__str__"],      true, "decimal.Decimal.__str__.__qualname__ == 'Decimal.__str__'"]
    - [str_qlen,     Decimal.__str__.__qualname__.__len__,     [],                        15,   "decimal.Decimal.__str__.__qualname__.__len__() == 15"]
    - [repr_qeq,     Decimal.__repr__.__qualname__.__eq__,     ["Decimal.__repr__"],     true, "decimal.Decimal.__repr__.__qualname__ == 'Decimal.__repr__' (len=16; 1 character longer than __str__)"]
    - [repr_qlen,    Decimal.__repr__.__qualname__.__len__,    [],                        16,   "decimal.Decimal.__repr__.__qualname__.__len__() == 16 ('Decimal.__repr__' has 16 characters; __repr__ is 1 char longer than __str__)"]
    - [truediv_qeq,  Decimal.__truediv__.__qualname__.__eq__,  ["Decimal.__truediv__"],  true, "decimal.Decimal.__truediv__.__qualname__ == 'Decimal.__truediv__' (len=19; longest arithmetic operator qualname)"]
    - [truediv_qlen, Decimal.__truediv__.__qualname__.__len__, [],                        19,   "decimal.Decimal.__truediv__.__qualname__.__len__() == 19 ('Decimal.__truediv__' has 19 characters; the longest of the Decimal dunder operator qualnames)"]

# ---------------------------------------------------------------------------
# decimal.Decimal comparison method __qualname__ lengths
# __lt__, __le__, __eq__, __ne__, __gt__, __ge__: all have qualname len=14.
# 'Decimal.__lt__' = 14 chars; the two-char method name (__lt__ is 6 chars) plus
# 'Decimal.' (8 chars) = 14.
# ---------------------------------------------------------------------------

table decimal_extra140.Decimal_comparison_qualnames:
  description: "decimal.Decimal comparison method __qualname__ lengths: all six comparison operators have len=14 ('Decimal.__xx__' pattern)"
  kind: python_call_eq
  category: qualname
  id_prefix: decmethqname140

  columns: [id, function, args, expected, description]
  rows:
    - [lt_qeq,  Decimal.__lt__.__qualname__.__eq__, ["Decimal.__lt__"], true, "decimal.Decimal.__lt__.__qualname__ == 'Decimal.__lt__' (len=14)"]
    - [lt_qlen, Decimal.__lt__.__qualname__.__len__, [],                 14,  "decimal.Decimal.__lt__.__qualname__.__len__() == 14 ('Decimal.__lt__' has 14 characters)"]
    - [le_qeq,  Decimal.__le__.__qualname__.__eq__, ["Decimal.__le__"], true, "decimal.Decimal.__le__.__qualname__ == 'Decimal.__le__' (len=14)"]
    - [le_qlen, Decimal.__le__.__qualname__.__len__, [],                 14,  "decimal.Decimal.__le__.__qualname__.__len__() == 14 (tied with all six comparison operators)"]
    - [eq_qeq,  Decimal.__eq__.__qualname__.__eq__, ["Decimal.__eq__"], true, "decimal.Decimal.__eq__.__qualname__ == 'Decimal.__eq__'"]
    - [ne_qeq,  Decimal.__ne__.__qualname__.__eq__, ["Decimal.__ne__"], true, "decimal.Decimal.__ne__.__qualname__ == 'Decimal.__ne__'"]
    - [gt_qeq,  Decimal.__gt__.__qualname__.__eq__, ["Decimal.__gt__"], true, "decimal.Decimal.__gt__.__qualname__ == 'Decimal.__gt__'"]
    - [ge_qeq,  Decimal.__ge__.__qualname__.__eq__, ["Decimal.__ge__"], true, "decimal.Decimal.__ge__.__qualname__ == 'Decimal.__ge__'"]

# ---------------------------------------------------------------------------
# decimal.Decimal higher-level method __qualname__ values
# quantize=16, normalize=17; fma/max/min=11; sqrt=12; to_integral=19.
# ---------------------------------------------------------------------------

table decimal_extra140.Decimal_highlevel_method_qualnames:
  description: "decimal.Decimal higher-level method __qualname__ values: quantize='Decimal.quantize'(16), normalize='Decimal.normalize'(17), fma='Decimal.fma'(11), sqrt='Decimal.sqrt'(12), to_integral='Decimal.to_integral'(19)"
  kind: python_call_eq
  category: qualname
  id_prefix: decmethqname140

  columns: [id, function, args, expected, description]
  rows:
    - [fma_qeq,        Decimal.fma.__qualname__.__eq__,           ["Decimal.fma"],           true, "decimal.Decimal.fma.__qualname__ == 'Decimal.fma' (fused multiply-add; len=11, shortest Decimal method qualname)"]
    - [fma_qlen,       Decimal.fma.__qualname__.__len__,          [],                         11,  "decimal.Decimal.fma.__qualname__.__len__() == 11 ('Decimal.fma' has 11 characters; the shortest Decimal method qualname)"]
    - [sqrt_qeq,       Decimal.sqrt.__qualname__.__eq__,          ["Decimal.sqrt"],           true, "decimal.Decimal.sqrt.__qualname__ == 'Decimal.sqrt' (len=12)"]
    - [sqrt_qlen,      Decimal.sqrt.__qualname__.__len__,         [],                         12,  "decimal.Decimal.sqrt.__qualname__.__len__() == 12 ('Decimal.sqrt' has 12 characters)"]
    - [quantize_qeq,   Decimal.quantize.__qualname__.__eq__,      ["Decimal.quantize"],       true, "decimal.Decimal.quantize.__qualname__ == 'Decimal.quantize' (len=16; sets the exponent of a Decimal to a given value)"]
    - [quantize_qlen,  Decimal.quantize.__qualname__.__len__,     [],                         16,  "decimal.Decimal.quantize.__qualname__.__len__() == 16 ('Decimal.quantize' has 16 characters)"]
    - [normalize_qeq,  Decimal.normalize.__qualname__.__eq__,     ["Decimal.normalize"],      true, "decimal.Decimal.normalize.__qualname__ == 'Decimal.normalize' (len=17; reduces trailing zeros in the coefficient)"]
    - [normalize_qlen, Decimal.normalize.__qualname__.__len__,    [],                         17,  "decimal.Decimal.normalize.__qualname__.__len__() == 17 ('Decimal.normalize' has 17 characters)"]
    - [to_int_qeq,     Decimal.to_integral.__qualname__.__eq__,   ["Decimal.to_integral"],    true, "decimal.Decimal.to_integral.__qualname__ == 'Decimal.to_integral' (len=19; rounds to nearest integer)"]
    - [to_int_qlen,    Decimal.to_integral.__qualname__.__len__,  [],                         19,  "decimal.Decimal.to_integral.__qualname__.__len__() == 19 ('Decimal.to_integral' has 19 characters)"]

# ---------------------------------------------------------------------------
# decimal.Decimal __hash__, __bool__, __float__, __int__ qualnames
# __hash__=16, __bool__=16, __float__=17, __int__=15.
# ---------------------------------------------------------------------------

table decimal_extra140.Decimal_conversion_method_qualnames:
  description: "decimal.Decimal conversion and hashing method __qualname__ lengths: __int__=15, __hash__=16, __bool__=16, __float__=17"
  kind: python_call_eq
  category: qualname
  id_prefix: decmethqname140

  columns: [id, function, args, expected, description]
  rows:
    - [int_qeq,   Decimal.__int__.__qualname__.__eq__,   ["Decimal.__int__"],   true, "decimal.Decimal.__int__.__qualname__ == 'Decimal.__int__' (len=15; same length group as __add__ and __mul__)"]
    - [int_qlen,  Decimal.__int__.__qualname__.__len__,  [],                     15,  "decimal.Decimal.__int__.__qualname__.__len__() == 15 ('Decimal.__int__' has 15 characters)"]
    - [hash_qeq,  Decimal.__hash__.__qualname__.__eq__,  ["Decimal.__hash__"],  true, "decimal.Decimal.__hash__.__qualname__ == 'Decimal.__hash__' (len=16; tied with __repr__ and quantize)"]
    - [hash_qlen, Decimal.__hash__.__qualname__.__len__, [],                     16,  "decimal.Decimal.__hash__.__qualname__.__len__() == 16 ('Decimal.__hash__' has 16 characters)"]
    - [bool_qeq,  Decimal.__bool__.__qualname__.__eq__,  ["Decimal.__bool__"],  true, "decimal.Decimal.__bool__.__qualname__ == 'Decimal.__bool__' (len=16; tied with __hash__)"]
    - [bool_qlen, Decimal.__bool__.__qualname__.__len__, [],                     16,  "decimal.Decimal.__bool__.__qualname__.__len__() == 16 ('Decimal.__bool__' has 16 characters)"]
    - [float_qeq, Decimal.__float__.__qualname__.__eq__, ["Decimal.__float__"], true, "decimal.Decimal.__float__.__qualname__ == 'Decimal.__float__' (len=17; tied with normalize)"]
    - [float_qlen,Decimal.__float__.__qualname__.__len__,[],                     17,  "decimal.Decimal.__float__.__qualname__.__len__() == 17 ('Decimal.__float__' has 17 characters; tied with normalize)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra140.Decimal.__add__qualname_eq:
  description: "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' — Decimal method qualnames use the public class name 'Decimal' (unlike io ABC methods which use private C-extension class names like '_IOBase'). This reflects that decimal.Decimal is a pure Python class in _pydecimal.py or a C extension where __qualname__ is set to the public name."
  category: qualname
  kind: python_call_eq
  function: Decimal.__add__.__qualname__.__eq__
  args: ["Decimal.__add__"]
  expected: true

invariant decimal_extra140.Decimal.fma_qualname_len_11:
  description: "decimal.Decimal.fma.__qualname__.__len__() == 11 ('Decimal.fma' has 11 characters; fma is the shortest Decimal method qualname among those covered, as 'fma' is only 3 characters long)"
  category: qualname
  kind: python_call_eq
  function: Decimal.fma.__qualname__.__len__
  args: []
  expected: 11

invariant decimal_extra140.Decimal.__lt__qualname_len_14:
  description: "decimal.Decimal.__lt__.__qualname__.__len__() == 14 ('Decimal.__lt__' has 14 characters; all six comparison operators share this length: __lt__, __le__, __eq__, __ne__, __gt__, __ge__)"
  category: qualname
  kind: python_call_eq
  function: Decimal.__lt__.__qualname__.__len__
  args: []
  expected: 14

invariant decimal_extra140.Decimal.normalize_qualname_eq:
  description: "decimal.Decimal.normalize.__qualname__ == 'Decimal.normalize' (len=17; normalize reduces trailing zeros to produce the simplest equivalent Decimal representation)"
  category: qualname
  kind: python_call_eq
  function: Decimal.normalize.__qualname__.__eq__
  args: ["Decimal.normalize"]
  expected: true

invariant decimal_extra140.Decimal.quantize_qualname_eq:
  description: "decimal.Decimal.quantize.__qualname__ == 'Decimal.quantize' (len=16; quantize sets the exponent of the result; it is 1 character shorter than normalize and 1 longer than __repr__)"
  category: qualname
  kind: python_call_eq
  function: Decimal.quantize.__qualname__.__eq__
  args: ["Decimal.quantize"]
  expected: true

invariant decimal_extra140.Decimal.__truediv__qualname_len_19:
  description: "decimal.Decimal.__truediv__.__qualname__.__len__() == 19 ('Decimal.__truediv__' has 19 characters; tied with to_integral (19) for the longest Decimal method qualname in this spec)"
  category: qualname
  kind: python_call_eq
  function: Decimal.__truediv__.__qualname__.__len__
  args: []
  expected: 19

invariant decimal_extra140.Decimal.__repr__qualname_len_16:
  description: "decimal.Decimal.__repr__.__qualname__.__len__() == 16 ('Decimal.__repr__' has 16 characters; 1 character longer than __str__ (15) because 'repr' is 1 character longer than 'str')"
  category: qualname
  kind: python_call_eq
  function: Decimal.__repr__.__qualname__.__len__
  args: []
  expected: 16

invariant decimal_extra140.Decimal.__eq__qualname_eq:
  description: "decimal.Decimal.__eq__.__qualname__ == 'Decimal.__eq__' (len=14; among the six comparison operators, __eq__ is notable as the one used in equality testing; all comparison qualnames are 14 characters)"
  category: qualname
  kind: python_call_eq
  function: Decimal.__eq__.__qualname__.__eq__
  args: ["Decimal.__eq__"]
  expected: true
