  id_prefix: mp2221

  columns: [id, function, args, expected]
  rows:
    - ["mp2221019", "multiprocessing.Process.__dict__.__contains__", ["__doc__"], true]
    - ["mp2221020", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__doc__"], true]
    - ["mp2221021", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__doc__"], true]
    - ["mp2221022", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__doc__"], true]
    - ["mp2221023", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__doc__"], true]
    - ["mp2221024", "multiprocessing.queues.Queue.__dict__.__contains__", ["__doc__"], true]

