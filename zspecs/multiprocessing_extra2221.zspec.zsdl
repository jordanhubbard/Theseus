# ---------------------------------------------------------------------------

table multiprocessing_extra2221.doc_dict_presence:
  description: "__doc__ dict-presence for mp.Process/sync.Lock/RLock/Semaphore/Event/queues.Queue — all True"
  kind: python_call_eq
