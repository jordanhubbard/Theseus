spec: multiprocessing_extra2221
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py, Lib/multiprocessing/synchronize.py, Lib/multiprocessing/queues.py"
  notes:
    - "Wave 2221 (_extra2221): identity/display protocol dict-presence — __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__ checks for multiprocessing classes."
    - "Classes checked: multiprocessing.Process (from multiprocessing.context), multiprocessing.synchronize.Lock, multiprocessing.synchronize.RLock, multiprocessing.synchronize.Semaphore, multiprocessing.synchronize.Event, multiprocessing.queues.Queue."
    - "multiprocessing.Process.__module__ == 'multiprocessing.context' — Process is defined in context.py (not process.py directly in public namespace)."
    - "multiprocessing.synchronize.Lock.__module__ == 'multiprocessing.synchronize'."
    - "multiprocessing.synchronize.RLock.__module__ == 'multiprocessing.synchronize'."
    - "multiprocessing.synchronize.Semaphore.__module__ == 'multiprocessing.synchronize'."
    - "multiprocessing.synchronize.Event.__module__ == 'multiprocessing.synchronize'."
    - "multiprocessing.queues.Queue.__module__ == 'multiprocessing.queues'."
    - "__repr__ IS in __dict__ for synchronize.Lock, RLock, Semaphore, Event — each defines a custom repr showing lock state. NOT in dict for Process or queues.Queue."
    - "__hash__ is NOT in __dict__ for any of the 6 classes."
    - "__str__ is NOT in __dict__ for any of the 6 classes."
    - "__doc__ IS in __dict__ for all 6 classes."
    - "__module__ IS in __dict__ for all 6 classes."
    - "__qualname__ is NOT in __dict__ for any of the 6 classes."
    - "__name__ is NOT in __dict__ for any of the 6 classes."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __hash__ dict-presence — all 6 multiprocessing classes
#
# __hash__ is NOT in the __dict__ of any multiprocessing class checked here.
# Process, synchronize.Lock/RLock/Semaphore/Event, and queues.Queue do not
# explicitly define or suppress __hash__ in their own class body. All 6 False.
# ---------------------------------------------------------------------------

table multiprocessing_extra2221.hash_dict_presence:
  description: "__hash__ dict-presence for mp.Process/sync.Lock/RLock/Semaphore/Event/queues.Queue — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2221

  columns: [id, function, args, expected]
  rows:
    - ["mp2221001", "multiprocessing.Process.__dict__.__contains__", ["__hash__"], false]
    - ["mp2221002", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__hash__"], false]
    - ["mp2221003", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__hash__"], false]
    - ["mp2221004", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__hash__"], false]
    - ["mp2221005", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__hash__"], false]
    - ["mp2221006", "multiprocessing.queues.Queue.__dict__.__contains__", ["__hash__"], false]

# ---------------------------------------------------------------------------
# Table 2: __repr__ dict-presence — all 6 multiprocessing classes
#
# __repr__ IS in the __dict__ of the four synchronize primitives (Lock, RLock,
# Semaphore, Event) — each defines a custom __repr__ in Lib/multiprocessing/
# synchronize.py that shows the lock state. __repr__ is NOT in the __dict__ of
# Process or queues.Queue. Lock/RLock/Semaphore/Event=True; Process/Queue=False.
# ---------------------------------------------------------------------------

table multiprocessing_extra2221.repr_dict_presence:
  description: "__repr__ dict-presence for mp.Process/sync.Lock/RLock/Semaphore/Event/queues.Queue — sync primitives True, Process/Queue False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2221

  columns: [id, function, args, expected]
  rows:
    - ["mp2221007", "multiprocessing.Process.__dict__.__contains__", ["__repr__"], false]
    - ["mp2221008", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__repr__"], true]
    - ["mp2221009", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__repr__"], true]
    - ["mp2221010", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__repr__"], true]
    - ["mp2221011", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__repr__"], true]
    - ["mp2221012", "multiprocessing.queues.Queue.__dict__.__contains__", ["__repr__"], false]

# ---------------------------------------------------------------------------
# Table 3: __str__ dict-presence — all 6 multiprocessing classes
#
# __str__ is NOT in the __dict__ of any multiprocessing class checked here.
# None of the six classes define a custom __str__ in their own class body.
# All 6 return False.
# ---------------------------------------------------------------------------

table multiprocessing_extra2221.str_dict_presence:
  description: "__str__ dict-presence for mp.Process/sync.Lock/RLock/Semaphore/Event/queues.Queue — all False"
