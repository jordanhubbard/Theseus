  columns: [id, function, args, expected]
  rows:
    - ["mp2221013", "multiprocessing.Process.__dict__.__contains__", ["__str__"], false]
    - ["mp2221014", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__str__"], false]
    - ["mp2221015", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__str__"], false]
    - ["mp2221016", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__str__"], false]
    - ["mp2221017", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__str__"], false]
    - ["mp2221018", "multiprocessing.queues.Queue.__dict__.__contains__", ["__str__"], false]

