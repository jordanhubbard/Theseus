spec: concurrent_futures_extra48
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra47.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__ tables, as_completed/wait __module__.__len__(), __all__.__len__()==14, __mro__.__len__() tables, __bases__[0].__name__.__len__() for all classes, Executor context manager qualname lens, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, map/__qualname__.__len__() for both executors, Future/ThreadPoolExecutor method __name__/__qualname__.__len__() tables, InvalidStateError/__name__.__len__()==17, CancelledError/__qualname__.__len__()==14, BrokenExecutor lengths, CancelledError/__module__.__len__()==24, TimeoutError/__name__/__module__.__len__(), concurrent.futures.__package__.__len__()==18, executor __name__ equality, executor __module__ equality, Executor/__name__/__module__ equality, exception identity/MRO depths, class __qualname__ equality tables (extra41), module string equality for thread/process/builtins (extra42), Future/__module__ lengths (extra43), class __class__.__name__=='type'/'function' tables (extra44), class __class__.__qualname__ equality tables (extra45), FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED __class__.__name__=='str', __class__.__qualname__=='str', __len__() lengths, and string value equality (extra46), class __doc__.__class__.__name__=='str'/__qualname__=='str'/__module__=='builtins' tables (extra47). ThreadPoolExecutor.submit qualname string equality == 'ThreadPoolExecutor.submit' (extra26 standalone). Future.done qualname string equality == 'Future.done' (extra27 standalone)."
    - "This spec covers: ThreadPoolExecutor.shutdown __qualname__ string equality; ProcessPoolExecutor.submit/__qualname__ string equality; ProcessPoolExecutor.shutdown/__qualname__ string equality; Future.result/__qualname__ string equality; Future.cancel/__qualname__ string equality; Future.exception/__qualname__ string equality; Executor.map/__qualname__ string equality."
    - "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'. The shutdown method is defined directly on ThreadPoolExecutor in Lib/concurrent/futures/thread.py; its __qualname__ is 'ThreadPoolExecutor.shutdown' (27 chars, matching the length from extra26). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit'. The submit method is defined directly on ProcessPoolExecutor in Lib/concurrent/futures/process.py; its __qualname__ is 'ProcessPoolExecutor.submit' (26 chars, matching the length from extra27). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown'. The shutdown method is defined directly on ProcessPoolExecutor; its __qualname__ is 'ProcessPoolExecutor.shutdown' (28 chars, matching the length from extra27). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.result.__qualname__ == 'Future.result'. The result method is defined directly on Future in _base.py; its __qualname__ is 'Future.result' (13 chars, matching the length from extra26). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.cancel.__qualname__ == 'Future.cancel'. The cancel method is defined directly on Future; its __qualname__ is 'Future.cancel' (13 chars, matching the length from extra26). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.exception.__qualname__ == 'Future.exception'. The exception method is defined directly on Future; its __qualname__ is 'Future.exception' (16 chars, matching the length from extra27). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.map.__qualname__ == 'Executor.map'. The map method is defined on the abstract Executor base class in _base.py. Both ThreadPoolExecutor and ProcessPoolExecutor inherit it without override; its __qualname__ is 'Executor.map' (12 chars, matching the length from extra26). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ThreadPoolExecutor method __qualname__ string equality — extra48
#
# Prior spec extra26 covered __qualname__.__len__() for TPE.submit (25) and
# TPE.shutdown (27), and also captured the full string equality for submit
# as a standalone invariant. Extra48 completes the string equality for
# TPE.shutdown:
#   ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'
# 'ThreadPoolExecutor.' prefix is 20 chars; 'shutdown' is 8 chars; total 28?
# Wait: 'ThreadPoolExecutor' = 18 chars; '.' = 1; 'shutdown' = 8; total = 27.
# Length confirmed in extra26 as 27. String value confirmed here.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra48.tpe_shutdown_qualname_eq:
  description: "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' — method defined directly on ThreadPoolExecutor (27 chars: 'ThreadPoolExecutor'(18) + '.'(1) + 'shutdown'(8))"
  category: method_names
  kind: python_call_eq
  function: ThreadPoolExecutor.shutdown.__qualname__.__eq__
  args: ["ThreadPoolExecutor.shutdown"]
  expected: true

# ---------------------------------------------------------------------------
# ProcessPoolExecutor method __qualname__ string equality — extra48
#
# Prior spec extra27 covered __qualname__.__len__() for PPE.submit (26) and
# PPE.shutdown (28), but no standalone string equality was captured for either.
# Extra48 supplies the full string equality checks:
#   ProcessPoolExecutor.submit.__qualname__   == 'ProcessPoolExecutor.submit'   (26)
#   ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' (28)
# 'ProcessPoolExecutor' = 19 chars; '.' = 1; 'submit' = 6; total 26.
# 'ProcessPoolExecutor' = 19 chars; '.' = 1; 'shutdown' = 8; total 28.
# ---------------------------------------------------------------------------

table concurrent_futures_extra48.ppe_method_qualname_eq:
  description: "concurrent.futures.ProcessPoolExecutor method __qualname__ string equality in extra48 namespace — complementing the length checks in extra27"
  kind: python_call_eq
  category: method_names
  id_prefix: cfmeth48ppequal

  columns: [id, function, args, expected, description]
  rows:
    - [submit,   ProcessPoolExecutor.submit.__qualname__.__eq__,   ["ProcessPoolExecutor.submit"],   true, "ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit' (26 chars: 'ProcessPoolExecutor'(19) + '.'(1) + 'submit'(6))"]
    - [shutdown, ProcessPoolExecutor.shutdown.__qualname__.__eq__, ["ProcessPoolExecutor.shutdown"], true, "ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' (28 chars: 'ProcessPoolExecutor'(19) + '.'(1) + 'shutdown'(8))"]

# ---------------------------------------------------------------------------
# concurrent.futures.Future method __qualname__ string equality — extra48
#
# Prior specs extra26 and extra27 captured __qualname__.__len__() for all
# Future public methods, and extra27 captured the full string equality for
# Future.done as a standalone invariant. Extra48 completes string equality
# for the remaining three methods:
#   Future.result.__qualname__    == 'Future.result'    (13 chars)
#   Future.cancel.__qualname__    == 'Future.cancel'    (13 chars)
#   Future.exception.__qualname__ == 'Future.exception' (16 chars)
# 'Future.' = 7 chars; 'result'/'cancel' = 6 chars each; total 13.
# 'Future.' = 7 chars; 'exception' = 9 chars; total 16.
# ---------------------------------------------------------------------------

table concurrent_futures_extra48.future_method_qualname_eq:
  description: "concurrent.futures.Future method __qualname__ string equality in extra48 namespace — result, cancel, exception"
  kind: python_call_eq
  category: method_names
  id_prefix: cfmeth48futurequal

  columns: [id, function, args, expected, description]
  rows:
    - [result,    Future.result.__qualname__.__eq__,    ["Future.result"],    true, "Future.result.__qualname__ == 'Future.result' (13 chars: 'Future.'(7) + 'result'(6)) — method defined on concurrent.futures.Future in _base.py"]
    - [cancel,    Future.cancel.__qualname__.__eq__,    ["Future.cancel"],    true, "Future.cancel.__qualname__ == 'Future.cancel' (13 chars: 'Future.'(7) + 'cancel'(6)) — method defined on concurrent.futures.Future in _base.py"]
    - [exception, Future.exception.__qualname__.__eq__, ["Future.exception"], true, "Future.exception.__qualname__ == 'Future.exception' (16 chars: 'Future.'(7) + 'exception'(9)) — method defined on concurrent.futures.Future in _base.py"]

# ---------------------------------------------------------------------------
# concurrent.futures.Executor.map __qualname__ string equality — extra48
#
# Executor.map is defined on the abstract Executor base class and inherited
# unchanged by both ThreadPoolExecutor and ProcessPoolExecutor. The __qualname__
# therefore reflects the defining class: 'Executor.map' (12 chars).
# Prior spec extra26 captured the length (12) via ThreadPoolExecutor.map
# (which reports 'Executor.map' because it is inherited). Extra48 captures
# the full string equality directly via Executor.map.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra48.Executor_map_qualname_eq:
  description: "concurrent.futures.Executor.map.__qualname__ == 'Executor.map' — abstract base class method defined in _base.py; inherited by both executor subclasses without override (12 chars: 'Executor.'(9) + 'map'(3))"
  category: method_names
  kind: python_call_eq
  function: Executor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — extra48
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra48.Future_result_qualname_eq:
  description: "concurrent.futures.Future.result.__qualname__ == 'Future.result' — blocking result-retrieval method defined on Future in _base.py (13 chars)"
  category: method_names
  kind: python_call_eq
  function: Future.result.__qualname__.__eq__
  args: ["Future.result"]
  expected: true

invariant concurrent_futures_extra48.Future_cancel_qualname_eq:
  description: "concurrent.futures.Future.cancel.__qualname__ == 'Future.cancel' — cancellation method defined on Future in _base.py (13 chars)"
  category: method_names
  kind: python_call_eq
  function: Future.cancel.__qualname__.__eq__
  args: ["Future.cancel"]
  expected: true

invariant concurrent_futures_extra48.Future_exception_qualname_eq:
  description: "concurrent.futures.Future.exception.__qualname__ == 'Future.exception' — exception-retrieval method defined on Future in _base.py (16 chars)"
  category: method_names
  kind: python_call_eq
  function: Future.exception.__qualname__.__eq__
  args: ["Future.exception"]
  expected: true

invariant concurrent_futures_extra48.ProcessPoolExecutor_submit_qualname_eq:
  description: "concurrent.futures.ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit' — method defined directly on ProcessPoolExecutor (26 chars)"
  category: method_names
  kind: python_call_eq
  function: ProcessPoolExecutor.submit.__qualname__.__eq__
  args: ["ProcessPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra48.ProcessPoolExecutor_shutdown_qualname_eq:
  description: "concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' — method defined directly on ProcessPoolExecutor (28 chars)"
  category: method_names
  kind: python_call_eq
  function: ProcessPoolExecutor.shutdown.__qualname__.__eq__
  args: ["ProcessPoolExecutor.shutdown"]
  expected: true
