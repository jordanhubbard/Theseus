spec: multiprocessing_extra1036
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing Process documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing.Process property descriptors, method qualnames, and module identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1036.process_property_descriptors:
  description: "multiprocessing.Process property descriptor class identity"
  kind: python_call_eq
  category: process_property_descriptors
  id_prefix: mp1036pd
  columns: [id, function, args, expected]
  rows:
    - [mp1036pd001, multiprocessing.Process.pid.__class__.__name__.__eq__,      ["property"], true]
    - [mp1036pd002, multiprocessing.Process.exitcode.__class__.__name__.__eq__, ["property"], true]
    - [mp1036pd003, multiprocessing.Process.authkey.__class__.__name__.__eq__,  ["property"], true]
    - [mp1036pd004, multiprocessing.Process.sentinel.__class__.__name__.__eq__, ["property"], true]
    - [mp1036pd005, multiprocessing.Process.daemon.__class__.__name__.__eq__,   ["property"], true]
    - [mp1036pd006, multiprocessing.Process.name.__class__.__name__.__eq__,     ["property"], true]

table multiprocessing_extra1036.process_method_qualnames:
  description: "multiprocessing.Process method __qualname__ identity"
  kind: python_call_eq
  category: process_method_qualnames
  id_prefix: mp1036mq
  columns: [id, function, args, expected]
  rows:
    - [mp1036mq001, multiprocessing.Process.start.__qualname__.__eq__,     ["Process.start"],     true]
    - [mp1036mq002, multiprocessing.Process.run.__qualname__.__eq__,       ["Process.run"],       true]
    - [mp1036mq003, multiprocessing.Process.join.__qualname__.__eq__,      ["Process.join"],      true]
    - [mp1036mq004, multiprocessing.Process.terminate.__qualname__.__eq__, ["Process.terminate"], true]
    - [mp1036mq005, multiprocessing.Process.kill.__qualname__.__eq__,      ["Process.kill"],      true]
    - [mp1036mq006, multiprocessing.Process.is_alive.__qualname__.__eq__,  ["Process.is_alive"],  true]
    - [mp1036mq007, multiprocessing.Process.close.__qualname__.__eq__,     ["Process.close"],     true]

table multiprocessing_extra1036.module_and_class_identity:
  description: "multiprocessing module and Process class identity"
  kind: python_call_eq
  category: module_and_class_identity
  id_prefix: mp1036ci
  columns: [id, function, args, expected]
  rows:
    - [mp1036ci001, multiprocessing.__doc__.__class__.__name__.__eq__,        ["str"],  true]
    - [mp1036ci002, multiprocessing.Process.__class__.__name__.__eq__,        ["type"], true]
    - [mp1036ci003, multiprocessing.Process.__module__.__eq__,                ["multiprocessing.process"], true]
    - [mp1036ci004, multiprocessing.Process.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [mp1036ci005, multiprocessing.__name__.__eq__,                          ["multiprocessing"], true]
