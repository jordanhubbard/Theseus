spec: jsonpointer
version: ">=5.0.0"
backend: node(jsonpointer)

docs: https://github.com/janl/node-jsonpointer#readme

provenance:
  derived_from:
    - "node-jsonpointer README — https://github.com/janl/node-jsonpointer#readme"
    - "RFC 6901 — JavaScript Object Notation (JSON) Pointer"
    - "Test vectors verified with jsonpointer via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "node-jsonpointer source"
  notes:
    - "jsonpointer implements RFC 6901 JSON Pointer for traversing/mutating JS objects."
    - "Install: npm install jsonpointer"
    - "Pattern: const jp = require('jsonpointer'); jp.get(obj, '/path/to/key')"
    - "Pointers start with '/'; '' refers to the root document; numeric segments index arrays."
    - ".set(obj, ptr, value) mutates obj in place — not exercised here (chain primitive doesn't expose post-call state of input args)."
  rfcs:
    - "RFC 6901 — JavaScript Object Notation (JSON) Pointer — https://www.rfc-editor.org/rfc/rfc6901"
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "get() returns undefined for missing paths; never throws on a valid pointer."
  stderr: "null"
  stickiness: "N/A — get is read-only."
  codes: {}

table jsonpointer.get:
  kind: node_chain_eq
  category: get
  entry: named
  function: get
  id_prefix: get

  columns: [id, entry_args, chain, expected]
  rows:
    - [nested_key,
       [{a: {b: 1}}, "/a/b"],
       [],
       1]

    - [array_index,
       [{a: [10, 20, 30]}, "/a/1"],
       [],
       20]

    - [array_first,
       [{items: ["x", "y"]}, "/items/0"],
       [],
       "x"]

    - [missing_path,
       [{a: 1}, "/missing"],
       [],
       ~]

    - [root_pointer,
       [{a: 1}, ""],
       [],
       {a: 1}]

    - [deep_path,
       [{x: {y: {z: "deep"}}}, "/x/y/z"],
       [],
       "deep"]

    - [escaped_slash,
       [{"foo/bar": 42}, "/foo~1bar"],
       [],
       42,
       {description: "RFC 6901 §3 — '/' inside a key is escaped as '~1'"}]

    - [escaped_tilde,
       [{"foo~bar": 42}, "/foo~0bar"],
       [],
       42,
       {description: "RFC 6901 §3 — '~' inside a key is escaped as '~0'"}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:04:09Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
