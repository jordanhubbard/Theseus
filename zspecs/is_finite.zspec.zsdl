spec: is_finite
version: ">=1.1.0"
backend: node(is-finite)

docs: https://www.npmjs.com/package/is-finite

provenance:
  derived_from:
    - "is-finite README — https://www.npmjs.com/package/is-finite"
    - "Test vectors verified with is-finite via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-finite source"
  notes:
    - "is-finite is an npm package. Install: npm install is-finite"
    - "Returns true if the value is a finite number."
    - "Infinity and NaN are not JSON-serializable so only finite cases are tested."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_finite.isFinite:
  kind: node_module_call_eq
  function: ~
  category: predicate
  id_prefix: isfinite

  columns: [id, args, expected]
  rows:
    - [finite_int,   [5],     true]
    - [finite_float, [3.14],  true]
    - [not_finite_s, ["foo"], false]
    - [not_finite_n, [null],  false]

