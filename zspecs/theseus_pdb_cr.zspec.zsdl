spec: theseus_pdb_cr
version: ">=3.8"
backend: python_cleanroom(theseus_pdb_cr)
blocks: pdb

docs: https://docs.python.org/3/library/pdb.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pdb.html"
  not_derived_from:
    - "CPython source: Lib/pdb.py"
  notes:
    - "Clean-room pdb module. Do NOT import pdb."
    - "Minimal implementation of debugger control functions."

error_model: python_exceptions

invariant theseus_pdb_cr.pdb2_set_trace:
  description: "set_trace function exists and is callable"
  category: presence
  kind: python_call_eq
  function: pdb2_set_trace
  args: []
  expected: true

invariant theseus_pdb_cr.pdb2_run:
  description: "run executes a string expression"
  category: behavior
  kind: python_call_eq
  function: pdb2_run
  args: []
  expected: true

invariant theseus_pdb_cr.pdb2_runcall:
  description: "runcall calls a function and returns result"
  category: behavior
  kind: python_call_eq
  function: pdb2_runcall
  args: []
  expected: true
