spec: io_extra2176
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 2176 (_extra2176): iterator/sequence protocol dict-presence theme — __iter__, __next__, __aiter__, __anext__, __await__, __length_hint__, __reversed__, __missing__."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase do NOT define __iter__ or __next__ in their own __dict__ — iteration support is inherited from C-level slot machinery, not Python-visible __dict__ entries."
    - "io.BytesIO defines both __iter__ and __next__ directly in its __dict__."
    - "io.StringIO defines __next__ but not __iter__ directly in its __dict__."
    - "io.BufferedReader, io.BufferedRandom, io.TextIOWrapper each define __next__ but not __iter__ in their own __dict__."
    - "io.BufferedWriter, io.FileIO, io.IncrementalNewlineDecoder define neither __iter__ nor __next__ in their own __dict__."
    - "No io class defines __aiter__, __anext__, __await__, __length_hint__, __reversed__, or __missing__ in its own __dict__."
  created_at: "2026-04-12"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __iter__ dict-presence across io classes
#
# Only io.BytesIO defines __iter__ in its own __dict__.
# All other io classes do not define __iter__ directly.
# ---------------------------------------------------------------------------

table io_extra2176.iter_presence:
  description: "io classes __iter__ dict-presence — only BytesIO returns true"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2176
  columns: [id, function, args, expected]
  rows:
    - ["io2176001", "io.IOBase.__dict__.__contains__",              ["__iter__"], false]
    - ["io2176002", "io.RawIOBase.__dict__.__contains__",           ["__iter__"], false]
    - ["io2176003", "io.BufferedIOBase.__dict__.__contains__",      ["__iter__"], false]
    - ["io2176004", "io.TextIOBase.__dict__.__contains__",          ["__iter__"], false]
    - ["io2176005", "io.BytesIO.__dict__.__contains__",             ["__iter__"], true]
    - ["io2176006", "io.StringIO.__dict__.__contains__",            ["__iter__"], false]
    - ["io2176007", "io.FileIO.__dict__.__contains__",              ["__iter__"], false]
    - ["io2176008", "io.BufferedReader.__dict__.__contains__",      ["__iter__"], false]
    - ["io2176009", "io.BufferedWriter.__dict__.__contains__",      ["__iter__"], false]
    - ["io2176010", "io.BufferedRandom.__dict__.__contains__",      ["__iter__"], false]
    - ["io2176011", "io.TextIOWrapper.__dict__.__contains__",       ["__iter__"], false]
    - ["io2176012", "io.IncrementalNewlineDecoder.__dict__.__contains__", ["__iter__"], false]

# ---------------------------------------------------------------------------
# Table 2: __next__ dict-presence across io classes
#
# BytesIO, StringIO, BufferedReader, BufferedRandom, TextIOWrapper each define
# __next__ directly. IOBase, RawIOBase, BufferedIOBase, TextIOBase, FileIO,
# BufferedWriter, and IncrementalNewlineDecoder do not.
# ---------------------------------------------------------------------------

table io_extra2176.next_presence:
  description: "io classes __next__ dict-presence — BytesIO, StringIO, BufferedReader, BufferedRandom, TextIOWrapper return true"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2176
  columns: [id, function, args, expected]
  rows:
    - ["io2176013", "io.IOBase.__dict__.__contains__",              ["__next__"], false]
    - ["io2176014", "io.RawIOBase.__dict__.__contains__",           ["__next__"], false]
    - ["io2176015", "io.BufferedIOBase.__dict__.__contains__",      ["__next__"], false]
    - ["io2176016", "io.TextIOBase.__dict__.__contains__",          ["__next__"], false]
    - ["io2176017", "io.BytesIO.__dict__.__contains__",             ["__next__"], true]
    - ["io2176018", "io.StringIO.__dict__.__contains__",            ["__next__"], true]
    - ["io2176019", "io.FileIO.__dict__.__contains__",              ["__next__"], false]
    - ["io2176020", "io.BufferedReader.__dict__.__contains__",      ["__next__"], true]
    - ["io2176021", "io.BufferedWriter.__dict__.__contains__",      ["__next__"], false]
    - ["io2176022", "io.BufferedRandom.__dict__.__contains__",      ["__next__"], true]
    - ["io2176023", "io.TextIOWrapper.__dict__.__contains__",       ["__next__"], true]
    - ["io2176024", "io.IncrementalNewlineDecoder.__dict__.__contains__", ["__next__"], false]

# ---------------------------------------------------------------------------
# Table 3: __aiter__ and __anext__ dict-presence — all absent
#
# No io class defines async iterator protocol methods in its own __dict__.
# io streams are synchronous; async wrappers live in asyncio, not io.
# ---------------------------------------------------------------------------

table io_extra2176.aiter_anext_absent:
  description: "io classes __aiter__ and __anext__ dict-presence — all false; io is synchronous-only"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2176
  columns: [id, function, args, expected]
  rows:
    - ["io2176025", "io.IOBase.__dict__.__contains__",         ["__aiter__"], false]
    - ["io2176026", "io.IOBase.__dict__.__contains__",         ["__anext__"], false]
    - ["io2176027", "io.RawIOBase.__dict__.__contains__",      ["__aiter__"], false]
    - ["io2176028", "io.RawIOBase.__dict__.__contains__",      ["__anext__"], false]
    - ["io2176029", "io.BufferedIOBase.__dict__.__contains__", ["__aiter__"], false]
    - ["io2176030", "io.BufferedIOBase.__dict__.__contains__", ["__anext__"], false]
    - ["io2176031", "io.TextIOBase.__dict__.__contains__",     ["__aiter__"], false]
    - ["io2176032", "io.TextIOBase.__dict__.__contains__",     ["__anext__"], false]
    - ["io2176033", "io.BytesIO.__dict__.__contains__",        ["__aiter__"], false]
    - ["io2176034", "io.BytesIO.__dict__.__contains__",        ["__anext__"], false]
    - ["io2176035", "io.StringIO.__dict__.__contains__",       ["__aiter__"], false]
    - ["io2176036", "io.StringIO.__dict__.__contains__",       ["__anext__"], false]

# ---------------------------------------------------------------------------
# Table 4: __await__, __length_hint__, __reversed__, __missing__ — all absent
#
# No io class defines __await__ (not awaitable), __length_hint__ (no size hint),
# __reversed__ (streams are forward-only), or __missing__ (not dict subclasses).
# ---------------------------------------------------------------------------

