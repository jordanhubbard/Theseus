spec: hashlib_extra378
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "hashlib.new.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed is a frozenset on some Python builds, but a set on CPython 3.14.3 macOS."
    - "'sha384' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha224' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha3_256' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha3_512' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha3_224' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha3_384' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.new is a pure-Python dispatcher function (type 'function') defined in Lib/hashlib.py. It differs from md5/sha256 etc., which are C builtins in the _hashlib extension."
    - "Note: algorithms_guaranteed is documented as a set of names that are always available regardless of OpenSSL version or platform. SHA-3 variants were added in Python 3.6 via the _sha3 C extension."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new.__class__.__name__
# hashlib.algorithms_guaranteed membership for SHA-2 and SHA-3 variants
#
# Wave 378 theme: hashlib.new type identity and algorithms_guaranteed set
# membership for SHA-384, SHA-224, and the SHA-3 family.
#
# hashlib.new is a Python-level function (type 'function') that dispatches to
# the appropriate hash constructor by algorithm name string. This contrasts
# with hashlib.md5, hashlib.sha256, etc., which are C builtins implemented in
# the _hashlib OpenSSL extension.
#
# hashlib.algorithms_guaranteed is a set of algorithm name strings that are
# guaranteed to be available on all platforms regardless of the OpenSSL
# version. On CPython 3.14.3 macOS, it is a plain Python set object. The SHA-3
# family (sha3_224, sha3_256, sha3_384, sha3_512) was implemented in the _sha3
# C extension module starting in Python 3.6 and is guaranteed on all modern
# platforms.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra378.new_class_name:
  description: "hashlib.new.__class__.__name__.__eq__('function') == True — hashlib.new is a pure-Python dispatcher function defined in Lib/hashlib.py; its type is 'function' unlike md5/sha256 which are C builtins; accepts algorithm name string like 'sha256'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: new.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant hashlib_extra378.algorithms_guaranteed_class:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True — algorithms_guaranteed is a plain Python set on CPython 3.14.3 macOS; contains all algorithm names guaranteed available on all platforms; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: type_identity
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

table hashlib_extra378.algorithms_guaranteed_sha2_members:
  description: "hashlib.algorithms_guaranteed contains SHA-2 extended family members sha384 and sha224 — both are guaranteed available on all platforms; sha384 is a 384-bit truncation of SHA-512; sha224 is a 224-bit truncation of SHA-256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: set_membership
  id_prefix: hashlibalgsha2_378

  columns: [id, function, args, expected]
  rows:
    - [sha384_in, algorithms_guaranteed.__contains__, ["sha384"], true]
    - [sha224_in, algorithms_guaranteed.__contains__, ["sha224"], true]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed SHA-3 family membership
#
# The SHA-3 family (Keccak-based, standardized in FIPS 202) was added in
# Python 3.6 via the _sha3 C extension module. All four SHA-3 variants
# (sha3_224, sha3_256, sha3_384, sha3_512) are in algorithms_guaranteed on
# all modern CPython builds. SHA-3 provides 224, 256, 384, and 512-bit output
# lengths with security margins independent of SHA-2.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra378.algorithms_guaranteed_sha3_members:
  description: "hashlib.algorithms_guaranteed contains all four SHA-3 family members — sha3_224, sha3_256, sha3_384, sha3_512 all guaranteed on all platforms since Python 3.6; SHA-3 is Keccak-based (FIPS 202); verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: set_membership
  id_prefix: hashlibalgsha3_378

  columns: [id, function, args, expected]
  rows:
    - [sha3_256_in, algorithms_guaranteed.__contains__, ["sha3_256"], true]
    - [sha3_512_in, algorithms_guaranteed.__contains__, ["sha3_512"], true]
    - [sha3_224_in, algorithms_guaranteed.__contains__, ["sha3_224"], true]
    - [sha3_384_in, algorithms_guaranteed.__contains__, ["sha3_384"], true]
