spec: urllib_parse_extra6
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
  notes:
    - "This spec extends urllib_parse.zspec.zsdl and prior extras through urllib_parse_extra5.zspec.zsdl."
    - "urllib_parse_extra3.zspec.zsdl covers ParseResult/SplitResult __name__; urlparse.scheme, netloc, path behavioral checks."
    - "urllib_parse_extra4.zspec.zsdl covers ParseResult/SplitResult/DefragResult __qualname__; urlparse/urlsplit/urljoin/urlencode/quote/unquote qualnames; quote/unquote value correctness."
    - "urllib_parse_extra5.zspec.zsdl covers quote_plus/unquote_plus/parse_qs/parse_qsl qualnames; urlparse.__module__; urlencode({'key': 'val'}) == 'key=val'."
    - "Focus: ParseResult/SplitResult/DefragResult __module__ (not yet covered); __module__ for urlsplit/urljoin/urlencode/quote/unquote (only urlparse.__module__ done in extra5); urlparse behavioral checks on query and fragment fields (extra3 covers scheme/netloc/path only); urlunparse/urlunsplit __module__."
    - "urllib.parse.ParseResult.__module__ == 'urllib.parse' — named-tuple subclass defined in urllib/parse.py."
    - "urllib.parse.SplitResult.__module__ == 'urllib.parse'."
    - "urllib.parse.DefragResult.__module__ == 'urllib.parse'."
    - "urllib.parse.urlparse('http://example.com/path?q=1').query == 'q=1' — query component, not yet tested."
    - "urllib.parse.urlparse('http://example.com/path#frag').fragment == 'frag' — fragment component, not yet tested."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Named result type __module__ checks
# urllib_parse_extra4 covers qualnames; urllib_parse_extra3 covers __name__.
# No prior spec checks __module__ for ParseResult, SplitResult, or DefragResult.
# ---------------------------------------------------------------------------

table urllib_parse_extra6.result_type_modules:
  kind: python_call_eq
  category: modules
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [ParseResult,  ParseResult.__module__.__eq__,  ["urllib.parse"], true]
    - [SplitResult,  SplitResult.__module__.__eq__,  ["urllib.parse"], true]
    - [DefragResult, DefragResult.__module__.__eq__, ["urllib.parse"], true]

# ---------------------------------------------------------------------------
# Function __module__ checks — urlsplit, urljoin, urlencode, quote, unquote
# urllib_parse_extra5 checks urlparse.__module__; no prior spec checks
# __module__ for the other core parsing functions.
# ---------------------------------------------------------------------------

table urllib_parse_extra6.function_modules:
  kind: python_call_eq
  category: modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [urlsplit,    urlsplit.__module__.__eq__,    ["urllib.parse"], true]
    - [urljoin,     urljoin.__module__.__eq__,     ["urllib.parse"], true]
    - [urlencode,   urlencode.__module__.__eq__,   ["urllib.parse"], true]
    - [quote,       quote.__module__.__eq__,       ["urllib.parse"], true]
    - [unquote,     unquote.__module__.__eq__,     ["urllib.parse"], true]
    - [urlunparse,  urlunparse.__module__.__eq__,  ["urllib.parse"], true]
    - [urlunsplit,  urlunsplit.__module__.__eq__,  ["urllib.parse"], true]

# ---------------------------------------------------------------------------
# urlparse behavioral — query and fragment fields
# urllib_parse_extra3 covers .scheme, .netloc, .path for 'http://example.com/path'.
# .query and .fragment are separate ParseResult fields not yet tested.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra6.urlparse.query:
  description: "urllib.parse.urlparse('http://example.com/path?q=1').query == 'q=1'"
  category: urlparse
  kind: python_call_eq
  function: urlparse
  args: ["http://example.com/path?q=1"]
  method: query.__eq__
  method_args: ["q=1"]
  expected: true

invariant urllib_parse_extra6.urlparse.fragment:
  description: "urllib.parse.urlparse('http://example.com/path#frag').fragment == 'frag'"
  category: urlparse
  kind: python_call_eq
  function: urlparse
  args: ["http://example.com/path#frag"]
  method: fragment.__eq__
  method_args: ["frag"]
  expected: true

invariant urllib_parse_extra6.urlparse.empty_query:
  description: "urllib.parse.urlparse('http://example.com/path').query == '' — no query string"
  category: urlparse
  kind: python_call_eq
  function: urlparse
  args: ["http://example.com/path"]
  method: query.__eq__
  method_args: [""]
  expected: true
