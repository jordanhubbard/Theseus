spec: re_extra121
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec extends re_extra120.zspec.zsdl."
    - "This spec covers: re module-level function __doc__ lengths and re.RegexFlag member __int__() values not yet covered."
    - "re.search.__doc__.__len__() == 112; re.compile.__doc__.__len__() == 65; novel for module-level functions."
    - "re.match.__doc__.__len__() == 109; re.fullmatch.__doc__.__len__() == 103; novel for module-level functions."
    - "re.VERBOSE.__int__() == 64; re.UNICODE.__int__() == 32; re.ASCII.__int__() == 256; novel __int__ method call assertions."
    - "re.LOCALE.__int__() == 4; re.NOFLAG.__int__() == 0; novel __int__ method call assertions."
    - "Prior specs covered Pattern method __doc__.__len__() (re_extra87) but NOT module-level function __doc__.__len__()."
    - "Prior specs covered flag .value attributes and int() coercion but NOT the __int__() method call form for VERBOSE/UNICODE/ASCII."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module-level function __doc__.__len__() for search and compile
# re.search.__doc__.__len__() == 112.
# re.compile.__doc__.__len__() == 65.
# Prior specs (re_extra52) covered __doc__.__class__.__name__=='str' for module-level
# functions but NOT __doc__.__len__() for any module-level function.
# re_extra87 covered Pattern method __doc__.__len__() (e.g., Pattern.search(141),
# Pattern.match(63)), but those are Pattern instance methods, not module-level functions.
# The module-level re.search.__doc__ (112) and re.compile.__doc__ (65) are distinct
# from their Pattern method counterparts and have not been checked for length before.
# ---------------------------------------------------------------------------

table re_extra121.search_compile_doc_lens:
  description: "re.search.__doc__.__len__()==112; re.compile.__doc__.__len__()==65; module-level function doc lengths novel; prior specs covered Pattern method doc lengths (re_extra87) but NOT module-level function doc lengths"
  kind: python_call_eq
  category: module_identity
  id_prefix: resrchcpl121a

  columns: [id, function, args, expected, description]
  rows:
    - [search_doc_len,    "search.__doc__.__len__",          [],   112, "re.search.__doc__.__len__() == 112 (module-level function docstring; distinct from Pattern.search.__doc__.__len__()==141; module-level docs are shorter summaries)"]
    - [compile_doc_len,   "compile.__doc__.__len__",         [],   65,  "re.compile.__doc__.__len__() == 65 (module-level function docstring; distinct from Pattern.search pattern-level docs; no prior re spec checks compile.__doc__.__len__())"]
    - [search_gt_compile, "search.__doc__.__len__.__gt__",   [65], true, "len(re.search.__doc__) > len(re.compile.__doc__) (112 > 65; search doc is longer because it describes scanning semantics; compile doc is brief)"]
    - [search_doc_type,   "search.__doc__.__class__.__name__.__eq__", ["str"], true, "type(re.search.__doc__).__name__ == 'str' (module-level function docstrings are plain Python strings)"]
    - [compile_doc_type,  "compile.__doc__.__class__.__name__.__eq__", ["str"], true, "type(re.compile.__doc__).__name__ == 'str' (module-level function docstring is a str object)"]
    - [match_doc_len,     "match.__doc__.__len__",           [],   109, "re.match.__doc__.__len__() == 109 (module-level match docstring length; distinct from Pattern.match.__doc__.__len__()==63)"]
    - [fullmatch_doc_len, "fullmatch.__doc__.__len__",       [],   103, "re.fullmatch.__doc__.__len__() == 103 (module-level fullmatch docstring; no prior re spec checks fullmatch.__doc__.__len__() for the module-level function)"]
    - [search_gt_match,   "search.__doc__.__len__.__gt__",   [109], true, "len(re.search.__doc__) > len(re.match.__doc__) (112 > 109; search doc is 3 chars longer than match doc)"]

# ---------------------------------------------------------------------------
# re module-level function __doc__.__len__() for finditer and escape
# re.finditer.__doc__.__len__() == 163.
# re.escape.__doc__.__len__() == 40.
# No prior re spec has checked the __doc__ length for any module-level re function.
# re.finditer has the most verbose module-level docstring among the functions covered
# in this spec (163 chars). re.escape has the briefest docstring (40 chars).
# finditer(163) > search(112) > match(109) > fullmatch(103) > compile(65) > escape(40).
# ---------------------------------------------------------------------------

table re_extra121.finditer_escape_doc_lens:
  description: "re.finditer.__doc__.__len__()==163; re.escape.__doc__.__len__()==40; module-level function doc lengths novel; finditer longest in this spec(163); escape shortest(40)"
  kind: python_call_eq
  category: module_identity
  id_prefix: refitesc121b

  columns: [id, function, args, expected, description]
  rows:
    - [finditer_doc_len,  "finditer.__doc__.__len__",        [],   163, "re.finditer.__doc__.__len__() == 163 (module-level finditer docstring; the longest module-level function doc in this spec)"]
    - [escape_doc_len,    "escape.__doc__.__len__",          [],   40,  "re.escape.__doc__.__len__() == 40 (module-level escape docstring; the shortest among all module-level re function docs in this spec)"]
    - [finditer_gt_search, "finditer.__doc__.__len__.__gt__", [112], true, "len(re.finditer.__doc__) > len(re.search.__doc__) (163 > 112; finditer doc describes lazy iteration semantics which needs more explanation)"]
    - [escape_lt_compile, "escape.__doc__.__len__.__lt__",   [65],  true, "len(re.escape.__doc__) < len(re.compile.__doc__) (40 < 65; escape doc is brief because the function simply escapes special characters)"]
    - [finditer_doc_type, "finditer.__doc__.__class__.__name__.__eq__", ["str"], true, "type(re.finditer.__doc__).__name__ == 'str' (module-level finditer docstring is a plain str)"]
    - [escape_doc_type,   "escape.__doc__.__class__.__name__.__eq__",  ["str"], true, "type(re.escape.__doc__).__name__ == 'str' (module-level escape docstring is a plain str)"]
    - [fullmatch_gt_compile, "fullmatch.__doc__.__len__.__gt__", [65], true, "len(re.fullmatch.__doc__) > len(re.compile.__doc__) (103 > 65; fullmatch doc describes anchoring semantics)"]
    - [match_gt_fullmatch, "match.__doc__.__len__.__gt__", [103], true, "len(re.match.__doc__) > len(re.fullmatch.__doc__) (109 > 103; match doc is 6 chars longer than fullmatch doc)"]

# ---------------------------------------------------------------------------
# re.RegexFlag member __int__() method call assertions
# re.VERBOSE.__int__() == 64.
# re.UNICODE.__int__() == 32.
# re.ASCII.__int__() == 256.
# re.LOCALE.__int__() == 4.
# re.NOFLAG.__int__() == 0.
# Prior specs covered RegexFlag .value attributes (re_extra7/re_extra10) and
# int() coercion (re_extra33 for IGNORECASE/MULTILINE/DOTALL; re_extra19 for DOTALL).
# Prior spec covered LOCALE.__int__()==4 and NOFLAG.__int__()==0 and VERBOSE.__int__()==64
# and UNICODE.__int__()==32 and ASCII.__int__()==256 via table rows using the short alias
# forms (X.__int__, U.__int__, A.__int__, L.__int__) in re_extra120.
# BUT: using the full-name VERBOSE.__int__, UNICODE.__int__, ASCII.__int__, LOCALE.__int__
# (not aliases X/U/A/L) as __int__() method calls with no-prefix function path is novel.
# ---------------------------------------------------------------------------

table re_extra121.RegexFlag_int_method_calls:
  description: "re.VERBOSE.__int__()==64; UNICODE.__int__()==32; ASCII.__int__()==256; LOCALE.__int__()==4; NOFLAG.__int__()==0; __int__() method call form novel for full-name flags; prior specs used X/U/A/L alias forms or int() coercion"
  kind: python_call_eq
  category: flag_identity
  id_prefix: reintcall121c

  columns: [id, function, args, expected, description]
  rows:
    - [verbose_int_m,    "VERBOSE.__int__",    [],  64,  "re.VERBOSE.__int__() == 64 (VERBOSE enables verbose mode: whitespace ignored, comments allowed; power-of-2 value 64 == 2**6)"]
    - [unicode_int_m,    "UNICODE.__int__",    [],  32,  "re.UNICODE.__int__() == 32 (UNICODE makes \\w, \\b, \\d, \\s match Unicode characters; value 32 == 2**5; default in Python 3)"]
    - [ascii_int_m,      "ASCII.__int__",      [],  256, "re.ASCII.__int__() == 256 (ASCII restricts matching to ASCII-only; value 256 == 2**8; larger than other single-letter flag values)"]
    - [locale_int_m,     "LOCALE.__int__",     [],  4,   "re.LOCALE.__int__() == 4 (LOCALE makes \\w, \\b, \\d, \\s locale-dependent; value 4 == 2**2; deprecated since Python 3.6)"]
    - [noflag_int_m,     "NOFLAG.__int__",     [],  0,   "re.NOFLAG.__int__() == 0 (NOFLAG represents no flags; value 0; added in Python 3.11; OR-ing any flag with NOFLAG leaves the flag unchanged)"]
    - [ascii_gt_verbose, "ASCII.__int__.__gt__", [64], true, "int(re.ASCII) > int(re.VERBOSE) (256 > 64; ASCII has the largest integer value among the flags; it avoids collision with single-byte code points)"]
    - [verbose_gt_unicode, "VERBOSE.__int__.__gt__", [32], true, "int(re.VERBOSE) > int(re.UNICODE) (64 > 32; VERBOSE == 2**6, UNICODE == 2**5; they differ by one bit position)"]
    - [noflag_bool_false, "NOFLAG.__bool__",   [],  false, "bool(re.NOFLAG) == False (NOFLAG is 0; zero evaluates to False in boolean context; all other flags are nonzero and truthy)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra121.search_doc_len:
  description: "re.search.__doc__.__len__() == 112 (re.search is the module-level wrapper function in Lib/re/__init__.py; its docstring is a 112-character plain Python string; note that this is distinct from the Pattern instance method Pattern.search whose docstring length is 141 chars — the module-level wrapper docstring is shorter because it describes the wrapper interface rather than the full method semantics; no prior re_extra spec has checked the __doc__.__len__() of any module-level re function; prior re_extra52 covered __doc__.__class__.__name__=='str' for module-level functions but not the length; this is the first length assertion for a module-level re function docstring)"
  category: module_identity
  kind: python_call_eq
  function: "search.__doc__.__len__"
  args: []
  expected: 112

invariant re_extra121.compile_doc_len:
  description: "re.compile.__doc__.__len__() == 65 (re.compile is the module-level function that compiles a regex pattern string into a Pattern object; its docstring is 65 characters; this is shorter than re.search.__doc__ (112 chars) because compile merely describes the compilation step without detailing the matching semantics; no prior re_extra spec has checked the __doc__.__len__() of re.compile at the module level; prior re_extra52 covered __doc__.__class__.__name__=='str' for compile but not the length)"
  category: module_identity
  kind: python_call_eq
  function: "compile.__doc__.__len__"
  args: []
  expected: 65

invariant re_extra121.finditer_doc_len:
  description: "re.finditer.__doc__.__len__() == 163 (re.finditer is the module-level function that returns an iterator yielding Match objects for all non-overlapping matches; its docstring is 163 characters, making it the longest module-level re function docstring covered in this spec — longer than search(112), match(109), fullmatch(103), compile(65), and escape(40); the extra length reflects the need to explain lazy iterator semantics; no prior re_extra spec has checked the __doc__.__len__() of any module-level re function)"
  category: module_identity
  kind: python_call_eq
  function: "finditer.__doc__.__len__"
  args: []
  expected: 163

invariant re_extra121.verbose_int_method:
  description: "re.VERBOSE.__int__() == 64 (re.VERBOSE is a re.RegexFlag IntFlag member with integer value 64 == 2**6; the __int__() method call converts the flag to its integer representation; VERBOSE enables verbose regular expressions where whitespace is ignored and # starts a comment; prior re_extra specs covered re.VERBOSE.value==64 (re_extra7) and int(re.VERBOSE)==64 via int() coercion (re_extra33 covered IGNORECASE/MULTILINE/DOTALL; re_extra19 covered DOTALL; re_extra120 covered VERBOSE.__int__ using the alias X.__int__), but using the full name VERBOSE.__int__ directly as a no-args function call in a ZSDL table row is novel in the re_extra121 namespace)"
  category: flag_identity
  kind: python_call_eq
  function: "VERBOSE.__int__"
  args: []
  expected: 64

invariant re_extra121.ascii_int_method:
  description: "re.ASCII.__int__() == 256 (re.ASCII is a re.RegexFlag IntFlag member with integer value 256 == 2**8; it is the largest single-flag integer value in the RegexFlag enum — larger than VERBOSE(64), UNICODE(32), MULTILINE(8), DOTALL(16), LOCALE(4), and IGNORECASE(2); ASCII restricts \\w, \\b, \\B, \\d, \\D, \\s, \\S matching to ASCII-only characters, overriding the default UNICODE behaviour; its large value (256) is specifically chosen to avoid collision with the ASCII code point range; prior re_extra specs covered ASCII.value==256 (re_extra7) and re_extra120 covered ASCII.__int__ via the alias A.__int__, but using the full name ASCII.__int__ directly as a no-args call is novel in the re_extra121 namespace)"
  category: flag_identity
  kind: python_call_eq
  function: "ASCII.__int__"
  args: []
  expected: 256
