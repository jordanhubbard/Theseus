spec: re_extra137
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.error (aliased as re.PatternError in Python 3.13+) exception class hierarchy — __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(), __class__.__name__, and method descriptor identity for __init__ and __str__."
    - "In Python 3.13+, re.error.__name__ == 'PatternError' (length 12) — the class was renamed from 'error' to 'PatternError'; re.error remains as an alias."
    - "re.error.__module__ == 're' (length 2) — PatternError is defined in the pure Python re module."
    - "re.error.__qualname__ == 'PatternError' (length 12) — qualname uses the canonical class name, not the alias 're.error'."
    - "re.error.__bases__[0].__name__ == 'Exception' (length 9) — PatternError directly extends Exception."
    - "re.error.__mro__.__len__() == 4 — MRO is [PatternError, Exception, BaseException, object]."
    - "re.error.__class__.__name__ == 'type' — PatternError is a pure Python class whose metaclass is the built-in 'type'."
    - "re.error.__init__.__class__.__name__ == 'function' — __init__ is a pure Python function (PatternError defines its own __init__)."
    - "re.error.__init__.__qualname__ == 'PatternError.__init__' (length 21)."
    - "re.error.__str__.__class__.__name__ == 'wrapper_descriptor' — __str__ is inherited from BaseException as a slot wrapper."
    - "re.PatternError is re.error evaluates to True — they are the same object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.error class identity (PatternError in Python 3.13+)
# __name__ == 'PatternError' (12), __module__ == 're' (2),
# __qualname__ == 'PatternError' (12).
# __bases__[0].__name__ == 'Exception' (9). MRO length == 4.
# __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

table re_extra137.error_class_identity:
  description: "re.error class identity: __name__='PatternError' (12), __module__='re' (2), __qualname__='PatternError' (12), __bases__[0].__name__='Exception' (9), __mro__.__len__()==4, __class__.__name__='type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: reerr137

  columns: [id, function, args, expected]
  rows:
    - [err_name_eq,      error.__name__.__eq__,                   ["PatternError"], true]
    - [err_name_not_err, error.__name__.__eq__,                   ["error"],        false]
    - [err_name_len,     error.__name__.__len__,                  [],               12]
    - [err_module_eq,    error.__module__.__eq__,                 ["re"],           true]
    - [err_module_len,   error.__module__.__len__,                [],               2]
    - [err_qualname_eq,  error.__qualname__.__eq__,               ["PatternError"], true]
    - [err_qualname_len, error.__qualname__.__len__,              [],               12]
    - [err_base_eq,      "error.__bases__[0].__name__.__eq__",    ["Exception"],    true]
    - [err_base_len,     "error.__bases__[0].__name__.__len__",   [],               9]
    - [err_mro_len,      error.__mro__.__len__,                   [],               4]
    - [err_cls_eq,       error.__class__.__name__.__eq__,         ["type"],         true]

# ---------------------------------------------------------------------------
# re.error MRO member names
# MRO is [PatternError, Exception, BaseException, object].
# Check qualname and module for Exception and BaseException.
# ---------------------------------------------------------------------------

table re_extra137.error_mro_member_names:
  description: "re.error MRO member names: mro[1]='Exception', mro[2]='BaseException', mro[3]='object'; Exception and BaseException are from builtins"
  kind: python_call_eq
  category: class_identity
  id_prefix: reerr137

  columns: [id, function, args, expected]
  rows:
    - [mro0_eq,   "error.__mro__[0].__name__.__eq__",  ["PatternError"],  true]
    - [mro1_eq,   "error.__mro__[1].__name__.__eq__",  ["Exception"],     true]
    - [mro2_eq,   "error.__mro__[2].__name__.__eq__",  ["BaseException"], true]
    - [mro3_eq,   "error.__mro__[3].__name__.__eq__",  ["object"],        true]
    - [mro1_mod,  "error.__mro__[1].__module__.__eq__", ["builtins"],     true]
    - [mro2_mod,  "error.__mro__[2].__module__.__eq__", ["builtins"],     true]

# ---------------------------------------------------------------------------
# re.error method descriptor identity
# __init__ is a pure Python function (PatternError defines its own __init__).
# __str__ is a wrapper_descriptor inherited from BaseException.
# __init__.__qualname__ == 'PatternError.__init__' (21).
# __str__.__qualname__ == 'BaseException.__str__' (21).
# ---------------------------------------------------------------------------

table re_extra137.error_method_descriptor_classes:
  description: "re.error method descriptor __class__.__name__: __init__='function' (own pure Python __init__), __str__='wrapper_descriptor' (inherited from BaseException)"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: reerr137

  columns: [id, function, args, expected]
  rows:
    - [init_cls_eq,     error.__init__.__class__.__name__.__eq__, ["function"],          true]
    - [init_cls_not_wd, error.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], false]
    - [str_cls_eq,      error.__str__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [str_cls_not_fn,  error.__str__.__class__.__name__.__eq__,  ["function"],           false]
    - [init_qn_eq,      error.__init__.__qualname__.__eq__,       ["PatternError.__init__"], true]
    - [init_qn_len,     error.__init__.__qualname__.__len__,      [],                    21]
    - [str_qn_eq,       error.__str__.__qualname__.__eq__,        ["BaseException.__str__"], true]
    - [str_qn_len,      error.__str__.__qualname__.__len__,       [],                    21]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra137.error.name_is_PatternError:
  description: "re.error.__name__ == 'PatternError' (length 12; in Python 3.13+ the exception was renamed from 'error' to 'PatternError', with re.error kept as an alias)"
  category: class_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra137.error.module_is_re:
  description: "re.error.__module__ == 're' (length 2; PatternError is defined in the pure Python re module, Lib/re/__init__.py)"
  category: class_identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra137.error.mro_len_4:
  description: "re.error.__mro__.__len__() == 4 (MRO is [PatternError, Exception, BaseException, object])"
  category: class_identity
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 4

invariant re_extra137.error.init_is_function:
  description: "re.error.__init__.__class__.__name__ == 'function' (PatternError defines its own __init__ as a pure Python function, setting msg, pattern, pos, etc.)"
  category: method_descriptor
  kind: python_call_eq
  function: error.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant re_extra137.error.init_qualname_len_21:
  description: "re.error.__init__.__qualname__.__len__() == 21 ('PatternError.__init__' is 21 chars: 'PatternError' (12) + '.' (1) + '__init__' (8))"
  category: method_descriptor
  kind: python_call_eq
  function: error.__init__.__qualname__.__len__
  args: []
  expected: 21

