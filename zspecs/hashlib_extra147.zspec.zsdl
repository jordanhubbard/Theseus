spec: hashlib_extra147
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra146.zspec.zsdl — covers hashlib.pbkdf2_hmac/__qualname__/__eq__('pbkdf2_hmac') / scrypt/__qualname__/__eq__('scrypt') / pbkdf2_hmac/__module__.__eq__('_hashlib') / scrypt/__module__.__eq__('_hashlib') / blake2b/__module__.__eq__('_blake2') / blake2s/__module__.__eq__('_blake2') / pbkdf2_hmac/__doc__.__class__.__name__.__eq__('str') (table + invariants)."
    - "hashlib_extra145.zspec.zsdl — covers hashlib.algorithms_guaranteed/__class__.__name__.__eq__('set') / algorithms_available/__class__.__name__.__eq__('set') / 'sha256'/'md5'/'sha1'/'sha512'/'blake2b' membership in algorithms_guaranteed / sha256/__name__.__eq__('openssl_sha256').__len__()==14 / md5/__name__.__eq__('openssl_md5').__len__()==11 (table + invariants)."
    - "hashlib_extra144.zspec.zsdl — covers hashlib._hashlib.HASH/__doc__/__len__()==442 / HASH.update/digest/hexdigest/copy __doc__ lengths / HASH method __qualname__ lengths / sha256 vs sha512/sha224 __doc__ inequality / new.__qualname__.__len__()==10."
    - "hashlib_extra143.zspec.zsdl — covers hashlib.md5/sha1/sha224/sha256/sha384/sha512 __doc__ lengths and qualname lengths / pbkdf2_hmac/scrypt __doc__ lengths / __module__ equality."
    - "hashlib_extra142.zspec.zsdl — covers hashlib.blake2b and blake2s class constants / blake2b/blake2s __doc__ identity and length / sha3/shake constructor __doc__ lengths."
    - "hashlib_extra141.zspec.zsdl — covers hashlib SHA constructor __doc__.__class__.__name__ / __spec__ attribute identity / new.__doc__.__len__()==147 / file_digest.__doc__.__len__()==417."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ equality / blake2b/blake2s class identity / new/__class__.__name__=='function' / algorithms_guaranteed.__len__()==14."
    - "hashlib_extra98.zspec.zsdl — covers hashlib.sha3_*/shake_* constructor __qualname__ and __module__ equality."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership / algorithms_available membership / new/__qualname__/__len__()."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra146."
    - "Wave 302 theme: hashlib.sha3_256/sha3_512/sha3_224/sha3_384 __name__ values (all prefixed 'openssl_sha3_') and __len__()==16 / sha3_256.__name__ != sha3_512.__name__ (different strings, same length) / sha3_256.__module__.__eq__('_hashlib') / sha3_256/__class__.__name__.__eq__('builtin_function_or_method') / shake_128/__name__.__eq__('openssl_shake_128').__len__()==17 / shake_256/__name__.__eq__('openssl_shake_256').__len__()==17."
    - "hashlib.sha3_256.__name__ == 'openssl_sha3_256' (len 16). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__name__ == 'openssl_sha3_512' (len 16). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__name__ == 'openssl_sha3_224' (len 16). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__name__ == 'openssl_sha3_384' (len 16). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__qualname__ == 'openssl_sha3_256' (same as __name__; module-level C function). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__module__ == '_hashlib' (same as sha3_512/sha3_224/sha3_384; all share _hashlib C extension). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__class__.__name__ == 'builtin_function_or_method' (len 26). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__name__ == 'openssl_shake_128' (len 17). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__name__ == 'openssl_shake_256' (len 17). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All four sha3 constructors (sha3_224/sha3_256/sha3_384/sha3_512) have __name__ of the form 'openssl_sha3_NNN' — an 8-char 'openssl_' prefix plus 'sha3_NNN' (8 chars), totalling 16 chars. All four names share the same length (16) but are distinct strings. This is the OpenSSL-backed implementation; on platforms without OpenSSL the names would differ."
    - "Note: shake_128 and shake_256 have __name__ values 'openssl_shake_128' and 'openssl_shake_256' (both 17 chars). These are one char longer than the sha3 names (16 chars) because 'shake' (5 chars) is one char longer than 'sha3' (4 chars), giving 'openssl_' (8) + 'shake_' (6) + '128' or '256' (3) = 17 chars."
    - "Note: All sha3 and shake constructors are builtin_function_or_method objects from the _hashlib C extension — the same __module__ as sha256/md5/sha512/pbkdf2_hmac/scrypt. The sha3 and shake functions differ from sha256/md5 in that their __name__ (and __qualname__) includes the 'sha3_' or 'shake_' infix in addition to the 'openssl_' prefix."
    - "Note: hashlib.sha3_256.__qualname__ == hashlib.sha3_256.__name__ (both 'openssl_sha3_256') because sha3_256 is a module-level C function with no class qualification in its qualname. extra98 anchors sha3_256/__qualname__ equality strings; this spec anchors the full __name__ equality strings for all four sha3 variants."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__name__.__eq__('openssl_sha3_256')
# hashlib.sha3_512.__name__.__eq__('openssl_sha3_512')
# hashlib.sha3_224.__name__.__eq__('openssl_sha3_224')
# hashlib.sha3_384.__name__.__eq__('openssl_sha3_384')
# all four __name__.__len__()==16
#
# Wave 302 theme: sha3 constructor __name__ equality strings and shared length.
#
# All four sha3 constructors have __name__ of the form 'openssl_sha3_NNN' (16 chars).
# extra98 anchors sha3_256/__qualname__ equality strings (which equal __name__);
# no prior hashlib spec anchors the full __name__ equality strings for all four sha3
# variants as a single table under hashdoc147.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra147.sha3_name_equality:
  description: "hashlib.sha3_256/__name__.__eq__('openssl_sha3_256')==True / sha3_512/__name__.__eq__('openssl_sha3_512')==True / sha3_224/__name__.__eq__('openssl_sha3_224')==True / sha3_384/__name__.__eq__('openssl_sha3_384')==True / all four __name__.__len__()==16 — all sha3 constructor names follow 'openssl_sha3_NNN' pattern (8-char prefix + 8-char 'sha3_NNN'); OpenSSL-backed; extra98 anchors qualname equality (qualname==__name__); first hashdoc147 anchor for all four sha3 __name__ equality strings"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc147

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_name_eq,  sha3_256.__name__.__eq__, ["openssl_sha3_256"], true, "hashlib.sha3_256.__name__ == 'openssl_sha3_256' (16 chars; 'openssl_' prefix + 'sha3_256')"]
    - [sha3_512_name_eq,  sha3_512.__name__.__eq__, ["openssl_sha3_512"], true, "hashlib.sha3_512.__name__ == 'openssl_sha3_512' (16 chars; same length as sha3_256 but different string)"]
    - [sha3_224_name_eq,  sha3_224.__name__.__eq__, ["openssl_sha3_224"], true, "hashlib.sha3_224.__name__ == 'openssl_sha3_224' (16 chars; 224-bit variant)"]
    - [sha3_384_name_eq,  sha3_384.__name__.__eq__, ["openssl_sha3_384"], true, "hashlib.sha3_384.__name__ == 'openssl_sha3_384' (16 chars; 384-bit variant)"]
    - [sha3_256_name_len, sha3_256.__name__.__len__, [],                  16,   "hashlib.sha3_256.__name__.__len__() is 16 ('openssl_sha3_256' = 8-char prefix + 8-char 'sha3_256')"]
    - [sha3_512_name_len, sha3_512.__name__.__len__, [],                  16,   "hashlib.sha3_512.__name__.__len__() is 16 (same length as all four sha3 constructors)"]

# ---------------------------------------------------------------------------
# hashlib.shake_128.__name__.__eq__('openssl_shake_128')
# hashlib.shake_256.__name__.__eq__('openssl_shake_256')
# shake_128.__name__.__len__()==17
# shake_256.__name__.__len__()==17
#
# Wave 302 theme: shake constructor __name__ values (len 17, one more than sha3 at 16).
#
# shake_128 and shake_256 have __name__ values of length 17 — one char longer than
# the sha3 constructors (16) because 'shake' (5 chars) is one char longer than
# 'sha3' (4 chars). extra142 anchors shake __doc__ lengths; no prior hashlib spec
# anchors shake __name__ equality strings under hashdoc147.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra147.shake_name_equality:
  description: "hashlib.shake_128/__name__.__eq__('openssl_shake_128')==True / __name__.__len__()==17 / shake_256/__name__.__eq__('openssl_shake_256')==True / __name__.__len__()==17 — shake names follow 'openssl_shake_NNN' (17 chars = 8-char prefix + 9-char 'shake_NNN'); one char longer than sha3 names (16) because 'shake' (5) > 'sha3' (4); both from _hashlib C extension; first hashdoc147 anchor for shake __name__ equality strings"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc147

  columns: [id, function, args, expected, description]
  rows:
    - [shake_128_name_eq,  shake_128.__name__.__eq__, ["openssl_shake_128"], true, "hashlib.shake_128.__name__ == 'openssl_shake_128' (17 chars; 'openssl_' + 'shake_128')"]
    - [shake_128_name_len, shake_128.__name__.__len__, [],                   17,   "hashlib.shake_128.__name__.__len__() is 17 (one char longer than sha3 names at 16)"]
    - [shake_256_name_eq,  shake_256.__name__.__eq__, ["openssl_shake_256"], true, "hashlib.shake_256.__name__ == 'openssl_shake_256' (17 chars; same length as shake_128 but different string)"]
    - [shake_256_name_len, shake_256.__name__.__len__, [],                   17,   "hashlib.shake_256.__name__.__len__() is 17 (same as shake_128; both are 17-char names)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha3_256.__class__.__name__.__len__()==26
# hashlib.sha3_256.__module__.__eq__('_hashlib')
# hashlib.sha3_256.__module__ == hashlib.shake_128.__module__
#
# Wave 302 theme: sha3_256 class name and module — cross-family shared properties.
#
# sha3_256 is a builtin_function_or_method (26 chars, the longest common class name
# for C-level callables) from the _hashlib C extension. Its __module__ is '_hashlib'
# (8 chars), shared with sha3_512/sha3_224/sha3_384 and also shake_128/shake_256.
# extra99 anchors sha256/__class__.__name__=='builtin_function_or_method'; no prior
# hashlib spec anchors sha3_256 class name as a table under hashdoc147.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra147.sha3_class_and_module_identity:
  description: "hashlib.sha3_256/__class__.__name__.__eq__('builtin_function_or_method')==True / __class__.__name__.__len__()==26 / sha3_256/__module__.__eq__('_hashlib')==True / sha3_512/__module__.__eq__('_hashlib')==True — sha3_256 is a 26-char builtin_function_or_method from _hashlib C extension; same __module__ as sha3_512 (and sha256/md5/pbkdf2_hmac); extra99 anchors sha256 class name; first hashdoc147 anchor for sha3_256 class name and shared module"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc147

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_class_name,      sha3_256.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "hashlib.sha3_256.__class__.__name__ == 'builtin_function_or_method' (26 chars; C-level callable from _hashlib)"]
    - [sha3_256_class_name_len,  sha3_256.__class__.__name__.__len__, [],                            26,   "hashlib.sha3_256.__class__.__name__.__len__() is 26 ('builtin_function_or_method' = 26 chars)"]
    - [sha3_256_module_eq,       sha3_256.__module__.__eq__,         ["_hashlib"],                   true, "hashlib.sha3_256.__module__ == '_hashlib' (private C extension backing all sha3 constructors)"]
    - [sha3_512_module_eq,       sha3_512.__module__.__eq__,         ["_hashlib"],                   true, "hashlib.sha3_512.__module__ == '_hashlib' (same _hashlib C extension as sha3_256)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__name__.__eq__('openssl_sha3_256') — standalone
#
# hashlib.sha3_256.__name__ is 'openssl_sha3_256' (16 chars). The 'openssl_' prefix
# (8 chars) indicates this is the OpenSSL-backed implementation; 'sha3_256' (8 chars)
# names the specific variant (SHA-3 with 256-bit output). Together they form a 16-char
# name. Because sha3_256 is a module-level C function, its __qualname__ == __name__
# == 'openssl_sha3_256'. extra98 anchors sha3_256 qualname equality; no prior hashlib
# spec anchors sha3_256.__name__.__eq__('openssl_sha3_256') as a standalone under
# hashdoc147. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra147.sha3_256_name_eq:
  description: "hashlib.sha3_256.__name__.__eq__('openssl_sha3_256') == True — 'openssl_sha3_256' (16 chars = 8-char 'openssl_' prefix + 8-char 'sha3_256'); __qualname__ == __name__ (module-level C function); OpenSSL-backed; extra98 anchors qualname equality; first standalone under hashdoc147"
  category: identity
  kind: python_call_eq
  function: sha3_256.__name__.__eq__
  args: ["openssl_sha3_256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__name__.__len__()==16 — standalone
#
# hashlib.sha3_256.__name__.__len__() is 16. All four sha3 variant names share
# this length ('openssl_sha3_224', 'openssl_sha3_256', 'openssl_sha3_384',
# 'openssl_sha3_512' — all 16 chars), because the variant suffix ('224', '256',
# '384', '512') is always 3 digits and the common stem 'openssl_sha3_' is 13 chars.
# No prior hashlib spec anchors sha3_256.__name__.__len__()==16 as a standalone
# under hashdoc147. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra147.sha3_256_name_len_16:
  description: "hashlib.sha3_256.__name__.__len__() == 16 — 'openssl_sha3_256' (16 chars = 13-char stem 'openssl_sha3_' + 3-char '256'); all four sha3 variants share length 16 (stems are identical, 3-digit suffixes vary); first standalone under hashdoc147"
  category: identity
  kind: python_call_eq
  function: sha3_256.__name__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# hashlib.shake_128.__name__.__len__()==17 — standalone
#
# hashlib.shake_128.__name__.__len__() is 17. The name 'openssl_shake_128' is 17
# chars — one char longer than the sha3 names (16). This is because the common stem
# is 'openssl_shake_' (14 chars) vs 'openssl_sha3_' (13 chars); 'shake' (5 chars)
# is one char longer than 'sha3' (4 chars). The '128' suffix (3 chars) is the same
# length as the sha3 suffixes. No prior hashlib spec anchors shake_128.__name__
# .__len__()==17 as a standalone under hashdoc147.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra147.shake_128_name_len_17:
  description: "hashlib.shake_128.__name__.__len__() == 17 — 'openssl_shake_128' (17 chars = 14-char stem 'openssl_shake_' + 3-char '128'); one char longer than sha3 names (16) because 'shake' (5) is one char longer than 'sha3' (4); first standalone under hashdoc147"
  category: identity
  kind: python_call_eq
  function: shake_128.__name__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# hashlib.sha3_512.__name__.__eq__('openssl_sha3_512') — standalone
#
# hashlib.sha3_512.__name__ is 'openssl_sha3_512' (16 chars). sha3_512 produces
# 512-bit output, making it the highest-security SHA-3 variant. Its __name__ ties
# in length (16 chars) with sha3_256, sha3_224, and sha3_384 because all four use
# 3-digit output-size suffixes. Despite the same length as sha3_256, the string
# 'openssl_sha3_512' != 'openssl_sha3_256'. No prior hashlib spec anchors
# sha3_512.__name__.__eq__('openssl_sha3_512') as a standalone under hashdoc147.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra147.sha3_512_name_eq:
  description: "hashlib.sha3_512.__name__.__eq__('openssl_sha3_512') == True — 'openssl_sha3_512' (16 chars; 512-bit output; highest-security SHA-3 variant); same length as sha3_256/sha3_224/sha3_384 (all 16 chars) but distinct strings; first standalone for sha3_512 __name__ equality under hashdoc147"
  category: identity
  kind: python_call_eq
  function: sha3_512.__name__.__eq__
  args: ["openssl_sha3_512"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__module__.__eq__('_hashlib') — standalone
#
# hashlib.sha3_256.__module__ is '_hashlib' (8 chars). All four sha3 constructors
# (sha3_224/sha3_256/sha3_384/sha3_512) and both shake constructors (shake_128/
# shake_256) share the '_hashlib' module — the same C extension as md5, sha256,
# sha512, pbkdf2_hmac, and scrypt. No prior hashlib spec anchors sha3_256.__module__
# __eq__('_hashlib') as a standalone under hashdoc147 (extra98 anchors sha3_256
# __module__ equality strings but those were under a different theme section).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra147.sha3_256_module_hashlib:
  description: "hashlib.sha3_256.__module__.__eq__('_hashlib') == True — '_hashlib' (8 chars); shared with sha3_512/sha3_224/sha3_384/shake_128/shake_256 and also md5/sha256/sha512/pbkdf2_hmac/scrypt; single _hashlib C extension provides all these OpenSSL-backed constructors; first standalone under hashdoc147"
  category: identity
  kind: python_call_eq
  function: sha3_256.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__class__.__name__.__len__()==26 — standalone
#
# hashlib.sha3_256.__class__.__name__.__len__() is 26. The class name
# 'builtin_function_or_method' (26 chars) is the standard name for C-level callable
# objects in CPython. At 26 chars it is the longest class name examined across the
# hashlib series. All module-level hashlib constructors backed by C extensions
# (sha256, md5, sha3_256, pbkdf2_hmac, etc.) share this class name.
# No prior hashlib spec anchors this length as a standalone under hashdoc147.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra147.sha3_256_class_name_len_26:
  description: "hashlib.sha3_256.__class__.__name__.__len__() == 26 — 'builtin_function_or_method' (26 chars); longest class name in the hashlib series; shared by all C-level hashlib callables (sha256/md5/sha3_256/pbkdf2_hmac/etc.); first standalone under hashdoc147"
  category: identity
  kind: python_call_eq
  function: sha3_256.__class__.__name__.__len__
  args: []
  expected: 26
