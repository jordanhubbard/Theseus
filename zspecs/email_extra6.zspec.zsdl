spec: email_extra6
version: ">=3.6"
backend: python_module(email)

docs: https://docs.python.org/3/library/email.html

provenance:
  derived_from:
    - "Python 3 email package documentation — https://docs.python.org/3/library/email.html"
    - "Python 3 email.utils documentation — https://docs.python.org/3/library/email.utils.html"
    - "Python 3 email.errors documentation — https://docs.python.org/3/library/email.errors.html"
    - "Python 3 email.policy documentation — https://docs.python.org/3/library/email.policy.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/email/__init__.py"
    - "email_extra.zspec.zsdl — covers email.__name__; message_from_string/bytes/file/binary_file __name__ and parsing behavior"
    - "email_extra2.zspec.zsdl — covers email.policy class names, SMTP/SMTPUTF8/HTTP instance class names, email.errors class names, email.contentmanager.get_content_manager name, email.generator class names/modules, SMTPUTF8.utf8, SMTP.linesep"
    - "email_extra3.zspec.zsdl — covers message_from_* __qualname__ and __module__; email.__spec__.name; email.message.Message/EmailMessage __name__ via email.message chain"
    - "email_extra4.zspec.zsdl — covers email.policy EmailPolicy/Policy/Compat32 qualnames; EmailPolicy/Policy __module__; email.errors MessageError/HeaderParseError/MessageDefect qualnames and __module__; Generator/BytesGenerator qualnames and hierarchy; email.utils parseaddr/formataddr qualnames and __module__; email.headerregistry.Address name/qualname/module"
    - "email_extra5.zspec.zsdl — covers email.headerregistry.Group name/qualname/module; Address.__bases__[0].__name__; errors BoundaryError/CharsetError/MultipartConversionError qualnames; BoundaryError/CharsetError __module__; Compat32.__module__; contentmanager.get_content_manager qualname/module"
  notes:
    - "This spec extends email_extra.zspec.zsdl through email_extra5.zspec.zsdl."
    - "Focus: new axes not yet tested in any prior email spec."
    - "email.utils parsedate/formatdate/make_msgid — extra4 covers parseaddr/formataddr qualname/module; parsedate/formatdate/make_msgid qualname and module via email backend are new."
    - "email.errors base hierarchy — no prior spec tests what MessageError and HeaderParseError inherit from (accessed via email backend); extra4/5 only cover their qualnames/modules."
    - "email.errors.MultipartConversionError.__module__ — extra5 covers its __qualname__ but not __module__."
    - "email.message.Message.__module__ and EmailMessage.__module__ — extra3 covers their __name__; __module__ via email backend is new."
    - "email.policy.SMTP.max_line_length — extra2 covers SMTP.linesep; max_line_length is a distinct policy attribute not tested."
    - "email.policy.HTTP.max_line_length — HTTP policy has max_line_length=None (unlimited); not tested in any prior spec."
    - "email.headerregistry.Group.__bases__[0].__name__ — extra5 covers Group name/qualname/module but not its base."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# email.utils — additional functions: parsedate, formatdate, make_msgid
# email_extra4 covers parseaddr/formataddr qualname and __module__.
# parsedate/formatdate/make_msgid qualname and __module__ are new.
# ---------------------------------------------------------------------------

table email_extra6.utils_extra_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: uqname

  columns: [id, function, args, expected]
  rows:
    - [parsedate,  utils.parsedate.__qualname__.__eq__,  ["parsedate"],  true]
    - [formatdate, utils.formatdate.__qualname__.__eq__, ["formatdate"], true]
    - [make_msgid, utils.make_msgid.__qualname__.__eq__, ["make_msgid"], true]

table email_extra6.utils_extra_modules:
  kind: python_call_eq
  category: modules
  id_prefix: umod

  columns: [id, function, args, expected]
  rows:
    - [parsedate,  utils.parsedate.__module__.__eq__,  ["email.utils"], true]
    - [formatdate, utils.formatdate.__module__.__eq__, ["email.utils"], true]
    - [make_msgid, utils.make_msgid.__module__.__eq__, ["email.utils"], true]

# ---------------------------------------------------------------------------
# email.errors base hierarchy — MessageError and HeaderParseError bases
# No prior spec tests what these classes inherit from via the email backend.
# email.errors.MessageError.__bases__[0].__name__ == 'Exception'
# email.errors.HeaderParseError.__bases__[0].__name__ == 'MessageParseError'
#   (HeaderParseError -> MessageParseError -> MessageError -> Exception)
# ---------------------------------------------------------------------------

invariant email_extra6.errors.MessageError.base:
  description: "email.errors.MessageError.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: errors.MessageError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant email_extra6.errors.HeaderParseError.base:
  description: "email.errors.HeaderParseError.__bases__[0].__name__ == 'MessageParseError'"
  category: hierarchy
  kind: python_call_eq
  function: errors.HeaderParseError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "MessageParseError"

# ---------------------------------------------------------------------------
# email.errors.MultipartConversionError.__module__
# email_extra5 covers MultipartConversionError.__qualname__ but not __module__.
# ---------------------------------------------------------------------------

invariant email_extra6.errors.MultipartConversionError.module:
  description: "email.errors.MultipartConversionError.__module__ == 'email.errors'"
  category: modules
  kind: python_call_eq
  function: errors.MultipartConversionError.__module__.__eq__
  args: ["email.errors"]
  expected: true

# ---------------------------------------------------------------------------
# email.message.Message and EmailMessage __module__
# email_extra3 checks their __name__ via email.message attribute chain.
# __module__ via the same chain is new.
# ---------------------------------------------------------------------------

invariant email_extra6.message.Message.module:
  description: "email.message.Message.__module__ == 'email.message'"
  category: modules
  kind: python_call_eq
  function: message.Message.__module__.__eq__
  args: ["email.message"]
  expected: true

invariant email_extra6.message.EmailMessage.module:
  description: "email.message.EmailMessage.__module__ == 'email.message'"
  category: modules
  kind: python_call_eq
  function: message.EmailMessage.__module__.__eq__
  args: ["email.message"]
  expected: true

# ---------------------------------------------------------------------------
# email.policy SMTP and HTTP max_line_length
# email_extra2 tests SMTP.linesep == '\r\n'. max_line_length is a distinct
# policy attribute controlling line wrapping. Not tested in any prior spec.
# SMTP.max_line_length == 998 (RFC 5321 limit).
# HTTP.max_line_length == None (no limit; HTTP streaming does not wrap).
# ---------------------------------------------------------------------------

invariant email_extra6.policy.SMTP.max_line_length:
  description: "email.policy.SMTP.max_line_length == 998"
  category: policy
  kind: python_call_eq
  function: policy.SMTP.max_line_length.__eq__
  args: [998]
  expected: true

invariant email_extra6.policy.HTTP.max_line_length_is_none:
  description: "email.policy.HTTP.max_line_length is None"
  category: policy
  kind: python_call_eq
  function: policy.HTTP.max_line_length.__eq__
  args: [~]
  expected: true

# ---------------------------------------------------------------------------
# email.headerregistry.Group base hierarchy
# email_extra5 covers Group __name__/__qualname__/__module__.
# The base class (Group inherits from object) is new.
# ---------------------------------------------------------------------------

invariant email_extra6.headerregistry.Group.base:
  description: "email.headerregistry.Group.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: headerregistry.Group.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
