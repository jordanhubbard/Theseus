spec: uuid_extra24
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra23.zspec.zsdl — covers UUID.__dict__.__class__.__name__.__len__()==12; UUID.hex/bytes/bytes_le.fget.__qualname__.__len__(); NAMESPACE_DNS/URL __class__.__name__.__len__()==4; RFC_4122.__class__.__name__.__len__()==3; RFC_4122.__len__()==21; uuid1/3/4/5 __qualname__.__len__()==5."
    - "uuid_extra22.zspec.zsdl — covers UUID.__mro__.__len__()==2; UUID.__str__/__repr__/__hash__/__eq__ __qualname__.__len__(); UUID.__slots__.__class__.__name__/.__len__()==3; UUID.hex.__class__.__name__=='property'; UUID.__bases__[0].__name__=='object'."
    - "uuid_extra18.zspec.zsdl — covers UUID.__module__/__bases__[0].__name__; uuid1/3/4/5 __module__; UUID property fget __qualname__ values and lengths for hex/bytes/urn/version/bytes_le/fields/variant."
  notes:
    - "This spec extends uuid through uuid_extra23; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: uuid4() type, UUID fields, UUID.__name__/__module__/__qualname__, uuid.__name__/__package__, uuid1/3/4/5 __name__/__module__/__qualname__, NAMESPACE_DNS/URL/OID/X500 class names, UUID.__bases__[0].__name__, UUID.__init__/__name__/__qualname__, UUID.hex length/urn prefix, UUID integer attributes, UUID property fget __qualname__ values/lengths for hex/bytes/bytes_le/urn/version/fields/variant (extra18/extra23), UUID.__slots__/__mro__/__dict__ properties (extra22/extra23), RFC_4122 length/class (extra23)."
    - "This spec covers: uuid.SafeUUID.__name__.__len__() (NOVEL — 'SafeUUID' is 8 chars; no prior uuid spec checks SafeUUID at all); uuid.SafeUUID.__qualname__.__len__() (NOVEL — same 8); uuid.SafeUUID.__mro__.__len__() (NOVEL — [SafeUUID, Enum, object] has depth 3); uuid.SafeUUID.__bases__[0].__name__.__len__() (NOVEL — 'Enum' is 4 chars); uuid.getnode.__name__.__len__() (NOVEL — 'getnode' is 7 chars; no prior uuid spec checks getnode); uuid.getnode.__qualname__.__len__() (NOVEL — same 7); uuid.getnode.__module__.__len__() (NOVEL — 'uuid' is 4 chars); UUID.node.fget.__qualname__.__len__() (NOVEL — 'UUID.node' is 9 chars; extra18 covers hex/bytes/urn/version/bytes_le/fields/variant but NOT node/time/clock_seq); UUID.time.fget.__qualname__.__len__() (NOVEL — 'UUID.time' is 9 chars); UUID.clock_seq.fget.__qualname__.__len__() (NOVEL — 'UUID.clock_seq' is 14 chars); UUID.time_hi_version.fget.__qualname__.__len__() (NOVEL — 'UUID.time_hi_version' is 20 chars); UUID.clock_seq_hi_variant.fget.__qualname__.__len__() (NOVEL — 'UUID.clock_seq_hi_variant' is 25 chars; longest UUID property fget qualname)."
    - "uuid.SafeUUID is an Enum subclass added in Python 3.7 to indicate whether a UUID was generated safely. SafeUUID.__mro__ == [SafeUUID, Enum, object] — depth 3. No prior uuid spec references SafeUUID at all. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' (len 4). SafeUUID inherits directly from Enum (not IntEnum or any other variant). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "uuid.getnode() is a module-level function that returns the hardware address as an integer. Its __name__ == __qualname__ == 'getnode' (len 7) and __module__ == 'uuid' (len 4). No prior uuid spec touches getnode at all. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "UUID.node.fget.__qualname__ == 'UUID.node' (len 9). extra18 covers property fget qualname lengths for hex(8)/bytes(10)/urn(8)/version(12)/bytes_le(13)/fields(11)/variant(12). node, time, clock_seq, time_hi_version, and clock_seq_hi_variant are all absent from prior specs. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "UUID.clock_seq.fget.__qualname__ == 'UUID.clock_seq' (len 14). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "UUID.time_hi_version.fget.__qualname__ == 'UUID.time_hi_version' (len 20). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "UUID.clock_seq_hi_variant.fget.__qualname__ == 'UUID.clock_seq_hi_variant' (len 25). This is the longest UUID property fget qualname due to the verbose RFC 4122 attribute name. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.SafeUUID — class identity (novel: no prior uuid spec touches SafeUUID)
#
# SafeUUID is an Enum subclass added in Python 3.7. It records whether a UUID
# was generated with OS-level safety guarantees. Its MRO is:
#   [SafeUUID, Enum, object] — depth 3.
# __name__ == __qualname__ == 'SafeUUID' (len 8).
# __bases__[0].__name__ == 'Enum' (len 4).
# No prior uuid spec references SafeUUID in any context.
# ---------------------------------------------------------------------------

invariant uuid_extra24.SafeUUID.name_len:
  description: "uuid.SafeUUID.__name__.__len__() == 8 — 'SafeUUID' has 8 characters; no prior uuid spec checks SafeUUID"
  category: class_identity
  kind: python_call_eq
  function: SafeUUID.__name__.__len__
  args: []
  expected: 8

invariant uuid_extra24.SafeUUID.qualname_len:
  description: "uuid.SafeUUID.__qualname__.__len__() == 8 — top-level class, __qualname__ == __name__ == 'SafeUUID'"
  category: class_identity
  kind: python_call_eq
  function: SafeUUID.__qualname__.__len__
  args: []
  expected: 8

invariant uuid_extra24.SafeUUID.mro_len:
  description: "uuid.SafeUUID.__mro__.__len__() == 3 — [SafeUUID, Enum, object]; depth 3 for simple Enum subclass"
  category: class_hierarchy
  kind: python_call_eq
  function: SafeUUID.__mro__.__len__
  args: []
  expected: 3

invariant uuid_extra24.SafeUUID.base_name_len:
  description: "uuid.SafeUUID.__bases__[0].__name__.__len__() == 4 — direct base is 'Enum' (4 chars)"
  category: class_hierarchy
  kind: python_call_eq
  "function": "SafeUUID.__bases__[0].__name__.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# uuid.getnode — function identity (novel: no prior uuid spec touches getnode)
#
# getnode() is a module-level function that returns the hardware (MAC) address
# as a 48-bit integer. Its __name__ == __qualname__ == 'getnode' (len 7) and
# __module__ == 'uuid' (len 4). No prior uuid spec references getnode.
# ---------------------------------------------------------------------------

table uuid_extra24.getnode_identity:
  description: "uuid.getnode __name__/__qualname__/__module__ string lengths — all novel; no prior uuid spec checks getnode"
  kind: python_call_eq
  category: function_identity
  id_prefix: ugni24

  columns: [id, function, args, expected]
  rows:
    - [name_len,    getnode.__name__.__len__,    [], 7]
    - [qualname_len, getnode.__qualname__.__len__, [], 7]
    - [module_len,  getnode.__module__.__len__,  [], 4]

# ---------------------------------------------------------------------------
# Table: UUID property fget __qualname__.__len__() — node/time/clock_seq group
#
# extra18 covers hex(8)/bytes(10)/urn(8)/version(12)/bytes_le(13)/fields(11)/
# variant(12). The remaining UUID properties — node, time, clock_seq,
# time_hi_version, clock_seq_hi_variant — have not been checked in any prior
# uuid spec. This table provides their fget qualname lengths.
#
#   UUID.node                -> 'UUID.node'                -> 9
#   UUID.time                -> 'UUID.time'                -> 9
#   UUID.clock_seq           -> 'UUID.clock_seq'           -> 14
#   UUID.time_hi_version     -> 'UUID.time_hi_version'     -> 20
#   UUID.clock_seq_hi_variant-> 'UUID.clock_seq_hi_variant'-> 25
#
# clock_seq_hi_variant (25 chars) is the longest UUID property fget qualname.
# All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra24.UUID_remaining_property_fget_qualname_lengths:
  description: "UUID.node/time/clock_seq/time_hi_version/clock_seq_hi_variant fget __qualname__.__len__() — novel; extra18 covers hex/bytes/urn/version/bytes_le/fields/variant"
  kind: python_call_eq
  category: method_identity
  id_prefix: urpfqln24

  columns: [id, function, args, expected]
  rows:
    - [node,                     UUID.node.fget.__qualname__.__len__,                     [], 9]
    - [time,                     UUID.time.fget.__qualname__.__len__,                     [], 9]
    - [clock_seq,                UUID.clock_seq.fget.__qualname__.__len__,                [], 14]
    - [time_hi_version,          UUID.time_hi_version.fget.__qualname__.__len__,          [], 20]
    - [clock_seq_hi_variant,     UUID.clock_seq_hi_variant.fget.__qualname__.__len__,     [], 25]
