spec: threading_extra284
version: ">=3.4"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers threading.current_thread(), threading.main_thread(), and threading.get_ident() behavioral contracts in the main thread."
    - "threading.current_thread().__class__.__name__ == '_MainThread' — in the main thread, current_thread() returns a _MainThread instance. Verified with Python 3.14.3."
    - "threading.main_thread().__class__.__name__ == '_MainThread' — main_thread() always returns the _MainThread instance. Verified with Python 3.14.3."
    - "threading.current_thread() is threading.main_thread() == True — when called from the main thread, both functions return the same object. Verified with Python 3.14.3."
    - "threading.current_thread.__class__.__name__ == 'function' — current_thread is a pure-Python function. Verified with Python 3.14.3."
    - "threading.main_thread.__class__.__name__ == 'function' — main_thread is a pure-Python function. Verified with Python 3.14.3."
    - "threading.get_ident.__class__.__name__ == 'builtin_function_or_method' — get_ident is a C-level builtin in _thread. Verified with Python 3.14.3."
    - "threading.get_ident.__module__ == '_thread' — get_ident is implemented in the _thread C extension. Verified with Python 3.14.3."
    - "threading.active_count() == 1 — only the main thread is active at import time in a fresh interpreter. Verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: current_thread and main_thread function identity
#
# current_thread is a pure-Python function in threading module.
# main_thread is a pure-Python function in threading module.
# get_ident is a C builtin in _thread module.
# ---------------------------------------------------------------------------

table threading_extra284.thread_function_identity:
  description: "threading.current_thread, main_thread function identity and threading.get_ident C-builtin identity; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex284fi

  columns: [id, function, args, expected, description]
  rows:
    - [fi_ct_cls,   current_thread.__class__.__name__.__eq__,  ["function"],                    true, "threading.current_thread.__class__.__name__ == 'function' — pure-Python function; verified with Python 3.14.3"]
    - [fi_ct_mod,   current_thread.__module__.__eq__,           ["threading"],                   true, "threading.current_thread.__module__ == 'threading'; verified with Python 3.14.3"]
    - [fi_mt_cls,   main_thread.__class__.__name__.__eq__,      ["function"],                    true, "threading.main_thread.__class__.__name__ == 'function' — pure-Python function; verified with Python 3.14.3"]
    - [fi_mt_mod,   main_thread.__module__.__eq__,              ["threading"],                   true, "threading.main_thread.__module__ == 'threading'; verified with Python 3.14.3"]
    - [fi_gi_cls,   get_ident.__class__.__name__.__eq__,        ["builtin_function_or_method"],  true, "threading.get_ident.__class__.__name__ == 'builtin_function_or_method' — C-level builtin in _thread; verified with Python 3.14.3"]
    - [fi_gi_mod,   get_ident.__module__.__eq__,                ["_thread"],                     true, "threading.get_ident.__module__ == '_thread' — implemented in the _thread C extension; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: current_thread and main_thread return value identity
#
# current_thread().__class__.__name__ == '_MainThread'
# main_thread().__class__.__name__ == '_MainThread'
# current_thread().name == 'MainThread'
# main_thread().name == 'MainThread'
# current_thread().daemon == False
# main_thread().daemon == False
# current_thread().is_alive() == True
# ---------------------------------------------------------------------------

table threading_extra284.main_thread_attributes:
  description: "threading.current_thread() and main_thread() return a _MainThread with name='MainThread', daemon=False, is_alive=True; verified with Python 3.14.3"
  kind: python_call_eq
  category: runtime
  id_prefix: thex284ma

  columns: [id, function, args, method, expected]
  rows:
    - [ma_ct_cls,   current_thread,  [],  __class__.__name__,  "_MainThread"]
    - [ma_mt_cls,   main_thread,     [],  __class__.__name__,  "_MainThread"]
    - [ma_ct_name,  current_thread,  [],  name,                "MainThread"]
    - [ma_mt_name,  main_thread,     [],  name,                "MainThread"]
    - [ma_ct_alive, current_thread,  [],  is_alive,            true]
    - [ma_mt_alive, main_thread,     [],  is_alive,            true]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra284
# ---------------------------------------------------------------------------

invariant threading_extra284.current_thread_class_is_main_thread:
  description: "threading.current_thread().__class__.__name__ == '_MainThread' — in main thread, current_thread returns _MainThread instance; new to extra284"
  category: runtime
  kind: python_call_eq
  function: current_thread
  args: []
  method: __class__.__name__
  expected: "_MainThread"

invariant threading_extra284.main_thread_class_is_main_thread:
  description: "threading.main_thread().__class__.__name__ == '_MainThread' — main_thread() always returns the _MainThread singleton; new to extra284"
  category: runtime
  kind: python_call_eq
  function: main_thread
  args: []
  method: __class__.__name__
  expected: "_MainThread"

invariant threading_extra284.current_thread_name_is_main_thread:
  description: "threading.current_thread().name == 'MainThread' — the main thread's name attribute; new to extra284"
  category: runtime
  kind: python_call_eq
  function: current_thread
  args: []
  method: name
  expected: "MainThread"

invariant threading_extra284.current_thread_is_function:
  description: "threading.current_thread.__class__.__name__ == 'function' — current_thread is a pure-Python function; new to extra284"
  category: identity
  kind: python_call_eq
  function: current_thread.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra284.main_thread_is_function:
  description: "threading.main_thread.__class__.__name__ == 'function' — main_thread is a pure-Python function; new to extra284"
  category: identity
  kind: python_call_eq
  function: main_thread.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra284.get_ident_is_builtin:
  description: "threading.get_ident.__class__.__name__ == 'builtin_function_or_method' — get_ident is a C-level builtin in _thread; new to extra284"
  category: identity
  kind: python_call_eq
  function: get_ident.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant threading_extra284.get_ident_module_is_thread:
  description: "threading.get_ident.__module__ == '_thread' — get_ident is implemented in the _thread C extension; new to extra284"
  category: identity
  kind: python_call_eq
  function: get_ident.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra284.current_thread_module_is_threading:
  description: "threading.current_thread.__module__ == 'threading' — current_thread is defined in the pure-Python threading module; new to extra284"
  category: identity
  kind: python_call_eq
  function: current_thread.__module__.__eq__
  args: ["threading"]
  expected: true
