spec: re_extra253
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers re.Pattern class identity and method identity: match, search, findall, sub, split, finditer, fullmatch."
    - "re.Pattern.__name__ == 'Pattern' (not 're.Pattern'); re.Pattern.__module__ == 're'."
    - "re.Pattern.__bases__[0].__name__ == 'object' — Pattern inherits directly from object."
    - "All re.Pattern methods are C-level method_descriptor objects (not Python functions); their __class__.__name__ is 'method_descriptor'."
    - "re.Pattern method __qualname__ values use the 'Pattern.' prefix (e.g. 'Pattern.match')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.Pattern class identity
#
# re.Pattern is the compiled regular expression class. Its __name__ is
# 'Pattern' (not 're.Pattern'), __module__ is 're', and it inherits directly
# from object.
# ---------------------------------------------------------------------------

table re_extra253.pattern_class_identity:
  description: "re.Pattern class identity — __name__, __module__, __bases__[0]; new to extra253"
  kind: python_call_eq
  category: identity
  id_prefix: rexpci253

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_name,
       "Pattern.__name__.__eq__",
       ["Pattern"],
       true,
       "re.Pattern.__name__.__eq__('Pattern') == True — re.Pattern is the compiled regex class; its __name__ is 'Pattern' (not 're.Pattern'); str.__eq__('Pattern') returns True; new to extra253"]
    - [pattern_module,
       "Pattern.__module__.__eq__",
       ["re"],
       true,
       "re.Pattern.__module__.__eq__('re') == True — re.Pattern is defined in the re module; its __module__ is 're'; str.__eq__('re') returns True; new to extra253"]
    - [pattern_base0,
       "Pattern.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "re.Pattern.__bases__[0].__name__.__eq__('object') == True — re.Pattern inherits directly from object (single inheritance); __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra253"]
    - [pattern_class_of_class,
       "Pattern.__class__.__name__.__eq__",
       ["type"],
       true,
       "re.Pattern.__class__.__name__.__eq__('type') == True — re.Pattern is a class object; its metaclass is the standard 'type'; str.__eq__('type') returns True; new to extra253"]
    - [pattern_name_not_re_dot_pattern,
       "Pattern.__name__.__eq__",
       ["re.Pattern"],
       false,
       "re.Pattern.__name__.__eq__('re.Pattern') == False — the __name__ attribute holds only the simple name 'Pattern', not the qualified 're.Pattern'; str.__eq__('re.Pattern') returns False; new to extra253"]
    - [pattern_module_not_sre,
       "Pattern.__module__.__eq__",
       ["_sre"],
       false,
       "re.Pattern.__module__.__eq__('_sre') == False — re.Pattern.__module__ is 're', not '_sre'; the pattern type is exposed through the re module, not directly through _sre; str.__eq__('_sre') returns False; new to extra253"]

# ---------------------------------------------------------------------------
# Table 2: re.Pattern match and search method identity
#
# match and search are the most commonly used Pattern methods. Both are
# method_descriptors defined in the C extension _sre.
# ---------------------------------------------------------------------------

table re_extra253.pattern_match_search_identity:
  description: "re.Pattern match and search method __name__, __qualname__, __class__.__name__; new to extra253"
  kind: python_call_eq
  category: identity
  id_prefix: rexpmsi253

  columns: [id, function, args, expected, description]
  rows:
    - [match_name,
       "Pattern.match.__name__.__eq__",
       ["match"],
       true,
       "re.Pattern.match.__name__.__eq__('match') == True — Pattern.match matches the pattern only at the beginning of the string; its __name__ is 'match'; str.__eq__('match') returns True; new to extra253"]
    - [match_qualname,
       "Pattern.match.__qualname__.__eq__",
       ["Pattern.match"],
       true,
       "re.Pattern.match.__qualname__.__eq__('Pattern.match') == True — match is defined directly on Pattern; its __qualname__ is 'Pattern.match'; str.__eq__('Pattern.match') returns True; new to extra253"]
    - [match_class,
       "Pattern.match.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "re.Pattern.match.__class__.__name__.__eq__('method_descriptor') == True — Pattern.match is a C-level method_descriptor; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra253"]
    - [search_name,
       "Pattern.search.__name__.__eq__",
       ["search"],
       true,
       "re.Pattern.search.__name__.__eq__('search') == True — Pattern.search scans through the string looking for the first location where the pattern matches; its __name__ is 'search'; str.__eq__('search') returns True; new to extra253"]
    - [search_qualname,
       "Pattern.search.__qualname__.__eq__",
       ["Pattern.search"],
       true,
       "re.Pattern.search.__qualname__.__eq__('Pattern.search') == True — search is defined directly on Pattern; its __qualname__ is 'Pattern.search'; str.__eq__('Pattern.search') returns True; new to extra253"]
    - [search_class,
       "Pattern.search.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "re.Pattern.search.__class__.__name__.__eq__('method_descriptor') == True — Pattern.search is a C-level method_descriptor; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra253"]

# ---------------------------------------------------------------------------
# Table 3: re.Pattern findall, finditer, fullmatch method identity
# ---------------------------------------------------------------------------

table re_extra253.pattern_find_fullmatch_identity:
  description: "re.Pattern findall, finditer, fullmatch method __name__, __qualname__; new to extra253"
  kind: python_call_eq
  category: identity
  id_prefix: rexpffi253

  columns: [id, function, args, expected, description]
  rows:
    - [findall_name,
       "Pattern.findall.__name__.__eq__",
       ["findall"],
       true,
       "re.Pattern.findall.__name__.__eq__('findall') == True — Pattern.findall returns all non-overlapping matches of the pattern as a list of strings; its __name__ is 'findall'; str.__eq__('findall') returns True; new to extra253"]
    - [findall_qualname,
       "Pattern.findall.__qualname__.__eq__",
       ["Pattern.findall"],
       true,
       "re.Pattern.findall.__qualname__.__eq__('Pattern.findall') == True — findall is defined directly on Pattern; its __qualname__ is 'Pattern.findall'; str.__eq__('Pattern.findall') returns True; new to extra253"]
    - [finditer_name,
       "Pattern.finditer.__name__.__eq__",
       ["finditer"],
       true,
       "re.Pattern.finditer.__name__.__eq__('finditer') == True — Pattern.finditer returns an iterator yielding match objects for all non-overlapping matches; its __name__ is 'finditer'; str.__eq__('finditer') returns True; new to extra253"]
    - [finditer_qualname,
       "Pattern.finditer.__qualname__.__eq__",
       ["Pattern.finditer"],
       true,
       "re.Pattern.finditer.__qualname__.__eq__('Pattern.finditer') == True — finditer is defined directly on Pattern; its __qualname__ is 'Pattern.finditer'; str.__eq__('Pattern.finditer') returns True; new to extra253"]
    - [fullmatch_name,
       "Pattern.fullmatch.__name__.__eq__",
       ["fullmatch"],
       true,
       "re.Pattern.fullmatch.__name__.__eq__('fullmatch') == True — Pattern.fullmatch requires the entire string to match the pattern; its __name__ is 'fullmatch'; str.__eq__('fullmatch') returns True; new to extra253"]
    - [fullmatch_qualname,
       "Pattern.fullmatch.__qualname__.__eq__",
       ["Pattern.fullmatch"],
       true,
       "re.Pattern.fullmatch.__qualname__.__eq__('Pattern.fullmatch') == True — fullmatch is defined directly on Pattern; its __qualname__ is 'Pattern.fullmatch'; str.__eq__('Pattern.fullmatch') returns True; new to extra253"]

# ---------------------------------------------------------------------------
# Table 4: re.Pattern sub and split method identity
# ---------------------------------------------------------------------------

table re_extra253.pattern_sub_split_identity:
  description: "re.Pattern sub and split method __name__, __qualname__, __class__.__name__; new to extra253"
  kind: python_call_eq
  category: identity
  id_prefix: rexpss253

  columns: [id, function, args, expected, description]
  rows:
    - [sub_name,
       "Pattern.sub.__name__.__eq__",
       ["sub"],
       true,
       "re.Pattern.sub.__name__.__eq__('sub') == True — Pattern.sub returns the string with all matches replaced by a replacement; its __name__ is 'sub'; str.__eq__('sub') returns True; new to extra253"]
    - [sub_qualname,
       "Pattern.sub.__qualname__.__eq__",
       ["Pattern.sub"],
       true,
       "re.Pattern.sub.__qualname__.__eq__('Pattern.sub') == True — sub is defined directly on Pattern; its __qualname__ is 'Pattern.sub'; str.__eq__('Pattern.sub') returns True; new to extra253"]
    - [sub_class,
       "Pattern.sub.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "re.Pattern.sub.__class__.__name__.__eq__('method_descriptor') == True — Pattern.sub is a C-level method_descriptor; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra253"]
    - [split_name,
       "Pattern.split.__name__.__eq__",
       ["split"],
       true,
       "re.Pattern.split.__name__.__eq__('split') == True — Pattern.split splits the string by occurrences of the pattern; its __name__ is 'split'; str.__eq__('split') returns True; new to extra253"]
    - [split_qualname,
       "Pattern.split.__qualname__.__eq__",
       ["Pattern.split"],
       true,
       "re.Pattern.split.__qualname__.__eq__('Pattern.split') == True — split is defined directly on Pattern; its __qualname__ is 'Pattern.split'; str.__eq__('Pattern.split') returns True; new to extra253"]
    - [split_class,
       "Pattern.split.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "re.Pattern.split.__class__.__name__.__eq__('method_descriptor') == True — Pattern.split is a C-level method_descriptor; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra253"]

# ---------------------------------------------------------------------------
# Standalone invariants — re_extra253
# ---------------------------------------------------------------------------

invariant re_extra253.pattern_name:
  description: "re.Pattern.__name__ == 'Pattern' — the compiled regex class has simple name 'Pattern', not 're.Pattern'; new to extra253"
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra253.pattern_module:
  description: "re.Pattern.__module__ == 're' — re.Pattern is defined in the re module; new to extra253"
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra253.pattern_base_is_object:
  description: "re.Pattern.__bases__[0].__name__ == 'object' — Pattern inherits directly from object; new to extra253"
  kind: python_call_eq
  function: "Pattern.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant re_extra253.pattern_match_name:
  description: "re.Pattern.match.__name__ == 'match' — Pattern.match matches at the start of the string; new to extra253"
  kind: python_call_eq
  function: Pattern.match.__name__.__eq__
  args: ["match"]
  expected: true

invariant re_extra253.pattern_search_name:
  description: "re.Pattern.search.__name__ == 'search' — Pattern.search scans for first location where pattern matches; new to extra253"
  kind: python_call_eq
  function: Pattern.search.__name__.__eq__
  args: ["search"]
  expected: true

invariant re_extra253.pattern_match_is_method_descriptor:
  description: "re.Pattern.match.__class__.__name__ == 'method_descriptor' — Pattern methods are C-level method_descriptors; new to extra253"
  kind: python_call_eq
  function: Pattern.match.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant re_extra253.pattern_sub_name:
  description: "re.Pattern.sub.__name__ == 'sub' — Pattern.sub returns string with matches replaced; new to extra253"
  kind: python_call_eq
  function: Pattern.sub.__name__.__eq__
  args: ["sub"]
  expected: true

invariant re_extra253.pattern_fullmatch_qualname:
  description: "re.Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch' — fullmatch is defined directly on Pattern; new to extra253"
  kind: python_call_eq
  function: Pattern.fullmatch.__qualname__.__eq__
  args: ["Pattern.fullmatch"]
  expected: true
