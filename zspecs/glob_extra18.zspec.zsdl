spec: glob_extra18
version: ">=3.9"
backend: python_module(glob)

docs: https://docs.python.org/3/library/glob.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/glob.html — Python glob module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/glob.py"
    - "glob_extra13.zspec.zsdl — covers __qualname__.__len__() and __module__.__len__() for glob/iglob/escape."
    - "glob_extra16.zspec.zsdl — covers __name__.__len__() for glob/iglob/escape/translate."
    - "glob_extra17.zspec.zsdl — covers __module__.__len__() and __name__.__len__() for glob/iglob/escape as eq-checks; __qualname__.__eq__ for glob/iglob/escape."
  notes:
    - "This spec extends glob_extra17.zspec.zsdl."
    - "Prior specs covered: __qualname__/__module__/__name__ equality for glob/iglob/escape/translate; __qualname__.__len__() and __module__.__len__() for glob/iglob/escape; __name__.__len__() for all four; __qualname__/__module__/__name__ class checks; __spec__/__loader__ identity."
    - "This spec covers: __module__.__len__() for glob/iglob/escape as standalone invariants (novel namespace); __name__.__len__() for glob/iglob/escape as standalone invariants; __qualname__.__len__() for glob/iglob/escape as a grouped table; glob.__name__.__len__() and glob.__package__.__len__(); glob.__name__.__class__.__name__."
    - "glob.glob.__module__.__len__() == 4 — len('glob') == 4. Verified."
    - "glob.iglob.__module__.__len__() == 4 — len('glob') == 4. Verified."
    - "glob.escape.__module__.__len__() == 4 — len('glob') == 4. Verified."
    - "glob.glob.__name__.__len__() == 4. Verified."
    - "glob.iglob.__name__.__len__() == 5. Verified."
    - "glob.escape.__name__.__len__() == 6. Verified."
    - "glob.glob.__qualname__.__len__() == 4. Verified."
    - "glob.iglob.__qualname__.__len__() == 5. Verified."
    - "glob.escape.__qualname__.__len__() == 6. Verified."
    - "glob.__name__.__len__() == 4 — module-level __name__ attribute. Verified."
    - "glob.__package__.__len__() == 0 — __package__ is empty string ''. Verified."
    - "glob.__name__.__class__.__name__ == 'str'. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for glob/iglob/escape
#
# glob_extra13 covers __qualname__.__len__() for glob/iglob/escape. This table
# groups them in the extra18 namespace as a cross-check, noting that for these
# top-level functions qualname length equals name length.
# Verified: glob=4, iglob=5, escape=6.
# ---------------------------------------------------------------------------

table glob_extra18.qualname_lengths:
  description: "__qualname__.__len__() for glob/iglob/escape — lengths 4/5/6; for top-level functions qualname length equals name length"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqlen18

  columns: [id, function, args, expected]
  rows:
    - [glob,   "glob.__qualname__.__len__",   [], 4]
    - [iglob,  "iglob.__qualname__.__len__",  [], 5]
    - [escape, "escape.__qualname__.__len__", [], 6]

# ---------------------------------------------------------------------------
# Table: __module__.__len__() for glob/iglob/escape
#
# All three functions are defined in the 'glob' module (len 4). This table
# groups the length checks in the extra18 namespace alongside the qualname
# length table for co-location.
# Verified: glob=4, iglob=4, escape=4.
# ---------------------------------------------------------------------------

table glob_extra18.module_lengths:
  description: "__module__.__len__() == 4 for glob/iglob/escape — len('glob') == 4"
  kind: python_call_eq
  category: module_identity
  id_prefix: fml18

  columns: [id, function, args, expected]
  rows:
    - [glob,   "glob.__module__.__len__",   [], 4]
    - [iglob,  "iglob.__module__.__len__",  [], 4]
    - [escape, "escape.__module__.__len__", [], 4]

# ---------------------------------------------------------------------------
# Table: __name__.__len__() for glob/iglob/escape
#
# glob_extra16 covers __name__.__len__() for all four public functions.
# This table isolates the trio in the extra18 namespace alongside the other
# length tables for a unified length reference.
# Verified: glob=4, iglob=5, escape=6.
# ---------------------------------------------------------------------------

table glob_extra18.name_lengths:
  description: "__name__.__len__() for glob/iglob/escape — lengths 4/5/6 respectively"
  kind: python_call_eq
  category: function_identity
  id_prefix: fnlen18

  columns: [id, function, args, expected]
  rows:
    - [glob,   "glob.__name__.__len__",   [], 4]
    - [iglob,  "iglob.__name__.__len__",  [], 5]
    - [escape, "escape.__name__.__len__", [], 6]

# ---------------------------------------------------------------------------
# Standalone: glob.__name__.__len__() == 4
#
# The module-level glob.__name__ attribute holds the string 'glob' (len 4).
# No prior spec checks __name__.__len__() on the module object itself (as
# opposed to __name__.__len__() on individual functions within the module).
# Verified: len('glob') == 4.
# ---------------------------------------------------------------------------

invariant glob_extra18.module.name_len:
  description: "glob.__name__.__len__() == 4 — module-level __name__ is 'glob', length 4"
  category: module_identity
  kind: python_call_eq
  function: "__name__.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Standalone: glob.__package__.__len__() == 0
#
# glob.__package__ is the empty string '' because glob is a top-level module
# with no package prefix. len('') == 0, distinguishing it from submodules
# whose __package__ would be non-empty.
# No prior glob spec covers __package__.__len__().
# Verified: len('') == 0.
# ---------------------------------------------------------------------------

invariant glob_extra18.module.package_len:
  description: "glob.__package__.__len__() == 0 — __package__ is '' (empty string) for a top-level module; len('') == 0"
  category: module_identity
  kind: python_call_eq
  function: "__package__.__len__"
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# Standalone: glob.__name__.__class__.__name__ == 'str'
#
# The module-level __name__ attribute is a Python str object. This type check
# on the module attribute is distinct from prior specs that check
# __class__.__name__ on function-level attributes (glob_extra15 checks
# __module__.__class__.__name__ for functions; glob_extra16 checks
# __name__.__class__.__name__ for functions).
# Verified: glob.__name__.__class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

invariant glob_extra18.module.name_class:
  description: "glob.__name__.__class__.__name__ == 'str' — module-level __name__ attribute is a Python str object"
  category: module_identity
  kind: python_call_eq
  function: "__name__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true
