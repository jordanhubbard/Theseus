spec: threading_extra202
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers __code__.co_name identity for public threading Python functions: current_thread, main_thread, active_count, enumerate, settrace, setprofile, getprofile, gettrace."
    - "threading.current_thread.__code__.co_name == 'current_thread' — Python function; co_name matches def name. Verified with Python 3.14.3."
    - "threading.main_thread.__code__.co_name == 'main_thread' — Python function; co_name matches def name. Verified with Python 3.14.3."
    - "threading.active_count.__code__.co_name == 'active_count' — Python function; co_name matches def name. Verified with Python 3.14.3."
    - "threading.enumerate.__code__.co_name == 'enumerate' — Python function returning list of active threads; co_name matches def name. Verified with Python 3.14.3."
    - "threading.settrace.__code__.co_name == 'settrace' — Python function for installing trace hook; co_name matches def name. Verified with Python 3.14.3."
    - "threading.setprofile.__code__.co_name == 'setprofile' — Python function for installing profile hook; co_name matches def name. Verified with Python 3.14.3."
    - "threading.getprofile.__code__.co_name == 'getprofile' — Python function returning current profile hook; co_name matches def name. Verified with Python 3.14.3."
    - "threading.gettrace.__code__.co_name == 'gettrace' — Python function returning current trace hook; co_name matches def name. Verified with Python 3.14.3."
    - "threading.stack_size is a builtin_function_or_method (C-level) with no __code__ attribute. Not covered here."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __code__.co_name for threading thread-query functions
#
# current_thread, main_thread, active_count: Python functions that query
# the current threading state. All have __code__ and co_name matches def name.
# ---------------------------------------------------------------------------

table threading_extra202.coname_thread_query:
  description: "threading thread-query functions: current_thread, main_thread, active_count __code__.co_name identity; new to extra202"
  kind: python_call_eq
  category: conames
  id_prefix: threadingconames202

  columns: [id, function, args, expected, description]
  rows:
    - [current_thread_co_name,
       current_thread.__code__.co_name.__eq__,
       ["current_thread"],
       true,
       "threading.current_thread.__code__.co_name.__eq__('current_thread') == True — Python function returning calling thread; __code__.co_name == 'current_thread'; new to extra202"]
    - [main_thread_co_name,
       main_thread.__code__.co_name.__eq__,
       ["main_thread"],
       true,
       "threading.main_thread.__code__.co_name.__eq__('main_thread') == True — Python function returning main thread; __code__.co_name == 'main_thread'; new to extra202"]
    - [active_count_co_name,
       active_count.__code__.co_name.__eq__,
       ["active_count"],
       true,
       "threading.active_count.__code__.co_name.__eq__('active_count') == True — Python function returning count of alive threads; __code__.co_name == 'active_count'; new to extra202"]

# ---------------------------------------------------------------------------
# Table 2: __code__.co_name for threading enumerate and hook-install functions
#
# enumerate, settrace, setprofile: Python functions for thread enumeration
# and installing trace/profile hooks on all threads.
# co_name matches each function's def name.
# ---------------------------------------------------------------------------

table threading_extra202.coname_enumerate_hooks:
  description: "threading enumerate, settrace, setprofile __code__.co_name identity; new to extra202"
  kind: python_call_eq
  category: conames
  id_prefix: threadingconames202

  columns: [id, function, args, expected, description]
  rows:
    - [enumerate_co_name,
       enumerate.__code__.co_name.__eq__,
       ["enumerate"],
       true,
       "threading.enumerate.__code__.co_name.__eq__('enumerate') == True — Python function returning list of all alive Thread objects; __code__.co_name == 'enumerate'; new to extra202"]
    - [settrace_co_name,
       settrace.__code__.co_name.__eq__,
       ["settrace"],
       true,
       "threading.settrace.__code__.co_name.__eq__('settrace') == True — Python function installing trace hook for all new threads; __code__.co_name == 'settrace'; new to extra202"]
    - [setprofile_co_name,
       setprofile.__code__.co_name.__eq__,
       ["setprofile"],
       true,
       "threading.setprofile.__code__.co_name.__eq__('setprofile') == True — Python function installing profile hook for all new threads; __code__.co_name == 'setprofile'; new to extra202"]

# ---------------------------------------------------------------------------
# Table 3: __code__.co_name for threading hook-retrieval functions
#
# getprofile, gettrace: Python functions that retrieve the currently installed
# profile and trace hooks. Both have __code__ and co_name matches def name.
# ---------------------------------------------------------------------------

table threading_extra202.coname_get_hooks:
  description: "threading getprofile and gettrace __code__.co_name identity; new to extra202"
  kind: python_call_eq
  category: conames
  id_prefix: threadingconames202

  columns: [id, function, args, expected, description]
  rows:
    - [getprofile_co_name,
       getprofile.__code__.co_name.__eq__,
       ["getprofile"],
       true,
       "threading.getprofile.__code__.co_name.__eq__('getprofile') == True — Python function returning the current profile hook; __code__.co_name == 'getprofile'; new to extra202"]
    - [gettrace_co_name,
       gettrace.__code__.co_name.__eq__,
       ["gettrace"],
       true,
       "threading.gettrace.__code__.co_name.__eq__('gettrace') == True — Python function returning the current trace hook; __code__.co_name == 'gettrace'; new to extra202"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra202
# ---------------------------------------------------------------------------

invariant threading_extra202.current_thread_co_name:
  description: "threading.current_thread.__code__.co_name == 'current_thread' — Python function; co_name matches def name; new to extra202"
  kind: python_call_eq
  function: current_thread.__code__.co_name.__eq__
  args: ["current_thread"]
  expected: true

invariant threading_extra202.main_thread_co_name:
  description: "threading.main_thread.__code__.co_name == 'main_thread' — Python function; co_name matches def name; new to extra202"
  kind: python_call_eq
  function: main_thread.__code__.co_name.__eq__
  args: ["main_thread"]
  expected: true

invariant threading_extra202.active_count_co_name:
  description: "threading.active_count.__code__.co_name == 'active_count' — Python function; co_name matches def name; new to extra202"
  kind: python_call_eq
  function: active_count.__code__.co_name.__eq__
  args: ["active_count"]
  expected: true

invariant threading_extra202.enumerate_co_name:
  description: "threading.enumerate.__code__.co_name == 'enumerate' — Python function listing alive threads; co_name matches def name; new to extra202"
  kind: python_call_eq
  function: enumerate.__code__.co_name.__eq__
  args: ["enumerate"]
  expected: true

invariant threading_extra202.settrace_co_name:
  description: "threading.settrace.__code__.co_name == 'settrace' — Python function installing trace hook; co_name matches def name; new to extra202"
  kind: python_call_eq
  function: settrace.__code__.co_name.__eq__
  args: ["settrace"]
  expected: true

invariant threading_extra202.setprofile_co_name:
  description: "threading.setprofile.__code__.co_name == 'setprofile' — Python function installing profile hook; co_name matches def name; new to extra202"
  kind: python_call_eq
  function: setprofile.__code__.co_name.__eq__
  args: ["setprofile"]
  expected: true

invariant threading_extra202.getprofile_co_name:
  description: "threading.getprofile.__code__.co_name == 'getprofile' — Python function returning current profile hook; co_name matches def name; new to extra202"
  kind: python_call_eq
  function: getprofile.__code__.co_name.__eq__
  args: ["getprofile"]
  expected: true

invariant threading_extra202.gettrace_co_name:
  description: "threading.gettrace.__code__.co_name == 'gettrace' — Python function returning current trace hook; co_name matches def name; new to extra202"
  kind: python_call_eq
  function: gettrace.__code__.co_name.__eq__
  args: ["gettrace"]
  expected: true
