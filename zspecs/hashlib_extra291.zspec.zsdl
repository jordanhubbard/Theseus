spec: hashlib_extra291
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module identity, algorithms_guaranteed, algorithms_available"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py, Modules/_hashopenssl.c"
  notes:
    - "algorithms_guaranteed is always a subset of algorithms_available"
    - "sha3_* and shake_* variants guaranteed since Python 3.6"
    - "blake2b and blake2s guaranteed since Python 3.6"
    - "__loader__ class is SourceFileLoader because hashlib is a pure-Python module"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table hashlib_extra291.module_spec_identity:
  description: "hashlib module __spec__ and __loader__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: hx291

  columns: [id, function, args, expected, description]
  rows:
    - [hx291-001, hashlib.__name__.__eq__, ["hashlib"], true, "module name is 'hashlib'"]
    - [hx291-002, hashlib.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "__spec__ is a ModuleSpec"]
    - [hx291-003, hashlib.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "__loader__ is a SourceFileLoader"]
    - [hx291-004, hashlib.__file__.__class__.__name__.__eq__, ["str"], true, "__file__ is a str"]
    - [hx291-005, hashlib.__spec__.name.__eq__, ["hashlib"], true, "__spec__.name equals 'hashlib'"]

table hashlib_extra291.algorithms_guaranteed_members:
  description: "Less-common members of hashlib.algorithms_guaranteed"
  kind: python_call_eq
  category: identity
  id_prefix: hx291

  columns: [id, function, args, expected, description]
  rows:
    - [hx291-006, hashlib.algorithms_guaranteed.__contains__, ["sha3_224"], true, "sha3_224 is in algorithms_guaranteed"]
    - [hx291-007, hashlib.algorithms_guaranteed.__contains__, ["sha3_384"], true, "sha3_384 is in algorithms_guaranteed"]
    - [hx291-008, hashlib.algorithms_guaranteed.__contains__, ["sha3_512"], true, "sha3_512 is in algorithms_guaranteed"]
    - [hx291-009, hashlib.algorithms_guaranteed.__contains__, ["shake_128"], true, "shake_128 is in algorithms_guaranteed"]
    - [hx291-010, hashlib.algorithms_guaranteed.__contains__, ["shake_256"], true, "shake_256 is in algorithms_guaranteed"]
    - [hx291-011, hashlib.algorithms_guaranteed.__contains__, ["blake2b"], true, "blake2b is in algorithms_guaranteed"]
    - [hx291-012, hashlib.algorithms_guaranteed.__contains__, ["blake2s"], true, "blake2s is in algorithms_guaranteed"]

invariant hashlib_extra291.guaranteed_len:
  description: "algorithms_guaranteed has exactly 14 members"
  category: identity
  kind: python_call_eq
  function: hashlib.algorithms_guaranteed.__len__
  args: []
  expected: 14

invariant hashlib_extra291.available_contains_sha256:
  description: "sha256 is in algorithms_available"
  category: identity
  kind: python_call_eq
  function: hashlib.algorithms_available.__contains__
  args: ["sha256"]
  expected: true

invariant hashlib_extra291.spec_name_eq:
  description: "__spec__.name equals 'hashlib'"
  category: identity
  kind: python_call_eq
  function: hashlib.__spec__.name.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlib_extra291.new_empty_name_raises:
  description: "hashlib.new with empty string raises ValueError"
  category: errors
  kind: python_call_raises
  function: hashlib.new
  args: [""]
  raises: ValueError
