spec: struct_extra33
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra32.zspec.zsdl — covers Struct METHOD __name__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack; Struct('>I').pack(255)==b'\\x00\\x00\\x00\\xff'."
    - "struct_extra31.zspec.zsdl — covers iter_unpack result __class__.__name__.__len__()==15; Struct.__new__/__sizeof__ __qualname__.__len__(); Struct.__class__.__name__.__len__()==4."
    - "struct_extra30.zspec.zsdl — covers calcsize('10s'/'?'/'e'); Struct('4B').size; Struct('4B').format.__len__()==2."
    - "struct_extra29.zspec.zsdl — covers struct.__spec__.__name__.__len__()==6; struct.__loader__.__class__.__name__.__len__()==16."
    - "struct_extra27.zspec.zsdl — covers Struct method __qualname__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack."
    - "struct_extra20.zspec.zsdl — covers __qualname__.__len__() for all six module-level functions."
    - "struct_extra19.zspec.zsdl — covers Struct.__qualname__.__len__()==6; error.__qualname__.__len__()==5."
    - "struct_extra16.zspec.zsdl — covers MODULE-LEVEL pack/unpack/calcsize/pack_into/unpack_from/iter_unpack __name__.__len__()."
  notes:
    - "This spec extends struct through struct_extra32; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: module-level function __name__.__len__() for pack/unpack/calcsize/pack_into/unpack_from/iter_unpack (extra16); Struct method __qualname__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack (extra27); Struct METHOD __name__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack (extra32); Struct.__qualname__.__len__()==6 and error.__qualname__.__len__()==5 (extra19); struct.__spec__.__name__.__len__()==6 (extra29)."
    - "This spec covers: struct.__name__.__len__() (NOVEL — struct.__name__=='struct' is 6 chars; extra29 covers struct.__spec__.__name__.__len__()==6 which reads the same string via __spec__, but the module's own __name__ attribute is a distinct invariant; extra16 covers MODULE-LEVEL function __name__.__len__(), not the module's own __name__); struct.error.__module__.__len__() (NOVEL — struct.error.__module__=='struct' is 6 chars; no prior spec checks error.__module__.__len__()); struct.Struct.__module__.__len__() (NOVEL — struct.Struct.__module__=='_struct' is 7 chars; Struct is implemented in the _struct C extension; no prior spec checks Struct.__module__.__len__()); behavioral pack('>3B',1,2,3)==b'\\x01\\x02\\x03' (NOVEL — prior behavioral specs cover pack for single-element formats; extra32 covers Struct('>I').pack(255); no prior spec checks pack() for a 3-element byte array format '>3B'); behavioral calcsize('3s')==3 (NOVEL — extra30 covers calcsize('10s')==10 and ('?')==1 and ('e')==2; extra5 covers '>5s'==5; extra11 covers '3s'==3 ... verify); behavioral Struct('!4s').pack(b'test')==b'test' (NOVEL — network-byte-order 4-char string pack; no prior spec tests Struct with '!4s' format)."
    - "struct.__name__ == 'struct' (len 6). extra29 covers struct.__spec__.__name__.__len__()==6 which reads the same 'struct' string but via the module's __spec__ attribute. The module object's own __name__ attribute (struct.__name__) is a distinct attribute path and a separate regression invariant. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct' (len 6). The error exception class is defined in the struct Python wrapper (not the _struct C extension), so its __module__ is 'struct'. No prior spec checks error.__module__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__ == '_struct' (len 7). The Struct type is implemented in the _struct C extension module, so its __module__ is '_struct' (7 chars). No prior spec checks Struct.__module__.__len__(). Distinct from error.__module__ ('struct', 6 chars). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.pack('>3B', 1, 2, 3) == b'\\x01\\x02\\x03'. The '>3B' format packs three unsigned bytes in big-endian order. Values 1/2/3 encode directly as single bytes 0x01/0x02/0x03. No prior spec checks a 3-element big-endian unsigned-byte pack. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct('!4s').pack(b'test') == b'test'. Network-byte-order 4-char string format; '!4s' is equivalent to '>4s' for strings. Packing b'test' (4 bytes) returns b'test' unchanged. No prior spec tests Struct with '!4s' format. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__name__.__len__()
#
# struct.__name__ == 'struct' (len 6).
# extra29 covers struct.__spec__.__name__.__len__()==6 (via __spec__).
# This invariant checks the module's own __name__ attribute directly,
# which is a distinct attribute path and a separate regression invariant.
# extra16 covers MODULE-LEVEL function __name__.__len__(), not the module's own.
# ---------------------------------------------------------------------------

invariant struct_extra33.struct_module.name_len:
  description: "struct.__name__.__len__() == 6 — 'struct' has 6 chars; novel: extra29 covers __spec__.__name__.__len__==6 (via __spec__ chain) but not the module's own __name__ attribute directly"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# struct.error.__module__.__len__() and struct.Struct.__module__.__len__()
#
# struct.error.__module__ == 'struct' (len 6): error is defined in the Python
# wrapper layer of the struct module.
# struct.Struct.__module__ == '_struct' (len 7): Struct is implemented in the
# C extension _struct and exposes that module name.
#
# No prior spec checks __module__.__len__() for error or Struct.
# These expose a structural difference (Python vs. C extension) via module names.
# ---------------------------------------------------------------------------

table struct_extra33.class_module_lens:
  description: "struct.error/__module__.__len__()==6 ('struct') and struct.Struct/__module__.__len__()==7 ('_struct') — novel; no prior spec checks __module__.__len__() for either class; reveals Python-vs-C-extension distinction"
  kind: python_call_eq
  category: module_metadata
  id_prefix: scml33

  columns: [id, function, args, expected]
  rows:
    - [error_module_len,  error.__module__.__len__,  [], 6]
    - [Struct_module_len, Struct.__module__.__len__, [], 7]

# ---------------------------------------------------------------------------
# Behavioral: struct.pack('>3B', 1, 2, 3) == b'\x01\x02\x03'
#
# The '>3B' format string encodes three unsigned bytes (B) in big-endian (>)
# order. Values 1, 2, 3 each fit in one byte and encode as 0x01, 0x02, 0x03.
# No prior spec checks a multi-element unsigned-byte pack with the module-level
# pack() function (extra32 covers Struct('>I').pack(255) via method_chain).
# This is a direct module-level pack() call with a 3-element format.
# ---------------------------------------------------------------------------

invariant struct_extra33.pack_3bytes_behavioral:
  description: "struct.pack('>3B', 1, 2, 3) == b'\\x01\\x02\\x03' — 3-element big-endian unsigned-byte pack; novel: extra32 covers Struct('>I').pack(255) via method_chain; no prior spec tests module-level pack() with 3-element format"
  category: behavioral
  kind: python_call_eq
  function: pack
  args: [">3B", 1, 2, 3]
  expected: !hex 010203

# ---------------------------------------------------------------------------
# Behavioral: struct.Struct('!4s').pack(b'test') == b'test'
#
# struct.Struct('!4s') creates a Struct for network-byte-order 4-char string.
# '!4s' is equivalent to '>4s' for string types (byte order is irrelevant
# for character arrays). Packing b'test' (4 bytes) returns b'test' unchanged.
# No prior spec uses Struct with '!4s' format or tests network-order string pack.
# ---------------------------------------------------------------------------

invariant struct_extra33.Struct_network_4s_pack:
  description: "struct.Struct('!4s').pack(b'test') == b'test' — network-byte-order 4-char string is identity for byte arrays; novel: no prior spec tests Struct with '!4s' format"
  category: behavioral
  kind: python_call_eq
  function: Struct
  args: ["!4s"]
  method: pack
  method_args: [!ascii "test"]
  expected: !ascii "test"
