spec: concurrent_futures_extra41
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra40.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__.__class__.__name__.__len__() tables, as_completed/wait __module__.__len__(), __all__.__len__()==14, __mro__.__len__() tables, __bases__[0].__name__.__len__() for all classes, Executor context manager qualname lens, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, map/__qualname__.__len__() for both executors, Future method __name__/__qualname__.__len__() tables, ThreadPoolExecutor submit/shutdown __name__/__qualname__.__len__() tables, InvalidStateError/__name__.__len__()==17, CancelledError/__qualname__.__len__()==14, BrokenExecutor/__name__/__qualname__.__len__()==14, BrokenExecutor/__module__.__len__()==24, CancelledError/__module__.__len__()==24, BrokenExecutor/__bases__[0].__name__.__len__()==12, TimeoutError/__name__/__module__.__len__(), concurrent.futures.__package__.__len__()==18, __spec__.__class__.__name__.__len__()==10, ThreadPoolExecutor/__name__=='ThreadPoolExecutor', ProcessPoolExecutor/__name__=='ProcessPoolExecutor', executor __module__ string equality, wait/__name__=='wait', function __module__ string equality (extra36), Executor/__name__=='Executor'/__module__==concurrent.futures._base, Executor map/submit qualname lengths, InvalidStateError/BrokenExecutor __name__/__module__ string equality (extra37), ProcessPoolExecutor/ThreadPoolExecutor/__bases__[0].__name__=='Executor', Future/__bases__[0].__name__=='object', exception MRO depths all 5 (extra38), ProcessPoolExecutor/__mro__.__len__()==3, ThreadPoolExecutor/__mro__.__len__()==3, Future/__mro__.__len__()==2, Executor/__mro__.__len__()==2, Executor/__bases__[0].__name__=='object', sentinel __class__.__name__=='str' (extra39), ThreadPoolExecutor/__qualname__=='ThreadPoolExecutor' (18 chars), ProcessPoolExecutor/__qualname__=='ProcessPoolExecutor' (19 chars), Future/__qualname__=='Future' (6 chars), Executor/__qualname__=='Executor' (8 chars), CancelledError/__qualname__=='CancelledError' (14 chars), BrokenExecutor/__qualname__=='BrokenExecutor' (14 chars) and their __len__() measurements (extra40)."
    - "This spec covers: ThreadPoolExecutor/__qualname__.__len__()==18; ProcessPoolExecutor/__qualname__.__len__()==19; Future/__qualname__.__len__()==6; Executor/__qualname__.__len__()==8; CancelledError/__qualname__.__len__()==14; BrokenExecutor/__qualname__.__len__()==14; InvalidStateError/__qualname__.__len__()==17; TimeoutError/__qualname__.__len__()==12."
    - "concurrent.futures.ThreadPoolExecutor.__qualname__.__len__() == 18. ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' (verified in extra40); len('ThreadPoolExecutor') == 18. Extra41 groups all class qualname lengths into a comprehensive table."
    - "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__() == 19. ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' (verified in extra40); len('ProcessPoolExecutor') == 19."
    - "concurrent.futures.Future.__qualname__.__len__() == 6. Future.__qualname__ == 'Future'; len('Future') == 6."
    - "concurrent.futures.Executor.__qualname__.__len__() == 8. Executor.__qualname__ == 'Executor'; len('Executor') == 8."
    - "concurrent.futures.CancelledError.__qualname__.__len__() == 14. CancelledError.__qualname__ == 'CancelledError'; len('CancelledError') == 14."
    - "concurrent.futures.BrokenExecutor.__qualname__.__len__() == 14. BrokenExecutor.__qualname__ == 'BrokenExecutor'; len('BrokenExecutor') == 14. Note: CancelledError and BrokenExecutor share the same __qualname__ length of 14."
    - "concurrent.futures.InvalidStateError.__qualname__.__len__() == 17. InvalidStateError.__qualname__ == 'InvalidStateError'; len('InvalidStateError') == 17: I-n-v-a-l-i-d-S-t-a-t-e-E-r-r-o-r = 17."
    - "concurrent.futures.TimeoutError.__qualname__.__len__() == 12. TimeoutError.__qualname__ == 'TimeoutError'; len('TimeoutError') == 12: T-i-m-e-o-u-t-E-r-r-o-r = 12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures core class __qualname__ lengths — extra41 namespace
#
# All four core classes with __qualname__.__len__():
#   ThreadPoolExecutor.__qualname__.__len__()  == 18
#   ProcessPoolExecutor.__qualname__.__len__() == 19
#   Future.__qualname__.__len__()              ==  6
#   Executor.__qualname__.__len__()            ==  8
# Extra40 captured the __eq__ string comparisons; extra41 gathers the
# __len__() measurements for all four core classes into one table alongside
# the exception class lengths.
# ---------------------------------------------------------------------------

table concurrent_futures_extra41.core_class_qualname_lengths:
  description: "concurrent.futures core class __qualname__.__len__() in extra41 namespace — ThreadPoolExecutor, ProcessPoolExecutor, Future, Executor"
  kind: python_call_eq
  category: class_names
  id_prefix: cfcoreclassqnlen41

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__qualname__.__len__,  [], 18, "ThreadPoolExecutor.__qualname__.__len__() == 18 — 'ThreadPoolExecutor' has 18 characters"]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__qualname__.__len__, [], 19, "ProcessPoolExecutor.__qualname__.__len__() == 19 — 'ProcessPoolExecutor' has 19 characters"]
    - [Future,              Future.__qualname__.__len__,              [],  6, "Future.__qualname__.__len__() == 6 — 'Future' has 6 characters"]
    - [Executor,            Executor.__qualname__.__len__,            [],  8, "Executor.__qualname__.__len__() == 8 — 'Executor' has 8 characters"]

# ---------------------------------------------------------------------------
# concurrent.futures exception class __qualname__ lengths — extra41 namespace
#
# Four exception classes with their __qualname__.__len__():
#   CancelledError.__qualname__.__len__()    == 14  ('CancelledError')
#   BrokenExecutor.__qualname__.__len__()    == 14  ('BrokenExecutor')
#   InvalidStateError.__qualname__.__len__() == 17  ('InvalidStateError')
#   TimeoutError.__qualname__.__len__()      == 12  ('TimeoutError')
# CancelledError and BrokenExecutor share the same length 14.
# InvalidStateError is the longest at 17; TimeoutError is the shortest at 12.
# ---------------------------------------------------------------------------

table concurrent_futures_extra41.exception_qualname_lengths:
  description: "concurrent.futures exception class __qualname__.__len__() in extra41 namespace — CancelledError, BrokenExecutor, InvalidStateError, TimeoutError"
  kind: python_call_eq
  category: class_names
  id_prefix: cfexcqnlen41

  columns: [id, function, args, expected, description]
  rows:
    - [CancelledError,    CancelledError.__qualname__.__len__,    [], 14, "CancelledError.__qualname__.__len__() == 14 — 'CancelledError' has 14 characters"]
    - [BrokenExecutor,    BrokenExecutor.__qualname__.__len__,    [], 14, "BrokenExecutor.__qualname__.__len__() == 14 — 'BrokenExecutor' has 14 characters; same as CancelledError"]
    - [InvalidStateError, InvalidStateError.__qualname__.__len__, [], 17, "InvalidStateError.__qualname__.__len__() == 17 — 'InvalidStateError' has 17 characters"]
    - [TimeoutError,      TimeoutError.__qualname__.__len__,      [], 12, "TimeoutError.__qualname__.__len__() == 12 — 'TimeoutError' has 12 characters"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra41
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra41.ThreadPoolExecutor_qualname_len:
  description: "concurrent.futures.ThreadPoolExecutor.__qualname__.__len__() == 18 — 'ThreadPoolExecutor' has 18 characters"
  category: class_names
  kind: python_call_eq
  function: ThreadPoolExecutor.__qualname__.__len__
  args: []
  expected: 18

invariant concurrent_futures_extra41.ProcessPoolExecutor_qualname_len:
  description: "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__() == 19 — 'ProcessPoolExecutor' has 19 characters"
  category: class_names
  kind: python_call_eq
  function: ProcessPoolExecutor.__qualname__.__len__
  args: []
  expected: 19

invariant concurrent_futures_extra41.Future_qualname_len:
  description: "concurrent.futures.Future.__qualname__.__len__() == 6 — 'Future' has 6 characters"
  category: class_names
  kind: python_call_eq
  function: Future.__qualname__.__len__
  args: []
  expected: 6

invariant concurrent_futures_extra41.Executor_qualname_len:
  description: "concurrent.futures.Executor.__qualname__.__len__() == 8 — 'Executor' has 8 characters"
  category: class_names
  kind: python_call_eq
  function: Executor.__qualname__.__len__
  args: []
  expected: 8

invariant concurrent_futures_extra41.CancelledError_qualname_len:
  description: "concurrent.futures.CancelledError.__qualname__.__len__() == 14 — 'CancelledError' has 14 characters"
  category: class_names
  kind: python_call_eq
  function: CancelledError.__qualname__.__len__
  args: []
  expected: 14

invariant concurrent_futures_extra41.BrokenExecutor_qualname_len:
  description: "concurrent.futures.BrokenExecutor.__qualname__.__len__() == 14 — 'BrokenExecutor' has 14 characters; same length as CancelledError"
  category: class_names
  kind: python_call_eq
  function: BrokenExecutor.__qualname__.__len__
  args: []
  expected: 14

invariant concurrent_futures_extra41.InvalidStateError_qualname_len:
  description: "concurrent.futures.InvalidStateError.__qualname__.__len__() == 17 — 'InvalidStateError' has 17 characters"
  category: class_names
  kind: python_call_eq
  function: InvalidStateError.__qualname__.__len__
  args: []
  expected: 17

invariant concurrent_futures_extra41.TimeoutError_qualname_len:
  description: "concurrent.futures.TimeoutError.__qualname__.__len__() == 12 — 'TimeoutError' has 12 characters"
  category: class_names
  kind: python_call_eq
  function: TimeoutError.__qualname__.__len__
  args: []
  expected: 12
