spec: re_extra2761
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers existing re invariants"
    - "re_extra2746.zspec.zsdl — covers __round__/__divmod__/__pow__ dict-presence"
    - "re_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
    - "re_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 631 (re_extra2761) theme: __matmul__, __truediv__, and __iadd__ dict-presence checks."
    - "Neither re.Pattern nor re.Match defines __matmul__, __truediv__, or __iadd__ in its own __dict__."
    - "__matmul__ supports the @ operator; regex objects are pattern-matching types, not matrix/numeric types."
    - "__truediv__ supports the / operator; regex objects do not implement true-division numeric semantics."
    - "__iadd__ supports the += operator; regex objects do not implement in-place addition semantics."
    - "Covers re.Pattern (type(re.compile(''))) and re.Match (type(re.match('', '')))."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __matmul__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2761.no_matmul_in_re_classes:
  description: "__matmul__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the @ matrix-multiplication protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2761

  columns: [id, function, args, expected]
  rows:
    - ["re2761001", "re.Pattern.__dict__.__contains__", ["__matmul__"], false]
    - ["re2761002", "re.Match.__dict__.__contains__",   ["__matmul__"], false]

# ---------------------------------------------------------------------------
# __truediv__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2761.no_truediv_in_re_classes:
  description: "__truediv__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the / true-division protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2761

  columns: [id, function, args, expected]
  rows:
    - ["re2761003", "re.Pattern.__dict__.__contains__", ["__truediv__"], false]
    - ["re2761004", "re.Match.__dict__.__contains__",   ["__truediv__"], false]

# ---------------------------------------------------------------------------
# __iadd__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2761.no_iadd_in_re_classes:
  description: "__iadd__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the += in-place addition protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2761

  columns: [id, function, args, expected]
  rows:
    - ["re2761005", "re.Pattern.__dict__.__contains__", ["__iadd__"], false]
    - ["re2761006", "re.Match.__dict__.__contains__",   ["__iadd__"], false]

# ---------------------------------------------------------------------------
# Complementary: re.Pattern and re.Match have regex methods but not arithmetic operator hooks
# Confirms that regex objects are pattern-matching types, not numeric or matrix types
# ---------------------------------------------------------------------------

table re_extra2761.re_has_regex_methods_not_arithmetic_operator_hooks:
  description: "re.Pattern defines match/search/sub/findall but NOT __matmul__/__truediv__/__iadd__; re.Match defines group/groups/start/end but NOT __matmul__/__truediv__/__iadd__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2761

  columns: [id, function, args, expected]
  rows:
    - ["re2761007", "re.Pattern.__dict__.__contains__", ["match"],       true]
    - ["re2761008", "re.Pattern.__dict__.__contains__", ["search"],      true]
    - ["re2761009", "re.Pattern.__dict__.__contains__", ["sub"],         true]
    - ["re2761010", "re.Pattern.__dict__.__contains__", ["findall"],     true]
    - ["re2761011", "re.Pattern.__dict__.__contains__", ["__matmul__"],  false]
    - ["re2761012", "re.Pattern.__dict__.__contains__", ["__truediv__"], false]
    - ["re2761013", "re.Pattern.__dict__.__contains__", ["__iadd__"],    false]
    - ["re2761014", "re.Match.__dict__.__contains__",   ["group"],       true]
    - ["re2761015", "re.Match.__dict__.__contains__",   ["groups"],      true]
    - ["re2761016", "re.Match.__dict__.__contains__",   ["start"],       true]
    - ["re2761017", "re.Match.__dict__.__contains__",   ["end"],         true]
    - ["re2761018", "re.Match.__dict__.__contains__",   ["__matmul__"],  false]
    - ["re2761019", "re.Match.__dict__.__contains__",   ["__truediv__"], false]
    - ["re2761020", "re.Match.__dict__.__contains__",   ["__iadd__"],    false]
