spec: ftplib_extra3
version: ">=3.9"
backend: python_module(ftplib)

docs: https://docs.python.org/3/library/ftplib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ftplib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ftplib.py internal socket handling"
    - "ftplib.zspec.zsdl — covers __name__ table (FTP/FTP_TLS/error_reply/error_temp/error_perm/error_proto), FTP.__module__, FTP.port value, Error hierarchy, exception bases table, method names"
    - "ftplib_extra.zspec.zsdl — covers FTP_TLS.__module__, FTP_TLS base, all_errors.__class__.__name__, all_errors.__len__, all_errors element names [0-2], error_proto.__module__"
    - "ftplib_extra2.zspec.zsdl — covers error_reply/error_temp/error_perm __module__, Error.__name__, Error.__module__, MSG_OOB.__class__.__name__, FTP.port.__class__.__name__, exception __name__ table for all four errors, all_errors[3].__name__"
  notes:
    - "This spec extends the ftplib chain with __qualname__ vectors not present in any prior spec."
    - "ftplib.FTP.__qualname__ == 'FTP' — top-level class, qualname equals name."
    - "ftplib.FTP_TLS.__qualname__ == 'FTP_TLS' — top-level class."
    - "ftplib.Error.__qualname__ == 'Error' — top-level base exception class."
    - "ftplib.error_reply.__qualname__ == 'error_reply' — top-level exception."
    - "ftplib.error_temp.__qualname__ == 'error_temp' — top-level exception."
    - "ftplib.error_perm.__qualname__ == 'error_perm' — top-level exception."
    - "ftplib.error_proto.__qualname__ == 'error_proto' — top-level exception."
    - "ftplib.FTP_PORT is a module-level integer constant (value 21); distinct from FTP.port (class attribute)."
    - "ftplib_extra2 checks FTP.port.__class__.__name__; this spec checks FTP_PORT.__class__.__name__ (module-level constant)."
    - "ftplib.FTP_PORT == 21 — the module-level FTP port constant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — FTP classes and exception classes
# None of these are covered in any prior ftplib spec.
# ---------------------------------------------------------------------------

table ftplib_extra3.qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [FTP,         FTP.__qualname__.__eq__,         ["FTP"],         true]
    - [FTP_TLS,     FTP_TLS.__qualname__.__eq__,     ["FTP_TLS"],     true]
    - [Error,       Error.__qualname__.__eq__,       ["Error"],       true]
    - [error_reply, error_reply.__qualname__.__eq__, ["error_reply"], true]
    - [error_temp,  error_temp.__qualname__.__eq__,  ["error_temp"],  true]
    - [error_perm,  error_perm.__qualname__.__eq__,  ["error_perm"],  true]
    - [error_proto, error_proto.__qualname__.__eq__, ["error_proto"], true]

# ---------------------------------------------------------------------------
# FTP_PORT — module-level constant type and value
# ftplib.zspec covers FTP.port == 21 (class attribute).
# ftplib_extra2 covers FTP.port.__class__.__name__ == 'int' (class attribute).
# This spec checks FTP_PORT (module-level constant), which is distinct.
# ---------------------------------------------------------------------------

invariant ftplib_extra3.FTP_PORT.class_name:
  description: "ftplib.FTP_PORT.__class__.__name__ == 'int' — module-level FTP port constant is an int"
  category: constants
  kind: python_call_eq
  function: FTP_PORT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant ftplib_extra3.FTP_PORT.value:
  description: "ftplib.FTP_PORT == 21 — standard FTP control port"
  category: constants
  kind: python_call_eq
  function: FTP_PORT.__eq__
  args: [21]
  expected: true
