spec: multiprocessing_extra1951
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 577 (_extra1951): __contains__, __iter__, __next__, __aiter__, __anext__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing has no async iterator types; none of its classes define __aiter__ or __anext__."
    - "None of the multiprocessing classes define __contains__, __iter__, __next__, __aiter__, or __anext__ in their own __dict__."
    - "multiprocessing.queues.Queue is the queue implementation; it provides get/put but no iteration protocol."
  created_at: "2026-04-12"
error_model: python_exceptions

table multiprocessing_extra1951.contains_protocol:
  description: "multiprocessing types __contains__ dict-presence checks — none define __contains__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1951

  columns: [id, function, args, expected]
  rows:
    - ["mp1951001", "multiprocessing.Process.__dict__.__contains__",                      ["__contains__"], false]
    - ["mp1951002", "multiprocessing.synchronize.Lock.__dict__.__contains__",             ["__contains__"], false]
    - ["mp1951003", "multiprocessing.synchronize.RLock.__dict__.__contains__",            ["__contains__"], false]
    - ["mp1951004", "multiprocessing.synchronize.Event.__dict__.__contains__",            ["__contains__"], false]
    - ["mp1951005", "multiprocessing.synchronize.Semaphore.__dict__.__contains__",        ["__contains__"], false]
    - ["mp1951006", "multiprocessing.synchronize.BoundedSemaphore.__dict__.__contains__", ["__contains__"], false]
    - ["mp1951007", "multiprocessing.synchronize.Condition.__dict__.__contains__",        ["__contains__"], false]
    - ["mp1951008", "multiprocessing.queues.Queue.__dict__.__contains__",                 ["__contains__"], false]

