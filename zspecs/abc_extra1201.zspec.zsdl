spec: abc_extra1201
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc.ABCMeta/__bases__/__len__, abc.ABC/__bases__/__len__, abc.abstractmethod/__bases__/__len__, abc.abstractproperty/__bases__/__len__, abc.abstractclassmethod/__bases__/__len__, abc.abstractstaticmethod/__bases__/__len__, abc.ABCMeta/__mro__/__len__, abc.ABC/__mro__/__len__"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc class __bases__.__len__() and __mro__.__len__() for ABCMeta (inherits from type; mro len==3), ABC (inherits from object; mro len==2), abstractmethod (1 base), abstractproperty (1 base), abstractclassmethod (1 base), and abstractstaticmethod (1 base) — behaviors not covered by abc_extra199 or earlier specs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra1201.abcmeta_abc_bases_and_mro_len:
  description: "abc.ABCMeta inherits from type (bases len==1, mro len==3); abc.ABC inherits from object (bases len==1, mro len==2)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: abc1201am
  columns: [id, function, args, expected]
  rows:
    - [abc1201am001, abc.ABCMeta.__bases__.__len__,              [], 1]
    - [abc1201am002, abc.ABCMeta.__mro__.__len__,                [], 3]
    - [abc1201am003, abc.ABCMeta.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [abc1201am004, abc.ABCMeta.__mro__.__class__.__name__.__eq__,   ["tuple"], true]
    - [abc1201am005, abc.ABC.__bases__.__len__,                   [], 1]
    - [abc1201am006, abc.ABC.__mro__.__len__,                     [], 2]
    - [abc1201am007, abc.ABC.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [abc1201am008, abc.ABC.__mro__.__class__.__name__.__eq__,   ["tuple"], true]

table abc_extra1201.abstractmethod_bases_len:
  description: "abc.abstractmethod and abc.abstractproperty each have exactly one direct base class"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: abc1201ab
  columns: [id, function, args, expected]
  rows:
    - [abc1201ab001, abc.abstractmethod.__bases__.__len__,              [], 1]
    - [abc1201ab002, abc.abstractproperty.__bases__.__len__,            [], 1]
    - [abc1201ab003, abc.abstractmethod.__bases__.__class__.__name__.__eq__,  ["tuple"], true]
    - [abc1201ab004, abc.abstractproperty.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [abc1201ab005, abc.abstractmethod.__mro__.__class__.__name__.__eq__,    ["tuple"], true]
    - [abc1201ab006, abc.abstractproperty.__mro__.__class__.__name__.__eq__,  ["tuple"], true]
    - [abc1201ab007, abc.abstractmethod.__name__.__len__.__eq__,              [14],      true]
    - [abc1201ab008, abc.abstractproperty.__name__.__len__.__eq__,            [16],      true]

table abc_extra1201.deprecated_decorators_bases_len:
  description: "abc.abstractclassmethod and abc.abstractstaticmethod each have exactly one direct base class (deprecated since 3.3, still present)"
