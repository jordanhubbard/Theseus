  rows:
    - [abc1201dd001, abc.abstractclassmethod.__bases__.__len__,              [], 1]
    - [abc1201dd002, abc.abstractstaticmethod.__bases__.__len__,             [], 1]
    - [abc1201dd003, abc.abstractclassmethod.__bases__.__class__.__name__.__eq__,  ["tuple"], true]
    - [abc1201dd004, abc.abstractstaticmethod.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [abc1201dd005, abc.abstractclassmethod.__mro__.__class__.__name__.__eq__,    ["tuple"], true]
