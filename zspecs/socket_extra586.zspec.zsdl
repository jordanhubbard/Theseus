spec: socket_extra586
version: ">=3.9"
backend: python_module(socket)
docs: "https://docs.python.org/3/library/socket.html"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket class and exception identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers socket.socket class qualname, module identity, method qualnames, and exception module identity"
  created_at: "2026-04-12T00:00:00Z"

table socket_extra586.socket_class_identity:
  description: "socket.socket class qualname and module identity"
  columns: [id, function, args, expected]
  rows:
    - [sk586md01, socket.socket.__qualname__.__eq__, ["socket"], true]
    - [sk586md02, socket.socket.__module__.__eq__, ["socket"], true]

table socket_extra586.socket_method_qualnames:
  description: "socket.socket method __qualname__ values"
  columns: [id, function, args, expected]
  rows:
    - [sk586qn01, socket.socket.__init__.__qualname__.__eq__, ["socket.__init__"], true]
    - [sk586qn02, socket.socket.connect.__qualname__.__eq__, ["socket.connect"], true]
    - [sk586qn03, socket.socket.bind.__qualname__.__eq__, ["socket.bind"], true]
    - [sk586qn04, socket.socket.listen.__qualname__.__eq__, ["socket.listen"], true]
    - [sk586qn05, socket.socket.accept.__qualname__.__eq__, ["socket.accept"], true]
    - [sk586qn06, socket.socket.send.__qualname__.__eq__, ["socket.send"], true]
    - [sk586qn07, socket.socket.recv.__qualname__.__eq__, ["socket.recv"], true]
    - [sk586qn08, socket.socket.close.__qualname__.__eq__, ["socket.close"], true]

table socket_extra586.socket_exception_identity:
  description: "socket exception types have correct module identity"
  columns: [id, function, args, expected]
  rows:
    - [sk586md03, socket.timeout.__module__.__eq__, ["socket"], true]
    - [sk586md04, socket.herror.__module__.__eq__, ["socket"], true]
    - [sk586md05, socket.gaierror.__module__.__eq__, ["socket"], true]
