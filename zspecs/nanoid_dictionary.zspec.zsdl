spec: nanoid_dictionary
version: ">=4.0.0"
backend: node(nanoid-dictionary)

docs: https://github.com/CyberAP/nanoid-dictionary#readme

provenance:
  derived_from:
    - "nanoid-dictionary README — https://github.com/CyberAP/nanoid-dictionary#readme"
    - "Test vectors verified with nanoid-dictionary via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "nanoid-dictionary source"
  notes:
    - "Predefined character-set strings for use with nanoid's customAlphabet()."
    - "Install: npm install nanoid-dictionary"
    - "Static data: alphanumeric (62 chars), lowercase, uppercase, numbers, hexadecimal*, cookieSafe, nolookalikes*."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure data lookup; never throws."
  stderr: "null"
  stickiness: "N/A — pure data."
  codes: {}

invariant nanoid_dictionary.alphanumeric_length:
  description: "alphanumeric is 62 chars (26 lower + 26 upper + 10 digits)"
  category: alphanumeric
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: alphanumeric}
    - {get: length}
  expected: 62

invariant nanoid_dictionary.lowercase_value:
  description: "lowercase is the 26-letter alphabet"
  category: lowercase
  kind: node_property_eq
  entry: bare
  property: lowercase
  expected: "abcdefghijklmnopqrstuvwxyz"

invariant nanoid_dictionary.uppercase_value:
  description: "uppercase is the 26-letter alphabet (uppercase)"
  category: uppercase
  kind: node_property_eq
  entry: bare
  property: uppercase
  expected: "ABCDEFGHIJKLMNOPQRSTUVWXYZ"

invariant nanoid_dictionary.numbers_value:
  description: "numbers is the 10 digit characters"
  category: numbers
  kind: node_property_eq
  entry: bare
  property: numbers
  expected: "0123456789"

invariant nanoid_dictionary.hexadecimalLowercase_length:
  description: "hexadecimalLowercase is 16 chars (0-9a-f)"
  category: hex
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: hexadecimalLowercase}
    - {get: length}
  expected: 16

invariant nanoid_dictionary.nolookalikes_smaller_than_alphanumeric:
  description: "nolookalikes excludes confusable chars (1/I/l/O/0) — has fewer chars than alphanumeric"
  category: nolookalikes
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: nolookalikes}
    - {get: length}
  expected: 49

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:39:58Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
