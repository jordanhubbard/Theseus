    - ["ab2596008", "abc.ABC.__dict__.__contains__",                    ["__set__"],    false]
    - ["ab2596009", "abc.ABC.__dict__.__contains__",                    ["__delete__"], false]
    - ["ab2596010", "abc.abstractclassmethod.__dict__.__contains__",    ["__get__"],    false]
    - ["ab2596011", "abc.abstractclassmethod.__dict__.__contains__",    ["__set__"],    false]
    - ["ab2596012", "abc.abstractclassmethod.__dict__.__contains__",    ["__delete__"], false]

