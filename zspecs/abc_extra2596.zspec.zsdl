spec: abc_extra2596
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#descriptors — Python descriptor protocol"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 2596 theme: __get__, __set__, __delete__ descriptor protocol dict-presence — checking whether abc classes implement the descriptor protocol."
    - "Key finding: abc.abstractproperty inherits from property, which defines __get__, __set__, and __delete__ in property.__dict__. However, abstractproperty itself does NOT define these methods in its own __dict__ — it inherits them via its MRO (abstractproperty -> property -> object). Thus '__get__' in abc.abstractproperty.__dict__ is False, but hasattr(abc.abstractproperty, '__get__') is True."
    - "abc.abstractclassmethod inherits from classmethod (which defines __get__ in classmethod.__dict__); abc.abstractstaticmethod inherits from staticmethod (which defines __get__ in staticmethod.__dict__). Neither defines __get__ in their own __dict__ directly."
    - "abc.ABCMeta and abc.ABC are metaclass/base class utilities with no descriptor protocol methods in their own __dict__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table abc_extra2596.abstractproperty_own_dict_descriptor_protocol:
  description: "abc.abstractproperty own __dict__ does NOT contain __get__/__set__/__delete__ — inherited from property, not defined directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2596
  columns: [id, function, args, expected]
  rows:
    - ["ab2596001", "abc.abstractproperty.__dict__.__contains__",  ["__get__"],    false]
    - ["ab2596002", "abc.abstractproperty.__dict__.__contains__",  ["__set__"],    false]
    - ["ab2596003", "abc.abstractproperty.__dict__.__contains__",  ["__delete__"], false]
    - ["ab2596004", "abc.ABCMeta.__dict__.__contains__",           ["__get__"],    false]
    - ["ab2596005", "abc.ABCMeta.__dict__.__contains__",           ["__set__"],    false]
    - ["ab2596006", "abc.ABCMeta.__dict__.__contains__",           ["__delete__"], false]

