spec: hashlib_extra306
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "This spec extends hashlib.zspec.zsdl, hashlib_extra.zspec.zsdl, and hashlib_extra2.zspec.zsdl; it does NOT duplicate invariants already present in those files."
    - "hashlib.new('nonexistent_algorithm') raises ValueError with 'unsupported hash type nonexistent_algorithm'."
    - "hashlib.new('md5', b'hello').hexdigest() returns a 32-character hex string (16 bytes * 2 hex chars)."
    - "hashlib.sha256(b'hello').copy().__class__.__name__ == 'HASH' — CPython's internal HASH C type name."
    - "hashlib.sha256(b'hello').digest().__len__() == 32 — SHA-256 always produces 32 raw bytes."
    - "hashlib.sha256(b'hello').hexdigest().__len__() == 64 — 32 bytes * 2 hex chars each."
    - "hashlib.md5(b'test').update(b'') returns None and does not raise — updating with empty bytes is a no-op."
    - "hashlib.md5(b'test').hexdigest() == '098f6bcd4621d373cade4e832627b4f6' — verified against Python 3.14.3."
    - "hashlib.algorithms_available.__class__.__name__ == 'set' — it is a plain Python frozenset or set."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Error: unknown algorithm raises ValueError
# ---------------------------------------------------------------------------

invariant hashlib_extra306.new.unknown_algorithm_raises:
  description: "hashlib.new('nonexistent_algorithm') raises ValueError — unknown hash type"
  category: error
  kind: python_call_raises
  function: new
  args: ["nonexistent_algorithm"]
  raises: ValueError

# ---------------------------------------------------------------------------
# hashlib.new('md5', ...) — hexdigest length
# ---------------------------------------------------------------------------

invariant hashlib_extra306.new_md5.hexdigest_len:
  description: "hashlib.new('md5', b'hello').hexdigest().__len__() == 32"
  category: properties
  kind: python_call_eq
  function: new
  args: ["md5", !bytes aGVsbG8=]
  method: hexdigest.__len__
  method_args: []
  expected: 32

# ---------------------------------------------------------------------------
# sha256 copy — class name
# ---------------------------------------------------------------------------

invariant hashlib_extra306.sha256.copy_class_name:
  description: "hashlib.sha256(b'hello').copy().__class__.__name__ == 'HASH' — CPython C type"
  category: copy_semantics
  kind: python_call_eq
  function: sha256
  args: [!bytes aGVsbG8=]
  method: copy.__class__.__name__.__eq__
  method_args: ["HASH"]
  expected: true

# ---------------------------------------------------------------------------
# sha256 digest/hexdigest lengths
# ---------------------------------------------------------------------------

invariant hashlib_extra306.sha256.digest_len:
  description: "hashlib.sha256(b'hello').digest().__len__() == 32 — raw bytes digest is 32 bytes"
  category: properties
  kind: python_call_eq
  function: sha256
  args: [!bytes aGVsbG8=]
  method: digest.__len__
  method_args: []
  expected: 32

invariant hashlib_extra306.sha256.hexdigest_len:
  description: "hashlib.sha256(b'hello').hexdigest().__len__() == 64 — hex string is 64 chars"
  category: properties
  kind: python_call_eq
  function: sha256
  args: [!bytes aGVsbG8=]
  method: hexdigest.__len__
  method_args: []
  expected: 64

# ---------------------------------------------------------------------------
# md5 update with empty bytes — returns None (no raise)
# ---------------------------------------------------------------------------

invariant hashlib_extra306.md5.update_empty_returns_none:
  description: "hashlib.md5(b'test').update(b'') returns None — updating with empty bytes does not raise"
  category: api_behavior
  kind: python_call_eq
  function: md5
  args: [!bytes dGVzdA==]
  method: update
  method_args: [!bytes ""]
  expected: ~

# ---------------------------------------------------------------------------
# md5(b'test') hexdigest — unchanged by empty update on a separate object
# ---------------------------------------------------------------------------

invariant hashlib_extra306.md5.test_hexdigest:
  description: "hashlib.md5(b'test').hexdigest() == '098f6bcd4621d373cade4e832627b4f6'"
  category: known_vector
  kind: python_call_eq
  function: md5
  args: [!bytes dGVzdA==]
  method: hexdigest
  method_args: []
  expected: "098f6bcd4621d373cade4e832627b4f6"

# ---------------------------------------------------------------------------
# algorithms_available — class name is 'set'
# ---------------------------------------------------------------------------

invariant hashlib_extra306.algorithms_available.class_name:
  description: "hashlib.algorithms_available.__class__.__name__ == 'set'"
  category: module_attributes
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true
