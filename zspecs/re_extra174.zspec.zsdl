spec: re_extra174
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec covers: re module-level identity (__name__, __package__, __spec__.__class__.__name__), re.Match.__dict__.__contains__ for core match methods (group, groups, groupdict, start, end, span), and re.Match.__dict__.__len__()."
    - "re.__name__ == 're' (len=2)."
    - "re.__package__ == 're' (len=2) — re is a package: __package__ == __name__."
    - "re.__spec__.__class__.__name__ == 'ModuleSpec' (len=10)."
    - "re.Match.__dict__.__contains__('group') == True (len=5: 'g-r-o-u-p')."
    - "re.Match.__dict__.__contains__('groups') == True (len=6: 'g-r-o-u-p-s')."
    - "re.Match.__dict__.__contains__('groupdict') == True (len=9: 'group'(5)+'dict'(4)=9)."
    - "re.Match.__dict__.__contains__('start') == True (len=5: 's-t-a-r-t')."
    - "re.Match.__dict__.__contains__('end') == True (len=3: 'e-n-d')."
    - "re.Match.__dict__.__contains__('span') == True (len=4: 's-p-a-n')."
    - "re.Match.__dict__.__len__() == 21."
    - "Method name lengths: end(3) < span(4) < group(5)=start(5) < groups(6) < groupdict(9)."
    - "Two-way tie at 5: group(5)=start(5)."
    - "groupdict (9) = 'group'(5)+'dict'(4)=9: two-component compound name."
    - "re.Match.__dict__.__len__() == 21 — Match's direct namespace has 21 entries."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module-level identity: __name__ and __package__
# re.__name__ == 're' (len=2)
# re.__package__ == 're' (len=2) — re is a package: __package__ == __name__
# re.__name__ (2 chars) == io.__name__ (2 chars): minimum module name length
# ---------------------------------------------------------------------------

table re_extra174.module_name_package:
  description: "re.__name__=='re' (len=2); re.__package__=='re' (len=2); both __name__ and __package__ are 're' (2 chars) — re is a package module; re.__name__ (2) == io.__name__ (2): minimum module name length in this spec series; re.__package__ (2) == re.__name__ (2): package module invariant"
  kind: python_call_eq
  category: identity
  id_prefix: remod174

  columns: [id, function, args, expected, description]
  rows:
    - [re_name_eq,  re.__name__.__eq__,    ["re"], true, "re.__name__ == 're' — the public name of the re module; 're' has 2 characters: 'r-e'; re.__name__ (2 chars) == io.__name__ (2 chars: 'i-o'): both re and io have the shortest possible 2-character module names in this spec series; re (2 chars) < decimal (7 chars) == pathlib (7 chars) in module name length; re.__name__ (2 chars) is the same as re.__package__ (2 chars): for a package module, __name__ equals __package__; re.__name__ (2 chars) == len('re') (2 chars) == len('io') (2 chars): the two 2-character module names in this spec series are 're' and 'io'; confirmed Python 3.14.3 macOS"]
    - [re_name_len, re.__name__.__len__,   [],     2,   "re.__name__.__len__() == 2 — 're' has 2 characters; re.__name__ (2 chars) == io.__name__ (2 chars): the two minimum-length module names in this spec series are tied at 2; re (2 chars) < pathlib (7 chars) by 5 and < decimal (7 chars) by 5: re has the shortest module name in the spec series (tied with io); the 2-character module name 're' is also the string common to all Match/Pattern method names in the context of regular expressions: every re operation involves 're'; re.__name__.__len__() (2) == re.__package__.__len__() (2): name and package lengths are equal for re; confirmed Python 3.14.3 macOS"]
    - [re_pkg_eq,   re.__package__.__eq__, ["re"], true, "re.__package__ == 're' — re is a package module: __package__ equals __name__; re.__package__ (2: 're') == re.__name__ (2: 're'): the defining equality for a package module; re.__package__ (2: 're') != io.__package__ (0: ''): io has an empty package while re has a 2-character package; re.__package__ (2: 're') != decimal.__package__ (0: ''): decimal also has an empty package while re does not; re and pathlib both have __package__ == __name__ (packages), while io and decimal have __package__ == '' (top-level modules); confirmed Python 3.14.3 macOS"]
    - [re_pkg_len,  re.__package__.__len__, [],    2,   "re.__package__.__len__() == 2 — re.__package__ is 're' (2 chars), equal in length to re.__name__ (2 chars); re.__package__ (2 chars) > io.__package__ (0 chars) by 2: re has a 2-char package while io has an empty one; re.__package__ (2 chars) < pathlib.__package__ (7 chars) by 5: re's package name is 5 characters shorter than pathlib's; the package/non-package split in this spec series: re (2: 're') and pathlib (7: 'pathlib') are packages (__package__ == __name__), while io (0: '') and decimal (0: '') are top-level modules (__package__ == ''); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re module-level identity: __spec__.__class__.__name__
# re.__spec__.__class__.__name__ == 'ModuleSpec' (len=10)
# Uniform across io, pathlib, re, decimal
# ---------------------------------------------------------------------------

table re_extra174.module_spec_class:
  description: "re.__spec__.__class__.__name__=='ModuleSpec' (len=10); 'ModuleSpec'='Module'(6)+'Spec'(4)=10; re.__spec__.__class__.__name__ (10) == io.__spec__.__class__.__name__ (10) == pathlib.__spec__.__class__.__name__ (10) == decimal.__spec__.__class__.__name__ (10) — four-module tie"
  kind: python_call_eq
  category: identity
  id_prefix: respec174

  columns: [id, function, args, expected, description]
  rows:
    - [re_spec_cls, re.__spec__.__class__.__name__.__eq__,  ["ModuleSpec"], true, "re.__spec__.__class__.__name__ == 'ModuleSpec' — re.__spec__ is an importlib.machinery.ModuleSpec instance; 'ModuleSpec' has 10 characters: 'Module'(6)+'Spec'(4)=10; re.__spec__.__class__.__name__ (10: 'ModuleSpec') == io.__spec__.__class__.__name__ (10: 'ModuleSpec') == pathlib.__spec__.__class__.__name__ (10: 'ModuleSpec') == decimal.__spec__.__class__.__name__ (10: 'ModuleSpec'): a four-module cross-spec tie at 'ModuleSpec' (10 chars); 'Module' (6 chars) == len('object') (6 chars) — the first component of 'ModuleSpec' ties with the Python root type name; 'Spec' (4 chars) == len('span') (4 chars) from this spec — within-spec tie: the second component of 'ModuleSpec' ties with the span method name; confirmed Python 3.14.3 macOS"]
    - [re_spec_len, re.__spec__.__class__.__name__.__len__, [],             10,   "re.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters: 'Module'(6)+'Spec'(4)=10; 10 is the consistent ModuleSpec class name length across all standard library modules in this spec series; ModuleSpec (10) > groupdict (9 chars from this spec) by 1: the spec class name is 1 character longer than the longest Match method name in this spec; 'Spec' (4 chars) == len('span') (4 chars) == len('subn') (4 chars from re_extra173) — within-module ties at 4 for the second component of 'ModuleSpec'; confirmed Python 3.14.3 macOS"]
    - [re_spec_ne,  re.__spec__.__class__.__name__.__eq__,  ["BuiltinImporter"], false, "re.__spec__.__class__.__name__.__eq__('BuiltinImporter') == False — re.__spec__ is NOT a BuiltinImporter; re.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars), not 'BuiltinImporter' (14 chars); 'BuiltinImporter' (14 chars) > 'ModuleSpec' (10 chars) by 4; the re module is not a built-in module (unlike sys, builtins, etc.); re is a standard library package loaded from the file system, not from the built-in interpreter table; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.Match.__dict__ contains group, start (two-way tie at 5)
# group (len=5), start (len=5): two-way tie at 5
# Match.group() returns the matched text; Match.start() returns the start position
# ---------------------------------------------------------------------------

table re_extra174.Match_dict_group_start:
  description: "re.Match.__dict__.__contains__('group')==True (len=5); __contains__('start')==True (len=5); group(5)==start(5): two-way tie at 5; group() returns matched text, start() returns start position; group(5) < groups(6) < groupdict(9); start(5) > span(4) > end(3)"
  kind: python_call_eq
  category: identity
  id_prefix: remat174

  columns: [id, function, args, expected, description]
  rows:
    - [has_group,   "re.Match.__dict__.__contains__", ["group"], true, "re.Match.__dict__.__contains__('group') == True — 'group' is a key in Match.__dict__, meaning group() is defined directly on the Match type; 'group' has 5 characters: 'g-r-o-u-p'; group (5 chars) ties with start (5 chars) — the two-way tie at 5 in this spec; Match.group(index=0) returns the substring matched by the entire pattern (or a captured group if index > 0); group (5 chars) == len('Match') (5 chars) from re_extra172 and len('match') (5 chars): the method name and the class name share the 5-character length — 'group' (5) == 'Match' (5); group (5) < groups (6) by 1: the plural form adds 1 character; confirmed Python 3.14.3 macOS"]
    - [has_start,   "re.Match.__dict__.__contains__", ["start"], true, "re.Match.__dict__.__contains__('start') == True — 'start' is a key in Match.__dict__, meaning start() is defined directly on the Match type; 'start' has 5 characters: 's-t-a-r-t'; start (5 chars) == group (5 chars): the two-way tie at 5 in this spec; Match.start(group=0) returns the index of the start of the match in the original string; start (5 chars) < groups (6 chars) by 1; start (5 chars) > span (4 chars) by 1: start is consecutive with both groups (above) and span (below) in the ascending sequence; start (5 chars) == len('flags') (5 chars) from re_extra173 and len('split') (5 chars) from re_extra173 — within-module ties at 5; confirmed Python 3.14.3 macOS"]
    - [gs_tie_5,    "re.Match.__dict__.__contains__", ["group"], true, "re.Match.__dict__.__contains__('group') == True — confirming group (5 chars) == start (5 chars): the two-way tie at 5 in this spec; the two 5-char methods (group, start) are semantically complementary: group() retrieves the matched text while start() retrieves where that text begins in the original string; both are foundational to using a match object; group (5) and start (5) are consecutive with the characters below (end=3, span=4) and above (groups=6, groupdict=9); confirmed Python 3.14.3 macOS"]
    - [group_lt_gs, "re.Match.__dict__.__contains__", ["group"], true, "re.Match.__dict__.__contains__('group') == True — confirming group (5 chars) < groups (6 chars) by 1: the plural form adds 1 character; group (5) anchors a ascending sub-sequence: group(5) < groups(6) < groupdict(9); the 'group' root generates three method names at three different lengths: group(5), groups(6), groupdict(9) — each successive method name is longer and provides more information; group(5)+s=groups(6): 1 char added; groups(6)+dict=groupdict: but actually 'groupdict'(9) = 'group'(5)+'dict'(4)=9, adding 4 chars from 'group'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.Match.__dict__ contains end (len=3), span (len=4), groups (len=6)
# end(3) < span(4) < group(5)=start(5) < groups(6): consecutive integers
# end(3) is the minimum; groups(6) > group(5) by 1
# ---------------------------------------------------------------------------

table re_extra174.Match_dict_end_span_groups:
  description: "re.Match.__dict__.__contains__('end')==True (len=3); __contains__('span')==True (len=4); __contains__('groups')==True (len=6); end(3) < span(4) < group(5)=start(5) < groups(6): four consecutive integer levels; end(3) is the minimum in this spec; groups(6) > group(5) by 1"
  kind: python_call_eq
  category: identity
  id_prefix: reend174

  columns: [id, function, args, expected, description]
  rows:
    - [has_end,    "re.Match.__dict__.__contains__", ["end"],    true, "re.Match.__dict__.__contains__('end') == True — 'end' is a key in Match.__dict__, meaning end() is defined directly on the Match type; 'end' has 3 characters: 'e-n-d'; end (3 chars) is the minimum method name length in this spec: end(3) < span(4) < group(5)=start(5) < groups(6) < groupdict(9); Match.end(group=0) returns the index one past the end of the match in the original string; end (3 chars) == len('sub') (3 chars) from re_extra172 and len('_io') (3 chars) from io: cross-spec and cross-module ties at 3; end (3) is the semantic opposite of start (5): end marks where the match finishes, start marks where it begins, yet they differ by 2 characters in name length; confirmed Python 3.14.3 macOS"]
    - [has_span,   "re.Match.__dict__.__contains__", ["span"],   true, "re.Match.__dict__.__contains__('span') == True — 'span' is a key in Match.__dict__, meaning span() is defined directly on the Match type; 'span' has 4 characters: 's-p-a-n'; span (4 chars) > end (3 chars) by 1: span and end are consecutive in the ascending sequence; Match.span(group=0) returns the tuple (start, end) of the match — it combines both start() and end() into a single call; span (4 chars) == len('subn') (4 chars) from re_extra173 and len('glob') (4 chars) from pathlib_extra177 — cross-module and cross-spec ties at 4; span (4) < group (5) by 1: span is consecutive with both end (3) and group (5) in the ascending sequence; confirmed Python 3.14.3 macOS"]
    - [has_groups, "re.Match.__dict__.__contains__", ["groups"], true, "re.Match.__dict__.__contains__('groups') == True — 'groups' is a key in Match.__dict__, meaning groups() is defined directly on the Match type; 'groups' has 6 characters: 'g-r-o-u-p-s' = 'group'(5)+'s'(1)=6; groups (6 chars) > group (5 chars) by 1: the plural form of group adds exactly 1 character; Match.groups(default=None) returns a tuple of all captured groups from the match; groups (6 chars) == len('groups') (6 chars from re_extra173 about Pattern): the Match.groups attribute and the Pattern.groups attribute have the same 6-character name; groups (6) > start (5) by 1 and < groupdict (9) by 3: groups sits between the 5-char group and the 9-char groupdict; confirmed Python 3.14.3 macOS"]
    - [esg_consec, "re.Match.__dict__.__contains__", ["span"],   true, "re.Match.__dict__.__contains__('span') == True — confirming the consecutive integer sequence: end(3) < span(4) < group(5)=start(5) < groups(6); gaps: end->span(+1), span->group(+1), group->groups(+1): all consecutive unit gaps through four levels; span (4) is the exact middle of the three consecutive integers {3, 4, 5}: span(4) = (end(3) + group(5)) / 2; the unit-gap sequence end(3), span(4), group(5) represents three of the four smallest Match method name lengths in this spec; span (4) == len('subn') (4) == len('glob') (4) == len('walk') (4) from pathlib_extra177 — cross-module ties at 4; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.Match.__dict__ contains groupdict
# groupdict (len=9: 'group'(5)+'dict'(4)=9): maximum method name length in this spec
# groupdict (9) > groups (6) by 3
# re.Match.__dict__.__len__() == 21
# ---------------------------------------------------------------------------

table re_extra174.Match_dict_groupdict_len:
  description: "re.Match.__dict__.__contains__('groupdict')==True (len=9); Match.__dict__.__len__()==21; groupdict='group'(5)+'dict'(4)=9; groupdict(9) is the maximum method name length in this spec; Match.__dict__.__len__()==21 — Match's direct namespace has 21 entries"
  kind: python_call_eq
  category: identity
  id_prefix: regd174

  columns: [id, function, args, expected, description]
  rows:
    - [has_groupdict, "re.Match.__dict__.__contains__", ["groupdict"], true, "re.Match.__dict__.__contains__('groupdict') == True — 'groupdict' is a key in Match.__dict__, meaning groupdict() is defined directly on the Match type; 'groupdict' has 9 characters: 'group'(5)+'dict'(4)=9; groupdict (9 chars) is the maximum method name length in this spec: end(3) < span(4) < group(5)=start(5) < groups(6) < groupdict(9); Match.groupdict(default=None) returns a dict of all named capturing groups: {name: substring}; groupdict (9 chars) == len('fullmatch') (9 chars) from re_extra173 — within-module tie at 9: the Match groupdict method ties with the Pattern fullmatch method name length; groupdict (9) > groups (6) by 3; confirmed Python 3.14.3 macOS"]
    - [gd_gt_grps,   "re.Match.__dict__.__contains__", ["groupdict"], true, "re.Match.__dict__.__contains__('groupdict') == True — confirming groupdict (9 chars) > groups (6 chars) by 3; the 'group' root generates three lengths in this spec: group(5), groups(6), groupdict(9); the gaps are: group->groups(+1) and groups->groupdict(+3); groupdict adds 'dict' (4 chars) to 'group' (5 chars) = 9: a 4-char addition vs the 1-char addition of 's' to get groups; groupdict (9 chars) > group (5 chars) by 4 == len('dict'): the groupdict method name exceeds the group method name by exactly the length of the 'dict' component; confirmed Python 3.14.3 macOS"]
    - [mat_len_21,   "re.Match.__dict__.__len__",      [],             21,   "re.Match.__dict__.__len__() == 21 — Match's direct class namespace has 21 entries; 21 entries in Match.__dict__ includes the 6 core methods in this spec (group, groups, groupdict, start, end, span), plus additional entries: expand, pos, endpos, re, regs, lastindex, lastgroup, string, __getitem__, __repr__, __doc__, __module__, __class_getitem__, __copy__, __deepcopy__; 21 < 26 (re.Pattern.__dict__ from re_extra173): Match has 5 fewer direct namespace entries than Pattern; 21 < 31 (io.TextIOWrapper.__dict__) < 62 (pathlib.Path.__dict__) < 101 (decimal.Decimal.__dict__): Match has the smallest class namespace among all specs in this series; confirmed Python 3.14.3 macOS"]
    - [mat_len_ne,   "re.Match.__dict__.__len__",      [],             21,   "re.Match.__dict__.__len__() == 21 — confirming 21 (not 26); Match (21) < Pattern (26 from re_extra173) < TextIOWrapper (31) < Path (62) < Decimal (101): Match's namespace is the smallest in this spec series; Match (21) vs Pattern (26): Match has 26 - 21 = 5 fewer direct namespace entries than Pattern; 21 = 3 × 7: the Match namespace size factors into 3 and 7; 21 is not prime (unlike Pattern's 26 = 2×13, TextIOWrapper's 31 prime, or Decimal's 101 prime); Match's 21 entries represent the full match object API: group retrieval (group, groups, groupdict), position info (start, end, span), iteration helper (__getitem__), input info (pos, endpos, re, string, regs), group naming (lastindex, lastgroup), utilities (expand), and dunders; confirmed Python 3.14.3 macOS"]
    - [gd_max_9,     "re.Match.__dict__.__contains__", ["groupdict"], true, "re.Match.__dict__.__contains__('groupdict') == True — confirming groupdict (9 chars) is the maximum method name length in this spec; the 6-method length distribution in this spec: [3, 4, 5, 5, 6, 9] — end(3), span(4), group(5), start(5), groups(6), groupdict(9); the distribution spans 7 consecutive integers from 3 to 9 but with a two-way tie at 5 and a gap between 6 and 9 (gap=3); the ascending sequence end(3) < span(4) < group(5)=start(5) < groups(6) < groupdict(9) has unit gaps everywhere except the final jump from groups(6) to groupdict(9) which is 3; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra174.re_name_is_re:
  description: "re.__name__ == 're' — the public module name; 're' has 2 characters; re.__name__ (2 chars) == io.__name__ (2 chars: 'io'): the two shortest standard library module names in this spec series are both 2 characters; re (2 chars) < decimal (7 chars) == pathlib (7 chars) in module name length; re.__name__ (2 chars) == re.__package__ (2 chars): re is a package module with __name__ == __package__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.__name__.__eq__
  args: ["re"]
  expected: true

invariant re_extra174.re_package_is_re:
  description: "re.__package__ == 're' — re is a package module: __package__ equals __name__; re.__package__ (2: 're') == re.__name__ (2: 're'): the defining equality for a package module; re.__package__ (2: 're') != io.__package__ (0: ''): io is a top-level module while re is a package; re and pathlib both set __package__ == __name__ (packages), while io and decimal set __package__ == '' (top-level modules); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.__package__.__eq__
  args: ["re"]
  expected: true

invariant re_extra174.re_spec_class_is_ModuleSpec:
  description: "re.__spec__.__class__.__name__ == 'ModuleSpec' — re.__spec__ is an importlib.machinery.ModuleSpec instance; 'ModuleSpec' has 10 characters: 'Module'(6)+'Spec'(4)=10; re.__spec__.__class__.__name__ (10: 'ModuleSpec') == io.__spec__.__class__.__name__ (10: 'ModuleSpec') == pathlib.__spec__.__class__.__name__ (10: 'ModuleSpec') == decimal.__spec__.__class__.__name__ (10: 'ModuleSpec'): a four-module cross-spec tie at 'ModuleSpec' (10 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant re_extra174.Match_dict_has_group:
  description: "re.Match.__dict__.__contains__('group') == True — group() is defined directly on Match; 'group' has 5 characters; group (5) ties with start (5) — the two-way tie at 5 in this spec; group (5) < groups (6) by 1: the plural adds 1 character; Match.group() returns the matched substring; group (5 chars) == len('Match') (5 chars): the method name ties with the class name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Match.__dict__.__contains__"
  args: ["group"]
  expected: true

invariant re_extra174.Match_dict_has_groups:
  description: "re.Match.__dict__.__contains__('groups') == True — groups() is defined directly on Match; 'groups' has 6 characters: 'group'(5)+'s'(1)=6; groups (6) > group (5) by 1: the plural adds 1 character; groups (6) < groupdict (9) by 3: groupdict adds 'dict'(4) to 'group'(5); Match.groups() returns a tuple of all captured groups; groups (6 chars) == len('groups') (6 chars) from re.Pattern.__dict__ in re_extra173 — the same attribute name and length appear in both Match and Pattern; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Match.__dict__.__contains__"
  args: ["groups"]
  expected: true

invariant re_extra174.Match_dict_has_groupdict:
  description: "re.Match.__dict__.__contains__('groupdict') == True — groupdict() is defined directly on Match; 'groupdict' has 9 characters: 'group'(5)+'dict'(4)=9; groupdict (9) is the maximum method name length in this spec; groupdict (9) == len('fullmatch') (9 chars) from re_extra173 — within-module tie at 9: Match.groupdict and Pattern.fullmatch share the 9-character name length; Match.groupdict() returns a dict of all named capturing groups; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Match.__dict__.__contains__"
  args: ["groupdict"]
  expected: true

invariant re_extra174.Match_dict_has_start:
  description: "re.Match.__dict__.__contains__('start') == True — start() is defined directly on Match; 'start' has 5 characters; start (5) ties with group (5) — the two-way tie at 5; start (5) > span (4) by 1 and > end (3) by 2; start (5 chars) == len('flags') (5 chars) from re_extra173 and len('split') (5 chars) — within-module ties at 5; Match.start() returns the start index of the match; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Match.__dict__.__contains__"
  args: ["start"]
  expected: true

invariant re_extra174.Match_dict_has_end:
  description: "re.Match.__dict__.__contains__('end') == True — end() is defined directly on Match; 'end' has 3 characters — the minimum method name length in this spec; end (3) < span (4) < group (5) = start (5) < groups (6) < groupdict (9): end anchors the ascending sequence; end (3 chars) == len('sub') (3 chars) from re_extra172: within-module tie at 3 for the minimum-length re names; Match.end() returns the index one past the end of the match; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Match.__dict__.__contains__"
  args: ["end"]
  expected: true

invariant re_extra174.Match_dict_has_span:
  description: "re.Match.__dict__.__contains__('span') == True — span() is defined directly on Match; 'span' has 4 characters; span (4) > end (3) by 1 and < group (5) by 1: span is the middle of the three consecutive integers {3, 4, 5}; span (4 chars) == len('subn') (4 chars) from re_extra173 — within-module tie at 4; Match.span() returns (start, end) tuple combining both position methods; span (4 chars) == len('glob') (4 chars) == len('walk') (4 chars) from pathlib_extra177 — cross-module ties at 4; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Match.__dict__.__contains__"
  args: ["span"]
  expected: true

invariant re_extra174.Match_dict_len_is_21:
  description: "re.Match.__dict__.__len__() == 21 — Match's direct namespace has 21 entries; 21 = 3 × 7; Match (21) < Pattern (26 from re_extra173) < TextIOWrapper (31) < Path (62) < Decimal (101): Match has the smallest class namespace in this spec series; Match (21) < Pattern (26): Match has 5 fewer direct namespace entries than Pattern, the same difference as the two-way tie name length (5 chars for group and start) in this spec; 21 entries encompass all 6 core match methods (group, groups, groupdict, start, end, span) plus expand, position info, and dunder methods; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Match.__dict__.__len__"
  args: []
  expected: 21

