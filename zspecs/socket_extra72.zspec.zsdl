spec: socket_extra72
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra71.zspec.zsdl — covers socket.gaierror/__name__/__module__/__bases__[0]/__mro__.__len__() / socket.herror/__name__/__module__/__bases__[0] / socket.timeout/__name__=='TimeoutError' / socket.error/__name__=='OSError' (table + invariants)."
    - "socket_extra70.zspec.zsdl — covers socket.socket.accept/__qualname__=='socket.accept' / accept/__class__/__name__=='function' / connect/__qualname__=='socket.connect' / bind/__qualname__=='socket.bind' / listen/__qualname__=='socket.listen' / AF_INET/__class__/__name__=='AddressFamily' / SOCK_STREAM/__class__/__name__=='SocketKind' (table + invariants)."
    - "socket_extra69.zspec.zsdl — covers socket module __name__/__spec__.name/__spec__.__class__/__loader__.__class__ / socket.socket.__dict__.__class__=='mappingproxy' / socket.__dict__.__contains__ accept/makefile/setblocking/settimeout (table + invariants)."
    - "socket_extra68.zspec.zsdl — covers socket.connect/bind/sendall/recv __class__/__name__=='method_descriptor' / __qualname__ eq and len / socket.__doc__/__class__/__name__=='str' (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra71; it does NOT duplicate invariants present in those files."
    - "Wave 239 theme: socket.socket method qualname lengths + socket module function identity."
    - "In python_module(socket), 'socket' in the module namespace refers to the socket.socket class. Module-level functions like gethostname are accessed directly by name."
    - "socket.socket.accept.__qualname__.__len__() == 13 — 'socket.accept' has 13 chars. socket_extra70 covers accept.__qualname__=='socket.accept'; this spec adds the len() check. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__qualname__.__len__() == 14 — 'socket.connect' has 14 chars (6+1+7). socket_extra70 covers connect.__qualname__=='socket.connect'; this spec adds the len() check. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__qualname__.__len__() == 11 — 'socket.bind' has 11 chars (6+1+4). socket_extra70 covers bind.__qualname__=='socket.bind'; this spec adds the len() check. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__qualname__.__len__() == 13 — 'socket.listen' has 13 chars (6+1+6). socket_extra70 covers listen.__qualname__=='socket.listen'; this spec adds the len() check. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__qualname__.__len__() == 12 — 'socket.close' has 12 chars (6+1+5). No prior socket spec checks close.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__class__.__name__ == 'builtin_function_or_method' — gethostname is a C builtin in the socket module. socket_extra67 covers gethostname/__class__/__name__; re-anchored in extra72 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__class__.__name__ == 'builtin_function_or_method' — gethostbyname is a C builtin. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getnameinfo.__class__.__name__ == 'builtin_function_or_method' — getnameinfo is a C builtin. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__class__.__name__ == 'builtin_function_or_method' — setdefaulttimeout is a C builtin. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.accept / connect qualname length
#
# Wave 239 theme: socket.socket method qualname lengths.
#
# socket.socket.accept.__qualname__ == 'socket.accept' (len 13).
# socket.socket.connect.__qualname__ == 'socket.connect' (len 14).
# socket_extra70 covers the qualname equality for accept and connect.
# No prior socket spec checks qualname.__len__() for any socket.socket method.
# In python_module(socket), 'socket' refers to the socket.socket class.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra72.socket_method_qualname_len_accept_connect:
  description: "socket.socket.accept/__qualname__.__len__()==13 / socket.socket.connect/__qualname__.__len__()==14 — accept qualname 'socket.accept' is 13 chars; connect qualname 'socket.connect' is 14 chars; socket_extra70 covers qualname equality; no prior socket spec checks qualname.__len__() for socket.socket methods; first qualname length anchor for accept and connect"
  kind: python_call_eq
  category: qualnames
  id_prefix: socketmore72

  columns: [id, function, args, expected]
  rows:
    - [accept_qualname_len_13,  socket.accept.__qualname__.__len__,  [], 13]
    - [connect_qualname_len_14, socket.connect.__qualname__.__len__, [], 14]

# ---------------------------------------------------------------------------
# socket.socket.bind / listen / close qualname length
#
# Wave 239 theme: socket.socket method qualname lengths (bind, listen, close).
#
# socket.socket.bind.__qualname__ == 'socket.bind' (len 11).
# socket.socket.listen.__qualname__ == 'socket.listen' (len 13).
# socket.socket.close.__qualname__ == 'socket.close' (len 12).
# socket_extra70 covers bind and listen qualname equality. No prior socket
# spec checks qualname.__len__() for any socket.socket method.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra72.socket_method_qualname_len_bind_listen_close:
  description: "socket.socket.bind/__qualname__.__len__()==11 / socket.socket.listen/__qualname__.__len__()==13 / socket.socket.close/__qualname__.__len__()==12 — bind qualname 'socket.bind' is 11 chars; listen qualname 'socket.listen' is 13 chars; close qualname 'socket.close' is 12 chars; socket_extra70 covers bind/listen qualname equality; no prior socket spec checks qualname.__len__() for bind/listen/close; first qualname length anchor for bind/listen/close"
  kind: python_call_eq
  category: qualnames
  id_prefix: socketmore72

  columns: [id, function, args, expected]
  rows:
    - [bind_qualname_len_11,   socket.bind.__qualname__.__len__,   [], 11]
    - [listen_qualname_len_13, socket.listen.__qualname__.__len__, [], 13]
    - [close_qualname_len_12,  socket.close.__qualname__.__len__,  [], 12]

# ---------------------------------------------------------------------------
# socket.gethostname / gethostbyname __class__.__name__
#
# Wave 239 theme: socket module-level C builtin function identity.
#
# socket.gethostname and socket.gethostbyname are C builtin functions in the
# socket module. socket_extra67 covers gethostname/__class__/__name__.
# Re-anchored in extra72 namespace alongside the novel qualname length checks.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra72.module_func_class_gethostname_gethostbyname:
  description: "socket.gethostname/__class__/__name__.__eq__('builtin_function_or_method')==True / gethostbyname/__class__/__name__.__eq__('builtin_function_or_method')==True — gethostname and gethostbyname are C builtins in the socket module; socket_extra67 covers gethostname class; re-anchored in extra72 namespace alongside novel qualname length checks; first combined class identity table for gethostname+gethostbyname in extra72"
  kind: python_call_eq
  category: class_identity
  id_prefix: socketmore72

  columns: [id, function, args, expected]
  rows:
    - [gethostname_class_builtin,   gethostname.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [gethostbyname_class_builtin, gethostbyname.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# socket.getnameinfo / socket.setdefaulttimeout __class__.__name__
#
# Wave 239 theme: socket module-level C builtin function identity (getnameinfo).
#
# socket.getnameinfo and socket.setdefaulttimeout are C builtin functions.
# No prior socket spec checks getnameinfo.__class__.__name__ or
# setdefaulttimeout.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra72.module_func_class_getnameinfo_setdefaulttimeout:
  description: "socket.getnameinfo/__class__/__name__.__eq__('builtin_function_or_method')==True / setdefaulttimeout/__class__/__name__.__eq__('builtin_function_or_method')==True — getnameinfo and setdefaulttimeout are C builtins in the socket module; no prior socket spec checks getnameinfo/__class__/__name__ or setdefaulttimeout/__class__/__name__; first class identity anchor for getnameinfo and setdefaulttimeout"
  kind: python_call_eq
  category: class_identity
  id_prefix: socketmore72

  columns: [id, function, args, expected]
  rows:
    - [getnameinfo_class_builtin,       getnameinfo.__class__.__name__.__eq__,       ["builtin_function_or_method"], true]
    - [setdefaulttimeout_class_builtin, setdefaulttimeout.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

