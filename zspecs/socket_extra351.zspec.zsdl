spec: socket_extra351
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "socket.AF_INET == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET6 == 30 (macOS value; Linux uses 10). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_TCP == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_UDP == 17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: AF_INET and AF_INET6 are AddressFamily IntEnum members. AF_INET6==30 is macOS/BSD-specific; Linux uses 10."
    - "Note: SOCK_STREAM and SOCK_DGRAM are SocketKind IntEnum members. Values 1 and 2 are universal across POSIX platforms."
    - "Note: IPPROTO_TCP==6 and IPPROTO_UDP==17 are IANA-assigned protocol numbers, universal across all platforms."
    - "Note: IPPROTO_TCP and IPPROTO_UDP are plain int values on macOS (not IntEnum members)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET.__eq__(2)
# socket.AF_INET6.__eq__(30)
# socket.SOCK_STREAM.__eq__(1)
# socket.SOCK_DGRAM.__eq__(2)
#
# Wave 351 theme: socket AF_* and SOCK_* constant values on macOS.
#
# AF_INET is AddressFamily.AF_INET with value 2 — universally 2 on all
# POSIX platforms (IPv4 address family). AF_INET6 is AddressFamily.AF_INET6
# with value 30 on macOS/Darwin (BSD-derived); Linux uses 10 for AF_INET6.
# SOCK_STREAM is SocketKind.SOCK_STREAM with value 1 — TCP stream socket,
# universal across all POSIX platforms. SOCK_DGRAM is SocketKind.SOCK_DGRAM
# with value 2 — UDP datagram socket, universal. These are IntEnum members;
# their __eq__ compares by integer value.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra351.af_and_sock_constants:
  description: "AF_INET.__eq__(2)==True / AF_INET6.__eq__(30)==True / SOCK_STREAM.__eq__(1)==True / SOCK_DGRAM.__eq__(2)==True — AddressFamily and SocketKind IntEnum values on macOS/Darwin 25.4.0: AF_INET==2 (universal POSIX IPv4), AF_INET6==30 (macOS/BSD; Linux==10), SOCK_STREAM==1 (universal TCP), SOCK_DGRAM==2 (universal UDP); first socketid351 anchor for AF_* and SOCK_* constant values"
  kind: python_call_eq
  category: socket_constants
  id_prefix: socketid351

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_eq,     "AF_INET.__eq__",     [2],  true, "socket.AF_INET == 2 — IPv4 address family (AddressFamily IntEnum); value 2 is universal across all POSIX platforms"]
    - [af_inet6_eq,    "AF_INET6.__eq__",    [30], true, "socket.AF_INET6 == 30 — IPv6 address family (AddressFamily IntEnum); value 30 on macOS/BSD (Linux uses 10)"]
    - [sock_stream_eq, "SOCK_STREAM.__eq__", [1],  true, "socket.SOCK_STREAM == 1 — TCP stream socket type (SocketKind IntEnum); value 1 is universal across POSIX platforms"]
    - [sock_dgram_eq,  "SOCK_DGRAM.__eq__",  [2],  true, "socket.SOCK_DGRAM == 2 — UDP datagram socket type (SocketKind IntEnum); value 2 is universal across POSIX platforms"]

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__eq__(6)
# socket.IPPROTO_UDP.__eq__(17)
#
# Wave 351 theme: socket.IPPROTO_TCP and IPPROTO_UDP protocol constant values.
#
# IPPROTO_TCP is 6 — the IANA-assigned protocol number for the Transmission
# Control Protocol. IPPROTO_UDP is 17 — the IANA-assigned protocol number
# for the User Datagram Protocol. Both values are defined in RFC 791 (IP)
# and IANA protocol number assignments; they are universal across all
# platforms. On macOS, IPPROTO_TCP and IPPROTO_UDP are plain int values
# (not IntEnum members), unlike AF_* and SOCK_* which are IntEnum.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra351.ipproto_tcp_udp_values:
  description: "IPPROTO_TCP.__eq__(6)==True / IPPROTO_UDP.__eq__(17)==True — IANA-assigned protocol numbers: TCP==6 (RFC 793), UDP==17 (RFC 768); universal across all platforms; plain int on macOS (not IntEnum unlike AF_*/SOCK_*); first socketid351 anchor for IPPROTO_TCP and IPPROTO_UDP values"
  kind: python_call_eq
  category: protocol_constants
  id_prefix: socketid351

  columns: [id, function, args, expected, description]
  rows:
    - [ipproto_tcp_eq, "IPPROTO_TCP.__eq__", [6],  true, "socket.IPPROTO_TCP == 6 — IANA protocol number for TCP (RFC 793); universal; plain int on macOS"]
    - [ipproto_udp_eq, "IPPROTO_UDP.__eq__", [17], true, "socket.IPPROTO_UDP == 17 — IANA protocol number for UDP (RFC 768); universal; plain int on macOS"]

# ---------------------------------------------------------------------------
# socket.AF_INET.__eq__(2) — standalone
#
# socket.AF_INET is 2. AF_INET is the AddressFamily IntEnum member for the
# IPv4 address family. Its integer value 2 is universally consistent across
# all POSIX platforms (Linux, macOS, BSD, Solaris). AF_INET is the most
# commonly used address family — nearly all IPv4 socket programming uses
# AF_INET. The value 2 originates from the original BSD socket API and has
# been stable since the 1980s.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra351.AF_INET_eq_2:
  description: "socket.AF_INET.__eq__(2) == True — AF_INET is 2, the IPv4 address family (AddressFamily IntEnum); value 2 is universal across all POSIX platforms; originates from BSD socket API (1980s); most common address family for IPv4 socket programming; first standalone for AF_INET==2 under socketid351"
  category: socket_constants
  kind: python_call_eq
  function: AF_INET.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.__eq__(1) — standalone
#
# socket.SOCK_STREAM is 1. SOCK_STREAM is the SocketKind IntEnum member for
# TCP stream sockets. Its integer value 1 is universal across all POSIX
# platforms. SOCK_STREAM provides a reliable, ordered, connection-based
# byte-stream communication channel — the standard interface for TCP
# networking. The value 1 is defined in the BSD socket API and has been
# stable since the original UNIX socket implementation.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra351.SOCK_STREAM_eq_1:
  description: "socket.SOCK_STREAM.__eq__(1) == True — SOCK_STREAM is 1 (SocketKind IntEnum); provides reliable ordered connection-based byte-stream (TCP); value 1 is universal across all POSIX platforms; defined in BSD socket API since original UNIX socket implementation; first standalone for SOCK_STREAM==1 under socketid351"
  category: socket_constants
  kind: python_call_eq
  function: SOCK_STREAM.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__eq__(6) — standalone
#
# socket.IPPROTO_TCP is 6. IPPROTO_TCP is the IANA-assigned protocol number
# for the Transmission Control Protocol (TCP), defined in RFC 793. Protocol
# number 6 is universally consistent across all platforms and operating
# systems. It is used when creating raw sockets (socket.SOCK_RAW) that
# work directly with TCP headers, and when calling setsockopt with
# IPPROTO_TCP-level options (e.g., TCP_NODELAY). On macOS, IPPROTO_TCP
# is a plain int (not an IntEnum member).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra351.IPPROTO_TCP_eq_6:
  description: "socket.IPPROTO_TCP.__eq__(6) == True — IPPROTO_TCP is 6 (IANA protocol number for TCP per RFC 793); universal across all platforms; used for SOCK_RAW TCP sockets and setsockopt TCP-level options (e.g. TCP_NODELAY); plain int on macOS (not IntEnum); first standalone for IPPROTO_TCP==6 under socketid351"
  category: protocol_constants
  kind: python_call_eq
  function: IPPROTO_TCP.__eq__
  args: [6]
  expected: true

# ---------------------------------------------------------------------------
# socket.IPPROTO_UDP.__eq__(17) — standalone
#
# socket.IPPROTO_UDP is 17. IPPROTO_UDP is the IANA-assigned protocol number
# for the User Datagram Protocol (UDP), defined in RFC 768. Protocol number
# 17 (0x11) is universally consistent across all platforms. It is used when
# creating raw sockets (socket.SOCK_RAW) that work directly with UDP headers,
# and is recognized by the kernel when routing packets. On macOS, IPPROTO_UDP
# is a plain int (not an IntEnum member).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra351.IPPROTO_UDP_eq_17:
  description: "socket.IPPROTO_UDP.__eq__(17) == True — IPPROTO_UDP is 17 (0x11, IANA protocol number for UDP per RFC 768); universal across all platforms; used for SOCK_RAW UDP sockets and kernel packet routing; plain int on macOS (not IntEnum); first standalone for IPPROTO_UDP==17 under socketid351"
  category: protocol_constants
  kind: python_call_eq
  function: IPPROTO_UDP.__eq__
  args: [17]
  expected: true
