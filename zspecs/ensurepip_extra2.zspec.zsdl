spec: ensurepip_extra2
version: ">=3.4"
backend: python_module(ensurepip)

docs: https://docs.python.org/3/library/ensurepip.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ensurepip.html — Python ensurepip documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ensurepip/__init__.py"
  notes:
    - "This spec extends ensurepip.zspec.zsdl."
    - "ensurepip.zspec.zsdl covers: __name__.__eq__('ensurepip'), version/__name__, bootstrap/__name__, version() returns str (method_chain), version().__gt__(''), version().__contains__('.'), version() is str (method_chain + expected)."
    - "This spec adds: bootstrap/__module__ == 'ensurepip', version/__module__ == 'ensurepip', bootstrap/version are function type, _uninstall/__name__ (private but importable), version().__class__.__name__ == 'str' (via method_args form), bootstrap/__qualname__, version/__qualname__."
    - "ensurepip._uninstall is a private function that reverses the bootstrap; its __name__ == '_uninstall'."
    - "ensurepip.bootstrap.__module__ == 'ensurepip' — bootstrap is defined in the ensurepip package init."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ checks — version and bootstrap are in 'ensurepip'
# (not covered in ensurepip.zspec.zsdl)
# ---------------------------------------------------------------------------

table ensurepip_extra2.function_modules:
  kind: python_call_eq
  category: modules
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [version,   version.__module__.__eq__,   ["ensurepip"], true]
    - [bootstrap, bootstrap.__module__.__eq__, ["ensurepip"], true]

# ---------------------------------------------------------------------------
# Function type checks — version and bootstrap are plain Python functions
# (not covered in ensurepip.zspec.zsdl)
# ---------------------------------------------------------------------------

table ensurepip_extra2.function_types:
  kind: python_call_eq
  category: types
  id_prefix: type

  columns: [id, function, args, expected]
  rows:
    - [version,   version.__class__.__name__.__eq__,   ["function"], true]
    - [bootstrap, bootstrap.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# _uninstall — private function __name__ check
# (not covered in ensurepip.zspec.zsdl; _uninstall reverses pip installation)
# ---------------------------------------------------------------------------

invariant ensurepip_extra2._uninstall.name:
  description: "ensurepip._uninstall.__name__ == '_uninstall' — private reversal function"
  category: functions
  kind: python_call_eq
  function: _uninstall.__name__.__eq__
  args: ["_uninstall"]
  expected: true

# ---------------------------------------------------------------------------
# version().__class__.__name__ == 'str'
# ensurepip.zspec.zsdl covers this via method_chain form (method: __class__,
# method_chain: __name__.__eq__, method_chain_args: ["str"], expected: true).
# This spec adds a complementary method_args form using method: __class__.__name__.__eq__
# (as described in the task prompt; different structural path through the ZSDL runtime)
# ---------------------------------------------------------------------------

invariant ensurepip_extra2.version.returns_str:
  description: "ensurepip.version() returns a str"
  category: functions
  kind: python_call_eq
  function: version
  args: []
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__ checks — qualname == name for top-level functions
# (not covered in ensurepip.zspec.zsdl)
# ---------------------------------------------------------------------------

table ensurepip_extra2.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [version,   version.__qualname__.__eq__,   ["version"],   true]
    - [bootstrap, bootstrap.__qualname__.__eq__, ["bootstrap"], true]
