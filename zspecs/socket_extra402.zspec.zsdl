spec: socket_extra402
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "socket.socket.bind.__name__ == 'bind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__name__ == 'listen'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__name__ == 'accept'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__name__ == 'connect'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.send.__name__ == 'send'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__name__ == 'recv'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__name__ == 'close'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.shutdown.__name__ == 'shutdown'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket is implemented as a Python class in Lib/socket.py wrapping the _socket.socket C extension type. Its instance methods (bind, listen, accept, connect, send, recv, close, shutdown) are Python function objects defined in the class body. Each method's __name__ is the bare method name, matching the attribute name used to access it. This differs from C extension type methods which would be wrapper_descriptor or method_wrapper objects."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket instance method __name__ attributes
#
# Wave 402 theme: socket.socket method identity.
#
# socket.socket is defined in Lib/socket.py as a Python class wrapping the
# lower-level _socket.socket C extension type. Its methods (bind, listen,
# accept, connect, send, recv, close, shutdown) are Python function objects
# defined with def in the class body. Accessed on the class, each is an
# ordinary Python function whose __name__ equals the bare method name.
#
# These eight methods represent the core BSD socket API lifecycle:
#   bind     — associate socket with a local address
#   listen   — mark socket as passive (server side)
#   accept   — accept an incoming connection
#   connect  — initiate a connection to a remote address
#   send     — send data through the socket
#   recv     — receive data from the socket
#   close    — close the socket file descriptor
#   shutdown — partially shut down the connection
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra402.method_names:
  description: "socket.socket instance method __name__ attributes — Python class wrapping _socket C extension; methods are Python function objects with bare method name in __name__; covers bind, listen, accept, connect, send, recv, close, shutdown; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: socketmn402

  columns: [id, function, args, expected]
  rows:
    - [bind_name,     socket.bind.__name__.__eq__,     ["bind"],     true]
    - [listen_name,   socket.listen.__name__.__eq__,   ["listen"],   true]
    - [accept_name,   socket.accept.__name__.__eq__,   ["accept"],   true]
    - [connect_name,  socket.connect.__name__.__eq__,  ["connect"],  true]
    - [send_name,     socket.send.__name__.__eq__,     ["send"],     true]
    - [recv_name,     socket.recv.__name__.__eq__,     ["recv"],     true]
    - [close_name,    socket.close.__name__.__eq__,    ["close"],    true]
    - [shutdown_name, socket.shutdown.__name__.__eq__, ["shutdown"], true]
