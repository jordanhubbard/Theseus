spec: decimal_extra235
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra224.zspec.zsdl — covers Decimal __gt__, __lt__, __eq__, __ne__ behavioral contracts"
    - "decimal_extra234.zspec.zsdl — covers Context class identity and method name/qualname checks"
  notes:
    - "This spec covers: decimal.Decimal comparison method behavioral contracts — __lt__, __gt__, __eq__, __ne__, __le__, __ge__."
    - "Integer operands used in method_args since JSON cannot serialize Decimal; Decimal accepts int operands for all comparison operators."
    - "Decimal('1').__lt__(2) == True — 1 < 2 is True; verified Python 3.14.3 macOS."
    - "Decimal('2').__gt__(1) == True — 2 > 1 is True; verified Python 3.14.3 macOS."
    - "Decimal('1').__eq__(1) == True — 1 == 1 is True; verified Python 3.14.3 macOS."
    - "Decimal('1').__ne__(2) == True — 1 != 2 is True; verified Python 3.14.3 macOS."
    - "Decimal('1').__le__(1) == True — 1 <= 1 is True; verified Python 3.14.3 macOS."
    - "Decimal('1').__ge__(1) == True — 1 >= 1 is True; verified Python 3.14.3 macOS."
    - "Decimal('1').__lt__(1) == False — 1 < 1 is False; verified Python 3.14.3 macOS."
    - "Decimal('1').__gt__(2) == False — 1 > 2 is False; verified Python 3.14.3 macOS."
    - "Decimal('1').__eq__(2) == False — 1 == 2 is False; verified Python 3.14.3 macOS."
    - "Decimal('1').__ne__(1) == False — 1 != 1 is False; verified Python 3.14.3 macOS."
    - "Decimal.__lt__.__name__ == '__lt__' — length 6; verified Python 3.14.3 macOS."
    - "Decimal.__lt__.__qualname__ == 'Decimal.__lt__' — length 14; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.__lt__ behavioral contracts
# Integer operands used since JSON cannot serialize Decimal objects.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra235.Decimal.lt_true:
  description: "decimal.Decimal('1').__lt__(2) == True — 1 < 2 is True; int operand used; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: __lt__
  method_args: [2]
  expected: true

invariant decimal_extra235.Decimal.lt_false_equal:
  description: "decimal.Decimal('1').__lt__(1) == False — 1 < 1 is False (equal is not less than); int operand used; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: __lt__
  method_args: [1]
  expected: false

invariant decimal_extra235.Decimal.lt_false_greater:
  description: "decimal.Decimal('2').__lt__(1) == False — 2 < 1 is False; int operand used; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["2"]
  method: __lt__
  method_args: [1]
  expected: false

