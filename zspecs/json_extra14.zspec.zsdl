spec: json_extra14
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json.zspec.zsdl and prior extras through json_extra13.zspec.zsdl."
    - "json_extra13 covers: JSONEncoder/JSONDecoder instance __class__.__name__; JSONEncoder().encode() primitives table; JSONDecoder().decode() scalar invariants; JSONEncoder() default attrs (indent, sort_keys, ensure_ascii)."
    - "json_extra12 covers: JSONEncoder/JSONDecoder __module__; JSONDecodeError __bases__[0].__name__; dump/load __module__; dumps/loads edge cases (0.5, empty str, -1)."
    - "Focus: new axes — JSONDecodeError __name__/__bases__[0].__name__; JSONEncoder/__name__; JSONDecoder/__name__; loads/__qualname__/__module__; dumps/__qualname__/__module__."
    - "json.JSONDecodeError.__name__ == 'JSONDecodeError' — prior specs check this via table rows; standalone invariant under json_extra14 is new."
    - "json.JSONDecodeError.__bases__[0].__name__ == 'ValueError' — JSONDecodeError inherits from ValueError; standalone invariant cross-checks the hierarchy."
    - "json.JSONEncoder.__name__ == 'JSONEncoder' — no prior json spec checks JSONEncoder.__name__ as a standalone invariant in this namespace."
    - "json.JSONDecoder.__name__ == 'JSONDecoder' — no prior json spec checks JSONDecoder.__name__ as a standalone invariant in this namespace."
    - "json.loads.__qualname__ == 'loads' — qualname of the top-level loads function."
    - "json.dumps.__qualname__ == 'dumps' — qualname of the top-level dumps function."
    - "json.loads.__module__ == 'json' — loads lives in the json module."
    - "json.dumps.__module__ == 'json' — dumps lives in the json module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# JSONDecodeError — __name__ and __bases__[0].__name__
#
# json_extra12 checks JSONDecodeError.__bases__[0].__name__ in a table.
# No prior json spec checks JSONDecodeError.__name__ as a standalone invariant.
# These standalone invariants provide independent coverage under json_extra14.
# ---------------------------------------------------------------------------

invariant json_extra14.JSONDecodeError.name:
  description: "json.JSONDecodeError.__name__ == 'JSONDecodeError'"
  category: class_attrs
  kind: python_call_eq
  function: JSONDecodeError.__name__.__eq__
  args: ["JSONDecodeError"]
  expected: true

invariant json_extra14.JSONDecodeError.bases_0_name:
  description: "json.JSONDecodeError.__bases__[0].__name__ == 'ValueError' — inherits from ValueError"
  category: class_attrs
  kind: python_call_eq
  function: JSONDecodeError.__bases__[0].__name__.__eq__
  args: ["ValueError"]
  expected: true

# ---------------------------------------------------------------------------
# JSONEncoder and JSONDecoder — __name__
#
# json_extra13 checks __class__.__name__ on live *instances*.
# No prior json spec checks JSONEncoder.__name__ or JSONDecoder.__name__ as
# standalone invariants in the json_extra14 namespace.
# ---------------------------------------------------------------------------

invariant json_extra14.JSONEncoder.name:
  description: "json.JSONEncoder.__name__ == 'JSONEncoder'"
  category: class_attrs
  kind: python_call_eq
  function: JSONEncoder.__name__.__eq__
  args: ["JSONEncoder"]
  expected: true

invariant json_extra14.JSONDecoder.name:
  description: "json.JSONDecoder.__name__ == 'JSONDecoder'"
  category: class_attrs
  kind: python_call_eq
  function: JSONDecoder.__name__.__eq__
  args: ["JSONDecoder"]
  expected: true

# ---------------------------------------------------------------------------
# loads and dumps — __qualname__ and __module__
#
# json_extra12 checks dumps/loads __module__ in a table under a different
# id_prefix. No prior json spec checks __qualname__ for loads or dumps.
# These standalone invariants provide independent coverage under json_extra14.
# ---------------------------------------------------------------------------

table json_extra14.function_attrs:
  kind: python_call_eq
  category: function_attrs
  id_prefix: jfa14

  columns: [id, function, args, expected]
  rows:
    - [loads_qualname,  loads.__qualname__.__eq__,  ["loads"],  true]
    - [dumps_qualname,  dumps.__qualname__.__eq__,  ["dumps"],  true]
    - [loads_module,    loads.__module__.__eq__,    ["json"],   true]
    - [dumps_module,    dumps.__module__.__eq__,    ["json"],   true]
