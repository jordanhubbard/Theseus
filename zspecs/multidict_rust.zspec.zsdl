spec: multidict_rust
version: ">=3.9"
backend: rust_module(multidict_rust)

docs: https://multidict.readthedocs.io/

provenance:
  derived_from:
    - "https://multidict.readthedocs.io/ — multidict library"
  notes:
    - "multidict provides dict-like data structures with multiple values per key."
    - "multidict.MultiDict({'a': 1, 'b': 2})['a'] == 1."
    - "multidict.MultiDict({'a': 1}).get('a') == 1."
    - "multidict.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant multidict_rust.getitem_a:
  description: "MultiDict({'a': 1})['a'] == 1"
  category: getitem
  kind: python_call_eq
  function: multidict_getitem_a
  args: []
  expected: 1

invariant multidict_rust.has_multi_dict_class:
  description: "multidict.MultiDict is a class"
  category: presence
  kind: python_call_eq
  function: multidict_has_multi_dict_class
  args: []
  expected: true

invariant multidict_rust.version_nonempty:
  description: "multidict.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: multidict_version_nonempty
  args: []
  expected: true

