spec: theseus_mailbox_cr
version: ">=3.8"
backend: python_cleanroom(theseus_mailbox_cr)
blocks: mailbox

docs: https://docs.python.org/3/library/mailbox.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/mailbox.html"
  not_derived_from:
    - "CPython source: Lib/mailbox.py (internal implementation)"
  notes:
    - "Clean-room mailbox module. Do NOT import mailbox."
    - "Mailbox: base class for mailbox access."
    - "Maildir: Maildir format mailbox."
    - "mbox: Unix mbox format mailbox."
    - "Message: mail message representation."

error_model: python_exceptions

invariant theseus_mailbox_cr.mailbox2_mbox_create:
  description: "mbox mailbox can be created and has add/len methods"
  category: mbox
  kind: python_call_eq
  function: mailbox2_mbox_create
  args: []
  expected: true

invariant theseus_mailbox_cr.mailbox2_message:
  description: "Message can be constructed from bytes"
  category: Message
  kind: python_call_eq
  function: mailbox2_message
  args: []
  expected: true

invariant theseus_mailbox_cr.mailbox2_maildir:
  description: "Maildir can be created in a temp directory"
  category: Maildir
  kind: python_call_eq
  function: mailbox2_maildir
  args: []
  expected: true
