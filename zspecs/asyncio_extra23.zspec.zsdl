spec: asyncio_extra23
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec extends asyncio.zspec.zsdl and prior extras through asyncio_extra22.zspec.zsdl."
    - "asyncio_extra18 covers: Task/Future/Queue/Lock/Event/Semaphore __qualname__ table."
    - "asyncio_extra22 covers: class __qualname__ length table; Condition/BoundedSemaphore/sleep/gather/run standalone qualname invariants."
    - "NOT yet covered in any prior spec: asyncio.Queue method __qualname__ table (put/get/put_nowait/get_nowait/empty/full/qsize) in extra23 namespace."
    - "NOT yet covered: asyncio.Lock method __qualname__ table (acquire/release) in extra23 namespace."
    - "NOT yet covered: asyncio.Queue method __qualname__ length table in extra23 namespace."
    - "NOT yet covered: asyncio.Lock method __qualname__ length table in extra23 namespace."
    - "Queue.put.__qualname__ == 'Queue.put' — coroutine method on asyncio.Queue."
    - "Queue.get.__qualname__ == 'Queue.get' — coroutine method on asyncio.Queue."
    - "Queue.put_nowait.__qualname__ == 'Queue.put_nowait' — synchronous method on asyncio.Queue."
    - "Queue.get_nowait.__qualname__ == 'Queue.get_nowait' — synchronous method on asyncio.Queue."
    - "Queue.empty.__qualname__ == 'Queue.empty' — synchronous method on asyncio.Queue."
    - "Queue.full.__qualname__ == 'Queue.full' — synchronous method on asyncio.Queue."
    - "Queue.qsize.__qualname__ == 'Queue.qsize' — synchronous method on asyncio.Queue."
    - "Lock.acquire.__qualname__ == 'Lock.acquire' — coroutine method on asyncio.Lock."
    - "Lock.release.__qualname__ == 'Lock.release' — synchronous method on asyncio.Lock."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Queue method __qualname__ table — extra23 namespace
#
# asyncio_extra18 checks asyncio.Queue class __qualname__ == 'Queue'. No
# prior spec provides a table of Queue *method* __qualname__ values. Each
# method follows the pattern 'Queue.<method>'.
# ---------------------------------------------------------------------------

table asyncio_extra23.queue_method_qualnames:
  description: "asyncio.Queue method __qualname__ values in extra23 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: qmqn23

  columns: [id, function, args, expected]
  rows:
    - [put,         Queue.put.__qualname__.__eq__,         ["Queue.put"],         true]
    - [get,         Queue.get.__qualname__.__eq__,         ["Queue.get"],         true]
    - [put_nowait,  Queue.put_nowait.__qualname__.__eq__,  ["Queue.put_nowait"],  true]
    - [get_nowait,  Queue.get_nowait.__qualname__.__eq__,  ["Queue.get_nowait"],  true]
    - [empty,       Queue.empty.__qualname__.__eq__,       ["Queue.empty"],       true]
    - [full,        Queue.full.__qualname__.__eq__,        ["Queue.full"],        true]
    - [qsize,       Queue.qsize.__qualname__.__eq__,       ["Queue.qsize"],       true]

# ---------------------------------------------------------------------------
# Queue method __qualname__ length table — extra23 namespace
#
# Lengths: Queue.put(9), Queue.get(9), Queue.put_nowait(16),
#          Queue.get_nowait(16), Queue.empty(11), Queue.full(10),
#          Queue.qsize(11).
# ---------------------------------------------------------------------------

table asyncio_extra23.queue_method_qualname_lengths:
  description: "asyncio.Queue method __qualname__ lengths in extra23 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: qmqnlen23

  columns: [id, function, args, expected]
  rows:
    - [put,         Queue.put.__qualname__.__len__,         [], 9]
    - [get,         Queue.get.__qualname__.__len__,         [], 9]
    - [put_nowait,  Queue.put_nowait.__qualname__.__len__,  [], 16]
    - [get_nowait,  Queue.get_nowait.__qualname__.__len__,  [], 16]
    - [empty,       Queue.empty.__qualname__.__len__,       [], 11]
    - [full,        Queue.full.__qualname__.__len__,        [], 10]
    - [qsize,       Queue.qsize.__qualname__.__len__,       [], 11]

# ---------------------------------------------------------------------------
# Lock.acquire.__qualname__ — standalone extra23 invariant
#
# asyncio_extra18 checks asyncio.Lock class __qualname__ == 'Lock'. No prior
# spec checks Lock method __qualname__ values. Lock.acquire is a coroutine
# method; its __qualname__ is 'Lock.acquire'.
# ---------------------------------------------------------------------------

invariant asyncio_extra23.Lock.acquire.qualname_eq:
  description: "asyncio.Lock.acquire.__qualname__ == 'Lock.acquire' — coroutine method qualname"
  category: method_names
  kind: python_call_eq
  function: Lock.acquire.__qualname__.__eq__
  args: ["Lock.acquire"]
  expected: true

# ---------------------------------------------------------------------------
# Lock.release.__qualname__ — standalone extra23 invariant
#
# asyncio.Lock.release is the synchronous release method. Its __qualname__
# is 'Lock.release'. No prior spec checks this value.
# ---------------------------------------------------------------------------

invariant asyncio_extra23.Lock.release.qualname_eq:
  description: "asyncio.Lock.release.__qualname__ == 'Lock.release' — synchronous method qualname"
  category: method_names
  kind: python_call_eq
  function: Lock.release.__qualname__.__eq__
  args: ["Lock.release"]
  expected: true
