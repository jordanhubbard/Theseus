spec: pathlib_extra1636
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for ABC virtual subclassing protocol"
    - "pathlib classes are not ABCs and do not define __subclasshook__ in their own __dict__."
    - "PurePath, PurePosixPath, PureWindowsPath, Path are ordinary Python classes using type as metaclass."
    - "PurePath.__class__.__name__ == 'type' — no custom metaclass, no virtual subclassing hooks."
    - "PurePath implements __fspath__, making PurePath and all subclasses satisfy the os.PathLike protocol."
    - "PurePosixPath.__bases__[0].__name__ == 'PurePath'; PureWindowsPath.__bases__[0].__name__ == 'PurePath'."
    - "Path.__bases__[0].__name__ == 'PurePath' on Python 3.12+."
    - "PosixPath.__bases__[0].__name__ == 'Path'; WindowsPath.__bases__[0].__name__ == 'Path'."
    - "issubclass(PurePosixPath, PureWindowsPath) is False — sibling classes, no cross-platform inheritance."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: pathlib classes do not define __subclasshook__, __instancecheck__,
# or __subclasscheck__ in their own __dict__. They use type (not ABCMeta) as
# their metaclass and have no virtual subclassing machinery of their own.
# ---------------------------------------------------------------------------

table pathlib_extra1636.no_virtual_subclassing:
  description: "pathlib classes do not define __subclasshook__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1636

  columns: [id, function, args, expected]
  rows:
    - ["pl1636001", "PurePath.__dict__.__contains__",        ["__subclasshook__"],  false]
    - ["pl1636002", "Path.__dict__.__contains__",            ["__subclasshook__"],  false]
    - ["pl1636003", "PurePosixPath.__dict__.__contains__",   ["__subclasshook__"],  false]
    - ["pl1636004", "PureWindowsPath.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["pl1636005", "PurePath.__dict__.__contains__",        ["__instancecheck__"], false]
    - ["pl1636006", "Path.__dict__.__contains__",            ["__instancecheck__"], false]
    - ["pl1636007", "PurePosixPath.__dict__.__contains__",   ["__instancecheck__"], false]
    - ["pl1636008", "PureWindowsPath.__dict__.__contains__", ["__instancecheck__"], false]
    - ["pl1636009", "PurePath.__dict__.__contains__",        ["__subclasscheck__"], false]
    - ["pl1636010", "Path.__dict__.__contains__",            ["__subclasscheck__"], false]
    - ["pl1636011", "PurePosixPath.__dict__.__contains__",   ["__subclasscheck__"], false]
    - ["pl1636012", "PureWindowsPath.__dict__.__contains__", ["__subclasscheck__"], false]
    - ["pl1636013", "PurePath.__class__.__name__.__eq__",    ["type"],              true]
    - ["pl1636014", "Path.__class__.__name__.__eq__",        ["type"],              true]
    - ["pl1636015", "PurePosixPath.__class__.__name__.__eq__", ["type"],            true]
    - ["pl1636016", "PureWindowsPath.__class__.__name__.__eq__", ["type"],          true]
    - ["pl1636017", "PurePath.__dict__.__contains__",        ["__fspath__"],        true]
    - ["pl1636018", "PurePosixPath.__dict__.__contains__",   ["__fspath__"],        false]
    - ["pl1636019", "PureWindowsPath.__dict__.__contains__", ["__fspath__"],        false]
    - ["pl1636020", "Path.__dict__.__contains__",            ["__fspath__"],        false]

# ---------------------------------------------------------------------------
# Table 2: isinstance/issubclass hierarchy — checked via __bases__ name access.
#
# PurePosixPath.__bases__[0].__name__   == "PurePath"
# PureWindowsPath.__bases__[0].__name__ == "PurePath"
# PurePath.__bases__[0].__name__        == "object"
# Path.__bases__[0].__name__            == "PurePath"
# PosixPath.__bases__[0].__name__       == "Path"
# WindowsPath.__bases__[0].__name__     == "Path"
#
# isinstance checks (via __instancecheck__ on type, since pathlib uses type):
# PurePosixPath("/usr").__class__.__name__ == "PurePosixPath"  (identity)
# PurePosixPath("/usr") is PurePath subclass — confirmed by issubclass
# PurePosixPath("/usr") is NOT PureWindowsPath — sibling
# ---------------------------------------------------------------------------

table pathlib_extra1636.isinstance_hierarchy:
  description: "isinstance and issubclass membership in the pathlib class hierarchy"
  kind: python_call_eq
  category: isinstance
  id_prefix: pl1636i

  columns: [id, function, args, method, expected]
  rows:
    - ["pl1636i001", "PurePosixPath.__bases__.__getitem__",   [0], __name__, "PurePath"]
    - ["pl1636i002", "PureWindowsPath.__bases__.__getitem__", [0], __name__, "PurePath"]
    - ["pl1636i003", "PurePath.__bases__.__getitem__",        [0], __name__, "object"]
    - ["pl1636i004", "Path.__bases__.__getitem__",            [0], __name__, "PurePath"]
    - ["pl1636i005", "PosixPath.__bases__.__getitem__",       [0], __name__, "Path"]
    - ["pl1636i006", "WindowsPath.__bases__.__getitem__",     [0], __name__, "Path"]
    - ["pl1636i007", "PurePath.__mro__.__getitem__",          [0], __name__, "PurePath"]
    - ["pl1636i008", "PurePosixPath.__mro__.__getitem__",     [0], __name__, "PurePosixPath"]
    - ["pl1636i009", "PurePosixPath.__mro__.__getitem__",     [1], __name__, "PurePath"]
    - ["pl1636i010", "PureWindowsPath.__mro__.__getitem__",   [1], __name__, "PurePath"]
    - ["pl1636i011", "PosixPath.__mro__.__getitem__",         [1], __name__, "Path"]
    - ["pl1636i012", "WindowsPath.__mro__.__getitem__",       [1], __name__, "Path"]
    - ["pl1636i013", "Path.__mro__.__getitem__",              [1], __name__, "PurePath"]
    - ["pl1636i014", "PurePath.__name__.__eq__",              ["PurePath"],        null, true]
    - ["pl1636i015", "PurePosixPath.__name__.__eq__",         ["PurePosixPath"],   null, true]
    - ["pl1636i016", "PureWindowsPath.__name__.__eq__",       ["PureWindowsPath"], null, true]
    - ["pl1636i017", "Path.__name__.__eq__",                  ["Path"],            null, true]
    - ["pl1636i018", "PosixPath.__name__.__eq__",             ["PosixPath"],       null, true]
    - ["pl1636i019", "WindowsPath.__name__.__eq__",           ["WindowsPath"],     null, true]
    - ["pl1636i020", "PurePath.__module__.__eq__",            ["pathlib"],         null, true]
    - ["pl1636i021", "PurePosixPath.__module__.__eq__",       ["pathlib"],         null, true]
    - ["pl1636i022", "PureWindowsPath.__module__.__eq__",     ["pathlib"],         null, true]
    - ["pl1636i023", "Path.__module__.__eq__",                ["pathlib"],         null, true]
    - ["pl1636i024", "PosixPath.__module__.__eq__",           ["pathlib"],         null, true]
    - ["pl1636i025", "WindowsPath.__module__.__eq__",         ["pathlib"],         null, true]

# ---------------------------------------------------------------------------
# Table 3: os.PathLike protocol — PurePath directly implements __fspath__,
# which satisfies the os.PathLike structural protocol. The key behaviors:
# - PurePath defines __fspath__ in its own __dict__ (True)
# - PurePosixPath does NOT define __fspath__ — inherits from PurePath (False)
# - PurePath defines other protocol-relevant methods: __str__, __repr__, __eq__,
#   __hash__, __lt__, __truediv__, name, suffix, stem, parts, parent, is_absolute
# - The metaclass of PurePath is type (no ABC registration)
# - issubclass(PurePath, os.PathLike) is True because ABCMeta.__subclasshook__
#   in os.PathLike checks for the presence of __fspath__ via __subclasshook__
# ---------------------------------------------------------------------------

table pathlib_extra1636.pathlike_protocol:
  description: "pathlib PurePath satisfies os.PathLike via __fspath__ implementation"
  kind: python_call_eq
  category: pathlike
  id_prefix: pl1636p

  columns: [id, function, args, expected]
  rows:
    - ["pl1636p001", "PurePath.__dict__.__contains__",        ["__fspath__"],    true]
    - ["pl1636p002", "PurePosixPath.__dict__.__contains__",   ["__fspath__"],    false]
    - ["pl1636p003", "PureWindowsPath.__dict__.__contains__", ["__fspath__"],    false]
    - ["pl1636p004", "Path.__dict__.__contains__",            ["__fspath__"],    false]
    - ["pl1636p005", "PurePath.__dict__.__contains__",        ["__str__"],       true]
    - ["pl1636p006", "PurePath.__dict__.__contains__",        ["__repr__"],      true]
    - ["pl1636p007", "PurePath.__dict__.__contains__",        ["__eq__"],        true]
    - ["pl1636p008", "PurePath.__dict__.__contains__",        ["__hash__"],      true]
    - ["pl1636p009", "PurePath.__dict__.__contains__",        ["__lt__"],        true]
    - ["pl1636p010", "PurePath.__dict__.__contains__",        ["__truediv__"],   true]
    - ["pl1636p011", "PurePath.__dict__.__contains__",        ["name"],          true]
    - ["pl1636p012", "PurePath.__dict__.__contains__",        ["suffix"],        true]
    - ["pl1636p013", "PurePath.__dict__.__contains__",        ["stem"],          true]
    - ["pl1636p014", "PurePath.__dict__.__contains__",        ["parts"],         true]
    - ["pl1636p015", "PurePath.__dict__.__contains__",        ["parent"],        true]
    - ["pl1636p016", "PurePath.__dict__.__contains__",        ["is_absolute"],   true]
    - ["pl1636p017", "PurePath.__dict__.__contains__",        ["joinpath"],      true]
    - ["pl1636p018", "PurePath.__dict__.__contains__",        ["__subclasshook__"], false]
    - ["pl1636p019", "PurePath.__dict__.__contains__",        ["__instancecheck__"], false]
    - ["pl1636p020", "PurePath.__dict__.__contains__",        ["__subclasscheck__"], false]
