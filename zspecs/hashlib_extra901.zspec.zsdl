spec: hashlib_extra901
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib constructor __module__ attributes and collection class names"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra901.hash_constructor_modules:
  description: "hashlib hash constructor __module__ identity"
  kind: python_call_eq
  category: constructor_modules
  id_prefix: hl901cm
  columns: [id, function, args, expected]
  rows:
    - [hl901cm001, hashlib.md5.__module__.__eq__,    ["hashlib"], true]
    - [hl901cm002, hashlib.sha1.__module__.__eq__,   ["hashlib"], true]
    - [hl901cm003, hashlib.sha256.__module__.__eq__,  ["hashlib"], true]
    - [hl901cm004, hashlib.sha512.__module__.__eq__,  ["hashlib"], true]
    - [hl901cm005, hashlib.new.__module__.__eq__,     ["hashlib"], true]

table hashlib_extra901.algorithm_collections:
  description: "hashlib algorithm collection class name identity"
  kind: python_call_eq
  category: collection_class_names
  id_prefix: hl901ac
  columns: [id, function, args, expected]
  rows:
    - [hl901ac001, hashlib.algorithms_available.__class__.__name__.__eq__,  ["set"],       true]
    - [hl901ac002, hashlib.algorithms_guaranteed.__class__.__name__.__eq__, ["frozenset"],  true]
    - [hl901ac003, hashlib.algorithms_available.__class__.__module__.__eq__, ["builtins"],  true]
    - [hl901ac004, hashlib.algorithms_guaranteed.__class__.__module__.__eq__, ["builtins"], true]
    - [hl901ac005, hashlib.algorithms_guaranteed.__class__.__name__.__eq__, ["frozenset"],  true]

table hashlib_extra901.module_level_attrs:
  description: "hashlib module-level attribute identity checks"
  kind: python_call_eq
  category: module_attrs
  id_prefix: hl901ma
  columns: [id, function, args, expected]
  rows:
    - [hl901ma001, hashlib.md5.__module__.__class__.__name__.__eq__,   ["str"],     true]
    - [hl901ma002, hashlib.sha1.__module__.__class__.__name__.__eq__,  ["str"],     true]
    - [hl901ma003, hashlib.sha256.__module__.__class__.__name__.__eq__, ["str"],    true]
    - [hl901ma004, hashlib.sha512.__module__.__class__.__name__.__eq__, ["str"],    true]
    - [hl901ma005, hashlib.new.__module__.__class__.__name__.__eq__,    ["str"],    true]
