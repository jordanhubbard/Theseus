spec: pathlib_extra127
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec extends pathlib_extra126.zspec.zsdl."
    - "This spec covers: pathlib.PurePath.__init__.__code__ and __new__.__code__ co_varnames and co_argcount not yet covered."
    - "No prior pathlib_extra spec has asserted any attribute of PurePath.__init__.__code__ or PurePath.__new__.__code__."
    - "PurePath.__init__.__code__.co_varnames: ('self', 'args', 'paths', 'arg', 'path') — 5 entries."
    - "PurePath.__init__.__code__.co_argcount == 1 (only 'self'; path segments passed as *args via co_varnames[1]='args')."
    - "PurePath.__new__.__code__.co_varnames: ('cls', 'args', 'kwargs') — 3 entries."
    - "PurePath.__new__.__code__.co_argcount == 1 (only 'cls'; positional args captured as *args via co_varnames[1])."
    - "PurePath.__init__.__code__.co_varnames[0] == 'self' (len 4); first parameter of __init__."
    - "PurePath.__init__.__code__.co_varnames[1] == 'args' (len 4); captures positional path segments via *args."
    - "PurePath.__init__.__code__.co_varnames[2] == 'paths' (len 5); local list of parsed path strings."
    - "PurePath.__new__.__code__.co_varnames[0] == 'cls' (len 3); first parameter of __new__ is the class being constructed."
    - "PurePath.__new__.__code__.co_varnames[1] == 'args' (len 4); captures positional args in __new__."
    - "PurePath.__new__.__code__.co_varnames[2] == 'kwargs' (len 6); captures keyword args in __new__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath.__init__.__code__ co_varnames[0], [1], [2]
# co_varnames[0] == 'self' (4 chars) — first parameter, the instance being initialized.
# co_varnames[1] == 'args' (4 chars) — captures *args (positional path segments).
# co_varnames[2] == 'paths' (5 chars) — local variable accumulating parsed path strings.
# co_argcount == 1 — only 'self' is a true positional parameter; path segments come via *args.
# co_varnames.__len__() == 5 — five local names: self, args, paths, arg, path.
# No prior pathlib_extra spec asserts any attribute of PurePath.__init__.__code__.
# ---------------------------------------------------------------------------

table pathlib_extra127.PurePath_init_code_varnames:
  description: "PurePath.__init__.__code__.co_varnames[0]=='self'(4); [1]=='args'(4); [2]=='paths'(5); co_argcount==1; co_varnames.__len__()==5; all assertions novel; no prior spec covers PurePath.__init__.__code__"
  kind: python_call_eq
  category: code_introspection
  id_prefix: pathlibinit127a

  columns: [id, function, args, expected, description]
  rows:
    - [init_cv0_eq,     "PurePath.__init__.__code__.co_varnames[0].__eq__",   ["self"],   true,  "PurePath.__init__.__code__.co_varnames[0] == 'self' (4 chars; the instance being initialized; first parameter of every instance __init__ method in Python)"]
    - [init_cv0_len,    "PurePath.__init__.__code__.co_varnames[0].__len__",  [],         4,     "PurePath.__init__.__code__.co_varnames[0].__len__() == 4 ('self' has 4 characters)"]
    - [init_cv1_eq,     "PurePath.__init__.__code__.co_varnames[1].__eq__",   ["args"],   true,  "PurePath.__init__.__code__.co_varnames[1] == 'args' (4 chars; captures the *args variadic positional path segments passed to PurePath())"]
    - [init_cv1_len,    "PurePath.__init__.__code__.co_varnames[1].__len__",  [],         4,     "PurePath.__init__.__code__.co_varnames[1].__len__() == 4 ('args' has 4 characters; same length as 'self' at position 0)"]
    - [init_cv2_eq,     "PurePath.__init__.__code__.co_varnames[2].__eq__",   ["paths"],  true,  "PurePath.__init__.__code__.co_varnames[2] == 'paths' (5 chars; local variable that accumulates the parsed path strings from the args tuple)"]
    - [init_cv2_len,    "PurePath.__init__.__code__.co_varnames[2].__len__",  [],         5,     "PurePath.__init__.__code__.co_varnames[2].__len__() == 5 ('paths' has 5 characters; 1 char longer than 'self' and 'args')"]
    - [init_argcount,   "PurePath.__init__.__code__.co_argcount.__eq__",      [1],        true,  "PurePath.__init__.__code__.co_argcount == 1 (only 'self' is a regular positional parameter; path segments come as *args so they are not counted in co_argcount)"]
    - [init_cv_len_5,   "PurePath.__init__.__code__.co_varnames.__len__",     [],         5,     "PurePath.__init__.__code__.co_varnames.__len__() == 5 (five local variable names: self, args, paths, arg, path — covering both parameters and loop variables)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__new__.__code__ co_varnames[0], [1], [2]
# co_varnames[0] == 'cls' (3 chars) — class being constructed; first param of __new__.
# co_varnames[1] == 'args' (4 chars) — captures *args positional arguments.
# co_varnames[2] == 'kwargs' (6 chars) — captures **kwargs keyword arguments.
# co_argcount == 1 — only 'cls' is a true positional parameter.
# co_varnames.__len__() == 3 — three local names: cls, args, kwargs.
# __new__ has fewer local variables than __init__ (3 vs 5) because it delegates.
# No prior pathlib_extra spec asserts any attribute of PurePath.__new__.__code__.
# ---------------------------------------------------------------------------

table pathlib_extra127.PurePath_new_code_varnames:
  description: "PurePath.__new__.__code__.co_varnames[0]=='cls'(3); [1]=='args'(4); [2]=='kwargs'(6); co_argcount==1; co_varnames.__len__()==3; all assertions novel; __new__ has 3 locals vs __init__'s 5"
  kind: python_call_eq
  category: code_introspection
  id_prefix: pathlibinit127b

  columns: [id, function, args, expected, description]
  rows:
    - [new_cv0_eq,      "PurePath.__new__.__code__.co_varnames[0].__eq__",    ["cls"],     true,  "PurePath.__new__.__code__.co_varnames[0] == 'cls' (3 chars; the class being constructed; __new__ receives the class as its first argument rather than an instance)"]
    - [new_cv0_len,     "PurePath.__new__.__code__.co_varnames[0].__len__",   [],          3,     "PurePath.__new__.__code__.co_varnames[0].__len__() == 3 ('cls' has 3 characters; shorter than 'self'(4) in __init__)"]
    - [new_cv1_eq,      "PurePath.__new__.__code__.co_varnames[1].__eq__",    ["args"],    true,  "PurePath.__new__.__code__.co_varnames[1] == 'args' (4 chars; captures the *args positional path arguments forwarded from __new__ to the constructor)"]
    - [new_cv1_len,     "PurePath.__new__.__code__.co_varnames[1].__len__",   [],          4,     "PurePath.__new__.__code__.co_varnames[1].__len__() == 4 ('args' has 4 characters; same name and length as co_varnames[1] in __init__)"]
    - [new_cv2_eq,      "PurePath.__new__.__code__.co_varnames[2].__eq__",    ["kwargs"],  true,  "PurePath.__new__.__code__.co_varnames[2] == 'kwargs' (6 chars; captures **kwargs keyword arguments; __new__ accepts and forwards keyword arguments for subclass flexibility)"]
    - [new_cv2_len,     "PurePath.__new__.__code__.co_varnames[2].__len__",   [],          6,     "PurePath.__new__.__code__.co_varnames[2].__len__() == 6 ('kwargs' has 6 characters; longer than 'cls'(3) and 'args'(4) at positions 0 and 1)"]
    - [new_argcount,    "PurePath.__new__.__code__.co_argcount.__eq__",       [1],         true,  "PurePath.__new__.__code__.co_argcount == 1 (only 'cls' is a regular positional parameter; *args and **kwargs are variadic and not counted in co_argcount)"]
    - [new_cv_len_3,    "PurePath.__new__.__code__.co_varnames.__len__",      [],          3,     "PurePath.__new__.__code__.co_varnames.__len__() == 3 (three local variable names: cls, args, kwargs — fewer than __init__'s 5 because __new__ delegates path resolution to __init__)"]

# ---------------------------------------------------------------------------
# Cross-method comparisons: PurePath.__init__ vs __new__ code objects
# __init__ co_varnames.__len__()==5 > __new__ co_varnames.__len__()==3.
# co_varnames[0] differs: 'self'(4) in __init__ vs 'cls'(3) in __new__.
# co_varnames[1] is identical: 'args'(4) in both.
# co_argcount is identical: 1 in both.
# These comparisons are novel — no prior pathlib spec has crossed __init__ and __new__.
# ---------------------------------------------------------------------------

table pathlib_extra127.PurePath_init_vs_new_cross_comparisons:
  description: "PurePath.__init__ vs __new__: co_varnames.__len__() 5>3; cv[0] 'self'(4)!='cls'(3); cv[1] 'args'(4)=='args'(4); co_argcount both==1; cross-method comparisons all novel"
  kind: python_call_eq
  category: code_introspection
  id_prefix: pathlibinit127c

  columns: [id, function, args, expected, description]
  rows:
    - [init_more_vars,  "PurePath.__init__.__code__.co_varnames.__len__.__gt__", [3],      true,  "PurePath.__init__ has more co_varnames than __new__ (5 > 3; __init__ iterates over each path segment with local loop variables 'arg' and 'path'; __new__ only needs cls, args, kwargs)"]
    - [cv0_init_ne_new, "PurePath.__init__.__code__.co_varnames[0].__eq__",  ["cls"],      false, "PurePath.__init__.__code__.co_varnames[0] != 'cls' (it is 'self'; __init__ receives an instance, __new__ receives the class; the first parameter name distinguishes them)"]
    - [cv0_new_ne_init, "PurePath.__new__.__code__.co_varnames[0].__eq__",   ["self"],     false, "PurePath.__new__.__code__.co_varnames[0] != 'self' (it is 'cls'; __new__ is a static method that receives the class as its first argument, not an instance)"]
    - [cv1_both_args,   "PurePath.__init__.__code__.co_varnames[1].__eq__",  ["args"],     true,  "PurePath.__init__.__code__.co_varnames[1] == 'args' == PurePath.__new__.__code__.co_varnames[1] (both methods capture variadic positional path segments as 'args')"]
    - [init_cv0_len_4,  "PurePath.__init__.__code__.co_varnames[0].__len__", [],           4,     "PurePath.__init__.__code__.co_varnames[0].__len__() == 4 ('self' has 4 chars; 1 more than 'cls'(3) in __new__)"]
    - [new_cv0_len_3,   "PurePath.__new__.__code__.co_varnames[0].__len__",  [],           3,     "PurePath.__new__.__code__.co_varnames[0].__len__() == 3 ('cls' has 3 chars; 1 fewer than 'self'(4) in __init__)"]
    - [both_argcount_1, "PurePath.__new__.__code__.co_argcount.__eq__",      [1],          true,  "PurePath.__new__.__code__.co_argcount == 1; same as PurePath.__init__.__code__.co_argcount == 1 (both have exactly one formal positional parameter, despite different first-parameter names)"]
    - [new_cv2_gt_cv0,  "PurePath.__new__.__code__.co_varnames[2].__len__.__gt__", [3],   true,  "len('kwargs') > len('cls') (6 > 3; the third local variable in __new__ is longer than the first; 'kwargs' captures all keyword arguments forwarded to the constructor)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra127.PurePath.init_code_co_varnames_len_5:
  description: "pathlib.PurePath.__init__.__code__.co_varnames.__len__() == 5 (five local variable names: 'self' at [0], 'args' at [1], 'paths' at [2], 'arg' at [3], 'path' at [4]; the two extra variables 'arg' and 'path' beyond the two parameters 'self' and 'args' are loop variables used when iterating over each path segment to build the internal path representation; co_argcount is 1 because only 'self' is a regular positional parameter; no prior pathlib_extra spec has asserted any attribute of PurePath.__init__.__code__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: PurePath.__init__.__code__.co_varnames.__len__
  args: []
  expected: 5

invariant pathlib_extra127.PurePath.new_code_co_varnames_len_3:
  description: "pathlib.PurePath.__new__.__code__.co_varnames.__len__() == 3 (three local variable names: 'cls' at [0], 'args' at [1], 'kwargs' at [2]; __new__ is simpler than __init__ because it only needs to capture the class and forward variadic arguments; it does not perform path string processing, which is done in __init__; 3 < 5: __new__ has fewer locals than __init__; no prior pathlib_extra spec has asserted any attribute of PurePath.__new__.__code__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: PurePath.__new__.__code__.co_varnames.__len__
  args: []
  expected: 3

invariant pathlib_extra127.PurePath.init_code_cv2_paths:
  description: "pathlib.PurePath.__init__.__code__.co_varnames[2] == 'paths' (5 chars; 'paths' is the local variable that accumulates the list of path strings parsed from the *args tuple; it is declared at index 2 in co_varnames, immediately after 'self' at [0] and 'args' at [1]; 'paths'(5) is 1 char longer than 'self'(4) and 'args'(4); no prior pathlib_extra spec has asserted co_varnames[2] for PurePath.__init__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "PurePath.__init__.__code__.co_varnames[2].__eq__"
  args: ["paths"]
  expected: true

invariant pathlib_extra127.PurePath.new_code_cv2_kwargs:
  description: "pathlib.PurePath.__new__.__code__.co_varnames[2] == 'kwargs' (6 chars; 'kwargs' captures keyword arguments passed to PurePath.__new__; this allows subclasses to pass keyword arguments through __new__ without breaking the MRO chain; 'kwargs'(6) is longer than 'cls'(3) and 'args'(4) in positions 0 and 1; no prior pathlib_extra spec has asserted co_varnames[2] for PurePath.__new__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "PurePath.__new__.__code__.co_varnames[2].__eq__"
  args: ["kwargs"]
  expected: true

invariant pathlib_extra127.PurePath.init_code_argcount_1:
  description: "pathlib.PurePath.__init__.__code__.co_argcount == 1 (co_argcount counts only formal positional parameters, excluding *args and **kwargs; PurePath.__init__ has exactly one formal parameter 'self'; the path segments are accepted via *args and are captured in co_varnames[1]='args' but are not counted in co_argcount; this design allows PurePath() to accept any number of path segment arguments; no prior pathlib_extra spec has asserted co_argcount for PurePath.__init__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: PurePath.__init__.__code__.co_argcount.__eq__
  args: [1]
  expected: true
