spec: token_rust
version: ">=3.9"
backend: rust_module(token_rust)

docs: https://docs.python.org/3/library/token.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/token.html — Python token documentation"
  not_derived_from:
    - "CPython source: Lib/token.py"
  notes:
    - "Clean-room Rust reimplementation of Python token module, exposed via PyO3."
    - "Defines integer constants for Python token types used by the tokenizer."
    - "ENDMARKER == 0 — marks end of input."
    - "NAME == 1 — identifier or keyword token."
    - "NUMBER == 2 — numeric literal."
    - "STRING == 3 — string literal."
    - "NEWLINE == 4 — logical newline."
    - "NL == 61 — non-logical newline (continuation line)."
    - "COMMENT == 60 — comment token."
    - "INDENT == 5 — indentation increase."
    - "DEDENT == 6 — indentation decrease."
    - "ENCODING == 62 — encoding declaration."
    - "tok_name is a dict mapping token int to token name string."
    - "tok_name[1] == 'NAME', tok_name[2] == 'NUMBER', tok_name[0] == 'ENDMARKER'."
    - "All test vectors verified against Python 3.14.3 token module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# Token type integer constants
table token_rust.constants.values:
  kind: python_call_eq
  category: constants
  id_prefix: tok_const

  columns: [id, function, args, expected]
  rows:
    - [ENDMARKER, ENDMARKER.__eq__, [0],  true]
    - [NAME,      NAME.__eq__,      [1],  true]
    - [NUMBER,    NUMBER.__eq__,    [2],  true]
    - [STRING,    STRING.__eq__,    [3],  true]
    - [NEWLINE,   NEWLINE.__eq__,   [4],  true]
    - [INDENT,    INDENT.__eq__,    [5],  true]
    - [DEDENT,    DEDENT.__eq__,    [6],  true]

# tok_name dict — int to token name
table token_rust.tok_name.lookup:
  kind: python_call_eq
  category: tok_name
  id_prefix: tok_name
  function: tok_name.__getitem__

  columns: [id, args, expected]
  rows:
    - [endmarker, [0], "ENDMARKER"]
    - [name,      [1], "NAME"]
    - [number,    [2], "NUMBER"]
    - [string,    [3], "STRING"]
    - [newline,   [4], "NEWLINE"]
    - [indent,    [5], "INDENT"]
    - [dedent,    [6], "DEDENT"]

# tok_name __contains__
table token_rust.tok_name.contains:
  kind: python_call_eq
  category: tok_name
  id_prefix: tok_has
  function: tok_name.__contains__

  columns: [id, args, expected]
  rows:
    - [has_0,  [0], true]
    - [has_1,  [1], true]
    - [miss_99,[99], false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T21:06:21Z
  iterations: 1
  pass_count: 17
  fail_count: 0
  total_invariants: 17
  notes: Synthesis succeeded in 1 iteration(s). 17 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
