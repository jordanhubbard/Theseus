spec: uuid_extra39
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra38.zspec.zsdl — covers UUID.__class__.__name__.__eq__('type'), uuid4/uuid1/uuid3/uuid5/getnode.__class__.__name__.__eq__('function'), NAMESPACE_DNS.__class__.__name__.__eq__('UUID'), UUID.time.fget.__class__.__name__.__eq__('function')."
    - "uuid_extra37.zspec.zsdl — covers UUID property fget __name__.__eq__ string values for time/variant/bytes/hex/urn/node/version/clock_seq."
    - "uuid_extra36.zspec.zsdl — covers UUID dunder method __module__.__eq__('uuid') for __repr__/__hash__/__eq__/__int__/__lt__/__le__/__gt__/__ge__."
    - "uuid_extra35.zspec.zsdl — covers UUID dunder method __name__.__eq__ string values."
    - "uuid_extra34.zspec.zsdl — covers UUID property fget __qualname__.__eq__ string values."
    - "uuid_extra18.zspec.zsdl — covers UUID property fget __qualname__.__eq__ and __qualname__.__len__() for bytes/version/bytes_le/fields/variant."
  notes:
    - "This spec extends uuid through uuid_extra38; it does NOT duplicate invariants present in those files."
    - "Coverage gap: No prior uuid spec checks __class__.__qualname__.__eq__ for UUID, uuid4, uuid1, uuid3, uuid5, NAMESPACE_DNS, or getnode. The __class__.__qualname__ axis mirrors __class__.__name__ for non-nested types and provides additional regression coverage distinct from __name__, __qualname__, and __module__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__class__.__qualname__ == 'type'. UUID is a Python class; its metaclass is the built-in type whose __qualname__ is 'type'. No prior spec checks UUID.__class__.__qualname__.__eq__('type'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__class__.__qualname__ == 'function'. uuid4 is a pure Python function; its class is the built-in function type whose __qualname__ is 'function'. No prior spec checks uuid4.__class__.__qualname__.__eq__('function'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__class__.__qualname__ == 'function'. uuid1 is a pure Python function defined in Lib/uuid.py. No prior spec checks uuid1.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__class__.__qualname__ == 'function'. uuid3 is a pure Python function defined in Lib/uuid.py. No prior spec checks uuid3.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__class__.__qualname__ == 'function'. uuid5 is a pure Python function defined in Lib/uuid.py. No prior spec checks uuid5.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.getnode.__class__.__qualname__ == 'function'. getnode is a pure Python function defined in Lib/uuid.py. No prior spec checks getnode.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__qualname__ == 'UUID'. NAMESPACE_DNS is a UUID instance; its __class__ is uuid.UUID, whose __qualname__ is 'UUID'. No prior spec checks NAMESPACE_DNS.__class__.__qualname__.__eq__('UUID'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__class__.__module__ == 'builtins'. The metaclass of UUID is the built-in type, whose __module__ is 'builtins'. No prior spec checks UUID.__class__.__module__.__eq__('builtins'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__class__.__module__ == 'builtins'. The built-in function type (to which Python functions belong) has __module__ == 'builtins'. No prior spec checks uuid4.__class__.__module__.__eq__('builtins'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__module__ == 'uuid'. NAMESPACE_DNS is a UUID instance; uuid.UUID is defined in the uuid module, so __class__.__module__ == 'uuid'. No prior spec checks NAMESPACE_DNS.__class__.__module__.__eq__('uuid'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid module-level and class-level object __class__.__qualname__.__eq__ values
#
# uuid_extra38 covers __class__.__name__.__eq__ for the same objects.
# No prior uuid spec checks __class__.__qualname__.__eq__ for UUID, uuid4,
# uuid1, uuid3, uuid5, NAMESPACE_DNS, or getnode.
# uuid.UUID.__class__.__qualname__ == 'type'
# uuid.uuid4/uuid1/uuid3/uuid5/getnode.__class__.__qualname__ == 'function'
# uuid.NAMESPACE_DNS.__class__.__qualname__ == 'UUID'
# ---------------------------------------------------------------------------

table uuid_extra39.callable_class_qualnames:
  description: "uuid UUID/uuid4/uuid1/uuid3/uuid5/NAMESPACE_DNS/getnode __class__.__qualname__.__eq__ — novel __class__.__qualname__ axis; no prior uuid spec checks __class__.__qualname__.__eq__ for any of these objects"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidclsqual39

  columns: [id, function, args, expected]
  rows:
    - [UUID_class_qualname_eq,          UUID.__class__.__qualname__.__eq__,          ["type"],     true]
    - [uuid4_class_qualname_eq,         uuid4.__class__.__qualname__.__eq__,         ["function"], true]
    - [uuid1_class_qualname_eq,         uuid1.__class__.__qualname__.__eq__,         ["function"], true]
    - [uuid3_class_qualname_eq,         uuid3.__class__.__qualname__.__eq__,         ["function"], true]
    - [uuid5_class_qualname_eq,         uuid5.__class__.__qualname__.__eq__,         ["function"], true]
    - [getnode_class_qualname_eq,       getnode.__class__.__qualname__.__eq__,       ["function"], true]
    - [NAMESPACE_DNS_class_qualname_eq, NAMESPACE_DNS.__class__.__qualname__.__eq__, ["UUID"],     true]

# ---------------------------------------------------------------------------
# uuid object __class__.__module__.__eq__ string values
#
# No prior uuid spec checks __class__.__module__.__eq__ for UUID (the class),
# uuid4, or NAMESPACE_DNS.
# uuid.UUID.__class__.__module__ == 'builtins'  (metaclass is built-in type)
# uuid.uuid4.__class__.__module__ == 'builtins' (function type is built-in)
# uuid.NAMESPACE_DNS.__class__.__module__ == 'uuid' (UUID class defined in uuid)
# Three rows cover the three distinct __class__.__module__ patterns in this module.
# ---------------------------------------------------------------------------

table uuid_extra39.callable_class_modules:
  description: "uuid UUID/__class__.__module__.__eq__('builtins'), uuid4/__class__.__module__.__eq__('builtins'), NAMESPACE_DNS/__class__.__module__.__eq__('uuid') — novel __class__.__module__ axis; no prior uuid spec checks __class__.__module__.__eq__ for any of these objects"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidclsmod39

  columns: [id, function, args, expected]
  rows:
    - [UUID_class_module_eq,          UUID.__class__.__module__.__eq__,          ["builtins"], true]
    - [uuid4_class_module_eq,         uuid4.__class__.__module__.__eq__,         ["builtins"], true]
    - [NAMESPACE_DNS_class_module_eq, NAMESPACE_DNS.__class__.__module__.__eq__, ["uuid"],     true]
