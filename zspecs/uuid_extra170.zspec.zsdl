spec: uuid_extra170
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "This spec covers: uuid module identity attributes — __name__=='uuid' (len=4); __package__=='' (uuid.py is a plain module file, not a package directory, so __package__ is empty string); __spec__.__class__.__name__=='ModuleSpec'; uuid.SafeUUID.__name__=='SafeUUID' (len=8); uuid.SafeUUID.__module__=='uuid'; uuid.SafeUUID.__bases__[0].__name__=='Enum' (SafeUUID directly subclasses enum.Enum); uuid.SafeUUID.safe.value.__eq__(0)==True; uuid.SafeUUID.unsafe.value.__eq__(-1)==True."
    - "uuid.__package__ == '' — uuid is implemented as Lib/uuid.py (a plain module file, not a package directory); the import system sets __package__ to '' for top-level non-package modules."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' — SafeUUID directly subclasses enum.Enum, not int; despite SafeUUID.safe.value being an int (0), SafeUUID itself is a plain Enum, not an IntEnum."
    - "uuid.SafeUUID.safe.value == 0; uuid.SafeUUID.unsafe.value == -1 — the .value attribute exposes the underlying int; safe.__eq__ returns NotImplemented for int comparison, so .value must be used for reliable numeric equality checks."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: uuid module __name__ and __package__ identity
#
# uuid.__name__ == 'uuid' (len 4)
# uuid.__package__ == '' (plain module file, not a package)
# uuid.__name__.__eq__('uuid') == True
# uuid.__package__.__eq__('') == True
#
# uuid is implemented as Lib/uuid.py.  Because it is a plain .py file (not a
# directory with __init__.py), __package__ is '' not 'uuid'.  __name__ is
# always the fully-qualified module name used at import time. New to extra170.
# ---------------------------------------------------------------------------

table uuid_extra170.module_name_and_package:
  description: "uuid.__name__=='uuid' (len=4); __package__=='' (plain module, not a package); new to extra170"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmodule170

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq_uuid,
       "__name__.__eq__",
       ["uuid"],
       true,
       "uuid.__name__.__eq__('uuid') == True — uuid.__name__ is the string 'uuid', the module's fully-qualified name as registered in sys.modules; str.__eq__('uuid') returns True; new to extra170"]
    - [name_len_4,
       "__name__.__len__",
       [],
       4,
       "uuid.__name__.__len__() == 4 — the string 'uuid' has 4 characters (u-u-i-d); str.__len__() returns 4; new to extra170"]
    - [package_eq_empty,
       "__package__.__eq__",
       [""],
       true,
       "uuid.__package__.__eq__('') == True — uuid is Lib/uuid.py, a plain module file rather than a package directory; the import system sets __package__ to '' for top-level non-package modules; str.__eq__('') returns True; new to extra170"]
    - [package_not_uuid,
       "__package__.__eq__",
       ["uuid"],
       false,
       "uuid.__package__.__eq__('uuid') == False — uuid is a plain module (not a package), so __package__ is '' not 'uuid'; str.__eq__('uuid') returns False; new to extra170"]

# ---------------------------------------------------------------------------
# Table 2: uuid.__spec__ and uuid.SafeUUID class identity
#
# uuid.__spec__.__class__.__name__ == 'ModuleSpec'
# uuid.SafeUUID.__name__ == 'SafeUUID' (len 8)
# uuid.SafeUUID.__module__ == 'uuid'
# uuid.SafeUUID.__bases__[0].__name__ == 'Enum'
#
# Every imported module has a __spec__ of type importlib.machinery.ModuleSpec.
# SafeUUID is defined in Lib/uuid.py as a direct subclass of enum.Enum (not
# IntEnum); despite its values being ints, the class itself is a plain Enum.
# New to extra170.
# ---------------------------------------------------------------------------

table uuid_extra170.spec_and_safeuuid_class:
  description: "uuid.__spec__.__class__.__name__=='ModuleSpec'; SafeUUID.__name__=='SafeUUID' (len=8); __module__=='uuid'; __bases__[0].__name__=='Enum'; new to extra170"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmodule170

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "uuid.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — every imported module carries a __spec__ attribute (an importlib.machinery.ModuleSpec instance) populated by the import system; its __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra170"]
    - [safeuuid_name_eq,
       "SafeUUID.__name__.__eq__",
       ["SafeUUID"],
       true,
       "uuid.SafeUUID.__name__.__eq__('SafeUUID') == True — SafeUUID is the enum class defined in Lib/uuid.py; its __name__ attribute is 'SafeUUID'; str.__eq__('SafeUUID') returns True; new to extra170"]
    - [safeuuid_name_len_8,
       "SafeUUID.__name__.__len__",
       [],
       8,
       "uuid.SafeUUID.__name__.__len__() == 8 — 'SafeUUID' has 8 characters (S-a-f-e-U-U-I-D); str.__len__() returns 8; new to extra170"]
    - [safeuuid_module_eq_uuid,
       "SafeUUID.__module__.__eq__",
       ["uuid"],
       true,
       "uuid.SafeUUID.__module__.__eq__('uuid') == True — SafeUUID is defined in Lib/uuid.py so its __module__ attribute is 'uuid'; str.__eq__('uuid') returns True; new to extra170"]

# ---------------------------------------------------------------------------
# Table 3: uuid.SafeUUID bases and member values
#
# uuid.SafeUUID.__bases__[0].__name__ == 'Enum'
# uuid.SafeUUID.safe.value.__eq__(0) == True
# uuid.SafeUUID.unsafe.value.__eq__(-1) == True
# uuid.SafeUUID.safe.__class__.__name__.__eq__('SafeUUID') == True
#
# SafeUUID directly subclasses enum.Enum (not IntEnum).  The .value attribute
# of each member is a plain int.  SafeUUID.safe has value 0 (UUID generation
# used a safe method); SafeUUID.unsafe has value -1 (UUID generation used an
# unsafe method or safety is unknown).  New to extra170.
# ---------------------------------------------------------------------------

table uuid_extra170.safeuuid_bases_and_values:
  description: "SafeUUID.__bases__[0].__name__=='Enum'; safe.value==0; unsafe.value==-1; safe.__class__.__name__=='SafeUUID'; new to extra170"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmodule170

  columns: [id, function, args, expected, description]
  rows:
    - [safeuuid_bases0_enum,
       "SafeUUID.__bases__[0].__name__.__eq__",
       ["Enum"],
       true,
       "uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum') == True — SafeUUID is defined as 'class SafeUUID(enum.Enum)' in Lib/uuid.py; its first (and only) direct base class is enum.Enum; __bases__[0].__name__ is 'Enum'; str.__eq__('Enum') returns True; new to extra170"]
    - [safeuuid_safe_value_0,
       "SafeUUID.safe.value.__eq__",
       [0],
       true,
       "uuid.SafeUUID.safe.value.__eq__(0) == True — SafeUUID.safe represents a UUID generated by a cryptographically safe method; its integer value is 0; int.__eq__(0) returns True; new to extra170"]
    - [safeuuid_unsafe_value_neg1,
       "SafeUUID.unsafe.value.__eq__",
       [-1],
       true,
       "uuid.SafeUUID.unsafe.value.__eq__(-1) == True — SafeUUID.unsafe represents a UUID generated by an unsafe method or one where safety is unknown; its integer value is -1; int.__eq__(-1) returns True; new to extra170"]
    - [safeuuid_safe_class_name,
       "SafeUUID.safe.__class__.__name__.__eq__",
       ["SafeUUID"],
       true,
       "uuid.SafeUUID.safe.__class__.__name__.__eq__('SafeUUID') == True — SafeUUID.safe is an instance of SafeUUID (enum members are instances of their own enum class); its __class__.__name__ is 'SafeUUID'; str.__eq__('SafeUUID') returns True; new to extra170"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra170
# ---------------------------------------------------------------------------

invariant uuid_extra170.name_eq_uuid:
  description: "uuid.__name__ == 'uuid' — the module's fully-qualified name; new to extra170"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra170.name_len_4:
  description: "uuid.__name__.__len__() == 4 — 'uuid' is a 4-character string; new to extra170"
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 4

invariant uuid_extra170.package_empty:
  description: "uuid.__package__ == '' — uuid is Lib/uuid.py (not a package directory), so __package__ is empty string; new to extra170"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant uuid_extra170.spec_is_modulespec:
  description: "uuid.__spec__.__class__.__name__ == 'ModuleSpec' — every imported module has a __spec__ of type importlib.machinery.ModuleSpec; new to extra170"
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant uuid_extra170.safeuuid_name_len_8:
  description: "uuid.SafeUUID.__name__.__len__() == 8 — 'SafeUUID' has 8 characters; new to extra170"
  kind: python_call_eq
  function: SafeUUID.__name__.__len__
  args: []
  expected: 8

invariant uuid_extra170.safeuuid_module_uuid:
  description: "uuid.SafeUUID.__module__ == 'uuid' — SafeUUID is defined in Lib/uuid.py; new to extra170"
  kind: python_call_eq
  function: SafeUUID.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra170.safeuuid_bases0_is_enum:
  description: "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' — SafeUUID directly subclasses enum.Enum, not IntEnum; new to extra170"
  kind: python_call_eq
  function: "SafeUUID.__bases__[0].__name__.__eq__"
  args: ["Enum"]
  expected: true

