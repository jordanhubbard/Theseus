spec: re_extra258
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers additional re.RegexFlag enum member values: ASCII, LOCALE, UNICODE, IGNORECASE, MULTILINE, DOTALL, VERBOSE, DEBUG, NOFLAG."
    - "re.ASCII.__class__.__name__ == 'RegexFlag' — all flag constants are RegexFlag enum members."
    - "re.LOCALE.__class__.__name__ == 'RegexFlag', int value == 4."
    - "re.ASCII (re.A): int value == 256 — match only ASCII characters for \\w, \\d, \\s."
    - "re.LOCALE (re.L): int value == 4 — use current locale for \\w, \\d, \\s."
    - "re.UNICODE (re.U): int value == 32 — match Unicode characters; default for str patterns."
    - "re.IGNORECASE (re.I): int value == 2 — case-insensitive matching."
    - "re.MULTILINE (re.M): int value == 8 — ^ and $ match at each line boundary."
    - "re.DOTALL (re.S): int value == 16 — . matches any character including newline."
    - "re.VERBOSE (re.X): int value == 64 — allow whitespace and comments in patterns."
    - "re.DEBUG: int value == 128 — display debug info about compiled expression."
    - "re.NOFLAG: int value == 0 — no flags (added in Python 3.11)."
    - "re.RegexFlag.NOFLAG is present in __members__ confirming Python 3.11+ availability."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.RegexFlag enum member class identity
#
# Every flag constant (ASCII, LOCALE, UNICODE, IGNORECASE, MULTILINE, DOTALL,
# VERBOSE, DEBUG, NOFLAG) is an instance of the re.RegexFlag IntFlag enum.
# Checking __class__.__name__ == 'RegexFlag' for each confirms correct type.
# ---------------------------------------------------------------------------

table re_extra258.regex_flag_class_identity:
  description: "re.RegexFlag enum member __class__.__name__ == 'RegexFlag' for all standard flags; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: rexfci258

  columns: [id, function, args, expected, description]
  rows:
    - [ascii_class,
       "ASCII.__class__.__name__.__eq__",
       ["RegexFlag"],
       true,
       "re.ASCII.__class__.__name__.__eq__('RegexFlag') == True — re.ASCII (re.A) is an instance of the RegexFlag IntFlag enum; it restricts \\w, \\d, \\s to ASCII characters only; str.__eq__('RegexFlag') returns True; new to extra258"]
    - [locale_class,
       "LOCALE.__class__.__name__.__eq__",
       ["RegexFlag"],
       true,
       "re.LOCALE.__class__.__name__.__eq__('RegexFlag') == True — re.LOCALE (re.L) is a RegexFlag enum member; it makes \\w, \\d, \\s locale-dependent; str.__eq__('RegexFlag') returns True; new to extra258"]
    - [unicode_class,
       "UNICODE.__class__.__name__.__eq__",
       ["RegexFlag"],
       true,
       "re.UNICODE.__class__.__name__.__eq__('RegexFlag') == True — re.UNICODE (re.U) is a RegexFlag enum member; it is the default for str patterns and enables Unicode matching; str.__eq__('RegexFlag') returns True; new to extra258"]
    - [ignorecase_class,
       "IGNORECASE.__class__.__name__.__eq__",
       ["RegexFlag"],
       true,
       "re.IGNORECASE.__class__.__name__.__eq__('RegexFlag') == True — re.IGNORECASE (re.I) is a RegexFlag enum member; it enables case-insensitive matching; str.__eq__('RegexFlag') returns True; new to extra258"]
    - [multiline_class,
       "MULTILINE.__class__.__name__.__eq__",
       ["RegexFlag"],
       true,
       "re.MULTILINE.__class__.__name__.__eq__('RegexFlag') == True — re.MULTILINE (re.M) is a RegexFlag enum member; it makes ^ and $ match at line boundaries; str.__eq__('RegexFlag') returns True; new to extra258"]
    - [dotall_class,
       "DOTALL.__class__.__name__.__eq__",
       ["RegexFlag"],
       true,
       "re.DOTALL.__class__.__name__.__eq__('RegexFlag') == True — re.DOTALL (re.S) is a RegexFlag enum member; it makes . match any character including newline; str.__eq__('RegexFlag') returns True; new to extra258"]
    - [verbose_class,
       "VERBOSE.__class__.__name__.__eq__",
       ["RegexFlag"],
       true,
       "re.VERBOSE.__class__.__name__.__eq__('RegexFlag') == True — re.VERBOSE (re.X) is a RegexFlag enum member; it allows whitespace and comments in patterns for readability; str.__eq__('RegexFlag') returns True; new to extra258"]
    - [debug_class,
       "DEBUG.__class__.__name__.__eq__",
       ["RegexFlag"],
       true,
       "re.DEBUG.__class__.__name__.__eq__('RegexFlag') == True — re.DEBUG is a RegexFlag enum member; it causes the regex engine to display debug information about the compiled expression; str.__eq__('RegexFlag') returns True; new to extra258"]
    - [noflag_class,
       "NOFLAG.__class__.__name__.__eq__",
       ["RegexFlag"],
       true,
       "re.NOFLAG.__class__.__name__.__eq__('RegexFlag') == True — re.NOFLAG (added in Python 3.11) is a RegexFlag enum member representing the absence of flags; its integer value is 0; str.__eq__('RegexFlag') returns True; new to extra258"]

# ---------------------------------------------------------------------------
# Table 2: re.RegexFlag enum member .value (integer values)
#
# Each RegexFlag member's .value attribute holds the corresponding integer.
# These integer values are powers of two (except NOFLAG == 0), allowing
# flags to be combined with bitwise OR. Verified against the Python docs.
# ---------------------------------------------------------------------------

table re_extra258.regex_flag_values:
  description: "re.RegexFlag enum member .value integer values for all standard flags; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: rexfv258

  columns: [id, function, args, expected, description]
  rows:
    - [noflag_value,
       "RegexFlag.NOFLAG.value.__eq__",
       [0],
       true,
       "re.RegexFlag.NOFLAG.value.__eq__(0) == True — NOFLAG has integer value 0, representing the absence of any flag; int.__eq__(0) returns True; new to extra258"]
    - [ignorecase_value,
       "RegexFlag.IGNORECASE.value.__eq__",
       [2],
       true,
       "re.RegexFlag.IGNORECASE.value.__eq__(2) == True — IGNORECASE has integer value 2; it is combined with other flags via bitwise OR; int.__eq__(2) returns True; new to extra258"]
    - [locale_value,
       "RegexFlag.LOCALE.value.__eq__",
       [4],
       true,
       "re.RegexFlag.LOCALE.value.__eq__(4) == True — LOCALE has integer value 4; it is mutually exclusive with ASCII and UNICODE in most contexts; int.__eq__(4) returns True; new to extra258"]
    - [multiline_value,
       "RegexFlag.MULTILINE.value.__eq__",
       [8],
       true,
       "re.RegexFlag.MULTILINE.value.__eq__(8) == True — MULTILINE has integer value 8; it changes ^ and $ semantics to line boundaries; int.__eq__(8) returns True; new to extra258"]
    - [dotall_value,
       "RegexFlag.DOTALL.value.__eq__",
       [16],
       true,
       "re.RegexFlag.DOTALL.value.__eq__(16) == True — DOTALL has integer value 16; it makes . match \\n as well; int.__eq__(16) returns True; new to extra258"]
    - [unicode_value,
       "RegexFlag.UNICODE.value.__eq__",
       [32],
       true,
       "re.RegexFlag.UNICODE.value.__eq__(32) == True — UNICODE has integer value 32; it is the default for str patterns in Python 3; int.__eq__(32) returns True; new to extra258"]
    - [verbose_value,
       "RegexFlag.VERBOSE.value.__eq__",
       [64],
       true,
       "re.RegexFlag.VERBOSE.value.__eq__(64) == True — VERBOSE has integer value 64; it allows whitespace and # comments in pattern strings; int.__eq__(64) returns True; new to extra258"]
    - [debug_value,
       "RegexFlag.DEBUG.value.__eq__",
       [128],
       true,
       "re.RegexFlag.DEBUG.value.__eq__(128) == True — DEBUG has integer value 128; it prints debug output about the compiled pattern to sys.stdout; int.__eq__(128) returns True; new to extra258"]
    - [ascii_value,
       "RegexFlag.ASCII.value.__eq__",
       [256],
       true,
       "re.RegexFlag.ASCII.value.__eq__(256) == True — ASCII has integer value 256; it restricts matching to ASCII characters for \\w, \\W, \\d, \\D, \\s, \\S; int.__eq__(256) returns True; new to extra258"]

# ---------------------------------------------------------------------------
# Standalone invariants — re_extra258
# ---------------------------------------------------------------------------

invariant re_extra258.ascii_is_regexflag:
  description: "re.ASCII.__class__.__name__ == 'RegexFlag' — re.ASCII is a RegexFlag enum member; new to extra258"
  kind: python_call_eq
  function: ASCII.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra258.locale_is_regexflag:
  description: "re.LOCALE.__class__.__name__ == 'RegexFlag' — re.LOCALE is a RegexFlag enum member; new to extra258"
  kind: python_call_eq
  function: LOCALE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra258.debug_is_regexflag:
  description: "re.DEBUG.__class__.__name__ == 'RegexFlag' — re.DEBUG is a RegexFlag enum member; new to extra258"
  kind: python_call_eq
  function: DEBUG.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra258.noflag_is_regexflag:
  description: "re.NOFLAG.__class__.__name__ == 'RegexFlag' — re.NOFLAG is a RegexFlag enum member (Python 3.11+); new to extra258"
  kind: python_call_eq
  function: NOFLAG.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra258.ascii_value:
  description: "re.RegexFlag.ASCII.value == 256 — ASCII flag has integer value 256; new to extra258"
  kind: python_call_eq
  function: RegexFlag.ASCII.value.__eq__
  args: [256]
  expected: true

invariant re_extra258.locale_value:
  description: "re.RegexFlag.LOCALE.value == 4 — LOCALE flag has integer value 4; new to extra258"
  kind: python_call_eq
  function: RegexFlag.LOCALE.value.__eq__
  args: [4]
  expected: true

invariant re_extra258.debug_value:
  description: "re.RegexFlag.DEBUG.value == 128 — DEBUG flag has integer value 128; new to extra258"
  kind: python_call_eq
  function: RegexFlag.DEBUG.value.__eq__
  args: [128]
  expected: true

invariant re_extra258.noflag_value:
  description: "re.RegexFlag.NOFLAG.value == 0 — NOFLAG has integer value 0 representing no flags; new to extra258"
  kind: python_call_eq
  function: RegexFlag.NOFLAG.value.__eq__
  args: [0]
  expected: true

invariant re_extra258.unicode_value:
  description: "re.RegexFlag.UNICODE.value == 32 — UNICODE flag has integer value 32; default for str patterns; new to extra258"
  kind: python_call_eq
  function: RegexFlag.UNICODE.value.__eq__
  args: [32]
  expected: true

invariant re_extra258.ignorecase_value:
  description: "re.RegexFlag.IGNORECASE.value == 2 — IGNORECASE flag has integer value 2; new to extra258"
  kind: python_call_eq
  function: RegexFlag.IGNORECASE.value.__eq__
  args: [2]
  expected: true

invariant re_extra258.multiline_value:
  description: "re.RegexFlag.MULTILINE.value == 8 — MULTILINE flag has integer value 8; new to extra258"
  kind: python_call_eq
  function: RegexFlag.MULTILINE.value.__eq__
  args: [8]
  expected: true

invariant re_extra258.dotall_value:
  description: "re.RegexFlag.DOTALL.value == 16 — DOTALL flag has integer value 16; new to extra258"
  kind: python_call_eq
  function: RegexFlag.DOTALL.value.__eq__
  args: [16]
  expected: true

invariant re_extra258.verbose_value:
  description: "re.RegexFlag.VERBOSE.value == 64 — VERBOSE flag has integer value 64; new to extra258"
  kind: python_call_eq
  function: RegexFlag.VERBOSE.value.__eq__
  args: [64]
  expected: true
