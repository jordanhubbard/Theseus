spec: os_extra37
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "os_extra36.zspec.zsdl — covers __module__.__len__() for scandir/walk/urandom; environ/__class__.__name__.__len__(); sep/linesep/curdir __class__.__name__.__eq__('str'); walk module quirk."
  notes:
    - "This spec extends os_extra36.zspec.zsdl."
    - "Prior specs covered: __module__/__name__/__qualname__ lengths and equalities for getcwd/listdir/mkdir/makedirs/remove/rename/stat/getpid/scandir/walk/urandom; environ/__class__.__name__; sep/linesep/curdir string class type checks."
    - "This spec covers: os.stat_result.__dict__.__class__.__name__.__len__()==12 ('mappingproxy'); os.stat_result.__mro__.__len__()==3; os.stat_result.__bases__[0].__name__.__len__()==5 ('tuple'); os.terminal_size.__dict__.__class__.__name__.__len__()==12; os.terminal_size.__mro__.__len__()==3; os.terminal_size.__bases__[0].__name__.__len__()==5; os.error.__dict__.__class__.__name__.__len__()==12; os.error.__bases__[0].__name__.__len__()==9 (base is Exception, not OSError — os.error IS OSError); os.getpid/__qualname__.__len__()==6; os.getppid/__qualname__.__len__()==7; os.getcwd/__qualname__.__len__()==6; os.listdir/__qualname__.__len__()==7; os.path.__class__.__name__.__len__()==6 ('module'); os.sep.__len__()==1; os.linesep.__len__()==1 (macOS, '\\n'); os.pardir.__len__()==2 ('..')."
    - "SURPRISE: os.error is an alias for OSError. os.error.__bases__ == (<class 'Exception'>,) because OSError's base is Exception, not itself. So os.error.__bases__[0].__name__ == 'Exception' (len 9), not 'OSError' (len 7)."
    - "os.stat_result.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Verified Python 3.12 macOS."
    - "os.stat_result.__mro__.__len__() == 3 — stat_result → tuple → object. Verified."
    - "os.stat_result.__bases__[0].__name__ == 'tuple' (len 5). Verified."
    - "os.terminal_size.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Verified."
    - "os.terminal_size.__mro__.__len__() == 3 — terminal_size → tuple → object. Verified."
    - "os.terminal_size.__bases__[0].__name__ == 'tuple' (len 5). Verified."
    - "os.error.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Verified."
    - "os.error.__bases__[0].__name__ == 'Exception' (len 9). SURPRISE — os.error is OSError; OSError's base is Exception. Verified."
    - "os.getpid.__qualname__ == 'getpid' (len 6). Verified."
    - "os.getppid.__qualname__ == 'getppid' (len 7). Verified."
    - "os.getcwd.__qualname__ == 'getcwd' (len 6). Verified."
    - "os.listdir.__qualname__ == 'listdir' (len 7). Verified."
    - "os.path.__class__.__name__ == 'module' (len 6). Verified."
    - "os.sep == '/' (len 1) on macOS/POSIX. Verified."
    - "os.linesep == '\\n' (len 1) on macOS/POSIX. Verified."
    - "os.pardir == '..' (len 2). Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: class __dict__.__class__.__name__.__len__() for stat_result/terminal_size/error
#
# The __dict__ of a C-defined class is a mappingproxy. len('mappingproxy') == 12.
# No prior os spec checks __dict__.__class__.__name__.__len__() for any of
# these three types. All three are C-extension types so all have mappingproxy
# dicts. Verified: all 12.
# ---------------------------------------------------------------------------

table os_extra37.type_dict_class_name_lengths:
  description: "__dict__.__class__.__name__.__len__() for stat_result/terminal_size/error — all 12 ('mappingproxy')"
  kind: python_call_eq
  category: type_attrs
  id_prefix: extdcnl37

  columns: [id, function, args, expected]
  rows:
    - [stat_result,   stat_result.__dict__.__class__.__name__.__len__,   [], 12]
    - [terminal_size, terminal_size.__dict__.__class__.__name__.__len__, [], 12]
    - [error,         error.__dict__.__class__.__name__.__len__,         [], 12]

# ---------------------------------------------------------------------------
# Table: __mro__.__len__() for stat_result and terminal_size
#
# Both os.stat_result and os.terminal_size inherit from tuple, which inherits
# from object: MRO length == 3.
# No prior os spec checks __mro__.__len__() for these types. Verified: both 3.
# ---------------------------------------------------------------------------

table os_extra37.type_mro_lengths:
  description: "__mro__.__len__() for stat_result and terminal_size — both 3 (type → tuple → object)"
  kind: python_call_eq
  category: type_attrs
  id_prefix: extmlen37

  columns: [id, function, args, expected]
  rows:
    - [stat_result,   stat_result.__mro__.__len__,   [], 3]
    - [terminal_size, terminal_size.__mro__.__len__, [], 3]

# ---------------------------------------------------------------------------
# Table: __bases__[0].__name__.__len__() for stat_result, terminal_size, error
#
# stat_result and terminal_size both inherit directly from tuple (len 5).
# error IS OSError, whose direct base is Exception (len 9) — not OSError itself.
# SURPRISE documented: os.error is an alias for OSError, so bases[0] is
# Exception, not OSError. Verified.
# ---------------------------------------------------------------------------

table os_extra37.type_base_name_lengths:
  description: "__bases__[0].__name__.__len__() for stat_result (5, 'tuple'), terminal_size (5, 'tuple'), error (9, 'Exception')"
  kind: python_call_eq
  category: type_attrs
  id_prefix: extbnl37

  columns: [id, function, args, expected]
  rows:
    - [stat_result,   "stat_result.__bases__[0].__name__.__len__",   [], 5]
    - [terminal_size, "terminal_size.__bases__[0].__name__.__len__", [], 5]
    - [error,         "error.__bases__[0].__name__.__len__",         [], 9]

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for getpid/getppid/getcwd/listdir
#
# No prior os spec checks __qualname__.__len__() for these four functions.
# (Prior specs check __qualname__ equality and __name__/__module__ lengths.)
# getpid (6), getppid (7), getcwd (6), listdir (7). Verified.
# ---------------------------------------------------------------------------

table os_extra37.function_qualname_lengths:
  description: "__qualname__.__len__() for getpid/getppid/getcwd/listdir — 6/7/6/7 respectively"
  kind: python_call_eq
  category: function_attrs
  id_prefix: extqlen37

  columns: [id, function, args, expected]
  rows:
    - [getpid,   getpid.__qualname__.__len__,   [], 6]
    - [getppid,  getppid.__qualname__.__len__,  [], 7]
    - [getcwd,   getcwd.__qualname__.__len__,   [], 6]
    - [listdir,  listdir.__qualname__.__len__,  [], 7]

# ---------------------------------------------------------------------------
# Standalone: os.path.__class__.__name__.__len__() == 6
#
# os.path is a module object (posixpath on macOS/POSIX).
# __class__.__name__ == 'module' (len 6).
# No prior os spec checks __class__.__name__.__len__() on os.path.
# Verified: 6.
# ---------------------------------------------------------------------------

invariant os_extra37.path.class_name_len:
  description: "os.path.__class__.__name__.__len__() == 6 — os.path is a 'module' (len 6)"
  category: type_attrs
  kind: python_call_eq
  function: path.__class__.__name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Standalone: os.sep.__len__() == 1
#
# On POSIX/macOS os.sep == '/' (one character). No prior os spec checks
# os.sep.__len__(). Verified: 1.
# ---------------------------------------------------------------------------

invariant os_extra37.sep.len:
  description: "os.sep.__len__() == 1 — os.sep is '/' on POSIX/macOS, one character"
  category: string_attrs
  kind: python_call_eq
  function: sep.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Standalone: os.linesep.__len__() == 1
#
# On macOS/POSIX os.linesep == '\n' (one character). No prior os spec checks
# os.linesep.__len__(). Verified: 1.
# ---------------------------------------------------------------------------

invariant os_extra37.linesep.len:
  description: "os.linesep.__len__() == 1 — os.linesep is '\\n' on macOS/POSIX, one character"
  category: string_attrs
  kind: python_call_eq
  function: linesep.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Standalone: os.pardir.__len__() == 2
#
# os.pardir == '..' (two characters, portable across platforms).
# No prior os spec checks os.pardir.__len__(). Verified: 2.
# ---------------------------------------------------------------------------

invariant os_extra37.pardir.len:
  description: "os.pardir.__len__() == 2 — os.pardir is '..' (parent directory marker), 2 characters"
  category: string_attrs
  kind: python_call_eq
  function: pardir.__len__
  args: []
  expected: 2
