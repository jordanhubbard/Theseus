spec: multiprocessing_extra1996
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.html#synchronization-primitives"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 580 (_extra1996): __index__, __complex__, __float__, __round__, __abs__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing types are process/IPC primitives, not numeric types."
    - "Covers multiprocessing.Process, synchronize.Lock, synchronize.RLock, synchronize.Semaphore, synchronize.Event, synchronize.Condition."
    - "None of these define __index__, __complex__, __float__, __round__, or __abs__ in their own __dict__."
  created_at: "2026-04-12"
error_model: python_exceptions

table multiprocessing_extra1996.index_protocol:
  description: "multiprocessing types __index__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1996

  columns: [id, function, args, expected]
  rows:
    - ["mp1996001", "multiprocessing.Process.__dict__.__contains__",                     ["__index__"],   false]
    - ["mp1996002", "multiprocessing.synchronize.Lock.__dict__.__contains__",            ["__index__"],   false]
    - ["mp1996003", "multiprocessing.synchronize.RLock.__dict__.__contains__",           ["__index__"],   false]
    - ["mp1996004", "multiprocessing.synchronize.Semaphore.__dict__.__contains__",       ["__index__"],   false]
    - ["mp1996005", "multiprocessing.synchronize.Event.__dict__.__contains__",           ["__index__"],   false]
    - ["mp1996006", "multiprocessing.synchronize.Condition.__dict__.__contains__",       ["__index__"],   false]

