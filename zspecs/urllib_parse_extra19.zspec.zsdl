spec: urllib_parse_extra19
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html
rfcs:
  - "RFC 3986 — Uniform Resource Identifier (URI): Generic Syntax"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
    - "urllib_parse_extra4.zspec.zsdl — covers __qualname__.__eq__ for urlparse/urlsplit/urljoin/urlencode/quote/unquote and ParseResult/SplitResult/DefragResult."
    - "urllib_parse_extra5.zspec.zsdl — covers __qualname__.__eq__ for quote_plus/unquote_plus/parse_qs/parse_qsl."
    - "urllib_parse_extra14.zspec.zsdl — covers __qualname__.__len__() for urlparse/urlencode/quote/unquote/urljoin/urlsplit and result classes ParseResult/SplitResult."
    - "urllib_parse_extra15.zspec.zsdl — covers __qualname__.__eq__ and __len__() for urlunparse; __len__() for quote_plus/unquote_plus."
    - "urllib_parse_extra16.zspec.zsdl — covers ParseResult.geturl.__qualname__; urldefrag __qualname__/__len__(); DefragResult __qualname__/__len__(); cross-namespace anchors."
    - "urllib_parse_extra17.zspec.zsdl — covers __module__ for ParseResult/SplitResult/DefragResult; ParseResult._fields type and len; cross-namespace qualname lengths and anchors."
    - "urllib_parse_extra18.zspec.zsdl — covers __module__.__eq__ for urlparse/urlsplit/urlunsplit/urlunparse/urlencode/urljoin/quote/unquote/quote_plus/unquote_plus; ParseResult.__bases__[0].__name__=='_ParseResultBase'; SplitResult.__bases__[0].__name__=='_SplitResultBase'; SplitResult._fields len==5."
  notes:
    - "This spec extends the urllib_parse chain through urllib_parse_extra18; it does NOT duplicate invariants in any prior spec."
    - "Focus: (1) ParseResult/__qualname__ as a standalone eq+len check — extra4/14 cover in tables; standalone cross-namespace anchor for extra19; (2) SplitResult.__qualname__ standalone eq+len; (3) DefragResult.__qualname__ standalone eq+len; (4) DefragResult.__bases__[0].__name__ == '_DefragResultBase' — extra18 covers ParseResult and SplitResult; DefragResult not yet covered; (5) urldefrag.__name__ and __module__ as standalone invariants — extra16 covers __qualname__/__len__() but not __name__ or __module__; (6) parse_qs/__name__ and parse_qsl/__name__ — extra5 covers __qualname__.__eq__; no prior spec checks __name__; (7) urlencode.__module__ standalone eq — extra18 covers in table; standalone cross-namespace anchor here."
    - "urllib.parse.ParseResult.__qualname__ == 'ParseResult' — len 11. Standalone anchor; extra4/14 cover in tables. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.SplitResult.__qualname__ == 'SplitResult' — len 11. Standalone anchor. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.DefragResult.__qualname__ == 'DefragResult' — len 12. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.DefragResult.__bases__[0].__name__ == '_DefragResultBase' — len 17. Internal NamedTuple base class. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.urldefrag.__name__ == 'urldefrag' — len 9. No prior spec checks __name__ (only __qualname__). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.urldefrag.__module__ == 'urllib.parse' — len 12. No prior spec checks urldefrag.__module__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.parse_qs.__name__ == 'parse_qs' — len 8. No prior spec checks __name__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.parse_qsl.__name__ == 'parse_qsl' — len 9. No prior spec checks __name__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.urlencode.__module__ == 'urllib.parse' — len 12. extra18 covers in table; standalone cross-namespace anchor here. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ParseResult, SplitResult, DefragResult — __qualname__ standalone invariants
#
# urllib_parse_extra4 covers __qualname__.__eq__ for all three in a table.
# urllib_parse_extra14 covers __qualname__.__len__() for ParseResult/SplitResult.
# urllib_parse_extra16 covers DefragResult.__qualname__.__len__() == 12.
# These standalone invariants provide cross-namespace anchors from extra19.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra19.ParseResult.qualname_eq:
  description: "urllib.parse.ParseResult.__qualname__ == 'ParseResult' — cross-namespace anchor from extra19; extra4 covers in table"
  category: class_qualnames
  kind: python_call_eq
  function: ParseResult.__qualname__.__eq__
  args: ["ParseResult"]
  expected: true

invariant urllib_parse_extra19.ParseResult.qualname_len:
  description: "len(urllib.parse.ParseResult.__qualname__) == 11 — len('ParseResult') == 11"
  category: class_qualnames
  kind: python_call_eq
  function: ParseResult.__qualname__.__len__
  args: []
  expected: 11

invariant urllib_parse_extra19.SplitResult.qualname_eq:
  description: "urllib.parse.SplitResult.__qualname__ == 'SplitResult' — cross-namespace anchor from extra19; extra4 covers in table"
  category: class_qualnames
  kind: python_call_eq
  function: SplitResult.__qualname__.__eq__
  args: ["SplitResult"]
  expected: true

invariant urllib_parse_extra19.SplitResult.qualname_len:
  description: "len(urllib.parse.SplitResult.__qualname__) == 11 — len('SplitResult') == 11"
  category: class_qualnames
  kind: python_call_eq
  function: SplitResult.__qualname__.__len__
  args: []
  expected: 11

invariant urllib_parse_extra19.DefragResult.qualname_eq:
  description: "urllib.parse.DefragResult.__qualname__ == 'DefragResult' — cross-namespace anchor from extra19"
  category: class_qualnames
  kind: python_call_eq
  function: DefragResult.__qualname__.__eq__
  args: ["DefragResult"]
  expected: true

invariant urllib_parse_extra19.DefragResult.qualname_len:
  description: "len(urllib.parse.DefragResult.__qualname__) == 12 — len('DefragResult') == 12"
  category: class_qualnames
  kind: python_call_eq
  function: DefragResult.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# DefragResult.__bases__[0].__name__
#
# urllib_parse_extra18 covers ParseResult.__bases__[0].__name__ == '_ParseResultBase'
# and SplitResult.__bases__[0].__name__ == '_SplitResultBase'.
# No prior spec checks DefragResult.__bases__[0].__name__.
# DefragResult's internal base class is _DefragResultBase (len 17).
# ---------------------------------------------------------------------------

invariant urllib_parse_extra19.DefragResult.bases0_name_eq:
  description: "urllib.parse.DefragResult.__bases__[0].__name__ == '_DefragResultBase' — internal NamedTuple base class for DefragResult"
  category: class_hierarchy
  kind: python_call_eq
  "function": "DefragResult.__bases__[0].__name__.__eq__"
  args: ["_DefragResultBase"]
  expected: true

invariant urllib_parse_extra19.DefragResult.bases0_name_len:
  description: "len(urllib.parse.DefragResult.__bases__[0].__name__) == 17 — len('_DefragResultBase') == 17"
  category: class_hierarchy
  kind: python_call_eq
  "function": "DefragResult.__bases__[0].__name__.__len__"
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# urllib.parse.ParseResult.__bases__[0].__name__ and SplitResult.__bases__[0].__name__
# cross-namespace anchors from extra19
#
# urllib_parse_extra18 covers both of these. These standalone invariants provide
# cross-namespace anchors from the extra19 namespace.
# ---------------------------------------------------------------------------

table urllib_parse_extra19.result_bases0_names:
  description: "__bases__[0].__name__.__eq__ for ParseResult and SplitResult — cross-namespace anchors from extra19; extra18 covers originally"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: rbn19

  columns: [id, function, args, expected]
  rows:
    - [ParseResult, "ParseResult.__bases__[0].__name__.__eq__", ["_ParseResultBase"], true]
    - [SplitResult, "SplitResult.__bases__[0].__name__.__eq__", ["_SplitResultBase"], true]

# ---------------------------------------------------------------------------
# urldefrag __name__ and __module__
#
# urllib_parse_extra16 covers urldefrag.__qualname__.__eq__ and __len__() == 9.
# No prior spec checks urldefrag.__name__ (distinct from __qualname__ for
# module-level functions they are equal, but __name__ is the simpler attribute)
# or urldefrag.__module__.
# urldefrag.__name__ == 'urldefrag' (len 9); __module__ == 'urllib.parse' (len 12).
# ---------------------------------------------------------------------------

invariant urllib_parse_extra19.urldefrag.name_eq:
  description: "urllib.parse.urldefrag.__name__ == 'urldefrag' — no prior spec checks __name__ for urldefrag (only __qualname__)"
  category: function_names
  kind: python_call_eq
  function: urldefrag.__name__.__eq__
  args: ["urldefrag"]
  expected: true

invariant urllib_parse_extra19.urldefrag.name_len:
  description: "len(urllib.parse.urldefrag.__name__) == 9 — len('urldefrag') == 9"
  category: function_names
  kind: python_call_eq
  function: urldefrag.__name__.__len__
  args: []
  expected: 9

invariant urllib_parse_extra19.urldefrag.module_eq:
  description: "urllib.parse.urldefrag.__module__ == 'urllib.parse' — no prior spec checks urldefrag.__module__"
  category: function_module
  kind: python_call_eq
  function: urldefrag.__module__.__eq__
  args: ["urllib.parse"]
  expected: true

# ---------------------------------------------------------------------------
# parse_qs and parse_qsl — __name__
#
# urllib_parse_extra5 covers parse_qs.__qualname__.__eq__ and
# parse_qsl.__qualname__.__eq__. No prior spec checks __name__ for either.
# parse_qs.__name__ == 'parse_qs' (len 8); parse_qsl.__name__ == 'parse_qsl' (len 9).
# ---------------------------------------------------------------------------

table urllib_parse_extra19.parse_function_names:
  description: "__name__.__eq__ for parse_qs and parse_qsl — no prior spec checks __name__ for these functions"
  kind: python_call_eq
  category: function_names
  id_prefix: pfn19

  columns: [id, function, args, expected]
  rows:
    - [parse_qs,  parse_qs.__name__.__eq__,  ["parse_qs"],  true]
    - [parse_qsl, parse_qsl.__name__.__eq__, ["parse_qsl"], true]

table urllib_parse_extra19.parse_function_name_lengths:
  description: "len(__name__) for parse_qs (8) and parse_qsl (9)"
  kind: python_call_eq
  category: function_names
  id_prefix: pfnlen19

  columns: [id, function, args, expected]
  rows:
    - [parse_qs,  parse_qs.__name__.__len__,  [], 8]
    - [parse_qsl, parse_qsl.__name__.__len__, [], 9]

# ---------------------------------------------------------------------------
# urlencode.__module__ standalone cross-namespace anchor
#
# urllib_parse_extra18 covers urlencode.__module__.__eq__ in a table.
# This standalone invariant provides a cross-namespace anchor from extra19.
# urlencode.__module__ == 'urllib.parse' (len 12).
# ---------------------------------------------------------------------------

invariant urllib_parse_extra19.urlencode.module_eq:
  description: "urllib.parse.urlencode.__module__ == 'urllib.parse' — cross-namespace anchor from extra19; extra18 covers in table"
  category: function_module
  kind: python_call_eq
  function: urlencode.__module__.__eq__
  args: ["urllib.parse"]
  expected: true

invariant urllib_parse_extra19.urlencode.module_len:
  description: "len(urllib.parse.urlencode.__module__) == 12 — len('urllib.parse') == 12"
  category: function_module
  kind: python_call_eq
  function: urlencode.__module__.__len__
  args: []
  expected: 12
