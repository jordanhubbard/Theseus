spec: inspect_extra15
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect.zspec.zsdl and prior extras through inspect_extra14.zspec.zsdl."
    - "inspect_extra14 covers Parameter kind enum values (POSITIONAL_OR_KEYWORD==1, VAR_POSITIONAL==2, VAR_KEYWORD==4); Parameter.empty.__class__.__name__; utility func __qualname__ (getmembers/getmodule/getfile/getsource/getsourcelines); Signature/BoundArguments/Parameter __bases__.__len__."
    - "NOT yet covered: isfunction/__name__/__qualname__ as standalone invariants."
    - "NOT yet covered: isbuiltin/__name__/__qualname__ as standalone invariants."
    - "NOT yet covered: isclass/__name__/__qualname__ as standalone invariants."
    - "NOT yet covered: ismodule/__name__/__qualname__ as standalone invariants."
    - "NOT yet covered: ismethod/__name__/__qualname__ as standalone invariants."
    - "NOT yet covered: ismethoddescriptor/__name__/__qualname__ as standalone invariants."
    - "NOT yet covered: getmembers.__name__.__eq__ standalone invariant."
    - "NOT yet covered: FullArgSpec.__qualname__/__module__ standalone invariants."
    - "NOT yet covered: Signature/__module__ standalone invariant."
    - "NOT yet covered: BoundArguments/__module__ standalone invariant."
    - "NOT yet covered: Parameter/__module__ standalone invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Predicate function __name__ checks — isfunction, isbuiltin, isclass,
# ismodule, ismethod, ismethoddescriptor
#
# Prior inspect specs cover __qualname__ for getmembers/getmodule/getfile/
# getsource/getsourcelines (inspect_extra14) but not the is* predicates.
# These are plain Python functions with __name__ == their bare identifier.
# ---------------------------------------------------------------------------

table inspect_extra15.predicate_names:
  kind: python_call_eq
  category: function_names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [isfunction,         isfunction.__name__.__eq__,         ["isfunction"],         true]
    - [isbuiltin,          isbuiltin.__name__.__eq__,          ["isbuiltin"],          true]
    - [isclass,            isclass.__name__.__eq__,            ["isclass"],            true]
    - [ismodule,           ismodule.__name__.__eq__,           ["ismodule"],           true]
    - [ismethod,           ismethod.__name__.__eq__,           ["ismethod"],           true]
    - [ismethoddescriptor, ismethoddescriptor.__name__.__eq__, ["ismethoddescriptor"], true]

# ---------------------------------------------------------------------------
# Predicate function __qualname__ checks
#
# For module-level functions, __qualname__ == __name__. No prior inspect
# spec verifies __qualname__ for any of these six predicate functions.
# ---------------------------------------------------------------------------

table inspect_extra15.predicate_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [isfunction,         isfunction.__qualname__.__eq__,         ["isfunction"],         true]
    - [isbuiltin,          isbuiltin.__qualname__.__eq__,          ["isbuiltin"],          true]
    - [isclass,            isclass.__qualname__.__eq__,            ["isclass"],            true]
    - [ismodule,           ismodule.__qualname__.__eq__,           ["ismodule"],           true]
    - [ismethod,           ismethod.__qualname__.__eq__,           ["ismethod"],           true]
    - [ismethoddescriptor, ismethoddescriptor.__qualname__.__eq__, ["ismethoddescriptor"], true]

# ---------------------------------------------------------------------------
# Class __module__ checks — Signature, BoundArguments, Parameter, FullArgSpec
#
# inspect_extra12 and inspect_extra14 cover __bases__.__len__ and
# __bases__[0].__name__ for these classes but no prior spec checks __module__
# for Signature, BoundArguments, or Parameter as standalone invariants.
# FullArgSpec.__module__ has also not been checked in any prior spec.
# ---------------------------------------------------------------------------

invariant inspect_extra15.Signature.module:
  description: "inspect.Signature.__module__ == 'inspect' — Signature is defined in the inspect module"
  category: module_attrs
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra15.BoundArguments.module:
  description: "inspect.BoundArguments.__module__ == 'inspect' — BoundArguments is defined in the inspect module"
  category: module_attrs
  kind: python_call_eq
  function: BoundArguments.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra15.Parameter.module:
  description: "inspect.Parameter.__module__ == 'inspect' — Parameter is defined in the inspect module"
  category: module_attrs
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra15.FullArgSpec.qualname:
  description: "inspect.FullArgSpec.__qualname__ == 'FullArgSpec' — namedtuple class qualname"
  category: class_qualnames
  kind: python_call_eq
  function: FullArgSpec.__qualname__.__eq__
  args: ["FullArgSpec"]
  expected: true

invariant inspect_extra15.FullArgSpec.module:
  description: "inspect.FullArgSpec.__module__ == 'inspect' — FullArgSpec is defined in the inspect module"
  category: module_attrs
  kind: python_call_eq
  function: FullArgSpec.__module__.__eq__
  args: ["inspect"]
  expected: true
