spec: os_path_extra7
version: ">=3.9"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py"
  notes:
    - "This spec extends os_path.zspec.zsdl and prior extras."
    - "os_path_extra6 covers __qualname__ for join/split/basename/dirname/normpath/abspath (table) and exists/isfile/isdir/isabs (standalone invariants)."
    - "This spec adds __name__ for islink/getsize/realpath (not covered in any prior spec) and __qualname__ for islink/getsize/realpath (also not covered)."
    - "Additionally adds new join() value vectors with trailing separator components and splitext() behavioral vectors not present in prior specs."
    - "os.path.islink.__name__ == 'islink' — not covered in any prior os_path spec."
    - "os.path.getsize.__name__ == 'getsize' — not covered in any prior os_path spec."
    - "os.path.realpath.__name__ == 'realpath' — not covered in any prior os_path spec."
    - "os.path.islink.__qualname__ == 'islink' — not covered in any prior os_path spec."
    - "os.path.getsize.__qualname__ == 'getsize' — not covered in any prior os_path spec."
    - "os.path.realpath.__qualname__ == 'realpath' — not covered in any prior os_path spec."
    - "os.path.splitext('file.txt') == ('file', '.txt') — splits basename from extension."
    - "os.path.splitext('archive.tar.gz') == ('archive.tar', '.gz') — only last extension is split."
    - "os.path.splitext('noext') == ('noext', '') — file without extension."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks — islink, getsize, realpath
#
# os_path_extra covers __name__ for join/split/exists/isfile/isdir/isabs/normpath/abspath.
# These three functions are not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant os_path_extra7.islink.name:
  description: "os.path.islink.__name__ == 'islink'"
  category: function_identity
  kind: python_call_eq
  function: islink.__name__.__eq__
  args: ["islink"]
  expected: true

invariant os_path_extra7.getsize.name:
  description: "os.path.getsize.__name__ == 'getsize'"
  category: function_identity
  kind: python_call_eq
  function: getsize.__name__.__eq__
  args: ["getsize"]
  expected: true

invariant os_path_extra7.realpath.name:
  description: "os.path.realpath.__name__ == 'realpath'"
  category: function_identity
  kind: python_call_eq
  function: realpath.__name__.__eq__
  args: ["realpath"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ checks — islink, getsize, realpath
#
# os_path_extra6 covers __qualname__ for join/split/basename/dirname/normpath/abspath
# (table) and exists/isfile/isdir/isabs (standalone). islink/getsize/realpath are new.
# ---------------------------------------------------------------------------

invariant os_path_extra7.islink.qualname:
  description: "os.path.islink.__qualname__ == 'islink'"
  category: qualnames
  kind: python_call_eq
  function: islink.__qualname__.__eq__
  args: ["islink"]
  expected: true

invariant os_path_extra7.getsize.qualname:
  description: "os.path.getsize.__qualname__ == 'getsize'"
  category: qualnames
  kind: python_call_eq
  function: getsize.__qualname__.__eq__
  args: ["getsize"]
  expected: true

invariant os_path_extra7.realpath.qualname:
  description: "os.path.realpath.__qualname__ == 'realpath'"
  category: qualnames
  kind: python_call_eq
  function: realpath.__qualname__.__eq__
  args: ["realpath"]
  expected: true

# ---------------------------------------------------------------------------
# Table: function_identity for islink, getsize, realpath
# ---------------------------------------------------------------------------

table os_path_extra7.function_names:
  kind: python_call_eq
  category: function_identity
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [islink,    islink.__name__.__eq__,    ["islink"],    true]
    - [getsize,   getsize.__name__.__eq__,   ["getsize"],   true]
    - [realpath,  realpath.__name__.__eq__,  ["realpath"],  true]

# ---------------------------------------------------------------------------
# splitext() — behavioral vectors
#
# os_path.zspec.zsdl does not cover splitext(). No prior os_path_extra covers it.
# splitext() splits off the final file extension component.
# ---------------------------------------------------------------------------

invariant os_path_extra7.splitext.simple:
  description: "os.path.splitext('file.txt') == ('file', '.txt')"
  category: splitext
  kind: python_call_eq
  function: splitext
  args: ["file.txt"]
  expected: ["file", ".txt"]

invariant os_path_extra7.splitext.double_ext:
  description: "os.path.splitext('archive.tar.gz') == ('archive.tar', '.gz') — only last extension split"
  category: splitext
  kind: python_call_eq
  function: splitext
  args: ["archive.tar.gz"]
  expected: ["archive.tar", ".gz"]

invariant os_path_extra7.splitext.no_ext:
  description: "os.path.splitext('noext') == ('noext', '') — file without extension"
  category: splitext
  kind: python_call_eq
  function: splitext
  args: ["noext"]
  expected: ["noext", ""]
