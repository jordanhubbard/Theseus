spec: abc_extra370
version: ">=3.9"
backend: python_module(collections.abc)
docs: https://docs.python.org/3/library/collections.abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc ABCs documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Callable derives from object"
    - "AsyncIterator derives from AsyncIterable"
    - "AsyncIterable derives from object"
    - "AsyncGenerator derives from AsyncIterator"
    - "Reversible derives from Iterable"
    - "ByteString is present but deprecated since Python 3.12; it still lives in collections.abc"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra370.abc_names:
  description: "Verify __name__ attribute of collections.abc async and callable ABCs"
  kind: python_call_eq
  category: identity
  id_prefix: abc370n

  columns: [id, function, args, expected]
  rows:
    - [abc370n001, collections.abc.Callable.__name__.__eq__, ["Callable"], true]
    - [abc370n002, collections.abc.AsyncIterator.__name__.__eq__, ["AsyncIterator"], true]
    - [abc370n003, collections.abc.AsyncIterable.__name__.__eq__, ["AsyncIterable"], true]
    - [abc370n004, collections.abc.AsyncGenerator.__name__.__eq__, ["AsyncGenerator"], true]
    - [abc370n005, collections.abc.Reversible.__name__.__eq__, ["Reversible"], true]
    - [abc370n006, collections.abc.ByteString.__name__.__eq__, ["ByteString"], true]

table abc_extra370.abc_modules:
  description: "Verify __module__ attribute of collections.abc async and callable ABCs"
  kind: python_call_eq
  category: identity
  id_prefix: abc370m

  columns: [id, function, args, expected]
  rows:
    - [abc370m001, collections.abc.Callable.__module__.__eq__, ["collections.abc"], true]
    - [abc370m002, collections.abc.AsyncIterator.__module__.__eq__, ["collections.abc"], true]
    - [abc370m003, collections.abc.AsyncIterable.__module__.__eq__, ["collections.abc"], true]
    - [abc370m004, collections.abc.AsyncGenerator.__module__.__eq__, ["collections.abc"], true]
    - [abc370m005, collections.abc.Reversible.__module__.__eq__, ["collections.abc"], true]
    - [abc370m006, collections.abc.ByteString.__module__.__eq__, ["collections.abc"], true]

table abc_extra370.abc_bases:
  description: "Verify __bases__[0].__name__ (first immediate base class name) of collections.abc async and callable ABCs"
  kind: python_call_eq
  category: identity
  id_prefix: abc370b

  columns: [id, function, args, expected]
  rows:
    - ["abc370b001", "collections.abc.Callable.__bases__[0].__name__.__eq__", ["object"], true]
    - ["abc370b002", "collections.abc.AsyncIterator.__bases__[0].__name__.__eq__", ["AsyncIterable"], true]
    - ["abc370b003", "collections.abc.AsyncIterable.__bases__[0].__name__.__eq__", ["object"], true]
    - ["abc370b004", "collections.abc.AsyncGenerator.__bases__[0].__name__.__eq__", ["AsyncIterator"], true]
    - ["abc370b005", "collections.abc.Reversible.__bases__[0].__name__.__eq__", ["Iterable"], true]
