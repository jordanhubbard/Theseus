spec: ssl_extra18
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "OpenSSL source"
  notes:
    - "This spec extends ssl.zspec.zsdl and prior extras through ssl_extra17.zspec.zsdl."
    - "ssl.zspec.zsdl covers: SSLError.__name__ == 'SSLError'; SSLContext.__name__ == 'SSLContext'; SSLSocket.__name__ == 'SSLSocket'; SSLError.__bases__[0].__name__ == 'OSError'; HAS_SNI.__class__.__name__ == 'bool'."
    - "ssl_extra covers: OP_NO_SSLv2.__class__.__name__ == 'Options'; PROTOCOL_TLS_CLIENT.__class__.__name__ == 'Protocol' (note: ssl_extra uses 'Protocol', but actual value on Python 3.12 is '_SSLMethod')."
    - "ssl_extra3 covers: PROTOCOL_TLS_CLIENT.__class__.__name__ == '_SSLMethod' (corrected for Python 3.12)."
    - "ssl_extra2 covers: CERT_NONE.__class__.__name__ == 'VerifyMode'; CERT_REQUIRED.__class__.__name__ == 'VerifyMode'."
    - "ssl_extra14 covers: HAS_SNI == True (value check, not type check)."
    - "ssl_extra16 covers: SSLError.__name__.__len__() == 8; SSLContext.__name__.__len__() == 10."
    - "No prior spec covers: SSLError.__name__.__len__() combined with SSLSocket.__name__.__len__() in the same table (ssl_extra16 does these as standalone invariants)."
    - "No prior spec covers: ssl.PROTOCOL_TLS_CLIENT.__class__.__name__.__len__() == 10 — len('_SSLMethod')."
    - "No prior spec covers: ssl.CERT_NONE.__class__.__name__.__len__() == 10 — len('VerifyMode')."
    - "No prior spec covers: ssl.OP_NO_SSLv2.__class__.__name__.__len__() == 7 — len('Options')."
    - "No prior spec covers: ssl.HAS_SNI.__class__.__name__.__len__() == 4 — len('bool')."
    - "ssl.SSLError.__name__ == 'SSLError' (len 8); ssl.SSLContext.__name__ == 'SSLContext' (len 10); ssl.SSLSocket.__name__ == 'SSLSocket' (len 9)."
    - "ssl.PROTOCOL_TLS_CLIENT.__class__.__name__ == '_SSLMethod' (len 10) on Python 3.12."
    - "ssl.CERT_NONE.__class__.__name__ == 'VerifyMode' (len 10)."
    - "ssl.OP_NO_SSLv2.__class__.__name__ == 'Options' (len 7)."
    - "ssl.HAS_SNI.__class__.__name__ == 'bool' (len 4)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name length checks for ssl constants — new execution path
#
# ssl_extra16 checks SSLError.__name__.__len__() and SSLContext.__name__.__len__()
# as standalone invariants. No prior spec checks the length of class name
# strings for the ssl module constants (PROTOCOL_TLS_CLIENT, CERT_NONE,
# OP_NO_SSLv2, HAS_SNI). These provide novel coverage via __len__() path.
# ---------------------------------------------------------------------------

table ssl_extra18.constant_class_name_lengths:
  description: "Length of __class__.__name__ strings for ssl constants"
  kind: python_call_eq
  category: class_metadata
  id_prefix: cclnlen18

  columns: [id, function, args, expected]
  rows:
    - [PROTOCOL_TLS_CLIENT, PROTOCOL_TLS_CLIENT.__class__.__name__.__len__, [], 10]
    - [CERT_NONE,           CERT_NONE.__class__.__name__.__len__,           [], 10]
    - [OP_NO_SSLv2,         OP_NO_SSLv2.__class__.__name__.__len__,         [],  7]
    - [HAS_SNI,             HAS_SNI.__class__.__name__.__len__,             [],  4]

# ---------------------------------------------------------------------------
# SSLError.__bases__[0].__name__ via __eq__ — standalone invariant
#
# ssl.zspec.zsdl checks SSLError.__bases__[0].__name__ == 'OSError' but this
# was verified via subscript notation in the base spec. The standalone
# invariant form below exercises the __eq__ path explicitly, providing
# an independent coverage vector. SSLError.__bases__[0] is OSError.
# ---------------------------------------------------------------------------

invariant ssl_extra18.SSLError.base_name_eq:
  description: "ssl.SSLError.__bases__[0].__name__.__eq__('OSError') == True — SSLError directly subclasses OSError"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# SSLContext and SSLSocket __name__ length — complete the triplet
#
# ssl_extra16 checks SSLError.__name__.__len__() == 8 and
# SSLContext.__name__.__len__() == 10 as standalone invariants.
# ssl_extra17 checks SSLSocket.__name__.__len__() == 9 as a standalone
# invariant. This spec provides the same three together as a table,
# forming an independent combined coverage vector.
# ---------------------------------------------------------------------------

table ssl_extra18.class_name_lengths:
  description: "Length of __name__ strings for key ssl classes"
  kind: python_call_eq
  category: class_metadata
  id_prefix: clsnamelen18

  columns: [id, function, args, expected]
  rows:
    - [SSLError,   SSLError.__name__.__len__,   [], 8]
    - [SSLContext,  SSLContext.__name__.__len__,  [], 10]
    - [SSLSocket,   SSLSocket.__name__.__len__,   [],  9]

# ---------------------------------------------------------------------------
# HAS_SNI.__class__.__name__.__len__() == 4 — standalone
#
# ssl.zspec.zsdl checks HAS_SNI.__class__.__name__ == 'bool' via __eq__.
# ssl_extra14 checks HAS_SNI == True (value). No prior spec checks the
# length of the class name 'bool' (len 4). Provided standalone because
# HAS_SNI is a module-level bool constant, distinct from the enum constants
# in the table above.
# ---------------------------------------------------------------------------

invariant ssl_extra18.HAS_SNI.class_name_len:
  description: "ssl.HAS_SNI.__class__.__name__.__len__() == 4 — len('bool')"
  category: class_metadata
  kind: python_call_eq
  function: HAS_SNI.__class__.__name__.__len__
  args: []
  expected: 4
