invariant inspect_extra82.getdoc_co_name:
  description: "inspect.getdoc.__code__.co_name.__eq__('getdoc') == True — getdoc code object name is 'getdoc'; wave 246 inspect getdoc code attrs; new to extra82"
  kind: python_call_eq
  function: getdoc.__code__.co_name.__eq__
  args: ["getdoc"]
  expected: true

invariant inspect_extra82.getfile_co_argcount:
  description: "inspect.getfile.__code__.co_argcount.__eq__(1) == True — getfile(object) has 1 positional arg; wave 246 inspect getfile code attrs; new to extra82"
