  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra82

  columns: [id, function, args, expected, description]
  rows:
    - [getmodule_code_co_name_eq_getmodule,
       getmodule.__code__.co_name.__eq__,
       ["getmodule"],
       true,
       "inspect.getmodule.__code__.co_name.__eq__('getmodule') == True — getmodule is a pure-Python function defined in Lib/inspect.py; its code object co_name records the function name 'getmodule' (9 chars); str.__eq__('getmodule') returns True; no prior inspect spec checks getmodule.__code__.co_name via inspectextra82; new to extra82"]
    - [getmodule_code_co_argcount_eq_2,
       getmodule.__code__.co_argcount.__eq__,
       [2],
       true,
       "inspect.getmodule.__code__.co_argcount.__eq__(2) == True — getmodule(object, _filename=None) takes two positional-or-keyword arguments: object and _filename; the code object's co_argcount is 2; int.__eq__(2) returns True; no prior inspect spec checks getmodule.__code__.co_argcount via inspectextra82; new to extra82"]
    - [getmro_code_co_name_eq_getmro,
       getmro.__code__.co_name.__eq__,
       ["getmro"],
       true,
       "inspect.getmro.__code__.co_name.__eq__('getmro') == True — getmro is a pure-Python function defined in Lib/inspect.py; its code object co_name records the function name 'getmro' (6 chars); str.__eq__('getmro') returns True; no prior inspect spec checks getmro.__code__.co_name via inspectextra82; new to extra82"]
    - [getmro_code_co_argcount_eq_1,
       getmro.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.getmro.__code__.co_argcount.__eq__(1) == True — getmro(cls) takes exactly one positional argument: cls; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks getmro.__code__.co_argcount via inspectextra82; new to extra82"]

