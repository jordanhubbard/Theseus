spec: inspect_extra82
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra81

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra81.zspec.zsdl."
    - "This spec covers: inspect getdoc/getfile/getmodule/getmro code attributes and isframe/iscode/isabstract/isgenerator code attributes (Wave 246)."
    - "inspect.getdoc.__code__.co_name == 'getdoc' — getdoc is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getdoc.__code__.co_argcount == 1 — getdoc(object) takes 1 positional argument. Verified with Python 3.14.3."
    - "inspect.getfile.__code__.co_name == 'getfile' — getfile is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getfile.__code__.co_argcount == 1 — getfile(object) takes 1 positional argument. Verified with Python 3.14.3."
    - "inspect.getmodule.__code__.co_name == 'getmodule' — getmodule is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getmodule.__code__.co_argcount == 2 — getmodule(object, _filename=None) takes 2 positional-or-keyword arguments. Verified with Python 3.14.3."
    - "inspect.getmro.__code__.co_name == 'getmro' — getmro is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getmro.__code__.co_argcount == 1 — getmro(cls) takes 1 positional argument. Verified with Python 3.14.3."
    - "inspect.isframe.__code__.co_name == 'isframe' — isframe is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isframe.__code__.co_argcount == 1 — isframe(object) takes 1 positional argument. Verified with Python 3.14.3."
    - "inspect.iscode.__code__.co_name == 'iscode' — iscode is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.iscode.__code__.co_argcount == 1 — iscode(object) takes 1 positional argument. Verified with Python 3.14.3."
    - "inspect.isabstract.__code__.co_name == 'isabstract' — isabstract is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isabstract.__code__.co_argcount == 1 — isabstract(object) takes 1 positional argument. Verified with Python 3.14.3."
    - "inspect.isgenerator.__code__.co_name == 'isgenerator' — isgenerator is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isgenerator.__code__.co_argcount == 1 — isgenerator(object) takes 1 positional argument. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# getdoc and getfile code attributes — extra82
#
# Wave 246 theme: inspect.getdoc/getfile code object attributes.
#
# inspect.getdoc.__code__.co_name     == 'getdoc'
# inspect.getdoc.__code__.co_argcount == 1
# inspect.getfile.__code__.co_name    == 'getfile'
# inspect.getfile.__code__.co_argcount == 1
#
# No prior inspect spec checks getdoc/getfile code attrs via inspectextra82. New to extra82.
# ---------------------------------------------------------------------------

table inspect_extra82.getdoc_getfile_code:
  description: "getdoc.__code__.co_name=='getdoc', co_argcount==1; getfile.__code__.co_name=='getfile', co_argcount==1; wave 246 inspect getdoc/getfile code attrs; new to extra82"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra82

  columns: [id, function, args, expected, description]
  rows:
    - [getdoc_code_co_name_eq_getdoc,
       getdoc.__code__.co_name.__eq__,
       ["getdoc"],
       true,
       "inspect.getdoc.__code__.co_name.__eq__('getdoc') == True — getdoc is a pure-Python function defined in Lib/inspect.py; its code object co_name records the function name 'getdoc' (6 chars); str.__eq__('getdoc') returns True; no prior inspect spec checks getdoc.__code__.co_name via inspectextra82; new to extra82"]
    - [getdoc_code_co_argcount_eq_1,
       getdoc.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.getdoc.__code__.co_argcount.__eq__(1) == True — getdoc(object) takes exactly one positional argument: object; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks getdoc.__code__.co_argcount via inspectextra82; new to extra82"]
    - [getfile_code_co_name_eq_getfile,
       getfile.__code__.co_name.__eq__,
       ["getfile"],
       true,
       "inspect.getfile.__code__.co_name.__eq__('getfile') == True — getfile is a pure-Python function defined in Lib/inspect.py; its code object co_name records the function name 'getfile' (7 chars); str.__eq__('getfile') returns True; no prior inspect spec checks getfile.__code__.co_name via inspectextra82; new to extra82"]
    - [getfile_code_co_argcount_eq_1,
       getfile.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.getfile.__code__.co_argcount.__eq__(1) == True — getfile(object) takes exactly one positional argument: object; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks getfile.__code__.co_argcount via inspectextra82; new to extra82"]

