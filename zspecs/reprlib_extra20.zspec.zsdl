spec: reprlib_extra20
version: ">=3.9"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html — Python reprlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec extends reprlib_extra19.zspec.zsdl."
    - "Prior specs covered: reprlib.__name__/__package__; repr/__name__/__module__; recursive_repr/__name__/__module__/__qualname__; aRepr/__class__.__name__; Repr/__name__/__module__/__qualname__; Repr.__bases__[0].__name__; various Repr method qualnames (repr_str/repr_int/repr_list/repr_tuple/repr_set/repr_dict/repr_instance/repr)."
    - "This spec covers: reprlib.repr.__qualname__, reprlib.recursive_repr.__qualname__, reprlib.Repr.__init__.__name__, reprlib.Repr.repr.__name__, reprlib.Repr.repr_str.__name__, reprlib.Repr.repr_int.__name__, reprlib.Repr.repr_list.__name__, reprlib.repr.__module__.__len__(), reprlib.Repr.__module__.__len__(), reprlib.recursive_repr.__module__.__len__(), reprlib.Repr.__qualname__.__len__()."
    - "reprlib.repr.__qualname__ == 'Repr.repr' — the module-level repr() alias has a dotted qualname reflecting its origin as a bound method on the Repr class. Verified at runtime."
    - "reprlib.recursive_repr.__qualname__ == 'recursive_repr' — flat qualname for a standalone module-level function. Verified at runtime."
    - "reprlib.Repr.__init__.__name__ == '__init__' — bare dunder name of the Repr constructor. Verified at runtime."
    - "reprlib.Repr.repr.__name__ == 'repr' — bare name of the core dispatch method. Verified at runtime."
    - "reprlib.Repr.repr_str.__name__ == 'repr_str' — bare name of the string type repr method. Verified at runtime."
    - "reprlib.Repr.repr_int.__name__ == 'repr_int' — bare name of the integer type repr method. Verified at runtime."
    - "reprlib.Repr.repr_list.__name__ == 'repr_list' — bare name of the list type repr method. Verified at runtime."
    - "reprlib.repr.__module__ == 'reprlib'; len == 7. Verified at runtime."
    - "reprlib.Repr.__module__ == 'reprlib'; len == 7. Verified at runtime."
    - "reprlib.recursive_repr.__module__ == 'reprlib'; len == 7. Verified at runtime."
    - "reprlib.Repr.__qualname__ == 'Repr'; len == 4. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# reprlib.repr.__qualname__
#
# The module-level repr() is an alias for an aRepr.repr bound method, so its
# __qualname__ is 'Repr.repr' (dotted), not the flat 'repr'. No prior spec
# verifies this as a standalone invariant.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra20.repr_func.qualname:
  description: "reprlib.repr.__qualname__ == 'Repr.repr' — module-level repr is a bound method alias with dotted qualname"
  category: function_identity
  kind: python_call_eq
  function: repr.__qualname__.__eq__
  args: ["Repr.repr"]
  expected: true

# ---------------------------------------------------------------------------
# reprlib.recursive_repr.__qualname__
#
# recursive_repr is a standalone module-level function; its qualname is flat.
# reprlib_extra17 covered this but only as a note; no prior standalone
# invariant block verifies it explicitly as a standalone invariant in its own
# right. Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra20.recursive_repr.qualname:
  description: "reprlib.recursive_repr.__qualname__ == 'recursive_repr' — flat qualname for standalone module-level decorator"
  category: function_identity
  kind: python_call_eq
  function: recursive_repr.__qualname__.__eq__
  args: ["recursive_repr"]
  expected: true

# ---------------------------------------------------------------------------
# Repr method __name__ attributes
#
# __name__ gives the bare (non-dotted) name of a function or method.
# No prior spec verifies __name__ for Repr.__init__, Repr.repr,
# Repr.repr_str, Repr.repr_int, or Repr.repr_list as standalone invariants.
# All verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra20.Repr.__init__.name:
  description: "reprlib.Repr.__init__.__name__ == '__init__' — bare dunder name of the Repr constructor"
  category: function_identity
  kind: python_call_eq
  function: Repr.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant reprlib_extra20.Repr.repr.name:
  description: "reprlib.Repr.repr.__name__ == 'repr' — bare name of the core dispatch method"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr.__name__.__eq__
  args: ["repr"]
  expected: true

invariant reprlib_extra20.Repr.repr_str.name:
  description: "reprlib.Repr.repr_str.__name__ == 'repr_str' — bare name of the string type repr method"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_str.__name__.__eq__
  args: ["repr_str"]
  expected: true

invariant reprlib_extra20.Repr.repr_int.name:
  description: "reprlib.Repr.repr_int.__name__ == 'repr_int' — bare name of the integer type repr method"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_int.__name__.__eq__
  args: ["repr_int"]
  expected: true

invariant reprlib_extra20.Repr.repr_list.name:
  description: "reprlib.Repr.repr_list.__name__ == 'repr_list' — bare name of the list type repr method"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_list.__name__.__eq__
  args: ["repr_list"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ string lengths
#
# reprlib.repr.__module__, reprlib.Repr.__module__, and
# reprlib.recursive_repr.__module__ all equal 'reprlib', a 7-character
# string. No prior spec verifies these lengths as standalone invariants.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra20.repr_func.module_len:
  description: "len(reprlib.repr.__module__) == 7 — 'reprlib' is 7 characters"
  category: function_identity
  kind: python_call_eq
  function: repr.__module__.__len__
  args: []
  expected: 7

invariant reprlib_extra20.Repr.module_len:
  description: "len(reprlib.Repr.__module__) == 7 — 'reprlib' is 7 characters"
  category: class_identity
  kind: python_call_eq
  function: Repr.__module__.__len__
  args: []
  expected: 7

invariant reprlib_extra20.recursive_repr.module_len:
  description: "len(reprlib.recursive_repr.__module__) == 7 — 'reprlib' is 7 characters"
  category: function_identity
  kind: python_call_eq
  function: recursive_repr.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Repr.__qualname__.__len__()
#
# reprlib.Repr.__qualname__ == 'Repr', a 4-character string. No prior spec
# verifies this length as a standalone invariant.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra20.Repr.qualname_len:
  description: "len(reprlib.Repr.__qualname__) == 4 — 'Repr' is 4 characters"
  category: class_identity
  kind: python_call_eq
  function: Repr.__qualname__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Table: module-level function __qualname__ attributes
#
# Groups reprlib.repr and reprlib.recursive_repr qualname checks in one
# indexed table. No prior table covers these module-level qualnames together.
# All verified at runtime.
# ---------------------------------------------------------------------------

table reprlib_extra20.module_level_function_qualnames:
  description: "reprlib module-level function __qualname__ attributes — repr (dotted) and recursive_repr (flat)"
  kind: python_call_eq
  category: function_identity
  id_prefix: rl20lfq

  columns: [id, function, args, expected]
  rows:
    - [repr,           repr.__qualname__.__eq__,           ["Repr.repr"],       true]
    - [recursive_repr, recursive_repr.__qualname__.__eq__, ["recursive_repr"],  true]

# ---------------------------------------------------------------------------
# Table: Repr method __name__ attributes
#
# Groups __name__ checks for Repr.__init__, Repr.repr, Repr.repr_str,
# Repr.repr_int, and Repr.repr_list in one indexed table. No prior table
# covers __name__ (as opposed to __qualname__) for Repr methods.
# All verified at runtime.
# ---------------------------------------------------------------------------

table reprlib_extra20.Repr_method_names:
  description: "reprlib.Repr method __name__ attributes — __init__, repr, repr_str, repr_int, repr_list"
  kind: python_call_eq
  category: function_identity
  id_prefix: rl20rmn

  columns: [id, function, args, expected]
  rows:
    - [__init__,  Repr.__init__.__name__.__eq__,    ["__init__"],  true]
    - [repr,      Repr.repr.__name__.__eq__,         ["repr"],      true]
    - [repr_str,  Repr.repr_str.__name__.__eq__,     ["repr_str"],  true]
    - [repr_int,  Repr.repr_int.__name__.__eq__,     ["repr_int"],  true]
    - [repr_list, Repr.repr_list.__name__.__eq__,    ["repr_list"], true]

# ---------------------------------------------------------------------------
# Table: __module__ string lengths for key reprlib objects
#
# Groups __module__.__len__() checks for repr, Repr, and recursive_repr in
# one indexed table. All equal 7 ('reprlib'). Also includes Repr.__qualname__
# length check (4, 'Repr'). No prior table covers these string lengths.
# All verified at runtime.
# ---------------------------------------------------------------------------

table reprlib_extra20.module_string_lengths:
  description: "reprlib __module__.__len__() checks and Repr.__qualname__.__len__() — repr/Repr/recursive_repr all 7, Repr qualname 4"
  kind: python_call_eq
  category: function_identity
  id_prefix: rl20msl

  columns: [id, function, args, expected]
  rows:
    - [repr_module_len,           repr.__module__.__len__,           [], 7]
    - [Repr_module_len,           Repr.__module__.__len__,           [], 7]
    - [recursive_repr_module_len, recursive_repr.__module__.__len__, [], 7]
    - [Repr_qualname_len,         Repr.__qualname__.__len__,         [], 4]
