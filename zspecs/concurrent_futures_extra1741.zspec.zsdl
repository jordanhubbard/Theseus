spec: concurrent_futures_extra1741
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 563 (_extra1741): descriptor protocol dict-presence checks."
    - "Theme: which concurrent.futures stdlib types define __get__, __set__, __delete__, __set_name__ in their own __dict__."
    - "All concurrent.futures types are pure Python executor/future classes with no descriptor protocol semantics."
    - "concurrent.futures.Future: represents an eventual computation result; no descriptor methods in own __dict__ -> all False."
    - "concurrent.futures.Executor: abstract base class for executor implementations; no descriptor methods in own __dict__ -> all False."
    - "concurrent.futures.ThreadPoolExecutor: thread-pool executor; no descriptor methods in own __dict__ -> all False."
    - "concurrent.futures.ProcessPoolExecutor: process-pool executor; no descriptor methods in own __dict__ -> all False."
    - "Rationale: executor/future types model async work submission and result retrieval, not attribute access protocols."
    - "Cross-check: __get__ is the hook that makes a class a non-data descriptor (like a function). None of the concurrent.futures types are intended to sit in a class body and intercept attribute access."
    - "Cross-check: __set_name__ is called by type.__new__ when a descriptor is stored as a class body attribute at class creation time. Executor types are instantiated at runtime, not at class creation time."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: descriptor protocol dict-presence checks (__get__, __set__, __delete__)
#
# Wave 563 theme: do concurrent.futures types define descriptor dunders in
# their own __dict__? concurrent.futures.Future tracks the state and result of
# an asynchronous computation submitted to an executor. Executor and its
# subclasses manage pools of threads or processes. None of these classes are
# designed to be used as descriptors (i.e., to be stored as class attributes
# and intercept attribute access via __get__, __set__, or __delete__). All
# checks return False.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1741.descriptor_protocol:
  description: "concurrent.futures types: __get__, __set__, __delete__ dict-presence checks (all False — no descriptor protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1741

  columns: [id, function, args, expected]
  rows:
    - ["cf1741001", "concurrent.futures.Future.__dict__.__contains__",              ["__get__"],    false]
    - ["cf1741002", "concurrent.futures.Future.__dict__.__contains__",              ["__set__"],    false]
    - ["cf1741003", "concurrent.futures.Future.__dict__.__contains__",              ["__delete__"], false]
    - ["cf1741004", "concurrent.futures.Executor.__dict__.__contains__",            ["__get__"],    false]
    - ["cf1741005", "concurrent.futures.Executor.__dict__.__contains__",            ["__set__"],    false]
    - ["cf1741006", "concurrent.futures.Executor.__dict__.__contains__",            ["__delete__"], false]
    - ["cf1741007", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__get__"],    false]
    - ["cf1741008", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__set__"],    false]
    - ["cf1741009", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__delete__"], false]
    - ["cf1741010", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__get__"],    false]

# ---------------------------------------------------------------------------
# Table 2: __set_name__ dict-presence cross-checks
#
# Wave 563 cross-check: __set_name__ is invoked by the metaclass immediately
# after a descriptor is bound to a class attribute (PEP 487). Since none of
# the concurrent.futures public types implement the descriptor protocol at all,
# none of them implement __set_name__ either. This table completes coverage of
# the fourth descriptor dunder for all four public types and adds remaining
# __set__ and __delete__ checks for ProcessPoolExecutor.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1741.set_name_protocol:
  description: "concurrent.futures types: __set_name__ dict-presence cross-checks and __set__/__delete__ extension (all False)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1741

  columns: [id, function, args, expected]
  rows:
    - ["cf1741011", "concurrent.futures.Future.__dict__.__contains__",              ["__set_name__"], false]
    - ["cf1741012", "concurrent.futures.Executor.__dict__.__contains__",            ["__set_name__"], false]
    - ["cf1741013", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__set_name__"], false]
    - ["cf1741014", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__set_name__"], false]
    - ["cf1741015", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__set__"],      false]
    - ["cf1741016", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__delete__"],   false]
    - ["cf1741017", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__set_name__"], false]
    - ["cf1741018", "concurrent.futures.Future.__dict__.__contains__",              ["__get__"],      false]
    - ["cf1741019", "concurrent.futures.Executor.__dict__.__contains__",            ["__get__"],      false]
    - ["cf1741020", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__get__"],      false]
    - ["cf1741021", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__get__"],      false]
    - ["cf1741022", "concurrent.futures.Future.__dict__.__contains__",              ["__set__"],      false]
    - ["cf1741023", "concurrent.futures.Executor.__dict__.__contains__",            ["__set__"],      false]
    - ["cf1741024", "concurrent.futures.Future.__dict__.__contains__",              ["__delete__"],   false]
    - ["cf1741025", "concurrent.futures.Executor.__dict__.__contains__",            ["__delete__"],   false]
