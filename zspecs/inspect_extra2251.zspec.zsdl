    - ["in2251015", "inspect.Parameter.__dict__.__contains__", ["__globals__"], false]
    - ["in2251016", "inspect.Signature.__dict__.__contains__", ["__code__"], false]
    - ["in2251017", "inspect.Signature.__dict__.__contains__", ["__globals__"], false]
    - ["in2251018", "inspect.BoundArguments.__dict__.__contains__", ["__code__"], false]
    - ["in2251019", "inspect.BoundArguments.__dict__.__contains__", ["__globals__"], false]

