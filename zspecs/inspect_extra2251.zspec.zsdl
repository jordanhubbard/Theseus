    - ["in2251029", "inspect.Signature.__dict__.__contains__", ["__builtins__"], false]
    - ["in2251030", "inspect.BoundArguments.__dict__.__contains__", ["__annotations__"], false]
    - ["in2251031", "inspect.BoundArguments.__dict__.__contains__", ["__builtins__"], false]
