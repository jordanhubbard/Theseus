spec: inspect_extra2251
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave extra2251: callable protocol and function-attribute dict-presence checks — __call__, __code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__ in inspect class __dict__."
    - "inspect.Parameter, inspect.Signature, inspect.BoundArguments are pure data-holder classes; none define __call__ in their own __dict__."
    - "inspect.ForwardRef is a special case: it defines __code__ and __globals__ as member_descriptor slots in its class __dict__ (True), but does NOT define __call__, __defaults__, __kwdefaults__, __annotations__, or __builtins__."
    - "inspect.attrgetter defines __call__ in its class __dict__ (True) — it is imported from operator and exposed via inspect internals; instances of attrgetter are callable."
    - "inspect.make_weakref defines __call__ in its class __dict__ (True) — it is a C-level callable type accessible from inspect internals."
    - "inspect.BlockFinder, inspect.FullArgSpec, inspect.ArgInfo, inspect.Attribute, inspect.BoundArguments, inspect.Signature, inspect.Parameter, inspect.ClosureVars do NOT define __call__."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table inspect_extra2251.call_protocol_data_classes:
  description: "inspect.Parameter, inspect.Signature, inspect.BoundArguments, inspect.FullArgSpec, inspect.ArgInfo, inspect.Attribute do NOT define __call__ in their __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2251

  columns: [id, function, args, expected]
  rows:
    - ["in2251001", "inspect.Parameter.__dict__.__contains__", ["__call__"], false]
    - ["in2251002", "inspect.Signature.__dict__.__contains__", ["__call__"], false]
    - ["in2251003", "inspect.BoundArguments.__dict__.__contains__", ["__call__"], false]
    - ["in2251004", "inspect.FullArgSpec.__dict__.__contains__", ["__call__"], false]
    - ["in2251005", "inspect.ArgInfo.__dict__.__contains__", ["__call__"], false]
    - ["in2251006", "inspect.Attribute.__dict__.__contains__", ["__call__"], false]

table inspect_extra2251.call_protocol_exception_and_internal_classes:
  description: "inspect.ClassFoundException, inspect.EndOfBlock, inspect.BlockFinder, inspect.ClosureVars do NOT define __call__; inspect.ForwardRef also does not define __call__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2251

  columns: [id, function, args, expected]
  rows:
    - ["in2251007", "inspect.ClassFoundException.__dict__.__contains__", ["__call__"], false]
    - ["in2251008", "inspect.EndOfBlock.__dict__.__contains__", ["__call__"], false]
    - ["in2251009", "inspect.BlockFinder.__dict__.__contains__", ["__call__"], false]
    - ["in2251010", "inspect.ClosureVars.__dict__.__contains__", ["__call__"], false]
    - ["in2251011", "inspect.ForwardRef.__dict__.__contains__", ["__call__"], false]

table inspect_extra2251.forwardref_code_globals_true:
  description: "inspect.ForwardRef defines __code__ and __globals__ as member_descriptor slots in its class __dict__ (both True)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2251

  columns: [id, function, args, expected]
  rows:
    - ["in2251012", "inspect.ForwardRef.__dict__.__contains__", ["__code__"], true]
    - ["in2251013", "inspect.ForwardRef.__dict__.__contains__", ["__globals__"], true]

table inspect_extra2251.code_globals_absent_other_classes:
  description: "inspect.Parameter, inspect.Signature, inspect.BoundArguments do NOT define __code__ or __globals__ in their __dict__"
