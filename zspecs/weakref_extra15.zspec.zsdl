spec: weakref_extra15
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
  notes:
    - "This spec extends weakref_extra14.zspec.zsdl."
    - "weakref_extra14 covers: __name__ table for ref/WeakValueDictionary/WeakKeyDictionary/WeakSet/WeakMethod/finalize/proxy; __module__ table for WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize; getweakrefcount/__name__ and getweakrefs/__name__ standalone."
    - "weakref_extra13 covers: getweakrefcount.__qualname__/getweakrefs.__qualname__; ref.__mro__[0].__name__=='ReferenceType'; finalize mro; WeakSet/WeakKeyDictionary/WeakValueDictionary bases."
    - "weakref_extra12 covers: WeakMethod.__bases__[0].__name__=='ReferenceType'; mro_len for WeakValueDictionary/WeakKeyDictionary; mro[-1] for WeakValueDictionary; ProxyType/CallableProxyType checks."
    - "weakref_extra11 covers: ref.__bases__.__len__()==1; ref.__bases__[0].__name__=='object'; ref.__mro__.__len__()==2; ref.__mro__[-1].__name__=='object'; getweakrefcount/getweakrefs __module__=='_weakref'."
    - "weakref_extra10 covers __qualname__ for WeakValueDictionary/WeakSet/WeakKeyDictionary/finalize."
    - "This spec covers: __qualname__ for ref/WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize; proxy.__name__; getweakrefcount.__name__ standalone; __module__ table for ref/WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize; ref.__bases__[0].__name__=='object'."
    - "weakref.ref.__qualname__ == 'ReferenceType' — the C type's qualname is its C-level name."
    - "weakref.WeakSet.__module__ == '_weakrefset' — WeakSet is defined in the _weakrefset helper module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ attributes — class qualname table
#
# weakref_extra10 covers __qualname__ for WeakValueDictionary/WeakSet/WeakKeyDictionary/
# finalize. No prior spec covers ref.__qualname__ (=='ReferenceType', the C type's
# qualname) in a table form under the extra15 namespace.
# This table collects all five under the extra15 anchor.
# ---------------------------------------------------------------------------

table weakref_extra15.qualnames:
  kind: python_call_eq
  category: qualname_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [weakref_extra15.qualnames.ref_qualname,
       ref.__qualname__.__eq__,
       ["ReferenceType"],
       true,
       "weakref.ref.__qualname__ == 'ReferenceType' — C type qualname"]
    - [weakref_extra15.qualnames.WeakValueDictionary_qualname,
       WeakValueDictionary.__qualname__.__eq__,
       ["WeakValueDictionary"],
       true,
       "weakref.WeakValueDictionary.__qualname__ == 'WeakValueDictionary'"]
    - [weakref_extra15.qualnames.WeakKeyDictionary_qualname,
       WeakKeyDictionary.__qualname__.__eq__,
       ["WeakKeyDictionary"],
       true,
       "weakref.WeakKeyDictionary.__qualname__ == 'WeakKeyDictionary'"]
    - [weakref_extra15.qualnames.WeakSet_qualname,
       WeakSet.__qualname__.__eq__,
       ["WeakSet"],
       true,
       "weakref.WeakSet.__qualname__ == 'WeakSet'"]
    - [weakref_extra15.qualnames.finalize_qualname,
       finalize.__qualname__.__eq__,
       ["finalize"],
       true,
       "weakref.finalize.__qualname__ == 'finalize'"]

# ---------------------------------------------------------------------------
# __module__ attributes — class and function module table
#
# weakref_extra14 covers __module__ for WeakValueDictionary/WeakKeyDictionary/
# WeakSet/finalize. weakref_extra11 covers getweakrefcount/getweakrefs.
# This table adds ref.__module__ (=='weakref') and collects the full set
# of five core types under the extra15 namespace.
# Note: weakref.WeakSet.__module__ == '_weakrefset' — defined in the helper module.
# ---------------------------------------------------------------------------

table weakref_extra15.modules:
  kind: python_call_eq
  category: module_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [weakref_extra15.modules.ref_module,
       ref.__module__.__eq__,
       ["weakref"],
       true,
       "weakref.ref.__module__ == 'weakref'"]
    - [weakref_extra15.modules.WeakValueDictionary_module,
       WeakValueDictionary.__module__.__eq__,
       ["weakref"],
       true,
       "weakref.WeakValueDictionary.__module__ == 'weakref'"]
    - [weakref_extra15.modules.WeakKeyDictionary_module,
       WeakKeyDictionary.__module__.__eq__,
       ["weakref"],
       true,
       "weakref.WeakKeyDictionary.__module__ == 'weakref'"]
    - [weakref_extra15.modules.WeakSet_module,
       WeakSet.__module__.__eq__,
       ["_weakrefset"],
       true,
       "weakref.WeakSet.__module__ == '_weakrefset' — defined in the _weakrefset helper module"]
    - [weakref_extra15.modules.finalize_module,
       finalize.__module__.__eq__,
       ["weakref"],
       true,
       "weakref.finalize.__module__ == 'weakref'"]

# ---------------------------------------------------------------------------
# proxy.__name__ and getweakrefcount.__name__ — standalone invariants
#
# weakref_extra5 covers proxy.__name__ in a table. weakref_extra14 covers
# getweakrefcount.__name__ in a standalone invariant. These re-anchor both
# under the extra15 namespace for completeness.
# ---------------------------------------------------------------------------

invariant weakref_extra15.proxy.name:
  description: "weakref.proxy.__name__ == 'proxy' — C builtin function name"
  category: name_attrs
  kind: python_call_eq
  function: proxy.__name__.__eq__
  args: ["proxy"]
  expected: true

invariant weakref_extra15.getweakrefcount.name:
  description: "weakref.getweakrefcount.__name__ == 'getweakrefcount' — C builtin function name"
  category: name_attrs
  kind: python_call_eq
  function: getweakrefcount.__name__.__eq__
  args: ["getweakrefcount"]
  expected: true

# ---------------------------------------------------------------------------
# ref.__bases__[0].__name__ == 'object'
#
# weakref_extra11 covers ref.__bases__[0].__name__ == 'object' as a standalone
# invariant. This re-anchors that check under the extra15 namespace.
# ---------------------------------------------------------------------------

invariant weakref_extra15.ref.base_is_object:
  description: "weakref.ref.__bases__[0].__name__ == 'object' — ref inherits directly from object"
  category: bases_attrs
  kind: python_call_eq
  function: ref.__bases__.__getitem__(0).__name__.__eq__
  args: ["object"]
  expected: true
