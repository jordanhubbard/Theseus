spec: uuid_extra120
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra119.zspec.zsdl — covers UUID property fget.__code__.co_consts lengths for hex/bytes/bytes_le/fields/version/urn/variant/time (table + invariants)."
    - "uuid_extra118.zspec.zsdl — covers UUID.__int__/__gt__/__le__/__ge__ __qualname__ equality and __len__() / UUID.__int__/__gt__/__le__/__ge__ __code__.co_argcount (table + invariants)."
    - "uuid_extra112.zspec.zsdl — covers UUID.__dict__.__class__.__module__.__eq__('builtins') / UUID.__dict__.__class__.__module__.__len__()==8 / UUID.__weakref__ class module and name lengths (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__str__/__repr__/__eq__/__hash__/__lt__ __qualname__ equality and __len__() / UUID.__str__/__repr__/__eq__/__hash__ __class__.__name__=='function' (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant/clock_seq_hi_variant (table + invariants)."
    - "uuid_extra85.zspec.zsdl — covers UUID.__dict__.__class__.__name__.__eq__('mappingproxy') / UUID.__dict__.__contains__('__setattr__') / SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy') (table + invariants)."
    - "uuid_extra61.zspec.zsdl — covers UUID.__dict__.__contains__('__init__'/'__repr__'/'__str__'/'__hash__'/'__eq__') (table + invariants)."
    - "uuid_extra45.zspec.zsdl — covers UUID.__dict__.__class__.__name__.__eq__('mappingproxy') / UUID.__dict__.__class__.__qualname__.__eq__('mappingproxy') (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in earlier uuid specs."
    - "Wave 301 theme: UUID.__dict__ extended key presence — clock_seq/time_hi_version/slots/module/doc/getstate/setstate/weakref keys and UUID.__dict__.__len__()==37."
    - "uuid.UUID.__dict__.__contains__('clock_seq') == True. UUID defines the clock_seq property in Lib/uuid.py; it is present in UUID.__dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('time_hi_version') == True. UUID defines the time_hi_version property in Lib/uuid.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__slots__') == True. UUID uses __slots__ = ('int', 'is_safe', '__weakref__') for memory efficiency. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__module__') == True. UUID stores __module__ in its class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__doc__') == True. UUID has a docstring stored in its class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__getstate__') == True. UUID defines __getstate__ in Lib/uuid.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__setstate__') == True. UUID defines __setstate__ in Lib/uuid.py for pickling support. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__weakref__') == True. UUID.__weakref__ is a getset_descriptor in UUID.__dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__len__() == 37. The UUID class __dict__ mappingproxy contains exactly 37 keys. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Prior specs anchor many UUID.__dict__ keys: hex/bytes/bytes_le/fields/variant/version/urn/time (property axis, extra97); __init__/__repr__/__str__/__hash__/__eq__ (dunder methods, extra61); __setattr__ (extra85); __int__/__gt__/__le__/__ge__ (comparison operators, extra118). This spec anchors the remaining uncovered keys: clock_seq, time_hi_version, __slots__, __module__, __doc__, __getstate__, __setstate__, __weakref__, and the total count (__len__()==37)."
    - "Note: clock_seq and time_hi_version are UUID time-based sub-field properties defined in Lib/uuid.py. time_hi_version encodes the top 12 bits of the 60-bit timestamp and the 4-bit version field. clock_seq encodes the 14-bit clock sequence used to avoid duplicates."
    - "Note: UUID.__dict__.__len__()==37 reflects the total number of class namespace entries including all properties, dunder methods, class attributes, and __slots__/__module__/__doc__. No prior uuid spec anchors UUID.__dict__.__len__() as an integer count."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('clock_seq') == True
# uuid.UUID.__dict__.__contains__('time_hi_version') == True
# uuid.UUID.__dict__.__contains__('__slots__') == True
# uuid.UUID.__dict__.__contains__('__module__') == True
#
# Wave 301 theme: UUID.__dict__ extended key presence (first group).
#
# clock_seq and time_hi_version are time-based UUID sub-field properties defined
# in Lib/uuid.py. __slots__ stores the tuple ('int', 'is_safe', '__weakref__').
# __module__ is the class's module name attribute. All four are present in
# UUID.__dict__. Prior specs anchor hex/bytes/bytes_le/fields/variant/version etc.
# (extra97) and __init__/__repr__/__str__/__hash__/__eq__ (extra61). No prior
# uuid spec anchors clock_seq, time_hi_version, __slots__, or __module__ in
# UUID.__dict__ under uuiddict120. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra120.UUID_dict_time_fields:
  description: "UUID.__dict__.__contains__('clock_seq')==True / UUID.__dict__.__contains__('time_hi_version')==True / UUID.__dict__.__contains__('__slots__')==True / UUID.__dict__.__contains__('__module__')==True — clock_seq and time_hi_version are time-based sub-field properties in Lib/uuid.py; __slots__ stores ('int', 'is_safe', '__weakref__') for memory efficiency; __module__ is stored in class __dict__; extra97 anchors property qualnames; extra61 anchors dunder method keys; first uuiddict120 anchor for these four keys"
  kind: python_call_eq
  category: dict_contents
  id_prefix: uuiddict120

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_clock_seq,      "UUID.__dict__.__contains__",  ["clock_seq"],       true, "UUID.__dict__.__contains__('clock_seq') is True; clock_seq is the 14-bit time-based clock sequence property defined in Lib/uuid.py"]
    - [dict_has_time_hi_ver,    "UUID.__dict__.__contains__",  ["time_hi_version"], true, "UUID.__dict__.__contains__('time_hi_version') is True; time_hi_version encodes the top 12 bits of the timestamp and the 4-bit version field"]
    - [dict_has_slots,          "UUID.__dict__.__contains__",  ["__slots__"],       true, "UUID.__dict__.__contains__('__slots__') is True; UUID uses __slots__ = ('int', 'is_safe', '__weakref__') for memory efficiency"]
    - [dict_has_module,         "UUID.__dict__.__contains__",  ["__module__"],      true, "UUID.__dict__.__contains__('__module__') is True; __module__ is the class's module name attribute stored in the class __dict__"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__doc__') == True
# uuid.UUID.__dict__.__contains__('__getstate__') == True
# uuid.UUID.__dict__.__contains__('__setstate__') == True
# uuid.UUID.__dict__.__contains__('__weakref__') == True
#
# Wave 301 theme: UUID.__dict__ extended key presence (second group).
#
# __doc__ is UUID's class docstring. __getstate__ and __setstate__ are pickle
# protocol methods defined in Lib/uuid.py. __weakref__ is a getset_descriptor
# for the weak reference slot (since UUID uses __slots__, __weakref__ appears
# in UUID.__dict__ as a descriptor). No prior uuid spec anchors these four keys
# in UUID.__dict__ under uuiddict120. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra120.UUID_dict_lifecycle_fields:
  description: "UUID.__dict__.__contains__('__doc__')==True / UUID.__dict__.__contains__('__getstate__')==True / UUID.__dict__.__contains__('__setstate__')==True / UUID.__dict__.__contains__('__weakref__')==True — __doc__ is UUID's class docstring; __getstate__/__setstate__ are pickle protocol methods in Lib/uuid.py; __weakref__ is a getset_descriptor for the weak reference slot (exposed because UUID uses __slots__); no prior uuid spec anchors these four keys in UUID.__dict__; first uuiddict120 lifecycle anchor"
  kind: python_call_eq
  category: dict_contents
  id_prefix: uuiddict120

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_doc,         "UUID.__dict__.__contains__",  ["__doc__"],       true, "UUID.__dict__.__contains__('__doc__') is True; UUID's class docstring is stored in UUID.__dict__"]
    - [dict_has_getstate,    "UUID.__dict__.__contains__",  ["__getstate__"],  true, "UUID.__dict__.__contains__('__getstate__') is True; __getstate__ is UUID's pickle serialization method defined in Lib/uuid.py"]
    - [dict_has_setstate,    "UUID.__dict__.__contains__",  ["__setstate__"],  true, "UUID.__dict__.__contains__('__setstate__') is True; __setstate__ is UUID's pickle deserialization method defined in Lib/uuid.py"]
    - [dict_has_weakref,     "UUID.__dict__.__contains__",  ["__weakref__"],   true, "UUID.__dict__.__contains__('__weakref__') is True; __weakref__ is a getset_descriptor in UUID.__dict__ (present because UUID uses __slots__ including '__weakref__')"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__len__() == 37
# uuid.UUID.__dict__.__contains__('clock_seq') == True (cross-check)
# uuid.UUID.__dict__.__contains__('time_hi_version') == True (cross-check)
# uuid.UUID.__dict__.__contains__('__getstate__') == True (cross-check)
# uuid.UUID.__dict__.__contains__('__weakref__') == True (cross-check)
#
# Wave 301 theme: UUID.__dict__ total count and cross-checks.
#
# UUID.__dict__.__len__() is 37 — the total number of entries in the UUID class
# namespace mappingproxy. This count includes all properties, dunder methods,
# class attributes, __slots__, __module__, __doc__, and descriptors. No prior
# uuid spec anchors UUID.__dict__.__len__()==37 as an integer check.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra120.UUID_dict_count_and_crosscheck:
  description: "UUID.__dict__.__len__()==37 / UUID.__dict__.__contains__('clock_seq')==True (cross-check) / UUID.__dict__.__contains__('time_hi_version')==True (cross-check) / UUID.__dict__.__contains__('__getstate__')==True (cross-check) / UUID.__dict__.__contains__('__weakref__')==True (cross-check) — UUID class namespace has exactly 37 entries; cross-checks confirm time-field and lifecycle keys from earlier tables; no prior uuid spec anchors UUID.__dict__.__len__()==37; first uuiddict120 count anchor"
  kind: python_call_eq
  category: dict_contents
  id_prefix: uuiddict120

  columns: [id, function, args, expected, description]
  rows:
    - [dict_len_37,             "UUID.__dict__.__len__",       [],               37,   "UUID.__dict__.__len__() is 37; UUID class namespace has exactly 37 entries including all properties/methods/descriptors/__slots__/__module__/__doc__"]
    - [clock_seq_xcheck,        "UUID.__dict__.__contains__",  ["clock_seq"],    true, "UUID.__dict__.__contains__('clock_seq') cross-check confirming the time-based sub-field property is in UUID.__dict__"]
    - [time_hi_ver_xcheck,      "UUID.__dict__.__contains__",  ["time_hi_version"], true, "UUID.__dict__.__contains__('time_hi_version') cross-check for the time_hi_version property"]
    - [getstate_xcheck,         "UUID.__dict__.__contains__",  ["__getstate__"], true, "UUID.__dict__.__contains__('__getstate__') cross-check for the pickle serialization method"]
    - [weakref_xcheck,          "UUID.__dict__.__contains__",  ["__weakref__"],  true, "UUID.__dict__.__contains__('__weakref__') cross-check for the weak reference getset_descriptor"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('clock_seq') == True — standalone
#
# uuid.UUID.__dict__.__contains__('clock_seq') is True. The clock_seq property
# returns the 14-bit clock sequence field from the UUID's time-based layout.
# It is defined as a @property in Lib/uuid.py via the clock_seq_hi_variant and
# clock_seq_low sub-fields. extra97 anchors clock_seq.fget.__qualname__ equality
# ('UUID.clock_seq'); no prior uuid spec anchors UUID.__dict__.__contains__
# ('clock_seq') as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra120.UUID_dict_has_clock_seq:
  description: "uuid.UUID.__dict__.__contains__('clock_seq') == True — clock_seq is a property defined in Lib/uuid.py; it returns the 14-bit clock sequence field; extra97 anchors clock_seq.fget.__qualname__; no prior uuid spec anchors UUID.__dict__.__contains__('clock_seq') as standalone; first standalone under uuiddict120"
  category: dict_contents
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["clock_seq"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('time_hi_version') == True — standalone
#
# uuid.UUID.__dict__.__contains__('time_hi_version') is True. The time_hi_version
# property extracts the top 12 bits of the 60-bit timestamp (time_hi) plus the
# 4-bit version field from the UUID's int representation. It is defined as a
# @property in Lib/uuid.py. extra97 anchors time_hi_version.fget.__qualname__
# (via the 'UUID.time_hi_version' qualname); no prior uuid spec anchors
# UUID.__dict__.__contains__('time_hi_version') as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra120.UUID_dict_has_time_hi_version:
  description: "uuid.UUID.__dict__.__contains__('time_hi_version') == True — time_hi_version is a property defined in Lib/uuid.py extracting the top 12 bits of the timestamp and the 4-bit version field; extra97 anchors fget qualname; no prior uuid spec anchors UUID.__dict__.__contains__('time_hi_version') as standalone; first standalone under uuiddict120"
  category: dict_contents
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["time_hi_version"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__slots__') == True — standalone
#
# uuid.UUID.__dict__.__contains__('__slots__') is True. UUID uses __slots__ =
# ('int', 'is_safe', '__weakref__') to limit instance attributes, reducing memory
# usage and preventing arbitrary attribute assignment. The __slots__ tuple itself
# is stored as an attribute in the class __dict__. No prior uuid spec anchors
# UUID.__dict__.__contains__('__slots__') as a standalone under uuiddict120.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra120.UUID_dict_has_slots:
  description: "uuid.UUID.__dict__.__contains__('__slots__') == True — UUID uses __slots__ = ('int', 'is_safe', '__weakref__') for memory efficiency; the __slots__ tuple is stored in UUID.__dict__; no prior uuid spec anchors UUID.__dict__.__contains__('__slots__') as standalone; first standalone under uuiddict120"
  category: dict_contents
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["__slots__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__len__() == 37 — standalone
#
# uuid.UUID.__dict__.__len__() is 37. The UUID class namespace mappingproxy
# contains exactly 37 entries. This count includes: all UUID properties (hex,
# bytes, bytes_le, fields, int, urn, variant, version, time, time_low, time_mid,
# time_hi_version, time_hi_and_version, clock_seq_hi_variant, clock_seq_low,
# clock_seq, node), all defined dunder methods (__init__, __repr__, __str__,
# __eq__, __lt__, __gt__, __le__, __ge__, __hash__, __int__, __getstate__,
# __setstate__, __setattr__, __delattr__), plus __slots__, __module__, __doc__,
# __weakref__, and _from_int. No prior uuid spec anchors UUID.__dict__.__len__()
# as an integer equality check. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra120.UUID_dict_len_37:
  description: "uuid.UUID.__dict__.__len__() == 37 — UUID class namespace has exactly 37 entries (all properties + dunder methods + __slots__/__module__/__doc__/__weakref__/_from_int); no prior uuid spec anchors UUID.__dict__.__len__()==37 as standalone integer check; first standalone under uuiddict120"
  category: dict_contents
  kind: python_call_eq
  function: "UUID.__dict__.__len__"
  args: []
  expected: 37
