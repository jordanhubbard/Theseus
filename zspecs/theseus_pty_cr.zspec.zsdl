spec: theseus_pty_cr
version: ">=3.3"
backend: python_cleanroom(theseus_pty_cr)
blocks: pty

docs: https://docs.python.org/3/library/pty.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pty.html"
  not_derived_from:
    - "CPython source: Lib/pty.py"
  notes:
    - "Clean-room pty module. Do NOT import pty."

error_model: python_exceptions

invariant theseus_pty_cr.pty2_openpty:
  description: "openpty() returns (master_fd, slave_fd) as ints"
  category: behavior
  kind: python_call_eq
  function: pty2_openpty
  args: []
  expected: true

invariant theseus_pty_cr.pty2_constants:
  description: "STDIN_FILENO == 0, STDOUT_FILENO == 1, STDERR_FILENO == 2"
  category: behavior
  kind: python_call_eq
  function: pty2_constants
  args: []
  expected: true

invariant theseus_pty_cr.pty2_fork:
  description: "fork is callable"
  category: behavior
  kind: python_call_eq
  function: pty2_fork
  args: []
  expected: true
