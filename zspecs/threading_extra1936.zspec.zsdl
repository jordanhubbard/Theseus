spec: threading_extra1936
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 576 (_extra1936): __get__/__set__/__delete__ descriptor protocol dict-presence checks, __set_name__ dict presence, __class__ attribute value checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "threading.Thread, Event, Condition, Semaphore, Barrier, Timer, BoundedSemaphore do NOT define __get__, __set__, __delete__, or __set_name__ in their own __dict__."
    - "threading.local (from _thread) does NOT define __get__, __set__, or __delete__ in its __dict__ despite descriptor-like thread-local behavior."
    - "threading.RLock.__class__.__name__ == 'function' (it is a factory function, not a class)."
    - "threading.Lock.__class__.__name__ == 'type' (it is the _thread.lock type directly)."
  created_at: "2026-04-12"
error_model: python_exceptions

table threading_extra1936.descriptor_protocol_thread_event:
  description: "threading.Thread and Event __get__/__set__/__delete__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1936
  columns: [id, function, args, expected]
  rows:
    - ["th1936001", "threading.Thread.__dict__.__contains__",     ["__get__"],    false]
    - ["th1936002", "threading.Thread.__dict__.__contains__",     ["__set__"],    false]
    - ["th1936003", "threading.Thread.__dict__.__contains__",     ["__delete__"], false]
    - ["th1936004", "threading.Event.__dict__.__contains__",      ["__get__"],    false]
    - ["th1936005", "threading.Event.__dict__.__contains__",      ["__set__"],    false]
    - ["th1936006", "threading.Event.__dict__.__contains__",      ["__delete__"], false]

