    - ["th1936018", "threading.local.__dict__.__contains__",   ["__delete__"], false]
    - ["th1936019", "threading.Barrier.__dict__.__contains__", ["__get__"],    false]
    - ["th1936020", "threading.Barrier.__dict__.__contains__", ["__set__"],    false]
    - ["th1936021", "threading.Barrier.__dict__.__contains__", ["__delete__"], false]
    - ["th1936022", "threading.Timer.__dict__.__contains__",   ["__get__"],    false]
