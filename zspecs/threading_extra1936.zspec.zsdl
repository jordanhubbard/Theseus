table threading_extra1936.set_name_presence:
  description: "threading classes __set_name__ dict-presence checks — none present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1936
  columns: [id, function, args, expected]
  rows:
    - ["th1936025", "threading.Thread.__dict__.__contains__",          ["__set_name__"], false]
    - ["th1936026", "threading.Event.__dict__.__contains__",           ["__set_name__"], false]
    - ["th1936027", "threading.Condition.__dict__.__contains__",       ["__set_name__"], false]
    - ["th1936028", "threading.Semaphore.__dict__.__contains__",       ["__set_name__"], false]
    - ["th1936029", "threading.local.__dict__.__contains__",           ["__set_name__"], false]
    - ["th1936030", "threading.Barrier.__dict__.__contains__",         ["__set_name__"], false]

table threading_extra1936.class_name_checks:
  description: "threading type and module __class__.__name__ identity checks"
  kind: python_call_eq
  category: class_name
  id_prefix: th1936
  columns: [id, function, args, expected]
  rows:
    - ["th1936031", "threading.__class__.__name__.__eq__",             ["module"],   true]
    - ["th1936032", "threading.Thread.__class__.__name__.__eq__",      ["type"],     true]
    - ["th1936033", "threading.Event.__class__.__name__.__eq__",       ["type"],     true]
    - ["th1936034", "threading.Condition.__class__.__name__.__eq__",   ["type"],     true]
    - ["th1936035", "threading.Semaphore.__class__.__name__.__eq__",   ["type"],     true]
    - ["th1936036", "threading.Barrier.__class__.__name__.__eq__",     ["type"],     true]
    - ["th1936037", "threading.Timer.__class__.__name__.__eq__",       ["type"],     true]
    - ["th1936038", "threading.local.__class__.__name__.__eq__",       ["type"],     true]
    - ["th1936039", "threading.RLock.__class__.__name__.__eq__",       ["function"], true]
    - ["th1936040", "threading.Lock.__class__.__name__.__eq__",        ["type"],     true]

table threading_extra1936.module_identity_checks:
  description: "threading class module and qualname identity checks"
  kind: python_call_eq
  category: qualname
  id_prefix: th1936
  columns: [id, function, args, expected]
  rows:
    - ["th1936041", "threading.Thread.__module__.__eq__",          ["threading"], true]
    - ["th1936042", "threading.Event.__module__.__eq__",           ["threading"], true]
    - ["th1936043", "threading.Condition.__module__.__eq__",       ["threading"], true]
    - ["th1936044", "threading.Semaphore.__module__.__eq__",       ["threading"], true]
    - ["th1936045", "threading.Barrier.__module__.__eq__",         ["threading"], true]
    - ["th1936046", "threading.local.__module__.__eq__",           ["_thread"],   true]
    - ["th1936047", "threading.Thread.__qualname__.__eq__",        ["Thread"],    true]
    - ["th1936048", "threading.Semaphore.__qualname__.__eq__",     ["Semaphore"], true]
