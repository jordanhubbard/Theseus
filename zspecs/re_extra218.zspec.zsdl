spec: re_extra218
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.IGNORECASE.value==2, re.MULTILINE.value==8, re.DOTALL.value==16, re.VERBOSE.value==64, re.UNICODE.value==32, re.ASCII.value==256. Verified with Python 3.14.3."
    - "type(re.IGNORECASE).__name__=='RegexFlag' (enum.IntFlag subclass). Verified with Python 3.14.3."
    - "re.compile(r'(\\w+)', re.IGNORECASE).flags==34 (IGNORECASE=2 | UNICODE=32). Verified with Python 3.14.3."
    - "re.error is re.PatternError is True in Python 3.13+. re.error.__name__=='PatternError'. Verified with Python 3.14.3."
    - "re.NOFLAG.value==0. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.RegexFlag integer values
# ---------------------------------------------------------------------------

table re_extra218.regex_flag_values:
  description: "re.RegexFlag integer .value checks: NOFLAG==0, IGNORECASE==2, MULTILINE==8, DOTALL==16, UNICODE==32, VERBOSE==64, ASCII==256; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: reextra218a

  columns: [id, function, args, expected, description]
  rows:
    - [noflag_val,     re.NOFLAG.value.__eq__,     [0],   true, "re.NOFLAG.value == 0; verified with Python 3.14.3"]
    - [ignorecase_val, re.IGNORECASE.value.__eq__,  [2],   true, "re.IGNORECASE.value == 2; verified with Python 3.14.3"]
    - [multiline_val,  re.MULTILINE.value.__eq__,   [8],   true, "re.MULTILINE.value == 8; verified with Python 3.14.3"]
    - [dotall_val,     re.DOTALL.value.__eq__,      [16],  true, "re.DOTALL.value == 16; verified with Python 3.14.3"]
    - [unicode_val,    re.UNICODE.value.__eq__,     [32],  true, "re.UNICODE.value == 32; verified with Python 3.14.3"]
    - [verbose_val,    re.VERBOSE.value.__eq__,     [64],  true, "re.VERBOSE.value == 64; verified with Python 3.14.3"]
    - [ascii_val,      re.ASCII.value.__eq__,       [256], true, "re.ASCII.value == 256; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# re.RegexFlag type identity
# ---------------------------------------------------------------------------

table re_extra218.regex_flag_type_identity:
  description: "re.IGNORECASE.__class__.__name__=='RegexFlag'; type(re.IGNORECASE).__name__=='RegexFlag'; re.NOFLAG.__class__.__name__=='RegexFlag'; RegexFlag is an IntFlag enum; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: reextra218b

  columns: [id, function, args, expected, description]
  rows:
    - [ignorecase_cls,  re.IGNORECASE.__class__.__name__.__eq__,  ["RegexFlag"], true, "re.IGNORECASE.__class__.__name__ == 'RegexFlag'; verified with Python 3.14.3"]
    - [multiline_cls,   re.MULTILINE.__class__.__name__.__eq__,   ["RegexFlag"], true, "re.MULTILINE.__class__.__name__ == 'RegexFlag'; verified with Python 3.14.3"]
    - [dotall_cls,      re.DOTALL.__class__.__name__.__eq__,      ["RegexFlag"], true, "re.DOTALL.__class__.__name__ == 'RegexFlag'; verified with Python 3.14.3"]
    - [noflag_cls,      re.NOFLAG.__class__.__name__.__eq__,      ["RegexFlag"], true, "re.NOFLAG.__class__.__name__ == 'RegexFlag'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# re.error / re.PatternError identity
# ---------------------------------------------------------------------------

table re_extra218.error_identity:
  description: "re.error identity: __name__=='PatternError' in Python 3.13+; __module__=='re'; __bases__[0].__name__=='Exception'; re.error is re.PatternError (aliases); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: reextra218c

  columns: [id, function, args, expected, description]
  rows:
    - [err_name,    re.error.__name__.__eq__,             ["PatternError"], true, "re.error.__name__ == 'PatternError' (Python 3.13+); verified with Python 3.14.3"]
    - [err_mod,     re.error.__module__.__eq__,           ["re"],           true, "re.error.__module__ == 're'; verified with Python 3.14.3"]
    - [err_base0,   "re.error.__bases__[0].__name__.__eq__", ["Exception"], true, "re.error.__bases__[0].__name__ == 'Exception'; verified with Python 3.14.3"]
    - [perr_name,   re.PatternError.__name__.__eq__,      ["PatternError"], true, "re.PatternError.__name__ == 'PatternError'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — Pattern object attributes
# ---------------------------------------------------------------------------

invariant re_extra218.pattern_class_name:
  description: "re.compile(r'(\\w+)').__class__.__name__=='Pattern' — the compiled pattern object is of type 're.Pattern'; type(p).__name__=='Pattern'; p.groups==1 (one capturing group); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra218.noflag_value_eq_0:
  description: "re.NOFLAG.value.__eq__(0) returns True — NOFLAG is the zero-value RegexFlag meaning no flags are set; added in Python 3.11; value is 0; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: re.NOFLAG.value.__eq__
  args: [0]
  expected: true

invariant re_extra218.ignorecase_value_eq_2:
  description: "re.IGNORECASE.value.__eq__(2) returns True — IGNORECASE flag value is 2; RegexFlag is an IntFlag so values are powers of 2; IGNORECASE=2, MULTILINE=8, DOTALL=16, UNICODE=32, VERBOSE=64, ASCII=256; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: re.IGNORECASE.value.__eq__
  args: [2]
  expected: true

invariant re_extra218.error_name_is_pattern_error:
  description: "re.error.__name__.__eq__('PatternError') returns True — in Python 3.13+ re.error was renamed to PatternError; re.error is kept as an alias; re.error is re.PatternError evaluates to True; module is 're'; base is Exception; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: re.error.__name__.__eq__
  args: ["PatternError"]
  expected: true

# ---------------------------------------------------------------------------
# re.compile raises re.error on invalid patterns
# ---------------------------------------------------------------------------

invariant re_extra218.compile_unclosed_group_raises:
  description: "re.compile('(unclosed') raises re.error (PatternError) — missing closing parenthesis is a syntax error in regex patterns; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: re.compile
  args: ["(unclosed"]
  raises: re.error

invariant re_extra218.compile_unclosed_bracket_raises:
  description: "re.compile('[') raises re.error (PatternError) — unterminated character set is a syntax error; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: re.compile
  args: ["["]
  raises: re.error

invariant re_extra218.compile_leading_quantifier_raises:
  description: "re.compile('*foo') raises re.error (PatternError) — a quantifier with nothing to quantify is a syntax error; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: re.compile
  args: ["*foo"]
  raises: re.error
