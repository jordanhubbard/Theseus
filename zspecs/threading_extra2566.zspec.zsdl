spec: threading_extra2566
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2566 (_extra2566): __getattr__, __setattr__, __delattr__ dict-presence checks."
    - "threading.local: defines __setattr__ and __delattr__ in its own __dict__ to maintain per-thread storage isolation — attribute writes and deletes are intercepted to ensure they operate on the correct thread-local dict rather than the shared class dict."
    - "threading.Thread: pure-Python class — no __setattr__, __delattr__, or __getattr__ in own __dict__."
    - "threading.RLock, Event, Semaphore, Condition, Barrier, Timer: pure-Python synchronization classes — none define attribute access hooks."
    - "threading._DummyThread: internal subclass of Thread — no attribute access hooks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __setattr__ dict-presence for threading types
#
# threading.local defines __setattr__ to intercept attribute writes and
# store them in the per-thread __dict__ for the calling thread, not in
# the shared instance __dict__.  No other threading class defines
# __setattr__ in its own __dict__.
# ---------------------------------------------------------------------------

table threading_extra2566.setattr_protocol:
  description: "threading types __setattr__ dict-presence checks — wave 2566 _extra2566"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2566

  columns: [id, function, args, expected]
  rows:
    - ["th2566001", "threading.local.__dict__.__contains__", ["__setattr__"], true]
    - ["th2566002", "threading.Thread.__dict__.__contains__", ["__setattr__"], false]
    - ["th2566003", "threading.RLock.__dict__.__contains__", ["__setattr__"], false]
    - ["th2566004", "threading.Event.__dict__.__contains__", ["__setattr__"], false]
    - ["th2566005", "threading.Semaphore.__dict__.__contains__", ["__setattr__"], false]

# ---------------------------------------------------------------------------
# Table 2: __delattr__ dict-presence for threading types
#
# threading.local also defines __delattr__ (paired with __setattr__) so
# that attribute deletion is similarly routed to the correct per-thread
# storage dict.  No other threading class defines __delattr__.
# ---------------------------------------------------------------------------

table threading_extra2566.delattr_protocol:
  description: "threading types __delattr__ dict-presence checks — wave 2566 _extra2566"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2566

  columns: [id, function, args, expected]
  rows:
    - ["th2566006", "threading.local.__dict__.__contains__", ["__delattr__"], true]
    - ["th2566007", "threading.Thread.__dict__.__contains__", ["__delattr__"], false]
    - ["th2566008", "threading.Condition.__dict__.__contains__", ["__delattr__"], false]
    - ["th2566009", "threading.Barrier.__dict__.__contains__", ["__delattr__"], false]
    - ["th2566010", "threading.Timer.__dict__.__contains__", ["__delattr__"], false]

# ---------------------------------------------------------------------------
# Table 3: __getattr__ dict-presence for threading types
#
# No threading class defines __getattr__ in its own __dict__.
# threading.local does NOT need __getattr__ because it uses __setattr__
# and __delattr__ to write/delete into per-thread storage, while reads
# happen through the normal descriptor protocol (tp_getattro at C level)
# which also resolves the per-thread dict transparently.
# ---------------------------------------------------------------------------

table threading_extra2566.getattr_protocol:
  description: "threading types __getattr__ dict-presence checks — all False — wave 2566 _extra2566"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2566

  columns: [id, function, args, expected]
  rows:
    - ["th2566011", "threading.local.__dict__.__contains__", ["__getattr__"], false]
    - ["th2566012", "threading.Thread.__dict__.__contains__", ["__getattr__"], false]
    - ["th2566013", "threading.RLock.__dict__.__contains__", ["__getattr__"], false]
    - ["th2566014", "threading.Semaphore.__dict__.__contains__", ["__getattr__"], false]
    - ["th2566015", "threading._DummyThread.__dict__.__contains__", ["__getattr__"], false]

# ---------------------------------------------------------------------------
# Table 4: threading.local full attribute-protocol summary and broader checks
#
# threading.local is the only threading type that customises the attribute
# access protocol at the Python level.  It defines both __setattr__ and
# __delattr__ (present) while omitting __getattr__ (absent).  The remaining
# synchronization primitives (Condition, Barrier, Timer, Event) and thread
# management classes (Thread, _DummyThread) inherit everything from object.
# ---------------------------------------------------------------------------

table threading_extra2566.attr_protocol_summary:
  description: "threading full attribute-protocol dict-presence summary — wave 2566 _extra2566"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2566

  columns: [id, function, args, expected]
  rows:
    - ["th2566016", "threading.local.__dict__.__contains__", ["__setattr__"], true]
    - ["th2566017", "threading.local.__dict__.__contains__", ["__delattr__"], true]
    - ["th2566018", "threading.local.__dict__.__contains__", ["__getattr__"], false]
    - ["th2566019", "threading.Condition.__dict__.__contains__", ["__getattr__"], false]
    - ["th2566020", "threading.Condition.__dict__.__contains__", ["__setattr__"], false]
