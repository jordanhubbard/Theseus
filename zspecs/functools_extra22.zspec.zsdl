spec: functools_extra22
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools.zspec.zsdl and prior extras through functools_extra21.zspec.zsdl."
    - "functools_extra21 covers: cache.__name__.__len__()==5; partial/cached_property/partialmethod __mro__.__len__()==2; mro[0]/__name__ self-reference checks; mro[-1]/mro[1] __name__=='object' for partial/cached_property."
    - "No prior functools spec records __name__.__eq__ for all seven of reduce/partial/lru_cache/cache/cached_property/total_ordering/wraps together in the extra22 namespace."
    - "reduce.__module__ == '_functools': reduce is a C-level builtin in _functoolsmodule.c; the __module__ attribute reflects the C extension origin, not the 'functools' wrapper module."
    - "partial.__module__ == 'functools': partial is a C type whose __module__ is explicitly set to 'functools'."
    - "reduce(f, [x]) == x for any f (including None): when the iterable has exactly one element, reduce returns it directly without ever calling the function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks — seven core functools callables
#
# functools_extra13 covers __name__.__eq__ for reduce/partial/wraps/cached_property.
# functools_extra14 covers __name__.__eq__ for cmp_to_key/total_ordering/lru_cache/
# singledispatch/singledispatchmethod. functools_extra18 covers cache.__name__.__eq__.
# No prior spec groups all seven of reduce/partial/lru_cache/cache/cached_property/
# total_ordering/wraps into a single __name__ table in the extra22 namespace.
# ---------------------------------------------------------------------------

table functools_extra22.names:
  kind: python_call_eq
  category: function_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra22.names.reduce,
       reduce.__name__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__name__ == 'reduce'"]
    - [functools_extra22.names.partial,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__ == 'partial'"]
    - [functools_extra22.names.lru_cache,
       lru_cache.__name__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__name__ == 'lru_cache'"]
    - [functools_extra22.names.cache,
       cache.__name__.__eq__,
       ["cache"],
       true,
       "functools.cache.__name__ == 'cache'"]
    - [functools_extra22.names.cached_property,
       cached_property.__name__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__name__ == 'cached_property'"]
    - [functools_extra22.names.total_ordering,
       total_ordering.__name__.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__name__ == 'total_ordering'"]
    - [functools_extra22.names.wraps,
       wraps.__name__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__name__ == 'wraps'"]

# ---------------------------------------------------------------------------
# __module__ checks — seven core functools callables
#
# reduce.__module__ == '_functools': reduce is a C-level builtin exposed from
# the _functools extension; its __module__ reflects the C origin.
# All other six have __module__ == 'functools'.
# functools_extra20 covers __module__.__len__ for several members.
# No prior spec records all seven __module__ values together in one table.
# ---------------------------------------------------------------------------

table functools_extra22.modules:
  kind: python_call_eq
  category: function_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra22.modules.reduce,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__ == '_functools' — C-level origin in _functools extension"]
    - [functools_extra22.modules.partial,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__ == 'functools'"]
    - [functools_extra22.modules.lru_cache,
       lru_cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.lru_cache.__module__ == 'functools'"]
    - [functools_extra22.modules.cache,
       cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.cache.__module__ == 'functools'"]
    - [functools_extra22.modules.cached_property,
       cached_property.__module__.__eq__,
       ["functools"],
       true,
       "functools.cached_property.__module__ == 'functools'"]
    - [functools_extra22.modules.total_ordering,
       total_ordering.__module__.__eq__,
       ["functools"],
       true,
       "functools.total_ordering.__module__ == 'functools'"]
    - [functools_extra22.modules.wraps,
       wraps.__module__.__eq__,
       ["functools"],
       true,
       "functools.wraps.__module__ == 'functools'"]

# ---------------------------------------------------------------------------
# Behavioral: functools.reduce single-element identity
#
# reduce(f, [x]) == x for any f, including None: when the iterable has exactly
# one element, reduce returns it directly without ever invoking the function.
# Verified: functools.reduce(None, [10]) == 10.
# This captures the core identity property of reduce over a singleton list.
# No prior functools spec records reduce(None, [10]) == 10 in ZSDL form.
# ---------------------------------------------------------------------------

invariant functools_extra22.reduce.single_element_identity:
  description: "functools.reduce(None, [10]) == 10 — single-element list returns element without calling function"
  category: behavioral
  kind: python_call_eq
  function: reduce
  args: [~, [10]]
  expected: 10
