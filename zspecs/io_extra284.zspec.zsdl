spec: io_extra284
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "io_extra283 covers StringIO and BytesIO method __qualname__ values."
    - "This spec focuses on io.RawIOBase and io.BufferedIOBase method __qualname__ values."
    - "RawIOBase methods are defined on the C implementation class '_RawIOBase'; their __qualname__ follows '_RawIOBase.<method>'."
    - "BufferedIOBase methods are defined on the C implementation class '_BufferedIOBase'; their __qualname__ follows '_BufferedIOBase.<method>'."
    - "io.RawIOBase.read.__qualname__ == '_RawIOBase.read' — confirmed via Python 3.14.3."
    - "io.BufferedIOBase.read.__qualname__ == '_BufferedIOBase.read' — confirmed via Python 3.14.3."
    - "io.RawIOBase.__module__ == 'io' and io.BufferedIOBase.__module__ == 'io' — public names are in the 'io' module."
    - "io.RawIOBase.__class__.__name__ == 'ABCMeta' — RawIOBase is an abstract base class."
    - "io.BufferedIOBase.__class__.__name__ == 'ABCMeta' — BufferedIOBase is an abstract base class."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.RawIOBase method __qualname__ — method_descriptor objects
# Qualnames follow '_RawIOBase.<method>' (C-level class name)
# ---------------------------------------------------------------------------

table io_extra284.rawiobase_method_qualnames:
  description: "io.RawIOBase method __qualname__ values — all follow '_RawIOBase.<method>'"
  kind: python_call_eq
  category: method_identity
  id_prefix: raw_qn

  columns: [id, function, args, expected, description]
  rows:
    - [read,     RawIOBase.read.__qualname__.__eq__,     ["_RawIOBase.read"],     true, "io.RawIOBase.read.__qualname__ == '_RawIOBase.read'"]
    - [readall,  RawIOBase.readall.__qualname__.__eq__,  ["_RawIOBase.readall"],  true, "io.RawIOBase.readall.__qualname__ == '_RawIOBase.readall'"]
    - [readinto, RawIOBase.readinto.__qualname__.__eq__, ["_RawIOBase.readinto"], true, "io.RawIOBase.readinto.__qualname__ == '_RawIOBase.readinto'"]
    - [write,    RawIOBase.write.__qualname__.__eq__,    ["_RawIOBase.write"],    true, "io.RawIOBase.write.__qualname__ == '_RawIOBase.write'"]

# ---------------------------------------------------------------------------
# io.BufferedIOBase method __qualname__ — method_descriptor objects
# Qualnames follow '_BufferedIOBase.<method>' (C-level class name)
# ---------------------------------------------------------------------------

table io_extra284.bufferediobase_method_qualnames:
  description: "io.BufferedIOBase method __qualname__ values — all follow '_BufferedIOBase.<method>'"
  kind: python_call_eq
  category: method_identity
  id_prefix: buf_qn

  columns: [id, function, args, expected, description]
  rows:
    - [read,     BufferedIOBase.read.__qualname__.__eq__,     ["_BufferedIOBase.read"],     true, "io.BufferedIOBase.read.__qualname__ == '_BufferedIOBase.read'"]
    - [read1,    BufferedIOBase.read1.__qualname__.__eq__,    ["_BufferedIOBase.read1"],    true, "io.BufferedIOBase.read1.__qualname__ == '_BufferedIOBase.read1'"]
    - [readinto, BufferedIOBase.readinto.__qualname__.__eq__, ["_BufferedIOBase.readinto"], true, "io.BufferedIOBase.readinto.__qualname__ == '_BufferedIOBase.readinto'"]
    - [write,    BufferedIOBase.write.__qualname__.__eq__,    ["_BufferedIOBase.write"],    true, "io.BufferedIOBase.write.__qualname__ == '_BufferedIOBase.write'"]
    - [detach,   BufferedIOBase.detach.__qualname__.__eq__,   ["_BufferedIOBase.detach"],   true, "io.BufferedIOBase.detach.__qualname__ == '_BufferedIOBase.detach'"]

# ---------------------------------------------------------------------------
# RawIOBase class metadata — ABC with module 'io'
# ---------------------------------------------------------------------------

invariant io_extra284.RawIOBase.class_name:
  description: "io.RawIOBase.__name__ == 'RawIOBase' — public name of the abstract base class"
  category: class_metadata
  kind: python_call_eq
  function: RawIOBase.__name__.__eq__
  args: ["RawIOBase"]
  expected: true

invariant io_extra284.RawIOBase.module:
  description: "io.RawIOBase.__module__ == 'io' — RawIOBase is exposed in the public 'io' namespace"
  category: class_metadata
  kind: python_call_eq
  function: RawIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra284.RawIOBase.metaclass:
  description: "io.RawIOBase.__class__.__name__ == 'ABCMeta' — RawIOBase is an abstract base class"
  category: class_metadata
  kind: python_call_eq
  function: RawIOBase.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

# ---------------------------------------------------------------------------
# BufferedIOBase class metadata — ABC with module 'io'
# ---------------------------------------------------------------------------

invariant io_extra284.BufferedIOBase.class_name:
  description: "io.BufferedIOBase.__name__ == 'BufferedIOBase' — public name of the abstract base class"
  category: class_metadata
  kind: python_call_eq
  function: BufferedIOBase.__name__.__eq__
  args: ["BufferedIOBase"]
  expected: true

invariant io_extra284.BufferedIOBase.module:
  description: "io.BufferedIOBase.__module__ == 'io' — BufferedIOBase is exposed in the public 'io' namespace"
  category: class_metadata
  kind: python_call_eq
  function: BufferedIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra284.BufferedIOBase.metaclass:
  description: "io.BufferedIOBase.__class__.__name__ == 'ABCMeta' — BufferedIOBase is an abstract base class"
  category: class_metadata
  kind: python_call_eq
  function: BufferedIOBase.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

# ---------------------------------------------------------------------------
# Method descriptor type identity — both RawIOBase and BufferedIOBase methods
# are method_descriptor objects at the class level
# ---------------------------------------------------------------------------

invariant io_extra284.RawIOBase.read.descriptor_type:
  description: "io.RawIOBase.read is a method_descriptor at the class level"
  category: method_identity
  kind: python_call_eq
  function: RawIOBase.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra284.BufferedIOBase.read.descriptor_type:
  description: "io.BufferedIOBase.read is a method_descriptor at the class level"
  category: method_identity
  kind: python_call_eq
  function: BufferedIOBase.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true
