spec: hashlib_extra63
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_blake2/blake2module.c"
    - "hashlib_extra62.zspec.zsdl — covers hashlib.__spec__.origin.__class__.__name__.__eq__('str') / __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') / __spec__.has_location==True / __loader__.__class__.__name__.__len__()==16 (table + invariants)."
    - "hashlib_extra61.zspec.zsdl — covers hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "hashlib_extra60.zspec.zsdl — covers hashlib.__all__.__contains__ for sha256/sha1/sha512/sha3_256 (table); blake2b/blake2s/md5/sha1 __doc__.__class__.__qualname__.__eq__('str'); __all__.__contains__('algorithms_guaranteed') (invariant)."
    - "hashlib_extra37.zspec.zsdl — covers blake2b/blake2s instance method __qualname__.__len__() for update/digest/hexdigest/copy (length axis only; does NOT check __qualname__.__eq__ string values)."
    - "hashlib_extra33.zspec.zsdl — covers HASH.update/digest/hexdigest/copy __qualname__.__len__() via md5().__class__; HASH-backed method qualnames."
    - "hashlib_extra28.zspec.zsdl — covers sha3_256/sha3_512/blake2b/blake2s __qualname__.__len__() at the class level."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra62; it does NOT duplicate invariants present in those files."
    - "Wave 227 theme: Class method __qualname__ string equality checks for methods not yet covered."
    - "blake2b and blake2s are C extension types (not OpenSSL-backed HASH objects). Their method descriptors use the type name as the class prefix in __qualname__: 'blake2b.<method>' and 'blake2s.<method>'."
    - "hashlib_extra37 covers blake2b/blake2s method __qualname__.__len__() (the length axis: update/digest/hexdigest/copy). No prior hashlib spec checks blake2b or blake2s method __qualname__.__eq__ string values (the equality axis). These are the two orthogonal axes; extra37 establishes lengths; this spec establishes the exact string values. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "blake2b.update.__qualname__ == 'blake2b.update'. The method_descriptor for blake2b.update has __qualname__ 'blake2b.update' — the C type name 'blake2b' plus dot plus method name. No prior hashlib spec checks blake2b.update.__qualname__.__eq__('blake2b.update'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "blake2b.digest.__qualname__ == 'blake2b.digest'. Same pattern as update. No prior hashlib spec checks blake2b.digest.__qualname__.__eq__('blake2b.digest'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "blake2b.hexdigest.__qualname__ == 'blake2b.hexdigest'. No prior hashlib spec checks blake2b.hexdigest.__qualname__.__eq__('blake2b.hexdigest'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "blake2b.copy.__qualname__ == 'blake2b.copy'. No prior hashlib spec checks blake2b.copy.__qualname__.__eq__('blake2b.copy'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "blake2s.update.__qualname__ == 'blake2s.update'. blake2s methods use 'blake2s.' prefix, parallel to blake2b. No prior hashlib spec checks blake2s.update.__qualname__.__eq__('blake2s.update'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "blake2s.digest.__qualname__ == 'blake2s.digest'. No prior hashlib spec checks blake2s.digest.__qualname__.__eq__('blake2s.digest'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "blake2s.hexdigest.__qualname__ == 'blake2s.hexdigest'. No prior hashlib spec checks blake2s.hexdigest.__qualname__.__eq__('blake2s.hexdigest'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# blake2b method descriptor __qualname__.__eq__ string values
#
# Wave 227 theme: Class method __qualname__ string equality checks for methods
# not yet covered.
#
# hashlib_extra37 covers blake2b method __qualname__.__len__() (length axis):
#   update   -> len 14
#   digest   -> len 14
#   hexdigest -> len 17
#   copy     -> len 12
#
# This spec covers the complementary __qualname__.__eq__ string equality axis:
# the exact string values 'blake2b.update', 'blake2b.digest', 'blake2b.hexdigest',
# 'blake2b.copy'. No prior hashlib spec checks __qualname__.__eq__ for any
# blake2b method descriptor. Accessed via the type-level attribute on blake2b
# (the C extension type), not on an instance.
# ---------------------------------------------------------------------------

table hashlib_extra63.blake2b_method_qualname_eq:
  description: "blake2b method descriptor __qualname__.__eq__ string values — blake2b.update/digest/hexdigest/copy all use 'blake2b.' prefix; hashlib_extra37 covers __qualname__.__len__() (length axis); this spec covers the complementary __qualname__.__eq__ string equality axis; no prior hashlib spec checks __qualname__.__eq__ for any blake2b method"
  kind: python_call_eq
  category: function_names
  id_prefix: hashlibqual63

  columns: [id, function, args, expected]
  rows:
    - [blake2b_update_qualname_eq,    blake2b.update.__qualname__.__eq__,    ["blake2b.update"],    true]
    - [blake2b_digest_qualname_eq,    blake2b.digest.__qualname__.__eq__,    ["blake2b.digest"],    true]
    - [blake2b_hexdigest_qualname_eq, blake2b.hexdigest.__qualname__.__eq__, ["blake2b.hexdigest"], true]
    - [blake2b_copy_qualname_eq,      blake2b.copy.__qualname__.__eq__,      ["blake2b.copy"],      true]

# ---------------------------------------------------------------------------
# blake2s method descriptor __qualname__.__eq__ string values
#
# blake2s mirrors blake2b as a separate C extension type with 'blake2s.' prefix
# in all method qualnames. hashlib_extra37 covers blake2s method
# __qualname__.__len__() (lengths match blake2b: update/digest=14, hexdigest=17,
# copy=12). No prior hashlib spec checks __qualname__.__eq__ string values for
# any blake2s method descriptor. This table establishes the complementary
# string equality axis for blake2s methods.
# ---------------------------------------------------------------------------

table hashlib_extra63.blake2s_method_qualname_eq:
  description: "blake2s method descriptor __qualname__.__eq__ string values — blake2s.update/digest/hexdigest use 'blake2s.' prefix; hashlib_extra37 covers __qualname__.__len__() (length axis) for blake2s; this spec covers the complementary __qualname__.__eq__ equality axis; no prior hashlib spec checks __qualname__.__eq__ for any blake2s method"
  kind: python_call_eq
  category: function_names
  id_prefix: hashlibqual63

  columns: [id, function, args, expected]
  rows:
    - [blake2s_update_qualname_eq,    blake2s.update.__qualname__.__eq__,    ["blake2s.update"],    true]
    - [blake2s_digest_qualname_eq,    blake2s.digest.__qualname__.__eq__,    ["blake2s.digest"],    true]
    - [blake2s_hexdigest_qualname_eq, blake2s.hexdigest.__qualname__.__eq__, ["blake2s.hexdigest"], true]

# ---------------------------------------------------------------------------
# blake2b.update.__qualname__.__eq__('blake2b.update') — standalone
#
# The blake2b C extension type's update method descriptor has __qualname__
# 'blake2b.update'. hashlib_extra37 confirms the length (14) but does not
# check the exact string. This invariant anchors the primary string equality
# for the most commonly used blake2b method.
# ---------------------------------------------------------------------------

invariant hashlib_extra63.blake2b_update_qualname_str:
  description: "hashlib.blake2b.update.__qualname__.__eq__('blake2b.update') == True — blake2b C extension method_descriptor; qualname uses 'blake2b.' class prefix; hashlib_extra37 covers __len__()==14 (length axis only); no prior hashlib spec checks blake2b.update.__qualname__.__eq__; primary string equality anchor for blake2b.update qualname"
  category: function_names
  kind: python_call_eq
  function: blake2b.update.__qualname__.__eq__
  args: ["blake2b.update"]
  expected: true

# ---------------------------------------------------------------------------
# blake2s.update.__qualname__.__eq__('blake2s.update') — standalone
#
# Parallel to blake2b.update: the blake2s type's update method_descriptor has
# __qualname__ 'blake2s.update'. hashlib_extra37 confirms len==14. No prior
# hashlib spec checks the string value via __qualname__.__eq__ for blake2s.update.
# ---------------------------------------------------------------------------

invariant hashlib_extra63.blake2s_update_qualname_str:
  description: "hashlib.blake2s.update.__qualname__.__eq__('blake2s.update') == True — blake2s C extension method_descriptor; qualname uses 'blake2s.' class prefix; hashlib_extra37 covers __len__()==14 (length axis only); no prior hashlib spec checks blake2s.update.__qualname__.__eq__; primary string equality anchor for blake2s.update qualname"
  category: function_names
  kind: python_call_eq
  function: blake2s.update.__qualname__.__eq__
  args: ["blake2s.update"]
  expected: true
