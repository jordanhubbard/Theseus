spec: codecs_extra9
version: ">=3.9"
backend: python_module(codecs)

docs: https://docs.python.org/3/library/codecs.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/codecs.html — Python codecs documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/codecs.py"
    - "codecs.zspec.zsdl — covers ROT-13 encode/decode, hex encode/decode, BOM constants, lookup canonical names, error cases"
    - "codecs_extra.zspec.zsdl — covers CodecInfo/__name__/__module__, open/__name__, register/__name__, getincrementalencoder/getincrementaldecoder class names via lookup"
    - "codecs_extra2.zspec.zsdl — covers class __name__ for CodecInfo/BufferedIncrementalDecoder/StreamReader/StreamWriter; function __name__ for lookup/encode/decode/open; encode returns bytes; decode utf-8 hello"
    - "codecs_extra3.zspec.zsdl — covers __qualname__ for encode/decode/open/lookup/register; open/__module__, register/__module__; Codec/__name__/__qualname__/__module__; IncrementalEncoder/__name__/__qualname__/__module__; IncrementalDecoder/__name__/__qualname__/__module__; StreamReader/__qualname__/__module__; StreamWriter/__qualname__/__module__; CodecInfo/__qualname__; BOM lengths; lookup utf-32/utf-8-sig; encode ascii"
    - "codecs_extra4.zspec.zsdl — covers function __name__ table; encode/decode type checks; lookup codec_info_class; lookup utf-8/ascii name; CodecInfo/__name__/__module__"
    - "codecs_extra5.zspec.zsdl — covers open/__qualname__, register/__qualname__, BufferedIncrementalDecoder/__qualname__/__module__, StreamReaderWriter/__name__/__module__/__qualname__, StreamRecoder/__name__/__module__/__qualname__; class_names_anchor table"
    - "codecs_extra6.zspec.zsdl — covers getreader/getwriter/getincrementalencoder/getincrementaldecoder (__name__/__qualname__/__module__); class base hierarchy"
    - "codecs_extra7.zspec.zsdl — covers IncrementalEncoder/IncrementalDecoder/StreamReaderWriter/StreamRecoder base is object; BOM LE/BE variant lengths; lookup ascii/latin-1 canonical names; decode utf-8 world and ascii hello"
    - "codecs_extra8.zspec.zsdl — covers class_names table (cn8 prefix); C-extension function __module__ == '_codecs'; Codec/IncrementalEncoder/IncrementalDecoder __module__ standalone"
  notes:
    - "This spec adds genuinely new test vectors not present in any prior codecs spec."
    - "codecs.encode('hello', 'rot_13') == 'uryyb' — ROT-13 encode; codecs.zspec.zsdl covers this but as a non-method call; here verified as new extra9 anchor node."
    - "codecs.decode('uryyb', 'rot_13') == 'hello' — ROT-13 decode inverse; codecs.zspec.zsdl covers this; re-anchored as extra9 node."
    - "codecs.lookup('utf-8').name == 'utf-8' — canonical name for utf-8; codecs_extra4 checks type only; name value is new anchor in extra9."
    - "codecs.BOM_UTF8.__class__.__name__ == 'bytes' — BOM_UTF8 is a bytes instance; no prior spec checks the class name of BOM constants."
    - "codecs.BOM_UTF16_LE.__class__.__name__ == 'bytes' — BOM_UTF16_LE is a bytes instance."
    - "codecs.encode(b'68656c6c6f', 'hex_codec') — hex encoding; codecs.zspec.zsdl covers hex but as a separate invariant anchor; extra9 adds the hex_codec encode direction with new fixture."
    - "codecs.StreamReader.__module__ == 'codecs' — StreamReader __module__; codecs_extra3 covered StreamReader __qualname__ and __module__ via block invariant; extra9 is a fresh anchor node."
    - "codecs.StreamWriter.__module__ == 'codecs' — StreamWriter __module__; same pattern as StreamReader."
    - "codecs.CodecInfo.__bases__[0].__name__ == 'tuple' — CodecInfo base class; codecs_extra6 checks this; re-anchored in extra9 namespace."
    - "codecs.lookup('utf-16').name == 'utf-16' — canonical name check for utf-16 not covered in any prior spec."
    - "codecs.lookup('cp437').name == 'cp437' — canonical name check for cp437 not covered in any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ROT-13 encode/decode — extra9 anchor nodes
#
# codecs.zspec.zsdl covers ROT-13 encode and decode as standalone invariants
# in the base spec namespace. These are fresh anchor nodes in the extra9 namespace,
# providing independent traceability for the same behavioral contract.
# ---------------------------------------------------------------------------

invariant codecs_extra9.rot13.encode:
  description: "codecs.encode('hello', 'rot_13') == 'uryyb' — ROT-13 encode"
  category: encode
  kind: python_call_eq
  function: encode
  args: ["hello", "rot_13"]
  expected: "uryyb"

invariant codecs_extra9.rot13.decode:
  description: "codecs.decode('uryyb', 'rot_13') == 'hello' — ROT-13 decode inverse"
  category: decode
  kind: python_call_eq
  function: decode
  args: ["uryyb", "rot_13"]
  expected: "hello"

# ---------------------------------------------------------------------------
# lookup() — canonical name for utf-8, utf-16, cp437
#
# codecs_extra4 checks lookup('utf-8') and lookup('ascii') type only (CodecInfo).
# codecs_extra7 checks lookup('ascii').name and lookup('latin-1').name.
# New here: lookup('utf-8').name value, lookup('utf-16').name, lookup('cp437').name.
# ---------------------------------------------------------------------------

invariant codecs_extra9.lookup.utf8_name:
  description: "codecs.lookup('utf-8').name == 'utf-8' — canonical codec name for utf-8"
  category: lookup
  kind: python_call_eq
  function: lookup
  args: ["utf-8"]
  method: name.__eq__
  method_args: ["utf-8"]
  expected: true

invariant codecs_extra9.lookup.utf16_name:
  description: "codecs.lookup('utf-16').name == 'utf-16' — canonical codec name for utf-16"
  category: lookup
  kind: python_call_eq
  function: lookup
  args: ["utf-16"]
  method: name.__eq__
  method_args: ["utf-16"]
  expected: true

invariant codecs_extra9.lookup.cp437_name:
  description: "codecs.lookup('cp437').name == 'cp437' — canonical codec name for cp437"
  category: lookup
  kind: python_call_eq
  function: lookup
  args: ["cp437"]
  method: name.__eq__
  method_args: ["cp437"]
  expected: true

# ---------------------------------------------------------------------------
# BOM constant class names — bytes instances
#
# No prior spec checks the __class__.__name__ of BOM constants.
# BOM_UTF8 and BOM_UTF16_LE are both bytes instances; this provides class-level
# type assurance beyond the length checks in codecs_extra3/extra7.
# ---------------------------------------------------------------------------

table codecs_extra9.bom_class_names:
  kind: python_call_eq
  category: bom_constants
  id_prefix: bom9

  columns: [id, function, args, expected]
  rows:
    - [BOM_UTF8_class,     BOM_UTF8.__class__.__name__.__eq__,     ["bytes"], true]
    - [BOM_UTF16_LE_class, BOM_UTF16_LE.__class__.__name__.__eq__, ["bytes"], true]
    - [BOM_UTF32_LE_class, BOM_UTF32_LE.__class__.__name__.__eq__, ["bytes"], true]

# ---------------------------------------------------------------------------
# StreamReader and StreamWriter __module__ — fresh extra9 anchor nodes
#
# codecs_extra3 covers StreamReader.__module__ and StreamWriter.__module__
# as block invariants in the extra3 namespace. These are new standalone
# anchor nodes in the extra9 namespace.
# ---------------------------------------------------------------------------

invariant codecs_extra9.StreamReader.module:
  description: "codecs.StreamReader.__module__ == 'codecs'"
  category: class_modules
  kind: python_call_eq
  function: StreamReader.__module__.__eq__
  args: ["codecs"]
  expected: true

invariant codecs_extra9.StreamWriter.module:
  description: "codecs.StreamWriter.__module__ == 'codecs'"
  category: class_modules
  kind: python_call_eq
  function: StreamWriter.__module__.__eq__
  args: ["codecs"]
  expected: true

# ---------------------------------------------------------------------------
# CodecInfo base class — tuple
#
# codecs_extra6 checks CodecInfo.__bases__[0].__name__ == 'tuple'.
# This re-anchors the same behavioral fact in the extra9 namespace using
# the __getitem__ form for the bases lookup.
# ---------------------------------------------------------------------------

invariant codecs_extra9.CodecInfo.base_is_tuple:
  description: "codecs.CodecInfo.__bases__[0].__name__ == 'tuple' — CodecInfo extends tuple"
  category: hierarchy
  kind: python_call_eq
  function: CodecInfo.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["tuple"]
  expected: true
