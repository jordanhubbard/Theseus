spec: arr_flatten
version: ">=1.1.0"
backend: node(arr-flatten)

docs: https://www.npmjs.com/package/arr-flatten

provenance:
  derived_from:
    - "arr-flatten README — https://www.npmjs.com/package/arr-flatten"
    - "Test vectors verified with arr-flatten via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "arr-flatten source"
  notes:
    - "arr-flatten is an npm package. Install: npm install arr-flatten"
    - "Recursively flattens a nested array into a single-level array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a flat array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table arr_flatten.flatten:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: aflat

  columns: [id, args, expected]
  rows:
    - [nested,  [[[1, [2]], [3]]],  [1, 2, 3]]
    - [deep,    [[1, [2, [3]]]],    [1, 2, 3]]
    - [flat,    [[1, 2, 3]],        [1, 2, 3]]

