spec: threading_extra288
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading Thread, Event, and Condition class method identity via __qualname__ and property __class__.__name__"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "Thread.daemon, Thread.name, Thread.ident, Thread.native_id are all property descriptors"
    - "Condition does not have acquire/release methods (uses __enter__/__exit__ instead)"
    - "Thread method __qualname__ values follow 'ClassName.method_name' pattern"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table threading_extra288.thread_method_qualnames:
  description: "__qualname__ for Thread.start, Thread.run, Thread.join, Thread.is_alive"
  kind: python_call_eq
  category: identity
  id_prefix: thex288

  columns: [id, function, args, expected, description]
  rows:
    - [thex288_001, threading.Thread.start.__qualname__.__eq__, ["Thread.start"], true, "Thread.start __qualname__"]
    - [thex288_002, threading.Thread.run.__qualname__.__eq__, ["Thread.run"], true, "Thread.run __qualname__"]
    - [thex288_003, threading.Thread.join.__qualname__.__eq__, ["Thread.join"], true, "Thread.join __qualname__"]
    - [thex288_004, threading.Thread.is_alive.__qualname__.__eq__, ["Thread.is_alive"], true, "Thread.is_alive __qualname__"]

table threading_extra288.event_condition_method_qualnames:
  description: "__qualname__ for Event.set, Event.clear, Event.wait, Event.is_set and Condition.wait, Condition.notify, Condition.notify_all"
  kind: python_call_eq
  category: identity
  id_prefix: thex288e

  columns: [id, function, args, expected, description]
  rows:
    - [thex288e_001, threading.Event.set.__qualname__.__eq__, ["Event.set"], true, "Event.set __qualname__"]
    - [thex288e_002, threading.Event.clear.__qualname__.__eq__, ["Event.clear"], true, "Event.clear __qualname__"]
    - [thex288e_003, threading.Event.wait.__qualname__.__eq__, ["Event.wait"], true, "Event.wait __qualname__"]
    - [thex288e_004, threading.Event.is_set.__qualname__.__eq__, ["Event.is_set"], true, "Event.is_set __qualname__"]
    - [thex288e_005, threading.Condition.wait.__qualname__.__eq__, ["Condition.wait"], true, "Condition.wait __qualname__"]
    - [thex288e_006, threading.Condition.notify.__qualname__.__eq__, ["Condition.notify"], true, "Condition.notify __qualname__"]
    - [thex288e_007, threading.Condition.notify_all.__qualname__.__eq__, ["Condition.notify_all"], true, "Condition.notify_all __qualname__"]

invariant threading_extra288.thread_daemon_is_property:
  description: "Thread.daemon is a property descriptor"
  category: identity
  kind: python_call_eq
  function: threading.Thread.daemon.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra288.thread_name_is_property:
  description: "Thread.name is a property descriptor"
  category: identity
  kind: python_call_eq
  function: threading.Thread.name.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra288.thread_ident_is_property:
  description: "Thread.ident is a property descriptor"
  category: identity
  kind: python_call_eq
  function: threading.Thread.ident.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra288.thread_native_id_is_property:
  description: "Thread.native_id is a property descriptor"
  category: identity
  kind: python_call_eq
  function: threading.Thread.native_id.__class__.__name__.__eq__
  args: ["property"]
  expected: true
