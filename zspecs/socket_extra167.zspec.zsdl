spec: socket_extra167
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra166.zspec.zsdl — covers socket.AF_INET/__SOCK_STREAM/__AF_INET6/__SOCK_DGRAM/__IPPROTO_TCP/__IPPROTO_UDP enum constant class names (AddressFamily/SocketKind/int) and integer values (2/1/30/2/6/17) and class name lengths (13/10) (table + invariants)."
    - "socket_extra165.zspec.zsdl — covers socket.error/__timeout/__gaierror/__herror class identity (__name__/__module__/__bases__) and lengths (table + invariants)."
    - "socket_extra164.zspec.zsdl — covers socket.socket.__dict__ method membership and meta-attributes (table + invariants)."
    - "socket_extra163.zspec.zsdl — covers socket.__spec__ attributes (table + invariants)."
    - "socket_extra159.zspec.zsdl — covers socket.socket.__name__/__module__/__bases__[0].__name__ (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra166."
    - "Wave 349 theme: socket.AddressFamily and socket.SocketKind enum class identity — AddressFamily.__name__=='AddressFamily' / AddressFamily.__module__=='socket' / AddressFamily.__bases__[0].__name__=='IntEnum' / SocketKind.__name__=='SocketKind' / SocketKind.__module__=='socket' / SocketKind.__bases__[0].__name__=='IntEnum' / AddressFamily.__name__.__len__()==13 / SocketKind.__name__.__len__()==10. socket_extra166 anchors AF_INET.__class__.__name__=='AddressFamily'(13 chars) and SOCK_STREAM.__class__.__name__=='SocketKind'(10 chars) — the class names as seen from enum member instances. This spec anchors the enum classes themselves (AddressFamily and SocketKind directly) as the primary novel content."
    - "socket.AddressFamily.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__bases__[0].__name__ == 'IntEnum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__name__ == 'SocketKind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__bases__[0].__name__ == 'IntEnum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__name__.__len__() == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__name__.__len__() == 10. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.AddressFamily.__name__ == 'AddressFamily' (13 chars = 'Address'=7 + 'Family'=6). socket.AddressFamily.__module__ == 'socket' (6 chars). socket.AddressFamily.__bases__[0].__name__ == 'IntEnum' (7 chars). AddressFamily is an IntEnum subclass (not a plain Enum), so its members support direct integer comparison. socket_extra166 anchors AF_INET.__class__.__name__=='AddressFamily' from the member side; this spec anchors AddressFamily directly."
    - "Note: socket.SocketKind.__name__ == 'SocketKind' (10 chars = 'Socket'=6 + 'Kind'=4). socket.SocketKind.__module__ == 'socket' (6 chars). socket.SocketKind.__bases__[0].__name__ == 'IntEnum' (7 chars). SocketKind is also an IntEnum subclass. 'SocketKind'(10) < 'AddressFamily'(13) by 3 chars."
    - "Note: Both AddressFamily and SocketKind have __module__=='socket'(6 chars) and __bases__[0].__name__=='IntEnum'(7 chars). AddressFamily.__name__(13) > SocketKind.__name__(10) by 3 chars."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AddressFamily.__name__.__eq__('AddressFamily')
# socket.AddressFamily.__module__.__eq__('socket')
# socket.SocketKind.__name__.__eq__('SocketKind')
# socket.SocketKind.__module__.__eq__('socket')
#
# Wave 349 theme: AddressFamily and SocketKind enum class __name__ and __module__.
#
# AddressFamily.__name__ == 'AddressFamily' (13 chars; 'Address'=7 + 'Family'=6).
# AddressFamily.__module__ == 'socket' (6 chars; defined in Lib/socket.py).
# SocketKind.__name__ == 'SocketKind' (10 chars; 'Socket'=6 + 'Kind'=4).
# SocketKind.__module__ == 'socket' (6 chars; same module as AddressFamily).
# socket_extra166 anchors enum member class names (AF_INET.__class__.__name__=='AddressFamily');
# this spec anchors the enum classes themselves as a table under sockclass167.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra167.AddressFamily_SocketKind_name_and_module:
  description: "socket.AddressFamily.__name__.__eq__('AddressFamily')==True / AddressFamily.__module__.__eq__('socket')==True / SocketKind.__name__.__eq__('SocketKind')==True / SocketKind.__module__.__eq__('socket')==True — AddressFamily.__name__ is 'AddressFamily' (13 chars = 'Address'=7 + 'Family'=6; the IntEnum class for socket address families; added in Python 3.4 alongside SocketKind; address family constants like AF_INET(2)/AF_INET6(30)/AF_UNIX are members of this enum; 'AddressFamily'(13) is a compound word: 'Address'=the network address type, 'Family'=the grouping/classification; socket_extra166 anchors AF_INET.__class__.__name__=='AddressFamily'(13 chars) from the member perspective); AddressFamily.__module__ is 'socket' (6 chars; AddressFamily is defined in Lib/socket.py; __module__=='socket' (the public module); 6 chars = same length as 'struct'(6) and 'Struct'(6)); SocketKind.__name__ is 'SocketKind' (10 chars = 'Socket'=6 + 'Kind'=4; the IntEnum class for socket types/kinds; SOCK_STREAM(1)/SOCK_DGRAM(2)/SOCK_RAW are members; 'SocketKind'(10) < 'AddressFamily'(13) by 3 chars); SocketKind.__module__ is 'socket' (6 chars; same module as AddressFamily; both AddressFamily and SocketKind are defined in Lib/socket.py; AddressFamily.__module__(6)==SocketKind.__module__(6)=='socket'(6); first sockclass167 anchor for AddressFamily and SocketKind __name__ and __module__)"
  kind: python_call_eq
  category: identity
  id_prefix: sockclass167

  columns: [id, function, args, expected, description]
  rows:
    - [af_name,       "AddressFamily.__name__.__eq__",   ["AddressFamily"], true, "socket.AddressFamily.__name__ == 'AddressFamily' (13 chars = 'Address'=7 + 'Family'=6; IntEnum for address families; Python 3.4+; socket_extra166 anchors AF_INET.__class__.__name__=='AddressFamily')"]
    - [af_module,     "AddressFamily.__module__.__eq__", ["socket"],        true, "socket.AddressFamily.__module__ == 'socket' (6 chars; defined in Lib/socket.py; public module name)"]
    - [sk_name,       "SocketKind.__name__.__eq__",      ["SocketKind"],    true, "socket.SocketKind.__name__ == 'SocketKind' (10 chars = 'Socket'=6 + 'Kind'=4; IntEnum for socket types; 'SocketKind'(10) < 'AddressFamily'(13) by 3)"]
    - [sk_module,     "SocketKind.__module__.__eq__",    ["socket"],        true, "socket.SocketKind.__module__ == 'socket' (6 chars; same module as AddressFamily; both in Lib/socket.py)"]

# ---------------------------------------------------------------------------
# socket.AddressFamily.__bases__[0].__name__.__eq__('IntEnum')
# socket.SocketKind.__bases__[0].__name__.__eq__('IntEnum')
# socket.AddressFamily.__name__.__len__()==13
# socket.SocketKind.__name__.__len__()==10
#
# Wave 349 theme: AddressFamily and SocketKind inherit from IntEnum; name lengths.
#
# AddressFamily.__bases__[0].__name__ == 'IntEnum' (7 chars; IntEnum base).
# SocketKind.__bases__[0].__name__ == 'IntEnum' (7 chars; same base as AddressFamily).
# AddressFamily.__name__.__len__() == 13 ('AddressFamily' = 13 chars).
# SocketKind.__name__.__len__() == 10 ('SocketKind' = 10 chars).
# No prior socket spec anchors AddressFamily.__bases__ or SocketKind.__bases__ as a table
# under sockclass167. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra167.bases_IntEnum_and_name_lengths:
  description: "socket.AddressFamily.__bases__[0].__name__.__eq__('IntEnum')==True / SocketKind.__bases__[0].__name__.__eq__('IntEnum')==True / AddressFamily.__name__.__len__()==13 / SocketKind.__name__.__len__()==10 — AddressFamily.__bases__[0].__name__ is 'IntEnum' (7 chars; AddressFamily inherits from enum.IntEnum; IntEnum is an int subclass combined with Enum, so AddressFamily members are both ints and enum members; this enables direct integer comparison: AF_INET.__eq__(2)==True works because IntEnum inherits from int; 'IntEnum'(7 chars) = 'Int'=3 + 'Enum'=4); SocketKind.__bases__[0].__name__ is 'IntEnum' (7 chars; SocketKind also inherits from IntEnum; SOCK_STREAM.__eq__(1)==True works for the same reason; AddressFamily.__bases__[0].__name__(7)==SocketKind.__bases__[0].__name__(7)=='IntEnum'(7) — both enums share the same base; contrasts with uuid.SafeUUID.__bases__[0].__name__=='Enum'(4 chars) — SafeUUID is plain Enum not IntEnum); AddressFamily.__name__.__len__() is 13 ('AddressFamily' = 'Address'=7 + 'Family'=6 = 13; 'AddressFamily'(13) is one of the longer Python built-in type names; socket_extra166 anchors AF_INET.__class__.__name__.__len__()==13 from the member perspective; this spec anchors it from the class directly); SocketKind.__name__.__len__() is 10 ('SocketKind' = 'Socket'=6 + 'Kind'=4 = 10; 'SocketKind'(10) < 'AddressFamily'(13) by 3; socket_extra166 anchors SOCK_STREAM.__class__.__name__.__len__()==10 from the member; first sockclass167 anchor for bases and name lengths)"
  kind: python_call_eq
  category: identity
  id_prefix: sockclass167

  columns: [id, function, args, expected, description]
  rows:
    - [af_bases_intenum,    "AddressFamily.__bases__[0].__name__.__eq__",  ["IntEnum"], true, "socket.AddressFamily.__bases__[0].__name__ == 'IntEnum' (7 chars; AddressFamily inherits from IntEnum; members are int+enum; enables __eq__(int) comparisons)"]
    - [sk_bases_intenum,    "SocketKind.__bases__[0].__name__.__eq__",     ["IntEnum"], true, "socket.SocketKind.__bases__[0].__name__ == 'IntEnum' (7 chars; SocketKind also inherits from IntEnum; same base as AddressFamily)"]
    - [af_name_len_13,      "AddressFamily.__name__.__len__",              [], 13,        "socket.AddressFamily.__name__.__len__() is 13 ('AddressFamily' = 'Address'=7 + 'Family'=6 = 13; socket_extra166 anchors via AF_INET.__class__.__name__.__len__()==13)"]
    - [sk_name_len_10,      "SocketKind.__name__.__len__",                 [], 10,        "socket.SocketKind.__name__.__len__() is 10 ('SocketKind' = 'Socket'=6 + 'Kind'=4 = 10; socket_extra166 anchors via SOCK_STREAM.__class__.__name__.__len__()==10; 'SocketKind'(10) < 'AddressFamily'(13) by 3)"]

# ---------------------------------------------------------------------------
# module and base lengths for AddressFamily and SocketKind
#
# Wave 349 theme: module and IntEnum base name lengths for both enum classes.
#
# AddressFamily.__module__.__len__() == 6 ('socket' = 6 chars).
# SocketKind.__module__.__len__() == 6 ('socket' = 6 chars; same).
# AddressFamily.__bases__[0].__name__.__len__() == 7 ('IntEnum' = 7 chars).
# SocketKind.__bases__[0].__name__.__len__() == 7 ('IntEnum' = 7 chars; same).
# No prior socket spec anchors these module/base lengths as a table under sockclass167.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra167.module_and_base_lengths:
  description: "socket.AddressFamily.__module__.__len__()==6 / SocketKind.__module__.__len__()==6 / AddressFamily.__bases__[0].__name__.__len__()==7 / SocketKind.__bases__[0].__name__.__len__()==7 — AddressFamily.__module__.__len__() is 6 ('socket' = 6 chars; both AddressFamily and SocketKind have __module__=='socket'(6 chars); 'socket'(6) < 'AddressFamily'(13) and 'socket'(6) < 'SocketKind'(10) — the module name is shorter than either class name; 'socket'(6)==struct.__name__(6)==error.__module__(6) across different modules); SocketKind.__module__.__len__() is 6 ('socket' = 6 chars; same as AddressFamily.__module__.__len__()==6; both are defined in the same module; AddressFamily.__module__.__len__()==SocketKind.__module__.__len__()==6); AddressFamily.__bases__[0].__name__.__len__() is 7 ('IntEnum' = 'Int'=3 + 'Enum'=4 = 7 chars; 'IntEnum'(7) > 'Enum'(4) by 3 chars — the 'Int' prefix; 'IntEnum'(7) > 'socket'(6) by 1 char; 'IntEnum'(7) < 'SocketKind'(10) by 3; 'IntEnum'(7) < 'AddressFamily'(13) by 6); SocketKind.__bases__[0].__name__.__len__() is 7 ('IntEnum' = 7 chars; same as AddressFamily base; both classes inherit from IntEnum with the same 7-char base name; length ordering: 'socket'(6) < 'IntEnum'(7) < 'SocketKind'(10) < 'AddressFamily'(13); first sockclass167 anchor for module and base name lengths)"
  kind: python_call_eq
  category: identity
  id_prefix: sockclass167

  columns: [id, function, args, expected, description]
  rows:
    - [af_module_len_6,      "AddressFamily.__module__.__len__",              [], 6, "socket.AddressFamily.__module__.__len__() is 6 ('socket' = 6 chars; public module name; same for both AddressFamily and SocketKind)"]
    - [sk_module_len_6,      "SocketKind.__module__.__len__",                 [], 6, "socket.SocketKind.__module__.__len__() is 6 ('socket' = 6 chars; same as AddressFamily.__module__.__len__()==6; both in Lib/socket.py)"]
    - [af_base_len_7,        "AddressFamily.__bases__[0].__name__.__len__",   [], 7, "socket.AddressFamily.__bases__[0].__name__.__len__() is 7 ('IntEnum' = 'Int'=3 + 'Enum'=4 = 7 chars; 'IntEnum'(7) > 'Enum'(4) by 3)"]
    - [sk_base_len_7,        "SocketKind.__bases__[0].__name__.__len__",      [], 7, "socket.SocketKind.__bases__[0].__name__.__len__() is 7 ('IntEnum' = 7 chars; same base as AddressFamily; length ordering: 'socket'(6) < 'IntEnum'(7) < 'SocketKind'(10) < 'AddressFamily'(13))"]

# ---------------------------------------------------------------------------
# AddressFamily and SocketKind name length difference
#
# Wave 349 theme: name length comparison and module confirmation.
#
# AddressFamily.__name__.__len__() == 13 (confirmed).
# SocketKind.__name__.__len__() == 10 (confirmed).
# AddressFamily.__module__.__eq__('socket') (confirmed).
# SocketKind.__bases__[0].__name__.__eq__('IntEnum') (confirmed).
# No prior socket spec anchors these as a combined table under sockclass167.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra167.name_lengths_and_confirmations:
  description: "socket.AddressFamily.__name__.__len__()==13 / SocketKind.__name__.__len__()==10 / AddressFamily.__module__.__eq__('socket')==True / SocketKind.__bases__[0].__name__.__eq__('IntEnum')==True — AddressFamily.__name__.__len__() is 13 (confirmed; 'AddressFamily' = 13 chars; 13 > 10 by 3 — AddressFamily name is 3 chars longer than SocketKind; 13 = 10 + 3; this 3-char difference is because 'Address'(7) > 'Socket'(6) by 1 and 'Family'(6) > 'Kind'(4) by 2: total 1+2=3 extra chars); SocketKind.__name__.__len__() is 10 (confirmed; 'SocketKind' = 10 chars; 10 < 13 by 3; SocketKind has both a shorter first word ('Socket'=6 vs 'Address'=7) and a shorter second word ('Kind'=4 vs 'Family'=6)); AddressFamily.__module__ is 'socket' (confirmed; 6 chars; 'socket'(6) < 'IntEnum'(7) < 'SocketKind'(10) < 'AddressFamily'(13); the module name is the shortest of the four strings); SocketKind.__bases__[0].__name__ is 'IntEnum' (confirmed; 7 chars; IntEnum base enables integer comparison for enum members; AddressFamily.__bases__[0].__name__=='IntEnum'(7) too — both enums share the same base; first sockclass167 anchor for this combined confirmation table)"
  kind: python_call_eq
  category: identity
  id_prefix: sockclass167

  columns: [id, function, args, expected, description]
  rows:
    - [af_name_len_13_b,     "AddressFamily.__name__.__len__",              [], 13,        "socket.AddressFamily.__name__.__len__() is 13 (confirmed; 'AddressFamily' = 13 chars; 13 > SocketKind(10) by 3; 'Address'(7)+'Family'(6)=13)"]
    - [sk_name_len_10_b,     "SocketKind.__name__.__len__",                 [], 10,        "socket.SocketKind.__name__.__len__() is 10 (confirmed; 'SocketKind' = 10 chars; 10 < AddressFamily(13) by 3; 'Socket'(6)+'Kind'(4)=10)"]
    - [af_module_socket_b,   "AddressFamily.__module__.__eq__",             ["socket"], true, "socket.AddressFamily.__module__ == 'socket' (confirmed; 6 chars; 'socket'(6) < 'IntEnum'(7) < 'SocketKind'(10) < 'AddressFamily'(13))"]
    - [sk_bases_intenum_b,   "SocketKind.__bases__[0].__name__.__eq__",     ["IntEnum"], true, "socket.SocketKind.__bases__[0].__name__ == 'IntEnum' (confirmed; 7 chars; both AddressFamily and SocketKind inherit from IntEnum)"]

# ---------------------------------------------------------------------------
# socket.AddressFamily.__name__.__eq__('AddressFamily') — standalone
#
# socket.AddressFamily.__name__ is 'AddressFamily' (13 chars). AddressFamily is the IntEnum
# class for socket address families. It was introduced in Python 3.4 alongside SocketKind.
# 'AddressFamily' (13 chars) = 'Address'=7 + 'Family'=6. socket_extra166 anchors
# AF_INET.__class__.__name__=='AddressFamily' from the member's perspective; this standalone
# anchors AddressFamily.__name__ directly from the class itself.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra167.AddressFamily_name_AddressFamily:
  description: "socket.AddressFamily.__name__.__eq__('AddressFamily') == True — 'AddressFamily' (13 chars = 'Address'=7 + 'Family'=6; IntEnum class for socket address families; introduced in Python 3.4; members include AF_INET(2)/AF_INET6(30 on macOS)/AF_UNIX etc.; socket_extra166 anchors AF_INET.__class__.__name__=='AddressFamily' from member perspective; AddressFamily.__module__=='socket'(6 chars); AddressFamily.__bases__[0].__name__=='IntEnum'(7 chars); 'AddressFamily'(13) > 'SocketKind'(10) by 3 chars; first sockclass167 standalone for AddressFamily.__name__"
  category: identity
  kind: python_call_eq
  function: AddressFamily.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AddressFamily.__module__.__eq__('socket') — standalone
#
# socket.AddressFamily.__module__ is 'socket' (6 chars). AddressFamily is defined in
# Lib/socket.py so its __module__ is 'socket'. Both AddressFamily and SocketKind have
# __module__ == 'socket' (6 chars) — they are both defined in the same source file.
# 'socket' (6 chars) is 7 chars shorter than 'AddressFamily' (13 chars).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra167.AddressFamily_module_socket:
  description: "socket.AddressFamily.__module__.__eq__('socket') == True — 'socket' (6 chars; defined in Lib/socket.py; public module name); AddressFamily.__module__(6)==SocketKind.__module__(6)=='socket' — both share the same module; 'socket'(6) < 'IntEnum'(7) < 'SocketKind'(10) < 'AddressFamily'(13) in length ordering; AddressFamily.__name__=='AddressFamily'(13); first sockclass167 standalone for AddressFamily.__module__"
  category: identity
  kind: python_call_eq
  function: AddressFamily.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AddressFamily.__bases__[0].__name__.__eq__('IntEnum') — standalone
#
# socket.AddressFamily.__bases__[0].__name__ is 'IntEnum' (7 chars). AddressFamily inherits
# from enum.IntEnum, making its members both integers and enum members. This is why
# AF_INET.__eq__(2) == True works — AddressFamily inherits from int via IntEnum.
# 'IntEnum' (7 chars) = 'Int'=3 + 'Enum'=4. This contrasts with uuid.SafeUUID which
# inherits from plain Enum (SafeUUID.__bases__[0].__name__=='Enum', 4 chars).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra167.AddressFamily_bases_IntEnum:
  description: "socket.AddressFamily.__bases__[0].__name__.__eq__('IntEnum') == True — 'IntEnum' (7 chars = 'Int'=3 + 'Enum'=4; AddressFamily inherits from IntEnum making members both int and enum; AF_INET.__eq__(2)==True works because IntEnum inherits from int); contrasts with uuid.SafeUUID.__bases__[0].__name__=='Enum'(4 chars — plain Enum, not IntEnum); AddressFamily.__module__=='socket'(6); 'IntEnum'(7) > 'Enum'(4) by 3 chars — the 'Int' prefix; first sockclass167 standalone for AddressFamily.__bases__[0].__name__"
  category: identity
  kind: python_call_eq
  function: "AddressFamily.__bases__[0].__name__.__eq__"
  args: ["IntEnum"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SocketKind.__name__.__eq__('SocketKind') — standalone
#
# socket.SocketKind.__name__ is 'SocketKind' (10 chars). SocketKind is the IntEnum class
# for socket types. It was introduced in Python 3.4. 'SocketKind' (10 chars) = 'Socket'=6 +
# 'Kind'=4. socket_extra166 anchors SOCK_STREAM.__class__.__name__=='SocketKind' from the
# member's perspective; this standalone anchors SocketKind.__name__ directly.
# 'SocketKind'(10) < 'AddressFamily'(13) by 3 chars.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra167.SocketKind_name_SocketKind:
  description: "socket.SocketKind.__name__.__eq__('SocketKind') == True — 'SocketKind' (10 chars = 'Socket'=6 + 'Kind'=4; IntEnum class for socket types; introduced in Python 3.4; members include SOCK_STREAM(1)/SOCK_DGRAM(2)/SOCK_RAW etc.; socket_extra166 anchors SOCK_STREAM.__class__.__name__=='SocketKind' from member perspective; SocketKind.__module__=='socket'(6 chars); SocketKind.__bases__[0].__name__=='IntEnum'(7 chars); 'SocketKind'(10) < 'AddressFamily'(13) by 3 chars; first sockclass167 standalone for SocketKind.__name__"
  category: identity
  kind: python_call_eq
  function: SocketKind.__name__.__eq__
  args: ["SocketKind"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SocketKind.__module__.__eq__('socket') — standalone
#
# socket.SocketKind.__module__ is 'socket' (6 chars). SocketKind is defined in Lib/socket.py
# alongside AddressFamily. Both AddressFamily.__module__ and SocketKind.__module__ are
# 'socket' (6 chars). 'socket' (6 chars) is 4 chars shorter than 'SocketKind' (10 chars)
# and 7 chars shorter than 'AddressFamily' (13 chars).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra167.SocketKind_module_socket:
  description: "socket.SocketKind.__module__.__eq__('socket') == True — 'socket' (6 chars; defined in Lib/socket.py; same module as AddressFamily; SocketKind.__module__(6)==AddressFamily.__module__(6)=='socket'(6)); 'socket'(6) < 'IntEnum'(7) < 'SocketKind'(10) < 'AddressFamily'(13) in length ordering; SocketKind.__name__=='SocketKind'(10 chars); first sockclass167 standalone for SocketKind.__module__"
  category: identity
  kind: python_call_eq
  function: SocketKind.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SocketKind.__bases__[0].__name__.__eq__('IntEnum') — standalone
#
# socket.SocketKind.__bases__[0].__name__ is 'IntEnum' (7 chars). SocketKind inherits from
# enum.IntEnum, just like AddressFamily. This means SocketKind members are both integers and
# enum members: SOCK_STREAM.__eq__(1) == True works because IntEnum inherits from int.
# AddressFamily.__bases__[0].__name__ == 'IntEnum' too — both socket enum classes share the
# same base class. 'IntEnum' (7 chars) == AddressFamily base == SocketKind base.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra167.SocketKind_bases_IntEnum:
  description: "socket.SocketKind.__bases__[0].__name__.__eq__('IntEnum') == True — 'IntEnum' (7 chars = 'Int'=3 + 'Enum'=4; SocketKind inherits from IntEnum making members both int and enum; SOCK_STREAM.__eq__(1)==True works because IntEnum inherits from int); AddressFamily.__bases__[0].__name__=='IntEnum'(7 chars) too — both socket enum classes share the same IntEnum base; SocketKind.__module__=='socket'(6); 'IntEnum'(7) == 'AddressFamily base name len' == 'SocketKind base name len'; first sockclass167 standalone for SocketKind.__bases__[0].__name__"
  category: identity
  kind: python_call_eq
  function: "SocketKind.__bases__[0].__name__.__eq__"
  args: ["IntEnum"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AddressFamily.__name__.__len__() == 13 — standalone
#
# socket.AddressFamily.__name__.__len__() is 13. 'AddressFamily' (13 chars) = 'Address'=7 +
# 'Family'=6. socket_extra166 anchors AF_INET.__class__.__name__.__len__()==13 from the member
# perspective; this standalone anchors the same length from the class directly.
# 'AddressFamily'(13) is a notably long Python type name. 'AddressFamily'(13) > 'SocketKind'(10)
# by 3 chars. The difference comes from 'Address'(7) > 'Socket'(6) by 1 and 'Family'(6) >
# 'Kind'(4) by 2, totaling 3 chars.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra167.AddressFamily_name_len_13:
  description: "socket.AddressFamily.__name__.__len__() == 13 — 'AddressFamily' (13 chars = 'Address'=7 + 'Family'=6 = 13; socket_extra166 anchors AF_INET.__class__.__name__.__len__()==13 from member perspective; this standalone anchors from the class directly); 'AddressFamily'(13) > 'SocketKind'(10) by 3: 'Address'(7)>'Socket'(6) by 1 + 'Family'(6)>'Kind'(4) by 2 = 3 total extra chars; 'AddressFamily'(13) > 'IntEnum'(7) by 6 > 'socket'(6) by 7; first sockclass167 standalone for AddressFamily.__name__.__len__()==13"
  category: identity
  kind: python_call_eq
  function: AddressFamily.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
