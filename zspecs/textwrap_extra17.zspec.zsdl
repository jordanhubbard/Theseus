spec: textwrap_extra17
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl and prior extras through textwrap_extra16.zspec.zsdl."
    - "textwrap_extra16 covers: wrap('hello world', 5)==['hello','world']; fill('hello world', 5)=='hello\\nworld'; shorten('hello world foo bar', 15, placeholder='...')=='hello world...'; indent('hello\\nworld','  ')=='  hello\\n  world'; dedent('  hello\\n  world')=='hello\\nworld'."
    - "textwrap_extra15 covers: wrap('', 70)==[]; wrap('word', 70)==['word']; wrap('   leading spaces', 70)==['leading spaces']; fill edge cases; dedent empty and no-indent; indent tab prefix; shorten capital-T width=10."
    - "textwrap_extra14 covers: TextWrapper().tabsize==8; TextWrapper.__qualname__; wrap('hello world', 100); wrap('a b', 1); fill('a b c', 3); dedent('\\thello\\n\\tworld'); indent('foo\\nbar', '-- '); shorten 'the quick brown fox' width=10."
    - "textwrap_extra13 covers: TextWrapper().expand_tabs/max_lines/width; wrap/fill at width=5; dedent three-line two-space; shorten default placeholder width=8."
    - "This spec covers: TextWrapper.__name__=='TextWrapper'; TextWrapper.__module__=='textwrap'; TextWrapper.__bases__[0].__name__=='object'; wrap.__qualname__=='wrap'; fill.__qualname__=='fill'; shorten.__qualname__=='shorten'; indent.__qualname__=='indent'; dedent.__qualname__=='dedent'."
    - "textwrap.TextWrapper.__name__ == 'TextWrapper' — verified at runtime."
    - "textwrap.TextWrapper.__module__ == 'textwrap' — verified at runtime."
    - "textwrap.TextWrapper.__bases__[0].__name__ == 'object' — TextWrapper has no custom base class. Verified at runtime."
    - "textwrap.wrap.__qualname__ == 'wrap' — module-level function, qualname equals simple name. Verified at runtime."
    - "textwrap.fill.__qualname__ == 'fill' — module-level function. Verified at runtime."
    - "textwrap.shorten.__qualname__ == 'shorten' — module-level function. Verified at runtime."
    - "textwrap.indent.__qualname__ == 'indent' — module-level function. Verified at runtime."
    - "textwrap.dedent.__qualname__ == 'dedent' — module-level function. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TextWrapper class identity — __name__ and __module__
#
# textwrap_extra14 covers TextWrapper.__qualname__.
# No prior spec verifies TextWrapper.__name__ == 'TextWrapper' as a standalone
# invariant. __name__ is the simple class name; __qualname__ for a non-nested
# class is identical, but __name__ is a distinct attribute worth pinning.
# Verified: textwrap.TextWrapper.__name__ == 'TextWrapper'.
# ---------------------------------------------------------------------------

invariant textwrap_extra17.TextWrapper.name:
  description: "textwrap.TextWrapper.__name__ == 'TextWrapper' — class name attribute"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__name__.__eq__
  args: ["TextWrapper"]
  expected: true

invariant textwrap_extra17.TextWrapper.module:
  description: "textwrap.TextWrapper.__module__ == 'textwrap' — TextWrapper defined in textwrap module"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# TextWrapper base class — __bases__[0].__name__
#
# No prior spec verifies TextWrapper.__bases__[0].__name__ == 'object' as a
# standalone invariant. TextWrapper inherits directly from object with no
# intermediate base class.
# Verified: textwrap.TextWrapper.__bases__[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant textwrap_extra17.TextWrapper.bases_object:
  description: "textwrap.TextWrapper.__bases__[0].__name__ == 'object' — TextWrapper inherits from object"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function qualnames — wrap, fill, shorten, indent, dedent
#
# For a module-level function the __qualname__ equals the simple function name.
# No prior spec verifies wrap.__qualname__, fill.__qualname__, shorten.__qualname__,
# indent.__qualname__, or dedent.__qualname__ individually as standalone invariants.
# All verified at runtime.
# ---------------------------------------------------------------------------

invariant textwrap_extra17.wrap.qualname:
  description: "textwrap.wrap.__qualname__ == 'wrap' — module-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: wrap.__qualname__.__eq__
  args: ["wrap"]
  expected: true

invariant textwrap_extra17.fill.qualname:
  description: "textwrap.fill.__qualname__ == 'fill' — module-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: fill.__qualname__.__eq__
  args: ["fill"]
  expected: true

invariant textwrap_extra17.shorten.qualname:
  description: "textwrap.shorten.__qualname__ == 'shorten' — module-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: shorten.__qualname__.__eq__
  args: ["shorten"]
  expected: true

invariant textwrap_extra17.indent.qualname:
  description: "textwrap.indent.__qualname__ == 'indent' — module-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: indent.__qualname__.__eq__
  args: ["indent"]
  expected: true

invariant textwrap_extra17.dedent.qualname:
  description: "textwrap.dedent.__qualname__ == 'dedent' — module-level function qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: dedent.__qualname__.__eq__
  args: ["dedent"]
  expected: true

# ---------------------------------------------------------------------------
# Table: TextWrapper class identity — __name__, __module__, base class
#
# Groups the three TextWrapper class identity vectors in one indexed table.
# ---------------------------------------------------------------------------

table textwrap_extra17.TextWrapper_identity:
  description: "textwrap.TextWrapper class identity — __name__, __module__, base class"
  kind: python_call_eq
  category: class_identity
  columns: [id, function, args, expected, description]
  rows:
    - [textwrap_extra17.TextWrapper_identity.name,
       TextWrapper.__name__.__eq__,
       ["TextWrapper"],
       true,
       "TextWrapper.__name__ == 'TextWrapper'"]
    - [textwrap_extra17.TextWrapper_identity.module,
       TextWrapper.__module__.__eq__,
       ["textwrap"],
       true,
       "TextWrapper.__module__ == 'textwrap'"]
    - [textwrap_extra17.TextWrapper_identity.bases_object,
       TextWrapper.__bases__[0].__name__.__eq__,
       ["object"],
       true,
       "TextWrapper.__bases__[0].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# Table: module-level function qualnames — wrap, fill, shorten, indent, dedent
#
# Groups all five qualname checks in one indexed table.
# ---------------------------------------------------------------------------

table textwrap_extra17.function_qualnames:
  description: "textwrap module-level function __qualname__ identity"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [textwrap_extra17.function_qualnames.wrap,
       wrap.__qualname__.__eq__,
       ["wrap"],
       true,
       "wrap.__qualname__ == 'wrap'"]
    - [textwrap_extra17.function_qualnames.fill,
       fill.__qualname__.__eq__,
       ["fill"],
       true,
       "fill.__qualname__ == 'fill'"]
    - [textwrap_extra17.function_qualnames.shorten,
       shorten.__qualname__.__eq__,
       ["shorten"],
       true,
       "shorten.__qualname__ == 'shorten'"]
    - [textwrap_extra17.function_qualnames.indent,
       indent.__qualname__.__eq__,
       ["indent"],
       true,
       "indent.__qualname__ == 'indent'"]
    - [textwrap_extra17.function_qualnames.dedent,
       dedent.__qualname__.__eq__,
       ["dedent"],
       true,
       "dedent.__qualname__ == 'dedent'"]
