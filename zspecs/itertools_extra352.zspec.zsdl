spec: itertools_extra352
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "itertools.chain().__class__.__name__ == 'chain' — instance of chain yields its C type name. Verified with Python 3.14.3."
    - "itertools.count().__class__.__name__ == 'count' — verified with Python 3.14.3."
    - "itertools.cycle([]).__class__.__name__ == 'cycle' — verified with Python 3.14.3."
    - "itertools.repeat(1).__class__.__name__ == 'repeat' — verified with Python 3.14.3."
    - "itertools.repeat(1, 3).__class__.__name__ == 'repeat' — verified with Python 3.14.3."
    - "itertools.accumulate([]).__class__.__name__ == 'accumulate' — verified with Python 3.14.3."
    - "itertools.groupby([]).__class__.__name__ == 'groupby' — verified with Python 3.14.3."
    - "itertools.pairwise([]).__class__.__name__ == 'pairwise' — pairwise added in Python 3.10. Verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools instance __class__.__name__ for core types
#
# itertools.chain().__class__.__name__ == 'chain'
# itertools.count().__class__.__name__ == 'count'
# itertools.cycle([]).__class__.__name__ == 'cycle'
# itertools.repeat(1).__class__.__name__ == 'repeat'
# itertools.accumulate([]).__class__.__name__ == 'accumulate'
#
# When instances of C extension types are created, __class__.__name__
# equals the simple type name. This mirrors the type's own __name__.
# ---------------------------------------------------------------------------

table itertools_extra352.instance_class_name_core:
  description: "itertools instance __class__.__name__ for chain/count/cycle/repeat/accumulate; each instance's __class__.__name__ equals the simple C type name; new to extra352"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsinst352

  columns: [id, function, args, expected, description]
  rows:
    - [chain_instance_class_name_eq,
       "chain().__class__.__name__.__eq__",
       ["chain"],
       true,
       "itertools.chain().__class__.__name__.__eq__('chain') == True — calling chain() creates an instance of the C extension type itertools.chain; the instance's __class__ is the chain type; __class__.__name__ is 'chain'; str.__eq__('chain') returns True; new to extra352"]
    - [count_instance_class_name_eq,
       "count().__class__.__name__.__eq__",
       ["count"],
       true,
       "itertools.count().__class__.__name__.__eq__('count') == True — calling count() with no arguments creates a count iterator starting from 0; the instance's __class__.__name__ is 'count'; str.__eq__('count') returns True; new to extra352"]
    - [cycle_instance_class_name_eq,
       "cycle([]).__class__.__name__.__eq__",
       ["cycle"],
       true,
       "itertools.cycle([]).__class__.__name__.__eq__('cycle') == True — calling cycle([]) creates a cycle iterator over an empty iterable; the instance's __class__.__name__ is 'cycle'; str.__eq__('cycle') returns True; new to extra352"]
    - [repeat_instance_class_name_eq,
       "repeat(1).__class__.__name__.__eq__",
       ["repeat"],
       true,
       "itertools.repeat(1).__class__.__name__.__eq__('repeat') == True — calling repeat(1) creates an infinite repeat iterator yielding 1; the instance's __class__.__name__ is 'repeat'; str.__eq__('repeat') returns True; new to extra352"]
    - [accumulate_instance_class_name_eq,
       "accumulate([]).__class__.__name__.__eq__",
       ["accumulate"],
       true,
       "itertools.accumulate([]).__class__.__name__.__eq__('accumulate') == True — calling accumulate([]) creates an accumulate iterator over an empty iterable; the instance's __class__.__name__ is 'accumulate'; str.__eq__('accumulate') returns True; new to extra352"]

# ---------------------------------------------------------------------------
# Table 2: itertools instance __class__.__name__ for repeat with times, groupby, pairwise
#
# itertools.repeat(1, 3).__class__.__name__ == 'repeat'
# itertools.groupby([]).__class__.__name__ == 'groupby'
# itertools.pairwise([]).__class__.__name__ == 'pairwise'
#
# repeat with a finite count still returns a repeat instance.
# pairwise was added in Python 3.10 (requires version >=3.10).
# ---------------------------------------------------------------------------

table itertools_extra352.instance_class_name_extended:
  description: "itertools instance __class__.__name__ for repeat(1,3)/groupby/pairwise; pairwise requires Python 3.10+; new to extra352"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsinst352

  columns: [id, function, args, expected, description]
  rows:
    - [repeat_times_instance_class_name_eq,
       "repeat(1, 3).__class__.__name__.__eq__",
       ["repeat"],
       true,
       "itertools.repeat(1, 3).__class__.__name__.__eq__('repeat') == True — calling repeat(1, 3) creates a finite repeat iterator that yields 1 exactly 3 times; even with a times argument the instance type is still repeat; __class__.__name__ is 'repeat'; str.__eq__('repeat') returns True; new to extra352"]
    - [groupby_instance_class_name_eq,
       "groupby([]).__class__.__name__.__eq__",
       ["groupby"],
       true,
       "itertools.groupby([]).__class__.__name__.__eq__('groupby') == True — calling groupby([]) creates a groupby iterator over an empty iterable; the instance's __class__.__name__ is 'groupby'; str.__eq__('groupby') returns True; new to extra352"]
    - [pairwise_instance_class_name_eq,
       "pairwise([]).__class__.__name__.__eq__",
       ["pairwise"],
       true,
       "itertools.pairwise([]).__class__.__name__.__eq__('pairwise') == True — pairwise was added in Python 3.10 as a C extension type; calling pairwise([]) creates an instance over an empty iterable; __class__.__name__ is 'pairwise'; str.__eq__('pairwise') returns True; new to extra352"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra352
# ---------------------------------------------------------------------------

invariant itertools_extra352.chain_instance_class:
  description: "itertools.chain().__class__.__name__ == 'chain' — instance class name matches C type name; new to extra352"
  kind: python_call_eq
  function: chain().__class__.__name__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra352.count_instance_class:
  description: "itertools.count().__class__.__name__ == 'count' — instance class name matches C type name; new to extra352"
  kind: python_call_eq
  function: count().__class__.__name__.__eq__
  args: ["count"]
  expected: true

invariant itertools_extra352.cycle_instance_class:
  description: "itertools.cycle([]).__class__.__name__ == 'cycle' — instance class name matches C type name; new to extra352"
  kind: python_call_eq
  function: cycle([]).__class__.__name__.__eq__
  args: ["cycle"]
  expected: true

invariant itertools_extra352.repeat_instance_class:
  description: "itertools.repeat(1).__class__.__name__ == 'repeat' — instance class name matches C type name; new to extra352"
  kind: python_call_eq
  function: repeat(1).__class__.__name__.__eq__
  args: ["repeat"]
  expected: true

invariant itertools_extra352.repeat_times_instance_class:
  description: "itertools.repeat(1, 3).__class__.__name__ == 'repeat' — finite repeat still yields repeat instance; new to extra352"
  kind: python_call_eq
  function: repeat(1, 3).__class__.__name__.__eq__
  args: ["repeat"]
  expected: true

invariant itertools_extra352.accumulate_instance_class:
  description: "itertools.accumulate([]).__class__.__name__ == 'accumulate' — instance class name matches C type name; new to extra352"
  kind: python_call_eq
  function: accumulate([]).__class__.__name__.__eq__
  args: ["accumulate"]
  expected: true

invariant itertools_extra352.groupby_instance_class:
  description: "itertools.groupby([]).__class__.__name__ == 'groupby' — instance class name matches C type name; new to extra352"
  kind: python_call_eq
  function: groupby([]).__class__.__name__.__eq__
  args: ["groupby"]
  expected: true

invariant itertools_extra352.pairwise_instance_class:
  description: "itertools.pairwise([]).__class__.__name__ == 'pairwise' — pairwise added in Python 3.10; instance class name matches C type name; new to extra352"
  kind: python_call_eq
  function: pairwise([]).__class__.__name__.__eq__
  args: ["pairwise"]
  expected: true
