spec: header_case
version: ">=2.0.0"
backend: node(header-case)

docs: https://www.npmjs.com/package/header-case

provenance:
  derived_from:
    - "header-case README — https://www.npmjs.com/package/header-case"
    - "Test vectors verified with header-case@2.0.4 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "header-case source"
  notes:
    - "header-case exports {headerCase} named function."
    - "headerCase converts string to Header-Case (title case with dashes)."
    - "Used for HTTP header name formatting."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns Header-Cased string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table header_case.header_case:
  kind: node_module_call_eq
  function: headerCase
  category: headerCase
  id_prefix: hcase

  columns: [id, args, expected]
  rows:
    - [space,   ["content type"],   "Content-Type"]
    - [camel,   ["contentType"],    "Content-Type"]
    - [multi,   ["foo bar baz"],    "Foo-Bar-Baz"]
    - [dash,    ["foo-bar"],        "Foo-Bar"]

