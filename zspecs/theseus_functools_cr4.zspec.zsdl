spec: theseus_functools_cr4
version: ">=3.9"
backend: python_cleanroom(theseus_functools_cr4)
blocks: functools

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html"
  notes:
    - "Clean-room extended functools utilities. Do NOT import functools."
    - "reduce(function, iterable, initializer=None): left-fold over iterable."
    - "partial(func, *args, **kwargs): return new callable with some args pre-filled."
    - "functools4_reduce(): reduce(lambda a, b: a+b, [1,2,3,4]) == 10."
    - "functools4_partial_kwargs(): partial(int, base=16)('ff') == 255."
    - "functools4_partial_basic(): partial(pow, 2)(10) == 1024 (2**10)."
    - "Zero-arg invariant signatures — def functools4_reduce(): return hardcoded_result"
    - "reduce: apply function cumulatively to sequence; reduce(f,[a,b,c]) = f(f(a,b),c)."
    - "partial: freeze positional args and keyword args; partial(f, a)(b) == f(a, b)."
    - "Export: reduce(func, iterable[, init]), partial(func, *args, **kw), wraps, lru_cache."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_functools_cr4.reduce:
  description: "reduce(lambda a,b: a+b, [1,2,3,4]) == 10"
  category: reduce
  kind: python_call_eq
  function: functools4_reduce
  args: []
  expected: 10

invariant theseus_functools_cr4.partial_kwargs:
  description: "partial(int, base=16)('ff') == 255"
  category: partial
  kind: python_call_eq
  function: functools4_partial_kwargs
  args: []
  expected: 255

invariant theseus_functools_cr4.partial_basic:
  description: "partial(pow, 2)(10) == 1024"
  category: partial
  kind: python_call_eq
  function: functools4_partial_basic
  args: []
  expected: 1024
