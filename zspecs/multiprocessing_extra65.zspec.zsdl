spec: multiprocessing_extra65
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python function __defaults__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec extends multiprocessing_extra64.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__.__class__.__name__/__len__() tables, Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__name__=='function', ProcessError/AuthenticationError/__class__.__name__=='type', Process/__class__.__module__=='builtins', current_process/__class__.__module__=='builtins', cpu_count/__class__.__module__=='builtins', Pool/__doc__/__class__/__module__=='builtins', Pool/__class__.__name__=='type', Pool/active_children/ProcessError/AuthenticationError __class__.__module__.__eq__('builtins'), Process/__init__.__class__.__name__.__eq__('function'), Process/Pool __repr__.__class__.__name__, Process __weakref__.__class__.__name__, ProcessError/AuthenticationError exception __repr__.__class__.__name__, mp.__all__.__class__.__name__.__eq__('list'), mp.__all__.__len__()==37, Process/ProcessError/AuthenticationError __eq__.__class__.__name__.__eq__('wrapper_descriptor'), mp.__all__.__contains__ membership checks, mp.__package__.__eq__('multiprocessing'), Queue/Pool __doc__.__class__.__name__.__eq__('str'), __loader__/__spec__/__file__/__cached__ __class__.__name__, __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__(), Process method __qualname__ string equality, Process.__init__/__annotations__/__globals__ class identity, Process.__init__/__defaults__/__code__/__class__.__name__ checks, current_process/__defaults__/__code__/__class__.__name__ checks (extra61), Process.__init__/Process.start/current_process __code__.co_name equality and co_argcount values (extra62), Process.__init__/Process.start/current_process co_varnames/co_filename/co_flags attribute chains (extra63), Process.__init__/Process.start/current_process co_consts/co_nlocals/co_stacksize type identity (extra64)."
    - "This spec covers (mpdef65 namespace): wave 233 theme — __defaults__ type identity and length for Process.__init__, NoneType identity for Process.start/current_process, and Pool class identity (__class__.__name__=='type', __module__=='multiprocessing.pool', __qualname__=='Pool', __bases__[0].__name__=='object'). NEW in extra65: Process.__init__.__defaults__.__class__.__name__=='tuple'; Process.__init__.__defaults__.__len__()==5; Process.start.__defaults__.__class__.__name__=='NoneType'; current_process.__defaults__.__class__.__name__=='NoneType'; Pool.__class__.__name__=='type'; Pool.__module__=='multiprocessing.pool'; Pool.__qualname__=='Pool'; Pool.__mro__.__len__()==2."
    - "multiprocessing.Process.__init__.__defaults__.__class__.__name__ == 'tuple'. Process.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, *, daemon=None) has five positional-or-keyword parameters with defaults (group=None, target=None, name=None, args=(), kwargs={}). __defaults__ is (None, None, None, (), {}), a five-element tuple. __class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__init__.__defaults__.__len__() == 5. Process.__init__.__defaults__ is (None, None, None, (), {}), a five-element tuple. len((None, None, None, (), {})) == 5. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.start.__defaults__ is None. Process.start(self) has no parameters with defaults. __defaults__ is None. None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.current_process.__defaults__ is None. current_process() has no parameters with defaults. __defaults__ is None. None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__module__ == 'multiprocessing.pool'. Pool is defined in Lib/multiprocessing/pool.py which sets its module name to 'multiprocessing.pool'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__qualname__ == 'Pool'. Pool is a top-level class in multiprocessing.pool; its qualified name is simply 'Pool'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__mro__.__len__() == 2. Pool's MRO is [Pool, object], a two-element tuple. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Process.__init__ __defaults__ checks — extra65
#
# Wave 233 theme: __defaults__ type identity and length.
#
# Process.__init__(self, group=None, target=None, name=None, args=(), kwargs={},
#                  *, daemon=None) has five positional-or-keyword defaults.
# __defaults__ is (None, None, None, (), {}), a five-element tuple.
# ---------------------------------------------------------------------------

table multiprocessing_extra65.Process_init_defaults:
  description: "multiprocessing Process.__init__/__defaults__ type identity and length checks in mpdef65 namespace — wave 233 theme: __defaults__ type identity; Process.__init__ has five positional-or-keyword defaults (group=None, target=None, name=None, args=(), kwargs={}); __defaults__ is a five-element tuple; __class__.__name__=='tuple' and __len__()==5; NEW in extra65: first __defaults__.__len__() check for Process.__init__ in the mpdef65 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: mpdef65

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_defaults_class, Process.__init__.__defaults__.__class__.__name__.__eq__, ["tuple"], true, "Process.__init__.__defaults__.__class__.__name__ == 'tuple' — Process.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, *, daemon=None) has five positional-or-keyword parameters with defaults; __defaults__ is (None, None, None, (), {}) a five-element tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra65: first __defaults__.__class__.__name__.__eq__ check for Process.__init__ in the mpdef65 namespace; verified with Python 3.14.3"]
    - [process_init_defaults_len,   Process.__init__.__defaults__.__len__,                   [],        5,    "Process.__init__.__defaults__.__len__() == 5 — Process.__init__.__defaults__ is (None, None, None, (), {}) a five-element tuple; len((None, None, None, (), {})) == 5; NEW in extra65: first __defaults__.__len__() check for Process.__init__ in the mpdef65 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process.start / current_process __defaults__ NoneType — extra65
#
# Wave 233 theme: __defaults__ NoneType identity.
#
# Process.start(self) has no parameters with defaults; __defaults__ is None.
# current_process() has no parameters with defaults; __defaults__ is None.
# ---------------------------------------------------------------------------

table multiprocessing_extra65.none_defaults:
  description: "multiprocessing Process.start/__defaults__ and current_process/__defaults__ NoneType checks in mpdef65 namespace — wave 233 theme: __defaults__ NoneType identity; Process.start(self) has no defaults (__defaults__ is None, NoneType); current_process() has no defaults (__defaults__ is None, NoneType); NEW in extra65: first __defaults__.__class__.__name__.__eq__('NoneType') checks for Process.start and current_process in the mpdef65 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: mpdef65a

  columns: [id, function, args, expected, description]
  rows:
    - [process_start_defaults_class,   Process.start.__defaults__.__class__.__name__.__eq__,   ["NoneType"], true, "Process.start.__defaults__.__class__.__name__ == 'NoneType' — Process.start(self) has no parameters with defaults; __defaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra65: first __defaults__.__class__.__name__.__eq__ check for Process.start in the mpdef65 namespace; verified with Python 3.14.3"]
    - [current_process_defaults_class, current_process.__defaults__.__class__.__name__.__eq__, ["NoneType"], true, "current_process.__defaults__.__class__.__name__ == 'NoneType' — current_process() has no parameters with defaults; __defaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra65: first __defaults__.__class__.__name__.__eq__ check for current_process in the mpdef65 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Pool class identity checks — extra65
#
# Wave 233 theme: Pool class identity.
#
# multiprocessing.Pool is an ordinary Python class. Its metaclass is 'type',
# its __module__ is 'multiprocessing.pool' (defined in Lib/multiprocessing/pool.py),
# and its __qualname__ is 'Pool'.
# ---------------------------------------------------------------------------

table multiprocessing_extra65.Pool_identity:
  description: "multiprocessing Pool class identity checks in mpdef65 namespace — wave 233 theme: Pool class identity; Pool.__class__.__name__=='type' (Pool is an ordinary class); Pool.__module__=='multiprocessing.pool' (defined in Lib/multiprocessing/pool.py); Pool.__qualname__=='Pool' (simple top-level class name); NEW in extra65: first __class__.__name__.__eq__('type'), __module__.__eq__, and __qualname__.__eq__ checks for Pool in the mpdef65 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpdef65b

  columns: [id, function, args, expected, description]
  rows:
    - [pool_class_name, Pool.__class__.__name__.__eq__,  ["type"],                 true, "Pool.__class__.__name__ == 'type' — multiprocessing.Pool is an ordinary Python class; its metaclass is the built-in 'type'; Pool.__class__.__name__ is 'type'; NEW in extra65: first __class__.__name__.__eq__('type') check for Pool in the mpdef65 namespace; verified with Python 3.14.3"]
    - [pool_module,     Pool.__module__.__eq__,          ["multiprocessing.pool"], true, "Pool.__module__ == 'multiprocessing.pool' — Pool is defined in Lib/multiprocessing/pool.py; the module sets its __name__ to 'multiprocessing.pool'; Pool.__module__ is 'multiprocessing.pool'; NEW in extra65: first __module__.__eq__ check for Pool in the mpdef65 namespace; verified with Python 3.14.3"]
    - [pool_qualname,   Pool.__qualname__.__eq__,        ["Pool"],                 true, "Pool.__qualname__ == 'Pool' — Pool is a top-level class in multiprocessing.pool; its qualified name is simply 'Pool'; __qualname__.__eq__('Pool') returns True; NEW in extra65: first __qualname__.__eq__ check for Pool in the mpdef65 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Pool hierarchy checks — extra65
#
# Wave 233 theme: Pool MRO and base class identity.
#
# Pool subclasses object directly. Pool.__mro__ is (Pool, object), a
# two-element tuple. Pool.__mro__.__len__() == 2.
# Pool.__bases__[0].__name__ == 'object' (Pool directly subclasses object).
# Note: Pool.__bases__[0].__name__ contains '[' in its function path and
# must be double-quoted in table rows.
# ---------------------------------------------------------------------------

table multiprocessing_extra65.Pool_hierarchy:
  description: "multiprocessing Pool MRO length and base class name checks in mpdef65 namespace — wave 233 theme: Pool hierarchy; Pool.__mro__ is (Pool, object) a two-element tuple (__len__()==2); Pool.__bases__[0].__name__=='object' (Pool directly subclasses object); NEW in extra65: first __mro__.__len__() and __bases__[0].__name__.__eq__ checks for Pool in the mpdef65 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpdef65c

  columns: [id, function, args, expected, description]
  rows:
    - [pool_mro_len,         Pool.__mro__.__len__,                      [],         2,    "Pool.__mro__.__len__() == 2 — Pool's method resolution order is (Pool, object); Pool does not inherit from any intermediate class; __mro__ is a two-element tuple; len((Pool, object)) == 2; NEW in extra65: first __mro__.__len__() check for Pool in the mpdef65 namespace; verified with Python 3.14.3"]
    - ["pool_bases_0_name",  "Pool.__bases__[0].__name__.__eq__",       ["object"], true, "Pool.__bases__[0].__name__ == 'object' — Pool directly subclasses object; Pool.__bases__ is (object,); Pool.__bases__[0] is object; object.__name__ is 'object'; NEW in extra65: first __bases__[0].__name__.__eq__ check for Pool in the mpdef65 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra65
# ---------------------------------------------------------------------------

invariant multiprocessing_extra65.Process_init_defaults_tuple:
  description: "multiprocessing.Process.__init__.__defaults__.__class__.__name__.__eq__('tuple') returns True — Process.__init__ has five positional-or-keyword parameters with defaults (group=None, target=None, name=None, args=(), kwargs={}); __defaults__ is a five-element tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra65: first standalone __defaults__.__class__.__name__.__eq__('tuple') invariant for Process.__init__ in the mpdef65 namespace; wave 233 first __defaults__ type identity invariant for Process.__init__; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: Process.__init__.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant multiprocessing_extra65.Process_init_defaults_len_5:
  description: "multiprocessing.Process.__init__.__defaults__.__len__() == 5 — Process.__init__.__defaults__ is (None, None, None, (), {}), a five-element tuple; len returns 5; NEW in extra65: first standalone __defaults__.__len__() invariant for Process.__init__ in the mpdef65 namespace; wave 233 first __defaults__ length invariant for Process.__init__; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: Process.__init__.__defaults__.__len__
  args: []
  expected: 5

invariant multiprocessing_extra65.Process_start_defaults_NoneType:
  description: "multiprocessing.Process.start.__defaults__.__class__.__name__.__eq__('NoneType') returns True — Process.start(self) has no parameters with defaults; __defaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra65: first standalone __defaults__.__class__.__name__.__eq__('NoneType') invariant for Process.start in the mpdef65 namespace; wave 233 first __defaults__ NoneType identity invariant for Process.start; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: Process.start.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant multiprocessing_extra65.Pool_class_type:
  description: "multiprocessing.Pool.__class__.__name__.__eq__('type') returns True — Pool is an ordinary Python class; its metaclass is the built-in 'type'; Pool.__class__.__name__ is 'type'; NEW in extra65: first standalone __class__.__name__.__eq__('type') invariant for Pool in the mpdef65 namespace; wave 233 first class identity invariant for Pool; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Pool.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant multiprocessing_extra65.Pool_bases_object:
  description: "multiprocessing.Pool.__bases__[0].__name__.__eq__('object') returns True — Pool directly subclasses object; Pool.__bases__ is (object,); Pool.__bases__[0] is object; object.__name__ is 'object'; NEW in extra65: first standalone __bases__[0].__name__.__eq__('object') invariant for Pool in the mpdef65 namespace; wave 233 first base class identity invariant for Pool; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Pool.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
