spec: socket_extra2476
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "socket_extra.zspec.zsdl, socket_extra2.zspec.zsdl, and other pre-existing socket_extra files"
  notes:
    - "Theme: __contains__ and __getitem__ dict-presence — membership test and item access protocol checks in class __dict__."
    - "socket.socket does NOT define __contains__ or __getitem__ in its own __dict__; socket instances are not mappings or sequences."
    - "socket.socket IS a context manager: it defines __enter__ and __exit__ in its __dict__; that is the only container-like protocol it participates in."
    - "socket.socket defines a Python-level class (Lib/socket.py) that wraps the C-level _socket.socket; its __dict__ includes Python-implemented helpers (accept, close, makefile, sendfile, dup, detach, get_inheritable, set_inheritable) and context manager methods."
    - "Low-level network methods (bind, connect, listen, recv, send, fileno) are NOT in socket.socket.__dict__; they are defined on the underlying C type _socket.socket and inherited."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: socket.socket — __contains__ and __getitem__ absent
#
# socket.socket is the Python-level socket wrapper class. It does NOT define
# __contains__ or __getitem__ in its class __dict__. Socket instances are not
# mappings, sets, or sequences; membership testing and subscript access are
# not part of the socket API.
# ---------------------------------------------------------------------------

table socket_extra2476.socket_contains_getitem_absent:
  description: "socket.socket.__dict__: __contains__ and __getitem__ absent — socket is not a mapping or sequence; new to extra2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2476

  columns: [id, function, args, expected]
  rows:
    - ["sk2476-001", "socket.socket.__dict__.__contains__", ["__contains__"], false]
    - ["sk2476-002", "socket.socket.__dict__.__contains__", ["__getitem__"],  false]
    - ["sk2476-003", "socket.socket.__dict__.__contains__", ["__setitem__"],  false]
    - ["sk2476-004", "socket.socket.__dict__.__contains__", ["__delitem__"],  false]
    - ["sk2476-005", "socket.socket.__dict__.__contains__", ["__iter__"],     false]
    - ["sk2476-006", "socket.socket.__dict__.__contains__", ["__len__"],      false]

# ---------------------------------------------------------------------------
# Table 2: socket.socket — context manager protocol present (contrast)
#
# Unlike the absent __contains__/__getitem__, socket.socket DOES define the
# context manager protocol (__enter__/__exit__) in its own __dict__. This
# allows 'with socket.socket(...) as s:' usage. This table establishes the
# contrast: socket is a CM but not a container.
# ---------------------------------------------------------------------------

table socket_extra2476.socket_ctx_manager_present:
  description: "socket.socket.__dict__: __enter__ and __exit__ present — socket IS a context manager; contrasts with absent __contains__/__getitem__; new to extra2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2476

  columns: [id, function, args, expected]
  rows:
    - ["sk2476-007", "socket.socket.__dict__.__contains__", ["__enter__"],  true]
    - ["sk2476-008", "socket.socket.__dict__.__contains__", ["__exit__"],   true]
    - ["sk2476-009", "socket.socket.__dict__.__contains__", ["__init__"],   true]
    - ["sk2476-010", "socket.socket.__dict__.__contains__", ["__repr__"],   true]

# ---------------------------------------------------------------------------
# Table 3: socket.socket — Python-layer network helpers present in __dict__
#
# The Python-level socket.socket class defines helpers that augment the
# inherited C-level _socket.socket. These are own attributes of the Python
# wrapper class. Low-level primitives (bind, connect, recv, send, fileno)
# are inherited from _socket.socket and are NOT in socket.socket.__dict__.
# ---------------------------------------------------------------------------

table socket_extra2476.socket_python_helpers_present:
  description: "socket.socket.__dict__: Python-layer helpers present; low-level C-inherited methods absent; new to extra2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2476

  columns: [id, function, args, expected]
  rows:
    - ["sk2476-011", "socket.socket.__dict__.__contains__", ["accept"],          true]
    - ["sk2476-012", "socket.socket.__dict__.__contains__", ["close"],           true]
    - ["sk2476-013", "socket.socket.__dict__.__contains__", ["makefile"],        true]
    - ["sk2476-014", "socket.socket.__dict__.__contains__", ["sendfile"],        true]
    - ["sk2476-015", "socket.socket.__dict__.__contains__", ["dup"],             true]
    - ["sk2476-016", "socket.socket.__dict__.__contains__", ["detach"],          true]
    - ["sk2476-017", "socket.socket.__dict__.__contains__", ["get_inheritable"], true]
    - ["sk2476-018", "socket.socket.__dict__.__contains__", ["set_inheritable"], true]
    - ["sk2476-019", "socket.socket.__dict__.__contains__", ["bind"],            false]
    - ["sk2476-020", "socket.socket.__dict__.__contains__", ["connect"],         false]
