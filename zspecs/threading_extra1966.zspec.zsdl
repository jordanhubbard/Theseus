spec: threading_extra1966
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 578 (_extra1966): __enter__/__exit__, __aenter__/__aexit__, __del__ dict-presence checks."
    - "threading.Lock and threading.Condition and threading.Semaphore define __enter__ and __exit__ (context manager protocol)."
    - "threading.BoundedSemaphore does NOT define __enter__/__exit__ in its own __dict__ — it inherits from threading.Semaphore."
    - "threading.RLock is a factory function returning _thread.RLock; threading.RLock itself does NOT define __enter__/__exit__ in its __dict__."
    - "threading.Event, threading.Barrier, threading.Thread do NOT define __enter__ or __exit__."
    - "None of the threading types define __aenter__ or __aexit__ — threading is synchronous, no async context managers."
    - "None of the threading types define __del__ — no finalizer protocol in threading classes."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

table threading_extra1966.context_manager_enter:
  description: "threading types __enter__ dict-presence checks — Lock, Condition, Semaphore define it; others do not"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1966
  columns: [id, function, args, expected]
  rows:
    - ["th1966001", "threading.Lock.__dict__.__contains__",             ["__enter__"], true]
    - ["th1966002", "threading.Condition.__dict__.__contains__",        ["__enter__"], true]
    - ["th1966003", "threading.Semaphore.__dict__.__contains__",        ["__enter__"], true]
    - ["th1966004", "threading.RLock.__dict__.__contains__",            ["__enter__"], false]
    - ["th1966005", "threading.BoundedSemaphore.__dict__.__contains__", ["__enter__"], false]
    - ["th1966006", "threading.Event.__dict__.__contains__",            ["__enter__"], false]
    - ["th1966007", "threading.Barrier.__dict__.__contains__",          ["__enter__"], false]
    - ["th1966008", "threading.Thread.__dict__.__contains__",           ["__enter__"], false]

