    - ["th1966010", "threading.Condition.__dict__.__contains__",        ["__exit__"], true]
    - ["th1966011", "threading.Semaphore.__dict__.__contains__",        ["__exit__"], true]
    - ["th1966012", "threading.RLock.__dict__.__contains__",            ["__exit__"], false]
    - ["th1966013", "threading.BoundedSemaphore.__dict__.__contains__", ["__exit__"], false]
    - ["th1966014", "threading.Event.__dict__.__contains__",            ["__exit__"], false]
    - ["th1966015", "threading.Barrier.__dict__.__contains__",          ["__exit__"], false]
    - ["th1966016", "threading.Thread.__dict__.__contains__",           ["__exit__"], false]

