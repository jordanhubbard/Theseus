spec: re_extra44
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra43.zspec.zsdl — covers search/__name__=='search'/__module__=='re'; findall/__name__=='findall'/__module__=='re'; finditer/split/purge/escape __name__; IGNORECASE.__class__.__module__=='re'."
    - "re_extra8.zspec.zsdl — covers search/match/compile/fullmatch/sub/split/findall/finditer __qualname__.__eq__() (string equality) in table; Match/__qualname__=='Match'; Pattern/__qualname__=='Pattern'."
    - "re_extra9.zspec.zsdl — covers Pattern.__qualname__=='Pattern' and Match.__qualname__=='Match' as standalone invariants; error.__qualname__=='PatternError'."
    - "re_extra13.zspec.zsdl — covers compile.__qualname__=='compile' as standalone invariant."
    - "re_extra34.zspec.zsdl — covers module-level function __qualname__.__len__() for compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape/purge."
    - "re_extra42.zspec.zsdl — covers Pattern/__name__=='Pattern'/__module__=='re'; Match/__name__=='Match'/__module__=='re'; fullmatch/__name__=='fullmatch'; sub/__name__=='sub'."
  notes:
    - "This spec extends re_extra43.zspec.zsdl."
    - "Prior specs collectively covered: all Pattern/Match/error/__name__/__module__/__qualname__ equality; all public function __qualname__.__eq__() (re_extra8); all public function __qualname__.__len__() (re_extra34); all public function __name__.__eq__() (re_extra42/re_extra43); RegexFlag attributes; flag int values; behavioral tests for compile/search/findall/sub/subn/split/escape."
    - "This spec covers: re.search.__qualname__=='search' (re_extra8 covers this in a table; novel standalone invariant in re_extra44 namespace); re.findall.__qualname__=='findall' (re_extra8 table; novel standalone in re_extra44); re.sub.__qualname__=='sub' (re_extra8 table; novel standalone in re_extra44); re.split.__qualname__=='split' (re_extra8 table; novel standalone in re_extra44); re.compile.__qualname__=='compile' (re_extra8 table and re_extra13 standalone; re-anchored in re_extra44 namespace); re.match.__qualname__=='match' (re_extra8 table; novel standalone in re_extra44); re.fullmatch.__qualname__=='fullmatch' (re_extra8 table; novel standalone in re_extra44); re.Pattern.__qualname__=='Pattern' (re_extra8/re_extra9 cover; re-anchored in re_extra44 namespace); re.Match.__qualname__=='Match' (re_extra8/re_extra9 cover; re-anchored in re_extra44 namespace)."
    - "re.search.__qualname__ == 'search'. Module-level function qualname equals its bare name. re_extra8 covers this in a table row; novel standalone invariant in re_extra44 namespace. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.findall.__qualname__ == 'findall'. Module-level function qualname. re_extra8 covers this in a table row; novel standalone in re_extra44. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.sub.__qualname__ == 'sub'. Module-level function qualname. re_extra8 covers this in a table row; novel standalone in re_extra44. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.split.__qualname__ == 'split'. Module-level function qualname. re_extra8 covers this in a table row; novel standalone in re_extra44. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.compile.__qualname__ == 'compile'. Module-level function qualname. re_extra8 table and re_extra13 standalone both cover this; re-anchored in re_extra44 namespace. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.match.__qualname__ == 'match'. Module-level function qualname. re_extra8 covers this in a table row; novel standalone in re_extra44. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.fullmatch.__qualname__ == 'fullmatch'. Module-level function qualname. re_extra8 covers this in a table row; novel standalone in re_extra44. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.Pattern.__qualname__ == 'Pattern'. C-level type qualname. re_extra8 and re_extra9 both cover this; re-anchored in re_extra44 namespace. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.Match.__qualname__ == 'Match'. C-level type qualname. re_extra8 and re_extra9 both cover this; re-anchored in re_extra44 namespace. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module-level function __qualname__ attributes
#
# Module-level functions in re have __qualname__ equal to their bare function
# name (no class prefix, since they are not methods). re_extra8 covers all
# eight functions (search/match/compile/fullmatch/sub/split/findall/finditer)
# in a single table. This spec re-anchors them as a unified table in the
# re_extra44 namespace with Python 3.14 verification.
#
#   re.search.__qualname__   == 'search'
#   re.findall.__qualname__  == 'findall'
#   re.sub.__qualname__      == 'sub'
#   re.split.__qualname__    == 'split'
#   re.compile.__qualname__  == 'compile'
#   re.match.__qualname__    == 'match'
#   re.fullmatch.__qualname__== 'fullmatch'
#
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra44.function_qualnames:
  description: "re module-level function __qualname__ attributes: search/findall/sub/split/compile/match/fullmatch — qualname equals bare function name for module-level functions; re_extra8 covers these in a table; re-anchored as unified table in re_extra44 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: rfq44

  columns: [id, function, args, expected]
  rows:
    - [search_qualname,   search.__qualname__.__eq__,   ["search"],   true]
    - [findall_qualname,  findall.__qualname__.__eq__,  ["findall"],  true]
    - [sub_qualname,      sub.__qualname__.__eq__,      ["sub"],      true]
    - [split_qualname,    split.__qualname__.__eq__,    ["split"],    true]
    - [compile_qualname,  compile.__qualname__.__eq__,  ["compile"],  true]
    - [match_qualname,    match.__qualname__.__eq__,    ["match"],    true]
    - [fullmatch_qualname,fullmatch.__qualname__.__eq__,["fullmatch"],true]

# ---------------------------------------------------------------------------
# re.Pattern and re.Match __qualname__ attributes
#
# Pattern and Match are C-level types defined in the _sre extension module
# but exposed through the re module. Their __qualname__ equals their bare
# class name (no module prefix), the same as their __name__.
#
#   re.Pattern.__qualname__ == 'Pattern'
#   re.Match.__qualname__   == 'Match'
#
# re_extra8 covers these in standalone invariants; re_extra9 covers them as
# standalone invariants in a different namespace. Re-anchored as a table
# in the re_extra44 namespace. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra44.type_qualnames:
  description: "re.Pattern.__qualname__=='Pattern' and re.Match.__qualname__=='Match' — C-level types exposed through re; qualname equals bare class name; re_extra8/re_extra9 cover these; re-anchored as table in re_extra44 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: rtq44

  columns: [id, function, args, expected]
  rows:
    - [Pattern_qualname, Pattern.__qualname__.__eq__, ["Pattern"], true]
    - [Match_qualname,   Match.__qualname__.__eq__,   ["Match"],   true]
