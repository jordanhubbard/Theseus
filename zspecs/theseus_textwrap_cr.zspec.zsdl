spec: theseus_textwrap_cr
version: ">=3.8"
backend: python_cleanroom(theseus_textwrap_cr)
blocks: textwrap

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/textwrap.html"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "Clean-room textwrap module. Do NOT import textwrap."

error_model: python_exceptions

invariant theseus_textwrap_cr.textwrap2_wrap:
  description: "wrap() breaks long text into lines"
  category: behavior
  kind: python_call_eq
  function: textwrap2_wrap
  args: []
  expected: true

invariant theseus_textwrap_cr.textwrap2_dedent:
  description: "dedent() strips common leading whitespace"
  category: behavior
  kind: python_call_eq
  function: textwrap2_dedent
  args: []
  expected: true

invariant theseus_textwrap_cr.textwrap2_indent:
  description: "indent() adds prefix to each line"
  category: behavior
  kind: python_call_eq
  function: textwrap2_indent
  args: []
  expected: true
