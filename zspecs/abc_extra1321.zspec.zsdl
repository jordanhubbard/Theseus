spec: abc_extra1321
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 535 (_extra1321): focuses on __repr__ and __str__ method class checks for abc module objects."
    - "abc.ABCMeta.__repr__.__qualname__ == 'type.__repr__' — ABCMeta inherits __repr__ from type."
    - "abc.ABCMeta.__repr__.__class__.__name__ == 'wrapper_descriptor' — C-level slot from type."
    - "abc.ABC.__repr__.__qualname__ == 'object.__repr__' — ABC inherits __repr__ from object."
    - "abc.ABC.__repr__.__class__.__name__ == 'wrapper_descriptor' — C-level slot from object."
    - "abc.abstractmethod.__repr__.__qualname__ == 'function.__repr__' — abstractmethod is a class wrapping functions."
    - "abc.abstractmethod.__repr__.__class__.__name__ == 'method-wrapper' — bound method on the abstractmethod instance."
    - "All abc classes inherit __str__ from object — wrapper_descriptor or method-wrapper."
    - "repr() of class and metaclass objects is always str."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra1321.repr_qualnames:
  description: "abc module objects: __repr__ qualname checks — ABCMeta inherits from type, ABC from object, abstractmethod from function"
  kind: python_call_eq
  category: identity
  id_prefix: ab1321rq
  columns: [id, function, args, expected]
  rows:
    - [ab1321rq001, abc.ABCMeta.__repr__.__qualname__.__eq__,      ["type.__repr__"],     true]
    - [ab1321rq002, abc.ABC.__repr__.__qualname__.__eq__,          ["object.__repr__"],   true]
    - [ab1321rq003, abc.abstractmethod.__repr__.__qualname__.__eq__,["function.__repr__"], true]
    - [ab1321rq004, abc.ABCMeta.__str__.__qualname__.__eq__,       ["object.__str__"],    true]
    - [ab1321rq005, abc.ABC.__str__.__qualname__.__eq__,           ["object.__str__"],    true]
    - [ab1321rq006, abc.abstractmethod.__str__.__qualname__.__eq__,["object.__str__"],    true]

table abc_extra1321.repr_class_names:
  description: "abc module objects: __repr__ method class checks — wrapper_descriptor for types/classes, method-wrapper for abstractmethod"
  kind: python_call_eq
  category: identity
  id_prefix: ab1321rc
  columns: [id, function, args, expected]
  rows:
    - [ab1321rc001, abc.ABCMeta.__repr__.__class__.__name__.__eq__,       ["wrapper_descriptor"], true]
    - [ab1321rc002, abc.ABC.__repr__.__class__.__name__.__eq__,           ["wrapper_descriptor"], true]
    - [ab1321rc003, abc.abstractmethod.__repr__.__class__.__name__.__eq__,["method-wrapper"],     true]
    - [ab1321rc004, abc.ABCMeta.__str__.__class__.__name__.__eq__,        ["wrapper_descriptor"], true]
    - [ab1321rc005, abc.ABC.__str__.__class__.__name__.__eq__,            ["wrapper_descriptor"], true]
    - [ab1321rc006, abc.abstractmethod.__str__.__class__.__name__.__eq__, ["method-wrapper"],     true]

table abc_extra1321.qualname_is_str:
  description: "abc module: __repr__.__qualname__ is always a str — qualname.__class__.__name__ == 'str'"
  kind: python_call_eq
  category: identity
  id_prefix: ab1321qs
  columns: [id, function, args, expected]
  rows:
    - [ab1321qs001, abc.ABCMeta.__repr__.__qualname__.__class__.__name__.__eq__,       ["str"], true]
    - [ab1321qs002, abc.ABC.__repr__.__qualname__.__class__.__name__.__eq__,           ["str"], true]
    - [ab1321qs003, abc.abstractmethod.__repr__.__qualname__.__class__.__name__.__eq__,["str"], true]
    - [ab1321qs004, abc.ABCMeta.__str__.__qualname__.__class__.__name__.__eq__,        ["str"], true]
    - [ab1321qs005, abc.ABC.__str__.__qualname__.__class__.__name__.__eq__,            ["str"], true]
    - [ab1321qs006, abc.abstractmethod.__str__.__qualname__.__class__.__name__.__eq__, ["str"], true]
