spec: pdb_extra2
version: ">=3.9"
backend: python_module(pdb)

docs: https://docs.python.org/3/library/pdb.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pdb.html — Python pdb module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pdb.py"
  notes:
    - "Covers Pdb class name/module and top-level function __name__ attributes not duplicated from pdb.zspec.zsdl or pdb_extra.zspec.zsdl."
    - "Pdb.__name__ == 'Pdb' and Pdb.__module__ == 'pdb' are the primary class identity invariants."
    - "run, runcall, post_mortem, set_trace, pm are all module-level public functions in pdb."
    - "These __name__ checks complement the table in pdb.zspec.zsdl by providing standalone invariants usable in isolation."
    - "Pdb.__qualname__ == 'Pdb' — top-level class, so qualname equals name."
    - "run.__module__ == 'pdb' — all public functions are defined in pdb, not imported from bdb."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pdb class — name, module, and qualname
# ---------------------------------------------------------------------------

invariant pdb_extra2.Pdb.name:
  description: "pdb.Pdb.__name__ == 'Pdb'"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__name__.__eq__
  args: ["Pdb"]
  expected: true

invariant pdb_extra2.Pdb.module:
  description: "pdb.Pdb.__module__ == 'pdb'"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__module__.__eq__
  args: ["pdb"]
  expected: true

invariant pdb_extra2.Pdb.qualname:
  description: "pdb.Pdb.__qualname__ == 'Pdb' — top-level class, qualname equals name"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__qualname__.__eq__
  args: ["Pdb"]
  expected: true

# ---------------------------------------------------------------------------
# Public API function __name__ checks — standalone invariants
# ---------------------------------------------------------------------------

invariant pdb_extra2.functions.run:
  description: "pdb.run.__name__ == 'run'"
  category: functions
  kind: python_call_eq
  function: run.__name__.__eq__
  args: ["run"]
  expected: true

invariant pdb_extra2.functions.runcall:
  description: "pdb.runcall.__name__ == 'runcall'"
  category: functions
  kind: python_call_eq
  function: runcall.__name__.__eq__
  args: ["runcall"]
  expected: true

invariant pdb_extra2.functions.post_mortem:
  description: "pdb.post_mortem.__name__ == 'post_mortem'"
  category: functions
  kind: python_call_eq
  function: post_mortem.__name__.__eq__
  args: ["post_mortem"]
  expected: true

invariant pdb_extra2.functions.set_trace:
  description: "pdb.set_trace.__name__ == 'set_trace'"
  category: functions
  kind: python_call_eq
  function: set_trace.__name__.__eq__
  args: ["set_trace"]
  expected: true

invariant pdb_extra2.functions.pm:
  description: "pdb.pm.__name__ == 'pm'"
  category: functions
  kind: python_call_eq
  function: pm.__name__.__eq__
  args: ["pm"]
  expected: true

# ---------------------------------------------------------------------------
# Public API function __module__ checks — all defined in pdb
# ---------------------------------------------------------------------------

invariant pdb_extra2.function_modules.run:
  description: "pdb.run.__module__ == 'pdb'"
  category: function_modules
  kind: python_call_eq
  function: run.__module__.__eq__
  args: ["pdb"]
  expected: true

invariant pdb_extra2.function_modules.runcall:
  description: "pdb.runcall.__module__ == 'pdb'"
  category: function_modules
  kind: python_call_eq
  function: runcall.__module__.__eq__
  args: ["pdb"]
  expected: true

invariant pdb_extra2.function_modules.post_mortem:
  description: "pdb.post_mortem.__module__ == 'pdb'"
  category: function_modules
  kind: python_call_eq
  function: post_mortem.__module__.__eq__
  args: ["pdb"]
  expected: true

invariant pdb_extra2.function_modules.set_trace:
  description: "pdb.set_trace.__module__ == 'pdb'"
  category: function_modules
  kind: python_call_eq
  function: set_trace.__module__.__eq__
  args: ["pdb"]
  expected: true

invariant pdb_extra2.function_modules.pm:
  description: "pdb.pm.__module__ == 'pdb'"
  category: function_modules
  kind: python_call_eq
  function: pm.__module__.__eq__
  args: ["pdb"]
  expected: true
