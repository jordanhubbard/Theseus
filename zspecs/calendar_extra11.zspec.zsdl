spec: calendar_extra11
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
  notes:
    - "This spec extends calendar.zspec.zsdl and calendar_extra through calendar_extra10.zspec.zsdl."
    - "calendar_extra7 covers: Calendar/__qualname__; TextCalendar/__name__/__bases__; HTMLCalendar/__name__/__bases__; isleap; leapdays; monthrange; firstweekday/__module__; timegm/__module__."
    - "calendar_extra9 covers: TextCalendar/__module__/__qualname__; HTMLCalendar/__module__/__qualname__; MRO lengths."
    - "calendar_extra10 covers: Calendar/TextCalendar/HTMLCalendar __qualname__ standalone; Calendar.__module__; base class checks; isleap truth-table."
    - "NEW in extra11 — Axis 1: TextCalendar.__name__, HTMLCalendar.__name__, Calendar.__name__ as standalone extra11-namespace invariants."
    - "NEW in extra11 — Axis 2: month_name.__class__.__name__ == '_localized_month' and month_abbr.__class__.__name__ == '_localized_month' — module-level sequence objects are _localized_month instances."
    - "NEW in extra11 — Axis 3: day_name.__class__.__name__ == '_localized_day' — module-level sequence object is a _localized_day instance."
    - "NEW in extra11 — Axis 4: MONDAY == 0 and SUNDAY == 6 as standalone invariants."
    - "calendar.TextCalendar.__name__ == 'TextCalendar' — verified Python 3.12."
    - "calendar.HTMLCalendar.__name__ == 'HTMLCalendar' — verified Python 3.12."
    - "calendar.Calendar.__name__ == 'Calendar' — verified Python 3.12."
    - "calendar.month_name.__class__.__name__ == '_localized_month' — verified Python 3.12."
    - "calendar.month_abbr.__class__.__name__ == '_localized_month' — verified Python 3.12."
    - "calendar.day_name.__class__.__name__ == '_localized_day' — verified Python 3.12."
    - "calendar.MONDAY == 0 — verified Python 3.12."
    - "calendar.SUNDAY == 6 — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ for Calendar, TextCalendar, HTMLCalendar
#
# calendar_extra7 covers TextCalendar.__name__ and HTMLCalendar.__name__.
# This spec anchors all three class __name__ values as a table in the
# extra11 namespace, including Calendar.__name__ not yet tabled here.
# ---------------------------------------------------------------------------

table calendar_extra11.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Calendar,      Calendar.__name__.__eq__,      ["Calendar"],      true]
    - [TextCalendar,  TextCalendar.__name__.__eq__,  ["TextCalendar"],  true]
    - [HTMLCalendar,  HTMLCalendar.__name__.__eq__,  ["HTMLCalendar"],  true]

# ---------------------------------------------------------------------------
# month_name and month_abbr are _localized_month instances
#
# calendar.month_name and calendar.month_abbr are locale-aware sequence
# objects. Their type is the private _localized_month class defined in
# Lib/calendar.py. This is confirmed by __class__.__name__.
# ---------------------------------------------------------------------------

invariant calendar_extra11.month_name.class_name:
  description: "calendar.month_name.__class__.__name__ == '_localized_month' — locale-aware month names sequence"
  category: class_instances
  kind: python_call_eq
  function: month_name.__class__.__name__.__eq__
  args: ["_localized_month"]
  expected: true

invariant calendar_extra11.month_abbr.class_name:
  description: "calendar.month_abbr.__class__.__name__ == '_localized_month' — locale-aware month abbreviations sequence"
  category: class_instances
  kind: python_call_eq
  function: month_abbr.__class__.__name__.__eq__
  args: ["_localized_month"]
  expected: true

# ---------------------------------------------------------------------------
# day_name is a _localized_day instance
#
# calendar.day_name is a locale-aware sequence of weekday names. Its type
# is the private _localized_day class defined in Lib/calendar.py.
# ---------------------------------------------------------------------------

invariant calendar_extra11.day_name.class_name:
  description: "calendar.day_name.__class__.__name__ == '_localized_day' — locale-aware day names sequence"
  category: class_instances
  kind: python_call_eq
  function: day_name.__class__.__name__.__eq__
  args: ["_localized_day"]
  expected: true

# ---------------------------------------------------------------------------
# MONDAY == 0 and SUNDAY == 6
#
# The calendar module defines weekday constants matching the ISO convention
# where Monday is 0. SUNDAY is 6 — one past Saturday (5). These are used
# by Calendar() to set the first day of the week.
# ---------------------------------------------------------------------------

invariant calendar_extra11.MONDAY.value:
  description: "calendar.MONDAY == 0 — Monday is weekday index 0 (ISO convention)"
  category: module_constants
  kind: python_call_eq
  function: MONDAY.__eq__
  args: [0]
  expected: true

invariant calendar_extra11.SUNDAY.value:
  description: "calendar.SUNDAY == 6 — Sunday is weekday index 6"
  category: module_constants
  kind: python_call_eq
  function: SUNDAY.__eq__
  args: [6]
  expected: true
