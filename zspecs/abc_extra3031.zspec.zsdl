    - ["ab3031005", operator.contains, [abc.ABCMeta.__dict__,                                "__init_subclass__"], false]
    - ["ab3031006", operator.contains, [abc.abstractmethod.__dict__,                         "__init_subclass__"], false]

# ---------------------------------------------------------------------------
# __class_getitem__ dict-presence — operator.contains(Cls.__dict__, '__class_getitem__')
#
# No abc class defines __class_getitem__ in its own __dict__; all false.
# abc.ABC does not define generic alias support; ABCMeta and abstractmethod
# likewise have no __class_getitem__ override.
# ---------------------------------------------------------------------------

table ab3031.class_getitem:
  description: "abc types __class_getitem__ dict-presence checks; wave 649"
