  columns: [id, function, args, expected]
  rows:
    - ["ab3031007", operator.contains, [abc.ABC.__dict__,                                    "__class_getitem__"], false]
    - ["ab3031008", operator.contains, [abc.ABCMeta.__dict__,                                "__class_getitem__"], false]
    - ["ab3031009", operator.contains, [abc.abstractmethod.__dict__,                         "__class_getitem__"], false]

# ---------------------------------------------------------------------------
# combined — all three dunder methods across all 3 abc subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __missing__: all false.
# __init_subclass__: all false.
# __class_getitem__: all false.
# ---------------------------------------------------------------------------

