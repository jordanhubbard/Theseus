spec: ab3031
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 649 (ab3031): __missing__, __init_subclass__, __class_getitem__ dict-presence for abc module types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: abc.ABC, abc.ABCMeta, and the function type (type(abstractmethod(lambda: None)))."
    - "Note: abc.abstractproperty was removed in Python 3.13 and is NOT used here."
    - "None of the three abc subjects define __missing__, __init_subclass__, or __class_getitem__ in their own __dict__."
    - "abc.ABC is a plain convenience base class; its __dict__ contains only __doc__ and __weakref__-related slots."
    - "abc.ABCMeta is a metaclass implementing abstract method tracking; it has no generic-alias or missing-key hooks."
    - "The function type (returned by type(abstractmethod(lambda: None))) is the built-in function type; its __dict__ has no dunder overrides."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __missing__ dict-presence — operator.contains(Cls.__dict__, '__missing__')
#
# No abc class defines __missing__; all results are false.
# abc types are metaclass machinery and decorator helpers, not dict subclasses.
# ---------------------------------------------------------------------------

table ab3031.missing:
  description: "abc types __missing__ dict-presence checks; wave 649"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3031

  columns: [id, function, args, expected]
  rows:
    - ["ab3031001", operator.contains, [abc.ABC.__dict__,                                    "__missing__"], false]
    - ["ab3031002", operator.contains, [abc.ABCMeta.__dict__,                                "__missing__"], false]
    - ["ab3031003", operator.contains, [abc.abstractmethod.__dict__,                         "__missing__"], false]

# ---------------------------------------------------------------------------
# __init_subclass__ dict-presence — operator.contains(Cls.__dict__, '__init_subclass__')
#
# No abc class defines __init_subclass__ in its own __dict__; all false.
# The method is inherited from object; none of these classes override it.
# ---------------------------------------------------------------------------

table ab3031.init_subclass:
  description: "abc types __init_subclass__ dict-presence checks; wave 649"
  kind: python_call_eq
