spec: number_is_integer
version: ">=1.0.1"
backend: node(number-is-integer)

docs: https://www.npmjs.com/package/number-is-integer

provenance:
  derived_from:
    - "number-is-integer README — https://www.npmjs.com/package/number-is-integer"
    - "Test vectors verified with number-is-integer via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "number-is-integer source"
  notes:
    - "number-is-integer is an npm package. Install: npm install number-is-integer"
    - "ES6 Number.isInteger polyfill. Returns true if the value is an integer."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table number_is_integer.check:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: numisint

  columns: [id, args, expected]
  rows:
    - [integer,   [5],    true]
    - [float,     [5.5],  false]
    - [zero,      [0],    true]
