spec: ssl_extra5
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html
rfcs:
  - "RFC 8446 — The Transport Layer Security (TLS) Protocol Version 1.3"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ssl.py"
    - "CPython source: Modules/_ssl.c"
    - "ssl.zspec.zsdl — SSLError/SSLContext/SSLSocket/SSLCertVerificationError __name__; SSLError base/module; CERT_NONE/OPTIONAL/REQUIRED values; HAS_SNI/HAS_ALPN bool type"
    - "ssl_extra.zspec.zsdl — SSLContext.__module__=='_ssl'; SSLCertVerificationError module/base; create_default_context; OP_NO_SSLv2/3 Options; Purpose; PROTOCOL_TLS_CLIENT/SERVER Protocol"
    - "ssl_extra2.zspec.zsdl — SSLZeroReturnError/SSLWantReadError/SSLWantWriteError names/bases/modules; CERT_NONE/REQUIRED VerifyMode class; PROTOCOL truthiness; SSLSocket.__module__"
    - "ssl_extra3.zspec.zsdl — TLSVersion name/base (IntEnum); TLSv1_2/TLSv1_3 member names; PROTOCOL_TLS_CLIENT._SSLMethod"
    - "ssl_extra4.zspec.zsdl — SSLObject name/module/base; CertificateError name/module/base; VerifyMode name/base; CERT_OPTIONAL VerifyMode; HAS_SNI==True; SSLContext base 'object'"
  notes:
    - "This spec extends the ssl chain; it does NOT duplicate invariants present in any prior spec."
    - "ssl.AlertDescription is an IntEnum; __name__ == 'AlertDescription', __bases__[0].__name__ == 'IntEnum'."
    - "ssl.SSLErrorNumber is an IntEnum; __name__ == 'SSLErrorNumber', __bases__[0].__name__ == 'IntEnum'."
    - "ssl.Options is an IntFlag; __name__ == 'Options', __bases__[0].__name__ == 'IntFlag'."
    - "ssl.VerifyMode.__module__ == 'ssl' — module attribute not yet checked."
    - "ssl.AlertDescription.__module__ == 'ssl'."
    - "ssl.SSLErrorNumber.__module__ == 'ssl'."
    - "ssl.Options.__module__ == 'ssl'."
    - "ssl.create_default_context.__module__ == 'ssl' (ssl_extra.zspec only tests __name__)."
    - "ssl.SSLError.__module__ == 'ssl' was in ssl.zspec.zsdl; ssl.SSLContext.__module__ == '_ssl' was in ssl_extra; this spec covers the remaining classes' __module__ that were not yet checked."
    - "ssl.SSLSocket.__module__ == 'ssl' is in ssl_extra2; ssl.SSLObject.__module__ == 'ssl' is in ssl_extra4. This spec adds AlertDescription/SSLErrorNumber/Options/VerifyMode modules."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "ssl.SSLError (subclass of OSError) is raised for TLS failures. All invariants here are pure class attribute reads and do not initiate TLS handshakes."
  stderr: "null"
  stickiness: "N/A — all tested invariants are stateless class attribute reads."
  codes: {}

# ---------------------------------------------------------------------------
# AlertDescription — class name, module, and IntEnum base class
# ssl.AlertDescription is an IntEnum added in Python 3.6 representing TLS
# alert codes; none of the prior specs have tested it.
# ---------------------------------------------------------------------------

invariant ssl_extra5.AlertDescription.name:
  description: "ssl.AlertDescription.__name__ == 'AlertDescription'"
  category: class_names
  kind: python_call_eq
  function: AlertDescription.__name__.__eq__
  args: ["AlertDescription"]
  expected: true

invariant ssl_extra5.AlertDescription.base:
  description: "ssl.AlertDescription.__bases__[0].__name__ == 'IntEnum' — AlertDescription is an IntEnum"
  category: hierarchy
  kind: python_call_eq
  function: AlertDescription.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IntEnum"

invariant ssl_extra5.AlertDescription.module:
  description: "ssl.AlertDescription.__module__ == 'ssl'"
  category: modules
  kind: python_call_eq
  function: AlertDescription.__module__.__eq__
  args: ["ssl"]
  expected: true

# ---------------------------------------------------------------------------
# SSLErrorNumber — class name, module, and IntEnum base class
# ssl.SSLErrorNumber is an IntEnum for ssl_errno values; not tested previously.
# ---------------------------------------------------------------------------

invariant ssl_extra5.SSLErrorNumber.name:
  description: "ssl.SSLErrorNumber.__name__ == 'SSLErrorNumber'"
  category: class_names
  kind: python_call_eq
  function: SSLErrorNumber.__name__.__eq__
  args: ["SSLErrorNumber"]
  expected: true

invariant ssl_extra5.SSLErrorNumber.base:
  description: "ssl.SSLErrorNumber.__bases__[0].__name__ == 'IntEnum' — SSLErrorNumber is an IntEnum"
  category: hierarchy
  kind: python_call_eq
  function: SSLErrorNumber.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IntEnum"

invariant ssl_extra5.SSLErrorNumber.module:
  description: "ssl.SSLErrorNumber.__module__ == 'ssl'"
  category: modules
  kind: python_call_eq
  function: SSLErrorNumber.__module__.__eq__
  args: ["ssl"]
  expected: true

# ---------------------------------------------------------------------------
# Options — class name, module, and IntFlag base class
# ssl_extra.zspec checks instance type (__class__.__name__ == 'Options') for
# OP_NO_SSLv2/OP_NO_SSLv3; this spec checks the Options *class itself*.
# ---------------------------------------------------------------------------

invariant ssl_extra5.Options.name:
  description: "ssl.Options.__name__ == 'Options'"
  category: class_names
  kind: python_call_eq
  function: Options.__name__.__eq__
  args: ["Options"]
  expected: true

invariant ssl_extra5.Options.base:
  description: "ssl.Options.__bases__[0].__name__ == 'IntFlag' — Options is an IntFlag subclass"
  category: hierarchy
  kind: python_call_eq
  function: Options.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IntFlag"

invariant ssl_extra5.Options.module:
  description: "ssl.Options.__module__ == 'ssl'"
  category: modules
  kind: python_call_eq
  function: Options.__module__.__eq__
  args: ["ssl"]
  expected: true

# ---------------------------------------------------------------------------
# VerifyMode.__module__ — not tested in any prior spec
# ssl_extra4.zspec checks VerifyMode.__name__ and __bases__[0].__name__;
# this spec adds the __module__ check.
# ---------------------------------------------------------------------------

invariant ssl_extra5.VerifyMode.module:
  description: "ssl.VerifyMode.__module__ == 'ssl'"
  category: modules
  kind: python_call_eq
  function: VerifyMode.__module__.__eq__
  args: ["ssl"]
  expected: true

# ---------------------------------------------------------------------------
# create_default_context.__module__ — ssl_extra only tested __name__
# ---------------------------------------------------------------------------

invariant ssl_extra5.create_default_context.module:
  description: "ssl.create_default_context.__module__ == 'ssl'"
  category: modules
  kind: python_call_eq
  function: create_default_context.__module__.__eq__
  args: ["ssl"]
  expected: true
