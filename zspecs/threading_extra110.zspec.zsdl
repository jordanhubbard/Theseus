spec: threading_extra110
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra109.zspec.zsdl."
    - "This spec covers: threading.TIMEOUT_MAX (a float constant, value > 0, class name 'float'); threading.get_ident (a builtin_function_or_method from _thread, module '_thread', qualname 'get_ident', name 'get_ident'); threading.get_native_id (a builtin_function_or_method from _thread, module '_thread'); threading.stack_size (a builtin_function_or_method from _thread); threading.local class identity (__module__ == '_thread', __bases__[0].__name__ == 'object', MRO depth 2); wave 261."
    - "type(threading.TIMEOUT_MAX).__name__ == 'float'. Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX > 0 == True. Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float'. Verified with Python 3.14.3."
    - "type(threading.get_ident).__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "threading.get_ident.__module__ == '_thread'. Verified with Python 3.14.3."
    - "threading.get_ident.__qualname__ == 'get_ident'. Verified with Python 3.14.3."
    - "threading.get_ident.__name__ == 'get_ident'. Verified with Python 3.14.3."
    - "type(threading.get_native_id).__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "threading.get_native_id.__module__ == '_thread'. Verified with Python 3.14.3."
    - "type(threading.stack_size).__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "threading.stack_size.__module__ == '_thread'. Verified with Python 3.14.3."
    - "threading.local.__module__ == '_thread'. Verified with Python 3.14.3."
    - "threading.local.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "threading.local.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.TIMEOUT_MAX constant identity
#
# Wave 261 theme: threading.TIMEOUT_MAX is a float constant that defines the
# maximum value for the timeout parameter in blocking calls. It is a positive
# float (on macOS/Darwin it is a very large value). Its type is 'float' and
# its __class__.__name__ is 'float'. Being a constant, it is greater than 0.
# On CPython, TIMEOUT_MAX is typically sys.maxsize or a platform-derived
# large float.
#
# type(threading.TIMEOUT_MAX).__name__ == 'float'
# threading.TIMEOUT_MAX.__class__.__name__ == 'float'
# threading.TIMEOUT_MAX > 0 == True (verified as True)
#
# New to extra110.
# ---------------------------------------------------------------------------

table threading_extra110.timeout_max_identity:
  description: "threading.TIMEOUT_MAX: type 'float', class name 'float'; positive value; class module checked; wave 261; new to extra110"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingtm110

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_max_type_float,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — threading.TIMEOUT_MAX is a float constant defining the maximum allowed timeout value for threading blocking calls; it is set from the C extension layer based on platform limits; its Python type is 'float'; __class__.__name__ is 'float'; str.__eq__('float') returns True; new to extra110"]
    - [timeout_max_gt_zero,
       "TIMEOUT_MAX.__gt__",
       [0],
       true,
       "threading.TIMEOUT_MAX.__gt__(0) == True — threading.TIMEOUT_MAX is a positive float representing the maximum timeout; it is always greater than zero; float.__gt__(0) returns True; new to extra110"]
    - [timeout_max_class_name_float,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — TIMEOUT_MAX is a plain Python float (not a subclass); __class__.__name__ is 'float'; str.__eq__('float') returns True; this second vector confirms type via the same chain; new to extra110"]
    - [timeout_max_not_int,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["int"],
       false,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('int') == False — TIMEOUT_MAX is a float, not an integer; even if the platform value happens to be a round number, its Python type is 'float'; str.__eq__('int') returns False; new to extra110"]

# ---------------------------------------------------------------------------
# Table 2: threading.get_ident and threading.get_native_id identity
#
# Wave 261 theme: threading.get_ident returns the identifier (integer) of the
# current thread. It is actually _thread.get_ident (the C-level function from
# the _thread extension module) re-exported via threading. Its type name is
# 'builtin_function_or_method', its __module__ is '_thread' (not 'threading'),
# its __qualname__ is 'get_ident', and its __name__ is 'get_ident'.
# threading.get_native_id similarly is from _thread with type
# 'builtin_function_or_method' and __module__ '_thread'.
#
# type(threading.get_ident).__name__ == 'builtin_function_or_method'
# threading.get_ident.__module__ == '_thread'
# threading.get_ident.__qualname__ == 'get_ident'
# threading.get_ident.__name__ == 'get_ident'
# type(threading.get_native_id).__name__ == 'builtin_function_or_method'
# threading.get_native_id.__module__ == '_thread'
#
# New to extra110.
# ---------------------------------------------------------------------------

table threading_extra110.get_ident_get_native_id_identity:
  description: "threading.get_ident: builtin_function_or_method from _thread module; qualname 'get_ident'; threading.get_native_id: also builtin_function_or_method from _thread; wave 261; new to extra110"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadinggi110

  columns: [id, function, args, expected, description]
  rows:
    - [get_ident_type_builtin,
       "get_ident.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.get_ident.__class__.__name__.__eq__('builtin_function_or_method') == True — threading.get_ident is the _thread.get_ident C function re-exported through the threading module; it is implemented in Modules/_threadmodule.c and returns the integer identifier of the current thread; its type is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra110"]
    - [get_ident_module_thread,
       "get_ident.__module__.__eq__",
       ["_thread"],
       true,
       "threading.get_ident.__module__.__eq__('_thread') == True — threading.get_ident is actually _thread.get_ident imported into the threading module; its __module__ is '_thread' (the C extension), not 'threading' (the pure-Python wrapper); str.__eq__('_thread') returns True; new to extra110"]
    - [get_ident_qualname_eq,
       "get_ident.__qualname__.__eq__",
       ["get_ident"],
       true,
       "threading.get_ident.__qualname__.__eq__('get_ident') == True — threading.get_ident is a top-level C function (not a method); its __qualname__ is 'get_ident' (not a dotted name since it is not nested in a class); str.__eq__('get_ident') returns True; new to extra110"]
    - [get_ident_name_eq,
       "get_ident.__name__.__eq__",
       ["get_ident"],
       true,
       "threading.get_ident.__name__.__eq__('get_ident') == True — threading.get_ident has __name__ equal to 'get_ident'; for C builtin functions __name__ and __qualname__ are equal for top-level functions; str.__eq__('get_ident') returns True; new to extra110"]
    - [get_native_id_type_builtin,
       "get_native_id.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.get_native_id.__class__.__name__.__eq__('builtin_function_or_method') == True — threading.get_native_id returns the native integer thread id of the current thread; it is also a C function from _thread exposed through threading; its type is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra110"]
    - [get_native_id_module_thread,
       "get_native_id.__module__.__eq__",
       ["_thread"],
       true,
       "threading.get_native_id.__module__.__eq__('_thread') == True — threading.get_native_id is _thread.get_native_id re-exported through threading; its __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra110"]

# ---------------------------------------------------------------------------
# Table 3: threading.stack_size and threading.local identity
#
# Wave 261 theme: threading.stack_size is a C function from _thread that
# gets or sets the thread stack size. Like get_ident, its __module__ is
# '_thread' and its type is 'builtin_function_or_method'. threading.local
# is a C-extension type (_thread._local) re-exported as threading.local.
# Its __module__ is '_thread' (not 'threading'), __bases__[0].__name__ is
# 'object' (inherits directly from object), and MRO depth is 2.
#
# type(threading.stack_size).__name__ == 'builtin_function_or_method'
# threading.stack_size.__module__ == '_thread'
# threading.local.__module__ == '_thread'
# threading.local.__bases__[0].__name__ == 'object'
# threading.local.__mro__.__len__() == 2
# threading.local.__name__ == '_local'
#
# New to extra110.
# ---------------------------------------------------------------------------

table threading_extra110.stack_size_and_local_identity:
  description: "threading.stack_size: builtin_function_or_method from _thread; threading.local: C-extension type with __module__ '_thread', __name__ '_local', bases from object, MRO depth 2; wave 261; new to extra110"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingss110

  columns: [id, function, args, expected, description]
  rows:
    - [stack_size_type_builtin,
       "stack_size.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.stack_size.__class__.__name__.__eq__('builtin_function_or_method') == True — threading.stack_size is the _thread.stack_size C function re-exported through threading; it gets or sets the thread stack size in bytes; its type is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra110"]
    - [stack_size_module_thread,
       "stack_size.__module__.__eq__",
       ["_thread"],
       true,
       "threading.stack_size.__module__.__eq__('_thread') == True — threading.stack_size is _thread.stack_size re-exported through threading; its __module__ is '_thread' (the C extension), not 'threading'; str.__eq__('_thread') returns True; new to extra110"]
    - [local_module_thread,
       "local.__module__.__eq__",
       ["_thread"],
       true,
       "threading.local.__module__.__eq__('_thread') == True — threading.local is the _thread._local C-extension type re-exported as 'local' in the threading module; its __module__ is '_thread' (where the type is actually defined); str.__eq__('_thread') returns True; new to extra110"]
    - [local_bases_0_object,
       "local.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.local.__bases__[0].__name__.__eq__('object') == True — threading.local is a C-extension type that inherits directly from object; its __bases__[0] is object; object.__name__ is 'object'; str.__eq__('object') returns True; new to extra110"]
    - [local_mro_len_2,
       "local.__mro__.__len__",
       [],
       2,
       "threading.local.__mro__.__len__() == 2 — threading.local inherits directly from object; its MRO is [_local, object] with length 2; int.__eq__(2) returns True; new to extra110"]
    - [local_name_local,
       "local.__name__.__eq__",
       ["_local"],
       true,
       "threading.local.__name__.__eq__('_local') == True — threading.local is actually the _thread._local type; its __name__ is '_local' (with leading underscore — the private name from the _thread module); it is exposed as 'local' in the threading namespace; str.__eq__('_local') returns True; new to extra110"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra110
# ---------------------------------------------------------------------------

invariant threading_extra110.timeout_max_type_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant; wave 261; new to extra110"
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra110.get_ident_module:
  description: "threading.get_ident.__module__ == '_thread' — re-exported C function from _thread, not 'threading'; wave 261; new to extra110"
  kind: python_call_eq
  function: get_ident.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra110.get_native_id_type:
  description: "type(threading.get_native_id).__name__ == 'builtin_function_or_method' — C function from _thread; wave 261; new to extra110"
  kind: python_call_eq
  function: get_native_id.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant threading_extra110.local_name:
  description: "threading.local.__name__ == '_local' — the type's actual name in _thread is '_local'; wave 261; new to extra110"
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra110.local_mro_len:
  description: "threading.local.__mro__.__len__() == 2 — [_local, object]; inherits directly from object; wave 261; new to extra110"
  kind: python_call_eq
  function: local.__mro__.__len__
  args: []
  expected: 2
