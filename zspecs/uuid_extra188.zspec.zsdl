spec: uuid_extra188
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "uuid.UUID.__init__.__qualname__ == 'UUID.__init__' (len=13) — __init__ is defined directly on UUID."
    - "uuid.UUID.__init__.__module__ == 'uuid' (len=4) — __init__ belongs to the uuid module."
    - "uuid.UUID.__init__.__code__.co_argcount == 7 — positional parameters: self, hex, bytes, bytes_le, fields, int, version."
    - "uuid.UUID.__init__.__code__.co_kwonlyargcount == 1 — one keyword-only parameter: is_safe."
    - "uuid.UUID.__init__.__code__.co_name == '__init__' (len=8) — the code object name matches the function name."
    - "uuid.UUID.__reduce__.__qualname__ == 'object.__reduce__' (len=17) — inherited from object, not overridden in UUID."
    - "uuid.UUID.__reduce_ex__.__qualname__ == 'object.__reduce_ex__' (len=20) — inherited from object, longest qualname covered."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__init__ identity — qualname, module, co_name
# ---------------------------------------------------------------------------

table uuidinit188.init_identity:
  kind: python_call_eq
  category: qualnames
  id_prefix: uuidinit188

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname, UUID.__init__.__qualname__.__eq__, ["UUID.__init__"],   true, "uuid.UUID.__init__.__qualname__ == 'UUID.__init__' (defined directly on UUID)"]
    - [init_module,   UUID.__init__.__module__.__eq__,   ["uuid"],            true, "uuid.UUID.__init__.__module__ == 'uuid' (init belongs to the uuid module)"]
    - [init_co_name,  UUID.__init__.__code__.co_name.__eq__, ["__init__"],    true, "uuid.UUID.__init__.__code__.co_name == '__init__' (code object name matches function name)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__ code object parameter counts
# co_argcount=7 (self + 6 positional), co_kwonlyargcount=1 (is_safe)
# ---------------------------------------------------------------------------

table uuidinit188.init_param_counts:
  kind: python_call_eq
  category: code_counts
  id_prefix: uuidinit188

  columns: [id, function, args, expected, description]
  rows:
    - [init_co_argcount,       UUID.__init__.__code__.co_argcount.__eq__,       [7], true, "uuid.UUID.__init__.__code__.co_argcount == 7 (self, hex, bytes, bytes_le, fields, int, version)"]
    - [init_co_kwonlyargcount, UUID.__init__.__code__.co_kwonlyargcount.__eq__,  [1], true, "uuid.UUID.__init__.__code__.co_kwonlyargcount == 1 (is_safe is keyword-only)"]
    - [init_co_name_len,       UUID.__init__.__code__.co_name.__len__,           [],  8, "len(uuid.UUID.__init__.__code__.co_name) == 8 ('__init__' has 8 characters)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__reduce__ and __reduce_ex__ qualnames
# Both are inherited from object; qualnames use 'object.' prefix
# ---------------------------------------------------------------------------

table uuidinit188.reduce_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: uuidinit188

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_qualname,    UUID.__reduce__.__qualname__.__eq__,    ["object.__reduce__"],    true, "uuid.UUID.__reduce__.__qualname__ == 'object.__reduce__' (inherited from object, not overridden in UUID)"]
    - [reduce_ex_qualname, UUID.__reduce_ex__.__qualname__.__eq__, ["object.__reduce_ex__"], true, "uuid.UUID.__reduce_ex__.__qualname__ == 'object.__reduce_ex__' (inherited from object)"]
    - [reduce_qualname_len, UUID.__reduce__.__qualname__.__len__,  [], 17, "len(uuid.UUID.__reduce__.__qualname__) == 17 ('object.__reduce__' has 17 characters)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuidinit188.UUID.__init__.qualname:
  description: "uuid.UUID.__init__.__qualname__ == 'UUID.__init__' (defined directly on UUID)"
  category: qualnames
  kind: python_call_eq
  function: UUID.__init__.__qualname__.__eq__
  args: ["UUID.__init__"]
  expected: true

invariant uuidinit188.UUID.__init__.module:
  description: "uuid.UUID.__init__.__module__ == 'uuid' (init belongs to the uuid module)"
  category: qualnames
  kind: python_call_eq
  function: UUID.__init__.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuidinit188.UUID.__init__.co_argcount:
  description: "uuid.UUID.__init__.__code__.co_argcount == 7 (self, hex, bytes, bytes_le, fields, int, version)"
  category: code_counts
  kind: python_call_eq
  function: UUID.__init__.__code__.co_argcount.__eq__
  args: [7]
  expected: true

invariant uuidinit188.UUID.__init__.co_kwonlyargcount:
  description: "uuid.UUID.__init__.__code__.co_kwonlyargcount == 1 (is_safe is the sole keyword-only parameter)"
  category: code_counts
  kind: python_call_eq
  function: UUID.__init__.__code__.co_kwonlyargcount.__eq__
  args: [1]
  expected: true

invariant uuidinit188.UUID.__init__.co_name:
  description: "uuid.UUID.__init__.__code__.co_name == '__init__' (code object name matches the function name)"
  category: qualnames
  kind: python_call_eq
  function: UUID.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

invariant uuidinit188.UUID.__init__.qualname_len:
  description: "len(uuid.UUID.__init__.__qualname__) == 13 ('UUID.__init__' has 13 characters)"
  category: qualnames
  kind: python_call_eq
  function: UUID.__init__.__qualname__.__len__
  args: []
  expected: 13

invariant uuidinit188.UUID.__reduce__.qualname:
  description: "uuid.UUID.__reduce__.__qualname__ == 'object.__reduce__' (inherited from object, not overridden in UUID)"
  category: qualnames
  kind: python_call_eq
  function: UUID.__reduce__.__qualname__.__eq__
  args: ["object.__reduce__"]
  expected: true

invariant uuidinit188.UUID.__reduce_ex__.qualname:
  description: "uuid.UUID.__reduce_ex__.__qualname__ == 'object.__reduce_ex__' (inherited from object — longest qualname among methods covered)"
  category: qualnames
  kind: python_call_eq
  function: UUID.__reduce_ex__.__qualname__.__eq__
  args: ["object.__reduce_ex__"]
  expected: true

