spec: asyncio_extra1066
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio Task, Future, and Queue method documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio.Task cancel/result/exception/add_done_callback qualnames, asyncio.Future add_done_callback/set_result/set_exception qualnames, asyncio.Queue get/put/get_nowait/put_nowait/task_done qualnames — behaviors not covered by extra1036 or extra1051"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra1066.task_extra_method_qualnames:
  description: "asyncio.Task cancel, result, exception, and add_done_callback __qualname__ identity"
  kind: python_call_eq
  category: task_method_qualnames
  id_prefix: as1066tm
  columns: [id, function, args, expected]
  rows:
    - [as1066tm001, asyncio.Task.cancel.__qualname__.__eq__,            ["Task.cancel"],            true]
    - [as1066tm002, asyncio.Task.result.__qualname__.__eq__,            ["Task.result"],            true]
    - [as1066tm003, asyncio.Task.exception.__qualname__.__eq__,         ["Task.exception"],         true]
    - [as1066tm004, asyncio.Task.add_done_callback.__qualname__.__eq__, ["Task.add_done_callback"], true]
    - [as1066tm005, asyncio.Task.remove_done_callback.__qualname__.__eq__, ["Task.remove_done_callback"], true]
    - [as1066tm006, asyncio.Task.cancelled.__qualname__.__eq__,         ["Task.cancelled"],         true]
    - [as1066tm007, asyncio.Task.done.__qualname__.__eq__,              ["Task.done"],              true]

table asyncio_extra1066.future_extra_method_qualnames:
  description: "asyncio.Future add_done_callback, set_result, set_exception, remove_done_callback __qualname__ identity"
  kind: python_call_eq
  category: future_method_qualnames
  id_prefix: as1066fm
  columns: [id, function, args, expected]
  rows:
    - [as1066fm001, asyncio.Future.add_done_callback.__qualname__.__eq__,    ["Future.add_done_callback"],    true]
    - [as1066fm002, asyncio.Future.remove_done_callback.__qualname__.__eq__, ["Future.remove_done_callback"], true]
    - [as1066fm003, asyncio.Future.set_result.__qualname__.__eq__,           ["Future.set_result"],           true]
    - [as1066fm004, asyncio.Future.set_exception.__qualname__.__eq__,        ["Future.set_exception"],        true]
    - [as1066fm005, asyncio.Future.cancelled.__qualname__.__eq__,            ["Future.cancelled"],            true]
    - [as1066fm006, asyncio.Future.exception.__qualname__.__eq__,            ["Future.exception"],            true]

table asyncio_extra1066.queue_extra_method_qualnames:
  description: "asyncio.Queue get, put, get_nowait, put_nowait, task_done __qualname__ identity"
  kind: python_call_eq
  category: queue_method_qualnames
  id_prefix: as1066qm
  columns: [id, function, args, expected]
  rows:
    - [as1066qm001, asyncio.Queue.get.__qualname__.__eq__,        ["Queue.get"],        true]
    - [as1066qm002, asyncio.Queue.put.__qualname__.__eq__,        ["Queue.put"],        true]
    - [as1066qm003, asyncio.Queue.get_nowait.__qualname__.__eq__, ["Queue.get_nowait"], true]
    - [as1066qm004, asyncio.Queue.put_nowait.__qualname__.__eq__, ["Queue.put_nowait"], true]
    - [as1066qm005, asyncio.Queue.task_done.__qualname__.__eq__,  ["Queue.task_done"],  true]
    - [as1066qm006, asyncio.Queue.get.__class__.__name__.__eq__,  ["function"],         true]
    - [as1066qm007, asyncio.Queue.put.__class__.__name__.__eq__,  ["function"],         true]
