spec: re_extra72
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub, findall, split, escape vectors, compile error cases"
    - "re_extra.zspec.zsdl — covers Pattern/Match class name via instance, flag integer values, match/search/sub/split/findall variants, error.__name__, error base"
    - "re_extra2.zspec.zsdl — covers RegexFlag class name, flag class membership, compile pattern/flags, fullmatch/purge/escape __name__"
    - "re_extra3.zspec.zsdl — covers Pattern.__name__, Match.__name__ (type objects), error.__name__ (PatternError), error base, DOTALL/MULTILINE class names, fullmatch returns Match"
    - "re_extra4.zspec.zsdl — covers Match/Pattern type_name anchors, compile.__module__, all function __name__ checks, function __module__ table, subn, finditer class name"
    - "re_extra5.zspec.zsdl — covers compile flags type, match groups/groupdict, search start/end, findall three singles, split whitespace, subn result/count, escape dot, fullmatch match class"
    - "re_extra6.zspec.zsdl — covers purge/escape/error/Pattern/Match __module__, Pattern base is object, error base, function_modules table, RegexFlag.__module__, VERBOSE/ASCII values, compile.__name__"
    - "re_extra7.zspec.zsdl — covers compile().pattern, RegexFlag member .value attributes, Pattern/Match/RegexFlag __qualname__, RegexFlag.__bases__[0].__name__, compile().groups, match().span()"
  notes:
    - "This spec extends all prior re specs and does NOT duplicate invariants present in those files."
    - "This spec covers: re module-level function __qualname__ values and lengths for search, compile, match, fullmatch, sub, subn, split, findall, finditer, purge, escape; plus purge/escape class name, module, and code object attribute co_argcount."
    - "re module functions are defined at module level so __qualname__ == __name__."
    - "re.search.__qualname__ == 'search' — len 6."
    - "re.compile.__qualname__ == 'compile' — len 7."
    - "re.match.__qualname__ == 'match' — len 5."
    - "re.fullmatch.__qualname__ == 'fullmatch' — len 9."
    - "re.sub.__qualname__ == 'sub' — len 3."
    - "re.subn.__qualname__ == 'subn' — len 4."
    - "re.split.__qualname__ == 'split' — len 5."
    - "re.findall.__qualname__ == 'findall' — len 7."
    - "re.finditer.__qualname__ == 'finditer' — len 8."
    - "re.purge.__qualname__ == 'purge' — len 5."
    - "re.escape.__qualname__ == 'escape' — len 6."
    - "re.purge.__class__.__name__ == 'function'."
    - "re.escape.__class__.__name__ == 'function'."
    - "re.purge.__module__ == 're' (already in re_extra6; standalone anchor from this namespace)."
    - "re.escape.__module__ == 're' (already in re_extra6; standalone anchor from this namespace)."
    - "re.escape.__code__.co_argcount == 1 — def escape(pattern): takes one positional arg."
    - "re.purge.__code__.co_argcount == 0 — def purge(): takes no positional args."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re function __qualname__ equality — search, compile, match, fullmatch, sub
# For module-level functions __qualname__ == __name__. No prior re spec checks
# __qualname__ on these functions (re_extra7 only checks Pattern/Match/RegexFlag
# class __qualname__).
# ---------------------------------------------------------------------------

table re_extra72.re_function_qualname_eq:
  description: "re module-level functions have __qualname__ equal to their plain name"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: remeth72

  columns: [id, function, args, expected]
  rows:
    - [search,    search.__qualname__.__eq__,    ["search"],    true]
    - [compile,   compile.__qualname__.__eq__,   ["compile"],   true]
    - [match,     match.__qualname__.__eq__,     ["match"],     true]
    - [fullmatch, fullmatch.__qualname__.__eq__, ["fullmatch"], true]
    - [sub,       sub.__qualname__.__eq__,       ["sub"],       true]

# ---------------------------------------------------------------------------
# re function __qualname__ string lengths — search=6, compile=7, match=5,
# fullmatch=9, sub=3
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra72.re_function_qualname_lengths:
  description: "re module-level function __qualname__ string lengths"
  kind: python_call_eq
  category: function_qualname_lengths
  id_prefix: remeth72

  columns: [id, function, args, expected]
  rows:
    - [search,    search.__qualname__.__len__,    [], 6]
    - [compile,   compile.__qualname__.__len__,   [], 7]
    - [match,     match.__qualname__.__len__,     [], 5]
    - [fullmatch, fullmatch.__qualname__.__len__, [], 9]
    - [sub,       sub.__qualname__.__len__,       [], 3]

# ---------------------------------------------------------------------------
# purge and escape — class name and module identity
# re_extra6 covers __module__ for purge/escape; re_extra2 covers __name__.
# New here: __class__.__name__ for both, and __module__ as a re_extra72-
# namespace anchor.
# ---------------------------------------------------------------------------

table re_extra72.purge_escape_identity:
  description: "re.purge and re.escape are plain Python functions with module 're'"
  kind: python_call_eq
  category: function_identity
  id_prefix: remeth72

  columns: [id, function, args, expected]
  rows:
    - [purge_class,   purge.__class__.__name__.__eq__,  ["function"], true]
    - [escape_class,  escape.__class__.__name__.__eq__, ["function"], true]
    - [purge_module,  purge.__module__.__eq__,          ["re"],       true]
    - [escape_module, escape.__module__.__eq__,         ["re"],       true]

# ---------------------------------------------------------------------------
# purge and escape — co_argcount from code object
# No prior re spec accesses the __code__ attribute of any re function.
# escape takes exactly one positional argument (pattern).
# purge takes no positional arguments.
# ---------------------------------------------------------------------------

table re_extra72.purge_escape_code:
  description: "re.escape and re.purge code object argument counts"
  kind: python_call_eq
  category: code_attributes
  id_prefix: remeth72

  columns: [id, function, args, expected]
  rows:
    - [escape_argcount, escape.__code__.co_argcount.__eq__, [1], true]
    - [purge_argcount,  purge.__code__.co_argcount.__eq__,  [0], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra72.search.qualname_search:
  description: "re.search.__qualname__ == 'search'"
  category: function_qualnames
  kind: python_call_eq
  function: search.__qualname__.__eq__
  args: ["search"]
  expected: true

invariant re_extra72.compile.qualname_len_7:
  description: "len(re.compile.__qualname__) == 7"
  category: function_qualname_lengths
  kind: python_call_eq
  function: compile.__qualname__.__len__
  args: []
  expected: 7

invariant re_extra72.sub.qualname_len_3:
  description: "len(re.sub.__qualname__) == 3"
  category: function_qualname_lengths
  kind: python_call_eq
  function: sub.__qualname__.__len__
  args: []
  expected: 3

invariant re_extra72.escape.class_function:
  description: "re.escape.__class__.__name__ == 'function'"
  category: function_identity
  kind: python_call_eq
  function: escape.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant re_extra72.purge.co_argcount_0:
  description: "re.purge.__code__.co_argcount == 0 — purge() takes no positional args"
  category: code_attributes
  kind: python_call_eq
  function: purge.__code__.co_argcount.__eq__
  args: [0]
  expected: true
