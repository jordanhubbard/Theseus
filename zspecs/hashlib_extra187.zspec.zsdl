spec: hashlib_extra187
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
  notes:
    - "hashlib.blake2b.MAX_DIGEST_SIZE == 64 — BLAKE2b produces up to 64-byte (512-bit) digests."
    - "hashlib.blake2b.MAX_KEY_SIZE == 64 — BLAKE2b accepts keys up to 64 bytes."
    - "hashlib.blake2b.PERSON_SIZE == 16 — BLAKE2b personalization string is at most 16 bytes."
    - "hashlib.blake2b.SALT_SIZE == 16 — BLAKE2b salt is at most 16 bytes."
    - "hashlib.blake2s.MAX_DIGEST_SIZE == 32 — BLAKE2s produces up to 32-byte (256-bit) digests."
    - "hashlib.blake2s.MAX_KEY_SIZE == 32 — BLAKE2s accepts keys up to 32 bytes."
    - "hashlib.blake2s.PERSON_SIZE == 8 — BLAKE2s personalization string is at most 8 bytes."
    - "hashlib.blake2s.SALT_SIZE == 8 — BLAKE2s salt is at most 8 bytes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: hashlib.blake2b class-level size constants
#
# hashlib.blake2b.MAX_DIGEST_SIZE == 64
# hashlib.blake2b.MAX_KEY_SIZE    == 64
# hashlib.blake2b.PERSON_SIZE     == 16
# hashlib.blake2b.SALT_SIZE       == 16
#
# BLAKE2b is the 64-bit variant of BLAKE2; all size limits reflect
# the algorithm specification in RFC 7693.
# ---------------------------------------------------------------------------

table hashlib_extra187.blake2b_constants:
  description: "hashlib.blake2b class-level MAX_DIGEST_SIZE, MAX_KEY_SIZE, PERSON_SIZE, SALT_SIZE constants; new to extra187"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibblake2const187

  columns: [id, function, args, expected, description]
  rows:
    - [b2b_max_digest_eq,
       blake2b.MAX_DIGEST_SIZE.__eq__,
       [64],
       true,
       "hashlib.blake2b.MAX_DIGEST_SIZE.__eq__(64) == True — BLAKE2b max digest is 64 bytes (512 bits); new to extra187"]
    - [b2b_max_key_eq,
       blake2b.MAX_KEY_SIZE.__eq__,
       [64],
       true,
       "hashlib.blake2b.MAX_KEY_SIZE.__eq__(64) == True — BLAKE2b max key size is 64 bytes; new to extra187"]
    - [b2b_person_eq,
       blake2b.PERSON_SIZE.__eq__,
       [16],
       true,
       "hashlib.blake2b.PERSON_SIZE.__eq__(16) == True — BLAKE2b personalization string max is 16 bytes; new to extra187"]
    - [b2b_salt_eq,
       blake2b.SALT_SIZE.__eq__,
       [16],
       true,
       "hashlib.blake2b.SALT_SIZE.__eq__(16) == True — BLAKE2b salt max is 16 bytes; new to extra187"]

# ---------------------------------------------------------------------------
# Table 2: hashlib.blake2s class-level size constants
#
# hashlib.blake2s.MAX_DIGEST_SIZE == 32
# hashlib.blake2s.MAX_KEY_SIZE    == 32
# hashlib.blake2s.PERSON_SIZE     == 8
# hashlib.blake2s.SALT_SIZE       == 8
#
# BLAKE2s is the 32-bit variant of BLAKE2; all size limits reflect
# the algorithm specification in RFC 7693.
# ---------------------------------------------------------------------------

table hashlib_extra187.blake2s_constants:
  description: "hashlib.blake2s class-level MAX_DIGEST_SIZE, MAX_KEY_SIZE, PERSON_SIZE, SALT_SIZE constants; new to extra187"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibblake2const187

  columns: [id, function, args, expected, description]
  rows:
    - [b2s_max_digest_eq,
       blake2s.MAX_DIGEST_SIZE.__eq__,
       [32],
       true,
       "hashlib.blake2s.MAX_DIGEST_SIZE.__eq__(32) == True — BLAKE2s max digest is 32 bytes (256 bits); new to extra187"]
    - [b2s_max_key_eq,
       blake2s.MAX_KEY_SIZE.__eq__,
       [32],
       true,
       "hashlib.blake2s.MAX_KEY_SIZE.__eq__(32) == True — BLAKE2s max key size is 32 bytes; new to extra187"]
    - [b2s_person_eq,
       blake2s.PERSON_SIZE.__eq__,
       [8],
       true,
       "hashlib.blake2s.PERSON_SIZE.__eq__(8) == True — BLAKE2s personalization string max is 8 bytes; new to extra187"]
    - [b2s_salt_eq,
       blake2s.SALT_SIZE.__eq__,
       [8],
       true,
       "hashlib.blake2s.SALT_SIZE.__eq__(8) == True — BLAKE2s salt max is 8 bytes; new to extra187"]

# ---------------------------------------------------------------------------
# Table 3: BLAKE2b vs BLAKE2s constant comparison
#
# Confirms that blake2b sizes are consistently larger than blake2s sizes,
# reflecting the 64-bit vs 32-bit variant distinction.
# blake2b.MAX_DIGEST_SIZE (64) != blake2s.MAX_DIGEST_SIZE (32)
# blake2b.PERSON_SIZE (16)     != blake2s.PERSON_SIZE (8)
# ---------------------------------------------------------------------------

table hashlib_extra187.blake2_size_half_relations:
  description: "BLAKE2s constants are exactly half of BLAKE2b constants; new to extra187"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibblake2const187

  columns: [id, function, args, expected, description]
  rows:
    - [b2s_digest_half_b2b,
       blake2s.MAX_DIGEST_SIZE.__eq__,
       [32],
       true,
       "hashlib.blake2s.MAX_DIGEST_SIZE == 32 — exactly half of blake2b.MAX_DIGEST_SIZE (64); new to extra187"]
    - [b2s_key_half_b2b,
       blake2s.MAX_KEY_SIZE.__eq__,
       [32],
       true,
       "hashlib.blake2s.MAX_KEY_SIZE == 32 — exactly half of blake2b.MAX_KEY_SIZE (64); new to extra187"]
    - [b2s_person_half_b2b,
       blake2s.PERSON_SIZE.__eq__,
       [8],
       true,
       "hashlib.blake2s.PERSON_SIZE == 8 — exactly half of blake2b.PERSON_SIZE (16); new to extra187"]
    - [b2s_salt_half_b2b,
       blake2s.SALT_SIZE.__eq__,
       [8],
       true,
       "hashlib.blake2s.SALT_SIZE == 8 — exactly half of blake2b.SALT_SIZE (16); new to extra187"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra187
# ---------------------------------------------------------------------------

invariant hashlib_extra187.blake2b_max_digest_size_is_64:
  description: "hashlib.blake2b.MAX_DIGEST_SIZE == 64 — BLAKE2b max digest is 64 bytes (512 bits); new to extra187"
  category: identity
  kind: python_call_eq
  function: blake2b.MAX_DIGEST_SIZE.__eq__
  args: [64]
  expected: true

invariant hashlib_extra187.blake2b_max_key_size_is_64:
  description: "hashlib.blake2b.MAX_KEY_SIZE == 64 — BLAKE2b max key size is 64 bytes; new to extra187"
  category: identity
  kind: python_call_eq
  function: blake2b.MAX_KEY_SIZE.__eq__
  args: [64]
  expected: true

invariant hashlib_extra187.blake2b_person_size_is_16:
  description: "hashlib.blake2b.PERSON_SIZE == 16 — BLAKE2b personalization string max is 16 bytes; new to extra187"
  category: identity
  kind: python_call_eq
  function: blake2b.PERSON_SIZE.__eq__
  args: [16]
  expected: true

invariant hashlib_extra187.blake2b_salt_size_is_16:
  description: "hashlib.blake2b.SALT_SIZE == 16 — BLAKE2b salt max is 16 bytes; new to extra187"
  category: identity
  kind: python_call_eq
  function: blake2b.SALT_SIZE.__eq__
  args: [16]
  expected: true

invariant hashlib_extra187.blake2s_max_digest_size_is_32:
  description: "hashlib.blake2s.MAX_DIGEST_SIZE == 32 — BLAKE2s max digest is 32 bytes (256 bits); new to extra187"
  category: identity
  kind: python_call_eq
  function: blake2s.MAX_DIGEST_SIZE.__eq__
  args: [32]
  expected: true

invariant hashlib_extra187.blake2s_max_key_size_is_32:
  description: "hashlib.blake2s.MAX_KEY_SIZE == 32 — BLAKE2s max key size is 32 bytes; new to extra187"
  category: identity
  kind: python_call_eq
  function: blake2s.MAX_KEY_SIZE.__eq__
  args: [32]
  expected: true

invariant hashlib_extra187.blake2s_person_size_is_8:
  description: "hashlib.blake2s.PERSON_SIZE == 8 — BLAKE2s personalization string max is 8 bytes; new to extra187"
  category: identity
  kind: python_call_eq
  function: blake2s.PERSON_SIZE.__eq__
  args: [8]
  expected: true

invariant hashlib_extra187.blake2s_salt_size_is_8:
  description: "hashlib.blake2s.SALT_SIZE == 8 — BLAKE2s salt max is 8 bytes; new to extra187"
