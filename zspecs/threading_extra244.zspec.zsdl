spec: threading_extra244
version: ">=3.2"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra243.zspec.zsdl — covers current_thread, active_count, enumerate function identity"
    - "threading_extra242.zspec.zsdl — covers Semaphore and BoundedSemaphore class identity"
    - "threading_extra241.zspec.zsdl — covers Timer and main_thread identity"
    - "threading_extra.zspec.zsdl — covers module checks for synchronization primitives, local, get_ident, TIMEOUT_MAX, stack_size"
    - "threading.zspec.zsdl — covers class __name__ checks and function names"
  notes:
    - "This spec covers threading.TIMEOUT_MAX constant identity and threading.local class identity contracts."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant defined as sys.maxsize / 1e9 on CPython. Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX == 9223372036.0 on Python 3.14.3 (approximately sys.maxsize / 1e9). Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a large positive float. Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__gt__(86400) == True — TIMEOUT_MAX is much larger than 1 day (86400 seconds). Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__gt__(1e10) == False — TIMEOUT_MAX is approximately 9.22e9, which is less than 1e10. Verified with Python 3.14.3."
    - "threading.local.__name__ == '_local' (len=6) — threading.local is actually the C extension _thread._local; __name__ is '_local'. Verified with Python 3.14.3."
    - "threading.local.__module__ == '_thread' (len=7) — threading.local is defined in the C extension _thread; __module__ is '_thread'. Verified with Python 3.14.3."
    - "threading.local.__class__.__name__ == 'type' — threading.local is a C extension type. Verified with Python 3.14.3."
    - "threading.local.__bases__[0].__name__ == 'object' — threading.local inherits directly from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.TIMEOUT_MAX constant identity contracts
#
# threading.TIMEOUT_MAX.__class__.__name__ == 'float'
# threading.TIMEOUT_MAX.__gt__(0) == True
# threading.TIMEOUT_MAX.__gt__(86400) == True
# threading.TIMEOUT_MAX.__gt__(1e10) == False
# threading.TIMEOUT_MAX.__class__.__module__ == 'builtins'
#
# TIMEOUT_MAX is a float constant = sys.maxsize / 1e9 ~= 9.22e9. New to extra244.
# ---------------------------------------------------------------------------

table threading_extra244.thrmax244_identity:
  description: "threading.TIMEOUT_MAX constant identity: class, comparison checks; new to extra244"
  kind: python_call_eq
  category: identity
  id_prefix: thrmax244

  columns: [id, function, args, expected, description]
  rows:
    - [tmax_class_is_float,
       TIMEOUT_MAX.__class__.__name__.__eq__,
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — TIMEOUT_MAX is a float constant defined as sys.maxsize / 1e9; new to extra244"]
    - [tmax_gt_0,
       TIMEOUT_MAX.__gt__,
       [0],
       true,
       "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a large positive float approximately 9.22e9; new to extra244"]
    - [tmax_gt_86400,
       TIMEOUT_MAX.__gt__,
       [86400],
       true,
       "threading.TIMEOUT_MAX.__gt__(86400) == True — TIMEOUT_MAX is much larger than 1 day (86400 seconds); new to extra244"]
    - [tmax_gt_1e10_false,
       TIMEOUT_MAX.__gt__,
       [10000000000.0],
       false,
       "threading.TIMEOUT_MAX.__gt__(1e10) == False — TIMEOUT_MAX is approximately 9.22e9, which is less than 1e10 (10000000000.0); new to extra244"]
    - [tmax_class_module_builtins,
       TIMEOUT_MAX.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "threading.TIMEOUT_MAX.__class__.__module__.__eq__('builtins') == True — float is defined in the builtins module; new to extra244"]

# ---------------------------------------------------------------------------
# Table 2: threading.TIMEOUT_MAX additional float property checks
#
# threading.TIMEOUT_MAX.__class__.__name__.__len__() == 5
# threading.TIMEOUT_MAX.__gt__(1000000) == True  (> 1 million seconds)
# threading.TIMEOUT_MAX.__gt__(1000000000) == True (> 1 billion seconds)
# threading.TIMEOUT_MAX.__eq__(9223372036.0) == True
# threading.TIMEOUT_MAX.__class__.__name__.__contains__('float') == True
#
# New to extra244.
# ---------------------------------------------------------------------------

table threading_extra244.thrmax244_float:
  description: "threading.TIMEOUT_MAX float property and comparison checks; new to extra244"
  kind: python_call_eq
  category: identity
  id_prefix: thrmax244f

  columns: [id, function, args, expected, description]
  rows:
    - [tmax_class_name_len_5,
       TIMEOUT_MAX.__class__.__name__.__len__,
       [],
       5,
       "threading.TIMEOUT_MAX.__class__.__name__.__len__() == 5 — 'float' has exactly 5 characters; str.__len__() returns 5; new to extra244"]
    - [tmax_gt_1000000,
       TIMEOUT_MAX.__gt__,
       [1000000],
       true,
       "threading.TIMEOUT_MAX.__gt__(1000000) == True — TIMEOUT_MAX is approximately 9.22e9, much larger than 1 million seconds; new to extra244"]
    - [tmax_gt_1000000000,
       TIMEOUT_MAX.__gt__,
       [1000000000],
       true,
       "threading.TIMEOUT_MAX.__gt__(1000000000) == True — TIMEOUT_MAX approximately 9.22e9 is larger than 1 billion seconds; new to extra244"]
    - [tmax_eq_9223372036,
       TIMEOUT_MAX.__eq__,
       [9223372036.0],
       true,
       "threading.TIMEOUT_MAX.__eq__(9223372036.0) == True — TIMEOUT_MAX == 9223372036.0 on Python 3.14.3 (sys.maxsize / 1e9); new to extra244"]
    - [tmax_class_name_contains_float,
       TIMEOUT_MAX.__class__.__name__.__contains__,
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__contains__('float') == True — 'float' contains the substring 'float'; new to extra244"]

# ---------------------------------------------------------------------------
# Table 3: threading.local class identity contracts
#
# threading.local.__name__ == '_local' (len=6)
# threading.local.__module__ == '_thread' (len=7)
# threading.local.__class__.__name__ == 'type'
# threading.local.__bases__[0].__name__ == 'object'
# threading.local.__name__.__len__() == 6
#
# threading.local is actually _thread._local, a C extension type. New to extra244.
# ---------------------------------------------------------------------------

table threading_extra244.thrlocal244_identity:
  description: "threading.local class identity: name, module, bases, class; new to extra244"
  kind: python_call_eq
  category: identity
  id_prefix: thrlocal244

  columns: [id, function, args, expected, description]
  rows:
    - [tl_name_eq,
       local.__name__.__eq__,
       ["_local"],
       true,
       "threading.local.__name__.__eq__('_local') == True — threading.local is _thread._local; __name__ is '_local' (len=6); new to extra244"]
    - [tl_name_len_6,
       local.__name__.__len__,
       [],
       6,
       "threading.local.__name__.__len__() == 6 — '_local' has exactly 6 characters; str.__len__() returns 6; new to extra244"]
    - [tl_module_eq,
       local.__module__.__eq__,
       ["_thread"],
       true,
       "threading.local.__module__.__eq__('_thread') == True — threading.local is defined in the C extension _thread; __module__ is '_thread' (len=7); new to extra244"]
    - [tl_module_len_7,
       local.__module__.__len__,
       [],
       7,
       "threading.local.__module__.__len__() == 7 — '_thread' has exactly 7 characters; str.__len__() returns 7; new to extra244"]
    - [tl_bases_0_is_object,
       "local.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.local.__bases__[0].__name__.__eq__('object') == True — threading.local inherits directly from object; __bases__[0] is object; new to extra244"]

# ---------------------------------------------------------------------------
# Table 4: threading.local class type and content checks
#
# threading.local.__class__.__name__ == 'type'
# threading.local.__name__.__contains__('local') == True
# threading.local.__module__.__contains__('thread') == True
# threading.local.__bases__[0].__name__.__len__() == 6
# threading.local.__class__.__module__ == 'builtins'
#
# New to extra244.
# ---------------------------------------------------------------------------

table threading_extra244.thrlocal244_class:
  description: "threading.local class type, name/module content checks; new to extra244"
  kind: python_call_eq
  category: identity
  id_prefix: thrlocal244c

  columns: [id, function, args, expected, description]
  rows:
    - [tl_class_is_type,
       local.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.local.__class__.__name__.__eq__('type') == True — threading.local is a C extension type; its metaclass is the built-in type; new to extra244"]
    - [tl_name_contains_local,
       local.__name__.__contains__,
       ["local"],
       true,
       "threading.local.__name__.__contains__('local') == True — '_local' contains the substring 'local'; new to extra244"]
    - [tl_module_contains_thread,
       local.__module__.__contains__,
       ["thread"],
       true,
       "threading.local.__module__.__contains__('thread') == True — '_thread' contains the substring 'thread'; new to extra244"]
    - [tl_bases_0_len_6,
       "local.__bases__[0].__name__.__len__",
       [],
       6,
       "threading.local.__bases__[0].__name__.__len__() == 6 — 'object' has exactly 6 characters; new to extra244"]
    - [tl_class_module_builtins,
       local.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "threading.local.__class__.__module__.__eq__('builtins') == True — type is defined in the builtins module; new to extra244"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra244
# ---------------------------------------------------------------------------

invariant threading_extra244.tmax_class_is_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float'; new to extra244"
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra244.tmax_gt_0:
  description: "threading.TIMEOUT_MAX.__gt__(0) == True — large positive float; new to extra244"
  kind: python_call_eq
  function: TIMEOUT_MAX.__gt__
  args: [0]
  expected: true

invariant threading_extra244.tmax_gt_86400:
  description: "threading.TIMEOUT_MAX.__gt__(86400) == True — TIMEOUT_MAX exceeds 1 day in seconds; new to extra244"
  kind: python_call_eq
  function: TIMEOUT_MAX.__gt__
  args: [86400]
  expected: true

invariant threading_extra244.tmax_eq_9223372036:
  description: "threading.TIMEOUT_MAX == 9223372036.0 on Python 3.14.3; new to extra244"
  kind: python_call_eq
  function: TIMEOUT_MAX.__eq__
  args: [9223372036.0]
  expected: true

invariant threading_extra244.tl_name_eq:
  description: "threading.local.__name__ == '_local' (len=6) — C extension _thread._local; new to extra244"
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra244.tl_module_eq:
  description: "threading.local.__module__ == '_thread' — C extension; not 'threading'; new to extra244"
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra244.tl_bases_0_is_object:
  description: "threading.local.__bases__[0].__name__ == 'object' — inherits from object; new to extra244"
  kind: python_call_eq
  function: "local.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra244.tl_class_is_type:
  description: "threading.local.__class__.__name__ == 'type' — C extension type; new to extra244"
  kind: python_call_eq
  function: local.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra244.tl_name_len_6:
  description: "threading.local.__name__.__len__() == 6 — '_local' has 6 characters; new to extra244"
  kind: python_call_eq
  function: local.__name__.__len__
  args: []
  expected: 6

invariant threading_extra244.tl_module_len_7:
  description: "threading.local.__module__.__len__() == 7 — '_thread' has 7 characters; new to extra244"
  kind: python_call_eq
  function: local.__module__.__len__
  args: []
  expected: 7
