spec: pathlib_extra80
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra79."
    - "Prior specs covered: PurePath/PurePosixPath/PureWindowsPath/Path/PosixPath/WindowsPath __name__/__module__/__qualname__; Path instance attributes; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes; PurePath __dict__ membership; __bases__ and MRO lengths; Path/__dict__ membership for open/read_text/write_text/iterdir/mkdir/exists/unlink."
    - "pathlib_extra79 covers Path.__dict__.__class__.__name__ == 'mappingproxy'; Path.__dict__.__contains__ for open/read_text/write_text/iterdir/mkdir/exists/unlink; PurePath.__dict__.__contains__ for __str__/joinpath."
    - "This spec covers: Path method __code__ deeper dive — co_name and co_argcount for mkdir/exists/unlink/stat/rename."
    - "pathlib.Path.mkdir.__code__.co_name == 'mkdir' — verified by code object attribute."
    - "pathlib.Path.mkdir.__code__.co_argcount == 4 — mkdir(self, mode=511, parents=False, exist_ok=False); all four are positional-or-keyword with defaults."
    - "pathlib.Path.exists.__code__.co_name == 'exists' — verified by code object attribute."
    - "pathlib.Path.exists.__code__.co_argcount == 1 — only self is positional; follow_symlinks is keyword-only (added Python 3.12)."
    - "pathlib.Path.unlink.__code__.co_name == 'unlink' — verified by code object attribute."
    - "pathlib.Path.unlink.__code__.co_argcount == 2 — self + missing_ok are both positional-or-keyword."
    - "pathlib.Path.stat.__code__.co_name == 'stat' — verified by code object attribute."
    - "pathlib.Path.stat.__code__.co_argcount == 1 — only self is positional; follow_symlinks is keyword-only."
    - "pathlib.Path.rename.__code__.co_name == 'rename' — verified by code object attribute."
    - "pathlib.Path.rename.__code__.co_argcount == 2 — self + target are both positional-or-keyword."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.mkdir and Path.exists __code__ attributes
# mkdir(self, mode=511, parents=False, exist_ok=False) — 4 positional args.
# exists(self, *, follow_symlinks=True) — 1 positional; follow_symlinks kw-only.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra80.mkdir_exists_code:
  description: "Path.mkdir and Path.exists __code__ co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore80

  columns: [id, function, args, expected]
  rows:
    - [mkdir_co_name,    Path.mkdir.__code__.co_name.__eq__,    ["mkdir"],  true]
    - [mkdir_co_argc,    Path.mkdir.__code__.co_argcount.__eq__, [4],       true]
    - [exists_co_name,   Path.exists.__code__.co_name.__eq__,   ["exists"], true]
    - [exists_co_argc,   Path.exists.__code__.co_argcount.__eq__, [1],      true]

# ---------------------------------------------------------------------------
# Path.unlink and Path.stat __code__ attributes
# unlink(self, missing_ok=False) — 2 positional-or-keyword args.
# stat(self, *, follow_symlinks=True) — 1 positional; follow_symlinks kw-only.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra80.unlink_stat_code:
  description: "Path.unlink and Path.stat __code__ co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore80

  columns: [id, function, args, expected]
  rows:
    - [unlink_co_name,  Path.unlink.__code__.co_name.__eq__,     ["unlink"], true]
    - [unlink_co_argc,  Path.unlink.__code__.co_argcount.__eq__,  [2],       true]
    - [stat_co_name,    Path.stat.__code__.co_name.__eq__,        ["stat"],  true]
    - [stat_co_argc,    Path.stat.__code__.co_argcount.__eq__,    [1],       true]

# ---------------------------------------------------------------------------
# Path.rename __code__ attributes
# rename(self, target) — 2 positional-or-keyword args (no defaults).
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra80.rename_code:
  description: "Path.rename __code__ co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore80

  columns: [id, function, args, expected]
  rows:
    - [rename_co_name,  Path.rename.__code__.co_name.__eq__,    ["rename"], true]
    - [rename_co_argc,  Path.rename.__code__.co_argcount.__eq__, [2],       true]

# ---------------------------------------------------------------------------
# Combined co_name identity for mkdir/exists/unlink/stat/rename
# A single table confirming all five method code names match the method name.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra80.method_code_names:
  description: "Path method __code__.co_name values match their method names"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore80

  columns: [id, function, args, expected]
  rows:
    - [mkdir_name,   Path.mkdir.__code__.co_name.__eq__,   ["mkdir"],   true]
    - [exists_name,  Path.exists.__code__.co_name.__eq__,  ["exists"],  true]
    - [unlink_name,  Path.unlink.__code__.co_name.__eq__,  ["unlink"],  true]
    - [stat_name,    Path.stat.__code__.co_name.__eq__,    ["stat"],    true]
    - [rename_name,  Path.rename.__code__.co_name.__eq__,  ["rename"],  true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra80.mkdir_code.co_name:
  description: "pathlib.Path.mkdir.__code__.co_name == 'mkdir'"
  category: code_attrs
  kind: python_call_eq
  function: Path.mkdir.__code__.co_name.__eq__
  args: ["mkdir"]
  expected: true

invariant pathlib_extra80.mkdir_code.co_argcount:
  description: "pathlib.Path.mkdir.__code__.co_argcount == 4 (self, mode, parents, exist_ok)"
  category: code_attrs
  kind: python_call_eq
  function: Path.mkdir.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant pathlib_extra80.exists_code.co_argcount:
  description: "pathlib.Path.exists.__code__.co_argcount == 1 (only self; follow_symlinks is keyword-only)"
  category: code_attrs
  kind: python_call_eq
  function: Path.exists.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant pathlib_extra80.stat_code.co_argcount:
  description: "pathlib.Path.stat.__code__.co_argcount == 1 (only self; follow_symlinks is keyword-only)"
  category: code_attrs
  kind: python_call_eq
  function: Path.stat.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant pathlib_extra80.rename_code.co_argcount:
  description: "pathlib.Path.rename.__code__.co_argcount == 2 (self + target)"
  category: code_attrs
  kind: python_call_eq
  function: Path.rename.__code__.co_argcount.__eq__
  args: [2]
  expected: true
