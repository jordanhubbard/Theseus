spec: datetime_extra16
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
    - "datetime_extra4.zspec.zsdl — covers __qualname__ table for datetime/date/time/timedelta/timezone/tzinfo classes"
    - "datetime_extra5.zspec.zsdl — covers additional __qualname__ table"
    - "datetime_extra11.zspec.zsdl — covers strptime/__name__ on datetime; fromordinal/__name__; fromtimestamp/__name__"
    - "datetime_extra12.zspec.zsdl — covers __qualname__ for all six classes as standalone invariants; __module__ table"
    - "datetime_extra15.zspec.zsdl — covers MINYEAR/MAXYEAR __class__.__qualname__; resolution __class__.__name__ table; six-class __qualname__ table"
  notes:
    - "This spec extends datetime.zspec.zsdl and prior extras through datetime_extra15.zspec.zsdl."
    - "NEW in extra16 — Axis 1: __qualname__ for class method descriptors on date (today, fromisoformat, strftime, isoformat) — dotted qualnames such as 'date.today'."
    - "NEW in extra16 — Axis 2: __qualname__ for class method descriptors on datetime (now, fromisoformat, strptime) — dotted qualnames such as 'datetime.now'."
    - "NEW in extra16 — Axis 3: __qualname__ for time.isoformat — dotted qualname 'time.isoformat'."
    - "NEW in extra16 — Axis 4: timedelta.__qualname__ == 'timedelta' as standalone extra16-namespace invariant (flat class qualname)."
    - "datetime.date.today.__qualname__ == 'date.today' — verified Python 3.12."
    - "datetime.date.fromisoformat.__qualname__ == 'date.fromisoformat' — verified Python 3.12."
    - "datetime.date.strftime.__qualname__ == 'date.strftime' — verified Python 3.12."
    - "datetime.date.isoformat.__qualname__ == 'date.isoformat' — verified Python 3.12."
    - "datetime.datetime.now.__qualname__ == 'datetime.now' — verified Python 3.12."
    - "datetime.datetime.fromisoformat.__qualname__ == 'datetime.fromisoformat' — verified Python 3.12."
    - "datetime.datetime.strptime.__qualname__ == 'datetime.strptime' — verified Python 3.12."
    - "datetime.time.isoformat.__qualname__ == 'time.isoformat' — verified Python 3.12."
    - "datetime.timedelta.__qualname__ == 'timedelta' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# date class method __qualname__ values
#
# datetime_extra4 and extra12 cover the __qualname__ of the date *class* itself
# ('date'). This spec covers the __qualname__ of *methods* on date, which are
# dotted strings such as 'date.today'. No prior spec checks these.
# ---------------------------------------------------------------------------

table datetime_extra16.date_method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qn

  columns: [id, function, args, expected]
  rows:
    - [today,        "date.today.__qualname__.__eq__",        ["date.today"],        true]
    - [fromisoformat, "date.fromisoformat.__qualname__.__eq__", ["date.fromisoformat"], true]
    - [strftime,     "date.strftime.__qualname__.__eq__",     ["date.strftime"],     true]
    - [isoformat,    "date.isoformat.__qualname__.__eq__",    ["date.isoformat"],    true]

# ---------------------------------------------------------------------------
# datetime class method __qualname__ values
#
# As with date above, prior specs cover the datetime class's own __qualname__
# but not the dotted __qualname__ of its methods. These are new in extra16.
# ---------------------------------------------------------------------------

table datetime_extra16.datetime_method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qn

  columns: [id, function, args, expected]
  rows:
    - [now,          "datetime.now.__qualname__.__eq__",          ["datetime.now"],          true]
    - [fromisoformat, "datetime.fromisoformat.__qualname__.__eq__", ["datetime.fromisoformat"], true]
    - [strptime,     "datetime.strptime.__qualname__.__eq__",     ["datetime.strptime"],     true]

# ---------------------------------------------------------------------------
# time.isoformat __qualname__
#
# datetime_extra4 and extra12 cover the time class's own __qualname__ == 'time'.
# No prior spec checks the __qualname__ of the isoformat method on the time
# class, which is 'time.isoformat' (dotted).
# ---------------------------------------------------------------------------

invariant datetime_extra16.time.isoformat_qualname:
  description: "datetime.time.isoformat.__qualname__ == 'time.isoformat' — dotted method qualname"
  category: method_qualnames
  kind: python_call_eq
  function: "time.isoformat.__qualname__.__eq__"
  args: ["time.isoformat"]
  expected: true

# ---------------------------------------------------------------------------
# timedelta.__qualname__ — standalone extra16-namespace invariant
#
# datetime_extra12 and extra15 cover timedelta.__qualname__ in tables. This
# spec re-anchors it as a standalone invariant in the extra16 namespace for
# systematic chain continuity alongside the method-qualname coverage above.
# ---------------------------------------------------------------------------

invariant datetime_extra16.timedelta.qualname:
  description: "datetime.timedelta.__qualname__ == 'timedelta' — flat class qualname"
  category: class_qualnames
  kind: python_call_eq
  function: timedelta.__qualname__.__eq__
  args: ["timedelta"]
  expected: true
