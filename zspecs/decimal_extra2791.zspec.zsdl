spec: decimal_extra2791
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers existing decimal invariants"
    - "decimal_extra2776.zspec.zsdl — covers __isub__/__imul__/__itruediv__ dict-presence"
    - "decimal_extra2761.zspec.zsdl — covers __matmul__/__truediv__/__iadd__ dict-presence"
    - "decimal_extra2746.zspec.zsdl — covers __round__/__divmod__/__pow__ dict-presence"
    - "decimal_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
    - "decimal_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 633 (decimal_extra2791) theme: __iand__, __ior__, and __ixor__ dict-presence checks."
    - "decimal.Decimal does NOT define __iand__, __ior__, or __ixor__ in its own __dict__."
    - "Although decimal.Decimal defines arithmetic operators such as __sub__, __mul__, and __truediv__, it is an immutable numeric type and does not implement in-place bitwise operator hooks."
    - "decimal.Context and decimal.DecimalException also do NOT define __iand__, __ior__, or __ixor__ in their own __dict__."
    - "__iand__ supports the &= operator; Decimal is a decimal floating-point type and has no bitwise-AND semantics."
    - "__ior__ supports the |= operator; Decimal does not implement in-place bitwise-OR semantics."
    - "__ixor__ supports the ^= operator; Decimal does not implement in-place bitwise-XOR semantics."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __iand__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2791.no_iand_in_decimal_classes:
  description: "__iand__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal is a decimal floating-point type with no bitwise-AND semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2791

  columns: [id, function, args, expected]
  rows:
    - ["dc2791001", "decimal.Decimal.__dict__.__contains__",          ["__iand__"], false]
    - ["dc2791002", "decimal.Context.__dict__.__contains__",          ["__iand__"], false]
    - ["dc2791003", "decimal.DecimalException.__dict__.__contains__", ["__iand__"], false]

# ---------------------------------------------------------------------------
# __ior__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2791.no_ior_in_decimal_classes:
  description: "__ior__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal does not implement |= in-place bitwise-OR"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2791

  columns: [id, function, args, expected]
  rows:
    - ["dc2791004", "decimal.Decimal.__dict__.__contains__",          ["__ior__"], false]
    - ["dc2791005", "decimal.Context.__dict__.__contains__",          ["__ior__"], false]
    - ["dc2791006", "decimal.DecimalException.__dict__.__contains__", ["__ior__"], false]

# ---------------------------------------------------------------------------
# __ixor__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2791.no_ixor_in_decimal_classes:
  description: "__ixor__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal does not implement ^= in-place bitwise-XOR"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2791

  columns: [id, function, args, expected]
  rows:
    - ["dc2791007", "decimal.Decimal.__dict__.__contains__",          ["__ixor__"], false]
    - ["dc2791008", "decimal.Context.__dict__.__contains__",          ["__ixor__"], false]
    - ["dc2791009", "decimal.DecimalException.__dict__.__contains__", ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Complementary: decimal.Decimal defines binary arithmetic hooks but none of the in-place bitwise variants
# Contrasts Decimal's __sub__/__mul__/__truediv__ presence with absent __iand__/__ior__/__ixor__
# ---------------------------------------------------------------------------

table decimal_extra2791.decimal_has_binary_ops_but_not_inplace_bitwise_variants:
  description: "decimal.Decimal defines __sub__/__mul__/__truediv__ but NOT __iand__/__ior__/__ixor__; decimal.Context has sqrt/exp/ln but none of the in-place bitwise hooks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2791

  columns: [id, function, args, expected]
  rows:
    - ["dc2791010", "decimal.Decimal.__dict__.__contains__", ["__sub__"],     true]
    - ["dc2791011", "decimal.Decimal.__dict__.__contains__", ["__mul__"],     true]
    - ["dc2791012", "decimal.Decimal.__dict__.__contains__", ["__truediv__"], true]
    - ["dc2791013", "decimal.Decimal.__dict__.__contains__", ["__iand__"],    false]
    - ["dc2791014", "decimal.Decimal.__dict__.__contains__", ["__ior__"],     false]
    - ["dc2791015", "decimal.Decimal.__dict__.__contains__", ["__ixor__"],    false]
    - ["dc2791016", "decimal.Context.__dict__.__contains__", ["sqrt"],        true]
    - ["dc2791017", "decimal.Context.__dict__.__contains__", ["exp"],         true]
    - ["dc2791018", "decimal.Context.__dict__.__contains__", ["ln"],          true]
    - ["dc2791019", "decimal.Context.__dict__.__contains__", ["__iand__"],    false]
    - ["dc2791020", "decimal.Context.__dict__.__contains__", ["__ior__"],     false]
    - ["dc2791021", "decimal.Context.__dict__.__contains__", ["__ixor__"],    false]
