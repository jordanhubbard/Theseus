spec: struct_extra221
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.__dict__.__contains__('pack') == True — pack is a top-level name in struct.__dict__."
    - "struct.__dict__.__contains__('unpack') == True — unpack is a top-level name in struct.__dict__."
    - "struct.__dict__.__contains__('calcsize') == True — calcsize is a top-level name in struct.__dict__."
    - "struct.__dict__.__contains__('pack_into') == True — pack_into is a top-level name in struct.__dict__."
    - "struct.__dict__.__contains__('unpack_from') == True — unpack_from is a top-level name in struct.__dict__."
    - "struct.__dict__.__contains__('iter_unpack') == True — iter_unpack is a top-level name in struct.__dict__."
    - "struct.__dict__.__contains__('Struct') == True — Struct is a top-level name in struct.__dict__."
    - "struct.__dict__.__contains__('error') == True — error is a top-level name in struct.__dict__."
    - "struct.__dict__.__class__.__name__ == 'dict' — struct.__dict__ is an ordinary dict."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module __dict__ membership checks — pack/unpack functions
#
# struct.__dict__.__contains__('pack')        == True
# struct.__dict__.__contains__('unpack')      == True
# struct.__dict__.__contains__('pack_into')   == True
# struct.__dict__.__contains__('unpack_from') == True
# struct.__dict__.__contains__('iter_unpack') == True
# struct.__dict__.__contains__('calcsize')    == True
# ---------------------------------------------------------------------------

table struct_extra221.dict_membership_functions:
  description: "struct module __dict__ membership checks for pack/unpack functions in struct221 namespace — wave 221 theme: pack, unpack, pack_into, unpack_from, iter_unpack, calcsize are all top-level names exported by struct; these are the core C struct conversion functions; confirmed present in struct.__dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: identity
  id_prefix: struct221

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_pack,        struct.__dict__.__contains__, ["pack"],        true, "struct.__dict__.__contains__('pack') == True — pack packs values into bytes according to a format string; exported as top-level name in struct.__dict__; verified with Python 3.14.3"]
    - [dict_has_unpack,      struct.__dict__.__contains__, ["unpack"],      true, "struct.__dict__.__contains__('unpack') == True — unpack unpacks bytes into values according to a format string; exported as top-level name in struct.__dict__; verified with Python 3.14.3"]
    - [dict_has_pack_into,   struct.__dict__.__contains__, ["pack_into"],   true, "struct.__dict__.__contains__('pack_into') == True — pack_into packs values into an existing buffer; exported as top-level name in struct.__dict__; verified with Python 3.14.3"]
    - [dict_has_unpack_from, struct.__dict__.__contains__, ["unpack_from"], true, "struct.__dict__.__contains__('unpack_from') == True — unpack_from unpacks from a buffer at a given offset; exported as top-level name in struct.__dict__; verified with Python 3.14.3"]
    - [dict_has_iter_unpack, struct.__dict__.__contains__, ["iter_unpack"], true, "struct.__dict__.__contains__('iter_unpack') == True — iter_unpack iteratively unpacks from a buffer; exported as top-level name in struct.__dict__; verified with Python 3.14.3"]
    - [dict_has_calcsize,    struct.__dict__.__contains__, ["calcsize"],    true, "struct.__dict__.__contains__('calcsize') == True — calcsize returns the byte size for a format string; exported as top-level name in struct.__dict__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct module __dict__ membership checks — Struct class and error exception
#
# struct.__dict__.__contains__('Struct') == True
# struct.__dict__.__contains__('error')  == True
# ---------------------------------------------------------------------------

table struct_extra221.dict_membership_class_and_error:
  description: "struct module __dict__ membership checks for Struct class and error exception in struct221a namespace — wave 221 theme: Struct and error are top-level names exported by struct; Struct is the compiled format object class; error is the exception class raised on struct errors; confirmed present in struct.__dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: identity
  id_prefix: struct221a

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_Struct, struct.__dict__.__contains__, ["Struct"], true, "struct.__dict__.__contains__('Struct') == True — Struct is the compiled format object class; exported as top-level name in struct.__dict__; verified with Python 3.14.3"]
    - [dict_has_error,  struct.__dict__.__contains__, ["error"],  true, "struct.__dict__.__contains__('error') == True — error is the exception raised for struct packing/unpacking errors; exported as top-level name in struct.__dict__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct module __dict__ type check
#
# struct.__dict__.__class__.__name__ == 'dict'
# ---------------------------------------------------------------------------

table struct_extra221.dict_class_name:
  description: "struct module __dict__ type check in struct221b namespace — wave 221 theme: struct.__dict__ is an ordinary dict (unlike class __dict__ which is a mappingproxy); struct.__dict__.__class__.__name__ == 'dict'; confirmed with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: identity
  id_prefix: struct221b

  columns: [id, function, args, expected, description]
  rows:
    - [dict_class_name_is_dict, struct.__dict__.__class__.__name__.__eq__, ["dict"], true, "struct.__dict__.__class__.__name__ == 'dict' — struct.__dict__ is an ordinary dict (module __dict__ is always a plain dict, not a mappingproxy); confirmed with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants for struct __dict__ membership checks
# ---------------------------------------------------------------------------

invariant struct_extra221.dict_contains_pack:
  description: "struct.__dict__.__contains__('pack') == True — pack is the primary function for packing values into bytes; 'pack' appears as a key in struct.__dict__; struct.pack(format, v1, v2, ...) returns a bytes object containing the values packed according to the format string; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: struct.__dict__.__contains__
  args: ["pack"]
  expected: true

invariant struct_extra221.dict_contains_Struct:
  description: "struct.__dict__.__contains__('Struct') == True — Struct is the compiled format object class; 'Struct' appears as a key in struct.__dict__; struct.Struct(fmt) creates a compiled format object that can be reused for multiple pack/unpack operations more efficiently than the module-level functions; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: struct.__dict__.__contains__
  args: ["Struct"]
  expected: true

invariant struct_extra221.dict_class_name_dict:
  description: "struct.__dict__.__class__.__name__ == 'dict' — struct.__dict__ is an ordinary Python dict object (module-level __dict__ is always a plain dict, not a mappingproxy like class __dict__); __class__.__name__ returns 'dict'; confirmed with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: struct.__dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true
