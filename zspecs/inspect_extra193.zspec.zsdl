spec: inspect_extra193
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.FrameInfo.__name__ == 'FrameInfo' (len=9); FrameInfo is a namedtuple subclass defined in inspect.py; verified with Python 3.14.3."
    - "inspect.FrameInfo.__module__ == 'inspect' (len=7); defined in the inspect standard library module; verified with Python 3.14.3."
    - "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo' (len=10); FrameInfo inherits from _FrameInfo, its private namedtuple base; verified with Python 3.14.3."
    - "inspect.currentframe.__name__ == 'currentframe' (len=12); currentframe is a Python-level function in inspect.py wrapping sys._getframe; verified with Python 3.14.3."
    - "inspect.currentframe.__module__ == 'inspect' (len=7); defined in the inspect module; verified with Python 3.14.3."
    - "inspect.currentframe.__class__.__name__ == 'function' (len=8); currentframe is a Python-level function, not a C builtin; verified with Python 3.14.3."
    - "inspect.stack.__name__ == 'stack' (len=5); stack is a Python-level function in inspect.py; verified with Python 3.14.3."
    - "inspect.stack.__module__ == 'inspect' (len=7); defined in the inspect standard library module; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.FrameInfo class identity
#
# inspect.FrameInfo.__name__              == 'FrameInfo' (len=9)
# inspect.FrameInfo.__module__            == 'inspect' (len=7)
# inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo' (len=10)
#
# FrameInfo is a namedtuple subclass in inspect.py. Its direct base class is
# _FrameInfo (the private namedtuple generated class). New to extra193.
# ---------------------------------------------------------------------------

table inspect_extra193.frameinfo_identity:
  description: "inspect.FrameInfo identity: __name__=='FrameInfo'(len=9); __module__=='inspect'(len=7); __bases__[0].__name__=='_FrameInfo'(len=10); new to extra193"
  kind: python_call_eq
  category: identity
  id_prefix: inspectframe193

  columns: [id, function, args, expected, description]
  rows:
    - [frameinfo_name_eq,
       FrameInfo.__name__.__eq__,
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__name__.__eq__('FrameInfo') == True — FrameInfo is a namedtuple subclass in inspect.py; __name__ is 'FrameInfo' (len=9); str.__eq__('FrameInfo') returns True; verified with Python 3.14.3; new to extra193"]
    - [frameinfo_name_len,
       FrameInfo.__name__.__len__,
       [],
       9,
       "inspect.FrameInfo.__name__.__len__() == 9 — 'FrameInfo' has 9 characters: F-r-a-m-e-I-n-f-o; str.__len__() returns 9; verified with Python 3.14.3; new to extra193"]
    - [frameinfo_module_eq,
       FrameInfo.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FrameInfo.__module__.__eq__('inspect') == True — FrameInfo is defined in the inspect standard library module; __module__ is 'inspect' (len=7); str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra193"]
    - [frameinfo_module_len,
       FrameInfo.__module__.__len__,
       [],
       7,
       "inspect.FrameInfo.__module__.__len__() == 7 — 'inspect' has 7 characters: i-n-s-p-e-c-t; str.__len__() returns 7; verified with Python 3.14.3; new to extra193"]
    - [frameinfo_base_name_eq,
       "FrameInfo.__bases__.__getitem__(0).__name__.__eq__",
       ["_FrameInfo"],
       true,
       "inspect.FrameInfo.__bases__[0].__name__.__eq__('_FrameInfo') == True — FrameInfo inherits from _FrameInfo, the private namedtuple base generated in inspect.py; __bases__[0].__name__ is '_FrameInfo' (len=10); str.__eq__('_FrameInfo') returns True; verified with Python 3.14.3; new to extra193"]

# ---------------------------------------------------------------------------
# Table 2: inspect.currentframe identity
#
# inspect.currentframe.__name__              == 'currentframe' (len=12)
# inspect.currentframe.__module__            == 'inspect' (len=7)
# inspect.currentframe.__class__.__name__    == 'function' (len=8)
#
# currentframe is a Python-level function in inspect.py that wraps
# sys._getframe. Its __class__.__name__ is 'function' (not
# 'builtin_function_or_method'). New to extra193.
# ---------------------------------------------------------------------------

table inspect_extra193.currentframe_identity:
  description: "inspect.currentframe identity: __name__=='currentframe'(len=12); __module__=='inspect'(len=7); __class__.__name__=='function'(len=8); new to extra193"
  kind: python_call_eq
  category: identity
  id_prefix: inspectframe193

  columns: [id, function, args, expected, description]
  rows:
    - [currentframe_name_eq,
       currentframe.__name__.__eq__,
       ["currentframe"],
       true,
       "inspect.currentframe.__name__.__eq__('currentframe') == True — currentframe is a Python-level function in inspect.py wrapping sys._getframe; __name__ is 'currentframe' (len=12); str.__eq__('currentframe') returns True; verified with Python 3.14.3; new to extra193"]
    - [currentframe_name_len,
       currentframe.__name__.__len__,
       [],
       12,
       "inspect.currentframe.__name__.__len__() == 12 — 'currentframe' has 12 characters: c-u-r-r-e-n-t-f-r-a-m-e; str.__len__() returns 12; verified with Python 3.14.3; new to extra193"]
    - [currentframe_module_eq,
       currentframe.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.currentframe.__module__.__eq__('inspect') == True — currentframe is defined in the inspect module; __module__ is 'inspect' (len=7); str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra193"]
    - [currentframe_class_name_eq,
       currentframe.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.currentframe.__class__.__name__.__eq__('function') == True — currentframe is a Python-level function, not a C builtin; __class__.__name__ is 'function' (len=8); str.__eq__('function') returns True; verified with Python 3.14.3; new to extra193"]
    - [currentframe_class_name_len,
       currentframe.__class__.__name__.__len__,
       [],
       8,
       "inspect.currentframe.__class__.__name__.__len__() == 8 — 'function' has 8 characters: f-u-n-c-t-i-o-n; str.__len__() returns 8; verified with Python 3.14.3; new to extra193"]

# ---------------------------------------------------------------------------
# Table 3: inspect.stack identity
#
# inspect.stack.__name__    == 'stack' (len=5)
# inspect.stack.__module__  == 'inspect' (len=7)
#
# stack is a Python-level function in inspect.py that returns a list of
# FrameInfo objects for the current call stack. New to extra193.
# ---------------------------------------------------------------------------

table inspect_extra193.stack_identity:
  description: "inspect.stack identity: __name__=='stack'(len=5); __module__=='inspect'(len=7); new to extra193"
  kind: python_call_eq
  category: identity
  id_prefix: inspectframe193

  columns: [id, function, args, expected, description]
  rows:
    - [stack_name_eq,
       stack.__name__.__eq__,
       ["stack"],
       true,
       "inspect.stack.__name__.__eq__('stack') == True — stack is a Python-level function in inspect.py returning FrameInfo objects for the call stack; __name__ is 'stack' (len=5); str.__eq__('stack') returns True; verified with Python 3.14.3; new to extra193"]
    - [stack_name_len,
       stack.__name__.__len__,
       [],
       5,
       "inspect.stack.__name__.__len__() == 5 — 'stack' has 5 characters: s-t-a-c-k; str.__len__() returns 5; verified with Python 3.14.3; new to extra193"]
    - [stack_module_eq,
       stack.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.stack.__module__.__eq__('inspect') == True — stack is defined in the inspect standard library module; __module__ is 'inspect' (len=7); str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra193"]
    - [stack_module_len,
       stack.__module__.__len__,
       [],
       7,
       "inspect.stack.__module__.__len__() == 7 — 'inspect' has 7 characters: i-n-s-p-e-c-t; str.__len__() returns 7; verified with Python 3.14.3; new to extra193"]
    - [frameinfo_base_name_len,
       "FrameInfo.__bases__.__getitem__(0).__name__.__len__",
       [],
       10,
       "inspect.FrameInfo.__bases__[0].__name__.__len__() == 10 — '_FrameInfo' has 10 characters: _-F-r-a-m-e-I-n-f-o; str.__len__() returns 10; verified with Python 3.14.3; new to extra193"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra193
# ---------------------------------------------------------------------------

invariant inspect_extra193.frameinfo_name_eq:
  description: "inspect.FrameInfo.__name__.__eq__('FrameInfo') == True — FrameInfo is a namedtuple subclass in inspect.py; __name__ is 'FrameInfo' (len=9); verified with Python 3.14.3; new to extra193"
  category: identity
  kind: python_call_eq
  function: FrameInfo.__name__.__eq__
  args: ["FrameInfo"]
  expected: true

invariant inspect_extra193.frameinfo_module_eq:
  description: "inspect.FrameInfo.__module__.__eq__('inspect') == True — FrameInfo is defined in the inspect module; __module__ is 'inspect' (len=7); verified with Python 3.14.3; new to extra193"
  category: identity
  kind: python_call_eq
  function: FrameInfo.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra193.frameinfo_base_name_eq:
  description: "inspect.FrameInfo.__bases__[0].__name__.__eq__('_FrameInfo') == True — FrameInfo inherits from _FrameInfo, the private namedtuple base; __bases__[0].__name__ is '_FrameInfo' (len=10); verified with Python 3.14.3; new to extra193"
  category: identity
  kind: python_call_eq
  function: "FrameInfo.__bases__.__getitem__(0).__name__.__eq__"
  args: ["_FrameInfo"]
  expected: true

invariant inspect_extra193.currentframe_name_eq:
  description: "inspect.currentframe.__name__.__eq__('currentframe') == True — currentframe is a Python-level function in inspect.py; __name__ is 'currentframe' (len=12); verified with Python 3.14.3; new to extra193"
  category: identity
  kind: python_call_eq
  function: currentframe.__name__.__eq__
  args: ["currentframe"]
  expected: true

invariant inspect_extra193.currentframe_module_eq:
  description: "inspect.currentframe.__module__.__eq__('inspect') == True — currentframe is defined in the inspect module; __module__ is 'inspect' (len=7); verified with Python 3.14.3; new to extra193"
  category: identity
  kind: python_call_eq
  function: currentframe.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra193.currentframe_class_name_eq:
  description: "inspect.currentframe.__class__.__name__.__eq__('function') == True — currentframe is a Python-level function (not a C builtin); __class__.__name__ is 'function' (len=8); verified with Python 3.14.3; new to extra193"
  category: identity
  kind: python_call_eq
  function: currentframe.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra193.stack_name_eq:
  description: "inspect.stack.__name__.__eq__('stack') == True — stack is a Python-level function returning FrameInfo objects for the call stack; __name__ is 'stack' (len=5); verified with Python 3.14.3; new to extra193"
  category: identity
  kind: python_call_eq
  function: stack.__name__.__eq__
  args: ["stack"]
  expected: true

invariant inspect_extra193.stack_module_eq:
  description: "inspect.stack.__module__.__eq__('inspect') == True — stack is defined in the inspect standard library module; __module__ is 'inspect' (len=7); verified with Python 3.14.3; new to extra193"
  category: identity
  kind: python_call_eq
  function: stack.__module__.__eq__
  args: ["inspect"]
  expected: true
