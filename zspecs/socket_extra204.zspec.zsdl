spec: socket_extra204
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra203.zspec.zsdl — covers socket module __dict__.__contains__ for socket/AF_INET/AF_INET6/SOCK_STREAM/SOCK_DGRAM/gethostname/gethostbyname/getaddrinfo/create_connection; socket.socket.__mro__.__len__()==3 and __mro__[0].__name__=='socket'."
  notes:
    - "socket.socket.__mro__ is a tuple of length 3: (socket, socket, object). The two 'socket' entries are the Python-level socket class (socket.socket) and its C extension base (_socket.socket). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.socket.__mro__[0].__name__ == 'socket' — first MRO entry is the Python socket class. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.socket.__mro__[1].__name__ == 'socket' — second MRO entry is the C _socket.socket base. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.error.__mro__ is a tuple of length 4: (OSError, Exception, BaseException, object). socket.error is an alias for OSError. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.error.__mro__[0].__name__ == 'OSError' — socket.error is an alias for OSError since Python 3.3. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.error.__mro__[1].__name__ == 'Exception' — OSError inherits from Exception. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.socket.__dict__.__contains__('accept') == True — accept is in socket.socket.__dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.socket.__dict__.__contains__('close') == True — close is in socket.socket.__dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.socket.__dict__.__contains__('makefile') == True — makefile is in socket.socket.__dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__mro__ — type, length, and entry names
# ---------------------------------------------------------------------------

table socket_extra204.socket_mro_type_and_entries:
  description: "socket.socket.__mro__ is a tuple of length 3; __mro__[0].__name__=='socket' and __mro__[1].__name__=='socket'"
  kind: python_call_eq
  category: class_mro
  id_prefix: socketmro204

  columns: [id, function, args, expected, description]
  rows:
    - [socket_mro_type,   socket.__mro__.__class__.__name__.__eq__,  ["tuple"],  true,  "socket.socket.__mro__.__class__.__name__ == 'tuple' — __mro__ is always a tuple"]
    - [socket_mro_len,    socket.__mro__.__len__,                    [],         3,     "socket.socket.__mro__.__len__() == 3 — MRO is (socket, socket, object) with Python and C layers"]
    - ["socket_mro0",     "socket.__mro__[0].__name__.__eq__",       ["socket"], true,  "socket.socket.__mro__[0].__name__ == 'socket' — first MRO entry is the Python socket class"]
    - ["socket_mro1",     "socket.__mro__[1].__name__.__eq__",       ["socket"], true,  "socket.socket.__mro__[1].__name__ == 'socket' — second MRO entry is the C _socket.socket base"]

# ---------------------------------------------------------------------------
# socket.error.__mro__ — length and entry names
# ---------------------------------------------------------------------------

table socket_extra204.error_mro_length_and_names:
  description: "socket.error.__mro__.__len__()==4; OSError->Exception->BaseException->object chain"
  kind: python_call_eq
  category: class_mro
  id_prefix: socketmro204

  columns: [id, function, args, expected, description]
  rows:
    - [error_mro_len,   error.__mro__.__len__,                    [], 4,             "socket.error.__mro__.__len__() == 4 — MRO is (OSError, Exception, BaseException, object)"]
    - ["error_mro0",    "error.__mro__[0].__name__.__eq__",       ["OSError"],     true, "socket.error.__mro__[0].__name__ == 'OSError' — socket.error is an alias for OSError"]
    - ["error_mro1",    "error.__mro__[1].__name__.__eq__",       ["Exception"],   true, "socket.error.__mro__[1].__name__ == 'Exception' — OSError inherits from Exception"]
    - ["error_mro2",    "error.__mro__[2].__name__.__eq__",       ["BaseException"], true, "socket.error.__mro__[2].__name__ == 'BaseException' — third MRO entry is BaseException"]

# ---------------------------------------------------------------------------
# socket.socket.__dict__ membership — accept, close, makefile
# ---------------------------------------------------------------------------

table socket_extra204.socket_class_dict_membership:
  description: "socket.socket.__dict__.__contains__ checks for accept, close, makefile — methods defined directly on the Python-level socket class"
  kind: python_call_eq
  category: class_dict
  id_prefix: socketmro204

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_accept,   socket.__dict__.__contains__, ["accept"],   true, "socket.socket.__dict__.__contains__('accept') — accept is defined in the Python socket class"]
    - [dict_has_close,    socket.__dict__.__contains__, ["close"],    true, "socket.socket.__dict__.__contains__('close') — close is defined in the Python socket class"]
    - [dict_has_makefile, socket.__dict__.__contains__, ["makefile"], true, "socket.socket.__dict__.__contains__('makefile') — makefile is defined in the Python socket class"]
    - [error_mro_len_2,   error.__mro__.__len__,        [],           4,    "socket.error.__mro__.__len__() == 4 re-anchored in dict table"]

# ---------------------------------------------------------------------------
# Standalone invariants (8 total)
# ---------------------------------------------------------------------------

invariant socket_extra204.socket_mro_type_is_tuple:
  description: "socket.socket.__mro__.__class__.__name__ == 'tuple' — the MRO is always a tuple"
  category: class_mro
  kind: python_call_eq
  function: socket.__mro__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant socket_extra204.socket_mro_len:
  description: "socket.socket.__mro__.__len__() == 3 — socket.socket MRO is (socket, socket, object) with both Python and C layers"
  category: class_mro
  kind: python_call_eq
  function: socket.__mro__.__len__
  args: []
  expected: 3

invariant socket_extra204.socket_mro0_name:
  description: "socket.socket.__mro__[0].__name__ == 'socket' — first entry in socket.socket MRO is the Python-level socket class"
  category: class_mro
  kind: python_call_eq
  function: "socket.__mro__[0].__name__.__eq__"
  args: ["socket"]
  expected: true

invariant socket_extra204.socket_mro1_name:
  description: "socket.socket.__mro__[1].__name__ == 'socket' — second entry is the C extension _socket.socket base class"
  category: class_mro
  kind: python_call_eq
  function: "socket.__mro__[1].__name__.__eq__"
  args: ["socket"]
  expected: true

invariant socket_extra204.error_mro_len:
  description: "socket.error.__mro__.__len__() == 4 — socket.error (alias for OSError) MRO is (OSError, Exception, BaseException, object)"
  category: class_mro
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 4

invariant socket_extra204.error_mro0_name:
  description: "socket.error.__mro__[0].__name__ == 'OSError' — socket.error is an alias for OSError since Python 3.3"
  category: class_mro
  kind: python_call_eq
  function: "error.__mro__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

invariant socket_extra204.socket_dict_has_accept:
  description: "socket.socket.__dict__.__contains__('accept') == True — accept is a method defined on the Python-level socket class"
  category: class_dict
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["accept"]
  expected: true

invariant socket_extra204.socket_dict_has_makefile:
  description: "socket.socket.__dict__.__contains__('makefile') == True — makefile is a method defined on the Python-level socket class"
  category: class_dict
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["makefile"]
  expected: true

