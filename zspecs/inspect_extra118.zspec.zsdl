spec: inspect_extra118
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra117.zspec.zsdl."
    - "This spec covers: inspect.getdoc, inspect.getfile, inspect.getsource, inspect.getmembers, and inspect.getsourcefile code attributes not yet covered — getdoc.__code__.co_qualname ('getdoc', len 6), getfile.__code__.co_qualname ('getfile', len 7), getsource.__code__.co_qualname ('getsource', len 9), getmembers.__code__.co_argcount (2), getmembers.__code__.co_name ('getmembers'), getsourcefile.__code__.co_argcount (1); wave 269."
    - "inspect.getdoc.__code__.co_qualname == 'getdoc'. Verified with Python 3.14.3."
    - "inspect.getfile.__code__.co_qualname == 'getfile'. Verified with Python 3.14.3."
    - "inspect.getsource.__code__.co_qualname == 'getsource'. Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_argcount == 2. Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_name == 'getmembers'. Verified with Python 3.14.3."
    - "inspect.getsourcefile.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getdoc, getfile, getsource co_qualname code attributes
#
# Wave 269 theme: inspect introspection functions are pure-Python functions
# defined at module level in Lib/inspect.py. For top-level functions the
# code object attribute co_qualname (introduced in Python 3.11) equals
# co_name and also equals __qualname__. getdoc.__code__.co_qualname is 'getdoc'
# (6 chars), getfile.__code__.co_qualname is 'getfile' (7 chars), and
# getsource.__code__.co_qualname is 'getsource' (9 chars). Previously covered:
# getdoc.__code__.co_argcount, getdoc.__code__.co_name, getfile.__code__.co_argcount,
# getfile.__code__.co_name, getsource.__code__.co_argcount, getsource.__code__.co_name.
# New here: all three co_qualname values.
#
# getdoc.__code__.co_qualname == 'getdoc'       (len 6)
# getfile.__code__.co_qualname == 'getfile'     (len 7)
# getsource.__code__.co_qualname == 'getsource' (len 9)
#
# New to extra118.
# ---------------------------------------------------------------------------

table inspect_extra118.getdoc_getfile_getsource_co_qualname:
  description: "inspect.getdoc/getfile/getsource co_qualname: getdoc='getdoc'(6), getfile='getfile'(7), getsource='getsource'(9); co_qualname equals co_name for top-level functions; wave 269; new to extra118"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectdfsq118

  columns: [id, function, args, expected, description]
  rows:
    - [getdoc_co_qualname_eq,
       "getdoc.__code__.co_qualname.__eq__",
       ["getdoc"],
       true,
       "inspect.getdoc.__code__.co_qualname.__eq__('getdoc') == True — getdoc is a top-level function; co_qualname equals co_name ('getdoc', 6 chars); str.__eq__('getdoc') returns True; new to extra118"]
    - [getdoc_co_qualname_len,
       "getdoc.__code__.co_qualname.__len__",
       [],
       6,
       "inspect.getdoc.__code__.co_qualname.__len__() == 6 — 'getdoc' has 6 chars: g-e-t(3)+d-o-c(3); str.__len__() returns 6; new to extra118"]
    - [getfile_co_qualname_eq,
       "getfile.__code__.co_qualname.__eq__",
       ["getfile"],
       true,
       "inspect.getfile.__code__.co_qualname.__eq__('getfile') == True — getfile is a top-level function; co_qualname equals co_name ('getfile', 7 chars); str.__eq__('getfile') returns True; new to extra118"]
    - [getfile_co_qualname_len,
       "getfile.__code__.co_qualname.__len__",
       [],
       7,
       "inspect.getfile.__code__.co_qualname.__len__() == 7 — 'getfile' has 7 chars: g-e-t(3)+f-i-l-e(4); one more char than getdoc (6); str.__len__() returns 7; new to extra118"]
    - [getsource_co_qualname_eq,
       "getsource.__code__.co_qualname.__eq__",
       ["getsource"],
       true,
       "inspect.getsource.__code__.co_qualname.__eq__('getsource') == True — getsource is a top-level function; co_qualname equals co_name ('getsource', 9 chars); str.__eq__('getsource') returns True; new to extra118"]
    - [getsource_co_qualname_len,
       "getsource.__code__.co_qualname.__len__",
       [],
       9,
       "inspect.getsource.__code__.co_qualname.__len__() == 9 — 'getsource' has 9 chars: g-e-t(3)+s-o-u-r-c-e(6); longest of the three; str.__len__() returns 9; new to extra118"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getmembers code attributes
#
# Wave 269 theme: inspect.getmembers is a pure-Python function that retrieves
# all attributes of an object, optionally filtered by a predicate. Unlike
# getdoc, getfile, and getsource (all co_argcount=1), getmembers has
# co_argcount=2 (the 'object' arg and the optional 'predicate' arg). Its
# co_name and co_qualname are both 'getmembers' (10 chars). Its __name__
# and __qualname__ are also 'getmembers', and its __module__ is 'inspect'.
# None of getmembers's code attributes have been covered in prior specs.
#
# getmembers.__code__.co_argcount == 2
# getmembers.__code__.co_name == 'getmembers'       (len 10)
# getmembers.__code__.co_qualname == 'getmembers'   (len 10)
#
# New to extra118.
# ---------------------------------------------------------------------------

table inspect_extra118.getmembers_code_attrs:
  description: "inspect.getmembers code attributes: co_argcount=2 (object+predicate), co_name='getmembers'(10), co_qualname='getmembers'(10); distinct from single-arg getdoc/getfile/getsource; wave 269; new to extra118"
  kind: python_call_eq
  category: code_identity
  id_prefix: inspectgmca118

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_co_argcount,
       "getmembers.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmembers.__code__.co_argcount.__eq__(2) == True — getmembers takes 2 args: 'object' (the target to inspect) and 'predicate' (optional filter); co_argcount is 2, unlike getdoc/getfile/getsource (all co_argcount=1); int.__eq__(2) returns True; new to extra118"]
    - [getmembers_co_name_eq,
       "getmembers.__code__.co_name.__eq__",
       ["getmembers"],
       true,
       "inspect.getmembers.__code__.co_name.__eq__('getmembers') == True — co_name is the function name as it appears in bytecode; 'getmembers' has 10 chars; str.__eq__('getmembers') returns True; new to extra118"]
    - [getmembers_co_name_len,
       "getmembers.__code__.co_name.__len__",
       [],
       10,
       "inspect.getmembers.__code__.co_name.__len__() == 10 — 'getmembers' has 10 chars: g-e-t(3)+m-e-m-b-e-r-s(7); the longest of the four inspect function names considered here; str.__len__() returns 10; new to extra118"]
    - [getmembers_co_qualname_eq,
       "getmembers.__code__.co_qualname.__eq__",
       ["getmembers"],
       true,
       "inspect.getmembers.__code__.co_qualname.__eq__('getmembers') == True — top-level function; co_qualname equals co_name ('getmembers'); str.__eq__('getmembers') returns True; new to extra118"]
    - [getmembers_module_eq,
       "getmembers.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getmembers.__module__.__eq__('inspect') == True — getmembers is defined in Lib/inspect.py; __module__ is 'inspect' (7 chars); str.__eq__('inspect') returns True; new to extra118"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getsourcefile code attribute comparison
#
# Wave 269 theme: inspect.getsourcefile is a pure-Python function that returns
# the name of the Python source file in which an object was defined. Its
# co_argcount is 1 (one argument: 'object'), co_name is 'getsourcefile'
# (13 chars), and co_qualname is also 'getsourcefile' (13 chars). Its __name__
# and __qualname__ are both 'getsourcefile'. Previously covered:
# getsourcefile.__module__ and getsourcefile.__qualname__.__len__. New here:
# co_argcount, co_name, co_qualname. Comparing the four function name lengths:
# getdoc(6) < getfile(7) < getsource(9) < getsourcefile(13).
#
# getsourcefile.__code__.co_argcount == 1
# getsourcefile.__code__.co_name == 'getsourcefile'     (len 13)
# getsourcefile.__code__.co_qualname == 'getsourcefile' (len 13)
#
# New to extra118.
# ---------------------------------------------------------------------------

table inspect_extra118.getsourcefile_code_attrs:
  description: "inspect.getsourcefile code attrs: co_argcount=1, co_name='getsourcefile'(13), co_qualname='getsourcefile'(13); longest of the four inspect function names; getdoc(6)<getfile(7)<getsource(9)<getsourcefile(13); wave 269; new to extra118"
  kind: python_call_eq
  category: code_identity
  id_prefix: inspectgsfc118

  columns: [id, function, args, expected, description]
  rows:
    - [getsourcefile_co_argcount,
       "getsourcefile.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getsourcefile.__code__.co_argcount.__eq__(1) == True — getsourcefile takes 1 arg: 'object'; same argcount as getdoc, getfile, and getsource (all 1); int.__eq__(1) returns True; new to extra118"]
    - [getsourcefile_co_name_eq,
       "getsourcefile.__code__.co_name.__eq__",
       ["getsourcefile"],
       true,
       "inspect.getsourcefile.__code__.co_name.__eq__('getsourcefile') == True — co_name is 'getsourcefile' (13 chars); the longest of the four inspect function names; str.__eq__('getsourcefile') returns True; new to extra118"]
    - [getsourcefile_co_name_len,
       "getsourcefile.__code__.co_name.__len__",
       [],
       13,
       "inspect.getsourcefile.__code__.co_name.__len__() == 13 — 'getsourcefile' has 13 chars: g-e-t(3)+s-o-u-r-c-e(6)+f-i-l-e(4); 4 more than getsource (9); str.__len__() returns 13; new to extra118"]
    - [getsourcefile_co_qualname_eq,
       "getsourcefile.__code__.co_qualname.__eq__",
       ["getsourcefile"],
       true,
       "inspect.getsourcefile.__code__.co_qualname.__eq__('getsourcefile') == True — top-level function; co_qualname equals co_name ('getsourcefile', 13 chars); str.__eq__('getsourcefile') returns True; new to extra118"]
    - [getsourcefile_co_qualname_len,
       "getsourcefile.__code__.co_qualname.__len__",
       [],
       13,
       "inspect.getsourcefile.__code__.co_qualname.__len__() == 13 — 'getsourcefile' has 13 chars; same as co_name.__len__(); str.__len__() returns 13; new to extra118"]
    - [getdoc_co_qualname_len_6,
       "getdoc.__code__.co_qualname.__len__",
       [],
       6,
       "inspect.getdoc.__code__.co_qualname.__len__() == 6 — 'getdoc' is the shortest of the four names (6 < 7 < 9 < 13); anchor for the length comparison: getdoc(6) < getfile(7) < getsource(9) < getsourcefile(13); str.__len__() returns 6; new to extra118"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra118
# ---------------------------------------------------------------------------

invariant inspect_extra118.getdoc_co_qualname:
  description: "inspect.getdoc.__code__.co_qualname == 'getdoc' — top-level function; co_qualname equals co_name; len=6; wave 269; new to extra118"
  kind: python_call_eq
  function: getdoc.__code__.co_qualname.__eq__
  args: ["getdoc"]
  expected: true

invariant inspect_extra118.getfile_co_qualname:
  description: "inspect.getfile.__code__.co_qualname == 'getfile' — top-level function; co_qualname equals co_name; len=7; wave 269; new to extra118"
  kind: python_call_eq
  function: getfile.__code__.co_qualname.__eq__
  args: ["getfile"]
  expected: true

invariant inspect_extra118.getsource_co_qualname:
  description: "inspect.getsource.__code__.co_qualname == 'getsource' — top-level function; co_qualname equals co_name; len=9; wave 269; new to extra118"
  kind: python_call_eq
  function: getsource.__code__.co_qualname.__eq__
  args: ["getsource"]
  expected: true

invariant inspect_extra118.getmembers_co_argcount:
  description: "inspect.getmembers.__code__.co_argcount == 2 — takes object and predicate args; unlike getdoc/getfile/getsource (all argcount=1); wave 269; new to extra118"
  kind: python_call_eq
  function: getmembers.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra118.getsourcefile_co_name:
  description: "inspect.getsourcefile.__code__.co_name == 'getsourcefile' — longest of the four inspect function names (13 chars); wave 269; new to extra118"
  kind: python_call_eq
  function: getsourcefile.__code__.co_name.__eq__
  args: ["getsourcefile"]
  expected: true
