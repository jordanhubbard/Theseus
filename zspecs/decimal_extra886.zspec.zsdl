spec: decimal_extra886
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from:
    - decimal module CPython source
    - Python documentation for decimal.Decimal
  not_derived_from:
    - any third-party decimal or numeric library
  notes:
    - Covers decimal.Decimal additional arithmetic and comparison method qualnames
    - Includes compare, max, min, fma, scaleb, same_quantum and related variants
  created_at: "2026-04-12"

table decimal_extra886.comparison_method_qualnames:
  description: decimal.Decimal comparison method __qualname__ assertions
  kind: python_call_eq
  category: qualname
  id_prefix: dc886cq
  columns: [id, function, args, expected]
  rows:
    - [dc886cq001, decimal.Decimal.compare.__qualname__.__eq__, ["Decimal.compare"], true]
    - [dc886cq002, decimal.Decimal.compare_signal.__qualname__.__eq__, ["Decimal.compare_signal"], true]
    - [dc886cq003, decimal.Decimal.compare_total.__qualname__.__eq__, ["Decimal.compare_total"], true]
    - [dc886cq004, decimal.Decimal.compare_total_mag.__qualname__.__eq__, ["Decimal.compare_total_mag"], true]

table decimal_extra886.arithmetic_method_qualnames:
  description: decimal.Decimal arithmetic method __qualname__ assertions
  kind: python_call_eq
  category: qualname
  id_prefix: dc886aq
  columns: [id, function, args, expected]
  rows:
    - [dc886aq001, decimal.Decimal.max.__qualname__.__eq__, ["Decimal.max"], true]
    - [dc886aq002, decimal.Decimal.max_mag.__qualname__.__eq__, ["Decimal.max_mag"], true]
    - [dc886aq003, decimal.Decimal.min.__qualname__.__eq__, ["Decimal.min"], true]
    - [dc886aq004, decimal.Decimal.min_mag.__qualname__.__eq__, ["Decimal.min_mag"], true]
    - [dc886aq005, decimal.Decimal.remainder_near.__qualname__.__eq__, ["Decimal.remainder_near"], true]
    - [dc886aq006, decimal.Decimal.fma.__qualname__.__eq__, ["Decimal.fma"], true]
    - [dc886aq007, decimal.Decimal.scaleb.__qualname__.__eq__, ["Decimal.scaleb"], true]
    - [dc886aq008, decimal.Decimal.same_quantum.__qualname__.__eq__, ["Decimal.same_quantum"], true]
