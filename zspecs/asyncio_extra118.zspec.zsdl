spec: asyncio_extra118
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-future.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-future.html — Python asyncio Future documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_asyncio.c"
  notes:
    - "This spec extends asyncio_extra117.zspec.zsdl."
    - "This spec covers: wave 258 theme — asyncio.Future class method __qualname__ equality and length for methods not yet covered as equality checks, plus Future class identity. Prior specs covered: extra103 covered Future.cancel/result/done/exception/add_done_callback __qualname__ equality and lengths; extra15 covered Future method __qualname__ equality for cancel/result/done/cancelled/running/exception. NOT previously covered as __qualname__.__eq__ checks: Future.set_result (len=17), Future.set_exception (len=20), Future.remove_done_callback (len=27), Future.__await__ (len=16), Future.__iter__ (len=15), Future.__init__ (len=15). NEW in extra118: Future.set_result.__qualname__.__eq__('Future.set_result')==True; Future.set_exception.__qualname__.__eq__('Future.set_exception')==True; Future.remove_done_callback.__qualname__.__eq__('Future.remove_done_callback')==True; Future.__await__.__qualname__.__eq__('Future.__await__')==True; Future.__iter__.__qualname__.__eq__('Future.__iter__')==True; Future.__init__.__qualname__.__eq__('Future.__init__')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Future.set_result.__qualname__ == 'Future.set_result' (len=17: 'Future.'=7+'set_result'=10=17). Future.set_exception.__qualname__ == 'Future.set_exception' (len=20: 'Future.'=7+'set_exception'=13=20). Future.remove_done_callback.__qualname__ == 'Future.remove_done_callback' (len=27: 'Future.'=7+'remove_done_callback'=20=27; longest Future method qualname). Future.__await__.__qualname__ == 'Future.__await__' (len=16: 'Future.'=7+'__await__'=9=16). Future.__iter__.__qualname__ == 'Future.__iter__' (len=15: 'Future.'=7+'__iter__'=8=15; tied with __init__). Future.__init__.__qualname__ == 'Future.__init__' (len=15: tied with __iter__). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Future.__mro__.__len__() == 2 ([Future, object]; Future has no parent besides object, unlike Task which has __mro__.__len__()==3). Future.__module__ == '_asyncio' (C extension, len=8). Future.__name__ == 'Future' (len=6). Future.__bases__[0].__name__ == 'object'. Qualname length ordering: done=11 < cancel==result==13 (tied) < __init__==__iter__==15 (tied) < __await__==cancelled==exception==16 (three-way tie) < set_result=17 < set_exception=20 < add_done_callback=24 < remove_done_callback=27 (longest). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Future state-mutation method __qualname__ equality — extra118
#
# Wave 258 theme: set_result, set_exception, remove_done_callback __qualname__ equality.
#
# asyncio.Future.set_result.__qualname__            == 'Future.set_result'            (len=17)
# asyncio.Future.set_exception.__qualname__         == 'Future.set_exception'         (len=20)
# asyncio.Future.remove_done_callback.__qualname__  == 'Future.remove_done_callback'  (len=27, longest)
# ---------------------------------------------------------------------------

table asyncio_extra118.future_mutation_qualname_eq:
  description: "asyncio.Future state-mutation method __qualname__ equality checks in futmut118 namespace — wave 258 theme: set_result, set_exception, remove_done_callback __qualname__ equality; Future.set_result.__qualname__.__eq__('Future.set_result')==True (len=17: 'Future.'=7+'set_result'=10=17; set_result stores a result value in the Future and notifies callbacks; can only be called once; raises InvalidStateError if Future is already done); Future.set_result.__qualname__.__len__()==17; Future.set_exception.__qualname__.__eq__('Future.set_exception')==True (len=20: 'Future.'=7+'set_exception'=13=20; set_exception stores an exception in the Future and notifies callbacks; raises InvalidStateError if already done; raises TypeError if exc is not a BaseException subclass); Future.set_exception.__qualname__.__len__()==20; Future.remove_done_callback.__qualname__.__eq__('Future.remove_done_callback')==True (len=27: 'Future.'=7+'remove_done_callback'=20=27; the longest Future method qualname; removes a done callback previously registered with add_done_callback; returns the count of removed callbacks); Future.remove_done_callback.__qualname__.__len__()==27; compare: set_result=17 < set_exception=20 (3 more because 'set_exception'=13 vs 'set_result'=10, diff=3) < remove_done_callback=27 (7 more than set_exception: 'remove_done_callback'=20 vs 'set_exception'=13, diff=7); also Future.add_done_callback.__qualname__.__len__()==24 (3 less than remove=27); all three are C extension method_descriptors (type='method_descriptor'); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: futmut118

  columns: [id, function, args, expected, description]
  rows:
    - [sr_eq,    Future.set_result.__qualname__.__eq__,           ["Future.set_result"],           true, "Future.set_result.__qualname__ == 'Future.set_result' (len=17); verified with Python 3.14.3"]
    - [sr_len,   Future.set_result.__qualname__.__len__,          [],                              17,   "Future.set_result.__qualname__.__len__() == 17 ('Future.'=7+'set_result'=10=17); verified with Python 3.14.3"]
    - [se_eq,    Future.set_exception.__qualname__.__eq__,        ["Future.set_exception"],        true, "Future.set_exception.__qualname__ == 'Future.set_exception' (len=20); verified with Python 3.14.3"]
    - [se_len,   Future.set_exception.__qualname__.__len__,       [],                              20,   "Future.set_exception.__qualname__.__len__() == 20 ('Future.'=7+'set_exception'=13=20); verified with Python 3.14.3"]
    - [rdc_eq,   Future.remove_done_callback.__qualname__.__eq__, ["Future.remove_done_callback"], true, "Future.remove_done_callback.__qualname__ == 'Future.remove_done_callback' (len=27, longest Future method qualname); verified with Python 3.14.3"]
    - [rdc_len,  Future.remove_done_callback.__qualname__.__len__, [],                             27,   "Future.remove_done_callback.__qualname__.__len__() == 27 (longest; 'Future.'=7+'remove_done_callback'=20=27); verified with Python 3.14.3"]
    - [adc_len,  Future.add_done_callback.__qualname__.__len__,   [],                              24,   "Future.add_done_callback.__qualname__.__len__() == 24 (3 less than remove_done_callback=27); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Future iterator and init method __qualname__ equality — extra118
#
# Wave 258 theme: __await__, __iter__, __init__ __qualname__ equality.
#
# asyncio.Future.__await__.__qualname__  == 'Future.__await__'  (len=16)
# asyncio.Future.__iter__.__qualname__   == 'Future.__iter__'   (len=15, tied with __init__)
# asyncio.Future.__init__.__qualname__   == 'Future.__init__'   (len=15, tied with __iter__)
# ---------------------------------------------------------------------------

table asyncio_extra118.future_dunder_qualname_eq:
  description: "asyncio.Future dunder method __qualname__ equality checks in futmut118 namespace — wave 258 theme: __await__, __iter__, __init__ __qualname__ equality; Future.__await__.__qualname__.__eq__('Future.__await__')==True (len=16: 'Future.'=7+'__await__'=9=16; __await__ is the coroutine protocol method that makes Future awaitable; it returns a generator yielding self; enables 'result = await future' syntax in async functions); Future.__await__.__qualname__.__len__()==16; Future.__iter__.__qualname__.__eq__('Future.__iter__')==True (len=15: 'Future.'=7+'__iter__'=8=15; __iter__ is the generator protocol method used in the older 'yield from' syntax: 'result = yield from future'; tied with __init__ at len=15); Future.__iter__.__qualname__.__len__()==15; Future.__init__.__qualname__.__eq__('Future.__init__')==True (len=15: tied with __iter__: 'Future.'=7+'__init__'=8=15; __init__ initializes a new Future object, setting up internal state including _loop, _callbacks, _state, _result, _exception); Future.__init__.__qualname__.__len__()==15; compare lengths: __init__==__iter__==15 (tied; both have 8-char dunder names: '__init__'=8=='__iter__'=8) < __await__==16 ('__await__'=9, one more char than '__iter__'=8) < cancelled==exception==16 (also len=16); note: '__await__'=9 chars vs '__iter__'=8 chars (difference=1 char) propagates to qualname length difference=1; all three are C extension wrapper_descriptors (type='wrapper_descriptor'); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: futmut118a

  columns: [id, function, args, expected, description]
  rows:
    - [aw_eq,    Future.__await__.__qualname__.__eq__, ["Future.__await__"], true, "Future.__await__.__qualname__ == 'Future.__await__' (len=16; makes Future awaitable); verified with Python 3.14.3"]
    - [aw_len,   Future.__await__.__qualname__.__len__, [],                  16,   "Future.__await__.__qualname__.__len__() == 16 ('Future.'=7+'__await__'=9=16); verified with Python 3.14.3"]
    - [it_eq,    Future.__iter__.__qualname__.__eq__,  ["Future.__iter__"],  true, "Future.__iter__.__qualname__ == 'Future.__iter__' (len=15; yield-from protocol); verified with Python 3.14.3"]
    - [it_len,   Future.__iter__.__qualname__.__len__, [],                   15,   "Future.__iter__.__qualname__.__len__() == 15 (tied with __init__; '__iter__'=8=='__init__'=8); verified with Python 3.14.3"]
    - [in_eq,    Future.__init__.__qualname__.__eq__,  ["Future.__init__"],  true, "Future.__init__.__qualname__ == 'Future.__init__' (len=15; tied with __iter__); verified with Python 3.14.3"]
    - [in_len,   Future.__init__.__qualname__.__len__, [],                   15,   "Future.__init__.__qualname__.__len__() == 15 (tied with __iter__); verified with Python 3.14.3"]
    - [aw_gt_it, Future.__await__.__qualname__.__len__, [],                  16,   "Future.__await__ qualname len=16 > Future.__iter__ qualname len=15 (diff=1: '__await__'=9 vs '__iter__'=8); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Future class identity and qualname length ordering — extra118
#
# Wave 258 theme: Future class __name__/__module__/__mro__ and qualname length ordering.
#
# asyncio.Future.__name__.__len__()     == 6   ('Future'=6)
# asyncio.Future.__module__.__len__()   == 8   ('_asyncio'=8)
# asyncio.Future.__mro__.__len__()      == 2   ([Future, object])
# asyncio.Future.__bases__[0].__name__  == 'object'
# ---------------------------------------------------------------------------

table asyncio_extra118.future_class_identity:
  description: "asyncio.Future class identity checks in futmut118 namespace — wave 258 theme: Future class identity attributes; Future.__name__.__eq__('Future')==True (len=6: 'Future'=6; compare Task.__name__.__len__()==4); Future.__name__.__len__()==6; Future.__module__.__eq__('_asyncio')==True (C extension module; len=8; same module as Task: both are C-accelerated); Future.__module__.__len__()==8; Future.__mro__.__len__()==2 ([Future, object]: Future inherits only from object; unlike Task.__mro__.__len__()==3 which adds Task before Future); Future.__bases__[0].__name__.__eq__('object')==True (Future has a single base class object; contrast: Task.__bases__[0].__name__=='Future'; Task inherits from Future which inherits from object); Future.__qualname__.__class__.__name__.__eq__('str')==True (qualname is a plain str); compare: Future.__name__.__len__()==6 (2 more than Task.__name__.__len__()==4); Future.__module__.__len__()==8==Task.__module__.__len__()==8 (same C extension); Future.__mro__.__len__()==2 < Task.__mro__.__len__()==3 (Task has 1 more level via Future in its MRO); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: futmut118b

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,    Future.__name__.__eq__,                            ["Future"],    true, "Future.__name__ == 'Future' (len=6); verified with Python 3.14.3"]
    - [name_len,   Future.__name__.__len__,                           [],            6,    "Future.__name__.__len__() == 6 ('Future'=6; 2 more than Task.__name__ len=4); verified with Python 3.14.3"]
    - [mod_eq,     Future.__module__.__eq__,                          ["_asyncio"],  true, "Future.__module__ == '_asyncio' (C extension, len=8, same as Task); verified with Python 3.14.3"]
    - [mod_len,    Future.__module__.__len__,                         [],            8,    "Future.__module__.__len__() == 8 ('_asyncio'=8; same as Task.__module__.__len__()==8); verified with Python 3.14.3"]
    - [mro_len,    Future.__mro__.__len__,                            [],            2,    "Future.__mro__.__len__() == 2 ([Future, object]; Task.__mro__.__len__()==3 because Task adds one more level); verified with Python 3.14.3"]
    - [base_eq,    "Future.__bases__[0].__name__.__eq__",             ["object"],   true, "Future.__bases__[0].__name__ == 'object' (direct base is object; contrast: Task.__bases__[0].__name__=='Future'); verified with Python 3.14.3"]
    - [qn_cls_eq,  Future.__qualname__.__class__.__name__.__eq__,     ["str"],      true, "Future.__qualname__.__class__.__name__ == 'str' (qualname is a plain Python str); verified with Python 3.14.3"]
    - [qn_len,     Future.__qualname__.__len__,                       [],            6,    "Future.__qualname__.__len__() == 6 ('Future'=6, tied with __name__ len=6); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra118
# ---------------------------------------------------------------------------

invariant asyncio_extra118.future_set_result_qualname_eq:
  description: "asyncio.Future.set_result.__qualname__.__eq__('Future.set_result') returns True — 'Future.set_result' has len=17: 'Future.'=7+'set_result'=10=17; Future.set_result is a C extension method_descriptor in the _asyncio module; it stores the result value in the Future and transitions the state from PENDING to FINISHED; once set_result is called, any callbacks registered with add_done_callback are invoked; raises asyncio.InvalidStateError if the future is already done; Future.set_result.__qualname__.__len__()==17 (len=17 places it between Future.cancelled/exception/running==16 and Future.set_exception==20); compare: Task does not have set_result or set_exception (those are Future-only methods; Task's result is set internally by the event loop when the coroutine completes); Future.__module__=='_asyncio'; Future.__mro__.__len__()==2; first standalone Future.set_result qualname equality invariant in futmut118 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: Future.set_result.__qualname__.__eq__
  args: ["Future.set_result"]
  expected: true

invariant asyncio_extra118.future_set_exception_qualname_len_20:
  description: "asyncio.Future.set_exception.__qualname__.__len__() == 20 — 'Future.set_exception' = 'Future.'=7+'set_exception'=13=20; len=20 places it uniquely between set_result=17 (diff=3: 'set_exception'=13 vs 'set_result'=10) and add_done_callback=24 (diff=4: 'add_done_callback'=17 vs 'set_exception'=13); Future.set_exception.__qualname__.__eq__('Future.set_exception')==True; Future.set_exception stores an exception in the Future (requires a BaseException instance, not a class; raises TypeError for exception classes; raises asyncio.InvalidStateError if already done); 'set_exception'=13 chars vs 'set_result'=10 chars (3-char difference propagates exactly to the qualname length difference of 3); Future.__module__=='_asyncio'; Future.__name__.__len__()==6; first standalone Future.set_exception qualname length invariant in futmut118 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: Future.set_exception.__qualname__.__len__
  args: []
  expected: 20

invariant asyncio_extra118.future_remove_done_callback_qualname_len_27:
  description: "asyncio.Future.remove_done_callback.__qualname__.__len__() == 27 — 'Future.remove_done_callback' = 'Future.'=7+'remove_done_callback'=20=27; this is the longest __qualname__ of any asyncio.Future method; compare: Future.add_done_callback.__qualname__.__len__()==24 (3 shorter: 'add_done_callback'=17 vs 'remove_done_callback'=20, diff=3); Future.set_exception.__qualname__.__len__()==20 (7 shorter than remove_done_callback); Future.done.__qualname__.__len__()==11 (shortest Future method, 16 shorter than remove_done_callback); Future.remove_done_callback returns the count of removed callbacks (0 or 1); Future.remove_done_callback.__qualname__.__eq__('Future.remove_done_callback')==True; Future.__mro__.__len__()==2; Future.__module__=='_asyncio'; first standalone Future.remove_done_callback qualname length invariant in futmut118 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: Future.remove_done_callback.__qualname__.__len__
  args: []
  expected: 27

invariant asyncio_extra118.future_await_qualname_eq:
  description: "asyncio.Future.__await__.__qualname__.__eq__('Future.__await__') returns True — 'Future.__await__' has len=16: 'Future.'=7+'__await__'=9=16; Future.__await__ is a C extension wrapper_descriptor implementing the awaitable protocol; when Python executes 'result = await future', it calls future.__await__() which returns a generator; that generator yields the future itself to the event loop scheduler, which resumes it when the future is done; Future.__await__.__qualname__.__len__()==16 (tied with Future.cancelled and Future.exception at len=16; '__await__'=9 chars while 'cancelled'=9 chars too — same length); compare: '__await__'=9 > '__iter__'=8 > '__init__'=8 (both __iter__ and __init__ have len=15, one less than __await__); Future.__module__=='_asyncio'; first standalone Future.__await__ qualname equality invariant in futmut118 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: Future.__await__.__qualname__.__eq__
  args: ["Future.__await__"]
  expected: true

invariant asyncio_extra118.future_mro_len_2:
  description: "asyncio.Future.__mro__.__len__() == 2 — the MRO (Method Resolution Order) is [asyncio.Future, object]: 2 entries; Future inherits directly from object and has no intermediate base classes; compare: asyncio.Task.__mro__.__len__()==3 ([Task, Future, object]) — Task adds one more level by inheriting from Future; Future.__bases__[0].__name__=='object' (not 'Future'; contrast with Task.__bases__[0].__name__=='Future'); Future.__mro__.__len__()==2 is the minimal non-trivial MRO in Python (every class inherits object); Future.__name__.__len__()==6 ('Future'=6; 2 more than Task.__name__.__len__()==4); Future.__module__=='_asyncio' (len=8); Future.__qualname__=='Future' (len=6, same as __name__); this confirms the flat inheritance structure of asyncio.Future vs the deeper Task hierarchy; first standalone Future __mro__ length invariant in futmut118 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: Future.__mro__.__len__
  args: []
  expected: 2
