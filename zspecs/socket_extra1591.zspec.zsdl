spec: socket_extra1591
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — descriptor protocol checks via __dict__.__contains__ for socket.socket and socket exception classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for descriptor protocol"
    - "socket.socket is a Python class wrapping the C-level socket; it does not implement the descriptor protocol (__get__, __set__, __delete__) in its own __dict__."
    - "socket.socket implements the context manager protocol (__enter__, __exit__) for use with the 'with' statement."
    - "socket.error, socket.timeout, socket.herror, socket.gaierror are exception subclasses and also do not implement the descriptor protocol."
  created_at: "2026-04-12"
error_model: python_exceptions

table socket_extra1591.socket_no_descriptor:
  description: "socket.socket does not define descriptor protocol methods in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1591nd

  columns: [id, function, args, expected]
  rows:
    - ["sk1591nd001", "socket.socket.__dict__.__contains__", ["__get__"],    false]
    - ["sk1591nd002", "socket.socket.__dict__.__contains__", ["__set__"],    false]
    - ["sk1591nd003", "socket.socket.__dict__.__contains__", ["__delete__"], false]
    - ["sk1591nd004", "socket.socket.__dict__.__contains__", ["__set_name__"], false]
    - ["sk1591nd005", "socket.socket.__dict__.__contains__", ["__enter__"],  true]
    - ["sk1591nd006", "socket.socket.__dict__.__contains__", ["__exit__"],   true]
    - ["sk1591nd007", "socket.socket.__dict__.__class__.__name__.__eq__",    ["mappingproxy"], true]
    - ["sk1591nd008", "socket.socket.__name__.__eq__",       ["socket"],     true]
    - ["sk1591nd009", "socket.socket.__module__.__eq__",     ["socket"],     true]
    - ["sk1591nd010", "socket.socket.__bases__.__len__",     [],             1]
    - ["sk1591nd011", "socket.socket.__mro__.__class__.__name__.__eq__",     ["tuple"], true]
    - ["sk1591nd012", "socket.socket.__dict__.__contains__", ["__init__"],   true]
    - ["sk1591nd013", "socket.socket.__dict__.__contains__", ["__repr__"],   true]
    - ["sk1591nd014", "socket.socket.__dict__.__contains__", ["__del__"],    false]
    - ["sk1591nd015", "socket.socket.__dict__.__contains__", ["__reduce__"], false]

table socket_extra1591.socket_methods_present:
