table socket_extra1591.socket_exceptions_no_descriptor:
  description: "socket exception classes do not define descriptor protocol methods in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1591ex

  columns: [id, function, args, expected]
  rows:
    - ["sk1591ex001", "socket.error.__dict__.__contains__",   ["__get__"],    false]
    - ["sk1591ex002", "socket.error.__dict__.__contains__",   ["__set__"],    false]
    - ["sk1591ex003", "socket.error.__dict__.__contains__",   ["__delete__"], false]
    - ["sk1591ex004", "socket.timeout.__dict__.__contains__", ["__get__"],    false]
    - ["sk1591ex005", "socket.timeout.__dict__.__contains__", ["__set__"],    false]
    - ["sk1591ex006", "socket.timeout.__dict__.__contains__", ["__delete__"], false]
    - ["sk1591ex007", "socket.herror.__dict__.__contains__",  ["__get__"],    false]
    - ["sk1591ex008", "socket.herror.__dict__.__contains__",  ["__set__"],    false]
    - ["sk1591ex009", "socket.herror.__dict__.__contains__",  ["__delete__"], false]
    - ["sk1591ex010", "socket.gaierror.__dict__.__contains__", ["__get__"],   false]
    - ["sk1591ex011", "socket.gaierror.__dict__.__contains__", ["__set__"],   false]
    - ["sk1591ex012", "socket.gaierror.__dict__.__contains__", ["__delete__"], false]
    - ["sk1591ex013", "socket.error.__name__.__eq__",          ["OSError"],   true]
    - ["sk1591ex014", "socket.timeout.__name__.__eq__",        ["TimeoutError"], true]
    - ["sk1591ex015", "socket.herror.__name__.__eq__",         ["herror"],    true]
    - ["sk1591ex016", "socket.gaierror.__name__.__eq__",       ["gaierror"],  true]
    - ["sk1591ex017", "issubclass(socket.timeout, socket.error).__eq__",     [true],  true]
    - ["sk1591ex018", "issubclass(socket.herror, socket.error).__eq__",      [true],  true]
    - ["sk1591ex019", "issubclass(socket.gaierror, socket.error).__eq__",    [true],  true]
    - ["sk1591ex020", "issubclass(socket.error, OSError).__eq__",            [true],  true]
    - ["sk1591ex021", "socket.timeout.__dict__.__contains__",  ["__set_name__"], false]
    - ["sk1591ex022", "socket.herror.__dict__.__contains__",   ["__set_name__"], false]
    - ["sk1591ex023", "socket.gaierror.__dict__.__contains__", ["__set_name__"], false]
    - ["sk1591ex024", "socket.error.__dict__.__class__.__name__.__eq__",     ["mappingproxy"], true]
    - ["sk1591ex025", "socket.timeout.__dict__.__class__.__name__.__eq__",   ["mappingproxy"], true]
    - ["sk1591ex026", "socket.herror.__dict__.__class__.__name__.__eq__",    ["mappingproxy"], true]
    - ["sk1591ex027", "socket.gaierror.__dict__.__class__.__name__.__eq__",  ["mappingproxy"], true]
