table multiprocessing_extra134.mp_basemanager_identity:
  description: "multiprocessing.managers.BaseManager class identity checks in mpbasemanager134 namespace — wave 259 theme: BaseManager.__name__.__eq__('BaseManager')==True (len=11: 'Base'=4+'Manager'=7=11); BaseManager.__module__.__eq__('multiprocessing.managers')==True (len=24: 'multiprocessing'=15+'.'=1+'managers'=8=24); BaseManager.__bases__[0].__name__.__eq__('object')==True (flat hierarchy — BaseManager inherits directly from object); BaseManager.__mro__.__len__()==2 ([BaseManager, object]); BaseManager.__dict__.__len__()==22; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbasemanager134

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,   multiprocessing.managers.BaseManager.__name__.__eq__,                    ["BaseManager"],              true, "multiprocessing.managers.BaseManager.__name__ == 'BaseManager' (len=11); verified with Python 3.14.3"]
    - [name_len,  multiprocessing.managers.BaseManager.__name__.__len__,                   [],                           11,   "multiprocessing.managers.BaseManager.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [mod_eq,    multiprocessing.managers.BaseManager.__module__.__eq__,                  ["multiprocessing.managers"], true, "multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers' (len=24); verified with Python 3.14.3"]
    - [mod_len,   multiprocessing.managers.BaseManager.__module__.__len__,                 [],                           24,   "multiprocessing.managers.BaseManager.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [base0_eq,  "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__",     ["object"],                   true, "multiprocessing.managers.BaseManager.__bases__[0].__name__ == 'object'; verified with Python 3.14.3"]
    - [base0_len, "multiprocessing.managers.BaseManager.__bases__[0].__name__.__len__",    [],                           6,    "multiprocessing.managers.BaseManager.__bases__[0].__name__.__len__() == 6 ('object'=6); verified with Python 3.14.3"]
    - [mro_len,   multiprocessing.managers.BaseManager.__mro__.__len__,                    [],                           2,    "multiprocessing.managers.BaseManager.__mro__.__len__() == 2 ([BaseManager, object]); verified with Python 3.14.3"]
    - [dict_len,  multiprocessing.managers.BaseManager.__dict__.__len__,                   [],                           22,   "multiprocessing.managers.BaseManager.__dict__.__len__() == 22; verified with Python 3.14.3"]

