table multiprocessing_extra134.mp_syncmanager_identity:
  description: "multiprocessing.managers.SyncManager class identity checks in mpsyncmanager134 namespace — wave 259 theme: SyncManager.__name__.__eq__('SyncManager')==True (len=11: 'Sync'=4+'Manager'=7=11, same length as 'BaseManager'); SyncManager.__module__.__eq__('multiprocessing.managers')==True (len=24, same module as BaseManager); SyncManager.__bases__[0].__name__.__eq__('BaseManager')==True (SyncManager subclasses BaseManager, len=11); SyncManager.__mro__.__len__()==3 ([SyncManager, BaseManager, object], one deeper than BaseManager's 2); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsyncmanager134

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,   multiprocessing.managers.SyncManager.__name__.__eq__,                  ["SyncManager"],              true, "multiprocessing.managers.SyncManager.__name__ == 'SyncManager' (len=11); verified with Python 3.14.3"]
    - [name_len,  multiprocessing.managers.SyncManager.__name__.__len__,                 [],                           11,   "multiprocessing.managers.SyncManager.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [mod_eq,    multiprocessing.managers.SyncManager.__module__.__eq__,                ["multiprocessing.managers"], true, "multiprocessing.managers.SyncManager.__module__ == 'multiprocessing.managers' (len=24); verified with Python 3.14.3"]
    - [base0_eq,  "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__",   ["BaseManager"],              true, "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager' (len=11); verified with Python 3.14.3"]
    - [mro_len,   multiprocessing.managers.SyncManager.__mro__.__len__,                  [],                           3,    "multiprocessing.managers.SyncManager.__mro__.__len__() == 3 ([SyncManager, BaseManager, object]); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra134
# ---------------------------------------------------------------------------

invariant multiprocessing_extra134.Value_class_name_method:
  description: "multiprocessing.Value.__class__.__name__.__eq__('method') returns True — multiprocessing.Value is a bound method of the default SyncManager instance, NOT a standalone function; its __class__.__name__ is 'method' (6 chars); this is because multiprocessing.Value is registered via manager registration and exposed as a module-level bound method shim; multiprocessing.Value.__func__.__name__ is 'Value'; multiprocessing.Array.__class__.__name__ is also 'method'; NEW in extra134: first standalone Value class name invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Value.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra134.BaseManager_module_len_24:
  description: "multiprocessing.managers.BaseManager.__module__.__len__() == 24 — BaseManager.__module__ is 'multiprocessing.managers' (24 chars: 'multiprocessing'=15 + '.'=1 + 'managers'=8 = 24); BaseManager.__mro__.__len__()==2 ([BaseManager, object]); BaseManager.__dict__.__len__()==22; SyncManager.__module__ is also 'multiprocessing.managers' (same length=24); NEW in extra134: first standalone BaseManager module length invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.__module__.__len__
  args: []
  expected: 24

invariant multiprocessing_extra134.SyncManager_mro_len_3:
  description: "multiprocessing.managers.SyncManager.__mro__.__len__() == 3 — SyncManager's MRO is [SyncManager, BaseManager, object] (length=3); SyncManager subclasses BaseManager which in turn subclasses object; BaseManager.__mro__.__len__()==2 ([BaseManager, object]); SyncManager.__name__.__len__()==11 ('SyncManager'=11, same length as 'BaseManager'=11); SyncManager.__bases__[0].__name__ is 'BaseManager'; NEW in extra134: first standalone SyncManager MRO length invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.SyncManager.__mro__.__len__
  args: []
  expected: 3

invariant multiprocessing_extra134.BaseManager_dict_len_22:
  description: "multiprocessing.managers.BaseManager.__dict__.__len__() == 22 — BaseManager's class __dict__ has 22 entries, including start, get_server, connect, shutdown, register, _create, _debug_info, _number_of_objects, _Client, _Server, and various dunders; BaseManager.__dict__.__class__.__name__ is 'mappingproxy'; BaseManager.__name__.__len__()==11; BaseManager.__module__.__len__()==24; NEW in extra134: first standalone BaseManager dict length invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.__dict__.__len__
  args: []
  expected: 22

invariant multiprocessing_extra134.BaseManager_name_len_11:
  description: "multiprocessing.managers.BaseManager.__name__.__len__() == 11 — BaseManager.__name__ is 'BaseManager' (11 chars: 'Base'=4 + 'Manager'=7 = 11); SyncManager.__name__.__len__()==11 as well ('Sync'=4 + 'Manager'=7 = 11, tied); BaseManager.__bases__[0].__name__ is 'object' (len=6); BaseManager.__mro__.__len__()==2; NEW in extra134: first standalone BaseManager name length invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.__name__.__len__
  args: []
  expected: 11

