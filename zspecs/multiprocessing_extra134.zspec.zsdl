spec: multiprocessing_extra134
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html#managers

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#managers — Python multiprocessing managers documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "This spec covers: wave 259 theme — multiprocessing.Value and Array class names, multiprocessing.managers.BaseManager and SyncManager identity. multiprocessing.Value.__class__.__name__=='method' (Value is a bound method of SyncManager, not a standalone function); multiprocessing.Array.__class__.__name__=='method'; multiprocessing.managers.BaseManager.__name__=='BaseManager' (len=11); multiprocessing.managers.BaseManager.__module__=='multiprocessing.managers' (len=24); multiprocessing.managers.BaseManager.__bases__[0].__name__=='object'; multiprocessing.managers.BaseManager.__mro__.__len__()==2; multiprocessing.managers.BaseManager.__dict__.__len__()==22; multiprocessing.managers.SyncManager.__name__=='SyncManager' (len=11); multiprocessing.managers.SyncManager.__bases__[0].__name__=='BaseManager'; multiprocessing.managers.SyncManager.__mro__.__len__()==3. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Value and multiprocessing.Array are bound methods of the default SyncManager instance — their __class__.__name__ is 'method', NOT 'function' or 'builtin_function_or_method'. This is because they are registered manager methods accessed via a module-level shim. multiprocessing.Value.__func__.__name__=='Value'; multiprocessing.Array.__func__.__name__=='Array'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.managers.BaseManager.__module__ is 'multiprocessing.managers' (len=24: 'multiprocessing'=15+'.'=1+'managers'=8=24). BaseManager.__dict__.__len__()==22. BaseManager.__mro__.__len__()==2 ([BaseManager, object]) — flat hierarchy. SyncManager.__mro__.__len__()==3 ([SyncManager, BaseManager, object]). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Value and Array class names — extra134
#
# multiprocessing.Value.__class__.__name__ == 'method'
# multiprocessing.Array.__class__.__name__ == 'method'
# multiprocessing.Value.__func__.__name__  == 'Value'
# multiprocessing.Array.__func__.__name__  == 'Array'
# ---------------------------------------------------------------------------

table multiprocessing_extra134.mp_value_array_class:
  description: "multiprocessing.Value and Array __class__.__name__ checks in mpvalarray134 namespace — wave 259 theme: Value and Array are bound methods of the default SyncManager instance; multiprocessing.Value.__class__.__name__.__eq__('method')==True (NOT 'function' — Value is a bound method, not a plain function); multiprocessing.Array.__class__.__name__.__eq__('method')==True (same — both are manager shims); multiprocessing.Value.__func__.__name__.__eq__('Value')==True; multiprocessing.Array.__func__.__name__.__eq__('Array')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpvalarray134

  columns: [id, function, args, expected, description]
  rows:
    - [value_cls_eq,       multiprocessing.Value.__class__.__name__.__eq__,      ["method"], true, "multiprocessing.Value.__class__.__name__ == 'method' (bound method, not function); verified with Python 3.14.3"]
    - [value_cls_len,      multiprocessing.Value.__class__.__name__.__len__,      [],         6,    "multiprocessing.Value.__class__.__name__.__len__() == 6 ('method'=6); verified with Python 3.14.3"]
    - [array_cls_eq,       multiprocessing.Array.__class__.__name__.__eq__,      ["method"], true, "multiprocessing.Array.__class__.__name__ == 'method' (bound method, not function); verified with Python 3.14.3"]
    - [array_cls_len,      multiprocessing.Array.__class__.__name__.__len__,      [],         6,    "multiprocessing.Array.__class__.__name__.__len__() == 6 ('method'=6); verified with Python 3.14.3"]
    - [value_func_name_eq, multiprocessing.Value.__func__.__name__.__eq__,        ["Value"],  true, "multiprocessing.Value.__func__.__name__ == 'Value'; verified with Python 3.14.3"]
    - [array_func_name_eq, multiprocessing.Array.__func__.__name__.__eq__,        ["Array"],  true, "multiprocessing.Array.__func__.__name__ == 'Array'; verified with Python 3.14.3"]

