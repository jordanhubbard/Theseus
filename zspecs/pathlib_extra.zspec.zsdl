spec: pathlib_extra
version: ">=3.4"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath name/stem/suffix/parts/parent/joinpath/str/as_posix/relative_to"
    - "pathlib_pure.zspec.zsdl — covers class names, module, hierarchy, Windows components, match, drive, anchor"
  notes:
    - "This spec extends pathlib.zspec.zsdl and pathlib_pure.zspec.zsdl with coverage not already present."
    - "Path.__name__ == 'Path' and Path.__module__ == 'pathlib' — concrete path class identity."
    - "PurePosixPath('/a/b/c').name == 'c' — final component."
    - "PurePosixPath('/a/b/c').stem == 'c' — final component without suffix (no dot extension)."
    - "PurePosixPath('/a/b/c.txt').suffix == '.txt' — includes the leading dot."
    - "PurePosixPath('/a/b/c.txt').parent is a PurePosixPath — class name check on the parent object."
    - "PurePosixPath('/a/b') / 'c' uses __truediv__ and gives PurePosixPath('/a/b/c')."
    - "PurePosixPath('/a/b/c').parts == ('/', 'a', 'b', 'c') — tuple of all path components."
    - "All expected values verified by running Python 3.12 pathlib module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class identity — name checks (supplement pathlib_pure.zspec.zsdl)
# pathlib_pure already has PurePosixPath, PureWindowsPath, PurePath names
# We add Path.__name__ and Path.__module__
# ---------------------------------------------------------------------------

invariant pathlib_extra.Path.class_name:
  description: "Path.__name__ == 'Path'"
  category: class_metadata
  kind: python_call_eq
  function: Path.__name__.__eq__
  args: ["Path"]
  expected: true

invariant pathlib_extra.Path.module:
  description: "Path.__module__ == 'pathlib'"
  category: class_metadata
  kind: python_call_eq
  function: Path.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra.PurePosixPath.module:
  description: "PurePosixPath.__module__ == 'pathlib'"
  category: class_metadata
  kind: python_call_eq
  function: PurePosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

# ---------------------------------------------------------------------------
# PurePosixPath component access — vectors not already in pathlib.zspec.zsdl
# pathlib.zspec.zsdl has: name('/etc/passwd')=='passwd', stem('archive.tar.gz'),
#   suffix('archive.tar.gz'), suffixes, root, no_suffix.
# We add name/stem/suffix for the '/a/b/c' and '/a/b/c.txt' paths from the spec.
# ---------------------------------------------------------------------------

invariant pathlib_extra.PurePosixPath.name_abc:
  description: "PurePosixPath('/a/b/c').name == 'c'"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: name
  expected: "c"

invariant pathlib_extra.PurePosixPath.stem_no_extension:
  description: "PurePosixPath('/a/b/c').stem == 'c' — stem equals name when there is no extension"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: stem
  expected: "c"

invariant pathlib_extra.PurePosixPath.suffix_txt:
  description: "PurePosixPath('/a/b/c.txt').suffix == '.txt'"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c.txt"]
  method: suffix
  expected: ".txt"

# ---------------------------------------------------------------------------
# Parent — string value for a path with an extension
# pathlib.zspec.zsdl checks parent('/etc/passwd') == '/etc'
# We verify parent('/a/b/c.txt') == '/a/b' via __str__
# ---------------------------------------------------------------------------

invariant pathlib_extra.PurePosixPath.parent_with_ext:
  description: "str(PurePosixPath('/a/b/c.txt').parent) == '/a/b'"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c.txt"]
  method: parent
  method_chain: __str__
  expected: "/a/b"

# ---------------------------------------------------------------------------
# Division operator — PurePosixPath('/a/b') / 'c'
# pathlib.zspec.zsdl covers joinpath and __truediv__ for '/usr' / 'bin/python'
# We verify '/a/b' / 'c' == '/a/b/c' using __str__
# ---------------------------------------------------------------------------

invariant pathlib_extra.PurePosixPath.truediv_simple:
  description: "PurePosixPath('/a/b') / 'c' == PurePosixPath('/a/b/c')"
  category: joining
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b"]
  method: __truediv__
  method_args: ["c"]
  method_chain: __str__
  expected: "/a/b/c"

# ---------------------------------------------------------------------------
# Parts tuple — '/a/b/c' splits into ('/', 'a', 'b', 'c')
# pathlib.zspec.zsdl has parts for '/usr/bin/python'; we add '/a/b/c'
# ---------------------------------------------------------------------------

invariant pathlib_extra.PurePosixPath.parts_abc:
  description: "PurePosixPath('/a/b/c').parts == ('/', 'a', 'b', 'c')"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: parts
  expected: ["/", "a", "b", "c"]

# ---------------------------------------------------------------------------
# PurePosixPath suffix for file without extension — already in pathlib.zspec.zsdl
# as no_suffix for 'Makefile'; we add a path-qualified variant
# ---------------------------------------------------------------------------

invariant pathlib_extra.PurePosixPath.no_extension_suffix_empty:
  description: "PurePosixPath('/a/b/c').suffix == '' — path with no extension has empty suffix"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: suffix
  expected: ""

# ---------------------------------------------------------------------------
# Parent string value for a 3-component path
# pathlib.zspec.zsdl has parent('/etc/passwd') == '/etc'
# We add parent('/a/b/c') == '/a/b' with a different path
# ---------------------------------------------------------------------------

invariant pathlib_extra.PurePosixPath.parent_str:
  description: "str(PurePosixPath('/a/b/c').parent) == '/a/b'"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: parent
  method_chain: __str__
  expected: "/a/b"

# ---------------------------------------------------------------------------
# PurePosixPath — is_absolute check on a path starting with '/'
# pathlib.zspec.zsdl covers is_absolute for '/etc/passwd' and 'relative/path'
# We add a distinct path
# ---------------------------------------------------------------------------

invariant pathlib_extra.PurePosixPath.is_absolute_abc:
  description: "PurePosixPath('/a/b/c').is_absolute() == True"
  category: predicates
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: is_absolute
  expected: true
