spec: multiprocessing_extra2806
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "multiprocessing_extra.zspec.zsdl — covers Process.__module__, base class, factory __name__ checks"
    - "multiprocessing_extra2.zspec.zsdl — covers factory __module__ checks, extra primitive names"
    - "multiprocessing_extra2791.zspec.zsdl — covers __iand__, __ior__, __ixor__ dict-presence checks"
  notes:
    - "Wave 634 theme: __ilshift__, __irshift__, and __ipow__ dict-presence checks (in-place shift/power operators)."
    - "None of the multiprocessing public classes define __ilshift__, __irshift__, or __ipow__ in their __dict__."
    - "multiprocessing.Process is a real class (Lib/multiprocessing/process.py); Pool and ApplyResult are in Lib/multiprocessing/pool.py."
    - "multiprocessing.pool.AsyncResult is an alias for multiprocessing.pool.ApplyResult; __name__ is 'ApplyResult' in Python 3.14.4."
    - "Process, Pool, and ApplyResult are process-management/coordination classes, not numeric shift/power types."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process — __ilshift__/__irshift__/__ipow__ dict-presence checks
#
# Process is the core class for spawning new OS processes. It manages process
# lifecycle (start, join, terminate) and does not implement in-place shift or
# power operator dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2806.process_operator_dict:
  description: "multiprocessing.Process __ilshift__, __irshift__, __ipow__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2806p

  columns: [id, function, args, expected]
  rows:
    - ["mp2806p_ils",  multiprocessing.Process.__dict__.__contains__, ["__ilshift__"],  false]
    - ["mp2806p_irs",  multiprocessing.Process.__dict__.__contains__, ["__irshift__"],  false]
    - ["mp2806p_ipo",  multiprocessing.Process.__dict__.__contains__, ["__ipow__"],     false]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool — __ilshift__/__irshift__/__ipow__ dict-presence checks
#
# Pool is a process pool manager providing map/apply/starmap/imap interfaces.
# It coordinates worker processes and does not define in-place shift or power operator dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2806.pool_operator_dict:
  description: "multiprocessing.pool.Pool __ilshift__, __irshift__, __ipow__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2806pl

  columns: [id, function, args, expected]
  rows:
    - ["mp2806pl_ils",  multiprocessing.pool.Pool.__dict__.__contains__, ["__ilshift__"],  false]
    - ["mp2806pl_irs",  multiprocessing.pool.Pool.__dict__.__contains__, ["__irshift__"],  false]
    - ["mp2806pl_ipo",  multiprocessing.pool.Pool.__dict__.__contains__, ["__ipow__"],     false]

# ---------------------------------------------------------------------------
# multiprocessing.pool.ApplyResult — __ilshift__/__irshift__/__ipow__ dict-presence checks
#
# ApplyResult (also exported as AsyncResult) is the result object returned by
# Pool.apply_async(). It wraps a pending result and provides get()/ready()/wait().
# It does not implement in-place shift or power operator dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2806.applyresult_operator_dict:
  description: "multiprocessing.pool.ApplyResult __ilshift__, __irshift__, __ipow__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2806ar

  columns: [id, function, args, expected]
  rows:
    - ["mp2806ar_ils",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__ilshift__"],  false]
    - ["mp2806ar_irs",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__irshift__"],  false]
    - ["mp2806ar_ipo",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__ipow__"],     false]

# ---------------------------------------------------------------------------
# Full 3×3 cross-type matrix — Process, Pool, ApplyResult × three in-place shift/power operator dunders
#
# Consolidates the complete 3×3 dict-presence check in one table.
# Every cell is False: Process, Pool, and ApplyResult do not define <<=, >>=, or **=
# operator dunders in their respective __dict__ attributes.
# ---------------------------------------------------------------------------

table multiprocessing_extra2806.all_types_ilshift_irshift_ipow_matrix:
  description: "Full 3×3 dict-presence matrix for multiprocessing types vs __ilshift__/__irshift__/__ipow__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2806mx

  columns: [id, function, args, expected]
  rows:
    - ["mp2806mx_p_ils",   multiprocessing.Process.__dict__.__contains__,          ["__ilshift__"],  false]
    - ["mp2806mx_p_irs",   multiprocessing.Process.__dict__.__contains__,          ["__irshift__"],  false]
    - ["mp2806mx_p_ipo",   multiprocessing.Process.__dict__.__contains__,          ["__ipow__"],     false]
    - ["mp2806mx_pl_ils",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__ilshift__"],  false]
    - ["mp2806mx_pl_irs",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__irshift__"],  false]
    - ["mp2806mx_pl_ipo",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__ipow__"],     false]
    - ["mp2806mx_ar_ils",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__ilshift__"],  false]
    - ["mp2806mx_ar_irs",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__irshift__"],  false]
    - ["mp2806mx_ar_ipo",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__ipow__"],     false]
