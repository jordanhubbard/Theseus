spec: select_extra5
version: ">=3.9"
backend: python_module(select)

docs: https://docs.python.org/3/library/select.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/select.html — Python select module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/selectmodule.c"
  notes:
    - "Extends select.zspec.zsdl, select_extra, select_extra2, select_extra3, and select_extra4."
    - "select.zspec.zsdl covers: select.__name__; poll.__name__; kqueue.__name__; kevent.__name__; POLLIN/POLLOUT/POLLERR is_int; KQ_FILTER_READ/WRITE is_int; kqueue()/poll() instance class."
    - "select_extra covers: error.__name__=='error'; error.__bases__[0].__name__=='OSError'; select.__name__; select.__module__."
    - "select_extra2 covers: select.__name__/module; error.__name__=='OSError'; error base=='Exception'; POLLIN==1; POLLOUT==4; KQ_FILTER_READ==-1; KQ_FILTER_WRITE==-2; KQ_EV_ADD/DELETE/ENABLE/DISABLE."
    - "select_extra3 covers: module __name__; poll.__module__; error.__module__; POLLERR>=1; POLLERR==8; POLLHUP==16; POLLNVAL==32."
    - "select_extra4 covers: kqueue/kevent __module__/__qualname__; select.__qualname__; KQ_FILTER_PROC==-5; KQ_FILTER_SIGNAL==-6; KQ_EV_ONESHOT/CLEAR/ERROR/EOF values and types."
    - "This spec adds: PIPE_BUF value and type; POLLPRI/POLLRDNORM/POLLWRNORM/POLLRDBAND/POLLWRBAND values and types (macOS); KQ_FILTER_AIO/VNODE/TIMER values; KQ_NOTE_DELETE/WRITE/EXTEND/ATTRIB/LINK/RENAME/REVOKE vnode-watch note values; KQ_NOTE_EXIT/FORK/EXEC process-watch note values."
    - "PIPE_BUF==512 on macOS/Darwin — the minimum guaranteed atomic pipe write size (POSIX)."
    - "POLLPRI==2, POLLRDNORM==64, POLLWRNORM==4, POLLRDBAND==128, POLLWRBAND==256 on macOS/Darwin."
    - "KQ_FILTER_AIO==-3, KQ_FILTER_VNODE==-4, KQ_FILTER_TIMER==-7 on macOS/Darwin."
    - "KQ_NOTE_DELETE==1, KQ_NOTE_WRITE==2, KQ_NOTE_EXTEND==4, KQ_NOTE_ATTRIB==8, KQ_NOTE_LINK==16, KQ_NOTE_RENAME==32, KQ_NOTE_REVOKE==64 — vnode change filter notes."
    - "KQ_NOTE_EXIT==2147483648, KQ_NOTE_FORK==1073741824, KQ_NOTE_EXEC==536870912 — process exit/fork/exec filter notes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PIPE_BUF — minimum atomic pipe write size (POSIX)
#
# Not mentioned in any prior select spec.
# PIPE_BUF == 512 on macOS/Darwin.
# ---------------------------------------------------------------------------

invariant select_extra5.PIPE_BUF.is_int:
  description: "select.PIPE_BUF.__class__.__name__ == 'int' — PIPE_BUF is an integer constant"
  category: constants
  kind: python_call_eq
  function: PIPE_BUF.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant select_extra5.PIPE_BUF.value:
  description: "select.PIPE_BUF == 512 on macOS/Darwin — minimum guaranteed atomic pipe-write size"
  category: constants
  kind: python_call_eq
  function: PIPE_BUF.__eq__
  args: [512]
  expected: true

# ---------------------------------------------------------------------------
# Additional POLL* constants — macOS values
#
# select.zspec.zsdl covers POLLIN/POLLOUT/POLLERR is_int.
# select_extra2 covers POLLIN==1, POLLOUT==4.
# select_extra3 covers POLLERR==8, POLLHUP==16, POLLNVAL==32.
# New here: POLLPRI, POLLRDNORM, POLLWRNORM, POLLRDBAND, POLLWRBAND.
# ---------------------------------------------------------------------------

table select_extra5.poll_extra_constants.values:
  kind: python_call_eq
  category: constants
  id_prefix: poll_extra

  columns: [id, function, args, expected]
  rows:
    - [pri,     POLLPRI.__eq__,     [2],   true]
    - [rdnorm,  POLLRDNORM.__eq__,  [64],  true]
    - [wrnorm,  POLLWRNORM.__eq__,  [4],   true]
    - [rdband,  POLLRDBAND.__eq__,  [128], true]
    - [wrband,  POLLWRBAND.__eq__,  [256], true]

table select_extra5.poll_extra_constants.types:
  kind: python_call_eq
  category: constants
  id_prefix: poll_extra_type

  columns: [id, function, args, expected]
  rows:
    - [pri,    POLLPRI.__class__.__name__.__eq__,     ["int"], true]
    - [rdnorm, POLLRDNORM.__class__.__name__.__eq__,  ["int"], true]
    - [wrnorm, POLLWRNORM.__class__.__name__.__eq__,  ["int"], true]
    - [rdband, POLLRDBAND.__class__.__name__.__eq__,  ["int"], true]
    - [wrband,  POLLWRBAND.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# KQ_FILTER_AIO, KQ_FILTER_VNODE, KQ_FILTER_TIMER — kqueue filter constants
#
# select_extra2 covers KQ_FILTER_READ==-1 and KQ_FILTER_WRITE==-2.
# select_extra4 covers KQ_FILTER_PROC==-5 and KQ_FILTER_SIGNAL==-6.
# New here: KQ_FILTER_AIO==-3, KQ_FILTER_VNODE==-4, KQ_FILTER_TIMER==-7.
# ---------------------------------------------------------------------------

table select_extra5.kq_filter_extra.values:
  kind: python_call_eq
  category: constants
  id_prefix: kqfilter

  columns: [id, function, args, expected]
  rows:
    - [aio,   KQ_FILTER_AIO.__eq__,   [-3], true]
    - [vnode, KQ_FILTER_VNODE.__eq__, [-4], true]
    - [timer, KQ_FILTER_TIMER.__eq__, [-7], true]

table select_extra5.kq_filter_extra.types:
  kind: python_call_eq
  category: constants
  id_prefix: kqfilter_type

  columns: [id, function, args, expected]
  rows:
    - [aio,   KQ_FILTER_AIO.__class__.__name__.__eq__,   ["int"], true]
    - [vnode, KQ_FILTER_VNODE.__class__.__name__.__eq__, ["int"], true]
    - [timer, KQ_FILTER_TIMER.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# KQ_NOTE_* vnode-watch filter notes — macOS/BSD
#
# No prior select spec covers any KQ_NOTE_* constants.
# KQ_NOTE_DELETE/WRITE/EXTEND/ATTRIB/LINK/RENAME/REVOKE are vnode filter notes.
# ---------------------------------------------------------------------------

table select_extra5.kq_note_vnode.values:
  kind: python_call_eq
  category: constants
  id_prefix: kqnote_vnode

  columns: [id, function, args, expected]
  rows:
    - [delete, KQ_NOTE_DELETE.__eq__, [1],  true]
    - [write,  KQ_NOTE_WRITE.__eq__,  [2],  true]
    - [extend, KQ_NOTE_EXTEND.__eq__, [4],  true]
    - [attrib, KQ_NOTE_ATTRIB.__eq__, [8],  true]
    - [link,   KQ_NOTE_LINK.__eq__,   [16], true]
    - [rename, KQ_NOTE_RENAME.__eq__, [32], true]
    - [revoke, KQ_NOTE_REVOKE.__eq__, [64], true]

# ---------------------------------------------------------------------------
# KQ_NOTE_EXIT, KQ_NOTE_FORK, KQ_NOTE_EXEC — process-watch filter notes
#
# These large-valued constants monitor process lifecycle events via kqueue.
# ---------------------------------------------------------------------------

invariant select_extra5.KQ_NOTE_EXIT.value:
  description: "select.KQ_NOTE_EXIT == 2147483648 on macOS — process exit kevent note"
  category: constants
  kind: python_call_eq
  function: KQ_NOTE_EXIT.__eq__
  args: [2147483648]
  expected: true

invariant select_extra5.KQ_NOTE_FORK.value:
  description: "select.KQ_NOTE_FORK == 1073741824 on macOS — process fork kevent note"
  category: constants
  kind: python_call_eq
  function: KQ_NOTE_FORK.__eq__
  args: [1073741824]
  expected: true

invariant select_extra5.KQ_NOTE_EXEC.value:
  description: "select.KQ_NOTE_EXEC == 536870912 on macOS — process exec kevent note"
  category: constants
  kind: python_call_eq
  function: KQ_NOTE_EXEC.__eq__
  args: [536870912]
  expected: true
