spec: socket_extra2821
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra2806.zspec.zsdl — covers __ilshift__, __irshift__, and __ipow__ absence for socket.socket, AddressFamily, SocketKind."
    - "socket_extra2791.zspec.zsdl — covers __iand__, __ior__, and __ixor__ absence for socket.socket, AddressFamily, SocketKind."
    - "socket_extra2776.zspec.zsdl — covers __isub__, __imul__, and __itruediv__ absence for socket.socket, AddressFamily, SocketKind."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "socket.socket.__dict__.__contains__('__radd__') == False — socket.socket is a network I/O type; it does not define the reflected addition operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.socket.__dict__.__contains__('__rsub__') == False — socket.socket does not define the reflected subtraction operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.socket.__dict__.__contains__('__rmul__') == False — socket.socket does not define the reflected multiplication operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__radd__') == False — AddressFamily is an IntEnum subclass; it does not add a reflected addition operator to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__rsub__') == False — AddressFamily does not add a reflected subtraction operator to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__rmul__') == False — AddressFamily does not add a reflected multiplication operator to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__radd__') == False — SocketKind is an IntEnum subclass; it does not add a reflected addition operator to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__rsub__') == False — SocketKind does not add a reflected subtraction operator to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__rmul__') == False — SocketKind does not add a reflected multiplication operator to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket.socket.__dict__ — __radd__, __rsub__, __rmul__ absence
# socket.socket is the main socket class; it wraps a file descriptor and
# provides network I/O methods (connect, bind, send, recv, etc.). Reflected
# arithmetic operators (__radd__, __rsub__, __rmul__) have no meaning for a
# network socket and are not defined in socket.socket.__dict__.
# ---------------------------------------------------------------------------

table socket_extra2821.socket_dict_radd_rsub_rmul:
  description: "socket.socket.__dict__ does not contain __radd__, __rsub__, or __rmul__ — socket.socket is a network I/O type with no reflected arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2821

  columns: [id, function, args, expected]
  rows:
    - ["sk2821-sock-radd", socket.socket.__dict__.__contains__, ["__radd__"], false]
    - ["sk2821-sock-rsub", socket.socket.__dict__.__contains__, ["__rsub__"], false]
    - ["sk2821-sock-rmul", socket.socket.__dict__.__contains__, ["__rmul__"], false]

# ---------------------------------------------------------------------------
# Table 2: socket.AddressFamily.__dict__ — __radd__, __rsub__, __rmul__ absence
# AddressFamily is an IntEnum subclass (AF_INET=2, AF_INET6=10, AF_UNIX=1, etc.).
# It inherits integer arithmetic from int/IntEnum but does not add reflected
# arithmetic operators to its own __dict__ (checked with
# 'in AddressFamily.__dict__', not MRO lookup).
# ---------------------------------------------------------------------------

table socket_extra2821.addressfamily_dict_radd_rsub_rmul:
  description: "socket.AddressFamily.__dict__ does not contain __radd__, __rsub__, or __rmul__ — AddressFamily (IntEnum subclass) adds no reflected arithmetic operators to its own __dict__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2821

  columns: [id, function, args, expected]
  rows:
    - ["sk2821-af-radd", socket.AddressFamily.__dict__.__contains__, ["__radd__"], false]
    - ["sk2821-af-rsub", socket.AddressFamily.__dict__.__contains__, ["__rsub__"], false]
    - ["sk2821-af-rmul", socket.AddressFamily.__dict__.__contains__, ["__rmul__"], false]

# ---------------------------------------------------------------------------
# Table 3: socket.SocketKind.__dict__ — __radd__, __rsub__, __rmul__ absence
# SocketKind is an IntEnum subclass (SOCK_STREAM=1, SOCK_DGRAM=2, etc.).
# Like AddressFamily, it does not add reflected arithmetic operators to its
# own __dict__.
# ---------------------------------------------------------------------------

table socket_extra2821.socketkind_dict_radd_rsub_rmul:
  description: "socket.SocketKind.__dict__ does not contain __radd__, __rsub__, or __rmul__ — SocketKind (IntEnum subclass) adds no reflected arithmetic operators to its own __dict__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2821

  columns: [id, function, args, expected]
  rows:
    - ["sk2821-sk-radd", socket.SocketKind.__dict__.__contains__, ["__radd__"], false]
    - ["sk2821-sk-rsub", socket.SocketKind.__dict__.__contains__, ["__rsub__"], false]
    - ["sk2821-sk-rmul", socket.SocketKind.__dict__.__contains__, ["__rmul__"], false]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — socket, AddressFamily, SocketKind all absent
# ---------------------------------------------------------------------------

table socket_extra2821.all_types_all_dunders_absent:
  description: "socket.socket, socket.AddressFamily, and socket.SocketKind all lack __radd__, __rsub__, and __rmul__ in __dict__ — no socket type defines these reflected arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2821

  columns: [id, function, args, expected]
  rows:
    - ["sk2821-x-sock-radd", socket.socket.__dict__.__contains__,        ["__radd__"], false]
    - ["sk2821-x-sock-rsub", socket.socket.__dict__.__contains__,        ["__rsub__"], false]
    - ["sk2821-x-sock-rmul", socket.socket.__dict__.__contains__,        ["__rmul__"], false]
    - ["sk2821-x-af-radd",   socket.AddressFamily.__dict__.__contains__, ["__radd__"], false]
    - ["sk2821-x-af-rsub",   socket.AddressFamily.__dict__.__contains__, ["__rsub__"], false]
    - ["sk2821-x-af-rmul",   socket.AddressFamily.__dict__.__contains__, ["__rmul__"], false]
    - ["sk2821-x-sk-radd",   socket.SocketKind.__dict__.__contains__,   ["__radd__"], false]
    - ["sk2821-x-sk-rsub",   socket.SocketKind.__dict__.__contains__,   ["__rsub__"], false]
    - ["sk2821-x-sk-rmul",   socket.SocketKind.__dict__.__contains__,   ["__rmul__"], false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra2821.socket_no_radd:
  description: "socket.socket.__dict__.__contains__('__radd__') == False — socket.socket is a network I/O object; it defines no reflected addition operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: socket.socket.__dict__.__contains__
  args: ["__radd__"]
  expected: false

invariant socket_extra2821.socket_no_rsub:
  description: "socket.socket.__dict__.__contains__('__rsub__') == False — socket.socket defines no reflected subtraction operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
