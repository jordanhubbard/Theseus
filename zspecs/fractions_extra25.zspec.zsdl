spec: fractions_extra25
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions_extra24.zspec.zsdl."
    - "Prior specs covered: Fraction __module__/__name__/__qualname__ lengths, __str__/__abs__/__neg__/__pos__/__repr__/__floor__/__ceil__ qualnames and lengths, property getter qualnames, from_float/from_decimal qualnames and lengths."
    - "This spec covers: Fraction.__mro__.__len__() and __bases__[0].__name__; Fraction.__abstractmethods__.__len__() (concrete class, returns 0); Fraction arithmetic operator __qualname__.__len__() for __add__/__mul__/__truediv__ (all 45 — closure wrapper) and __eq__/__lt__ (both 15 — direct methods); Fraction.__hash__.__qualname__.__len__() (17)."
    - "Fraction.__mro__ == [Fraction, Rational, Real, Complex, Number, object] — length 6."
    - "Fraction.__bases__[0].__name__ == 'Rational' — Fraction directly subclasses the numbers.Rational ABC."
    - "Fraction.__abstractmethods__ == frozenset() — Fraction is concrete, implements all abstract methods."
    - "Fraction.__add__, __mul__, __truediv__ share __qualname__ 'Fraction._operator_fallbacks.<locals>.forward' (45 chars) — generated by _operator_fallbacks closure."
    - "Fraction.__eq__ and __lt__ have direct __qualname__ 'Fraction.__eq__' and 'Fraction.__lt__' (both 15 chars)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Fraction.__mro__.__len__() and __bases__[0].__name__
#
# Fraction sits at the bottom of the numbers ABC tower: its MRO is
# [Fraction, Rational, Real, Complex, Number, object] — length 6.
# Fraction directly inherits from numbers.Rational. No prior fractions spec
# records __mro__.__len__() or __bases__[0].__name__ for the Fraction class.
# ---------------------------------------------------------------------------

invariant fractions_extra25.Fraction.mro_len:
  description: "len(fractions.Fraction.__mro__) == 6 — [Fraction, Rational, Real, Complex, Number, object]"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__mro__.__len__
  args: []
  expected: 6

invariant fractions_extra25.Fraction.bases0_name:
  description: "fractions.Fraction.__bases__[0].__name__ == 'Rational'"
  category: class_identity
  kind: python_call_eq
  function: "Fraction.__bases__[0].__name__.__eq__"
  args: ["Rational"]
  expected: true

# ---------------------------------------------------------------------------
# Fraction.__abstractmethods__.__len__() == 0
#
# Fraction is a concrete class that implements all abstract methods declared
# by the numbers.Rational ABC. Therefore its __abstractmethods__ frozenset is
# empty (length 0). This contrasts with the ABC classes in the numbers module
# (Complex=16, Real=23, Rational=24, Integral=34). No prior fractions spec
# records this check.
# ---------------------------------------------------------------------------

invariant fractions_extra25.Fraction.abstractmethods_len:
  description: "len(fractions.Fraction.__abstractmethods__) == 0 — Fraction is concrete; all abstract methods implemented"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__abstractmethods__.__len__
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# Arithmetic operator __qualname__.__len__() — closure-generated vs. direct
#
# Fraction arithmetic operators fall into two groups:
# 1. __add__, __mul__, __truediv__ are generated by _operator_fallbacks() and
#    have __qualname__ == 'Fraction._operator_fallbacks.<locals>.forward' (45 chars).
# 2. __eq__ and __lt__ are directly defined methods with __qualname__ ==
#    'Fraction.__eq__' and 'Fraction.__lt__' respectively (both 15 chars).
# No prior fractions spec records __qualname__.__len__() for any of these operators.
# ---------------------------------------------------------------------------

table fractions_extra25.operator_qualname_lens:
  description: "__qualname__.__len__() for Fraction arithmetic and comparison operators"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [__add__,
       "Fraction.__add__.__qualname__.__len__",
       [],
       45,
       "Fraction.__add__.__qualname__ is the _operator_fallbacks closure 'forward' (45 chars)"]
    - [__mul__,
       "Fraction.__mul__.__qualname__.__len__",
       [],
       45,
       "Fraction.__mul__.__qualname__ is the _operator_fallbacks closure 'forward' (45 chars)"]
    - [__truediv__,
       "Fraction.__truediv__.__qualname__.__len__",
       [],
       45,
       "Fraction.__truediv__.__qualname__ is the _operator_fallbacks closure 'forward' (45 chars)"]
    - [__eq__,
       "Fraction.__eq__.__qualname__.__len__",
       [],
       15,
       "Fraction.__eq__.__qualname__ == 'Fraction.__eq__' (15 chars) — direct method"]
    - [__lt__,
       "Fraction.__lt__.__qualname__.__len__",
       [],
       15,
       "Fraction.__lt__.__qualname__ == 'Fraction.__lt__' (15 chars) — direct method"]

# ---------------------------------------------------------------------------
# Fraction.__hash__.__qualname__.__len__() == 17 — standalone
#
# Fraction.__hash__.__qualname__ == 'Fraction.__hash__' (17 chars). __hash__
# is a directly defined method, not generated by _operator_fallbacks, so its
# qualname follows the 'Fraction.<name>' pattern. At 6 chars, '__hash__' is
# longer than '__eq__' and '__lt__' (each 4 chars including underscores),
# giving a composite qualname of 17 chars. No prior fractions spec records
# Fraction.__hash__.__qualname__.__len__().
# ---------------------------------------------------------------------------

invariant fractions_extra25.Fraction.hash_qualname_len:
  description: "len(fractions.Fraction.__hash__.__qualname__) == 17 — 'Fraction.__hash__' is 17 chars"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Fraction.__hash__.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# Fraction.__add__.__qualname__.__len__() == 45 — standalone
#
# Fraction.__add__.__qualname__ == 'Fraction._operator_fallbacks.<locals>.forward'
# (45 chars). This is the longest __qualname__ of any Fraction method measured
# across all fractions specs, reflecting the closure nesting from the
# _operator_fallbacks factory function. __mul__ and __truediv__ share this
# same qualname and length.
# ---------------------------------------------------------------------------

invariant fractions_extra25.Fraction.add_qualname_len:
  description: "len(fractions.Fraction.__add__.__qualname__) == 45 — '_operator_fallbacks.<locals>.forward' closure is 45 chars"
  category: method_qualname_lengths
  kind: python_call_eq
  function: "Fraction.__add__.__qualname__.__len__"
  args: []
  expected: 45

# ---------------------------------------------------------------------------
# Fraction.__bases__[0].__name__.__len__() == 8 — standalone
#
# Fraction.__bases__[0].__name__ == 'Rational' (8 chars). Knowing the length
# of the base class name complements the equality check above and is consistent
# with numbers.Rational.__name__.__len__() == 8. No prior fractions spec
# records this length as a standalone invariant.
# ---------------------------------------------------------------------------

invariant fractions_extra25.Fraction.bases0_name_len:
  description: "len(fractions.Fraction.__bases__[0].__name__) == 8 — 'Rational' is 8 chars"
  category: class_identity
  kind: python_call_eq
  function: "Fraction.__bases__[0].__name__.__len__"
  args: []
  expected: 8
