spec: io_extra2566
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2566 (_extra2566): __getattr__, __setattr__, __delattr__ dict-presence checks for io classes."
    - "None of the io stream classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, TextIOWrapper) define custom attribute access protocol."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

table io_extra2566.getattr_protocol:
  description: "io stream classes __getattr__ dict-presence — all False (no custom __getattr__ defined)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2566

