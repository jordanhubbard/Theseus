spec: threading_extra32
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra31.zspec.zsdl."
    - "Prior specs covered: Thread.__name__/__module__/__qualname__, Lock/RLock/Event/Condition/Semaphore/BoundedSemaphore/Timer/Barrier class names/modules, current_thread/main_thread/active_count/__name__, TIMEOUT_MAX, local().__class__.__name__, threading.excepthook/__name__, class __module__/__name__/__qualname__ length tables, Lock.__module__.__len__()==7 (C extension), Thread/Event/Semaphore/Condition method qualname lens, class __bases__[0].__name__ for Thread/Event/Semaphore/BoundedSemaphore/Timer, Thread/__mro__.__len__()==2, BoundedSemaphore/__mro__.__len__()==3."
    - "This spec covers: threading.__all__.__len__() and __class__.__name__.__len__(); class __dict__.__class__.__name__.__len__() for Thread/Event/Timer/Barrier/Condition/Semaphore; __mro__.__len__() for Event/Timer/Condition/Barrier; Barrier/__bases__[0].__name__ and Condition/__bases__[0].__name__; threading.TIMEOUT_MAX.__class__.__name__.__len__(); threading.Lock() instance __class__.__name__.__len__() (C type)."
    - "threading.__all__ is a list — __class__.__name__ == 'list', __len__() == 4."
    - "threading.__all__.__len__() == 28 — the module exports 28 public names."
    - "Class __dict__ is a mappingproxy for all pure-Python threading classes — 'mappingproxy' has 12 characters."
    - "Lock() instance is a C type (_thread.lock) — __class__.__name__ == 'lock' (4 chars)."
    - "RLock() instance is a Python class — __class__.__name__ == 'RLock' (5 chars)."
    - "Event.__mro__.__len__() == 2 — [Event, object]."
    - "Timer.__mro__.__len__() == 3 — [Timer, Thread, object]."
    - "Condition.__mro__.__len__() == 2 — [Condition, object]."
    - "Barrier.__mro__.__len__() == 2 — [Barrier, object]."
    - "Barrier.__bases__[0].__name__ == 'object' — Barrier inherits directly from object."
    - "Condition.__bases__[0].__name__ == 'object' — Condition inherits directly from object."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.__all__ metadata — extra32 namespace
#
# threading.__all__ is a list (not a tuple).
# __class__.__name__ == 'list' (4 chars); __len__() == 28.
# Prior specs have not measured __all__ metadata for threading.
# ---------------------------------------------------------------------------

table threading_extra32.all_metadata:
  description: "threading.__all__ metadata: list type name length and export count in extra32 namespace"
  kind: python_call_eq
  category: module_structure
  id_prefix: allmetadata32

  columns: [id, function, args, expected]
  rows:
    - [all_class_name_len, threading.__all__.__class__.__name__.__len__, [], 4]
    - [all_len,            threading.__all__.__len__,                    [], 28]

# ---------------------------------------------------------------------------
# Class __dict__.__class__.__name__.__len__() table — extra32 namespace
#
# Pure-Python threading classes have __dict__ of type mappingproxy.
# 'mappingproxy' has 12 characters. Classes measured: Thread, Event,
# Timer, Barrier, Condition, Semaphore — all yield 12.
# Note: threading.Lock returns a C-extension object (not a Python class),
# so threading.Lock.__dict__ is NOT a mappingproxy; Lock instances are
# _thread.lock objects with __class__.__name__ == 'lock' (4 chars).
# ---------------------------------------------------------------------------

table threading_extra32.class_dict_class_name_lengths:
  description: "threading class __dict__.__class__.__name__.__len__() for pure-Python classes in extra32 namespace — all equal 12 (mappingproxy)"
  kind: python_call_eq
  category: class_structure
  id_prefix: classdictnamelen32

  columns: [id, function, args, expected]
  rows:
    - [Thread,    Thread.__dict__.__class__.__name__.__len__,    [], 12]
    - [Event,     Event.__dict__.__class__.__name__.__len__,     [], 12]
    - [Timer,     Timer.__dict__.__class__.__name__.__len__,     [], 12]
    - [Barrier,   Barrier.__dict__.__class__.__name__.__len__,   [], 12]
    - [Condition, Condition.__dict__.__class__.__name__.__len__, [], 12]
    - [Semaphore, Semaphore.__dict__.__class__.__name__.__len__, [], 12]

# ---------------------------------------------------------------------------
# Class __mro__.__len__() table — extra32 namespace
#
# MRO depths for threading classes not yet measured:
#   Event.__mro__.__len__()     == 2 — [Event, object]
#   Timer.__mro__.__len__()     == 3 — [Timer, Thread, object]
#   Condition.__mro__.__len__() == 2 — [Condition, object]
#   Barrier.__mro__.__len__()   == 2 — [Barrier, object]
# Prior spec (extra31) measured Thread (2) and BoundedSemaphore (3).
# Timer has depth 3 because it inherits from Thread; the others are flat.
# ---------------------------------------------------------------------------

table threading_extra32.class_mro_lengths:
  description: "threading class __mro__.__len__() for Event/Timer/Condition/Barrier in extra32 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: clsmrolen32

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [Event,     Event.__mro__,     [], !ascii "", __len__, [], "Event MRO depth == 2"]
    - [Timer,     Timer.__mro__,     [], !ascii "", __len__, [], "Timer MRO depth == 3"]
    - [Condition, Condition.__mro__, [], !ascii "", __len__, [], "Condition MRO depth == 2"]
    - [Barrier,   Barrier.__mro__,   [], !ascii "", __len__, [], "Barrier MRO depth == 2"]

# ---------------------------------------------------------------------------
# Class __bases__[0].__name__ table for Barrier and Condition — extra32
#
# threading.Barrier and threading.Condition both inherit directly from object,
# making them flat classes (MRO depth 2). This is in contrast to:
#   - BoundedSemaphore (extends Semaphore)
#   - Timer (extends Thread)
# which were measured in extra31. Barrier and Condition were not covered there.
# ---------------------------------------------------------------------------

table threading_extra32.barrier_condition_bases_names:
  description: "threading.Barrier and threading.Condition __bases__[0].__name__ in extra32 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: barcondbasename32

  columns: [id, function, args, expected]
  rows:
    - [Barrier,   "Barrier.__bases__[0].__name__.__eq__",   ["object"], true]
    - [Condition, "Condition.__bases__[0].__name__.__eq__", ["object"], true]

# ---------------------------------------------------------------------------
# threading.TIMEOUT_MAX class name length — extra32 standalone invariant
#
# threading.TIMEOUT_MAX is the maximum timeout value, a float constant.
# Its __class__.__name__ == 'float' (5 chars). Prior specs mentioned
# TIMEOUT_MAX exists but did not measure __class__.__name__.__len__().
# ---------------------------------------------------------------------------

invariant threading_extra32.TIMEOUT_MAX_class_name_len:
  description: "threading.TIMEOUT_MAX.__class__.__name__.__len__() == 5 — TIMEOUT_MAX is a float constant"
  category: class_structure
  kind: python_call_eq
  function: threading.TIMEOUT_MAX.__class__.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# Lock C-extension instance class name length — extra32 standalone invariant
#
# threading.Lock() returns a C-extension object (_thread.lock), not a Python
# class instance. Its __class__.__name__ == 'lock' (4 chars). This contrasts
# with RLock(), which is a pure-Python class with __class__.__name__ == 'RLock'
# (5 chars). This invariant captures the C-extension nature of Lock.
# Note: the function chain uses threading.Lock().__class__.__name__.__len__
# but per ZSDL rules we use a module-qualified path.
# ---------------------------------------------------------------------------

invariant threading_extra32.all_len:
  description: "threading.__all__.__len__() == 28 — the module exports 28 public names"
  category: module_structure
  kind: python_call_eq
  function: threading.__all__.__len__
  args: []
  expected: 28

invariant threading_extra32.Barrier_base_name_eq:
  description: "threading.Barrier.__bases__[0].__name__ == 'object' — Barrier inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: "Barrier.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra32.Timer_mro_len:
  description: "threading.Timer.__mro__.__len__() == 3 — [Timer, Thread, object] reflects Thread inheritance"
  category: class_hierarchy
  kind: python_call_eq
  function: Timer.__mro__.__len__
  args: []
  expected: 3
