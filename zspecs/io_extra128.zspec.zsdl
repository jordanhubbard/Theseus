spec: io_extra128
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec extends io_extra127.zspec.zsdl."
    - "This spec covers: io.IOBase method __qualname__ string equality for writelines, truncate, seek, fileno, __enter__, and __exit__ — not yet covered by any prior io_extra spec."
    - "io_extra116 covered qualname equality for: close('_IOBase.close'), flush('_IOBase.flush'), readable('_IOBase.readable'), writable('_IOBase.writable'), seekable('_IOBase.seekable'), readline('_IOBase.readline')."
    - "io_extra43 covered qualname __len__() for: writelines(18), truncate(16), fileno(14), readline(16), readlines(17)."
    - "NO prior io spec asserts IOBase.writelines.__qualname__.__eq__('_IOBase.writelines') — only __len__() was covered."
    - "NO prior io spec asserts IOBase.truncate.__qualname__.__eq__('_IOBase.truncate') — only __len__() was covered."
    - "NO prior io spec asserts IOBase.fileno.__qualname__.__eq__('_IOBase.fileno') — only __len__() was covered."
    - "NO prior io spec asserts IOBase.__enter__.__qualname__.__eq__('_IOBase.__enter__') or __len__() — fully novel."
    - "NO prior io spec asserts IOBase.__exit__.__qualname__.__eq__('_IOBase.__exit__') or __len__() — fully novel."
    - "NO prior io spec asserts IOBase.seek.__qualname__.__eq__('_IOBase.seek') — only __class__.__name__=='method_descriptor' was covered."
    - "io.IOBase.writelines.__qualname__ == '_IOBase.writelines' (len 18; longest IOBase method qualname)."
    - "io.IOBase.truncate.__qualname__ == '_IOBase.truncate' (len 16)."
    - "io.IOBase.seek.__qualname__ == '_IOBase.seek' (len 12; shortest in this set)."
    - "io.IOBase.fileno.__qualname__ == '_IOBase.fileno' (len 14)."
    - "io.IOBase.__enter__.__qualname__ == '_IOBase.__enter__' (len 17)."
    - "io.IOBase.__exit__.__qualname__ == '_IOBase.__exit__' (len 16)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.IOBase.writelines, truncate, seek __qualname__ string equality
# writelines: '_IOBase.writelines' (18 chars; longest IOBase method qualname).
# truncate: '_IOBase.truncate' (16 chars).
# seek: '_IOBase.seek' (12 chars; tied with tell for shortest IOBase method qualname).
# io_extra43 covered writelines __len__()==18 and truncate __len__()==16.
# io_extra105 covered seek.__class__.__name__=='method_descriptor'.
# NO prior io spec asserts the qualname string value for any of these three.
# ---------------------------------------------------------------------------

table io_extra128.IOBase_writelines_truncate_seek_qualnames:
  description: "io.IOBase writelines/truncate/seek __qualname__ string equality: '_IOBase.writelines'(18), '_IOBase.truncate'(16), '_IOBase.seek'(12); io_extra43 covered __len__ for writelines/truncate; no prior spec covers equality for any of these three; all use '_IOBase.' prefix from C extension _io._IOBase"
  kind: python_call_eq
  category: qualnames
  id_prefix: iobase128a

  columns: [id, function, args, expected, description]
  rows:
    - [wl_qn_eq,       "IOBase.writelines.__qualname__.__eq__",      ["_IOBase.writelines"],  true,  "io.IOBase.writelines.__qualname__ == '_IOBase.writelines' (18 chars; longest IOBase method qualname; '_IOBase.' prefix reflects C implementation in _io._IOBase; writelines writes a list of lines to the stream)"]
    - [wl_qn_len,      "IOBase.writelines.__qualname__.__len__",     [],                      18,    "io.IOBase.writelines.__qualname__.__len__() == 18 ('_IOBase.'(8)+'writelines'(10)==18; longest IOBase method qualname; io_extra43 covered this length but not the equality)"]
    - [tr_qn_eq,       "IOBase.truncate.__qualname__.__eq__",        ["_IOBase.truncate"],    true,  "io.IOBase.truncate.__qualname__ == '_IOBase.truncate' (16 chars; truncate resizes the stream to at most size bytes; the C-level qualname uses '_IOBase.' prefix, not 'IOBase.')"]
    - [tr_qn_len,      "IOBase.truncate.__qualname__.__len__",       [],                      16,    "io.IOBase.truncate.__qualname__.__len__() == 16 ('_IOBase.'(8)+'truncate'(8)==16; io_extra43 covered this length but not the equality; same length as readable/writable/seekable/readline)"]
    - [seek_qn_eq,     "IOBase.seek.__qualname__.__eq__",            ["_IOBase.seek"],        true,  "io.IOBase.seek.__qualname__ == '_IOBase.seek' (12 chars; seek changes the stream position; '_IOBase.seek' at 12 chars is the shortest qualname in this group; tied with '_IOBase.tell' covered in io_extra116)"]
    - [seek_qn_len,    "IOBase.seek.__qualname__.__len__",           [],                      12,    "io.IOBase.seek.__qualname__.__len__() == 12 ('_IOBase.'(8)+'seek'(4)==12; same length as '_IOBase.tell' from io_extra116; shortest in this table)"]
    - [wl_ne_tr,       "IOBase.writelines.__qualname__.__eq__",      ["_IOBase.truncate"],    false, "io.IOBase.writelines.__qualname__ != '_IOBase.truncate' (writelines is 18 chars, truncate is 16; distinct methods despite both starting with '_IOBase.')"]
    - [wl_gt_seek,     "IOBase.writelines.__qualname__.__len__.__gt__", [12],                 true,  "len('_IOBase.writelines') > len('_IOBase.seek') (18 > 12; writelines qualname is 6 chars longer than seek qualname)"]

# ---------------------------------------------------------------------------
# io.IOBase.fileno, __enter__, __exit__ __qualname__ string equality
# fileno: '_IOBase.fileno' (14 chars; returns file descriptor integer).
# __enter__: '_IOBase.__enter__' (17 chars; context manager entry).
# __exit__: '_IOBase.__exit__' (16 chars; context manager exit).
# io_extra43 covered fileno __len__()==14 but not equality.
# NO prior io spec asserts __enter__ or __exit__ qualname at all (any form).
# These confirm IOBase participates in the context manager protocol via _IOBase.
# ---------------------------------------------------------------------------

table io_extra128.IOBase_fileno_enter_exit_qualnames:
  description: "io.IOBase fileno/__enter__/__exit__ __qualname__ string equality: '_IOBase.fileno'(14), '_IOBase.__enter__'(17), '_IOBase.__exit__'(16); io_extra43 covered fileno __len__ only; __enter__ and __exit__ qualnames are fully novel (no prior io spec asserts them)"
  kind: python_call_eq
  category: qualnames
  id_prefix: iobase128b

  columns: [id, function, args, expected, description]
  rows:
    - [fi_qn_eq,       "IOBase.fileno.__qualname__.__eq__",          ["_IOBase.fileno"],      true,  "io.IOBase.fileno.__qualname__ == '_IOBase.fileno' (14 chars; fileno returns the file descriptor integer for the stream; most IOBase subclasses raise UnsupportedOperation from their fileno implementation)"]
    - [fi_qn_len,      "IOBase.fileno.__qualname__.__len__",         [],                      14,    "io.IOBase.fileno.__qualname__.__len__() == 14 ('_IOBase.'(8)+'fileno'(6)==14; io_extra43 covered this length but not the equality assertion; tied with isatty at 14 chars)"]
    - [en_qn_eq,       "IOBase.__enter__.__qualname__.__eq__",       ["_IOBase.__enter__"],   true,  "io.IOBase.__enter__.__qualname__ == '_IOBase.__enter__' (17 chars; context manager entry; returns self so that the stream can be used as a context manager with 'with' statements)"]
    - [en_qn_len,      "IOBase.__enter__.__qualname__.__len__",      [],                      17,    "io.IOBase.__enter__.__qualname__.__len__() == 17 ('_IOBase.'(8)+'__enter__'(9)==17; no prior io spec asserts any attribute of IOBase.__enter__.__qualname__)"]
    - [ex_qn_eq,       "IOBase.__exit__.__qualname__.__eq__",        ["_IOBase.__exit__"],    true,  "io.IOBase.__exit__.__qualname__ == '_IOBase.__exit__' (16 chars; context manager exit; calls self.close() when the 'with' block ends regardless of whether an exception occurred)"]
    - [ex_qn_len,      "IOBase.__exit__.__qualname__.__len__",       [],                      16,    "io.IOBase.__exit__.__qualname__.__len__() == 16 ('_IOBase.'(8)+'__exit__'(8)==16; no prior io spec asserts any attribute of IOBase.__exit__.__qualname__)"]
    - [en_gt_ex,       "IOBase.__enter__.__qualname__.__len__.__gt__", [16],                  true,  "len('_IOBase.__enter__') > len('_IOBase.__exit__') (17 > 16; __enter__ qualname is 1 char longer than __exit__ qualname because '__enter__'(9) > '__exit__'(8))"]
    - [fi_ne_en,       "IOBase.fileno.__qualname__.__eq__",          ["_IOBase.__enter__"],   false, "io.IOBase.fileno.__qualname__ != '_IOBase.__enter__' (fileno is 14 chars, __enter__ is 17 chars; distinct methods with different qualnames and lengths)"]

# ---------------------------------------------------------------------------
# io.IOBase qualname cross-comparisons: writelines vs __enter__ vs truncate
# Confirms relative ordering: seek(12) < fileno(14) < truncate(16) == __exit__(16) < __enter__(17) < writelines(18).
# Also confirms all qualnames share the '_IOBase.' (8 char) prefix.
# These cross-comparisons are fully novel — no prior io spec compares qualname lengths across this set.
# ---------------------------------------------------------------------------

table io_extra128.IOBase_qualname_cross_comparisons:
  description: "io.IOBase qualname length cross-comparisons: seek(12) < fileno(14) < truncate(16)==__exit__(16) < __enter__(17) < writelines(18); all start with '_IOBase.'(8-char prefix); all cross-comparison assertions novel"
  kind: python_call_eq
  category: qualnames
  id_prefix: iobase128c

  columns: [id, function, args, expected, description]
  rows:
    - [seek_lt_fi,     "IOBase.seek.__qualname__.__len__.__lt__",    [14],                    true,  "len('_IOBase.seek') < len('_IOBase.fileno') (12 < 14; seek is 2 chars shorter than fileno; 'seek'(4) vs 'fileno'(6))"]
    - [fi_lt_tr,       "IOBase.fileno.__qualname__.__len__.__lt__",  [16],                    true,  "len('_IOBase.fileno') < len('_IOBase.truncate') (14 < 16; fileno is 2 chars shorter than truncate; 'fileno'(6) vs 'truncate'(8))"]
    - [tr_eq_ex,       "IOBase.truncate.__qualname__.__len__.__eq__", [16],                   true,  "len('_IOBase.truncate') == len('_IOBase.__exit__') == 16 (truncate and __exit__ share identical qualname length; both are 16 chars)"]
    - [ex_lt_en,       "IOBase.__exit__.__qualname__.__len__.__lt__", [17],                   true,  "len('_IOBase.__exit__') < len('_IOBase.__enter__') (16 < 17; __exit__(8) is 1 char shorter than __enter__(9))"]
    - [en_lt_wl,       "IOBase.__enter__.__qualname__.__len__.__lt__", [18],                  true,  "len('_IOBase.__enter__') < len('_IOBase.writelines') (17 < 18; __enter__ is 1 char shorter than writelines; writelines at 18 is the longest IOBase method qualname)"]
    - [wl_is_longest,  "IOBase.writelines.__qualname__.__len__.__gt__", [17],                 true,  "len('_IOBase.writelines') > len('_IOBase.__enter__') (18 > 17; writelines has the longest qualname of all IOBase methods in this spec)"]
    - [en_prefix,      "IOBase.__enter__.__qualname__.__contains__", ["_IOBase."],            true,  "io.IOBase.__enter__.__qualname__.__contains__('_IOBase.') == True (the '_IOBase.' prefix is present in all IOBase method qualnames; confirms that __enter__ is implemented in the C extension _io._IOBase type)"]
    - [ex_prefix,      "IOBase.__exit__.__qualname__.__contains__",  ["_IOBase."],            true,  "io.IOBase.__exit__.__qualname__.__contains__('_IOBase.') == True (same '_IOBase.' prefix as all other IOBase methods; __exit__ calls close() and is part of the context manager protocol)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra128.IOBase.writelines_qualname_eq:
  description: "io.IOBase.writelines.__qualname__ == '_IOBase.writelines' (18 chars; 'writelines' at 10 chars is the longest method name among all IOBase methods; the '_IOBase.' prefix at 8 chars comes from the C extension type _io._IOBase which is the actual implementation class for IOBase; writelines(lines) writes a list of lines to the stream, calling write() for each; io_extra43 covered __qualname__.__len__()==18 for writelines but did not assert the string value by equality; this is the first io spec to assert IOBase.writelines.__qualname__.__eq__('_IOBase.writelines')); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: "IOBase.writelines.__qualname__.__eq__"
  args: ["_IOBase.writelines"]
  expected: true

invariant io_extra128.IOBase.fileno_qualname_eq:
  description: "io.IOBase.fileno.__qualname__ == '_IOBase.fileno' (14 chars; fileno() returns the underlying file descriptor integer associated with the stream; most IOBase implementations that do not wrap a real OS file descriptor raise io.UnsupportedOperation from fileno(); '_IOBase.fileno' has 8-char prefix '_IOBase.' and 6-char suffix 'fileno'; io_extra43 covered __qualname__.__len__()==14 for fileno but never asserted the qualname string by equality; this is the first io spec to assert IOBase.fileno.__qualname__.__eq__('_IOBase.fileno')); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: "IOBase.fileno.__qualname__.__eq__"
  args: ["_IOBase.fileno"]
  expected: true

invariant io_extra128.IOBase.__enter___qualname_eq:
  description: "io.IOBase.__enter__.__qualname__ == '_IOBase.__enter__' (17 chars; __enter__ enables IOBase objects to be used as context managers with Python 'with' statements; it simply returns self so the opened stream is available as the 'as' target; '_IOBase.__enter__' is 17 chars: '_IOBase.'(8)+'__enter__'(9)==17; no prior io_extra spec asserts any attribute of IOBase.__enter__.__qualname__ — neither __eq__ nor __len__ was ever covered; this is fully novel); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: "IOBase.__enter__.__qualname__.__eq__"
  args: ["_IOBase.__enter__"]
  expected: true

invariant io_extra128.IOBase.__exit___qualname_eq:
  description: "io.IOBase.__exit__.__qualname__ == '_IOBase.__exit__' (16 chars; __exit__ is the context manager exit method for IOBase; it calls self.close() unconditionally when the 'with' block exits, regardless of whether an exception occurred; this ensures streams are always properly closed; '_IOBase.__exit__' is 16 chars: '_IOBase.'(8)+'__exit__'(8)==16; no prior io_extra spec asserts any attribute of IOBase.__exit__.__qualname__ — neither __eq__ nor __len__ was ever covered; this is fully novel); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: "IOBase.__exit__.__qualname__.__eq__"
  args: ["_IOBase.__exit__"]
  expected: true

invariant io_extra128.IOBase.seek_qualname_eq:
  description: "io.IOBase.seek.__qualname__ == '_IOBase.seek' (12 chars; seek(pos[, whence]) changes the stream position; '_IOBase.seek' at 12 chars is tied with '_IOBase.tell' (covered in io_extra116) as the shortest IOBase method qualname in the standard set; 'seek'(4) is one of the shortest method names; '_IOBase.seek' = '_IOBase.'(8)+'seek'(4)==12; io_extra105 covered IOBase.seek.__class__.__name__=='method_descriptor' but did not assert the qualname string; this is the first io spec to assert IOBase.seek.__qualname__.__eq__('_IOBase.seek')); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: "IOBase.seek.__qualname__.__eq__"
  args: ["_IOBase.seek"]
  expected: true

