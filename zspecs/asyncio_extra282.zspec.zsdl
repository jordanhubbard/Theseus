spec: asyncio_extra282
version: ">=3.4"
backend: python_module(asyncio.coroutines)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio coroutines documentation"
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/coroutines.py"
    - "asyncio_extra281.zspec.zsdl — covers asyncio.runners module identity; asyncio.run and asyncio.Runner class identity"
  notes:
    - "This spec covers: asyncio.coroutines module identity (__name__, __spec__.name, __name__.__len__(), __package__, __loader__.__class__.__name__); asyncio.coroutines.__all__ metadata (tuple type, len=2); asyncio.coroutines.iscoroutine function identity (__module__, __name__, __qualname__, __qualname__.__len__()); asyncio.coroutines.iscoroutinefunction function identity (__module__, __name__, __qualname__, __qualname__.__len__()). NEW in extra282: asyncio.coroutines.__name__=='asyncio.coroutines' (len=18); asyncio.coroutines.__spec__.name=='asyncio.coroutines'; asyncio.coroutines.__package__=='asyncio'; asyncio.coroutines.__loader__.__class__.__name__=='SourceFileLoader'; asyncio.coroutines.__all__.__class__.__name__=='tuple'; asyncio.coroutines.__all__.__len__()==2; iscoroutine.__module__=='asyncio.coroutines'; iscoroutine.__qualname__=='iscoroutine' (len=11); iscoroutinefunction.__module__=='asyncio.coroutines'; iscoroutinefunction.__qualname__=='iscoroutinefunction' (len=19). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.coroutines.__name__.__len__() == 18 — 'asyncio.coroutines' is 18 characters: 'asyncio'=7+'.coroutines'=11=18. Same length as asyncio.exceptions.__name__.__len__()==18 (extra280). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.coroutines.__all__ is a tuple (not a list) with 2 members: ('iscoroutinefunction', 'iscoroutine'). Compare: concurrent.futures.__all__ is a list (len=14). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "iscoroutinefunction.__qualname__.__len__() == 19 — 'iscoroutinefunction' is the longer of the two exported names (19 chars vs 11 for 'iscoroutine'). Both are module-level functions so __qualname__ == __name__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.coroutines.__loader__.__class__.__name__ == 'SourceFileLoader' — asyncio.coroutines is a plain Python source module, not frozen or a C extension. Same loader class as asyncio.runners (extra281). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.coroutines module identity — extra282
#
# asyncio.coroutines.__name__             == 'asyncio.coroutines'
# asyncio.coroutines.__spec__.name        == 'asyncio.coroutines'
# asyncio.coroutines.__name__.__len__()   == 18
# asyncio.coroutines.__package__          == 'asyncio'
# asyncio.coroutines.__loader__.__class__.__name__ == 'SourceFileLoader'
# asyncio.coroutines.__all__.__class__.__name__    == 'tuple'
# asyncio.coroutines.__all__.__len__()             == 2
# ---------------------------------------------------------------------------

table asyncio_extra282.asyncio_coroutines_module_identity:
  description: "asyncio.coroutines module identity checks in asynciocoro282 namespace — asyncio.coroutines is defined in Lib/asyncio/coroutines.py; its __name__ is 'asyncio.coroutines' (len=18: 'asyncio'=7+'.coroutines'=11); __spec__.name is also 'asyncio.coroutines'; __name__.__len__()==18; __package__ is 'asyncio'; __loader__.__class__.__name__ is 'SourceFileLoader' (plain source module); __all__ is a tuple with 2 members ('iscoroutinefunction', 'iscoroutine'); the module exports exactly these two public inspection functions; compare: asyncio.exceptions.__name__.__len__()==18 (same length); asyncio.runners.__name__.__len__()==15 (shorter); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciocoro282

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,     asyncio.coroutines.__name__.__eq__,                       ["asyncio.coroutines"],  true,  "asyncio.coroutines.__name__ == 'asyncio.coroutines'; verified with Python 3.14.3"]
    - [mod_spec_eq,     asyncio.coroutines.__spec__.name.__eq__,                  ["asyncio.coroutines"],  true,  "asyncio.coroutines.__spec__.name == 'asyncio.coroutines'; verified with Python 3.14.3"]
    - [mod_name_len,    asyncio.coroutines.__name__.__len__,                      [],                      18,    "asyncio.coroutines.__name__.__len__() == 18 ('asyncio.coroutines'=18); verified with Python 3.14.3"]
    - [mod_pkg_eq,      asyncio.coroutines.__package__.__eq__,                    ["asyncio"],             true,  "asyncio.coroutines.__package__ == 'asyncio' (parent package); verified with Python 3.14.3"]
    - [mod_loader_eq,   asyncio.coroutines.__loader__.__class__.__name__.__eq__,  ["SourceFileLoader"],    true,  "asyncio.coroutines.__loader__.__class__.__name__ == 'SourceFileLoader'; verified with Python 3.14.3"]
    - [all_class_eq,    asyncio.coroutines.__all__.__class__.__name__.__eq__,     ["tuple"],               true,  "asyncio.coroutines.__all__.__class__.__name__ == 'tuple' (not a list); verified with Python 3.14.3"]
    - [all_len,         asyncio.coroutines.__all__.__len__,                       [],                      2,     "asyncio.coroutines.__all__.__len__() == 2 — exports iscoroutinefunction and iscoroutine; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.coroutines function identity table — extra282
#
# iscoroutine.__module__             == 'asyncio.coroutines'
# iscoroutine.__name__               == 'iscoroutine'
# iscoroutine.__qualname__           == 'iscoroutine'
# iscoroutine.__qualname__.__len__() == 11
# iscoroutinefunction.__module__             == 'asyncio.coroutines'
# iscoroutinefunction.__name__               == 'iscoroutinefunction'
# iscoroutinefunction.__qualname__           == 'iscoroutinefunction'
# iscoroutinefunction.__qualname__.__len__() == 19
# ---------------------------------------------------------------------------

table asyncio_extra282.asyncio_coroutines_function_identity:
  description: "asyncio.coroutines function identity checks in asynciocoro282a namespace — iscoroutine and iscoroutinefunction are the two public functions exported from asyncio.coroutines; both are module-level functions so __qualname__ == __name__; iscoroutine.__module__.__eq__('asyncio.coroutines')==True; iscoroutine.__name__.__eq__('iscoroutine')==True; iscoroutine.__qualname__.__eq__('iscoroutine')==True (len=11); iscoroutinefunction.__module__.__eq__('asyncio.coroutines')==True; iscoroutinefunction.__name__.__eq__('iscoroutinefunction')==True; iscoroutinefunction.__qualname__.__eq__('iscoroutinefunction')==True (len=19, longest in spec); iscoroutinefunction.__qualname__.__len__()==19 is 8 chars longer than iscoroutine.__qualname__.__len__()==11 (the 'function' suffix adds 8 chars); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciocoro282a

  columns: [id, function, args, expected, description]
  rows:
    - [ic_mod_eq,    asyncio.coroutines.iscoroutine.__module__.__eq__,          ["asyncio.coroutines"],    true,  "iscoroutine.__module__ == 'asyncio.coroutines'; verified with Python 3.14.3"]
    - [ic_name_eq,   asyncio.coroutines.iscoroutine.__name__.__eq__,            ["iscoroutine"],           true,  "iscoroutine.__name__ == 'iscoroutine'; verified with Python 3.14.3"]
    - [ic_qn_eq,     asyncio.coroutines.iscoroutine.__qualname__.__eq__,        ["iscoroutine"],           true,  "iscoroutine.__qualname__ == 'iscoroutine' (module-level, qualname==name); verified with Python 3.14.3"]
    - [ic_qn_len,    asyncio.coroutines.iscoroutine.__qualname__.__len__,       [],                        11,    "iscoroutine.__qualname__.__len__() == 11 ('iscoroutine'=11); verified with Python 3.14.3"]
    - [icf_mod_eq,   asyncio.coroutines.iscoroutinefunction.__module__.__eq__,  ["asyncio.coroutines"],    true,  "iscoroutinefunction.__module__ == 'asyncio.coroutines'; verified with Python 3.14.3"]
    - [icf_name_eq,  asyncio.coroutines.iscoroutinefunction.__name__.__eq__,    ["iscoroutinefunction"],   true,  "iscoroutinefunction.__name__ == 'iscoroutinefunction'; verified with Python 3.14.3"]
    - [icf_qn_eq,    asyncio.coroutines.iscoroutinefunction.__qualname__.__eq__, ["iscoroutinefunction"],  true,  "iscoroutinefunction.__qualname__ == 'iscoroutinefunction' (module-level, qualname==name); verified with Python 3.14.3"]
    - [icf_qn_len,   asyncio.coroutines.iscoroutinefunction.__qualname__.__len__, [],                      19,    "iscoroutinefunction.__qualname__.__len__() == 19 ('iscoroutinefunction'=19, longest in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra282
# ---------------------------------------------------------------------------

invariant asyncio_extra282.coroutines_module_name_eq:
  description: "asyncio.coroutines.__name__.__eq__('asyncio.coroutines') returns True — asyncio.coroutines is defined in Lib/asyncio/coroutines.py; its __name__ is 'asyncio.coroutines' (len=18: 'asyncio'=7+'.coroutines'=11=18); asyncio.coroutines.__spec__.name is also 'asyncio.coroutines'; compare asyncio submodule name lengths: asyncio.runners=15, asyncio.coroutines=18, asyncio.exceptions=18 (same length), asyncio.taskgroups=18 (also 18); asyncio.coroutines.__package__ is 'asyncio'; asyncio.coroutines exports only two symbols: iscoroutinefunction and iscoroutine; NEW in extra282: first standalone asyncio.coroutines module name invariant in asynciocoro282 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.coroutines.__name__.__eq__
  args: ["asyncio.coroutines"]
  expected: true

invariant asyncio_extra282.iscoroutine_module_is_asyncio_coroutines:
  description: "asyncio.coroutines.iscoroutine.__module__.__eq__('asyncio.coroutines') returns True — iscoroutine is defined in Lib/asyncio/coroutines.py; its __module__ is 'asyncio.coroutines' (len=18); iscoroutine.__qualname__ is 'iscoroutine' (len=11, shorter than iscoroutinefunction's len=19 by 8 chars); iscoroutine is a module-level function so __qualname__==__name__=='iscoroutine'; asyncio.iscoroutine is the same object as asyncio.coroutines.iscoroutine (re-exported into the asyncio namespace); the function tests whether an object is a coroutine; NEW in extra282: first standalone iscoroutine.__module__ invariant in asynciocoro282a namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.coroutines.iscoroutine.__module__.__eq__
  args: ["asyncio.coroutines"]
  expected: true

invariant asyncio_extra282.iscoroutinefunction_module_is_asyncio_coroutines:
  description: "asyncio.coroutines.iscoroutinefunction.__module__.__eq__('asyncio.coroutines') returns True — iscoroutinefunction is defined in Lib/asyncio/coroutines.py; its __module__ is 'asyncio.coroutines' (len=18); iscoroutinefunction.__qualname__ is 'iscoroutinefunction' (len=19, the longest name in this spec, 8 chars longer than iscoroutine's 11); iscoroutinefunction is a module-level function so __qualname__==__name__=='iscoroutinefunction'; asyncio.iscoroutinefunction is the same object as asyncio.coroutines.iscoroutinefunction; NEW in extra282: first standalone iscoroutinefunction.__module__ invariant in asynciocoro282a namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.coroutines.iscoroutinefunction.__module__.__eq__
  args: ["asyncio.coroutines"]
  expected: true

invariant asyncio_extra282.coroutines_all_is_tuple_len2:
  description: "asyncio.coroutines.__all__.__len__() == 2 — asyncio.coroutines exports exactly two public names: iscoroutinefunction and iscoroutine; __all__.__class__.__name__ is 'tuple' (not a list, unlike concurrent.futures.__all__ which is a list); __all__.__len__() is 2; this is the smallest __all__ of any asyncio submodule in the async282 series (asyncio.runners has two as well: run and Runner); NEW in extra282: first standalone asyncio.coroutines __all__ length invariant in asynciocoro282 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.coroutines.__all__.__len__
  args: []
  expected: 2

invariant asyncio_extra282.coroutines_module_name_len_is_18:
  description: "asyncio.coroutines.__name__.__len__() == 18 — asyncio.coroutines.__name__ is 'asyncio.coroutines' (18 characters: 'asyncio'=7+'.coroutines'=11=18); asyncio.coroutines.__spec__.name.__len__() is also 18; compare asyncio submodule name lengths that equal 18: asyncio.coroutines=18, asyncio.exceptions=18, asyncio.taskgroups=18; asyncio.runners=15 (shorter); asyncio.coroutines.__package__ is 'asyncio' (len=7); NEW in extra282: first standalone asyncio.coroutines name length invariant in asynciocoro282 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.coroutines.__name__.__len__
  args: []
  expected: 18

invariant asyncio_extra282.iscoroutine_qualname_len_is_11:
  description: "asyncio.coroutines.iscoroutine.__qualname__.__len__() == 11 — iscoroutine.__qualname__ is 'iscoroutine' (11 characters); iscoroutine is a module-level function so __qualname__==__name__=='iscoroutine'; compare qualname lengths: iscoroutine=11, iscoroutinefunction=19 (8 chars longer because of the 'function' suffix); iscoroutine.__module__ is 'asyncio.coroutines'; asyncio.coroutines.__all__ contains both 'iscoroutine' (len=11) and 'iscoroutinefunction' (len=19); NEW in extra282: first standalone iscoroutine qualname length invariant in asynciocoro282a namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.coroutines.iscoroutine.__qualname__.__len__
  args: []
  expected: 11
