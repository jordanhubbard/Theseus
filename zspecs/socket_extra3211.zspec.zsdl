spec: sk3211
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 661 (sk3211): __and__, __or__, __xor__ dict-presence checks for socket types."
    - "Theme: __and__, __or__, __xor__ dict-presence (bitwise logical operators)."
    - "socket.socket is a Python class; it does not define __and__, __or__, or __xor__ in its __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses (EnumType metaclass)."
    - "AddressFamily and SocketKind are IntEnum but do NOT define __and__, __or__, or __xor__ in their own __dict__; these methods are inherited from int and not overridden at the subclass level."
    - "operator.contains(socket.AddressFamily.__dict__, '__and__') is False — inherited from int, not present in AddressFamily's own __dict__."
    - "operator.contains(socket.SocketKind.__dict__, '__and__') is False — same reasoning as AddressFamily."
    - "All values are False for all 3 socket types across all 3 operators."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

