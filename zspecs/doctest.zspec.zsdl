spec: doctest
version: ">=3.0"
backend: python_module(doctest)

docs: https://docs.python.org/3/library/doctest.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/doctest.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "doctest source: Lib/doctest.py (PSF; source inspection permitted)"
  not_derived_from:
    - "doctest source: internal _doctest_output_checker implementation details"
  notes:
    - "doctest.testmod() finds and runs doctests embedded in a module's docstrings."
    - "doctest.testfile() runs doctests from a standalone text file."
    - "doctest.run_docstring_examples() runs examples found in a single object's docstring."
    - "doctest.register_optionflag() registers a new option flag name and returns its integer bitmask value."
    - "Option flags (ELLIPSIS, NORMALIZE_WHITESPACE, IGNORE_EXCEPTION_DETAIL, SKIP, FAIL_FAST) are integer bitmasks."
    - "DocTest holds a collection of Examples extracted from a docstring; __module__ is 'doctest'."
    - "DocTestFinder locates doctests in module/class/function docstrings."
    - "DocTestRunner executes DocTest objects and records results."
    - "DocTestParser parses docstrings to extract Example objects."
    - "OutputChecker compares actual and expected output, with support for option flags."
    - "Example represents a single interactive example (source + expected output)."
    - "DocTestFailure and UnexpectedException are exception classes raised by DocTestRunner."
    - "DebugRunner is a DocTestRunner subclass that raises exceptions instead of printing failures."
    - "TestResults is a named tuple (or class) holding (failed, attempted) counts."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant doctest.names.testmod:
  description: "doctest.testmod.__name__ == 'testmod'"
  category: names
  kind: python_call_eq
  function: testmod.__name__.__eq__
  args: ["testmod"]
  expected: true

invariant doctest.names.testfile:
  description: "doctest.testfile.__name__ == 'testfile'"
  category: names
  kind: python_call_eq
  function: testfile.__name__.__eq__
  args: ["testfile"]
  expected: true

invariant doctest.names.run_docstring_examples:
  description: "doctest.run_docstring_examples.__name__ == 'run_docstring_examples'"
  category: names
  kind: python_call_eq
  function: run_docstring_examples.__name__.__eq__
  args: ["run_docstring_examples"]
  expected: true

invariant doctest.names.register_optionflag:
  description: "doctest.register_optionflag.__name__ == 'register_optionflag'"
  category: names
  kind: python_call_eq
  function: register_optionflag.__name__.__eq__
  args: ["register_optionflag"]
  expected: true

