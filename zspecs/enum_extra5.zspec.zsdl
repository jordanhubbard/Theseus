spec: enum_extra5
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "Extends enum.zspec.zsdl, enum_extra.zspec.zsdl, enum_extra2.zspec.zsdl, enum_extra3.zspec.zsdl, enum_extra4.zspec.zsdl."
    - "Previous specs cover: Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique class and function names, Enum member .name and .value, Enum.__members__ dict, list(Enum) iteration, IntEnum arithmetic, Flag bitwise ops, unique decorator behavior, auto() return class, enum.CONFORM/EJECT/KEEP/STRICT boundary constants."
    - "enum_extra4.zspec.zsdl covers: EnumType/__qualname__, EnumMeta qualname/module/name_3_9, StrEnum qualname/module/metaclass, IntFlag qualname/module, Flag qualname/module, global_enum module/is_function."
    - "enum.Enum.__mro__ is a tuple with length >= 2 — every class has at least itself and object in its MRO."
    - "enum.IntEnum.__mro__ contains the int class — confirmed via __contains__ on the tuple."
    - "enum.Flag.__mro__ contains Enum — Flag inherits from Enum so Enum appears in its MRO."
    - "enum.StrEnum.__mro__ contains str — StrEnum is a mix-in of str and Enum (Python 3.11+)."
    - "enum.IntFlag.__mro__ contains int — IntFlag inherits from int and Flag."
    - "enum.auto.__name__ == 'auto' — the auto helper class name."
    - "enum.unique.__name__ == 'unique' — the unique decorator function name."
    - "enum.nonmember.__name__ == 'nonmember' — added in Python 3.11 to exclude values from enum membership."
    - "The MRO tuple class name is 'tuple' for all enum classes."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# enum.Enum.__mro__ — length and type
#
# Every class has a __mro__ tuple. Enum's MRO includes at minimum Enum
# and object, so length >= 2.
# ---------------------------------------------------------------------------

invariant enum_extra5.Enum.mro_is_tuple:
  description: "enum.Enum.__mro__.__class__.__name__ == 'tuple' — __mro__ is always a tuple"
  category: mro
  kind: python_call_eq
  function: Enum.__mro__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant enum_extra5.Enum.mro_len_ge_2:
  description: "len(enum.Enum.__mro__) >= 2 — MRO includes at minimum Enum and object"
  category: mro
  kind: python_call_eq
  function: Enum.__mro__.__len__
  args: []
  method: __ge__
  method_args: [2]
  expected: true

# ---------------------------------------------------------------------------
# enum.IntEnum.__mro__ — second entry is int
#
# IntEnum is defined as class IntEnum(int, Enum), so int appears at index 1
# in its MRO (immediately after IntEnum itself).
# ---------------------------------------------------------------------------

invariant enum_extra5.IntEnum.mro_second_is_int:
  description: "enum.IntEnum.__mro__[1].__name__ == 'int' — int is the second MRO entry for IntEnum"
  category: mro
  kind: python_call_eq
  function: IntEnum.__mro__.__getitem__
  args: [1]
  method: __name__.__eq__
  method_args: ["int"]
  expected: true

invariant enum_extra5.IntEnum.mro_first_name:
  description: "enum.IntEnum.__mro__[0].__name__ == 'IntEnum' — first MRO entry is IntEnum itself"
  category: mro
  kind: python_call_eq
  function: IntEnum.__mro__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["IntEnum"]
  expected: true

invariant enum_extra5.IntEnum.mro_len_ge_3:
  description: "len(enum.IntEnum.__mro__) >= 3 — MRO includes IntEnum, int, Enum, object at minimum"
  category: mro
  kind: python_call_eq
  function: IntEnum.__mro__.__len__
  args: []
  method: __ge__
  method_args: [3]
  expected: true

# ---------------------------------------------------------------------------
# enum.Flag.__mro__ — contains Enum and Flag
#
# Flag inherits from Enum, so Enum appears in Flag's MRO.
# ---------------------------------------------------------------------------

invariant enum_extra5.Flag.mro_first_name:
  description: "enum.Flag.__mro__[0].__name__ == 'Flag' — first MRO entry is Flag itself"
  category: mro
  kind: python_call_eq
  function: Flag.__mro__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Flag"]
  expected: true

invariant enum_extra5.Flag.mro_len_ge_3:
  description: "len(enum.Flag.__mro__) >= 3 — Flag MRO includes Flag, Enum, object at minimum"
  category: mro
  kind: python_call_eq
  function: Flag.__mro__.__len__
  args: []
  method: __ge__
  method_args: [3]
  expected: true

# ---------------------------------------------------------------------------
# enum.IntFlag.__mro__ — length and first entry
#
# IntFlag inherits from int and Flag, so its MRO is longer than Flag's.
# ---------------------------------------------------------------------------

invariant enum_extra5.IntFlag.mro_first_name:
  description: "enum.IntFlag.__mro__[0].__name__ == 'IntFlag' — first MRO entry is IntFlag itself"
  category: mro
  kind: python_call_eq
  function: IntFlag.__mro__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["IntFlag"]
  expected: true

invariant enum_extra5.IntFlag.mro_len_ge_4:
  description: "len(enum.IntFlag.__mro__) >= 4 — IntFlag MRO includes IntFlag, int, Flag, Enum, object"
  category: mro
  kind: python_call_eq
  function: IntFlag.__mro__.__len__
  args: []
  method: __ge__
  method_args: [4]
  expected: true

# ---------------------------------------------------------------------------
# enum.StrEnum.__mro__ — first entry and length (Python 3.11+)
#
# StrEnum is defined as class StrEnum(str, Enum), so str appears in its MRO.
# ---------------------------------------------------------------------------

invariant enum_extra5.StrEnum.mro_first_name:
  description: "enum.StrEnum.__mro__[0].__name__ == 'StrEnum' — first MRO entry is StrEnum itself (Python 3.11+)"
  category: mro
  version: ">=3.11"
  kind: python_call_eq
  function: StrEnum.__mro__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["StrEnum"]
  expected: true

invariant enum_extra5.StrEnum.mro_len_ge_3:
  description: "len(enum.StrEnum.__mro__) >= 3 — StrEnum MRO includes StrEnum, str, Enum, object at minimum (Python 3.11+)"
  category: mro
  version: ">=3.11"
  kind: python_call_eq
  function: StrEnum.__mro__.__len__
  args: []
  method: __ge__
  method_args: [3]
  expected: true

# ---------------------------------------------------------------------------
# enum.auto — __name__ check
#
# enum_extra.zspec.zsdl or prior specs may cover auto.__name__; this
# provides orthogonal coverage via the mro/identity category.
# ---------------------------------------------------------------------------

invariant enum_extra5.auto.name:
  description: "enum.auto.__name__ == 'auto'"
  category: identity
  kind: python_call_eq
  function: auto.__name__.__eq__
  args: ["auto"]
  expected: true

# ---------------------------------------------------------------------------
# enum.unique — __name__ check
#
# The @unique decorator is a plain Python function. Its __name__ is 'unique'.
# ---------------------------------------------------------------------------

invariant enum_extra5.unique.name:
  description: "enum.unique.__name__ == 'unique'"
  category: identity
  kind: python_call_eq
  function: unique.__name__.__eq__
  args: ["unique"]
  expected: true

# ---------------------------------------------------------------------------
# enum.nonmember — __name__ check (Python 3.11+)
#
# enum.nonmember was added in Python 3.11 to mark values that should not
# become enum members. Its __name__ is 'nonmember'.
# ---------------------------------------------------------------------------

invariant enum_extra5.nonmember.name:
  description: "enum.nonmember.__name__ == 'nonmember' (Python 3.11+)"
  category: identity
  version: ">=3.11"
  kind: python_call_eq
  function: nonmember.__name__.__eq__
  args: ["nonmember"]
  expected: true
