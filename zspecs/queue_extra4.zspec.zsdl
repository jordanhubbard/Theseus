spec: queue_extra4
version: ">=3.9"
backend: python_module(queue)

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/queue.html — Python queue module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/queue.py"
  notes:
    - "This spec extends queue.zspec.zsdl, queue_extra.zspec.zsdl, queue_extra2.zspec.zsdl, queue_extra3.zspec.zsdl."
    - "queue_extra3 covers: __name__ for Queue/LifoQueue/PriorityQueue/SimpleQueue/Empty/Full; __module__ for all six; __bases__[0].__name__ for Empty and Full; Queue instance behavior (qsize, maxsize, class name)."
    - "This spec adds __qualname__ vectors for all major queue classes — not previously covered in any prior queue spec."
    - "For top-level (non-nested) classes, __qualname__ == __name__."
    - "queue.Queue.__qualname__ == 'Queue' — FIFO queue class."
    - "queue.LifoQueue.__qualname__ == 'LifoQueue' — LIFO (stack) queue class."
    - "queue.PriorityQueue.__qualname__ == 'PriorityQueue' — priority queue class."
    - "queue.SimpleQueue.__qualname__ == 'SimpleQueue' — unbounded simple FIFO queue."
    - "queue.Empty.__qualname__ == 'Empty' — exception raised on get from empty queue."
    - "queue.Full.__qualname__ == 'Full' — exception raised on put to full queue."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ table for all major queue module classes
#
# For top-level (non-nested) classes, __qualname__ == __name__.
# Prior specs verified __name__ and __module__; this spec introduces __qualname__.
# ---------------------------------------------------------------------------

table queue_extra4.class_qualnames:
  description: "All major queue module classes have correct __qualname__"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Queue,         Queue.__qualname__.__eq__,         ["Queue"],         true]
    - [LifoQueue,     LifoQueue.__qualname__.__eq__,     ["LifoQueue"],     true]
    - [PriorityQueue, PriorityQueue.__qualname__.__eq__, ["PriorityQueue"], true]
    - [SimpleQueue,   SimpleQueue.__qualname__.__eq__,   ["SimpleQueue"],   true]
    - [Empty,         Empty.__qualname__.__eq__,         ["Empty"],         true]
    - [Full,          Full.__qualname__.__eq__,          ["Full"],          true]
