spec: fcntl
version: ">=3.0"
backend: python_module(fcntl)

docs: https://docs.python.org/3/library/fcntl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fcntl.html — Python fcntl module documentation"
    - "POSIX.1-2017 — fcntl(2) and flock(2) system call specifications"
    - "4.4BSD — flock(2) lock constants (LOCK_SH=1, LOCK_EX=2, LOCK_NB=4, LOCK_UN=8)"
    - "Test vectors verified by running Python 3.14.3 fcntl module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/fcntlmodule.c"
  notes:
    - "fcntl is POSIX-only; it is not available on Windows. All invariants in this spec apply only to POSIX platforms (macOS, Linux, FreeBSD, etc.)."
    - "fcntl.fcntl() and fcntl.ioctl() call the corresponding POSIX system calls; their exact behavior depends on the file descriptor and command."
    - "fcntl.flock() applies or removes an advisory lock on an open file descriptor."
    - "fcntl.lockf() applies POSIX record locking via fcntl(2) F_SETLK/F_SETLKW/F_GETLK."
    - "LOCK_SH=1, LOCK_EX=2, LOCK_NB=4, LOCK_UN=8 — these values are standardized across BSD and Linux."
    - "F_GETFL, F_SETFL, F_GETFD, F_SETFD are portable POSIX constants; their exact integer values are platform-specific."
    - "FD_CLOEXEC is the close-on-exec flag bit used with F_GETFD/F_SETFD."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# function names
# ---------------------------------------------------------------------------

invariant fcntl.function.fcntl_name:
  description: "fcntl.fcntl.__name__ == 'fcntl'"
  category: function_names
  kind: python_call_eq
  function: fcntl.__name__.__eq__
  args: ["fcntl"]
  expected: true

invariant fcntl.function.ioctl_name:
  description: "fcntl.ioctl.__name__ == 'ioctl'"
  category: function_names
  kind: python_call_eq
  function: ioctl.__name__.__eq__
  args: ["ioctl"]
  expected: true

invariant fcntl.function.flock_name:
  description: "fcntl.flock.__name__ == 'flock'"
  category: function_names
  kind: python_call_eq
  function: flock.__name__.__eq__
  args: ["flock"]
  expected: true

invariant fcntl.function.lockf_name:
  description: "fcntl.lockf.__name__ == 'lockf'"
  category: function_names
  kind: python_call_eq
  function: lockf.__name__.__eq__
  args: ["lockf"]
  expected: true

# ---------------------------------------------------------------------------
# flock / lockf constants — portable POSIX values
# ---------------------------------------------------------------------------

invariant fcntl.constants.lock_sh:
  description: "fcntl.LOCK_SH == 1 — shared lock flag (BSD/POSIX)"
  category: constants
  kind: python_call_eq
  function: LOCK_SH.__eq__
  args: [1]
  expected: true

invariant fcntl.constants.lock_ex:
  description: "fcntl.LOCK_EX == 2 — exclusive lock flag (BSD/POSIX)"
  category: constants
  kind: python_call_eq
  function: LOCK_EX.__eq__
  args: [2]
  expected: true

invariant fcntl.constants.lock_nb:
  description: "fcntl.LOCK_NB == 4 — non-blocking modifier (BSD/POSIX)"
  category: constants
  kind: python_call_eq
  function: LOCK_NB.__eq__
  args: [4]
  expected: true

invariant fcntl.constants.lock_un:
  description: "fcntl.LOCK_UN == 8 — unlock flag (BSD/POSIX)"
  category: constants
  kind: python_call_eq
  function: LOCK_UN.__eq__
  args: [8]
  expected: true

# ---------------------------------------------------------------------------
# fcntl(2) file-descriptor control constants — type checks
# (exact integer values are platform-specific and not pinned)
# ---------------------------------------------------------------------------

invariant fcntl.constants.f_getfl_is_int:
  description: "fcntl.F_GETFL is an int — get file status flags"
  category: constants
  kind: python_call_eq
  function: F_GETFL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant fcntl.constants.f_setfl_is_int:
  description: "fcntl.F_SETFL is an int — set file status flags"
  category: constants
  kind: python_call_eq
  function: F_SETFL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant fcntl.constants.f_getfd_is_int:
  description: "fcntl.F_GETFD is an int — get file descriptor flags"
  category: constants
  kind: python_call_eq
  function: F_GETFD.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant fcntl.constants.f_setfd_is_int:
  description: "fcntl.F_SETFD is an int — set file descriptor flags"
  category: constants
  kind: python_call_eq
  function: F_SETFD.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant fcntl.constants.fd_cloexec_is_int:
  description: "fcntl.FD_CLOEXEC is an int — close-on-exec flag bit"
  category: constants
  kind: python_call_eq
  function: FD_CLOEXEC.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# LOCK_SH | LOCK_NB == 5 — bitwise combination works as expected
# ---------------------------------------------------------------------------

invariant fcntl.constants.lock_sh_nb_combined:
  description: "fcntl.LOCK_SH | fcntl.LOCK_NB == 5 — non-blocking shared lock is 1|4"
  category: constants
  kind: python_call_eq
  function: LOCK_SH.__or__
  args: [4]
  expected: 5
