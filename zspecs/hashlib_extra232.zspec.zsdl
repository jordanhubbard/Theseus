spec: hashlib_extra232
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.new.__name__ == '__hash_new' — the public API name is 'new' but the underlying function is '__hash_new'; __name__ reflects the actual function object."
    - "hashlib.new.__module__ == 'hashlib' — defined in the hashlib module."
    - "hashlib.new.__qualname__ == '__hash_new' — same as __name__ for this top-level function."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — it is a plain set, not frozenset, on Python 3.14.3."
    - "hashlib.algorithms_available.__class__.__name__ == 'set' — both algorithm sets are plain set objects."
    - "hashlib.new('sha256', b'hello').digest_size == 32 — sha256 produces a 256-bit/32-byte digest."
    - "hashlib.new('md5', b'hello').digest_size == 16 — md5 produces a 128-bit/16-byte digest."
    - "hmac.new.__name__ == 'new' — the HMAC constructor function name."
    - "hmac.HMAC.__name__ == 'HMAC' — the HMAC class name is 4 characters."
    - "hmac.digest.__name__ == 'digest' — one-shot HMAC digest function added in Python 3.7."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new function identity contracts
#
# hashlib.new.__name__    == '__hash_new'
# hashlib.new.__module__  == 'hashlib'
# hashlib.new.__qualname__ == '__hash_new'
#
# hashlib.new is the generic hash constructor. The underlying function object
# is named '__hash_new' (the public alias 'new' wraps it). __module__ is
# 'hashlib' because it is defined in hashlib.py.
# ---------------------------------------------------------------------------

table hashlib_extra232.hashlib_new_function_identity:
  description: "hashlib.new.__name__=='__hash_new'; new.__module__=='hashlib'; new.__qualname__=='__hash_new'; function identity contracts; new to extra232"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib232

  columns: [id, function, args, expected, description]
  rows:
    - [new_name_eq_hash_new,
       "new.__name__.__eq__",
       ["__hash_new"],
       true,
       "hashlib.new.__name__.__eq__('__hash_new') == True — the underlying function object for hashlib.new is named '__hash_new'; the public name 'new' is an alias; __name__ reflects the function object's actual name; new anchor in extra232 namespace; verified Python 3.14.3"]
    - [new_module_eq_hashlib,
       "new.__module__.__eq__",
       ["hashlib"],
       true,
       "hashlib.new.__module__.__eq__('hashlib') == True — hashlib.new is defined in the hashlib module (not _hashlib C extension); __module__ is 'hashlib'; new anchor in extra232 namespace; verified Python 3.14.3"]
    - [new_qualname_eq_hash_new,
       "new.__qualname__.__eq__",
       ["__hash_new"],
       true,
       "hashlib.new.__qualname__.__eq__('__hash_new') == True — __qualname__ equals __name__ for this top-level function; no outer class scope; new anchor in extra232 namespace; verified Python 3.14.3"]
    - [new_name_len_10,
       "new.__name__.__len__",
       [],
       10,
       "hashlib.new.__name__.__len__() == 10 — the string '__hash_new' has 10 characters including the two leading underscores; portable length anchor; new anchor in extra232 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed and algorithms_available class name contracts
#
# hashlib.algorithms_guaranteed.__class__.__name__ == 'set'
# hashlib.algorithms_available.__class__.__name__  == 'set'
# len(hashlib.algorithms_guaranteed) > 0
# 'sha256' in hashlib.algorithms_guaranteed
# 'md5' in hashlib.algorithms_guaranteed
#
# Both algorithm sets are plain set objects. algorithms_guaranteed lists
# algorithms present on all Python platforms; algorithms_available lists
# all OpenSSL-available algorithms on the current platform.
# ---------------------------------------------------------------------------

table hashlib_extra232.algorithms_set_class_names:
  description: "algorithms_guaranteed.__class__.__name__=='set'; algorithms_available.__class__.__name__=='set'; both are plain set objects; new to extra232"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib232a

  columns: [id, function, args, expected, description]
  rows:
    - [guaranteed_class_is_set,
       "algorithms_guaranteed.__class__.__name__.__eq__",
       ["set"],
       true,
       "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True — algorithms_guaranteed is a plain Python set (not frozenset); contains algorithm names guaranteed on all platforms; new anchor in extra232 namespace; verified Python 3.14.3"]
    - [available_class_is_set,
       "algorithms_available.__class__.__name__.__eq__",
       ["set"],
       true,
       "hashlib.algorithms_available.__class__.__name__.__eq__('set') == True — algorithms_available is a plain Python set; lists all OpenSSL-backed algorithms on the current platform; superset of algorithms_guaranteed; new anchor in extra232 namespace; verified Python 3.14.3"]
    - [guaranteed_contains_sha256,
       "algorithms_guaranteed.__contains__",
       ["sha256"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha256') == True — sha256 is guaranteed on all Python platforms; fundamental hash algorithm; new anchor in extra232 namespace; verified Python 3.14.3"]
    - [guaranteed_contains_md5,
       "algorithms_guaranteed.__contains__",
       ["md5"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('md5') == True — md5 is guaranteed on all Python platforms; widely used legacy hash; new anchor in extra232 namespace; verified Python 3.14.3"]
    - [guaranteed_contains_sha1,
       "algorithms_guaranteed.__contains__",
       ["sha1"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha1') == True — sha1 is guaranteed on all Python platforms; 160-bit hash; new anchor in extra232 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.new() return digest_size contracts
#
# hashlib.new('sha256', b'hello').digest_size == 32
# hashlib.new('md5', b'hello').digest_size    == 16
#
# hashlib.new() is the generic constructor. The returned hash object has a
# digest_size attribute giving the output length in bytes. sha256 yields 32
# bytes (256 bits); md5 yields 16 bytes (128 bits).
# ---------------------------------------------------------------------------

table hashlib_extra232.new_digest_size_contracts:
  description: "new('sha256').digest_size==32; new('md5').digest_size==16; generic constructor digest sizes; new to extra232"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib232b

  columns: [id, function, args, expected, description]
  rows:
    - [new_sha256_digest_size_32,
       "new('sha256', b'hello').digest_size.__eq__",
       [32],
       true,
       "hashlib.new('sha256', b'hello').digest_size.__eq__(32) == True — sha256 produces a 256-bit/32-byte digest; new() is the generic constructor equivalent to hashlib.sha256(); new anchor in extra232 namespace; verified Python 3.14.3"]
    - [new_md5_digest_size_16,
       "new('md5', b'hello').digest_size.__eq__",
       [16],
       true,
       "hashlib.new('md5', b'hello').digest_size.__eq__(16) == True — md5 produces a 128-bit/16-byte digest; new() generic constructor; new anchor in extra232 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# hmac module identity contracts
#
# hmac.new.__name__    == 'new'
# hmac.new.__module__  == 'hmac'
# hmac.HMAC.__name__   == 'HMAC'
# hmac.HMAC.__module__ == 'hmac'
# hmac.digest.__name__ == 'digest'
# hmac.digest.__module__ == 'hmac'
#
# The hmac module provides HMAC (Hash-based Message Authentication Code)
# functionality. hmac.new() creates HMAC objects. hmac.digest() is a
# one-shot function (Python 3.7+). hmac.HMAC is the HMAC class.
# ---------------------------------------------------------------------------

table hashlib_extra232.hmac_module_identity:
  description: "hmac.new.__name__=='new'; hmac.HMAC.__name__=='HMAC'; hmac.digest.__name__=='digest'; HMAC module function identity; new to extra232"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib232c

  columns: [id, function, args, expected, description]
  rows:
    - [hmac_new_name_eq_new,
       "hmac.new.__name__.__eq__",
       ["new"],
       true,
       "hmac.new.__name__.__eq__('new') == True — hmac.new is the HMAC constructor function; its __name__ is 'new' (3 characters); new anchor in extra232 namespace; verified Python 3.14.3"]
    - [hmac_new_module_eq_hmac,
       "hmac.new.__module__.__eq__",
       ["hmac"],
       true,
       "hmac.new.__module__.__eq__('hmac') == True — hmac.new is defined in the hmac module (not C extension); __module__ is 'hmac'; new anchor in extra232 namespace; verified Python 3.14.3"]
    - [hmac_HMAC_name_eq_HMAC,
       "hmac.HMAC.__name__.__eq__",
       ["HMAC"],
       true,
       "hmac.HMAC.__name__.__eq__('HMAC') == True — the HMAC class name is the 4-character string 'HMAC'; all-caps acronym for Hash-based Message Authentication Code; new anchor in extra232 namespace; verified Python 3.14.3"]
    - [hmac_HMAC_module_eq_hmac,
       "hmac.HMAC.__module__.__eq__",
       ["hmac"],
       true,
       "hmac.HMAC.__module__.__eq__('hmac') == True — HMAC class is defined in the hmac module; __module__ is 'hmac'; new anchor in extra232 namespace; verified Python 3.14.3"]
    - [hmac_digest_name_eq_digest,
       "hmac.digest.__name__.__eq__",
       ["digest"],
       true,
       "hmac.digest.__name__.__eq__('digest') == True — hmac.digest is the one-shot HMAC digest function added in Python 3.7; __name__ is 'digest' (6 characters); new anchor in extra232 namespace; verified Python 3.14.3"]
    - [hmac_digest_module_eq_hmac,
       "hmac.digest.__module__.__eq__",
       ["hmac"],
       true,
       "hmac.digest.__module__.__eq__('hmac') == True — hmac.digest one-shot function is defined in the hmac module; __module__ is 'hmac'; new anchor in extra232 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra232.new_name_eq_hash_new:
  description: "hashlib.new.__name__.__eq__('__hash_new') == True — hashlib.new is the public entry point for the generic hash constructor; the underlying function object is named '__hash_new' with two leading underscores; __name__ returns the actual function name not the alias; 'hashlib.new' is how users call it but the function object's identity is '__hash_new'; length 10 characters; no prior hashlib spec anchors new.__name__ as standalone in extra232 namespace; first extra232 anchor; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "new.__name__.__eq__"
  args: ["__hash_new"]
  expected: true

invariant hashlib_extra232.guaranteed_class_is_set:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True — algorithms_guaranteed is a plain Python set object (not frozenset); it contains the names of hash algorithms guaranteed to be available on all Python platforms; the set class name is 'set' (3 characters); prior specs anchor membership in algorithms_guaranteed but extra232 is the first to anchor the class name identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "algorithms_guaranteed.__class__.__name__.__eq__"
  args: ["set"]
  expected: true

invariant hashlib_extra232.hmac_new_name_eq_new:
  description: "hmac.new.__name__.__eq__('new') == True — hmac.new is the HMAC constructor; it creates and returns an HMAC object given a key and optional message; __name__ is 'new' (3 characters); hmac module is separate from hashlib but related; no prior spec anchors hmac.new.__name__ as standalone in extra232 namespace; first extra232 anchor for HMAC identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "hmac.new.__name__.__eq__"
  args: ["new"]
  expected: true
