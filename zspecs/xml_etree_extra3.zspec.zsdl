spec: xml_etree_extra3
version: ">=3.9"
backend: python_module(xml.etree.ElementTree)

docs: https://docs.python.org/3/library/xml.etree.elementtree.html

provenance:
  derived_from:
    - "Python 3 xml.etree.ElementTree documentation — https://docs.python.org/3/library/xml.etree.elementtree.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xml/etree/ElementTree.py"
    - "elementtree.zspec.zsdl — covers fromstring tag/text/attrib/get/findtext, Element constructor, tostring, SubElement, ParseError raise behavior"
    - "xml_extra.zspec.zsdl — covers class/function __name__ table (Element, ElementTree, SubElement, ParseError, parse, fromstring, tostring)"
    - "xml_extra2.zspec.zsdl — covers fromstring tag/attrib behavior, Element tag/attrib, tostring result class, ParseError class_name, VERSION/XML_VERSION constants"
    - "xml_extra3.zspec.zsdl — covers Element/ElementTree/XMLParser/ParseError __qualname__; tostring/indent/iterparse/parse __qualname__; Element/XMLParser base == 'object'; function type checks (indent/iterparse/parse/tostring __class__.__name__ == 'function'); ParseError/Element is_type; Element.__module__ exact value; XMLParser.__module__."
    - "xml_parse.zspec.zsdl — covers ElementTree/XMLParser/ParseError __module__, ParseError base, ElementTree.__bases__[0], XMLParser feed/close/version."
    - "xml_etree_extra.zspec.zsdl — covers Element/__name__, SubElement/__name__, parse/fromstring/tostring/indent/iterparse/register_namespace __name__, Comment/ProcessingInstruction __name__, ParseError name/base, fromstring result class, Element.__module__ class name check."
    - "xml_etree_extra2.zspec.zsdl — covers SubElement/__qualname__, fromstring/__qualname__, SubElement/fromstring/tostring/parse/indent/iterparse __module__, ParseError.__module__, SubElement callable check."
  notes:
    - "This spec extends all prior xml.etree.ElementTree specs."
    - "Focus: new axes not covered by any prior xml.etree spec."
    - "register_namespace.__qualname__ — xml_etree_extra covers __name__ ('register_namespace'); xml_extra3 function_qualnames table includes tostring/indent/iterparse/parse but NOT register_namespace. qualname is new."
    - "register_namespace.__module__ — xml_etree_extra2 covers SubElement/fromstring/tostring/parse/indent/iterparse __module__ but NOT register_namespace. module is new."
    - "Comment.__qualname__ and Comment.__module__ — xml_etree_extra covers Comment.__name__; qualname and module are new."
    - "ProcessingInstruction.__qualname__ and __module__ — xml_etree_extra covers __name__; qualname and module are new."
    - "fromstring with element text — elementtree.zspec.zsdl/xml_extra2 test fromstring tag; the .text attribute of a parsed element has not been tested in any prior spec."
    - "ElementTree type identity — xml_extra3 checks Element/ParseError is_type; ElementTree.__class__.__name__ is new."
    - "fromstring.__class__.__name__ — xml_extra3 checks indent/iterparse/parse/tostring types; fromstring type is new."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# register_namespace — __qualname__ and __module__
# xml_etree_extra covers __name__ == 'register_namespace'.
# xml_extra3 qualname table has tostring/indent/iterparse/parse but omits
# register_namespace. xml_etree_extra2 module table omits it too.
# ---------------------------------------------------------------------------

invariant xml_etree_extra3.register_namespace.qualname:
  description: "xml.etree.ElementTree.register_namespace.__qualname__ == 'register_namespace'"
  category: qualnames
  kind: python_call_eq
  function: register_namespace.__qualname__.__eq__
  args: ["register_namespace"]
  expected: true

invariant xml_etree_extra3.register_namespace.module:
  description: "xml.etree.ElementTree.register_namespace.__module__ == 'xml.etree.ElementTree'"
  category: modules
  kind: python_call_eq
  function: register_namespace.__module__.__eq__
  args: ["xml.etree.ElementTree"]
  expected: true

# ---------------------------------------------------------------------------
# Comment — __qualname__ and __module__
# xml_etree_extra covers Comment.__name__ == 'Comment'.
# qualname and module are new axes.
# ---------------------------------------------------------------------------

invariant xml_etree_extra3.Comment.qualname:
  description: "xml.etree.ElementTree.Comment.__qualname__ == 'Comment'"
  category: qualnames
  kind: python_call_eq
  function: Comment.__qualname__.__eq__
  args: ["Comment"]
  expected: true

invariant xml_etree_extra3.Comment.module:
  description: "xml.etree.ElementTree.Comment.__module__ == 'xml.etree.ElementTree'"
  category: modules
  kind: python_call_eq
  function: Comment.__module__.__eq__
  args: ["xml.etree.ElementTree"]
  expected: true

# ---------------------------------------------------------------------------
# ProcessingInstruction — __qualname__ and __module__
# xml_etree_extra covers ProcessingInstruction.__name__ == 'ProcessingInstruction'.
# qualname and module are new axes.
# ---------------------------------------------------------------------------

invariant xml_etree_extra3.ProcessingInstruction.qualname:
  description: "xml.etree.ElementTree.ProcessingInstruction.__qualname__ == 'ProcessingInstruction'"
  category: qualnames
  kind: python_call_eq
  function: ProcessingInstruction.__qualname__.__eq__
  args: ["ProcessingInstruction"]
  expected: true

invariant xml_etree_extra3.ProcessingInstruction.module:
  description: "xml.etree.ElementTree.ProcessingInstruction.__module__ == 'xml.etree.ElementTree'"
  category: modules
  kind: python_call_eq
  function: ProcessingInstruction.__module__.__eq__
  args: ["xml.etree.ElementTree"]
  expected: true

# ---------------------------------------------------------------------------
# fromstring — .text attribute of a parsed element
# elementtree.zspec.zsdl tests fromstring tag/text/attrib on a different element.
# xml_extra2 tests fromstring('<root/>').tag == 'root' only (empty element).
# Testing .text on an element with actual text content is a new vector.
# ---------------------------------------------------------------------------

invariant xml_etree_extra3.fromstring.text:
  description: "fromstring('<item>hello</item>').text == 'hello'"
  category: fromstring
  kind: python_call_eq
  function: fromstring
  args: ["<item>hello</item>"]
  method: text.__eq__
  method_args: ["hello"]
  expected: true

invariant xml_etree_extra3.fromstring.tag_with_text:
  description: "fromstring('<item>hello</item>').tag == 'item'"
  category: fromstring
  kind: python_call_eq
  function: fromstring
  args: ["<item>hello</item>"]
  method: tag.__eq__
  method_args: ["item"]
  expected: true

# ---------------------------------------------------------------------------
# Type identity checks — ElementTree and fromstring class type
# xml_extra3 covers Element/ParseError is_type and function types for
# indent/iterparse/parse/tostring. ElementTree is_type and fromstring type are new.
# ---------------------------------------------------------------------------

invariant xml_etree_extra3.ElementTree.is_type:
  description: "xml.etree.ElementTree.ElementTree.__class__.__name__ == 'type'"
  category: class_type
  kind: python_call_eq
  function: ElementTree.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant xml_etree_extra3.fromstring.class_name:
  description: "xml.etree.ElementTree.fromstring.__class__.__name__ == 'function' — fromstring is a Python function"
  category: types
  kind: python_call_eq
  function: fromstring.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# register_namespace type check — is a Python function
# xml_extra3 checks indent/iterparse/parse/tostring type;
# register_namespace type is new.
# ---------------------------------------------------------------------------

invariant xml_etree_extra3.register_namespace.class_name:
  description: "xml.etree.ElementTree.register_namespace.__class__.__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: register_namespace.__class__.__name__.__eq__
  args: ["function"]
  expected: true
