spec: inspect_extra268
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.Parameter.__class__.__name__ == 'type' — Parameter is a regular Python class."
    - "inspect.Parameter.__module__ == 'inspect' (len=7)."
    - "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter inherits directly from object."
    - "inspect.Parameter kind constants: POSITIONAL_ONLY(0), POSITIONAL_OR_KEYWORD(1), VAR_POSITIONAL(2), KEYWORD_ONLY(3), VAR_KEYWORD(4)."
    - "All Parameter kind constants are of type '_ParameterKind' (an enum with integer values 0..4)."
    - "inspect.BoundArguments.__class__.__name__ == 'type' — BoundArguments is a regular Python class."
    - "inspect.BoundArguments.__bases__[0].__name__ == 'object' — BoundArguments also inherits from object."
    - "inspect.BoundArguments.__module__ == 'inspect' (len=7)."
    - "Parameter.__name__ (9) == module name 'inspect' len+2 — actually both are in 'inspect'."
    - "BoundArguments.__name__ (14) > Parameter.__name__ (9)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.Parameter class identity and kind constant values
#
# Parameter is a regular Python class with __module__ == 'inspect'.
# Parameter.__bases__[0].__name__ == 'object'.
# Kind constants are _ParameterKind enum members with int values 0..4.
# ---------------------------------------------------------------------------

table inspect_extra268.parameter_class_and_kinds_identity:
  description: "inspect.Parameter(9) class identity and kind constants — Parameter is type(4) in inspect(7); inherits from object; kind constants are _ParameterKind with int values POSITIONAL_ONLY(0), POSITIONAL_OR_KEYWORD(1), VAR_POSITIONAL(2), KEYWORD_ONLY(3), VAR_KEYWORD(4); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex268p

  columns: [id, function, args, expected, description]
  rows:
    - [p_name_eq,          Parameter.__name__.__eq__,                   ["Parameter"],                  true, "inspect.Parameter.__name__ == 'Parameter'; verified with Python 3.14.3"]
    - [p_name_len,         Parameter.__name__.__len__,                  [],                             9,    "inspect.Parameter.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [p_qn_eq,            Parameter.__qualname__.__eq__,               ["Parameter"],                  true, "inspect.Parameter.__qualname__ == 'Parameter' — qualname equals name; verified with Python 3.14.3"]
    - [p_mod_eq,           Parameter.__module__.__eq__,                 ["inspect"],                    true, "inspect.Parameter.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [p_mod_len,          Parameter.__module__.__len__,                [],                             7,    "inspect.Parameter.__module__.__len__() == 7; verified with Python 3.14.3"]
    - [p_cls_eq,           Parameter.__class__.__name__.__eq__,         ["type"],                       true, "inspect.Parameter.__class__.__name__ == 'type' — Parameter is a regular Python class; verified with Python 3.14.3"]
    - [p_base_eq,          Parameter.__bases__.__getitem__(0).__name__.__eq__, ["object"],             true, "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter inherits directly from object; verified with Python 3.14.3"]
    - [pk_po_cls,          Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__, ["_ParameterKind"],     true, "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'; verified with Python 3.14.3"]
    - [pk_po_int,          Parameter.POSITIONAL_ONLY.__int__,           [],                             0,    "int(inspect.Parameter.POSITIONAL_ONLY) == 0; verified with Python 3.14.3"]
    - [pk_pok_cls,         Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__, ["_ParameterKind"], true, "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'; verified with Python 3.14.3"]
    - [pk_pok_int,         Parameter.POSITIONAL_OR_KEYWORD.__int__,     [],                             1,    "int(inspect.Parameter.POSITIONAL_OR_KEYWORD) == 1; verified with Python 3.14.3"]
    - [pk_vp_cls,          Parameter.VAR_POSITIONAL.__class__.__name__.__eq__, ["_ParameterKind"],      true, "inspect.Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind'; verified with Python 3.14.3"]
    - [pk_vp_int,          Parameter.VAR_POSITIONAL.__int__,            [],                             2,    "int(inspect.Parameter.VAR_POSITIONAL) == 2; verified with Python 3.14.3"]
    - [pk_ko_cls,          Parameter.KEYWORD_ONLY.__class__.__name__.__eq__, ["_ParameterKind"],        true, "inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind'; verified with Python 3.14.3"]
    - [pk_ko_int,          Parameter.KEYWORD_ONLY.__int__,              [],                             3,    "int(inspect.Parameter.KEYWORD_ONLY) == 3; verified with Python 3.14.3"]
    - [pk_vk_cls,          Parameter.VAR_KEYWORD.__class__.__name__.__eq__, ["_ParameterKind"],         true, "inspect.Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind'; verified with Python 3.14.3"]
    - [pk_vk_int,          Parameter.VAR_KEYWORD.__int__,               [],                             4,    "int(inspect.Parameter.VAR_KEYWORD) == 4; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# inspect.BoundArguments class identity
#
# BoundArguments is a regular Python class with __module__ == 'inspect'.
# BoundArguments.__bases__[0].__name__ == 'object'.
# BoundArguments.__name__ (14) > Parameter.__name__ (9).
# ---------------------------------------------------------------------------

table inspect_extra268.boundarguments_class_identity:
  description: "inspect.BoundArguments(14) class identity — BoundArguments is type in inspect(7); inherits from object; BoundArguments(14) name longer than Parameter(9); both share __module__ == 'inspect'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex268b

  columns: [id, function, args, expected, description]
  rows:
    - [ba_name_eq,         BoundArguments.__name__.__eq__,              ["BoundArguments"],             true, "inspect.BoundArguments.__name__ == 'BoundArguments'; verified with Python 3.14.3"]
    - [ba_name_len,        BoundArguments.__name__.__len__,             [],                             14,   "inspect.BoundArguments.__name__.__len__() == 14 — longer than Parameter(9); verified with Python 3.14.3"]
    - [ba_qn_eq,           BoundArguments.__qualname__.__eq__,          ["BoundArguments"],             true, "inspect.BoundArguments.__qualname__ == 'BoundArguments' — qualname equals name; verified with Python 3.14.3"]
    - [ba_mod_eq,          BoundArguments.__module__.__eq__,            ["inspect"],                    true, "inspect.BoundArguments.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [ba_mod_len,         BoundArguments.__module__.__len__,           [],                             7,    "inspect.BoundArguments.__module__.__len__() == 7 — same as Parameter module length; verified with Python 3.14.3"]
    - [ba_cls_eq,          BoundArguments.__class__.__name__.__eq__,    ["type"],                       true, "inspect.BoundArguments.__class__.__name__ == 'type' — BoundArguments is a regular Python class; verified with Python 3.14.3"]
    - [ba_base_name,       BoundArguments.__bases__.__getitem__(0).__name__.__eq__, ["object"],         true, "inspect.BoundArguments.__bases__[0].__name__ == 'object' — BoundArguments inherits directly from object; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra268
# ---------------------------------------------------------------------------

invariant inspect_extra268.parameter_is_type:
  description: "inspect.Parameter.__class__.__name__ == 'type' — Parameter is a regular Python class; both Parameter and BoundArguments are types in the inspect module"
  category: identity
  kind: python_call_eq
  function: Parameter.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra268.parameter_kind_positional_only_is_zero:
  description: "int(inspect.Parameter.POSITIONAL_ONLY) == 0 — POSITIONAL_ONLY is the lowest-valued kind constant; kind values run 0..4 in order POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD"
  category: identity
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__int__
  args: []
  expected: 0

invariant inspect_extra268.parameter_kind_var_keyword_is_four:
  description: "int(inspect.Parameter.VAR_KEYWORD) == 4 — VAR_KEYWORD is the highest-valued kind constant at 4; five constants total (0..4)"
  category: identity
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.__int__
  args: []
  expected: 4

invariant inspect_extra268.boundarguments_name_longer_than_parameter:
  description: "inspect.BoundArguments.__name__.__len__() == 14 > inspect.Parameter.__name__.__len__() == 9 — BoundArguments name is longer than Parameter name"
  category: identity
  kind: python_call_eq
  function: BoundArguments.__name__.__len__
  args: []
  expected: 14

invariant inspect_extra268.all_parameter_kinds_are_paramkind:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind' — all five Parameter kind constants share the same _ParameterKind enum class"
  category: identity
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true
