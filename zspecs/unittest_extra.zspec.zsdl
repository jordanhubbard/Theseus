spec: unittest_extra
version: ">=3.8"
backend: python_module(unittest)

docs: https://docs.python.org/3/library/unittest.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/unittest.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "unittest source: internal test runner implementation"
    - "unittest.zspec.zsdl — covers class names (__name__), function names (__name__), SkipTest.__bases__[0], TestLoader prefix, TestSuite/TestResult initial state"
    - "unittest_mock.zspec.zsdl — covers unittest.mock classes, module checks, inheritance, sentinel"
  notes:
    - "This spec extends unittest.zspec.zsdl and unittest_mock.zspec.zsdl; it does NOT duplicate invariants present in those files."
    - "unittest.zspec.zsdl covers: TestCase/TestSuite/TestLoader/TestResult/TextTestRunner/TextTestResult/FunctionTestCase/TestProgram/SkipTest/IsolatedAsyncioTestCase __name__; skip/skipIf/skipUnless/expectedFailure/__name__; SkipTest.__bases__[0] == Exception; TestLoader prefix; TestSuite/TestResult initial state."
    - "TestCase.__module__ == 'unittest.case' — TestCase is defined in Lib/unittest/case.py."
    - "TestSuite.__module__ == 'unittest.suite' — TestSuite is defined in Lib/unittest/suite.py."
    - "TestLoader.__module__ == 'unittest.loader' — TestLoader is defined in Lib/unittest/loader.py."
    - "TestResult.__module__ == 'unittest.result' — TestResult is defined in Lib/unittest/result.py."
    - "TestProgram.__module__ == 'unittest.main' — TestProgram is defined in Lib/unittest/main.py."
    - "FunctionTestCase.__module__ == 'unittest.case' — FunctionTestCase is defined alongside TestCase."
    - "SkipTest.__module__ == 'unittest.case' — SkipTest is defined in Lib/unittest/case.py."
    - "unittest.main is the TestProgram class re-exported from unittest.__init__; its __module__ is 'unittest.main'."
    - "skip, skipIf, skipUnless, expectedFailure are plain Python functions defined in unittest.case; their __module__ == 'unittest.case'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module checks — unittest classes are split across multiple submodules
# unittest.zspec.zsdl tests __name__; this spec tests __module__
# ---------------------------------------------------------------------------

table unittest_extra.class_modules:
  kind: python_call_eq
  category: modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [testcase,         TestCase.__module__.__eq__,         ["unittest.case"],   true]
    - [testsuite,        TestSuite.__module__.__eq__,        ["unittest.suite"],  true]
    - [testloader,       TestLoader.__module__.__eq__,       ["unittest.loader"], true]
    - [testresult,       TestResult.__module__.__eq__,       ["unittest.result"], true]
    - [testprogram,      TestProgram.__module__.__eq__,      ["unittest.main"],   true]
    - [functiontestcase, FunctionTestCase.__module__.__eq__, ["unittest.case"],   true]
    - [skiptest,         SkipTest.__module__.__eq__,         ["unittest.case"],   true]

# ---------------------------------------------------------------------------
# Decorator function module checks
# skip, skipIf, skipUnless, expectedFailure live in unittest.case
# ---------------------------------------------------------------------------

table unittest_extra.decorator_modules:
  kind: python_call_eq
  category: modules
  id_prefix: decmod

  columns: [id, function, args, expected]
  rows:
    - [skip,            skip.__module__.__eq__,            ["unittest.case"], true]
    - [skipif,          skipIf.__module__.__eq__,          ["unittest.case"], true]
    - [skipunless,      skipUnless.__module__.__eq__,      ["unittest.case"], true]
    - [expectedfailure, expectedFailure.__module__.__eq__, ["unittest.case"], true]

# ---------------------------------------------------------------------------
# unittest.main — the module-level 'main' symbol is the TestProgram class
# unittest.zspec.zsdl verifies TestProgram.__name__ == 'TestProgram' and
# main.__name__ == 'main' is NOT covered there (main is not in the function_names table).
# This spec confirms the re-export identity.
# ---------------------------------------------------------------------------

invariant unittest_extra.main.is_testprogram:
  description: "unittest.main.__name__ == 'TestProgram' — main is an alias for the TestProgram class"
  category: identities
  kind: python_call_eq
  function: main.__name__.__eq__
  args: ["TestProgram"]
  expected: true

invariant unittest_extra.main.module:
  description: "unittest.main.__module__ == 'unittest.main'"
  category: modules
  kind: python_call_eq
  function: main.__module__.__eq__
  args: ["unittest.main"]
  expected: true

# ---------------------------------------------------------------------------
# TestCase — base class check
# TestCase inherits from object; its __bases__[0].__name__ == 'object'
# ---------------------------------------------------------------------------

invariant unittest_extra.TestCase.base:
  description: "unittest.TestCase.__bases__[0].__name__ == 'object' — TestCase inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: TestCase.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# FunctionTestCase — base class check
# FunctionTestCase inherits from TestCase
# ---------------------------------------------------------------------------

invariant unittest_extra.FunctionTestCase.base:
  description: "unittest.FunctionTestCase.__bases__[0].__name__ == 'TestCase' — FunctionTestCase inherits from TestCase"
  category: hierarchy
  kind: python_call_eq
  function: FunctionTestCase.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "TestCase"

# ---------------------------------------------------------------------------
# TestLoader default instance — sortTestMethodsUsing is set (not None)
# Confirms TestLoader is instantiable and carries sorting behavior.
# ---------------------------------------------------------------------------

invariant unittest_extra.TestLoader.sort_method_not_none:
  description: "unittest.TestLoader().sortTestMethodsUsing is not None — default loader sorts tests"
  category: loader_attrs
  kind: python_call_eq
  function: TestLoader
  args: []
  method: sortTestMethodsUsing.__class__.__name__.__eq__
  method_args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# TestResult — skipped list starts empty
# unittest.zspec.zsdl covers errors, failures, testsRun, wasSuccessful;
# this spec adds the skipped list initial state.
# ---------------------------------------------------------------------------

invariant unittest_extra.result_skipped_empty:
  description: "unittest.TestResult().skipped == [] — no skipped tests in a fresh result"
  category: result_state
  kind: python_call_eq
  function: TestResult
  args: []
  method: skipped.__eq__
  method_args: [[]]
  expected: true
