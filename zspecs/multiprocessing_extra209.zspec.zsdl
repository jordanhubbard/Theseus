    - [pool_cls_module, pool.Pool.__module__.__eq__, ["multiprocessing.pool"],   true, "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool'"]

invariant multiprocessing_extra209.pool_class_base_name:
