spec: multiprocessing_extra209
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "multiprocessing.Pool is a bound method on the context object (not a class), so __bases__ does not exist."
    - "multiprocessing.Pool.__name__ == 'Pool'; __module__ == 'multiprocessing.context'."
    - "multiprocessing.pool.Pool is the actual class with __module__ == 'multiprocessing.pool'."
    - "multiprocessing.pool.Pool.__bases__[0].__name__ == 'object' — Pool inherits directly from object."
    - "multiprocessing.pool.Pool.map.__name__ == 'map'; __qualname__ == 'Pool.map'."
    - "multiprocessing.pool.Pool.apply.__name__ == 'apply'; __qualname__ == 'Pool.apply'."
    - "multiprocessing.pool.Pool.close.__name__ == 'close'; __qualname__ == 'Pool.close'."
    - "multiprocessing.pool.AsyncResult.__name__ == 'ApplyResult' — AsyncResult is an alias for ApplyResult."
    - "multiprocessing.pool.AsyncResult.__module__ == 'multiprocessing.pool'."
    - "multiprocessing.pool.AsyncResult.__bases__[0].__name__ == 'object'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Pool method identity — extra209 namespace
#
# multiprocessing.Pool is a bound method on the context instance (not a
# class), so only __name__ and __module__ are accessible; __bases__ does
# not exist on a method object.
# ---------------------------------------------------------------------------

table multiprocessing_extra209.pool_method_identity:
  description: "multiprocessing.Pool bound-method __name__ and __module__ in extra209 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp209poolmethident

  columns: [id, function, args, expected, description]
  rows:
    - [pool_name,   Pool.__name__.__eq__,   ["Pool"],                      true, "multiprocessing.Pool.__name__ == 'Pool'"]
    - [pool_module, Pool.__module__.__eq__, ["multiprocessing.context"],   true, "multiprocessing.Pool.__module__ == 'multiprocessing.context'"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool class identity — extra209 namespace
#
# multiprocessing.pool.Pool is the actual class.  Its __bases__[0] is object.
# ---------------------------------------------------------------------------

table multiprocessing_extra209.pool_class_identity:
