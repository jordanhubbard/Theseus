spec: fast_glob
version: ">=3.0.0"
backend: node(fast-glob)

docs: https://github.com/mrmlnc/fast-glob#readme

provenance:
  derived_from:
    - "fast-glob README — https://github.com/mrmlnc/fast-glob#readme"
    - "Test vectors verified with fast-glob via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "fast-glob source"
  notes:
    - "Fast and efficient glob library — engine behind globby."
    - "Install: npm install fast-glob"
    - "v3 CJS; module is itself the async fast-glob function with .sync, .stream, isDynamicPattern, escapePath helpers attached."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Throws TypeError on invalid pattern types; sync version returns [] for no match."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# Pure helpers
invariant fast_glob.isDynamicPattern_glob_true:
  description: "isDynamicPattern('*.js') is true"
  category: helpers
  kind: node_chain_eq
  entry: named
  function: isDynamicPattern
  entry_args: ["*.js"]
  chain: []
  expected: true

invariant fast_glob.isDynamicPattern_literal_false:
  description: "isDynamicPattern('foo.txt') is false"
  category: helpers
  kind: node_chain_eq
  entry: named
  function: isDynamicPattern
  entry_args: ["foo.txt"]
  chain: []
  expected: false

invariant fast_glob.isDynamicPattern_brace:
  description: "isDynamicPattern('{a,b}.js') is true (brace expansion)"
  category: helpers
  kind: node_chain_eq
  entry: named
  function: isDynamicPattern
  entry_args: ["{a,b}.js"]
  chain: []
  expected: true

invariant fast_glob.escapePath_star:
  description: "escapePath('foo*bar') escapes the asterisk"
  category: helpers
  kind: node_chain_eq
  entry: named
  function: escapePath
  entry_args: ["foo*bar"]
  chain: []
  expected: "foo\\*bar"

invariant fast_glob.escapePath_brackets:
  description: "escapePath('a[b]c') escapes brackets and special chars"
  category: helpers
  kind: node_chain_eq
  entry: named
  function: escapePath
  entry_args: ["a[b]c"]
  chain: []
  expected: "a\\[b\\]c"

# sync — empty result for non-matching pattern under unguessable subdir
invariant fast_glob.sync_no_match:
  description: "sync(['/tmp/no-such-pattern-zxc/*.txt']) is []"
  category: glob
  kind: node_chain_eq
  entry: named
  function: sync
  entry_args: [["/tmp/no-such-pattern-zxc/*.txt"]]
  chain:
    - {get: length}
  expected: 0
