spec: itertools_extra1111
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks chain.from_iterable qualname/class, itertools.__name__/__doc__ class, starmap/dropwhile/takewhile/groupby/filterfalse module and class identity, combinations_with_replacement/__new__/__qualname__ — not covered in _extra1081/_extra1096"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra1111.module_level_identity:
  description: "itertools module-level attributes and chain.from_iterable identity"
  kind: python_call_eq
  category: module_level_identity
  id_prefix: it1111ml
  columns: [id, function, args, expected]
  rows:
    - [it1111ml001, itertools.__name__.__eq__,                                    ["itertools"],                        true]
    - [it1111ml002, itertools.__doc__.__class__.__name__.__eq__,                  ["str"],                              true]
    - [it1111ml003, itertools.chain.from_iterable.__qualname__.__eq__,            ["chain.from_iterable"],              true]
    - [it1111ml004, itertools.chain.from_iterable.__class__.__name__.__eq__,      ["builtin_function_or_method"],        true]
    - [it1111ml005, itertools.chain.__module__.__eq__,                            ["itertools"],                        true]
    - [it1111ml006, itertools.chain.__qualname__.__eq__,                          ["chain"],                            true]
    - [it1111ml007, itertools.chain.__class__.__name__.__eq__,                    ["type"],                             true]
    - [it1111ml008, itertools.accumulate.__class__.__name__.__eq__,               ["type"],                             true]

table itertools_extra1111.filtering_class_identity:
