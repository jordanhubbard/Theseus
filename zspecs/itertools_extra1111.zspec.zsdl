    - [it1111fc003, itertools.starmap.__class__.__name__.__eq__,                  ["type"],                             true]
    - [it1111fc004, itertools.dropwhile.__module__.__eq__,                        ["itertools"],                        true]
    - [it1111fc005, itertools.dropwhile.__qualname__.__eq__,                      ["dropwhile"],                        true]
    - [it1111fc006, itertools.dropwhile.__class__.__name__.__eq__,                ["type"],                             true]
    - [it1111fc007, itertools.takewhile.__module__.__eq__,                        ["itertools"],                        true]
    - [it1111fc008, itertools.takewhile.__qualname__.__eq__,                      ["takewhile"],                        true]

table itertools_extra1111.combinatoric_new_and_groupby:
