spec: abc_extra2491
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "https://docs.python.org/3/library/abc.html#abc.ABC — ABC base class"
    - "https://docs.python.org/3/library/abc.html#abc.ABCMeta — ABCMeta metaclass"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "Theme: __setitem__, __delitem__, and __missing__ dict-presence — checking whether abc classes define mutable item access and missing-key protocol in their class __dict__."
    - "abc.ABC.__dict__.__contains__('__setitem__') == False — ABC does not define __setitem__; verified Python 3.14.4."
    - "abc.ABC.__dict__.__contains__('__delitem__') == False — ABC does not define __delitem__; verified Python 3.14.4."
    - "abc.ABC.__dict__.__contains__('__missing__') == False — ABC does not define __missing__; verified Python 3.14.4."
    - "abc.ABCMeta.__dict__.__contains__('__setitem__') == False — ABCMeta does not define __setitem__; verified Python 3.14.4."
    - "abc.ABCMeta.__dict__.__contains__('__delitem__') == False — ABCMeta does not define __delitem__; verified Python 3.14.4."
    - "abc.ABCMeta.__dict__.__contains__('__missing__') == False — ABCMeta does not define __missing__; verified Python 3.14.4."
    - "abc.ABC defines __doc__, __slots__, __abstractmethods__, _abc_impl in its class __dict__; verified Python 3.14.4."
    - "abc.ABCMeta defines __new__, register, __instancecheck__, __subclasscheck__ in its class __dict__; verified Python 3.14.4."
    - "Accessing a missing key via __dict__.__getitem__ raises KeyError for abc.ABC and abc.ABCMeta; verified Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc class __dict__ __contains__ checks — __setitem__, __delitem__,
# __missing__ dict-presence theme
#
# Neither abc.ABC nor abc.ABCMeta defines __setitem__, __delitem__, or
# __missing__ in their own class __dict__. ABC is a bare abstract base class
# helper and ABCMeta is a metaclass; neither provides mutable item access or
# missing-key fallback.
# ---------------------------------------------------------------------------

table abc_extra2491.abc_dict_mutable_item:
  description: "abc.ABC.__dict__.__contains__ checks for __setitem__, __delitem__, __missing__ — ABC defines __doc__, __slots__, __abstractmethods__, _abc_impl but NOT mutable item access methods; verified Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ab2491

  columns: [id, function, args, expected]
  rows:
    - ["ab2491001", abc.ABC.__dict__.__contains__, ["__doc__"],              true]
    - ["ab2491002", abc.ABC.__dict__.__contains__, ["__slots__"],            true]
    - ["ab2491003", abc.ABC.__dict__.__contains__, ["__abstractmethods__"],  true]
    - ["ab2491004", abc.ABC.__dict__.__contains__, ["_abc_impl"],            true]
    - ["ab2491005", abc.ABC.__dict__.__contains__, ["__setitem__"],          false]
    - ["ab2491006", abc.ABC.__dict__.__contains__, ["__delitem__"],          false]
    - ["ab2491007", abc.ABC.__dict__.__contains__, ["__missing__"],          false]

