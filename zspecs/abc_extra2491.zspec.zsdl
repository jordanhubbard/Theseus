  category: dict_presence
  id_prefix: ab2491

  columns: [id, function, args, expected]
  rows:
    - ["ab2491021", abc.ABC.__dict__.__getitem__,    ["__setitem__"],   KeyError]
    - ["ab2491022", abc.ABC.__dict__.__getitem__,    ["__delitem__"],   KeyError]
    - ["ab2491023", abc.ABC.__dict__.__getitem__,    ["__missing__"],   KeyError]
    - ["ab2491024", abc.ABCMeta.__dict__.__getitem__, ["__setitem__"],  KeyError]
