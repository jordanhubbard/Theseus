# ---------------------------------------------------------------------------
# __getitem__ on class __dict__ raises KeyError for absent mutable-item keys
# ---------------------------------------------------------------------------

table abc_extra2491.dict_getitem_raises:
  description: "abc.ABC and abc.ABCMeta __dict__.__getitem__ raises KeyError for absent __setitem__, __delitem__, __missing__ — neither defines mutable item access methods; verified Python 3.14.4"
