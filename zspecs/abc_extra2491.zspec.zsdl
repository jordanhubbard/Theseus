    - ["ab2491011", abc.ABCMeta.__dict__.__contains__, ["__subclasscheck__"],    true]
    - ["ab2491012", abc.ABCMeta.__dict__.__contains__, ["__setitem__"],          false]
    - ["ab2491013", abc.ABCMeta.__dict__.__contains__, ["__delitem__"],          false]
    - ["ab2491014", abc.ABCMeta.__dict__.__contains__, ["__missing__"],          false]

