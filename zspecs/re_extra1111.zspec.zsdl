spec: re_extra1111
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module compile/match/search/sub/findall/split function qualname/module documentation and Pattern/Match class identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.compile/__module__/__qualname__/__class__.__name__, re module __name__/__spec__.name, re.match/search/sub/findall/split __module__, re.__doc__/__class__.__name__, Pattern/Match __doc__/__class__.__name__, and Pattern/Match __name__/__module__; not covered in _extra1081 or _extra1096"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1111.compile_function_identity:
  description: "re.compile __module__, __qualname__, and __class__.__name__ checks"
  kind: python_call_eq
  category: compile_function_identity
  id_prefix: re1111cf
  columns: [id, function, args, expected]
  rows:
    - [re1111cf001, re.compile.__module__.__eq__,           ["re"],       true]
    - [re1111cf002, re.compile.__qualname__.__eq__,         ["compile"],  true]
    - [re1111cf003, re.compile.__class__.__name__.__eq__,   ["function"], true]
    - [re1111cf004, re.match.__module__.__eq__,             ["re"],       true]
    - [re1111cf005, re.match.__qualname__.__eq__,           ["match"],    true]
    - [re1111cf006, re.search.__module__.__eq__,            ["re"],       true]
    - [re1111cf007, re.search.__qualname__.__eq__,          ["search"],   true]
    - [re1111cf008, re.sub.__module__.__eq__,               ["re"],       true]
    - [re1111cf009, re.findall.__module__.__eq__,           ["re"],       true]
    - [re1111cf010, re.split.__module__.__eq__,             ["re"],       true]

table re_extra1111.module_identity:
  description: "re module __name__ and __spec__.name identity checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: re1111mi
  columns: [id, function, args, expected]
  rows:
    - [re1111mi001, re.__name__.__eq__,         ["re"], true]
    - [re1111mi002, re.__spec__.name.__eq__,    ["re"], true]
    - [re1111mi003, re.__name__.__eq__,         ["_sre"], false]
    - [re1111mi004, re.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [re1111mi005, re.compile.__module__.__eq__,              ["_sre"], false]
    - [re1111mi006, re.match.__class__.__name__.__eq__,        ["function"], true]
    - [re1111mi007, re.search.__class__.__name__.__eq__,       ["function"], true]
    - [re1111mi008, re.sub.__class__.__name__.__eq__,          ["function"], true]

table re_extra1111.pattern_and_match_class_identity:
  description: "re.Pattern and re.Match class __name__, __module__, and __doc__.__class__.__name__ checks"
  kind: python_call_eq
  category: pattern_and_match_class_identity
  id_prefix: re1111pm
  columns: [id, function, args, expected]
  rows:
    - [re1111pm001, re.Pattern.__name__.__eq__,                      ["Pattern"], true]
    - [re1111pm002, re.Pattern.__module__.__eq__,                    ["re"],      true]
    - [re1111pm003, re.Pattern.__doc__.__class__.__name__.__eq__,    ["str"],     true]
    - [re1111pm004, re.Match.__name__.__eq__,                        ["Match"],   true]
    - [re1111pm005, re.Match.__module__.__eq__,                      ["re"],      true]
    - [re1111pm006, re.Match.__doc__.__class__.__name__.__eq__,      ["str"],     true]
    - [re1111pm007, re.Pattern.__name__.__eq__,                      ["Match"],   false]
    - [re1111pm008, re.Match.__name__.__eq__,                        ["Pattern"], false]
