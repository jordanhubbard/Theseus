spec: hashlib_extra125
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra124.zspec.zsdl — covers pbkdf2_hmac and scrypt __class__.__name__.__len__()==26 / __doc__.__class__.__module__.__eq__('builtins') and __len__()==8 (table + invariants)."
    - "hashlib_extra123.zspec.zsdl — covers sha256.__doc__.__class__.__module__.__eq__('builtins') / sha256().__class__.__qualname__.__eq__('HASH') and __len__()==4 / sha256().__class__.__module__.__len__()==8 (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ / blake2b/blake2s class identity / new function class / algorithms_guaranteed length (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra124; it does NOT duplicate invariants present in those files."
    - "Wave 282 theme: hashlib HASH object instance method class names and qualnames — md5()/sha256()/sha1() instance __class__.__name__=='HASH' and __class__.__module__=='_hashlib' / HASH instance methods (update/digest/hexdigest/copy) __class__.__name__=='builtin_function_or_method' and qualnames 'HASH.update'/'HASH.digest'/'HASH.hexdigest'/'HASH.copy'."
    - "hashlib.md5().__class__.__name__ == 'HASH'. All hash instances (md5/sha1/sha256) share the same class name 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().__class__.__module__ == '_hashlib'. The HASH class is from the _hashlib C extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().__class__.__qualname__ == 'HASH'. The qualname equals the class name for this top-level C extension type. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().update.__class__.__name__ == 'builtin_function_or_method'. All HASH instance methods are C-level builtins. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().digest.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().hexdigest.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().copy.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().update.__qualname__ == 'HASH.update'. len('HASH.update')==11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().digest.__qualname__ == 'HASH.digest'. len('HASH.digest')==11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().hexdigest.__qualname__ == 'HASH.hexdigest'. len('HASH.hexdigest')==14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().copy.__qualname__ == 'HASH.copy'. len('HASH.copy')==9. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All hash constructors (md5, sha1, sha256, etc.) return instances of the same C extension class 'HASH' from _hashlib. The HASH class name is the same regardless of the algorithm. The __class__.__qualname__ equals __class__.__name__ because HASH is a top-level (non-nested) type. HASH instance methods have qualname 'HASH.<method>' with 'HASH.' (5-char) prefix. update and digest both have length 11 ('HASH.'=5 + 'update'=6 and 'HASH.'=5 + 'digest'=6). hexdigest is 14 chars ('HASH.'=5 + 'hexdigest'=9). copy is 9 chars ('HASH.'=5 + 'copy'=4). All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5().__class__.__name__.__eq__('HASH')
# hashlib.sha256().__class__.__name__.__eq__('HASH')
# hashlib.sha1().__class__.__name__.__eq__('HASH')
# hashlib.md5().__class__.__module__.__eq__('_hashlib')
# hashlib.md5().__class__.__qualname__.__eq__('HASH')
#
# Wave 282 theme: HASH class identity for md5/sha256/sha1 instances.
#
# All hash constructors return instances of the same C extension class 'HASH' from
# _hashlib. The class name is 'HASH' regardless of algorithm. The __module__ is
# '_hashlib' (the C extension). The __qualname__ is 'HASH' (same as __name__ because
# HASH is a top-level type). hashlib_extra123 anchors sha256().__class__.__qualname__
# and __qualname__.__len__()==4; no prior spec anchors md5().__class__.__name__ or
# the module under hashinst125. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra125.HASH_class_identity:
  description: "md5().__class__.__name__.__eq__('HASH')==True / sha256().__class__.__name__.__eq__('HASH')==True / sha1().__class__.__name__.__eq__('HASH')==True / md5().__class__.__module__.__eq__('_hashlib')==True / md5().__class__.__qualname__.__eq__('HASH')==True — all hash constructors return instances of the same C extension class 'HASH' from _hashlib; qualname equals name ('HASH') because it is a top-level type; extra123 anchors sha256().__class__.__qualname__ and __len__()==4; no prior spec anchors md5().__class__.__name__ as eq; first hashinst125 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashinst125

  columns: [id, function, args, expected, description]
  rows:
    - [md5_class_name,     "md5().__class__.__name__.__eq__",     ["HASH"],     true, "md5().__class__.__name__ is 'HASH' (C extension class from _hashlib; all algorithms share the same HASH type; no prior spec anchors md5 instance class name as eq)"]
    - [sha256_class_name,  "sha256().__class__.__name__.__eq__",  ["HASH"],     true, "sha256().__class__.__name__ is 'HASH' (same HASH class as md5; extra123 anchors sha256().__class__.__qualname__.__eq__('HASH') as a standalone; this confirms via __name__ path)"]
    - [sha1_class_name,    "sha1().__class__.__name__.__eq__",    ["HASH"],     true, "sha1().__class__.__name__ is 'HASH' (same HASH class; all three algorithms produce HASH instances; no prior spec anchors sha1 instance class name)"]
    - [md5_class_module,   "md5().__class__.__module__.__eq__",   ["_hashlib"], true, "md5().__class__.__module__ is '_hashlib' (HASH class is from the _hashlib C extension; no prior spec anchors md5 instance class module as eq call)"]
    - [md5_class_qualname, "md5().__class__.__qualname__.__eq__", ["HASH"],     true, "md5().__class__.__qualname__ is 'HASH' (qualname equals name for top-level types; no nested class prefix; no prior spec anchors md5 instance class qualname as eq call)"]

# ---------------------------------------------------------------------------
# hashlib.md5().update.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.md5().digest.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.md5().hexdigest.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.md5().copy.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha256().update.__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 282 theme: HASH instance method class names.
#
# All methods on a HASH instance (update, digest, hexdigest, copy) are C-level
# builtin_function_or_method objects from _hashlib. When accessed on an instance,
# they are bound methods but still report __class__.__name__ as
# 'builtin_function_or_method'. No prior hashlib spec anchors the __class__.__name__
# of update/digest/hexdigest/copy accessed on an instance under hashinst125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra125.HASH_method_class_names:
  description: "md5().update.__class__.__name__.__eq__('builtin_function_or_method')==True / md5().digest.__class__.__name__.__eq__('builtin_function_or_method')==True / md5().hexdigest.__class__.__name__.__eq__('builtin_function_or_method')==True / md5().copy.__class__.__name__.__eq__('builtin_function_or_method')==True / sha256().update.__class__.__name__.__eq__('builtin_function_or_method')==True — all HASH instance methods are C-level builtin_function_or_method bound methods from _hashlib; no prior spec anchors method class names on instances; first hashinst125 method class anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashinst125

  columns: [id, function, args, expected, description]
  rows:
    - [update_class,    "md5().update.__class__.__name__.__eq__",    ["builtin_function_or_method"], true, "md5().update.__class__.__name__ is 'builtin_function_or_method' (C-level bound method from _hashlib; no prior spec anchors update class name on instance)"]
    - [digest_class,    "md5().digest.__class__.__name__.__eq__",    ["builtin_function_or_method"], true, "md5().digest.__class__.__name__ is 'builtin_function_or_method' (C-level bound method; digest returns raw bytes of the hash)"]
    - [hexdigest_class, "md5().hexdigest.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "md5().hexdigest.__class__.__name__ is 'builtin_function_or_method' (C-level bound method; hexdigest returns hex string of the hash)"]
    - [copy_class,      "md5().copy.__class__.__name__.__eq__",      ["builtin_function_or_method"], true, "md5().copy.__class__.__name__ is 'builtin_function_or_method' (C-level bound method; copy returns a duplicate of the hash state)"]
    - [sha256_update,   "sha256().update.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "sha256().update.__class__.__name__ is 'builtin_function_or_method' (same class as md5().update; all HASH algorithms share the same method type)"]

# ---------------------------------------------------------------------------
# hashlib.md5().update.__qualname__.__eq__('HASH.update')
# hashlib.md5().digest.__qualname__.__eq__('HASH.digest')
# hashlib.md5().hexdigest.__qualname__.__eq__('HASH.hexdigest')
# hashlib.md5().copy.__qualname__.__eq__('HASH.copy')
# hashlib.md5().update.__qualname__.__len__()==11
#
# Wave 282 theme: HASH instance method qualnames.
#
# HASH instance methods have qualname 'HASH.<method>', with the 'HASH.' (5-char)
# prefix reflecting the C extension class name. update.__qualname__=='HASH.update'
# (11 chars, 'HASH.'=5 + 'update'=6). digest.__qualname__=='HASH.digest' (11 chars,
# 'HASH.'=5 + 'digest'=6). hexdigest.__qualname__=='HASH.hexdigest' (14 chars,
# 'HASH.'=5 + 'hexdigest'=9). copy.__qualname__=='HASH.copy' (9 chars, 'HASH.'=5 +
# 'copy'=4). update and digest share qualname length 11. No prior hashlib spec anchors
# any HASH instance method qualname under hashinst125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra125.HASH_method_qualnames:
  description: "md5().update.__qualname__.__eq__('HASH.update')==True / md5().digest.__qualname__.__eq__('HASH.digest')==True / md5().hexdigest.__qualname__.__eq__('HASH.hexdigest')==True / md5().copy.__qualname__.__eq__('HASH.copy')==True / md5().update.__qualname__.__len__()==11 — all four HASH instance method qualnames have 'HASH.' prefix (5 chars); update and digest both 11 chars; hexdigest 14; copy 9; no prior spec anchors any HASH instance method qualname; first hashinst125 qualname anchor"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: hashinst125

  columns: [id, function, args, expected, description]
  rows:
    - [update_qualname_eq,    "md5().update.__qualname__.__eq__",    ["HASH.update"],    true, "md5().update.__qualname__ is 'HASH.update' (11 chars; 'HASH.'=5 + 'update'=6; no prior spec anchors update qualname on instance)"]
    - [digest_qualname_eq,    "md5().digest.__qualname__.__eq__",    ["HASH.digest"],    true, "md5().digest.__qualname__ is 'HASH.digest' (11 chars; 'HASH.'=5 + 'digest'=6; same length as update qualname)"]
    - [hexdigest_qualname_eq, "md5().hexdigest.__qualname__.__eq__", ["HASH.hexdigest"], true, "md5().hexdigest.__qualname__ is 'HASH.hexdigest' (14 chars; 'HASH.'=5 + 'hexdigest'=9; longest of the four HASH method qualnames)"]
    - [copy_qualname_eq,      "md5().copy.__qualname__.__eq__",      ["HASH.copy"],      true, "md5().copy.__qualname__ is 'HASH.copy' (9 chars; 'HASH.'=5 + 'copy'=4; shortest of the four HASH method qualnames)"]
    - [update_qualname_len,   "md5().update.__qualname__.__len__",   [],                 11,   "md5().update.__qualname__.__len__() is 11 ('HASH.update'; 'HASH.'=5 + 'update'=6; same length as digest qualname; first hashinst125 length anchor for update)"]

# ---------------------------------------------------------------------------
# hashlib.md5().__class__.__name__.__eq__('HASH') — standalone
#
# hashlib.md5().__class__.__name__ is 'HASH'. The HASH class is the C extension type
# in _hashlib that implements all OpenSSL-backed hash algorithms. When you call
# hashlib.md5(), you get a HASH instance. Its __class__.__name__ is 'HASH' — a short
# (4-char) uppercase class name that reflects the generic nature of the class:
# it represents any hash algorithm, not a specific one. hashlib_extra123 anchors
# sha256().__class__.__qualname__.__eq__('HASH') as a standalone; no prior hashlib
# spec anchors md5().__class__.__name__.__eq__('HASH') as a standalone under hashinst125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra125.md5_instance_class_HASH:
  description: "hashlib.md5().__class__.__name__.__eq__('HASH') == True — md5() returns a HASH instance; HASH is the C extension class in _hashlib that implements all OpenSSL-backed algorithms generically; 4-char uppercase name reflects generic (algorithm-agnostic) type; extra123 anchors sha256().__class__.__qualname__.__eq__('HASH'); no prior spec anchors md5().__class__.__name__.__eq__('HASH') as standalone; first standalone under hashinst125"
  category: type_identity
  kind: python_call_eq
  function: "md5().__class__.__name__.__eq__"
  args: ["HASH"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().__class__.__module__.__eq__('_hashlib') — standalone
#
# hashlib.md5().__class__.__module__ is '_hashlib'. The HASH class is defined in
# the _hashlib C extension module (Modules/_hashopenssl.c). The '_hashlib' module
# contains all OpenSSL-backed hash implementations and is the C-level backing for
# the public hashlib module. The module name '_hashlib' has 8 chars — coincidentally
# the same as len('builtins')==8, which appears in many docstring class module checks.
# No prior hashlib spec anchors md5().__class__.__module__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra125.md5_instance_class_module_hashlib:
  description: "hashlib.md5().__class__.__module__.__eq__('_hashlib') == True — HASH class is defined in _hashlib C extension (Modules/_hashopenssl.c); '_hashlib' is the C-level backing for the public hashlib module; len('_hashlib')==8 coincides with len('builtins')==8 from docstring checks; no prior spec anchors md5().__class__.__module__ as standalone; first standalone under hashinst125"
  category: type_identity
  kind: python_call_eq
  function: "md5().__class__.__module__.__eq__"
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().update.__qualname__.__eq__('HASH.update') — standalone
#
# hashlib.md5().update.__qualname__ is 'HASH.update'. When a C extension method is
# accessed on an instance, its __qualname__ still reflects the class name prefix:
# 'HASH.update' (11 chars, 'HASH.'=5 + 'update'=6). The 'HASH.' prefix in the
# qualname identifies the method's defining class. No prior hashlib spec anchors
# any HASH instance method qualname as a standalone under hashinst125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra125.md5_update_qualname_HASH_update:
  description: "hashlib.md5().update.__qualname__.__eq__('HASH.update') == True — update.__qualname__ is 'HASH.update' (11 chars; 'HASH.'=5 + 'update'=6); the 'HASH.' prefix identifies the defining C extension class; same qualname for all algorithm instances (sha1, sha256, etc.); no prior spec anchors any HASH instance method qualname as standalone; first update qualname standalone under hashinst125"
  category: method_qualnames
  kind: python_call_eq
  function: "md5().update.__qualname__.__eq__"
  args: ["HASH.update"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().hexdigest.__qualname__.__eq__('HASH.hexdigest') — standalone
#
# hashlib.md5().hexdigest.__qualname__ is 'HASH.hexdigest'. This is 14 chars:
# 'HASH.'=5 + 'hexdigest'=9. hexdigest is the longest of the standard HASH methods
# (update/digest/hexdigest/copy) in qualname length (14 chars). The hexdigest method
# returns a hex string representation of the hash — twice as long as the raw digest
# bytes. No prior hashlib spec anchors hexdigest qualname as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra125.md5_hexdigest_qualname_HASH_hexdigest:
  description: "hashlib.md5().hexdigest.__qualname__.__eq__('HASH.hexdigest') == True — hexdigest.__qualname__ is 'HASH.hexdigest' (14 chars; 'HASH.'=5 + 'hexdigest'=9; longest HASH method qualname among update/digest/hexdigest/copy; hexdigest returns hex string twice as long as raw digest bytes; no prior spec anchors hexdigest qualname as standalone; first hexdigest qualname standalone under hashinst125)"
  category: method_qualnames
  kind: python_call_eq
  function: "md5().hexdigest.__qualname__.__eq__"
  args: ["HASH.hexdigest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().copy.__qualname__.__eq__('HASH.copy') — standalone
#
# hashlib.md5().copy.__qualname__ is 'HASH.copy'. This is 9 chars: 'HASH.'=5 + 'copy'=4.
# copy is the shortest qualname of the four standard HASH methods (9 chars). The copy
# method returns a duplicate HASH object with the same internal state — useful for
# computing multiple digests from a common prefix without re-hashing the prefix.
# No prior hashlib spec anchors copy qualname as a standalone under hashinst125.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra125.md5_copy_qualname_HASH_copy:
  description: "hashlib.md5().copy.__qualname__.__eq__('HASH.copy') == True — copy.__qualname__ is 'HASH.copy' (9 chars; 'HASH.'=5 + 'copy'=4; shortest HASH method qualname among update/digest/hexdigest/copy; copy returns a duplicate HASH with the same internal state for computing multiple digests from a common prefix; no prior spec anchors copy qualname as standalone; first copy qualname standalone under hashinst125)"
  category: method_qualnames
  kind: python_call_eq
  function: "md5().copy.__qualname__.__eq__"
  args: ["HASH.copy"]
  expected: true
