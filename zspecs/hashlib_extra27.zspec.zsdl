spec: hashlib_extra27
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra26.zspec.zsdl — covers sha224/sha384 __qualname__.__eq__; new.__qualname__.__eq__; algorithms_guaranteed/available __class__.__name__.__eq__."
    - "hashlib_extra25.zspec.zsdl — covers algorithms_guaranteed/__class__/__qualname__; algorithms_guaranteed/__len__()==14; algorithms_guaranteed contains sha3_256."
    - "hashlib_extra24.zspec.zsdl — covers md5/sha1/sha256/sha512 __qualname__.__eq__ as standalone invariants; __qualname__.__len__() for md5/sha1/sha256/sha512/sha224/sha384/new/pbkdf2_hmac."
    - "hashlib_extra23.zspec.zsdl — covers sha384/sha224 block_size/digest_size; new('sha224'/'sha384') __class__.__name__."
    - "hashlib_extra17.zspec.zsdl — covers sha256/md5/sha1 empty-input hexdigest; sha256 block_size/name; new.__qualname__."
    - "hashlib_extra14.zspec.zsdl — covers sha256().copy() name/digest_size/block_size; sha256 hexdigest vector."
  notes:
    - "This spec extends hashlib through hashlib_extra26; it does NOT duplicate invariants present in those files."
    - "Focus: __qualname__ for HASH instance methods (update, digest, hexdigest, copy) accessed via md5() and sha256(); __class__.__name__ for sha256().block_size and sha256().digest_size."
    - "No prior hashlib spec checks __qualname__ for any HASH instance method (update/digest/hexdigest/copy). Prior specs check constructor qualnames (md5.__qualname__, sha256.__qualname__) but NOT instance method qualnames."
    - "All HASH instance methods share the same qualname pattern 'HASH.<method>': 'HASH.update', 'HASH.digest', 'HASH.hexdigest', 'HASH.copy'. Both md5() and sha256() instances share this naming since they are all instances of the internal _hashlib.HASH type."
    - "sha256().block_size.__class__.__name__ == 'int': block_size is an int attribute. No prior spec checks __class__.__name__ on block_size directly. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sha256().digest_size.__class__.__name__ == 'int': digest_size is an int attribute. No prior spec checks __class__.__name__ on digest_size directly. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HASH instance method __qualname__ — via md5()
#
# No prior hashlib spec checks __qualname__ for any HASH instance method.
# hashlib_extra24 covers constructor qualnames (md5.__qualname__, sha256.__qualname__)
# but not the qualnames of methods on HASH instances.
# md5() returns a _hashlib.HASH instance; bound method qualnames use 'HASH.' prefix.
# 'HASH.update'=11, 'HASH.digest'=11, 'HASH.hexdigest'=14, 'HASH.copy'=9.
# ---------------------------------------------------------------------------

invariant hashlib_extra27.md5.update.qualname:
  description: "hashlib.md5().update.__qualname__ == 'HASH.update' — HASH instance method qualname"
  category: function_qualnames
  kind: python_call_eq
  function: md5
  args: []
  method: update.__qualname__.__eq__
  method_args: ["HASH.update"]
  expected: true

invariant hashlib_extra27.md5.digest.qualname:
  description: "hashlib.md5().digest.__qualname__ == 'HASH.digest' — HASH instance method qualname"
  category: function_qualnames
  kind: python_call_eq
  function: md5
  args: []
  method: digest.__qualname__.__eq__
  method_args: ["HASH.digest"]
  expected: true

invariant hashlib_extra27.md5.hexdigest.qualname:
  description: "hashlib.md5().hexdigest.__qualname__ == 'HASH.hexdigest' — HASH instance method qualname"
  category: function_qualnames
  kind: python_call_eq
  function: md5
  args: []
  method: hexdigest.__qualname__.__eq__
  method_args: ["HASH.hexdigest"]
  expected: true

invariant hashlib_extra27.md5.copy.qualname:
  description: "hashlib.md5().copy.__qualname__ == 'HASH.copy' — HASH instance method qualname"
  category: function_qualnames
  kind: python_call_eq
  function: md5
  args: []
  method: copy.__qualname__.__eq__
  method_args: ["HASH.copy"]
  expected: true

# ---------------------------------------------------------------------------
# HASH instance method __qualname__ — via sha256()
#
# sha256() also returns a _hashlib.HASH instance. Its method qualnames are
# identical to md5()'s because both share the same internal HASH type.
# This confirms the HASH method qualname pattern is algorithm-independent.
# ---------------------------------------------------------------------------

invariant hashlib_extra27.sha256.update.qualname:
  description: "hashlib.sha256().update.__qualname__ == 'HASH.update' — shared HASH method qualname"
  category: function_qualnames
  kind: python_call_eq
  function: sha256
  args: []
  method: update.__qualname__.__eq__
  method_args: ["HASH.update"]
  expected: true

invariant hashlib_extra27.sha256.digest.qualname:
  description: "hashlib.sha256().digest.__qualname__ == 'HASH.digest' — shared HASH method qualname"
  category: function_qualnames
  kind: python_call_eq
  function: sha256
  args: []
  method: digest.__qualname__.__eq__
  method_args: ["HASH.digest"]
  expected: true

invariant hashlib_extra27.sha256.hexdigest.qualname:
  description: "hashlib.sha256().hexdigest.__qualname__ == 'HASH.hexdigest' — shared HASH method qualname"
  category: function_qualnames
  kind: python_call_eq
  function: sha256
  args: []
  method: hexdigest.__qualname__.__eq__
  method_args: ["HASH.hexdigest"]
  expected: true

# ---------------------------------------------------------------------------
# sha256().block_size and sha256().digest_size — __class__.__name__
#
# No prior spec checks __class__.__name__ on block_size or digest_size directly.
# hashlib_extra23 checks the integer values of sha384/sha224 block_size/digest_size;
# hashlib_extra17 checks sha256 block_size value. But neither checks __class__.__name__.
# Both attributes are plain int values on HASH instances.
# ---------------------------------------------------------------------------

invariant hashlib_extra27.sha256.block_size.class_name:
  description: "hashlib.sha256().block_size.__class__.__name__ == 'int' — block_size is an int attribute"
  category: type_metadata
  kind: python_call_eq
  function: sha256
  args: []
  method: block_size.__class__.__name__.__eq__
  method_args: ["int"]
  expected: true

invariant hashlib_extra27.sha256.digest_size.class_name:
  description: "hashlib.sha256().digest_size.__class__.__name__ == 'int' — digest_size is an int attribute"
  category: type_metadata
  kind: python_call_eq
  function: sha256
  args: []
  method: digest_size.__class__.__name__.__eq__
  method_args: ["int"]
  expected: true
