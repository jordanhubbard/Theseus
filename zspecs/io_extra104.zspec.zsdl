spec: io_extra104
version: ">=3.9"
backend: python_module(io)
extends: io_extra99

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
  notes:
    - "This spec extends io_extra99.zspec.zsdl."
    - "This spec covers: io.BytesIO and io.StringIO method descriptor class names (__class__.__name__ for individual methods)."
    - "Both BytesIO and StringIO are C extension types from _io; their __init__ slot is a 'wrapper_descriptor' and all other methods are 'method_descriptor'."
    - "io.BytesIO.__init__.__class__.__name__ = 'wrapper_descriptor' — __init__ is a slot wrapper on the C type."
    - "io.BytesIO.read.__class__.__name__ = 'method_descriptor' — read is a regular C method exposed as method_descriptor."
    - "io.BytesIO.write.__class__.__name__ = 'method_descriptor' — write is a regular C method."
    - "io.BytesIO.seek.__class__.__name__ = 'method_descriptor' — seek is a regular C method."
    - "io.BytesIO.tell.__class__.__name__ = 'method_descriptor' — tell is a regular C method."
    - "io.BytesIO.getvalue.__class__.__name__ = 'method_descriptor' — getvalue is a regular C method."
    - "io.StringIO.__init__.__class__.__name__ = 'wrapper_descriptor' — __init__ is a slot wrapper, same as BytesIO."
    - "io.StringIO.read.__class__.__name__ = 'method_descriptor' — same kind as BytesIO.read."
    - "io.StringIO.write.__class__.__name__ = 'method_descriptor' — same kind as BytesIO.write."
    - "io.StringIO.getvalue.__class__.__name__ = 'method_descriptor' — same kind as BytesIO.getvalue."
    - "io.BytesIO.read.__qualname__ = 'BytesIO.read' (length 12); io.StringIO.read.__qualname__ = 'StringIO.read' (length 13)."
    - "io.BytesIO.__class__.__name__ = 'type' — BytesIO itself is an instance of the builtin type metaclass."
    - "io.StringIO.__class__.__name__ = 'type' — StringIO itself is an instance of the builtin type metaclass."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO method descriptor class names
# BytesIO is a C extension type; __init__ is a wrapper_descriptor (slot),
# while all other methods (read, write, seek, tell, getvalue, etc.) are
# method_descriptor (C methods registered via PyMethodDef).
# ---------------------------------------------------------------------------

table io_extra104.BytesIO_method_class_names:
  description: "io.BytesIO method __class__.__name__: __init__ is 'wrapper_descriptor', all regular methods are 'method_descriptor'"
  kind: python_call_eq
  category: method_class_names
  id_prefix: iomethodcls104

  columns: [id, function, args, expected, description]
  rows:
    - [bio_init_cls,     BytesIO.__init__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true,  "BytesIO.__init__ is a wrapper_descriptor (slot-based init on C type)"]
    - [bio_read_cls,     BytesIO.read.__class__.__name__.__eq__,         ["method_descriptor"],  true,  "BytesIO.read is a method_descriptor (C method via PyMethodDef)"]
    - [bio_write_cls,    BytesIO.write.__class__.__name__.__eq__,        ["method_descriptor"],  true,  "BytesIO.write is a method_descriptor (C method via PyMethodDef)"]
    - [bio_seek_cls,     BytesIO.seek.__class__.__name__.__eq__,         ["method_descriptor"],  true,  "BytesIO.seek is a method_descriptor (C method via PyMethodDef)"]
    - [bio_tell_cls,     BytesIO.tell.__class__.__name__.__eq__,         ["method_descriptor"],  true,  "BytesIO.tell is a method_descriptor (C method via PyMethodDef)"]
    - [bio_getval_cls,   BytesIO.getvalue.__class__.__name__.__eq__,     ["method_descriptor"],  true,  "BytesIO.getvalue is a method_descriptor (C method via PyMethodDef)"]
    - [bio_read_not_wd,  BytesIO.read.__class__.__name__.__eq__,         ["wrapper_descriptor"], false, "BytesIO.read is NOT a wrapper_descriptor (only __init__/slot-based methods are)"]
    - [bio_init_not_md,  BytesIO.__init__.__class__.__name__.__eq__,     ["method_descriptor"],  false, "BytesIO.__init__ is NOT a method_descriptor (it is a wrapper_descriptor slot)"]
    - [bio_readline_cls, BytesIO.readline.__class__.__name__.__eq__,     ["method_descriptor"],  true,  "BytesIO.readline is a method_descriptor (C method via PyMethodDef)"]
    - [bio_truncate_cls, BytesIO.truncate.__class__.__name__.__eq__,     ["method_descriptor"],  true,  "BytesIO.truncate is a method_descriptor (C method via PyMethodDef)"]
    - [bio_flush_cls,    BytesIO.flush.__class__.__name__.__eq__,        ["method_descriptor"],  true,  "BytesIO.flush is a method_descriptor (C method via PyMethodDef)"]
    - [bio_read1_cls,    BytesIO.read1.__class__.__name__.__eq__,        ["method_descriptor"],  true,  "BytesIO.read1 is a method_descriptor (C method for reading up to n bytes)"]

# ---------------------------------------------------------------------------
# io.StringIO method descriptor class names
# StringIO is also a C extension type; same pattern as BytesIO:
# __init__ is a wrapper_descriptor, all regular methods are method_descriptor.
# ---------------------------------------------------------------------------

table io_extra104.StringIO_method_class_names:
  description: "io.StringIO method __class__.__name__: __init__ is 'wrapper_descriptor', all regular methods are 'method_descriptor'"
  kind: python_call_eq
  category: method_class_names
  id_prefix: iomethodcls104

  columns: [id, function, args, expected, description]
  rows:
    - [sio_init_cls,     StringIO.__init__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true,  "StringIO.__init__ is a wrapper_descriptor (slot-based init on C type)"]
    - [sio_read_cls,     StringIO.read.__class__.__name__.__eq__,        ["method_descriptor"],  true,  "StringIO.read is a method_descriptor (C method via PyMethodDef)"]
    - [sio_write_cls,    StringIO.write.__class__.__name__.__eq__,       ["method_descriptor"],  true,  "StringIO.write is a method_descriptor (C method via PyMethodDef)"]
    - [sio_seek_cls,     StringIO.seek.__class__.__name__.__eq__,        ["method_descriptor"],  true,  "StringIO.seek is a method_descriptor (C method via PyMethodDef)"]
    - [sio_tell_cls,     StringIO.tell.__class__.__name__.__eq__,        ["method_descriptor"],  true,  "StringIO.tell is a method_descriptor (C method via PyMethodDef)"]
    - [sio_getval_cls,   StringIO.getvalue.__class__.__name__.__eq__,    ["method_descriptor"],  true,  "StringIO.getvalue is a method_descriptor (C method via PyMethodDef)"]
    - [sio_readline_cls, StringIO.readline.__class__.__name__.__eq__,    ["method_descriptor"],  true,  "StringIO.readline is a method_descriptor (C method via PyMethodDef)"]
    - [sio_readable_cls, StringIO.readable.__class__.__name__.__eq__,    ["method_descriptor"],  true,  "StringIO.readable is a method_descriptor (C method via PyMethodDef)"]
    - [sio_truncate_cls, StringIO.truncate.__class__.__name__.__eq__,    ["method_descriptor"],  true,  "StringIO.truncate is a method_descriptor (C method via PyMethodDef)"]

# ---------------------------------------------------------------------------
# BytesIO vs StringIO method descriptor type symmetry
# Both C types expose methods through the same descriptor mechanism.
# ---------------------------------------------------------------------------

table io_extra104.BytesIO_StringIO_symmetry:
  description: "BytesIO and StringIO share the same method descriptor pattern: __init__ is wrapper_descriptor, other methods are method_descriptor in both"
  kind: python_call_eq
  category: method_class_names
  id_prefix: iomethodcls104

  columns: [id, function, args, expected, description]
  rows:
    - [bio_read_qualname_len, BytesIO.read.__qualname__.__len__,            [], 12, "BytesIO.read.__qualname__ is 'BytesIO.read' (12 chars)"]
    - [sio_read_qualname_len, StringIO.read.__qualname__.__len__,           [], 13, "StringIO.read.__qualname__ is 'StringIO.read' (13 chars)"]
    - [bio_init_qualname_len, BytesIO.__init__.__qualname__.__len__,        [], 16, "BytesIO.__init__.__qualname__ is 'BytesIO.__init__' (16 chars)"]
    - [bio_cls_meta,          BytesIO.__class__.__name__.__eq__,            ["type"], true, "BytesIO itself is an instance of 'type' (the standard metaclass)"]
    - [sio_cls_meta,          StringIO.__class__.__name__.__eq__,           ["type"], true, "StringIO itself is an instance of 'type' (the standard metaclass)"]
    - [bio_read_name_eq,      BytesIO.read.__name__.__eq__,                 ["read"], true, "BytesIO.read.__name__ == 'read' (method_descriptor carries the bare method name)"]
    - [sio_write_name_eq,     StringIO.write.__name__.__eq__,               ["write"], true, "StringIO.write.__name__ == 'write' (method_descriptor carries the bare method name)"]
    - [bio_init_name_eq,      BytesIO.__init__.__name__.__eq__,             ["__init__"], true, "BytesIO.__init__.__name__ == '__init__' (wrapper_descriptor carries dunder name)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra104.BytesIO.init_is_wrapper_descriptor:
  description: "io.BytesIO.__init__.__class__.__name__ == 'wrapper_descriptor' (BytesIO is a C extension type; its __init__ is exposed as a wrapper_descriptor slot, not a method_descriptor)"
  category: method_class_names
  kind: python_call_eq
  function: BytesIO.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant io_extra104.BytesIO.read_is_method_descriptor:
  description: "io.BytesIO.read.__class__.__name__ == 'method_descriptor' (BytesIO.read is a C method registered via PyMethodDef, which produces a method_descriptor on the class)"
  category: method_class_names
  kind: python_call_eq
  function: BytesIO.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra104.StringIO.init_is_wrapper_descriptor:
  description: "io.StringIO.__init__.__class__.__name__ == 'wrapper_descriptor' (StringIO is a C extension type; its __init__ slot is exposed as a wrapper_descriptor, same as BytesIO)"
  category: method_class_names
  kind: python_call_eq
  function: StringIO.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant io_extra104.StringIO.getvalue_is_method_descriptor:
  description: "io.StringIO.getvalue.__class__.__name__ == 'method_descriptor' (StringIO.getvalue is a C method exposed as method_descriptor; both BytesIO and StringIO share this pattern)"
  category: method_class_names
  kind: python_call_eq
  function: StringIO.getvalue.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra104.BytesIO.read_qualname_len_12:
  description: "io.BytesIO.read.__qualname__.__len__() == 12 (the qualname 'BytesIO.read' has exactly 12 characters: 7 for 'BytesIO' + 1 for '.' + 4 for 'read')"
  category: method_class_names
  kind: python_call_eq
  function: BytesIO.read.__qualname__.__len__
  args: []
  expected: 12
