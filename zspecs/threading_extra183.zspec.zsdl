spec: threading_extra183
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading.current_thread and threading.main_thread function identity — threading.current_thread.__name__=='current_thread' (len=14); threading.current_thread.__module__=='threading'; threading.current_thread.__qualname__=='current_thread'; threading.main_thread.__name__=='main_thread' (len=11); threading.main_thread.__module__=='threading'; threading.main_thread.__qualname__=='main_thread'; threading.active_count.__name__=='active_count' (len=12); threading.active_count.__module__=='threading'."
    - "threading.current_thread.__name__ == 'current_thread' — current_thread is a Python function in Lib/threading.py that returns the Thread object corresponding to the caller's thread of control; its __name__ is 'current_thread', 14 characters. Verified with Python 3.14.3."
    - "threading.current_thread.__module__ == 'threading' — current_thread is defined in the pure-Python threading module (Lib/threading.py); its __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.current_thread.__qualname__ == 'current_thread' — current_thread is a module-level Python function (not nested), so its __qualname__ equals its __name__ 'current_thread', 14 characters. Verified with Python 3.14.3."
    - "threading.main_thread.__name__ == 'main_thread' — main_thread is a Python function in Lib/threading.py that returns the main Thread object (the thread from which the Python interpreter was started); its __name__ is 'main_thread', 11 characters. Verified with Python 3.14.3."
    - "threading.main_thread.__module__ == 'threading' — main_thread is defined in the pure-Python threading module; its __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.main_thread.__qualname__ == 'main_thread' — module-level Python function has __qualname__ == __name__ == 'main_thread'. Verified with Python 3.14.3."
    - "threading.active_count.__name__ == 'active_count' — active_count is a Python function in Lib/threading.py that returns the number of Thread objects currently alive; its __name__ is 'active_count', 12 characters. Verified with Python 3.14.3."
    - "threading.active_count.__module__ == 'threading' — active_count is defined in the pure-Python threading module; its __module__ is 'threading'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.current_thread __name__, __module__, __qualname__
#
# threading.current_thread.__name__ == 'current_thread'
# threading.current_thread.__name__.__len__() == 14
# threading.current_thread.__module__ == 'threading'
# threading.current_thread.__qualname__ == 'current_thread'
#
# threading.current_thread is a Python function in Lib/threading.py that
# returns the Thread object for the caller's thread of control. Its
# __name__ is 'current_thread' (14 chars). New to extra183.
# ---------------------------------------------------------------------------

table threading_extra183.current_thread_identity:
  description: "threading.current_thread.__name__ 'current_thread' len 14; __module__ 'threading'; __qualname__ 'current_thread' equals __name__; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: threadingcurrent183

  columns: [id, function, args, expected, description]
  rows:
    - [curthread_name_eq,
       current_thread.__name__.__eq__,
       ["current_thread"],
       true,
       "threading.current_thread.__name__.__eq__('current_thread') == True — current_thread is a Python function in Lib/threading.py returning the Thread object corresponding to the caller's thread of control; its __name__ is 'current_thread'; str.__eq__('current_thread') returns True; new to extra183"]
    - [curthread_name_len_14,
       current_thread.__name__.__len__,
       [],
       14,
       "threading.current_thread.__name__.__len__() == 14 — the name 'current_thread' has exactly 14 characters: c-u-r-r-e-n-t-_-t-h-r-e-a-d; str.__len__() returns 14; new to extra183"]
    - [curthread_module_eq,
       current_thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.current_thread.__module__.__eq__('threading') == True — current_thread is defined in the pure-Python threading module Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra183"]
    - [curthread_qualname_eq,
       current_thread.__qualname__.__eq__,
       ["current_thread"],
       true,
       "threading.current_thread.__qualname__.__eq__('current_thread') == True — current_thread is a module-level Python function (not nested or a method), so its __qualname__ equals its __name__ 'current_thread' (14 chars); str.__eq__('current_thread') returns True; new to extra183"]

# ---------------------------------------------------------------------------
# Table 2: threading.main_thread __name__, __module__, __qualname__
#
# threading.main_thread.__name__ == 'main_thread'
# threading.main_thread.__name__.__len__() == 11
# threading.main_thread.__module__ == 'threading'
# threading.main_thread.__qualname__ == 'main_thread'
#
# threading.main_thread is a Python function in Lib/threading.py that
# returns the main Thread object (the thread in which the Python
# interpreter started). Its __name__ is 'main_thread' (11 chars). New to extra183.
# ---------------------------------------------------------------------------

table threading_extra183.main_thread_identity:
  description: "threading.main_thread.__name__ 'main_thread' len 11; __module__ 'threading'; __qualname__ 'main_thread' equals __name__; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: threadingcurrent183

  columns: [id, function, args, expected, description]
  rows:
    - [mainthread_name_eq,
       main_thread.__name__.__eq__,
       ["main_thread"],
       true,
       "threading.main_thread.__name__.__eq__('main_thread') == True — main_thread is a Python function in Lib/threading.py returning the main Thread object (the thread in which the Python interpreter was started); its __name__ is 'main_thread'; str.__eq__('main_thread') returns True; new to extra183"]
    - [mainthread_name_len_11,
       main_thread.__name__.__len__,
       [],
       11,
       "threading.main_thread.__name__.__len__() == 11 — the name 'main_thread' has exactly 11 characters: m-a-i-n-_-t-h-r-e-a-d; str.__len__() returns 11; new to extra183"]
    - [mainthread_module_eq,
       main_thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.main_thread.__module__.__eq__('threading') == True — main_thread is defined in the pure-Python threading module Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra183"]
    - [mainthread_qualname_eq,
       main_thread.__qualname__.__eq__,
       ["main_thread"],
       true,
       "threading.main_thread.__qualname__.__eq__('main_thread') == True — main_thread is a module-level Python function (not nested), so its __qualname__ equals its __name__ 'main_thread' (11 chars); str.__eq__('main_thread') returns True; new to extra183"]

# ---------------------------------------------------------------------------
# Table 3: threading.active_count __name__ and __module__
#
# threading.active_count.__name__ == 'active_count'
# threading.active_count.__name__.__len__() == 12
# threading.active_count.__module__ == 'threading'
# threading.active_count.__qualname__ == 'active_count'
#
# threading.active_count is a Python function in Lib/threading.py that
# returns the number of Thread objects currently alive (same as
# len(enumerate())). Its __name__ is 'active_count' (12 chars). New to extra183.
# ---------------------------------------------------------------------------

table threading_extra183.active_count_identity:
  description: "threading.active_count.__name__ 'active_count' len 12; __module__ 'threading'; __qualname__ 'active_count' equals __name__; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: threadingcurrent183

  columns: [id, function, args, expected, description]
  rows:
    - [activecount_name_eq,
       active_count.__name__.__eq__,
       ["active_count"],
       true,
       "threading.active_count.__name__.__eq__('active_count') == True — active_count is a Python function in Lib/threading.py that returns the number of Thread objects currently alive (equivalent to len(threading.enumerate())); its __name__ is 'active_count'; str.__eq__('active_count') returns True; new to extra183"]
    - [activecount_name_len_12,
       active_count.__name__.__len__,
       [],
       12,
       "threading.active_count.__name__.__len__() == 12 — the name 'active_count' has exactly 12 characters: a-c-t-i-v-e-_-c-o-u-n-t; str.__len__() returns 12 (between main_thread=11 and current_thread=14); new to extra183"]
    - [activecount_module_eq,
       active_count.__module__.__eq__,
       ["threading"],
       true,
       "threading.active_count.__module__.__eq__('threading') == True — active_count is defined in the pure-Python threading module Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra183"]
    - [activecount_qualname_eq,
       active_count.__qualname__.__eq__,
       ["active_count"],
       true,
       "threading.active_count.__qualname__.__eq__('active_count') == True — active_count is a module-level Python function (not nested), so its __qualname__ equals its __name__ 'active_count' (12 chars); str.__eq__('active_count') returns True; new to extra183"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra183
# ---------------------------------------------------------------------------

invariant threading_extra183.current_thread_name_is_current_thread:
  description: "threading.current_thread.__name__ == 'current_thread' — Python function in Lib/threading.py returning the caller's Thread object; __name__ is 'current_thread' (14 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: current_thread.__name__.__eq__
  args: ["current_thread"]
  expected: true

invariant threading_extra183.current_thread_module_is_threading:
  description: "threading.current_thread.__module__ == 'threading' — current_thread is defined in the pure-Python threading module Lib/threading.py; its __module__ is 'threading'; new to extra183"
  category: identity
  kind: python_call_eq
  function: current_thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra183.current_thread_qualname_equals_name:
  description: "threading.current_thread.__qualname__ == 'current_thread' — module-level Python function has __qualname__ == __name__ == 'current_thread' (14 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: current_thread.__qualname__.__eq__
  args: ["current_thread"]
  expected: true

invariant threading_extra183.main_thread_name_is_main_thread:
  description: "threading.main_thread.__name__ == 'main_thread' — Python function in Lib/threading.py returning the main Thread object; __name__ is 'main_thread' (11 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: main_thread.__name__.__eq__
  args: ["main_thread"]
  expected: true

invariant threading_extra183.main_thread_module_is_threading:
  description: "threading.main_thread.__module__ == 'threading' — main_thread is defined in the pure-Python threading module Lib/threading.py; its __module__ is 'threading'; new to extra183"
  category: identity
  kind: python_call_eq
  function: main_thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra183.main_thread_qualname_equals_name:
  description: "threading.main_thread.__qualname__ == 'main_thread' — module-level Python function has __qualname__ == __name__ == 'main_thread' (11 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: main_thread.__qualname__.__eq__
  args: ["main_thread"]
  expected: true

invariant threading_extra183.active_count_name_is_active_count:
  description: "threading.active_count.__name__ == 'active_count' — Python function in Lib/threading.py returning the count of currently-alive Thread objects; __name__ is 'active_count' (12 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: active_count.__name__.__eq__
  args: ["active_count"]
  expected: true

invariant threading_extra183.active_count_module_is_threading:
  description: "threading.active_count.__module__ == 'threading' — active_count is defined in the pure-Python threading module Lib/threading.py; its __module__ is 'threading'; new to extra183"
  category: identity
  kind: python_call_eq
  function: active_count.__module__.__eq__
  args: ["threading"]
  expected: true
