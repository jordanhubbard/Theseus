spec: abc_extra243
version: ">=3.4"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/library/abc.html#abc.ABCMeta — ABCMeta metaclass"
    - "https://docs.python.org/3/library/abc.html#abc.ABC — ABC helper class"
    - "https://docs.python.org/3/library/abc.html#abc.abstractmethod — abstractmethod decorator"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py (internal implementation)"
    - "CPython source: Modules/_abc.c (C-level accelerators)"
  notes:
    - "This spec covers ABCMeta, ABC, and abstractmethod class/function identity, plus abstract method enforcement."
    - "abc.ABCMeta.__name__ == 'ABCMeta' (len=7); __module__ == 'abc' (len=3); __bases__[0].__name__ == 'type'."
    - "ABCMeta inherits from 'type' — it is itself a metaclass (a type of type)."
    - "abc.ABC.__name__ == 'ABC' (len=3); __module__ == 'abc' (len=3); __bases__[0].__name__ == 'object'."
    - "abc.abstractmethod is a plain function (not a class): type(abc.abstractmethod).__name__ == 'function'."
    - "abstractmethod.__name__ == 'abstractmethod' (len=14); __module__ == 'abc' (len=3)."
    - "Instantiating a class with an unimplemented abstractmethod raises TypeError."
    - "type(abc.ABC).__name__ == 'ABCMeta' — ABC's metaclass is ABCMeta."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta and abc.ABC class identity
#
# ABCMeta.__name__ == 'ABCMeta' (len=7)
# ABCMeta.__module__ == 'abc' (len=3)
# ABCMeta.__bases__[0].__name__ == 'type'
# ABC.__name__ == 'ABC' (len=3)
# ABC.__module__ == 'abc' (len=3)
# ABC.__bases__[0].__name__ == 'object'
# ---------------------------------------------------------------------------

table abc_extra243.abcmeta_abc_identity:
  description: "abc.ABCMeta and abc.ABC class identity — ABCMeta.__name__.__eq__('ABCMeta')==True (len=7); ABCMeta.__module__.__eq__('abc')==True (len=3); ABCMeta.__bases__[0].__name__.__eq__('type')==True (ABCMeta is a metaclass, inheriting from type); ABC.__name__.__eq__('ABC')==True (len=3); ABC.__module__.__eq__('abc')==True (len=3, same as ABCMeta); ABC.__bases__[0].__name__.__eq__('object')==True (ABC is a normal class inheriting from object); ABCMeta.__name__.__len__()==7; ABC.__name__.__len__()==3; ABC.__module__.__len__()==3; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc243id

  columns: [id, function, args, expected, description]
  rows:
    - [meta_name_eq,   ABCMeta.__name__.__eq__,                  ["ABCMeta"],  true, "abc.ABCMeta.__name__ == 'ABCMeta'; verified with Python 3.14.3"]
    - [meta_name_len,  ABCMeta.__name__.__len__,                 [],           7,    "abc.ABCMeta.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [meta_mod_eq,    ABCMeta.__module__.__eq__,                ["abc"],      true, "abc.ABCMeta.__module__ == 'abc'; verified with Python 3.14.3"]
    - [meta_mod_len,   ABCMeta.__module__.__len__,               [],           3,    "abc.ABCMeta.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [meta_base_eq,   "ABCMeta.__bases__[0].__name__.__eq__",   ["type"],     true, "abc.ABCMeta.__bases__[0].__name__ == 'type'; ABCMeta is a metaclass; verified with Python 3.14.3"]
    - [abc_name_eq,    ABC.__name__.__eq__,                      ["ABC"],      true, "abc.ABC.__name__ == 'ABC'; verified with Python 3.14.3"]
    - [abc_name_len,   ABC.__name__.__len__,                     [],           3,    "abc.ABC.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [abc_mod_eq,     ABC.__module__.__eq__,                    ["abc"],      true, "abc.ABC.__module__ == 'abc'; verified with Python 3.14.3"]
    - [abc_mod_len,    ABC.__module__.__len__,                   [],           3,    "abc.ABC.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [abc_base_eq,    "ABC.__bases__[0].__name__.__eq__",       ["object"],   true, "abc.ABC.__bases__[0].__name__ == 'object'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractmethod function identity
#
# abstractmethod.__name__ == 'abstractmethod' (len=14)
# abstractmethod.__module__ == 'abc' (len=3)
# abstractmethod.__class__.__name__ == 'function' (it is a plain function)
# ---------------------------------------------------------------------------

table abc_extra243.abstractmethod_identity:
  description: "abc.abstractmethod function identity — abstractmethod.__name__.__eq__('abstractmethod')==True (len=14); abstractmethod.__module__.__eq__('abc')==True (len=3, same module as ABCMeta and ABC); abstractmethod.__class__.__name__.__eq__('function')==True (abstractmethod is a plain function, not a class — it sets __isabstractmethod__=True on the decorated function and returns it); abstractmethod.__name__.__len__()==14; abstractmethod.__module__.__len__()==3; contrast: ABCMeta.__name__.__len__()==7 (shorter); ABC.__name__.__len__()==3 (shortest); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc243am

  columns: [id, function, args, expected, description]
  rows:
    - [am_name_eq,   abstractmethod.__name__.__eq__,           ["abstractmethod"],  true, "abc.abstractmethod.__name__ == 'abstractmethod'; verified with Python 3.14.3"]
    - [am_name_len,  abstractmethod.__name__.__len__,          [],                  14,   "abc.abstractmethod.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [am_mod_eq,    abstractmethod.__module__.__eq__,         ["abc"],             true, "abc.abstractmethod.__module__ == 'abc'; verified with Python 3.14.3"]
    - [am_mod_len,   abstractmethod.__module__.__len__,        [],                  3,    "abc.abstractmethod.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [am_cls_eq,    abstractmethod.__class__.__name__.__eq__, ["function"],        true, "abc.abstractmethod.__class__.__name__ == 'function' (plain function, not a class); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra243
# ---------------------------------------------------------------------------

invariant abc_extra243.abcmeta_wrong_bases_raises_typeerror:
  description: "abc.ABCMeta('X', 'notabases', {}) raises TypeError — ABCMeta delegates to type.__new__() for class creation; passing a str as the bases argument (second positional arg) instead of a tuple causes type.__new__() to raise TypeError('type.__new__() argument 2 must be tuple, not str'); this demonstrates that ABCMeta enforces the standard metaclass contract requiring bases to be a tuple; ABCMeta.__bases__[0].__name__ == 'type' (ABCMeta is a subclass of type); ABCMeta.__name__ == 'ABCMeta' (len=7); ABCMeta.__module__ == 'abc' (len=3); NEW in extra243: first standalone ABCMeta TypeError invariant in abc243id namespace; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: ABCMeta
  args: ["X", "notabases", {}]
  raises: TypeError

invariant abc_extra243.abcmeta_name_eq:
  description: "abc.ABCMeta.__name__.__eq__('ABCMeta') returns True — the metaclass is named 'ABCMeta' (len=7); it lives in the 'abc' module (len=3); ABCMeta.__bases__[0].__name__ == 'type' (it is a metaclass, a subclass of type); ABC.__class__.__name__ == 'ABCMeta' (ABC's metaclass is ABCMeta); ABC.__name__ == 'ABC' (len=3, shorter than ABCMeta); abstractmethod.__name__ == 'abstractmethod' (len=14, longest name in this spec); NEW in extra243: first standalone ABCMeta name equality invariant in abc243id namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra243.abcmeta_base_is_type:
  description: "abc.ABCMeta.__bases__[0].__name__.__eq__('type') returns True — ABCMeta inherits from 'type', making it a metaclass (a class whose instances are classes); this is what enables ABCMeta to intercept class creation and enforce abstract method contracts; ABC is created with ABCMeta as its metaclass so type(ABC).__name__ == 'ABCMeta'; ABCMeta.__name__ == 'ABCMeta' (len=7); ABCMeta.__module__ == 'abc' (len=3); ABC.__bases__[0].__name__ == 'object' (ABC itself inherits from object); NEW in extra243: first standalone ABCMeta base-is-type invariant; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra243.abstractmethod_module_eq:
  description: "abc.abstractmethod.__module__.__eq__('abc') returns True — abstractmethod is defined in Lib/abc.py; __module__ == 'abc' (len=3); abstractmethod is a plain function (__class__.__name__ == 'function') that sets __isabstractmethod__=True on the decorated function and returns it unchanged; abstractmethod.__name__ == 'abstractmethod' (len=14); ABCMeta.__module__ == 'abc' (same module); ABC.__module__ == 'abc' (same module); all three public abc-module members share the 'abc' module (len=3); NEW in extra243: first standalone abstractmethod module invariant; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__module__.__eq__
  args: ["abc"]
  expected: true
