# ---------------------------------------------------------------------------
# Table 3: functools.singledispatch — Python function qualname, module, doc
#
# Wave 272 theme: functools.singledispatch — single-dispatch generic function
# decorator that allows different implementations based on argument type.
#
# functools.singledispatch.__class__.__name__ == 'function'
# functools.singledispatch.__qualname__ == 'singledispatch' (len 14)
# functools.singledispatch.__module__ == 'functools' (len 9)
# len(functools.singledispatch.__doc__) == 339
# functools.singledispatch.__code__.co_argcount == 1
# len(functools.singledispatch.__code__.co_varnames) == 3
#
# singledispatch(func) transforms a function into a generic function,
# dispatching on the type of its first argument. New to extra149.
# ---------------------------------------------------------------------------

