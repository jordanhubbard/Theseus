# ---------------------------------------------------------------------------
# Table 1: functools.cmp_to_key — C builtin identity, qualname, module, doc
#
# Wave 272 theme: functools.cmp_to_key — converts a comparison function to a
# key function for use with sorted() and related functions.
#
# functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'
# functools.cmp_to_key.__qualname__ == 'cmp_to_key' (len 10)
# functools.cmp_to_key.__module__ == '_functools' (len 10)
# len(functools.cmp_to_key.__doc__) == 94
#
# cmp_to_key(mycmp) wraps a comparison function; the returned object can be
# used as a key= argument. Implemented in _functoolsmodule.c. New to extra149.
# ---------------------------------------------------------------------------

table functools_extra149.cmp_to_key_attrs:
