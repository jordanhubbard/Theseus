# ---------------------------------------------------------------------------
# Table 2: functools.WRAPPER_ASSIGNMENTS and functools.WRAPPER_UPDATES — tuples
#
# Wave 272 theme: WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES — the attribute
# name sequences used by update_wrapper and wraps.
#
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
# len(functools.WRAPPER_ASSIGNMENTS) == 6
# functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'
# len(functools.WRAPPER_UPDATES) == 1
#
# In Python 3.14, WRAPPER_ASSIGNMENTS has 6 entries (added __annotate__ and
# __type_params__ vs the older 5-entry version). New to extra149.
# ---------------------------------------------------------------------------

