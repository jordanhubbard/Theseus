spec: uuid_extra172
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid.zspec.zsdl — core UUID generation vectors."
    - "uuid_extra.zspec.zsdl through uuid_extra171.zspec.zsdl — prior extras."
  notes:
    - "This spec covers uuid.UUID class identity and uuid.uuid4() version and variant attributes."
    - "uuid.uuid4().version == 4 — UUID v4 is randomly generated; the version attribute is always 4."
    - "uuid.uuid4().variant.__class__.__name__ == 'str' — the variant attribute is a string descriptor."
    - "uuid.UUID.__name__ == 'UUID' (len=4) — the class name is 'UUID', a 4-character string."
    - "uuid.UUID.__module__ == 'uuid' — UUID is defined in the Python uuid module."
    - "uuid.UUID.__qualname__ == 'UUID' — UUID is a top-level class; qualname equals name."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — NAMESPACE_DNS is a UUID instance."
    - "uuid.NAMESPACE_DNS.version == 1 — the DNS namespace UUID is a version-1 UUID."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' — NAMESPACE_URL is a UUID instance."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: uuid.UUID class identity — __name__, __module__, __qualname__
#
# uuid.UUID.__name__     == 'UUID'  (len=4)
# uuid.UUID.__module__   == 'uuid'
# uuid.UUID.__qualname__ == 'UUID'
#
# uuid.UUID is the central class of the uuid module, representing universally
# unique identifiers. It is a top-level class defined in Lib/uuid.py.
# New to extra172.
# ---------------------------------------------------------------------------

table uuid_extra172.uuid_class_identity:
  description: "UUID.__name__=='UUID' (len=4); __module__=='uuid'; __qualname__=='UUID'; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: uuidv4172

  columns: [id, function, args, expected, description]
  rows:
    - [uuid_name_eq,
       "UUID.__name__.__eq__",
       ["UUID"],
       true,
       "uuid.UUID.__name__.__eq__('UUID') == True — UUID is the class name of the uuid.UUID class defined in Lib/uuid.py; __name__ is 'UUID'; str.__eq__('UUID') returns True; new to extra172"]
    - [uuid_name_len_4,
       "UUID.__name__.__len__",
       [],
       4,
       "uuid.UUID.__name__.__len__() == 4 — 'UUID' has 4 characters (U-U-I-D); str.__len__() returns 4; new to extra172"]
    - [uuid_module_eq,
       "UUID.__module__.__eq__",
       ["uuid"],
       true,
       "uuid.UUID.__module__.__eq__('uuid') == True — UUID is defined in Lib/uuid.py; its __module__ is 'uuid'; str.__eq__('uuid') returns True; new to extra172"]
    - [uuid_qualname_eq,
       "UUID.__qualname__.__eq__",
       ["UUID"],
       true,
       "uuid.UUID.__qualname__.__eq__('UUID') == True — UUID is a top-level class; its __qualname__ equals its __name__, which is 'UUID'; str.__eq__('UUID') returns True; new to extra172"]

# ---------------------------------------------------------------------------
# Table 2: uuid.uuid4() version and variant attributes
#
# uuid.uuid4().version == 4
# uuid.uuid4().variant is a str
#
# uuid4() generates a random (version 4) UUID. The version attribute is always
# the integer 4. The variant attribute describes the UUID layout (RFC 4122);
# it is returned as a string descriptor by the Python uuid module.
# New to extra172.
# ---------------------------------------------------------------------------

table uuid_extra172.uuid4_version_and_variant:
  description: "uuid4().version==4; uuid4().variant.__class__.__name__=='str'; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: uuidv4172

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_version_4,
       "uuid4().version.__eq__",
       [4],
       true,
       "uuid.uuid4().version.__eq__(4) == True — uuid4() generates a version-4 (random) UUID; the version attribute is the integer 4; int.__eq__(4) returns True; new to extra172"]
    - [uuid4_variant_is_str,
       "uuid4().variant.__class__.__name__.__eq__",
       ["str"],
       true,
       "uuid.uuid4().variant.__class__.__name__.__eq__('str') == True — the variant attribute of a UUID is a string describing the UUID layout (e.g. 'specified in RFC 4122'); __class__.__name__ is 'str'; new to extra172"]
    - [uuid4_version_not_1,
       "uuid4().version.__eq__",
       [1],
       false,
       "uuid.uuid4().version.__eq__(1) == False — uuid4() is a version-4 UUID, not version-1; version-1 UUIDs are time-based and generated by uuid1(); new to extra172"]
    - [uuid4_version_not_5,
       "uuid4().version.__eq__",
       [5],
       false,
       "uuid.uuid4().version.__eq__(5) == False — uuid4() is a version-4 UUID, not version-5; version-5 UUIDs are SHA-1 name-based and generated by uuid5(); new to extra172"]

# ---------------------------------------------------------------------------
# Table 3: uuid namespace constants — NAMESPACE_DNS and NAMESPACE_URL
#
# uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'
# uuid.NAMESPACE_DNS.version == 1
# uuid.NAMESPACE_URL.__class__.__name__ == 'UUID'
#
# The uuid module provides pre-defined namespace UUIDs as module-level
# constants. NAMESPACE_DNS and NAMESPACE_URL are both instances of uuid.UUID
# and have version 1 (they are fixed, well-known version-1 UUIDs defined by
# RFC 4122). New to extra172.
# ---------------------------------------------------------------------------

table uuid_extra172.namespace_constants:
  description: "NAMESPACE_DNS and NAMESPACE_URL are UUID instances; NAMESPACE_DNS.version==1; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: uuidv4172

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_class_uuid,
       "NAMESPACE_DNS.__class__.__name__.__eq__",
       ["UUID"],
       true,
       "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — NAMESPACE_DNS is a module-level constant that is an instance of uuid.UUID; __class__.__name__ is 'UUID'; new to extra172"]
    - [ns_dns_version_1,
       "NAMESPACE_DNS.version.__eq__",
       [1],
       true,
       "uuid.NAMESPACE_DNS.version.__eq__(1) == True — the DNS namespace UUID (6ba7b810-9dad-11d1-80b4-00c04fd430c8) is a fixed version-1 UUID defined in RFC 4122; new to extra172"]
    - [ns_url_class_uuid,
       "NAMESPACE_URL.__class__.__name__.__eq__",
       ["UUID"],
       true,
       "uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID') == True — NAMESPACE_URL is a module-level constant that is an instance of uuid.UUID; __class__.__name__ is 'UUID'; new to extra172"]
    - [ns_dns_class_not_int,
       "NAMESPACE_DNS.__class__.__name__.__eq__",
       ["int"],
       false,
       "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('int') == False — NAMESPACE_DNS is a UUID instance, not an int; __class__.__name__ is 'UUID', not 'int'; new to extra172"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra172
# ---------------------------------------------------------------------------

invariant uuid_extra172.uuid4_version_4:
  description: "uuid.uuid4().version == 4 — uuid4() always generates a version-4 (random) UUID; new to extra172"
  category: identity
  kind: python_call_eq
  function: uuid4().version.__eq__
  args: [4]
  expected: true

invariant uuid_extra172.uuid4_variant_is_str:
  description: "uuid.uuid4().variant.__class__.__name__ == 'str' — the variant attribute is a string descriptor; new to extra172"
  category: identity
  kind: python_call_eq
  function: uuid4().variant.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant uuid_extra172.uuid_name_eq:
  description: "uuid.UUID.__name__ == 'UUID' — the UUID class name is the 4-character string 'UUID'; new to extra172"
  category: identity
  kind: python_call_eq
  function: UUID.__name__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra172.uuid_name_len_4:
  description: "uuid.UUID.__name__.__len__() == 4 — 'UUID' has 4 characters (U-U-I-D); new to extra172"
  category: identity
  kind: python_call_eq
  function: UUID.__name__.__len__
  args: []
  expected: 4

invariant uuid_extra172.uuid_module_eq:
  description: "uuid.UUID.__module__ == 'uuid' — UUID is defined in Lib/uuid.py; new to extra172"
  category: identity
  kind: python_call_eq
  function: UUID.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra172.uuid_qualname_eq:
  description: "uuid.UUID.__qualname__ == 'UUID' — UUID is a top-level class so qualname equals name; new to extra172"
  category: identity
  kind: python_call_eq
  function: UUID.__qualname__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra172.ns_dns_class_uuid:
  description: "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — NAMESPACE_DNS is a UUID instance; new to extra172"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra172.ns_dns_version_1:
  description: "uuid.NAMESPACE_DNS.version == 1 — the DNS namespace UUID is a fixed version-1 UUID per RFC 4122; new to extra172"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_DNS.version.__eq__
  args: [1]
  expected: true

invariant uuid_extra172.ns_url_class_uuid:
  description: "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' — NAMESPACE_URL is a UUID instance; new to extra172"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_URL.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true
