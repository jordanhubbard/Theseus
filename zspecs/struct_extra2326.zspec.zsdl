spec: struct_extra2326
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2326 (_extra2326): numeric constants and fixed-size attribute checks."
    - "Covers struct.calcsize for all primitive format characters using native byte order."
    - "All sizes are for native byte order (no endian prefix), which is the default."
    - "Platform: macOS/Darwin 25.4.0, 64-bit. LP64 model: 'L' (unsigned long) is 8 bytes."
    - "struct.calcsize('B')=1, 'H'=2, 'I'=4, 'L'=8, 'Q'=8, 'f'=4, 'd'=8."
    - "struct.calcsize('c')=1, '?'=1, 'b'=1, 'h'=2, 'i'=4, 'q'=8."
    - "Note: 'L' is 8 on 64-bit macOS (LP64 ABI); this differs from 32-bit systems where it is 4."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: unsigned integer format sizes
# ---------------------------------------------------------------------------

table struct_extra2326.unsigned_int_sizes:
  description: "struct.calcsize for unsigned integer format characters (native byte order)"
  kind: python_call_eq
  category: constants
  id_prefix: st2326

  columns: [id, function, args, expected]
  rows:
    - ["st2326001", "struct.calcsize", ["B"], 1]
    - ["st2326002", "struct.calcsize", ["H"], 2]
    - ["st2326003", "struct.calcsize", ["I"], 4]
    - ["st2326004", "struct.calcsize", ["L"], 8]
    - ["st2326005", "struct.calcsize", ["Q"], 8]

# ---------------------------------------------------------------------------
# Table 2: signed integer format sizes
# ---------------------------------------------------------------------------

table struct_extra2326.signed_int_sizes:
  description: "struct.calcsize for signed integer format characters (native byte order)"
  kind: python_call_eq
  category: constants
  id_prefix: st2326

  columns: [id, function, args, expected]
  rows:
    - ["st2326006", "struct.calcsize", ["b"], 1]
    - ["st2326007", "struct.calcsize", ["h"], 2]
    - ["st2326008", "struct.calcsize", ["i"], 4]
    - ["st2326009", "struct.calcsize", ["q"], 8]

# ---------------------------------------------------------------------------
# Table 3: floating-point format sizes
# ---------------------------------------------------------------------------

table struct_extra2326.float_sizes:
  description: "struct.calcsize for floating-point format characters (native byte order)"
  kind: python_call_eq
  category: constants
  id_prefix: st2326

  columns: [id, function, args, expected]
  rows:
    - ["st2326010", "struct.calcsize", ["f"], 4]
    - ["st2326011", "struct.calcsize", ["d"], 8]

# ---------------------------------------------------------------------------
# Table 4: single-byte and boolean format sizes
# ---------------------------------------------------------------------------

table struct_extra2326.byte_and_bool_sizes:
  description: "struct.calcsize for char and bool format characters (native byte order)"
  kind: python_call_eq
  category: constants
  id_prefix: st2326

  columns: [id, function, args, expected]
  rows:
    - ["st2326012", "struct.calcsize", ["c"], 1]
    - ["st2326013", "struct.calcsize", ["?"], 1]

# ---------------------------------------------------------------------------
# Table 5: struct module identity and error class name
# ---------------------------------------------------------------------------

table struct_extra2326.pointer_sized_types:
  description: "struct.calcsize for pointer-sized and size_t format characters (64-bit macOS)"
  kind: python_call_eq
  category: constants
  id_prefix: st2326

  columns: [id, function, args, expected]
  rows:
    - ["st2326014", "struct.calcsize", ["P"], 8]
    - ["st2326015", "struct.calcsize", ["N"], 8]
    - ["st2326016", "struct.calcsize", ["n"], 8]

# ---------------------------------------------------------------------------
# Table 6: struct module identity and function names
# ---------------------------------------------------------------------------

table struct_extra2326.module_identity:
  description: "struct module __name__, error class __name__, and key function names"
  kind: python_call_eq
  category: constants
  id_prefix: st2326

  columns: [id, function, args, expected]
  rows:
    - ["st2326017", "struct.__name__",          [], "struct"]
    - ["st2326018", "struct.error.__name__",    [], "error"]
    - ["st2326019", "struct.calcsize.__name__", [], "calcsize"]
    - ["st2326020", "struct.pack.__name__",     [], "pack"]
    - ["st2326021", "struct.unpack.__name__",   [], "unpack"]
