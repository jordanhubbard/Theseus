spec: hashlib_extra239
version: ">=3.6"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "NIST FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"

provenance:
  derived_from:
    - "NIST FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra238.zspec.zsdl — covers sha512/sha384 hexdigest vectors and length contracts"
    - "hashlib_extra237.zspec.zsdl — covers sha256/md5/sha1 hexdigest vectors and hexdigest length contracts"
    - "hashlib_extra236.zspec.zsdl — covers hmac.HMAC class identity and method qualnames"
    - "hashlib_extra235.zspec.zsdl — covers HASH method qualnames and hash object .name attribute"
    - "_hashlib.zspec.zsdl — covers _hashlib C extension identity"
    - "hashlib_extra.zspec.zsdl — covers sha256 __name__/__qualname__ and algorithms_available"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.sha3_256(b'').hexdigest() == 'a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a' — NIST FIPS 202 known test vector."
    - "hashlib.sha3_512(b'').hexdigest() == 'a69f73cca23a9ac5c8b567dc185a756e97c982164fe25859e0d1dcc1475c80a615b2123af1f5f94c11e3e9402c3ac558f500199d95b6d3e301758586281dcd26' — NIST FIPS 202 known test vector."
    - "hashlib.sha3_256(b'abc').hexdigest() == '3a985da74fe225b2045c172d6bd390bd855f086e3e9d525b46bfe24511431532' — NIST FIPS 202 known test vector."
    - "hashlib.sha3_256 hexdigest length is 64 hex characters (32 bytes * 2)."
    - "hashlib.sha3_512 hexdigest length is 128 hex characters (64 bytes * 2)."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SHA3-256 known test vector contracts — hexdigest equality
#
# hashlib.sha3_256(b'').hexdigest() ==
#   'a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a'
#
# hashlib.sha3_256(b'abc').hexdigest() ==
#   '3a985da74fe225b2045c172d6bd390bd855f086e3e9d525b46bfe24511431532'
#
# These are NIST FIPS 202 known-answer test (KAT) vectors for SHA3-256.
# SHA3-256 produces a 32-byte (256-bit) digest, represented as 64 hex chars.
# Novel to hashlib_extra239: no prior hashlib spec anchors sha3_256 hexdigest.
# ---------------------------------------------------------------------------

table hashlib_extra239.sha3_256_hexdigest_vectors:
  description: "sha3_256(b'').hexdigest()==NIST empty vector; sha3_256(b'abc').hexdigest()==NIST abc vector; SHA3-256 known test vector contracts; new to hashlib_extra239"
  kind: python_call_eq
  category: hash_vectors
  id_prefix: hl239sha3_256

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_empty_hexdigest,
       "sha3_256(b'').hexdigest.__eq__",
       ["a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a"],
       true,
       "hashlib.sha3_256(b'').hexdigest().__eq__('a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a') == True — NIST FIPS 202 known test vector for SHA3-256 of empty byte string; 64 hex characters representing 32 bytes; novel sha3_256 hexdigest anchor; new to hashlib_extra239 namespace; verified Python 3.14.3"]
    - [sha3_256_abc_hexdigest,
       "sha3_256(b'abc').hexdigest.__eq__",
       ["3a985da74fe225b2045c172d6bd390bd855f086e3e9d525b46bfe24511431532"],
       true,
       "hashlib.sha3_256(b'abc').hexdigest().__eq__('3a985da74fe225b2045c172d6bd390bd855f086e3e9d525b46bfe24511431532') == True — NIST FIPS 202 known test vector for SHA3-256 of b'abc'; 64 hex characters representing 32 bytes; novel sha3_256 abc hexdigest anchor; new to hashlib_extra239 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# SHA3-512 known test vector contracts — hexdigest equality
#
# hashlib.sha3_512(b'').hexdigest() ==
#   'a69f73cca23a9ac5c8b567dc185a756e97c982164fe25859e0d1dcc1475c80a615b2123af1f5f94c11e3e9402c3ac558f500199d95b6d3e301758586281dcd26'
#
# This is the NIST FIPS 202 known-answer test (KAT) vector for SHA3-512 of the
# empty byte string. SHA3-512 produces a 64-byte (512-bit) digest, represented
# as 128 hex characters. Novel to hashlib_extra239.
# ---------------------------------------------------------------------------

table hashlib_extra239.sha3_512_hexdigest_vectors:
  description: "sha3_512(b'').hexdigest()==NIST empty vector; SHA3-512 known test vector contracts; new to hashlib_extra239"
  kind: python_call_eq
  category: hash_vectors
  id_prefix: hl239sha3_512

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_512_empty_hexdigest,
       "sha3_512(b'').hexdigest.__eq__",
       ["a69f73cca23a9ac5c8b567dc185a756e97c982164fe25859e0d1dcc1475c80a615b2123af1f5f94c11e3e9402c3ac558f500199d95b6d3e301758586281dcd26"],
       true,
       "hashlib.sha3_512(b'').hexdigest().__eq__('a69f73cca23a9ac5c8b567dc185a756e97c982164fe25859e0d1dcc1475c80a615b2123af1f5f94c11e3e9402c3ac558f500199d95b6d3e301758586281dcd26') == True — NIST FIPS 202 known test vector for SHA3-512 of empty byte string; 128 hex characters representing 64 bytes; novel sha3_512 hexdigest anchor; new to hashlib_extra239 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# SHA3-256 and SHA3-512 hexdigest length contracts
#
# sha3_256 hexdigest has 64 hex characters (digest_size=32, 32*2=64).
# sha3_512 hexdigest has 128 hex characters (digest_size=64, 64*2=128).
#
# Novel to hashlib_extra239: no prior spec anchors sha3_256/sha3_512
# hexdigest().__len__() values.
# ---------------------------------------------------------------------------

table hashlib_extra239.sha3_hexdigest_lengths:
  description: "sha3_256 hexdigest len==64; sha3_512 hexdigest len==128; SHA3 hexdigest length equals digest_size*2; new to hashlib_extra239"
  kind: python_call_eq
  category: hash_lengths
  id_prefix: hl239len

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_hexdigest_len,
       "sha3_256(b'').hexdigest().__len__",
       [],
       64,
       "hashlib.sha3_256(b'').hexdigest().__len__() == 64 — SHA3-256 digest_size is 32 bytes; hexdigest encodes as 2 hex chars per byte giving 64 characters total; novel length anchor for sha3_256 hexdigest; new to hashlib_extra239 namespace; verified Python 3.14.3"]
    - [sha3_512_hexdigest_len,
       "sha3_512(b'').hexdigest().__len__",
       [],
       128,
       "hashlib.sha3_512(b'').hexdigest().__len__() == 128 — SHA3-512 digest_size is 64 bytes; hexdigest encodes as 2 hex chars per byte giving 128 characters total; novel length anchor for sha3_512 hexdigest; new to hashlib_extra239 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra239.sha3_256_empty_hexdigest_eq:
  description: "hashlib.sha3_256(b'').hexdigest().__eq__('a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a') == True — SHA3-256 of the empty byte string is the canonical zero-content hash defined in NIST FIPS 202; the 64-character hex string represents 32 bytes (256 bits); this is a fundamental known-answer test (KAT) vector; no prior hashlib spec in the hashlib_extra* namespace anchors any sha3_256 hexdigest() output value; hashlib_extra239 is the first namespace to anchor sha3_256 empty hexdigest as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_vectors
  kind: python_call_eq
  function: "sha3_256(b'').hexdigest.__eq__"
  args: ["a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a"]
  expected: true

invariant hashlib_extra239.sha3_256_abc_hexdigest_eq:
  description: "hashlib.sha3_256(b'abc').hexdigest().__eq__('3a985da74fe225b2045c172d6bd390bd855f086e3e9d525b46bfe24511431532') == True — SHA3-256 of the byte string b'abc' is the NIST FIPS 202 known test vector for the 3-byte ASCII input; the 64-character hex string represents 32 bytes; this is a standard short-message KAT vector used to verify SHA3-256 correctness; no prior hashlib spec anchors sha3_256(b'abc') hexdigest; hashlib_extra239 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_vectors
  kind: python_call_eq
  function: "sha3_256(b'abc').hexdigest.__eq__"
  args: ["3a985da74fe225b2045c172d6bd390bd855f086e3e9d525b46bfe24511431532"]
  expected: true

invariant hashlib_extra239.sha3_512_empty_hexdigest_eq:
  description: "hashlib.sha3_512(b'').hexdigest().__eq__('a69f73cca23a9ac5c8b567dc185a756e97c982164fe25859e0d1dcc1475c80a615b2123af1f5f94c11e3e9402c3ac558f500199d95b6d3e301758586281dcd26') == True — SHA3-512 of the empty byte string is the canonical zero-content hash defined in NIST FIPS 202; the 128-character hex string represents 64 bytes (512 bits); SHA3 uses the Keccak sponge construction unlike SHA-2; no prior hashlib spec anchors any sha3_512 hexdigest() output value; hashlib_extra239 is the first namespace to anchor sha3_512 empty hexdigest as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_vectors
  kind: python_call_eq
  function: "sha3_512(b'').hexdigest.__eq__"
  args: ["a69f73cca23a9ac5c8b567dc185a756e97c982164fe25859e0d1dcc1475c80a615b2123af1f5f94c11e3e9402c3ac558f500199d95b6d3e301758586281dcd26"]
  expected: true

invariant hashlib_extra239.sha3_256_hexdigest_len_64:
  description: "hashlib.sha3_256(b'').hexdigest().__len__() == 64 — SHA3-256 always produces exactly 32 bytes of digest output; hexdigest() encodes each byte as exactly 2 lowercase hex characters, giving 64 characters total; this length is fixed for all SHA3-256 inputs regardless of input length; digest_size==32 is the source of truth; 64 == 32 * 2; no prior spec anchors sha3_256 hexdigest length; hashlib_extra239 is the first namespace to anchor this as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_lengths
  kind: python_call_eq
  function: "sha3_256(b'').hexdigest().__len__"
  args: []
  expected: 64

invariant hashlib_extra239.sha3_512_hexdigest_len_128:
  description: "hashlib.sha3_512(b'').hexdigest().__len__() == 128 — SHA3-512 always produces exactly 64 bytes of digest output; hexdigest() encodes each byte as exactly 2 lowercase hex characters, giving 128 characters total; this length is fixed for all SHA3-512 inputs regardless of input length; digest_size==64 is the source of truth; 128 == 64 * 2; no prior spec anchors sha3_512 hexdigest length; hashlib_extra239 is the first namespace to anchor this as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_lengths
  kind: python_call_eq
  function: "sha3_512(b'').hexdigest().__len__"
  args: []
  expected: 128
