spec: pstats_extra3
version: ">=3.9"
backend: python_module(pstats)

docs: https://docs.python.org/3/library/profile.html#the-stats-class

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/profile.html#the-stats-class"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "pstats.zspec.zsdl — covers Stats/__name__/__module__, FunctionProfile/__name__, StatsProfile/__name__, SortKey/__name__, Stats method names"
    - "pstats_extra.zspec.zsdl — covers Stats/__name__/__module__, FunctionProfile/__name__, StatsProfile/__name__, SortKey/__name__/__module__"
    - "pstats_extra2.zspec.zsdl — covers Stats/__bases__[0]/__name__, Stats/__qualname__, SortKey/__qualname__, SortKey member .value checks"
    - "profile_extra2.zspec.zsdl — covers SortKey member .value checks, Stats.dump_stats/__name__, Stats.add/__name__ (pstats backend)"
  notes:
    - "This spec extends pstats.zspec.zsdl, pstats_extra.zspec.zsdl, and pstats_extra2.zspec.zsdl."
    - "Focus: FunctionProfile and StatsProfile module and qualname affiliation; Stats method __qualname__ and __module__; FunctionProfile and StatsProfile base class name; SortKey member class name check."
    - "FunctionProfile.__module__ == 'pstats' — dataclass defined directly in pstats module."
    - "StatsProfile.__module__ == 'pstats' — dataclass defined directly in pstats module."
    - "FunctionProfile.__qualname__ == 'FunctionProfile' — top-level class."
    - "StatsProfile.__qualname__ == 'StatsProfile' — top-level class."
    - "FunctionProfile.__bases__[0].__name__ == 'object' — inherits directly from object."
    - "StatsProfile.__bases__[0].__name__ == 'object' — inherits directly from object."
    - "Stats.sort_stats.__module__ == 'pstats' — method defined in pstats module."
    - "Stats.print_stats.__qualname__ == 'Stats.print_stats' — method qualname includes class prefix."
    - "pstats.SortKey.CUMULATIVE is an instance of SortKey (the enum class); __class__.__name__ == 'SortKey'."
    - "SortKey is a StrEnum on Python 3.11+; each member's __class__ is SortKey itself."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# FunctionProfile — module and qualname
# pstats.zspec.zsdl and pstats_extra.zspec.zsdl cover FunctionProfile.__name__ only.
# pstats_extra2 does not cover FunctionProfile __module__ or __qualname__.
# ---------------------------------------------------------------------------

invariant pstats_extra3.FunctionProfile.module:
  description: "pstats.FunctionProfile.__module__ == 'pstats' — defined in the pstats module"
  category: classes
  kind: python_call_eq
  function: FunctionProfile.__module__.__eq__
  args: ["pstats"]
  expected: true

invariant pstats_extra3.FunctionProfile.qualname:
  description: "pstats.FunctionProfile.__qualname__ == 'FunctionProfile' — top-level class"
  category: classes
  kind: python_call_eq
  function: FunctionProfile.__qualname__.__eq__
  args: ["FunctionProfile"]
  expected: true

# ---------------------------------------------------------------------------
# StatsProfile — module and qualname
# pstats.zspec.zsdl and pstats_extra.zspec.zsdl cover StatsProfile.__name__ only.
# pstats_extra2 does not cover StatsProfile __module__ or __qualname__.
# ---------------------------------------------------------------------------

invariant pstats_extra3.StatsProfile.module:
  description: "pstats.StatsProfile.__module__ == 'pstats' — defined in the pstats module"
  category: classes
  kind: python_call_eq
  function: StatsProfile.__module__.__eq__
  args: ["pstats"]
  expected: true

invariant pstats_extra3.StatsProfile.qualname:
  description: "pstats.StatsProfile.__qualname__ == 'StatsProfile' — top-level class"
  category: classes
  kind: python_call_eq
  function: StatsProfile.__qualname__.__eq__
  args: ["StatsProfile"]
  expected: true

# ---------------------------------------------------------------------------
# FunctionProfile and StatsProfile — base class identity
# No prior pstats spec checks __bases__ for these dataclasses.
# ---------------------------------------------------------------------------

invariant pstats_extra3.FunctionProfile.base_name:
  description: "pstats.FunctionProfile.__bases__[0].__name__ == 'object' — inherits from object"
  category: hierarchy
  kind: python_call_eq
  function: FunctionProfile.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant pstats_extra3.StatsProfile.base_name:
  description: "pstats.StatsProfile.__bases__[0].__name__ == 'object' — inherits from object"
  category: hierarchy
  kind: python_call_eq
  function: StatsProfile.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Stats method __qualname__ checks
# pstats.zspec.zsdl covers Stats method __name__; no prior spec covers __qualname__.
# For instance methods, __qualname__ == 'Stats.<method_name>'.
# ---------------------------------------------------------------------------

table pstats_extra3.Stats_method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: method_qualname

  columns: [id, function, args, expected]
  rows:
    - [sort_stats,    Stats.sort_stats.__qualname__.__eq__,    ["Stats.sort_stats"],    true]
    - [print_stats,   Stats.print_stats.__qualname__.__eq__,   ["Stats.print_stats"],   true]
    - [print_callers, Stats.print_callers.__qualname__.__eq__, ["Stats.print_callers"], true]
    - [print_callees, Stats.print_callees.__qualname__.__eq__, ["Stats.print_callees"], true]
    - [strip_dirs,    Stats.strip_dirs.__qualname__.__eq__,    ["Stats.strip_dirs"],    true]

# ---------------------------------------------------------------------------
# Stats method __module__ checks
# No prior pstats spec checks method __module__ affiliation.
# ---------------------------------------------------------------------------

table pstats_extra3.Stats_method_modules:
  kind: python_call_eq
  category: method_modules
  id_prefix: method_module

  columns: [id, function, args, expected]
  rows:
    - [sort_stats,    Stats.sort_stats.__module__.__eq__,    ["pstats"], true]
    - [print_stats,   Stats.print_stats.__module__.__eq__,   ["pstats"], true]
    - [print_callers, Stats.print_callers.__module__.__eq__, ["pstats"], true]
    - [print_callees, Stats.print_callees.__module__.__eq__, ["pstats"], true]
    - [strip_dirs,    Stats.strip_dirs.__module__.__eq__,    ["pstats"], true]

# ---------------------------------------------------------------------------
# SortKey.CUMULATIVE.__class__.__name__ — enum member class identity
# Not covered in any prior pstats spec.
# pstats_extra2 checks SortKey.__qualname__ and member .value; this checks member .__class__.__name__.
# ---------------------------------------------------------------------------

invariant pstats_extra3.SortKey.CUMULATIVE_class_name:
  description: "pstats.SortKey.CUMULATIVE.__class__.__name__ == 'SortKey' — each member is an instance of SortKey"
  category: SortKey_members
  kind: python_call_eq
  function: SortKey.CUMULATIVE.__class__.__name__.__eq__
  args: ["SortKey"]
  expected: true
