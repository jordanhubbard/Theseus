spec: responses_rust
version: ">=3.9"
backend: rust_module(responses_rust)

docs: https://github.com/getsentry/responses

provenance:
  derived_from:
    - "https://github.com/getsentry/responses — responses documentation"
  not_derived_from:
    - "responses source: responses/__init__.py"
  notes:
    - "responses mocks the requests library for Python testing."
    - "responses.RequestsMock is available."
    - "responses.mock is a RequestsMock instance."
    - "responses.activate is the decorator."
    - "responses.__version__ is a non-empty string."
    - "Expose responses_has_mock() -> bool: hasattr(responses, 'mock')."
    - "Expose responses_has_activate() -> bool: hasattr(responses, 'activate')."
    - "Expose responses_version_nonempty() -> bool: len(responses.__version__) > 0."
    - "All test vectors verified against responses 0.25.7."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# responses_has_mock — mock present
invariant responses_rust.module.has_mock:
  description: "responses.mock is available"
  category: module
  kind: python_call_eq
  function: responses_has_mock
  args: []
  expected: true

# responses_has_activate — activate present
invariant responses_rust.module.has_activate:
  description: "responses.activate is available"
  category: module
  kind: python_call_eq
  function: responses_has_activate
  args: []
  expected: true

# responses_version_nonempty — version non-empty
invariant responses_rust.version.nonempty:
  description: "responses.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: responses_version_nonempty
  args: []
  expected: true

