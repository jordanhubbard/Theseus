spec: inspect_extra179
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.classify_class_attrs and related — inspect.classify_class_attrs.__name__=='classify_class_attrs' (len=20); inspect.getattr_static.__name__=='getattr_static' (len=14); inspect.getmro.__name__=='getmro' (len=6); inspect.getclasstree.__name__=='getclasstree' (len=12); inspect.getabsfile.__name__=='getabsfile' (len=10); inspect.getfile.__name__=='getfile' (len=7); inspect.getsourcefile.__name__=='getsourcefile' (len=13); inspect.getsourcelines.__name__=='getsourcelines' (len=14; same as getattr_static)."
    - "inspect.classify_class_attrs.__name__ == 'classify_class_attrs' — classify_class_attrs is a Python function in Lib/inspect.py that returns a list of (name, kind, defining_class, value) tuples for the attributes of a class; its __name__ is 'classify_class_attrs', 20 characters (the longest name among the functions in this spec). Verified with Python 3.14.3."
    - "inspect.getattr_static.__name__ == 'getattr_static' — getattr_static is a Python function in Lib/inspect.py that retrieves an attribute without triggering descriptor protocols; its __name__ is 'getattr_static', 14 characters. Verified with Python 3.14.3."
    - "inspect.getmro.__name__ == 'getmro' — getmro is a Python function in Lib/inspect.py that returns the MRO tuple for a class (same as __mro__ but as a proper API); its __name__ is 'getmro', 6 characters. Verified with Python 3.14.3."
    - "inspect.getclasstree.__name__ == 'getclasstree' — getclasstree is a Python function in Lib/inspect.py that arranges a list of classes into a hierarchy; its __name__ is 'getclasstree', 12 characters. Verified with Python 3.14.3."
    - "inspect.getabsfile.__name__ == 'getabsfile' — getabsfile is a Python function in Lib/inspect.py that returns the absolute path of the file in which an object was defined; its __name__ is 'getabsfile', 10 characters. Verified with Python 3.14.3."
    - "inspect.getfile.__name__ == 'getfile' — getfile is a Python function in Lib/inspect.py that returns the name of the Python source file in which an object was defined; its __name__ is 'getfile', 7 characters. Verified with Python 3.14.3."
    - "inspect.getsourcefile.__name__ == 'getsourcefile' — getsourcefile is a Python function in Lib/inspect.py that returns the name of the Python source file for an object; its __name__ is 'getsourcefile', 13 characters. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__name__ == 'getsourcelines' — getsourcelines is a Python function in Lib/inspect.py that returns a list of source lines and a line number for an object; its __name__ is 'getsourcelines', 14 characters, same length as 'getattr_static'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.classify_class_attrs and inspect.getattr_static __name__
#
# inspect.classify_class_attrs.__name__ == 'classify_class_attrs'
# inspect.classify_class_attrs.__name__.__len__() == 20
# inspect.getattr_static.__name__ == 'getattr_static'
# inspect.getattr_static.__name__.__len__() == 14
#
# classify_class_attrs (20 chars — longest in this spec) is a function that
# returns attribute metadata for a class. getattr_static (14 chars) retrieves
# attributes without triggering descriptor protocols. New to extra179.
# ---------------------------------------------------------------------------

table inspect_extra179.classify_class_attrs_and_getattr_static:
  description: "inspect.classify_class_attrs.__name__ 'classify_class_attrs' len 20 (longest); getattr_static.__name__ 'getattr_static' len 14; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: inspectclass179

  columns: [id, function, args, expected, description]
  rows:
    - [classify_class_attrs_name_eq,
       "classify_class_attrs.__name__.__eq__",
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__name__.__eq__('classify_class_attrs') == True — inspect.classify_class_attrs is a Python function in Lib/inspect.py that returns a list of (name, kind, defining_class, value) tuples describing the attributes defined on a class; its __name__ is 'classify_class_attrs'; str.__eq__('classify_class_attrs') returns True; new to extra179"]
    - [classify_class_attrs_name_len_20,
       "classify_class_attrs.__name__.__len__",
       [],
       20,
       "inspect.classify_class_attrs.__name__.__len__() == 20 — the name 'classify_class_attrs' has exactly 20 characters: c-l-a-s-s-i-f-y-_-c-l-a-s-s-_-a-t-t-r-s; this is the longest name among the functions covered in this spec; str.__len__() returns 20; new to extra179"]
    - [getattr_static_name_eq,
       "getattr_static.__name__.__eq__",
       ["getattr_static"],
       true,
       "inspect.getattr_static.__name__.__eq__('getattr_static') == True — inspect.getattr_static is a Python function in Lib/inspect.py that retrieves an attribute without triggering dynamic lookup via __getattr__ or descriptors; its __name__ is 'getattr_static'; str.__eq__('getattr_static') returns True; new to extra179"]
    - [getattr_static_name_len_14,
       "getattr_static.__name__.__len__",
       [],
       14,
       "inspect.getattr_static.__name__.__len__() == 14 — the name 'getattr_static' has exactly 14 characters: g-e-t-a-t-t-r-_-s-t-a-t-i-c; str.__len__() returns 14; same length as 'getsourcelines' (14); new to extra179"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getmro and inspect.getclasstree __name__
#
# inspect.getmro.__name__ == 'getmro'
# inspect.getmro.__name__.__len__() == 6
# inspect.getclasstree.__name__ == 'getclasstree'
# inspect.getclasstree.__name__.__len__() == 12
#
# getmro (6 chars) returns the MRO tuple for a class. getclasstree (12 chars)
# arranges classes into a hierarchy list. New to extra179.
# ---------------------------------------------------------------------------

table inspect_extra179.getmro_and_getclasstree:
  description: "inspect.getmro.__name__ 'getmro' len 6; getclasstree.__name__ 'getclasstree' len 12; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: inspectclass179

  columns: [id, function, args, expected, description]
  rows:
    - [getmro_name_eq,
       "getmro.__name__.__eq__",
       ["getmro"],
       true,
       "inspect.getmro.__name__.__eq__('getmro') == True — inspect.getmro is a Python function in Lib/inspect.py that returns the MRO (method resolution order) tuple for a class, equivalent to cls.__mro__ but as a documented public API; its __name__ is 'getmro'; str.__eq__('getmro') returns True; new to extra179"]
    - [getmro_name_len_6,
       "getmro.__name__.__len__",
       [],
       6,
       "inspect.getmro.__name__.__len__() == 6 — the name 'getmro' has exactly 6 characters: g-e-t-m-r-o; str.__len__() returns 6; new to extra179"]
    - [getclasstree_name_eq,
       "getclasstree.__name__.__eq__",
       ["getclasstree"],
       true,
       "inspect.getclasstree.__name__.__eq__('getclasstree') == True — inspect.getclasstree is a Python function in Lib/inspect.py that arranges a list of classes (as returned by getmembers) into a hierarchy reflecting their inheritance; its __name__ is 'getclasstree'; str.__eq__('getclasstree') returns True; new to extra179"]
    - [getclasstree_name_len_12,
       "getclasstree.__name__.__len__",
       [],
       12,
       "inspect.getclasstree.__name__.__len__() == 12 — the name 'getclasstree' has exactly 12 characters: g-e-t-c-l-a-s-s-t-r-e-e; str.__len__() returns 12; new to extra179"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getabsfile, .getfile, .getsourcefile, .getsourcelines __name__
#
# inspect.getabsfile.__name__ == 'getabsfile'    (len=10)
# inspect.getfile.__name__ == 'getfile'          (len=7)
# inspect.getsourcefile.__name__ == 'getsourcefile'  (len=13)
# inspect.getsourcelines.__name__ == 'getsourcelines'  (len=14; same as getattr_static)
#
# getabsfile (10) returns an absolute file path. getfile (7) returns the source
# filename. getsourcefile (13) returns the .py source file. getsourcelines (14
# — same length as getattr_static) returns source lines and line number.
# New to extra179.
# ---------------------------------------------------------------------------

table inspect_extra179.getfile_family_names:
  description: "inspect.getabsfile.__name__ 'getabsfile' len 10; getfile len 7; getsourcefile len 13; getsourcelines len 14 (same as getattr_static); new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: inspectclass179

  columns: [id, function, args, expected, description]
  rows:
    - [getabsfile_name_eq,
       "getabsfile.__name__.__eq__",
       ["getabsfile"],
       true,
       "inspect.getabsfile.__name__.__eq__('getabsfile') == True — inspect.getabsfile is a Python function in Lib/inspect.py that returns the absolute path of the file in which an object was defined (resolving symlinks via os.path.abspath); its __name__ is 'getabsfile'; str.__eq__('getabsfile') returns True; new to extra179"]
    - [getfile_name_eq,
       "getfile.__name__.__eq__",
       ["getfile"],
       true,
       "inspect.getfile.__name__.__eq__('getfile') == True — inspect.getfile is a Python function in Lib/inspect.py that returns the name of the Python source file in which an object was defined; raises TypeError for built-in objects; its __name__ is 'getfile'; str.__eq__('getfile') returns True; new to extra179"]
    - [getsourcefile_name_eq,
       "getsourcefile.__name__.__eq__",
       ["getsourcefile"],
       true,
       "inspect.getsourcefile.__name__.__eq__('getsourcefile') == True — inspect.getsourcefile is a Python function in Lib/inspect.py that returns the name of the Python source file (.py) for an object, or None if the source cannot be determined; its __name__ is 'getsourcefile'; str.__eq__('getsourcefile') returns True; new to extra179"]
    - [getsourcelines_name_eq,
       "getsourcelines.__name__.__eq__",
       ["getsourcelines"],
       true,
       "inspect.getsourcelines.__name__.__eq__('getsourcelines') == True — inspect.getsourcelines is a Python function in Lib/inspect.py that returns a list of source lines and the line number at which the object's definition starts; its __name__ is 'getsourcelines'; str.__eq__('getsourcelines') returns True; new to extra179"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra179
# ---------------------------------------------------------------------------

invariant inspect_extra179.classify_class_attrs_name_eq:
  description: "inspect.classify_class_attrs.__name__ == 'classify_class_attrs' — Python function in Lib/inspect.py with __name__ 'classify_class_attrs' (21 chars, longest in spec); new to extra179"
  kind: python_call_eq
  function: classify_class_attrs.__name__.__eq__
  args: ["classify_class_attrs"]
  expected: true

invariant inspect_extra179.classify_class_attrs_name_len_20:
  description: "inspect.classify_class_attrs.__name__.__len__() == 20 — 'classify_class_attrs' is 20 characters long; new to extra179"
  kind: python_call_eq
  function: classify_class_attrs.__name__.__len__
  args: []
  expected: 20

invariant inspect_extra179.getattr_static_name_eq:
  description: "inspect.getattr_static.__name__ == 'getattr_static' — Python function in Lib/inspect.py with __name__ 'getattr_static' (14 chars); new to extra179"
  kind: python_call_eq
  function: getattr_static.__name__.__eq__
  args: ["getattr_static"]
  expected: true

invariant inspect_extra179.getmro_name_len_6:
  description: "inspect.getmro.__name__.__len__() == 6 — 'getmro' is 6 characters long; new to extra179"
  kind: python_call_eq
  function: getmro.__name__.__len__
  args: []
  expected: 6

invariant inspect_extra179.getclasstree_name_eq:
  description: "inspect.getclasstree.__name__ == 'getclasstree' — Python function in Lib/inspect.py with __name__ 'getclasstree' (12 chars); new to extra179"
  kind: python_call_eq
  function: getclasstree.__name__.__eq__
  args: ["getclasstree"]
  expected: true

invariant inspect_extra179.getabsfile_name_len_10:
  description: "inspect.getabsfile.__name__.__len__() == 10 — 'getabsfile' is 10 characters long; new to extra179"
  kind: python_call_eq
  function: getabsfile.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra179.getfile_name_len_7:
  description: "inspect.getfile.__name__.__len__() == 7 — 'getfile' is 7 characters long; new to extra179"
  kind: python_call_eq
  function: getfile.__name__.__len__
  args: []
  expected: 7

invariant inspect_extra179.getsourcefile_name_len_13:
  description: "inspect.getsourcefile.__name__.__len__() == 13 — 'getsourcefile' is 13 characters long; new to extra179"
  kind: python_call_eq
  function: getsourcefile.__name__.__len__
  args: []
  expected: 13

invariant inspect_extra179.getsourcelines_name_len_14:
  description: "inspect.getsourcelines.__name__.__len__() == 14 — 'getsourcelines' is 14 characters long; same length as 'getattr_static' (14); new to extra179"
  kind: python_call_eq
  function: getsourcelines.__name__.__len__
  args: []
  expected: 14
