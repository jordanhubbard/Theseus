spec: shutil_extra20
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
    - "shutil_extra19.zspec.zsdl — covers __qualname__ equality table for copy/copy2/copytree/rmtree/move/copyfile/copystat/copymode/which/disk_usage; length invariants for copy/copy2/copytree/rmtree/disk_usage/which"
  notes:
    - "This spec extends shutil.zspec.zsdl and all prior shutil_extra specs through shutil_extra19.zspec.zsdl."
    - "Focus: __qualname__ length invariants for copyfile/copystat/copymode/move — not covered as standalone invariants in shutil_extra19."
    - "shutil.copyfile.__qualname__.__len__() == 8 — 'copyfile' has 8 characters; no prior shutil spec covers copyfile as a standalone length invariant."
    - "shutil.copystat.__qualname__.__len__() == 8 — 'copystat' has 8 characters; no prior shutil spec covers copystat as a standalone length invariant."
    - "shutil.copymode.__qualname__.__len__() == 8 — 'copymode' has 8 characters; no prior shutil spec covers copymode as a standalone length invariant."
    - "shutil.move.__qualname__.__len__() == 4 — 'move' has 4 characters; no prior shutil spec covers move as a standalone length invariant."
    - "Qualname length facts: copyfile=8, copystat=8, copymode=8, move=4."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ length table — copyfile, copystat, copymode, move
#
# shutil_extra19 provided length invariants for copy/copy2/copytree/rmtree/
# disk_usage/which but omitted copyfile, copystat, copymode, and move.
# This table fills that gap, anchoring all four in the extra20 namespace.
# The equality check (.__eq__) confirms qualname identity as a secondary axis.
# ---------------------------------------------------------------------------

table shutil_extra20.qualname_lengths:
  description: "__qualname__ length for copyfile/copystat/copymode/move — not covered in shutil_extra19"
  kind: python_call_eq
  category: function_identity
  id_prefix: qlen20

  columns: [id, function, args, expected]
  rows:
    - [copyfile, copyfile.__qualname__.__len__, [], 8]
    - [copystat, copystat.__qualname__.__len__, [], 8]
    - [copymode, copymode.__qualname__.__len__, [], 8]
    - [move,     move.__qualname__.__len__,     [], 4]

# ---------------------------------------------------------------------------
# Standalone __qualname__ length invariants
#
# Each invariant below provides a named, individually addressable check for
# the qualname length of one shutil function not yet covered in extra19.
# ---------------------------------------------------------------------------

invariant shutil_extra20.copyfile.qualname_length:
  description: "shutil.copyfile.__qualname__.__len__() == 8 — 'copyfile' has 8 characters"
  category: function_identity
  kind: python_call_eq
  function: copyfile.__qualname__.__len__
  args: []
  expected: 8

invariant shutil_extra20.copystat.qualname_length:
  description: "shutil.copystat.__qualname__.__len__() == 8 — 'copystat' has 8 characters"
  category: function_identity
  kind: python_call_eq
  function: copystat.__qualname__.__len__
  args: []
  expected: 8

invariant shutil_extra20.copymode.qualname_length:
  description: "shutil.copymode.__qualname__.__len__() == 8 — 'copymode' has 8 characters"
  category: function_identity
  kind: python_call_eq
  function: copymode.__qualname__.__len__
  args: []
  expected: 8

invariant shutil_extra20.move.qualname_length:
  description: "shutil.move.__qualname__.__len__() == 4 — 'move' has 4 characters"
  category: function_identity
  kind: python_call_eq
  function: move.__qualname__.__len__
  args: []
  expected: 4
