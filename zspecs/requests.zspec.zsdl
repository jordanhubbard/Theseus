spec: requests
version: ">=2.20"
backend: python_module(requests)

docs: https://requests.readthedocs.io/en/latest/api/

provenance:
  derived_from:
    - "requests documentation — https://requests.readthedocs.io/en/latest/api/"
    - "requests changelog — https://github.com/psf/requests/blob/main/HISTORY.md"
    - "Test vectors verified with requests 2.32.5 on Python 3.14 / macOS Darwin 25.4.0, 2026-04-08"
  not_derived_from:
    - "requests source: requests/__init__.py"
    - "requests source: requests/models.py"
    - "requests source: requests/exceptions.py"
    - "requests source: requests/status_codes.py"
    - "requests source: requests/auth.py"
  notes:
    - "All invariants are offline-safe — no actual HTTP requests are made."
    - "requests.HTTPBasicAuth is NOT exported at the top-level module; it lives in requests.auth."
    - "requests.auth must be imported explicitly; the harness imports it as a submodule."
    - "Response().ok raises TypeError when status_code is None (harness cannot test it directly)."
    - "Response().status_code == None on a freshly constructed Response with no request made."
    - "Response().is_redirect == False on a freshly constructed Response."
    - "Response().encoding == None on a freshly constructed Response."
    - "requests.codes is a LookupDict; status codes are accessible as attributes."
    - "codes.ok == 200, codes.not_found == 404, codes.internal_server_error == 500."
    - "codes.created == 201, codes.no_content == 204, codes.bad_request == 400."
    - "codes.unauthorized == 401, codes.forbidden == 403."
    - "requests.auth.HTTPBasicAuth, HTTPDigestAuth, AuthBase are accessible via the auth submodule."
  created_at: "2026-04-08T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version — __version__ contains a dot and starts with a digit
# ---------------------------------------------------------------------------

invariant requests.version.contains_dot:
  description: "__version__ contains '.' — version string is dotted (e.g. '2.32.5')"
  category: version
  kind: python_call_eq
  function: __version__.__contains__
  args: ["."]
  expected: true

invariant requests.version.starts_with_digit:
  description: "__version__[0].isdigit() — version string starts with a digit"
  category: version
  kind: python_call_eq
  function: __version__.__getitem__
  args: [0]
  method: isdigit
  expected: true

# ---------------------------------------------------------------------------
# class_names — core request/response class names
# ---------------------------------------------------------------------------

invariant requests.classes.Request_name:
  description: "Request.__name__ == 'Request'"
  category: classes
  kind: python_call_eq
  function: Request.__name__.__eq__
  args: ["Request"]
  expected: true

invariant requests.classes.Response_name:
  description: "Response.__name__ == 'Response'"
  category: classes
  kind: python_call_eq
  function: Response.__name__.__eq__
  args: ["Response"]
  expected: true

invariant requests.classes.Session_name:
  description: "Session.__name__ == 'Session'"
  category: classes
  kind: python_call_eq
  function: Session.__name__.__eq__
  args: ["Session"]
  expected: true

invariant requests.classes.PreparedRequest_name:
  description: "PreparedRequest.__name__ == 'PreparedRequest'"
  category: classes
  kind: python_call_eq
  function: PreparedRequest.__name__.__eq__
  args: ["PreparedRequest"]
  expected: true

