  args: ["ConnectTimeout"]
  expected: true

# ---------------------------------------------------------------------------
# status_codes — requests.codes.* HTTP status code constants
#
# requests.codes is a LookupDict; each attribute returns the integer code.
# Access pattern: codes.ok.__eq__(200) → True.
# ---------------------------------------------------------------------------

invariant requests.codes.ok_is_200:
  description: "codes.ok == 200 — HTTP 200 OK"
  category: codes
  kind: python_call_eq
  function: codes.ok.__eq__
  args: [200]
  expected: true

invariant requests.codes.not_found_is_404:
  description: "codes.not_found == 404 — HTTP 404 Not Found"
  category: codes
  kind: python_call_eq
  function: codes.not_found.__eq__
  args: [404]
  expected: true

invariant requests.codes.internal_server_error_is_500:
  description: "codes.internal_server_error == 500 — HTTP 500 Internal Server Error"
  category: codes
  kind: python_call_eq
  function: codes.internal_server_error.__eq__
  args: [500]
  expected: true

invariant requests.codes.created_is_201:
  description: "codes.created == 201 — HTTP 201 Created"
  category: codes
  kind: python_call_eq
  function: codes.created.__eq__
  args: [201]
  expected: true

invariant requests.codes.no_content_is_204:
  description: "codes.no_content == 204 — HTTP 204 No Content"
  category: codes
  kind: python_call_eq
  function: codes.no_content.__eq__
  args: [204]
  expected: true

invariant requests.codes.bad_request_is_400:
  description: "codes.bad_request == 400 — HTTP 400 Bad Request"
  category: codes
  kind: python_call_eq
  function: codes.bad_request.__eq__
  args: [400]
  expected: true

invariant requests.codes.unauthorized_is_401:
  description: "codes.unauthorized == 401 — HTTP 401 Unauthorized"
  category: codes
  kind: python_call_eq
  function: codes.unauthorized.__eq__
  args: [401]
  expected: true

invariant requests.codes.forbidden_is_403:
  description: "codes.forbidden == 403 — HTTP 403 Forbidden"
  category: codes
  kind: python_call_eq
  function: codes.forbidden.__eq__
  args: [403]
  expected: true

# ---------------------------------------------------------------------------
# response_defaults — Response() constructed with no request
#
# A freshly constructed Response has status_code == None, is_redirect == False,
# encoding == None.  Response().ok raises TypeError on None status_code so it
# is not testable here.
# ---------------------------------------------------------------------------

invariant requests.response.default_is_redirect_false:
  description: "Response().is_redirect == False — default response is not a redirect"
  category: response
  kind: python_call_eq
  function: Response
  args: []
  method: is_redirect
  expected: false

invariant requests.response.default_is_permanent_redirect_false:
  description: "Response().is_permanent_redirect == False — default response is not a permanent redirect"
  category: response
  kind: python_call_eq
  function: Response
  args: []
  method: is_permanent_redirect
  expected: false

# ---------------------------------------------------------------------------
# status_codes (extended) — additional HTTP status codes
# ---------------------------------------------------------------------------

invariant requests.codes.moved_permanently_is_301:
  description: "codes.moved_permanently == 301 — HTTP 301 Moved Permanently"
  category: codes
  kind: python_call_eq
  function: codes.moved_permanently.__eq__
  args: [301]
  expected: true

invariant requests.codes.accepted_is_202:
  description: "codes.accepted == 202 — HTTP 202 Accepted"
  category: codes
  kind: python_call_eq
  function: codes.accepted.__eq__
  args: [202]
  expected: true

