spec: pathlib_extra159
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path and pathlib.PurePath method __qualname__ values for key operation methods. All Path methods follow the 'Path.<method>' qualname pattern; all PurePath methods follow 'PurePath.<method>'."
    - "Path.mkdir.__qualname__ == 'Path.mkdir' (len=10). Path.exists.__qualname__ == 'Path.exists' (len=11). Path.glob.__qualname__ == 'Path.glob' (len=9). Path.iterdir.__qualname__ == 'Path.iterdir' (len=12)."
    - "PurePath.joinpath.__qualname__ == 'PurePath.joinpath' (len=17; already covered in pathlib_extra157). PurePath.with_name.__qualname__ == 'PurePath.with_name' (len=18). PurePath.with_suffix.__qualname__ == 'PurePath.with_suffix' (len=20)."
    - "pathlib.Path.__module__ == 'pathlib' — all public pathlib classes have __module__ == 'pathlib'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path operation method __qualname__ values
# Path prefix = 'Path.' = 5 chars.
# glob = 9, mkdir = 10, exists = 11, iterdir = 12.
# ---------------------------------------------------------------------------

table pathlib_extra159.Path_operation_qualnames:
  description: "pathlib.Path operation method __qualname__ values: glob=9, mkdir=10, exists=11, iterdir=12; all follow 'Path.<method>' pattern"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibmeth159

  columns: [id, function, args, expected, description]
  rows:
    - [glob_qeq,     Path.glob.__qualname__.__eq__,    ["Path.glob"],    true, "pathlib.Path.glob.__qualname__ == 'Path.glob' (len=9; 'Path.' (5) + 'glob' (4) = 9; glob() yields all matching paths under this path using glob-style patterns; one of the shortest Path method qualnames alongside cwd/stat/home/walk/open/copy/move)"]
    - [glob_qlen,    Path.glob.__qualname__.__len__,   [],               9,    "pathlib.Path.glob.__qualname__.__len__() == 9 ('Path.glob' has 9 characters; tied with stat, home, copy, move, open, walk at 9)"]
    - [mkdir_qeq,    Path.mkdir.__qualname__.__eq__,   ["Path.mkdir"],   true, "pathlib.Path.mkdir.__qualname__ == 'Path.mkdir' (len=10; 'Path.' (5) + 'mkdir' (5) = 10; mkdir() creates this directory; supports parents=True to create intermediate directories and exist_ok=True to suppress FileExistsError)"]
    - [mkdir_qlen,   Path.mkdir.__qualname__.__len__,  [],               10,   "pathlib.Path.mkdir.__qualname__.__len__() == 10 ('Path.mkdir' has 10 characters; 'Path.' (5) + 'mkdir' (5) = 10)"]
    - [exists_qeq,   Path.exists.__qualname__.__eq__,  ["Path.exists"],  true, "pathlib.Path.exists.__qualname__ == 'Path.exists' (len=11; 'Path.' (5) + 'exists' (6) = 11; exists() returns True if the path points to an existing file or directory; follows symlinks by default; tied with is_dir and is_file at 11)"]
    - [exists_qlen,  Path.exists.__qualname__.__len__, [],               11,   "pathlib.Path.exists.__qualname__.__len__() == 11 ('Path.exists' has 11 characters; 'Path.' (5) + 'exists' (6) = 11; tied with is_dir (11) and is_file (11))"]
    - [iterdir_qeq,  Path.iterdir.__qualname__.__eq__, ["Path.iterdir"], true, "pathlib.Path.iterdir.__qualname__ == 'Path.iterdir' (len=12; 'Path.' (5) + 'iterdir' (7) = 12; iterdir() yields Path objects for all files and directories in this directory; does not recurse; contrast with rglob() or walk() for recursive traversal)"]
    - [iterdir_qlen, Path.iterdir.__qualname__.__len__,[],               12,   "pathlib.Path.iterdir.__qualname__.__len__() == 12 ('Path.iterdir' has 12 characters; 'Path.' (5) + 'iterdir' (7) = 12)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath operation method __qualname__ values
# PurePath prefix = 'PurePath.' = 9 chars.
# joinpath = 17, with_name = 18, with_suffix = 20.
# ---------------------------------------------------------------------------

table pathlib_extra159.PurePath_operation_qualnames:
  description: "pathlib.PurePath operation method __qualname__ values: joinpath=17, with_name=18, with_suffix=20; also Path.__module__=='pathlib'"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibmeth159

  columns: [id, function, args, expected, description]
  rows:
    - [joinpath_qeq,    PurePath.joinpath.__qualname__.__eq__,    ["PurePath.joinpath"],    true, "pathlib.PurePath.joinpath.__qualname__ == 'PurePath.joinpath' (len=17; 'PurePath.' (9) + 'joinpath' (8) = 17; joinpath() combines the path with additional path segments; equivalent to the / operator on Path objects; also available as Path.joinpath via inheritance)"]
    - [joinpath_qlen,   PurePath.joinpath.__qualname__.__len__,   [],                       17,   "pathlib.PurePath.joinpath.__qualname__.__len__() == 17 ('PurePath.joinpath' has 17 characters; tied with PurePath.as_posix at 17)"]
    - [with_name_qeq,   PurePath.with_name.__qualname__.__eq__,   ["PurePath.with_name"],   true, "pathlib.PurePath.with_name.__qualname__ == 'PurePath.with_name' (len=18; 'PurePath.' (9) + 'with_name' (9) = 18; with_name() returns a new path with the filename component replaced; raises ValueError if the path has no name)"]
    - [with_name_qlen,  PurePath.with_name.__qualname__.__len__,  [],                       18,   "pathlib.PurePath.with_name.__qualname__.__len__() == 18 ('PurePath.with_name' has 18 characters; 'PurePath.' (9) + 'with_name' (9) = 18)"]
    - [with_suffix_qeq, PurePath.with_suffix.__qualname__.__eq__, ["PurePath.with_suffix"], true, "pathlib.PurePath.with_suffix.__qualname__ == 'PurePath.with_suffix' (len=20; 'PurePath.' (9) + 'with_suffix' (11) = 20; with_suffix() returns a new path with the file suffix replaced; pass '' to remove the suffix; tied with is_absolute and is_reserved at 20)"]
    - [with_suffix_qlen,PurePath.with_suffix.__qualname__.__len__,[],                       20,   "pathlib.PurePath.with_suffix.__qualname__.__len__() == 20 ('PurePath.with_suffix' has 20 characters; 'PurePath.' (9) + 'with_suffix' (11) = 20)"]
    - [path_module_eq,  Path.__module__.__eq__,                   ["pathlib"],              true, "pathlib.Path.__module__ == 'pathlib' (all six public pathlib classes — Path, PurePath, PosixPath, WindowsPath, PurePosixPath, PureWindowsPath — have __module__ == 'pathlib'; none point to a private C submodule because pathlib is implemented in pure Python)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra159.Path_glob_qualname_eq:
  description: "pathlib.Path.glob.__qualname__ == 'Path.glob' — Path.glob is a method for yielding all paths matching a glob pattern under this path; its qualname follows the standard 'Path.<method>' format with length 9 ('Path.' (5) + 'glob' (4) = 9); glob() is one of the most commonly used Path methods for directory scanning and file discovery"
  category: qualname
  kind: python_call_eq
  function: Path.glob.__qualname__.__eq__
  args: ["Path.glob"]
  expected: true

invariant pathlib_extra159.Path_iterdir_qualname_eq:
  description: "pathlib.Path.iterdir.__qualname__ == 'Path.iterdir' — iterdir() yields Path objects for all entries in this directory without recursion; its qualname length is 12 ('Path.' (5) + 'iterdir' (7) = 12); use Path.iterdir() for a single directory listing and Path.rglob('*') or Path.walk() for recursive traversal"
  category: qualname
  kind: python_call_eq
  function: Path.iterdir.__qualname__.__eq__
  args: ["Path.iterdir"]
  expected: true

invariant pathlib_extra159.PurePath_with_suffix_qualname_len_20:
  description: "pathlib.PurePath.with_suffix.__qualname__.__len__() == 20 — 'PurePath.with_suffix' has 20 characters ('PurePath.' (9) + 'with_suffix' (11) = 20); the longest of the three 'with_*' PurePath methods: with_name (18), with_stem (18), with_suffix (20); with_suffix() is used to change a file extension (e.g., Path('file.txt').with_suffix('.py') yields 'file.py')"
  category: qualname
  kind: python_call_eq
  function: PurePath.with_suffix.__qualname__.__len__
  args: []
  expected: 20

invariant pathlib_extra159.PurePath_with_name_qualname_len_18:
  description: "pathlib.PurePath.with_name.__qualname__.__len__() == 18 — 'PurePath.with_name' has 18 characters ('PurePath.' (9) + 'with_name' (9) = 18); with_name() replaces the final component of the path (filename including extension) with the given string; this is longer than joinpath (17) but shorter than with_suffix (20)"
  category: qualname
  kind: python_call_eq
  function: PurePath.with_name.__qualname__.__len__
  args: []
  expected: 18

invariant pathlib_extra159.Path_module_is_pathlib:
  description: "pathlib.Path.__module__ == 'pathlib' — Path is defined in the public pathlib module (pure Python) and has __module__ == 'pathlib'; unlike io's concrete classes (FileIO, BytesIO) which have __module__ == '_io' because they are implemented in a C extension, all pathlib classes are pure Python and all share __module__ == 'pathlib'"
  category: identity
  kind: python_call_eq
  function: Path.__module__.__eq__
  args: ["pathlib"]
  expected: true

