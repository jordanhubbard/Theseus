spec: gzip_extra17
version: ">=3.8"
backend: python_module(gzip)

docs: https://docs.python.org/3/library/gzip.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gzip.html — Python gzip module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gzip.py"
  notes:
    - "This spec extends gzip_extra16.zspec.zsdl."
    - "Prior specs covered: gzip.__name__/__package__, GzipFile.__name__/__module__/__qualname__, BadGzipFile.__name__/__module__, open/__name__/__module__, compress/__name__/__module__, decompress/__name__/__module__, GzipFile.__bases__[0].__name__, BadGzipFile.__bases__[0].__name__, various __qualname__ checks."
    - "This spec covers: gzip.GzipFile.__init__.__name__, gzip.BadGzipFile.__init__.__name__, gzip.open.__qualname__, gzip.compress.__qualname__, gzip.decompress.__qualname__, gzip.open.__module__.__len__(), gzip.compress.__module__.__len__(), gzip.decompress.__module__.__len__(), gzip.GzipFile.__module__.__len__(), gzip.BadGzipFile.__module__.__len__()."
    - "gzip.GzipFile.__init__.__name__ == '__init__': the constructor method name. Verified 2026-04-09."
    - "gzip.BadGzipFile.__init__.__name__ == '__init__': the constructor method name. Verified 2026-04-09."
    - "gzip.open.__qualname__ == 'open': the module-level open() function qualname. Verified 2026-04-09."
    - "gzip.compress.__qualname__ == 'compress': function qualname equals function name. Verified 2026-04-09."
    - "gzip.decompress.__qualname__ == 'decompress': function qualname equals function name. Verified 2026-04-09."
    - "gzip.open.__module__ == 'gzip' (len 4): the open function lives in the gzip module. Verified 2026-04-09."
    - "gzip.compress.__module__ == 'gzip' (len 4): compress lives in gzip. Verified 2026-04-09."
    - "gzip.decompress.__module__ == 'gzip' (len 4): decompress lives in gzip. Verified 2026-04-09."
    - "gzip.GzipFile.__module__ == 'gzip' (len 4): GzipFile is defined in gzip. Verified 2026-04-09."
    - "gzip.BadGzipFile.__module__ == 'gzip' (len 4): BadGzipFile is defined in gzip. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# GzipFile.__init__.__name__ == '__init__' — novel, extra17 anchor
#
# No prior gzip spec checks GzipFile.__init__.__name__. The constructor method
# name is '__init__'. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra17.GzipFile.init_name:
  description: "gzip.GzipFile.__init__.__name__ == '__init__' — constructor method name (extra17)"
  category: method_names
  kind: python_call_eq
  function: GzipFile.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# BadGzipFile.__init__.__name__ == '__init__' — novel, extra17 anchor
#
# No prior gzip spec checks BadGzipFile.__init__.__name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra17.BadGzipFile.init_name:
  description: "gzip.BadGzipFile.__init__.__name__ == '__init__' — constructor method name (extra17)"
  category: method_names
  kind: python_call_eq
  function: BadGzipFile.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# open.__qualname__ == 'open' — novel, extra17 anchor
#
# No prior gzip spec checks open.__qualname__ as a standalone invariant from
# the extra17 namespace. gzip.open is a module-level function; its __qualname__
# equals its __name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra17.open.qualname:
  description: "gzip.open.__qualname__ == 'open' — module-level function qualname (extra17)"
  category: qualnames
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# compress.__qualname__ == 'compress' — novel, extra17 anchor
#
# No prior gzip spec checks compress.__qualname__ from the extra17 namespace.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra17.compress.qualname:
  description: "gzip.compress.__qualname__ == 'compress' — module-level function qualname (extra17)"
  category: qualnames
  kind: python_call_eq
  function: compress.__qualname__.__eq__
  args: ["compress"]
  expected: true

# ---------------------------------------------------------------------------
# decompress.__qualname__ == 'decompress' — novel, extra17 anchor
#
# No prior gzip spec checks decompress.__qualname__ from the extra17 namespace.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra17.decompress.qualname:
  description: "gzip.decompress.__qualname__ == 'decompress' — module-level function qualname (extra17)"
  category: qualnames
  kind: python_call_eq
  function: decompress.__qualname__.__eq__
  args: ["decompress"]
  expected: true

# ---------------------------------------------------------------------------
# open.__module__.__len__() == 4 — novel, extra17 anchor
#
# gzip.open.__module__ == 'gzip' which has length 4. No prior gzip spec checks
# __module__.__len__() for the open function. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra17.open.module_len:
  description: "gzip.open.__module__.__len__() == 4 — 'gzip' module name has four characters (extra17)"
  category: module_affiliation
  kind: python_call_eq
  function: open.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# compress.__module__.__len__() == 4 — novel, extra17 anchor
#
# gzip.compress.__module__ == 'gzip' (len 4). No prior gzip spec checks this.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra17.compress.module_len:
  description: "gzip.compress.__module__.__len__() == 4 — 'gzip' module name has four characters (extra17)"
  category: module_affiliation
  kind: python_call_eq
  function: compress.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# decompress.__module__.__len__() == 4 — novel, extra17 anchor
#
# gzip.decompress.__module__ == 'gzip' (len 4). No prior gzip spec checks this.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra17.decompress.module_len:
  description: "gzip.decompress.__module__.__len__() == 4 — 'gzip' module name has four characters (extra17)"
  category: module_affiliation
  kind: python_call_eq
  function: decompress.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# GzipFile.__module__.__len__() == 4 — novel, extra17 anchor
#
# gzip.GzipFile.__module__ == 'gzip' (len 4). No prior gzip spec checks
# __module__.__len__() for GzipFile. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra17.GzipFile.module_len:
  description: "gzip.GzipFile.__module__.__len__() == 4 — 'gzip' module name has four characters (extra17)"
  category: module_affiliation
  kind: python_call_eq
  function: GzipFile.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# BadGzipFile.__module__.__len__() == 4 — novel, extra17 anchor
#
# gzip.BadGzipFile.__module__ == 'gzip' (len 4). No prior gzip spec checks
# __module__.__len__() for BadGzipFile. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra17.BadGzipFile.module_len:
  description: "gzip.BadGzipFile.__module__.__len__() == 4 — 'gzip' module name has four characters (extra17)"
  category: module_affiliation
  kind: python_call_eq
  function: BadGzipFile.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# __init__.__name__ table — GzipFile and BadGzipFile (extra17)
#
# No prior gzip spec presents __init__.__name__ checks in a table.
# This table anchors both from the extra17 namespace.
# ---------------------------------------------------------------------------

table gzip_extra17.init_names:
  kind: python_call_eq
  category: method_names
  id_prefix: init17

  columns: [id, function, args, expected]
  rows:
    - [GzipFile,    GzipFile.__init__.__name__.__eq__,    ["__init__"], true]
    - [BadGzipFile, BadGzipFile.__init__.__name__.__eq__, ["__init__"], true]

# ---------------------------------------------------------------------------
# __module__.__len__() table — open, compress, decompress, GzipFile, BadGzipFile
#                              (extra17)
#
# No prior gzip spec presents __module__.__len__() checks in a table.
# All five identifiers have module name 'gzip' (length 4). This table
# anchors all five from the extra17 namespace.
# ---------------------------------------------------------------------------

table gzip_extra17.module_lengths:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: modlen17

  columns: [id, function, args, expected]
  rows:
    - [open,        open.__module__.__len__,        [], 4]
    - [compress,    compress.__module__.__len__,    [], 4]
    - [decompress,  decompress.__module__.__len__,  [], 4]
    - [GzipFile,    GzipFile.__module__.__len__,    [], 4]
    - [BadGzipFile, BadGzipFile.__module__.__len__, [], 4]
