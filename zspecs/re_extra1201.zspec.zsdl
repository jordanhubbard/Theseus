spec: re_extra1201
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re class __bases__.__len__ checks for Pattern, Match, RegexFlag, error; __mro__.__len__ checks for Pattern, Match, RegexFlag, error"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.Pattern.__bases__.__len__, re.Match.__bases__.__len__, re.RegexFlag.__bases__.__len__, re.error.__bases__.__len__; re.Pattern.__mro__.__len__, re.Match.__mro__.__len__, re.RegexFlag.__mro__.__len__, re.error.__mro__.__len__; _extra1186 covered __bases__.__class__.__name__ (tuple) but not __bases__.__len__ integer values; _extra1171 covered __all__/__version__ but not MRO depths"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1201.bases_len_simple_classes:
  description: "re class __bases__.__len__ checks — Pattern and Match each directly inherit from object (1); error inherits from Exception (1)"
  kind: python_call_eq
  category: bases_len_simple_classes
  id_prefix: re1201bs
  columns: [id, function, args, expected]
  rows:
    - [re1201bs001, re.Pattern.__bases__.__len__,   [], 1]
    - [re1201bs002, re.Match.__bases__.__len__,     [], 1]
    - [re1201bs003, re.error.__bases__.__len__,     [], 1]
    - [re1201bs004, re.RegexFlag.__bases__.__len__, [], 1]
    - [re1201bs005, re.Pattern.__bases__.__len__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [re1201bs006, re.Match.__bases__.__len__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [re1201bs007, re.error.__bases__.__len__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [re1201bs008, re.Pattern.__bases__.__len__.__class__.__name__.__eq__,   ["function"], false]

table re_extra1201.mro_len_simple_classes:
  description: "re class __mro__.__len__ checks — Pattern and Match have depth 2; error has depth 4"
  kind: python_call_eq
  category: mro_len_simple_classes
  id_prefix: re1201ms
  columns: [id, function, args, expected]
  rows:
    - [re1201ms001, re.Pattern.__mro__.__len__, [], 2]
    - [re1201ms002, re.Match.__mro__.__len__,   [], 2]
    - [re1201ms003, re.error.__mro__.__len__,   [], 4]
    - [re1201ms004, re.Pattern.__mro__.__len__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [re1201ms005, re.Match.__mro__.__len__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [re1201ms006, re.error.__mro__.__len__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [re1201ms007, re.Pattern.__mro__.__len__.__class__.__name__.__eq__, ["function"], false]
    - [re1201ms008, re.error.__mro__.__len__.__class__.__name__.__eq__,   ["function"], false]

table re_extra1201.mro_len_regexflag:
  description: "re.RegexFlag __mro__.__len__ checks — RegexFlag has a deep MRO through IntFlag/int/ReprEnum/Flag/Enum/object"
  kind: python_call_eq
  category: mro_len_regexflag
  id_prefix: re1201rf
  columns: [id, function, args, expected]
  rows:
    - [re1201rf001, re.RegexFlag.__mro__.__len__, [], 7]
    - [re1201rf002, re.RegexFlag.__mro__.__len__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [re1201rf003, re.RegexFlag.__mro__.__len__.__class__.__name__.__eq__, ["function"], false]
    - [re1201rf004, re.RegexFlag.__mro__.__len__.__class__.__name__.__eq__, ["str"],      false]
    - [re1201rf005, re.RegexFlag.__bases__.__len__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [re1201rf006, re.RegexFlag.__bases__.__len__.__class__.__name__.__eq__, ["function"], false]
    - [re1201rf007, re.Pattern.__mro__.__len__.__class__.__name__.__eq__, ["str"],    false]
    - [re1201rf008, re.Match.__mro__.__len__.__class__.__name__.__eq__,   ["str"],    false]
