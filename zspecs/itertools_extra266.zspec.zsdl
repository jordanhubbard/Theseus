spec: itertools_extra266
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "All itertools iterators are C-level types: __class__.__name__ == 'type' for all members in this spec."
    - "All itertools types have __module__ == 'itertools' (len=9)."
    - "chain.__name__ (5) == count.__name__ (5) == cycle.__name__ (5) — tied shortest basic iterator names."
    - "combinations.__name__ (12) == permutations.__name__ (12) — tied longest names in spec."
    - "takewhile.__name__ (9) == dropwhile.__name__ (9) — equal lengths."
    - "For all types, __qualname__ == __name__ (module-level, no nesting)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Basic itertools types identity: chain, count, repeat, cycle, islice, starmap
#
# All are C-level types with __module__ == 'itertools'.
# chain, count, cycle: names all have length 5 (tied shortest).
# islice name len=6; repeat name len=6 (tied).
# starmap name len=7.
# ---------------------------------------------------------------------------

table itertools_extra266.basic_iterators_identity:
  description: "itertools chain(5), count(5), repeat(6), cycle(5), islice(6), starmap(7) identity — all C-level types(4) in itertools(9); chain/count/cycle names(5) tied shortest; starmap(7) longest in this table; all qualnames equal names; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex266b

  columns: [id, function, args, expected, description]
  rows:
    - [ch_name_eq,       chain.__name__.__eq__,                      ["chain"],                      true, "itertools.chain.__name__ == 'chain'; verified with Python 3.14.3"]
    - [ch_name_len,      chain.__name__.__len__,                     [],                             5,    "itertools.chain.__name__.__len__() == 5 — tied shortest with count and cycle; verified with Python 3.14.3"]
    - [ch_qn_eq,         chain.__qualname__.__eq__,                  ["chain"],                      true, "itertools.chain.__qualname__ == 'chain' — qualname equals name; verified with Python 3.14.3"]
    - [ch_mod_eq,        chain.__module__.__eq__,                    ["itertools"],                  true, "itertools.chain.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [ch_cls_eq,        chain.__class__.__name__.__eq__,            ["type"],                       true, "itertools.chain.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]
    - [ct_name_eq,       count.__name__.__eq__,                      ["count"],                      true, "itertools.count.__name__ == 'count'; verified with Python 3.14.3"]
    - [ct_name_len,      count.__name__.__len__,                     [],                             5,    "itertools.count.__name__.__len__() == 5 — tied shortest with chain and cycle; verified with Python 3.14.3"]
    - [ct_qn_eq,         count.__qualname__.__eq__,                  ["count"],                      true, "itertools.count.__qualname__ == 'count' — qualname equals name; verified with Python 3.14.3"]
    - [ct_mod_eq,        count.__module__.__eq__,                    ["itertools"],                  true, "itertools.count.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [ct_cls_eq,        count.__class__.__name__.__eq__,            ["type"],                       true, "itertools.count.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]
    - [rp_name_eq,       repeat.__name__.__eq__,                     ["repeat"],                     true, "itertools.repeat.__name__ == 'repeat'; verified with Python 3.14.3"]
    - [rp_name_len,      repeat.__name__.__len__,                    [],                             6,    "itertools.repeat.__name__.__len__() == 6 — tied with islice; verified with Python 3.14.3"]
    - [rp_mod_eq,        repeat.__module__.__eq__,                   ["itertools"],                  true, "itertools.repeat.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [rp_cls_eq,        repeat.__class__.__name__.__eq__,           ["type"],                       true, "itertools.repeat.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]
    - [cy_name_eq,       cycle.__name__.__eq__,                      ["cycle"],                      true, "itertools.cycle.__name__ == 'cycle'; verified with Python 3.14.3"]
    - [cy_name_len,      cycle.__name__.__len__,                     [],                             5,    "itertools.cycle.__name__.__len__() == 5 — tied shortest with chain and count; verified with Python 3.14.3"]
    - [cy_mod_eq,        cycle.__module__.__eq__,                    ["itertools"],                  true, "itertools.cycle.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [cy_cls_eq,        cycle.__class__.__name__.__eq__,            ["type"],                       true, "itertools.cycle.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]
    - [is_name_eq,       islice.__name__.__eq__,                     ["islice"],                     true, "itertools.islice.__name__ == 'islice'; verified with Python 3.14.3"]
    - [is_name_len,      islice.__name__.__len__,                    [],                             6,    "itertools.islice.__name__.__len__() == 6 — tied with repeat; verified with Python 3.14.3"]
    - [is_mod_eq,        islice.__module__.__eq__,                   ["itertools"],                  true, "itertools.islice.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [is_cls_eq,        islice.__class__.__name__.__eq__,           ["type"],                       true, "itertools.islice.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]
    - [sm_name_eq,       starmap.__name__.__eq__,                    ["starmap"],                    true, "itertools.starmap.__name__ == 'starmap'; verified with Python 3.14.3"]
    - [sm_name_len,      starmap.__name__.__len__,                   [],                             7,    "itertools.starmap.__name__.__len__() == 7 — longest in this table; verified with Python 3.14.3"]
    - [sm_mod_eq,        starmap.__module__.__eq__,                  ["itertools"],                  true, "itertools.starmap.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [sm_cls_eq,        starmap.__class__.__name__.__eq__,          ["type"],                       true, "itertools.starmap.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Combinatoric iterators identity: product, combinations, permutations,
# takewhile, dropwhile
#
# product name len=7; combinations name len=12 (tied longest with permutations).
# takewhile len=9 == dropwhile len=9 (tied).
# ---------------------------------------------------------------------------

table itertools_extra266.combinatoric_iterators_identity:
  description: "itertools product(7), combinations(12), permutations(12), takewhile(9), dropwhile(9) identity — all C-level types in itertools(9); combinations and permutations names(12) tied longest in spec; takewhile and dropwhile names(9) tied; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex266c

  columns: [id, function, args, expected, description]
  rows:
    - [pr_name_eq,       product.__name__.__eq__,                    ["product"],                    true, "itertools.product.__name__ == 'product'; verified with Python 3.14.3"]
    - [pr_name_len,      product.__name__.__len__,                   [],                             7,    "itertools.product.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [pr_qn_eq,         product.__qualname__.__eq__,                ["product"],                    true, "itertools.product.__qualname__ == 'product' — qualname equals name; verified with Python 3.14.3"]
    - [pr_mod_eq,        product.__module__.__eq__,                  ["itertools"],                  true, "itertools.product.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [pr_cls_eq,        product.__class__.__name__.__eq__,          ["type"],                       true, "itertools.product.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]
    - [cb_name_eq,       combinations.__name__.__eq__,               ["combinations"],               true, "itertools.combinations.__name__ == 'combinations'; verified with Python 3.14.3"]
    - [cb_name_len,      combinations.__name__.__len__,              [],                             12,   "itertools.combinations.__name__.__len__() == 12 — tied longest with permutations; verified with Python 3.14.3"]
    - [cb_qn_eq,         combinations.__qualname__.__eq__,           ["combinations"],               true, "itertools.combinations.__qualname__ == 'combinations' — qualname equals name; verified with Python 3.14.3"]
    - [cb_mod_eq,        combinations.__module__.__eq__,             ["itertools"],                  true, "itertools.combinations.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [cb_cls_eq,        combinations.__class__.__name__.__eq__,     ["type"],                       true, "itertools.combinations.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]
    - [pm_name_eq,       permutations.__name__.__eq__,               ["permutations"],               true, "itertools.permutations.__name__ == 'permutations'; verified with Python 3.14.3"]
    - [pm_name_len,      permutations.__name__.__len__,              [],                             12,   "itertools.permutations.__name__.__len__() == 12 — tied longest with combinations; verified with Python 3.14.3"]
    - [pm_qn_eq,         permutations.__qualname__.__eq__,           ["permutations"],               true, "itertools.permutations.__qualname__ == 'permutations' — qualname equals name; verified with Python 3.14.3"]
    - [pm_mod_eq,        permutations.__module__.__eq__,             ["itertools"],                  true, "itertools.permutations.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [pm_cls_eq,        permutations.__class__.__name__.__eq__,     ["type"],                       true, "itertools.permutations.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]
    - [tw_name_eq,       takewhile.__name__.__eq__,                  ["takewhile"],                  true, "itertools.takewhile.__name__ == 'takewhile'; verified with Python 3.14.3"]
    - [tw_name_len,      takewhile.__name__.__len__,                 [],                             9,    "itertools.takewhile.__name__.__len__() == 9 — tied with dropwhile; verified with Python 3.14.3"]
    - [tw_mod_eq,        takewhile.__module__.__eq__,                ["itertools"],                  true, "itertools.takewhile.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [tw_cls_eq,        takewhile.__class__.__name__.__eq__,        ["type"],                       true, "itertools.takewhile.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]
    - [dw_name_eq,       dropwhile.__name__.__eq__,                  ["dropwhile"],                  true, "itertools.dropwhile.__name__ == 'dropwhile'; verified with Python 3.14.3"]
    - [dw_name_len,      dropwhile.__name__.__len__,                 [],                             9,    "itertools.dropwhile.__name__.__len__() == 9 — tied with takewhile; verified with Python 3.14.3"]
    - [dw_mod_eq,        dropwhile.__module__.__eq__,                ["itertools"],                  true, "itertools.dropwhile.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [dw_cls_eq,        dropwhile.__class__.__name__.__eq__,        ["type"],                       true, "itertools.dropwhile.__class__.__name__ == 'type' — C-level type; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra266
# ---------------------------------------------------------------------------

invariant itertools_extra266.chain_module_is_itertools:
  description: "itertools.chain.__module__ == 'itertools' (len=9) — all itertools types share this module; chain name len=5 is tied shortest with count and cycle"
  category: identity
  kind: python_call_eq
  function: chain.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra266.combinations_name_len_equals_permutations:
  description: "itertools.combinations.__name__.__len__() == 12 == itertools.permutations.__name__.__len__() — both are length 12, longest names in spec"
  category: identity
  kind: python_call_eq
  function: combinations.__name__.__len__
  args: []
  expected: 12

invariant itertools_extra266.all_classes_are_type:
  description: "itertools.chain.__class__.__name__ == 'type' — all itertools iterators are C-level types, not Python functions; this is true for chain, count, repeat, cycle, islice, starmap, product, combinations, permutations, takewhile, dropwhile"
  category: identity
  kind: python_call_eq
  function: chain.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra266.takewhile_name_len_equals_dropwhile:
  description: "itertools.takewhile.__name__.__len__() == 9 == itertools.dropwhile.__name__.__len__() — both are length 9, same as itertools module name length"
  category: identity
  kind: python_call_eq
  function: takewhile.__name__.__len__
  args: []
  expected: 9

invariant itertools_extra266.product_qualname_equals_name:
  description: "itertools.product.__qualname__ == 'product' — module-level class; qualname equals name for all itertools types (no nesting)"
  category: identity
  kind: python_call_eq
  function: product.__qualname__.__eq__
  args: ["product"]
  expected: true
