spec: pathlib_extra229
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib class __class__.__name__ type and MRO contracts for Path, PurePath, PosixPath, PurePosixPath."
    - "pathlib.Path.__class__.__name__ == 'type'; verified with Python 3.14.3."
    - "pathlib.PurePath.__class__.__name__ == 'type'; verified with Python 3.14.3."
    - "pathlib.PosixPath.__class__.__name__ == 'type'; verified with Python 3.14.3."
    - "pathlib.Path.__mro__.__len__() == 3: [Path, PurePath, object]; verified with Python 3.14.3."
    - "pathlib.PurePosixPath.__mro__.__len__() == 3: [PurePosixPath, PurePath, object]; verified with Python 3.14.3."
    - "pathlib.PurePath.__mro__.__len__() == 2: [PurePath, object]; verified with Python 3.14.3."
    - "pathlib.Path.__mro__[0].__name__ == 'Path'; verified with Python 3.14.3."
    - "pathlib.PosixPath.__mro__[0].__name__ == 'PosixPath'; verified with Python 3.14.3."
    - "pathlib.PurePath.__mro__[0].__name__ == 'PurePath'; verified with Python 3.14.3."
    - "pathlib.PurePath.__mro__[1].__name__ == 'object'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib class __class__.__name__ values
# Path, PurePath, PosixPath are all plain classes (metaclass == type).
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table pathlib_extra229.class_type_names:
  description: "pathlib class __class__.__name__ contracts for Path, PurePath, PosixPath; all are plain classes with metaclass type; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_metadata
  id_prefix: plclstypename229

  columns: [id, function, args, expected]
  rows:
    - [path_classname,      Path.__class__.__name__.__eq__,      ["type"], true]
    - [purepath_classname,  PurePath.__class__.__name__.__eq__,  ["type"], true]
    - [posixpath_classname, PosixPath.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# pathlib class __mro__ length contracts
# Path and PurePosixPath have depth-3 MROs; PurePath has depth-2 MRO.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table pathlib_extra229.mro_lengths:
  description: "pathlib class __mro__ length contracts for Path (3), PurePosixPath (3), PurePath (2); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_metadata
  id_prefix: plmrolen229

  columns: [id, function, args, expected]
  rows:
    - [path_mro_len,          Path.__mro__.__len__,          [], 3]
    - [pureposixpath_mro_len, PurePosixPath.__mro__.__len__, [], 3]
    - [purepath_mro_len,      PurePath.__mro__.__len__,      [], 2]

# ---------------------------------------------------------------------------
# Standalone invariants for MRO element names
# Functions with [ in path must be double-quoted.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

invariant pathlib_extra229.Path.class_type:
  description: "pathlib.Path.__class__.__name__ == 'type' — Path is a plain class with metaclass type; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: Path.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant pathlib_extra229.PurePath.mro_len:
  description: "pathlib.PurePath.__mro__.__len__() == 2: PurePath -> object; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: PurePath.__mro__.__len__
  args: []
  expected: 2

invariant pathlib_extra229.Path.mro_len:
  description: "pathlib.Path.__mro__.__len__() == 3: Path -> PurePath -> object; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: Path.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra229.Path.mro0_name:
  description: "pathlib.Path.__mro__[0].__name__ == 'Path' — first element of MRO is the class itself; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: "Path.__mro__[0].__name__.__eq__"
  args: ["Path"]
  expected: true

invariant pathlib_extra229.PosixPath.mro0_name:
  description: "pathlib.PosixPath.__mro__[0].__name__ == 'PosixPath' — first element of MRO is the class itself; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: "PosixPath.__mro__[0].__name__.__eq__"
  args: ["PosixPath"]
  expected: true

invariant pathlib_extra229.PurePath.mro0_name:
  description: "pathlib.PurePath.__mro__[0].__name__ == 'PurePath' — first element of MRO is the class itself; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: "PurePath.__mro__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra229.PurePath.mro1_name:
  description: "pathlib.PurePath.__mro__[1].__name__ == 'object' — PurePath directly extends object; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: "PurePath.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true
