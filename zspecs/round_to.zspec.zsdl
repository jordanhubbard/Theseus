spec: round_to
version: ">=7.0.0"
backend: node(round-to)

docs: https://www.npmjs.com/package/round-to

provenance:
  derived_from:
    - "round-to README — https://www.npmjs.com/package/round-to"
    - "Test vectors verified with round-to via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "round-to source"
  notes:
    - "round-to is an npm package. Install: npm install round-to"
    - "Rounds a number to a given number of decimal places."
    - "roundTo: round half away from zero. roundToDown: floor to decimals. roundToUp: ceil to decimals."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table round_to.roundTo:
  kind: node_module_call_eq
  function: roundTo
  category: math
  id_prefix: rndto

  columns: [id, args, expected]
  rows:
    - [two_dec,   [1.234, 2],  1.23]
    - [one_dec,   [1.25, 1],   1.3]
    - [zero_dec,  [1.7, 0],    2]

table round_to.roundToDown:
  kind: node_module_call_eq
  function: roundToDown
  category: math
  id_prefix: rndtod

  columns: [id, args, expected]
  rows:
    - [two_dec,   [1.235, 2],  1.23]
    - [one_dec,   [1.29, 1],   1.2]
    - [zero_dec,  [1.9, 0],    1]

table round_to.roundToUp:
  kind: node_module_call_eq
  function: roundToUp
  category: math
  id_prefix: rndtou

  columns: [id, args, expected]
  rows:
    - [two_dec,   [1.234, 2],  1.24]
    - [one_dec,   [1.21, 1],   1.3]
    - [zero_dec,  [1.1, 0],    2]

