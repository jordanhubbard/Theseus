spec: io_extra185
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers: io.BufferedRandom class identity — __name__, __module__, __mro__ length, __bases__[0].__name__; io.BytesIO class identity — __name__, __mro__ length; io.StringIO class identity — __name__, __mro__ length."
    - "io.BufferedRandom.__name__ == 'BufferedRandom' (len=14); io.BufferedRandom.__module__ == 'io'."
    - "io.BufferedRandom.__mro__.__len__() == 4 — MRO: (BufferedRandom, BufferedIOBase, IOBase, object)."
    - "io.BufferedRandom.__bases__[0].__name__ == 'BufferedIOBase' — BufferedRandom directly inherits from BufferedIOBase."
    - "io.BytesIO.__name__ == 'BytesIO' (len=7); io.BytesIO.__mro__.__len__() == 4 — MRO: (BytesIO, BufferedIOBase, IOBase, object)."
    - "io.StringIO.__name__ == 'StringIO' (len=8); io.StringIO.__mro__.__len__() == 4 — MRO: (StringIO, TextIOBase, IOBase, object)."
    - "Name length groupings: BytesIO (7) < StringIO (8) < BufferedRandom (14): a strict ordering."
    - "BytesIO (7) < StringIO (8): difference of 1 character; StringIO (8) < BufferedRandom (14): difference of 6 characters."
    - "All three classes share MRO length == 4: a 3-way tie at MRO depth 4."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.BufferedRandom class identity
# __name__=='BufferedRandom' (len=14); __module__=='io'; __mro__.__len__()==4
# ---------------------------------------------------------------------------

table io_extra185.bufferedrandom_class_identity:
  description: "io.BufferedRandom class identity: __name__=='BufferedRandom' (len=14); __module__=='io'; __mro__.__len__()==4 (BufferedRandom > BufferedIOBase > IOBase > object); confirmed Python 3.14.3 macOS"
  kind: python_call_eq
  category: identity
  id_prefix: iobuffered185

  columns: [id, function, args, expected, description]
  rows:
    - [br_name,       BufferedRandom.__name__.__eq__,          ["BufferedRandom"], true, "io.BufferedRandom.__name__ == 'BufferedRandom' — BufferedRandom is a buffered I/O implementation allowing both read and write; 'BufferedRandom' has 14 characters: B(1)u(2)f(3)f(4)e(5)r(6)e(7)d(8)R(9)a(10)n(11)d(12)o(13)m(14); BufferedRandom (14) > StringIO (8) > BytesIO (6): the longest of the three class names covered; confirmed Python 3.14.3 macOS"]
    - [br_name_len,   BufferedRandom.__name__.__len__,         [],                 14,   "io.BufferedRandom.__name__.__len__() == 14 — 'BufferedRandom' has 14 characters; BytesIO (6) < StringIO (8) < BufferedRandom (14): BufferedRandom is the longest covered class name; StringIO (8) < BufferedRandom (14): difference of 6 characters; confirmed Python 3.14.3 macOS"]
    - [br_module,     BufferedRandom.__module__.__eq__,        ["io"],             true, "io.BufferedRandom.__module__ == 'io' — BufferedRandom is defined in the io module (backed by the _io C extension); __module__ reports 'io' as the public module name; confirmed Python 3.14.3 macOS"]
    - [br_mro_len,    BufferedRandom.__mro__.__len__,          [],                 4,    "io.BufferedRandom.__mro__.__len__() == 4 — the MRO is (BufferedRandom, BufferedIOBase, IOBase, object): 4 classes; all three covered classes share MRO length 4 — a 3-way tie; confirmed Python 3.14.3 macOS"]
    - [br_base0_name, "BufferedRandom.__bases__[0].__name__.__eq__", ["BufferedIOBase"], true, "io.BufferedRandom.__bases__[0].__name__ == 'BufferedIOBase' — BufferedRandom directly inherits from BufferedIOBase; __bases__[0] is the first and only direct base; 'BufferedIOBase' has 14 characters: same length as 'BufferedRandom'; confirmed Python 3.14.3 macOS"]
    - [br_base0_len,  "BufferedRandom.__bases__[0].__name__.__len__", [],          14,   "io.BufferedRandom.__bases__[0].__name__.__len__() == 14 — 'BufferedIOBase' has 14 characters: B(1)u(2)f(3)f(4)e(5)r(6)e(7)d(8)I(9)O(10)B(11)a(12)s(13)e(14); BufferedIOBase (14) == BufferedRandom (14): the base class name and the subclass name share the same length; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.BytesIO class identity
# __name__=='BytesIO' (len=6); __mro__.__len__()==4 (BytesIO > BufferedIOBase > IOBase > object)
# ---------------------------------------------------------------------------

table io_extra185.bytesio_class_identity:
  description: "io.BytesIO class identity: __name__=='BytesIO' (len=7); __module__=='io'; __mro__.__len__()==4 (BytesIO > BufferedIOBase > IOBase > object); BytesIO (7) < StringIO (8) < BufferedRandom (14)"
  kind: python_call_eq
  category: identity
  id_prefix: iobuffered185

  columns: [id, function, args, expected, description]
  rows:
    - [bio_name,       BytesIO.__name__.__eq__,          ["BytesIO"], true, "io.BytesIO.__name__ == 'BytesIO' — BytesIO is an in-memory binary stream; 'BytesIO' has 7 characters: B(1)y(2)t(3)e(4)s(5)I(6)O(7); BytesIO (7) < StringIO (8) < BufferedRandom (14): BytesIO has the shortest class name covered; confirmed Python 3.14.3 macOS"]
    - [bio_name_len,   BytesIO.__name__.__len__,         [],          7,    "io.BytesIO.__name__.__len__() == 7 — 'BytesIO' has 7 characters: B(1)y(2)t(3)e(4)s(5)I(6)O(7); BytesIO (7) < StringIO (8) < BufferedRandom (14): BytesIO has the shortest class name among the three covered; confirmed Python 3.14.3 macOS"]
    - [bio_module,     BytesIO.__module__.__eq__,        ["io"],      true, "io.BytesIO.__module__ == 'io' — BytesIO is defined in the io module; __module__ reports 'io'; all three covered classes share '__module__ == io'; confirmed Python 3.14.3 macOS"]
    - [bio_mro_len,    BytesIO.__mro__.__len__,          [],          4,    "io.BytesIO.__mro__.__len__() == 4 — the MRO is (BytesIO, BufferedIOBase, IOBase, object): 4 classes; BytesIO==StringIO==BufferedRandom (4): all three covered classes share MRO length 4; confirmed Python 3.14.3 macOS"]
    - [bio_base0_name, "BytesIO.__bases__[0].__name__.__eq__", ["BufferedIOBase"], true, "io.BytesIO.__bases__[0].__name__ == 'BufferedIOBase' — BytesIO directly inherits from BufferedIOBase; BytesIO and BufferedRandom share the same direct base class, BufferedIOBase; confirmed Python 3.14.3 macOS"]
    - [bio_mro1_name,  "BytesIO.__mro__[1].__name__.__eq__", ["BufferedIOBase"],  true, "io.BytesIO.__mro__[1].__name__ == 'BufferedIOBase' — the second MRO entry (index 1) for BytesIO is BufferedIOBase; MRO: (BytesIO[0], BufferedIOBase[1], IOBase[2], object[3]); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io.StringIO class identity
# __name__=='StringIO' (len=8); __mro__.__len__()==4 (StringIO > TextIOBase > IOBase > object)
# ---------------------------------------------------------------------------

table io_extra185.stringio_class_identity:
  description: "io.StringIO class identity: __name__=='StringIO' (len=8); __module__=='io'; __mro__.__len__()==4 (StringIO > TextIOBase > IOBase > object); BytesIO (7) < StringIO (8): difference of 1 character; StringIO (8) < BufferedRandom (14)"
  kind: python_call_eq
  category: identity
  id_prefix: iobuffered185

  columns: [id, function, args, expected, description]
  rows:
    - [sio_name,       StringIO.__name__.__eq__,         ["StringIO"], true, "io.StringIO.__name__ == 'StringIO' — StringIO is an in-memory text stream; 'StringIO' has 8 characters: S(1)t(2)r(3)i(4)n(5)g(6)I(7)O(8); StringIO (8) > BytesIO (7) by 1: StringIO is 1 character longer; StringIO (8) < BufferedRandom (14): StringIO is shorter than BufferedRandom by 6; confirmed Python 3.14.3 macOS"]
    - [sio_name_len,   StringIO.__name__.__len__,        [],           8,    "io.StringIO.__name__.__len__() == 8 — 'StringIO' has 8 characters; BytesIO (7) < StringIO (8) < BufferedRandom (14): StringIO is in the middle of the three covered class name lengths; confirmed Python 3.14.3 macOS"]
    - [sio_module,     StringIO.__module__.__eq__,       ["io"],       true, "io.StringIO.__module__ == 'io' — StringIO is defined in the io module; all three covered classes (BytesIO, StringIO, BufferedRandom) share __module__ == 'io'; confirmed Python 3.14.3 macOS"]
    - [sio_mro_len,    StringIO.__mro__.__len__,         [],           4,    "io.StringIO.__mro__.__len__() == 4 — the MRO is (StringIO, TextIOBase, IOBase, object): 4 classes; StringIO shares MRO length 4 with BytesIO and BufferedRandom; confirmed Python 3.14.3 macOS"]
    - [sio_base0_name, "StringIO.__bases__[0].__name__.__eq__", ["TextIOBase"], true, "io.StringIO.__bases__[0].__name__ == 'TextIOBase' — StringIO directly inherits from TextIOBase (the text-stream abstract base); unlike BytesIO and BufferedRandom whose base is BufferedIOBase, StringIO's base is TextIOBase; confirmed Python 3.14.3 macOS"]
    - [sio_mro2_name,  "StringIO.__mro__[2].__name__.__eq__", ["IOBase"],     true, "io.StringIO.__mro__[2].__name__ == 'IOBase' — the third MRO entry (index 2) is IOBase, shared by all io classes; MRO: (StringIO[0], TextIOBase[1], IOBase[2], object[3]); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra185.bufferedrandom_name_is_bufferedrandom:
  description: "io.BufferedRandom.__name__ == 'BufferedRandom' — BufferedRandom allows random read/write on a buffered binary stream; len=14; BufferedRandom (14) > StringIO (8) > BytesIO (7): the longest of the three covered class names; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BufferedRandom.__name__.__eq__
  args: ["BufferedRandom"]
  expected: true

invariant io_extra185.bufferedrandom_name_len_is_14:
  description: "io.BufferedRandom.__name__.__len__() == 14 — 'BufferedRandom' has 14 characters; BytesIO (7) < StringIO (8) < BufferedRandom (14): BufferedRandom is the maximum length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BufferedRandom.__name__.__len__
  args: []
  expected: 14

invariant io_extra185.bufferedrandom_module_is_io:
  description: "io.BufferedRandom.__module__ == 'io' — BufferedRandom's __module__ is 'io'; all three covered classes share __module__ == 'io'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BufferedRandom.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra185.bufferedrandom_mro_len_is_4:
  description: "io.BufferedRandom.__mro__.__len__() == 4 — MRO: (BufferedRandom, BufferedIOBase, IOBase, object); all three covered classes share MRO length 4; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BufferedRandom.__mro__.__len__
  args: []
  expected: 4

invariant io_extra185.bufferedrandom_base0_is_bufferediobase:
  description: "io.BufferedRandom.__bases__[0].__name__ == 'BufferedIOBase' — BufferedRandom's only direct base is BufferedIOBase; 'BufferedIOBase' has 14 characters — same length as 'BufferedRandom'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "BufferedRandom.__bases__[0].__name__.__eq__"
  args: ["BufferedIOBase"]
  expected: true

invariant io_extra185.bytesio_name_is_bytesio:
  description: "io.BytesIO.__name__ == 'BytesIO' — BytesIO is the in-memory binary stream class; len=7 (B-y-t-e-s-I-O); BytesIO (7) < StringIO (8) < BufferedRandom (14): BytesIO has the shortest class name covered; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BytesIO.__name__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra185.bytesio_mro_len_is_4:
  description: "io.BytesIO.__mro__.__len__() == 4 — MRO: (BytesIO, BufferedIOBase, IOBase, object); BytesIO shares MRO depth 4 with StringIO and BufferedRandom — a 3-way tie; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BytesIO.__mro__.__len__
  args: []
  expected: 4

invariant io_extra185.stringio_name_is_stringio:
  description: "io.StringIO.__name__ == 'StringIO' — StringIO is the in-memory text stream class; len=8; BytesIO (7) < StringIO (8) < BufferedRandom (14): StringIO is in the middle of the length ordering; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: StringIO.__name__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra185.stringio_mro_len_is_4:
  description: "io.StringIO.__mro__.__len__() == 4 — MRO: (StringIO, TextIOBase, IOBase, object); StringIO shares MRO depth 4 with BytesIO and BufferedRandom; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: StringIO.__mro__.__len__
  args: []
  expected: 4

invariant io_extra185.stringio_base0_is_textiobase:
  description: "io.StringIO.__bases__[0].__name__ == 'TextIOBase' — StringIO's direct base is TextIOBase, distinguishing it from BytesIO and BufferedRandom whose base is BufferedIOBase; 'TextIOBase' has 10 characters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "StringIO.__bases__[0].__name__.__eq__"
  args: ["TextIOBase"]
  expected: true
