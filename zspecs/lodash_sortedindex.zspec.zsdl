spec: lodash_sortedindex
version: ">=4.0.0"
backend: node(lodash.sortedindex)

docs: https://lodash.com/docs/#sortedIndex

provenance:
  derived_from:
    - "lodash.sortedindex README — https://www.npmjs.com/package/lodash.sortedindex"
    - "Test vectors verified with lodash.sortedindex@4.1.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.sortedindex exports the _.sortedIndex function directly as module.exports."
    - "sortedIndex(array, value) uses binary search to find the lowest insertion index."
    - "Array must be sorted in ascending order."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns integer insertion index."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_sortedindex.sortedindex:
  kind: node_module_call_eq
  function: ~
  category: sortedindex
  id_prefix: lsi

  columns: [id, args, expected]
  rows:
    - [middle,   [[1, 2, 3, 5], 4],    3]
    - [start,    [[2, 3, 4], 1],       0]
    - [end,      [[1, 2, 3], 5],       3]
    - [existing, [[1, 2, 3, 3, 5], 3], 2]
