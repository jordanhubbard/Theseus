spec: inspect_extra53
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra52.zspec.zsdl."
    - "Prior specs covered for Parameter/Signature/BoundArguments/FrameInfo: __module__.__eq__('inspect') (extra5/extra7/extra15/extra25); __module__.__len__()==7 (extra25/extra29/extra38); __class__.__name__=='type' (extra7/extra47); __class__.__qualname__=='type' (extra48); __bases__[0].__name__ for each (extra20/extra31/extra45); __mro__.__len__() for each (extra31)."
    - "Prior specs covered for FullArgSpec: __module__.__eq__('inspect') (extra9/extra15/extra25); __module__.__len__()==7 not recorded; __class__.__qualname__=='type' (extra48)."
    - "This spec covers: inspect.Parameter.__module__.__class__.__name__.__eq__('str')==true; inspect.Signature.__module__.__class__.__name__.__eq__('str')==true; inspect.BoundArguments.__module__.__class__.__name__.__eq__('str')==true; inspect.FrameInfo.__module__.__class__.__name__.__eq__('str')==true; inspect.FullArgSpec.__module__.__class__.__name__.__eq__('str')==true; inspect.Parameter.__module__.__class__.__qualname__.__eq__('str')==true; inspect.Signature.__module__.__class__.__qualname__.__eq__('str')==true; inspect.FullArgSpec.__module__.__len__()==7."
    - "Key findings: inspect is a pure-Python module in Lib/inspect.py. All inspect classes (Parameter, Signature, BoundArguments, FrameInfo, FullArgSpec) store their __module__ as the Python string 'inspect' (7 chars). Since this string is a Python str object, its __class__ is the str built-in type, and str.__name__ == 'str' (3 chars). Prior specs (extra52) established this pattern for inspect module-level functions (isfunction, isbuiltin, isclass, ismodule, signature, getmembers) but not for any inspect class object. The __module__.__class__.__name__=='str' check for inspect classes is a new dimension in extra53. Additionally, FullArgSpec.__module__.__len__()==7 was not recorded as an explicit row in any prior spec (extra25 recorded Parameter/Signature/FrameInfo/BoundArguments but not FullArgSpec). All eight invariants are new to extra53."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect class __module__.__class__.__name__ == 'str' — extra53 namespace
#
# All inspect classes (Parameter, Signature, BoundArguments, FrameInfo,
# FullArgSpec) store their __module__ as the Python string 'inspect' (7 chars).
# Since this string is a Python str object, its __class__ is the str built-in
# type, and str.__name__ == 'str' (3 chars). Prior extra52 established this
# pattern for inspect module-level functions, but not for any class object.
# Prior specs confirmed __module__.__eq__('inspect') and __module__.__len__()==7
# for all five classes (extra5/extra7/extra15/extra25/extra29/extra38), but no
# prior spec records __module__.__class__.__name__.__eq__('str') for any of them.
# All five checks below are new to extra53.
# ---------------------------------------------------------------------------

table inspect_extra53.class_module_string_class_name:
  description: "inspect class __module__.__class__.__name__ == 'str' — all inspect classes store __module__ as a Python str object; str.__name__ == 'str' (3 chars); extra52 covered functions; these five classes are new to extra53"
  kind: python_call_eq
  category: identity
  id_prefix: inspmod53

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_module_class_name,
       Parameter.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.Parameter.__module__.__class__.__name__ == 'str' — Parameter is a pure-Python class in Lib/inspect.py representing a parameter in a function signature; __module__ is the Python string 'inspect' (7 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra5/extra15/extra25/extra29 confirmed Parameter.__module__.__eq__('inspect') and __module__.__len__()==7; this is the first __module__.__class__.__name__ check for any inspect class; new to extra53"]
    - [Signature_module_class_name,
       Signature.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.Signature.__module__.__class__.__name__ == 'str' — Signature is a pure-Python class in Lib/inspect.py representing the signature of a callable; __module__ is the Python string 'inspect' (7 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra5/extra15/extra25/extra29 confirmed Signature.__module__.__eq__('inspect') and __module__.__len__()==7; this is the first __module__.__class__.__name__ check for Signature; new to extra53"]
    - [BoundArguments_module_class_name,
       BoundArguments.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.BoundArguments.__module__.__class__.__name__ == 'str' — BoundArguments is a pure-Python class in Lib/inspect.py representing the result of binding arguments to a Signature; __module__ is the Python string 'inspect' (7 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra7/extra15/extra25/extra29 confirmed BoundArguments.__module__.__eq__('inspect') and __module__.__len__()==7; this is the first __module__.__class__.__name__ check for BoundArguments; new to extra53"]
    - [FrameInfo_module_class_name,
       FrameInfo.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.FrameInfo.__module__.__class__.__name__ == 'str' — FrameInfo is a named-tuple-like class in Lib/inspect.py holding frame information returned by stack(); __module__ is the Python string 'inspect' (7 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra25 confirmed FrameInfo.__module__.__eq__('inspect') and __module__.__len__()==7; this is the first __module__.__class__.__name__ check for FrameInfo; new to extra53"]
    - [FullArgSpec_module_class_name,
       FullArgSpec.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.FullArgSpec.__module__.__class__.__name__ == 'str' — FullArgSpec is a namedtuple created by collections.namedtuple() in Lib/inspect.py holding full argument specification data; __module__ is the Python string 'inspect' (7 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra9/extra15 confirmed FullArgSpec.__module__.__eq__('inspect'); this is the first __module__.__class__.__name__ check for FullArgSpec; new to extra53"]

# ---------------------------------------------------------------------------
# inspect class __module__.__class__.__qualname__ == 'str' — extra53 namespace
#
# The str built-in type is a top-level type with no enclosing class scope, so
# __qualname__ == __name__ == 'str' (3 chars). Therefore for any inspect class T:
#   T.__module__.__class__.__qualname__ == 'str' (3 chars)
# No prior inspect spec records __module__.__class__.__qualname__.__eq__('str')
# for any inspect class object. The two checks below establish this pattern.
# ---------------------------------------------------------------------------

table inspect_extra53.class_module_string_class_qualname:
  description: "inspect class __module__.__class__.__qualname__ == 'str' — str built-in type has __qualname__ == __name__ == 'str' (3 chars); no prior inspect spec records this qualname form for any inspect class"
  kind: python_call_eq
  category: identity
  id_prefix: inspmod53

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_module_class_qualname,
       Parameter.__module__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "inspect.Parameter.__module__.__class__.__qualname__ == 'str' — Parameter.__module__ is a Python str object; the str built-in type is a top-level type with __qualname__ == __name__ == 'str' (3 chars); consistent with extra53's Parameter.__module__.__class__.__name__.__eq__('str'); no prior inspect spec records __module__.__class__.__qualname__ for any class; new to extra53"]
    - [Signature_module_class_qualname,
       Signature.__module__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "inspect.Signature.__module__.__class__.__qualname__ == 'str' — Signature.__module__ is a Python str object; the str built-in type is a top-level type with __qualname__ == __name__ == 'str' (3 chars); consistent with extra53's Signature.__module__.__class__.__name__.__eq__('str'); no prior inspect spec records __module__.__class__.__qualname__ for Signature; new to extra53"]

# ---------------------------------------------------------------------------
# inspect.FullArgSpec __module__.__len__() — extra53 namespace
#
# Prior specs recorded __module__.__len__()==7 for Parameter, Signature,
# BoundArguments, and FrameInfo (extra25/extra29/extra38). FullArgSpec had
# __module__.__eq__('inspect') confirmed in extra9/extra15, but no prior spec
# records FullArgSpec.__module__.__len__()==7 as an explicit invariant row.
# This is new to extra53.
# ---------------------------------------------------------------------------

table inspect_extra53.class_module_len:
  description: "inspect.FullArgSpec.__module__.__len__()==7 — 'inspect' is 7 chars; prior specs recorded this for Parameter/Signature/BoundArguments/FrameInfo but not FullArgSpec; first explicit __module__.__len__ row for FullArgSpec"
  kind: python_call_eq
  category: identity
  id_prefix: inspmod53

  columns: [id, function, args, expected, description]
  rows:
    - [FullArgSpec_module_len,
       FullArgSpec.__module__.__len__,
       [],
       7,
       "inspect.FullArgSpec.__module__.__len__() == 7 — 'inspect' has 7 characters; FullArgSpec is a namedtuple defined in Lib/inspect.py via collections.namedtuple() holding args/varargs/varkw/defaults/kwonlyargs/kwonlydefaults/annotations fields; prior extra9/extra15 confirmed FullArgSpec.__module__.__eq__('inspect'); extra25 recorded __module__.__len__()==7 for Parameter/Signature/FrameInfo/BoundArguments but not FullArgSpec; this is the first explicit __module__.__len__() row for FullArgSpec; new to extra53"]
