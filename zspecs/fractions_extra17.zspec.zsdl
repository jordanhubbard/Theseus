spec: fractions_extra17
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions_extra through fractions_extra16."
    - "fractions_extra6 covers Fraction.__mro__.__len__() == 6 and MRO[0,3] __name__."
    - "fractions_extra7 covers MRO[4,5] __name__ (Number, object)."
    - "fractions_extra8 covers MRO __getitem__ at indices 1 and 2 (Rational, Real)."
    - "fractions_extra16 covers Fraction.__bases__[0] name/qualname/module."
    - "No prior spec covers Fraction.__mro__[i].__qualname__.__eq__ for any MRO index."
    - "All six MRO entries are top-level classes: __qualname__ equals __name__ for each."
    - "fractions.Fraction MRO: Fraction → Rational → Real → Complex → Number → object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Fraction.__mro__ entries via __qualname__.__eq__
#
# Prior specs record MRO entries via __name__.__eq__ or __getitem__ returning
# the class object.  This spec records the same six entries via __qualname__
# — a distinct attribute that equals __name__ for top-level classes but
# differs for nested classes.  No prior fractions spec uses __qualname__ on
# MRO items.
# ---------------------------------------------------------------------------

table fractions_extra17.mro_qualnames:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mro_qualname

  columns: [id, function, args, expected, description]
  rows:
    - [0, "Fraction.__mro__[0].__qualname__.__eq__", ["Fraction"], true, "MRO[0].__qualname__ == 'Fraction' — the class itself"]
    - [1, "Fraction.__mro__[1].__qualname__.__eq__", ["Rational"], true, "MRO[1].__qualname__ == 'Rational' — direct base"]
    - [2, "Fraction.__mro__[2].__qualname__.__eq__", ["Real"],     true, "MRO[2].__qualname__ == 'Real'"]
    - [3, "Fraction.__mro__[3].__qualname__.__eq__", ["Complex"],  true, "MRO[3].__qualname__ == 'Complex'"]
    - [4, "Fraction.__mro__[4].__qualname__.__eq__", ["Number"],   true, "MRO[4].__qualname__ == 'Number'"]
    - [5, "Fraction.__mro__[5].__qualname__.__eq__", ["object"],   true, "MRO[5].__qualname__ == 'object' — root of all classes"]

# ---------------------------------------------------------------------------
# Fraction class-level identity invariants
#
# These record __qualname__.__eq__ and __module__.__eq__ for the Fraction
# class itself — expression forms distinct from the table above.
# ---------------------------------------------------------------------------

invariant fractions_extra17.Fraction.qualname:
  description: "fractions.Fraction.__qualname__ == 'Fraction' — top-level class, qualname equals name"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__qualname__.__eq__
  args: ["Fraction"]
  expected: true

invariant fractions_extra17.Fraction.module:
  description: "fractions.Fraction.__module__ == 'fractions' — defined in the fractions module"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__module__.__eq__
  args: ["fractions"]
  expected: true

invariant fractions_extra17.Fraction.mro_len:
  description: "len(fractions.Fraction.__mro__) == 6 — six entries in the MRO chain"
  category: class_hierarchy
  kind: python_call_eq
  function: Fraction.__mro__.__len__
  args: []
  expected: 6

invariant fractions_extra17.Fraction.bases_len:
  description: "len(fractions.Fraction.__bases__) == 1 — Fraction has exactly one direct base"
  category: class_hierarchy
  kind: python_call_eq
  function: Fraction.__bases__.__len__
  args: []
  expected: 1

invariant fractions_extra17.Fraction.qualname_len:
  description: "len(fractions.Fraction.__qualname__) == 8 — 'Fraction' is 8 characters"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__qualname__.__len__
  args: []
  expected: 8
