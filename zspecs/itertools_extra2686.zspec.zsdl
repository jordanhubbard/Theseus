spec: itertools_extra2686
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 626 theme: __and__, __or__, and __xor__ dict-presence checks (bitwise AND, OR, XOR operators)."
    - "All itertools iterator classes (chain, count, repeat, cycle, islice, compress, dropwhile, takewhile, starmap, groupby, filterfalse, accumulate, zip_longest, pairwise, product, permutations, combinations, combinations_with_replacement) are lazy iterators."
    - "Lazy iterators do not support bitwise operator protocols such as __and__, __or__, or __xor__."
    - "itertools.repeat does have a __len__ for finite repeats, but still defines none of __and__, __or__, __xor__."
    - "None of the itertools classes define __and__, __or__, or __xor__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __and__ dict-presence — absent from all itertools classes
# ---------------------------------------------------------------------------

table itertools_extra2686.and_protocol:
  description: "__and__ is absent from all itertools iterator class __dict__s — lazy iterators do not support bitwise AND"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2686

  columns: [id, function, args, expected]
  rows:
    - ["it2686001", "itertools.chain.__dict__.__contains__",                         ["__and__"], false]
    - ["it2686002", "itertools.count.__dict__.__contains__",                         ["__and__"], false]
    - ["it2686003", "itertools.repeat.__dict__.__contains__",                        ["__and__"], false]
    - ["it2686004", "itertools.cycle.__dict__.__contains__",                         ["__and__"], false]
    - ["it2686005", "itertools.islice.__dict__.__contains__",                        ["__and__"], false]
    - ["it2686006", "itertools.compress.__dict__.__contains__",                      ["__and__"], false]
    - ["it2686007", "itertools.dropwhile.__dict__.__contains__",                     ["__and__"], false]
    - ["it2686008", "itertools.takewhile.__dict__.__contains__",                     ["__and__"], false]
    - ["it2686009", "itertools.starmap.__dict__.__contains__",                       ["__and__"], false]
    - ["it2686010", "itertools.groupby.__dict__.__contains__",                       ["__and__"], false]
    - ["it2686011", "itertools.filterfalse.__dict__.__contains__",                   ["__and__"], false]
    - ["it2686012", "itertools.accumulate.__dict__.__contains__",                    ["__and__"], false]
    - ["it2686013", "itertools.zip_longest.__dict__.__contains__",                   ["__and__"], false]
    - ["it2686014", "itertools.pairwise.__dict__.__contains__",                      ["__and__"], false]
    - ["it2686015", "itertools.product.__dict__.__contains__",                       ["__and__"], false]
    - ["it2686016", "itertools.permutations.__dict__.__contains__",                  ["__and__"], false]
    - ["it2686017", "itertools.combinations.__dict__.__contains__",                  ["__and__"], false]
    - ["it2686018", "itertools.combinations_with_replacement.__dict__.__contains__",  ["__and__"], false]

