spec: operator_extra19
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl through operator_extra18.zspec.zsdl."
    - "operator_extra18 covers comparison call results (eq/ne/lt/le/gt/ge), not_(False), and bitwise results (and_/or_/xor)."
    - "No prior operator spec covers getitem/contains/length_hint/index/concat call results in the extra19 namespace."
    - "operator.getitem([1,2,3], 0)==1: returns first element of the list."
    - "operator.getitem([1,2,3], 2)==3: returns last element by positive index."
    - "operator.contains([1,2,3], 2)==True: 2 is present in the list."
    - "operator.contains([1,2,3], 4)==False: 4 is absent from the list."
    - "operator.length_hint([1,2,3])==3: returns exact length of a sized object."
    - "operator.length_hint([])==0: empty list has length 0."
    - "operator.index(5)==5: __index__ protocol on plain int returns the int itself."
    - "operator.concat([1,2],[3,4])==[1,2,3,4]: list concatenation via + operator."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Sequence / collection operator call results
#
# These operators exercise getitem, contains, length_hint, index, and concat.
# No prior operator spec records any of these call results in the extra19
# namespace.
# ---------------------------------------------------------------------------

table operator_extra19.sequence_calls:
  kind: python_call_eq
  category: call_results
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra19.sequence_calls.getitem_0,
       getitem,
       [[1, 2, 3], 0],
       1,
       "operator.getitem([1,2,3], 0) == 1 — first element by index"]
    - [operator_extra19.sequence_calls.getitem_2,
       getitem,
       [[1, 2, 3], 2],
       3,
       "operator.getitem([1,2,3], 2) == 3 — third element by index"]
    - [operator_extra19.sequence_calls.contains_present,
       contains,
       [[1, 2, 3], 2],
       true,
       "operator.contains([1,2,3], 2) == True — 2 is in the list"]
    - [operator_extra19.sequence_calls.contains_absent,
       contains,
       [[1, 2, 3], 4],
       false,
       "operator.contains([1,2,3], 4) == False — 4 is not in the list"]
    - [operator_extra19.sequence_calls.length_hint_nonempty,
       length_hint,
       [[1, 2, 3]],
       3,
       "operator.length_hint([1,2,3]) == 3 — length of three-element list"]
    - [operator_extra19.sequence_calls.length_hint_empty,
       length_hint,
       [[]],
       0,
       "operator.length_hint([]) == 0 — length of empty list"]
    - [operator_extra19.sequence_calls.index_5,
       index,
       [5],
       5,
       "operator.index(5) == 5 — __index__ protocol on int returns self"]

# ---------------------------------------------------------------------------
# concat call result
#
# operator.concat joins two sequences using the + operator.
# concat([1,2],[3,4]) == [1,2,3,4]: list concatenation.
# No prior operator spec records this as a ZSDL invariant in extra19.
# ---------------------------------------------------------------------------

invariant operator_extra19.concat.call_lists:
  description: "operator.concat([1,2], [3,4]) == [1,2,3,4] — list concatenation via operator"
  category: call_results
  kind: python_call_eq
  function: concat
  args: [[1, 2], [3, 4]]
  expected: [1, 2, 3, 4]
