spec: struct_extra2806
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra2791.zspec.zsdl — covers __iand__, __ior__, and __ixor__ absence for Struct, struct.error."
    - "struct_extra2776.zspec.zsdl — covers __isub__, __imul__, and __itruediv__ absence for Struct, struct.error."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "struct.Struct.__dict__.__contains__('__ilshift__') == False — struct.Struct is a binary format descriptor; it defines no in-place left-shift operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.Struct.__dict__.__contains__('__irshift__') == False — struct.Struct defines no in-place right-shift operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.Struct.__dict__.__contains__('__ipow__') == False — struct.Struct defines no in-place power operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__ilshift__') == False — struct.error is an Exception subclass; exception types never define in-place left-shift in their own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__irshift__') == False — struct.error defines no in-place right-shift operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__ipow__') == False — struct.error defines no in-place power operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.Struct.__dict__ — __ilshift__, __irshift__, __ipow__ absence
# struct.Struct is the compiled format object returned by struct.Struct(fmt).
# It exposes pack/unpack/pack_into/unpack_from/iter_unpack methods and the
# size/format attributes. In-place shift and power operators (<<=, >>=, **=)
# are undefined for a binary format descriptor.
# ---------------------------------------------------------------------------

table struct_extra2806.struct_dict_ilshift_irshift_ipow:
  description: "struct.Struct.__dict__ does not contain __ilshift__, __irshift__, or __ipow__ — Struct is a binary format descriptor, not an integer operand; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2806

  columns: [id, function, args, expected]
  rows:
    - ["st2806-struct-ilshift", struct.Struct.__dict__.__contains__, ["__ilshift__"], false]
    - ["st2806-struct-irshift", struct.Struct.__dict__.__contains__, ["__irshift__"], false]
    - ["st2806-struct-ipow",    struct.Struct.__dict__.__contains__, ["__ipow__"],    false]

# ---------------------------------------------------------------------------
# Table 2: struct.error.__dict__ — __ilshift__, __irshift__, __ipow__ absence
# struct.error is a subclass of Exception raised on pack/unpack failures.
# Exception types never define in-place shift or power operators in their own
# __dict__.
# ---------------------------------------------------------------------------

table struct_extra2806.error_dict_ilshift_irshift_ipow:
  description: "struct.error.__dict__ does not contain __ilshift__, __irshift__, or __ipow__ — struct.error is an Exception subclass; exception types define no in-place shift or power operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2806

  columns: [id, function, args, expected]
  rows:
    - ["st2806-error-ilshift", struct.error.__dict__.__contains__, ["__ilshift__"], false]
    - ["st2806-error-irshift", struct.error.__dict__.__contains__, ["__irshift__"], false]
    - ["st2806-error-ipow",    struct.error.__dict__.__contains__, ["__ipow__"],    false]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct.__dict__ — per-dunder detail with descriptions
# ---------------------------------------------------------------------------

table struct_extra2806.struct_dict_detail:
  description: "struct.Struct.__dict__ in-place shift/power operator absence detail — __ilshift__, __irshift__, and __ipow__ are not defined because Struct is a packing/unpacking tool, not a bitwise or arithmetic operand; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2806

  columns: [id, function, args, expected, description]
  rows:
    - ["st2806-d-ilshift", struct.Struct.__dict__.__contains__, ["__ilshift__"], false, "struct.Struct does not support <<= — binary format descriptors have no left-shift semantics"]
    - ["st2806-d-irshift", struct.Struct.__dict__.__contains__, ["__irshift__"], false, "struct.Struct does not support >>= — right-shift has no defined meaning for a format descriptor"]
    - ["st2806-d-ipow",    struct.Struct.__dict__.__contains__, ["__ipow__"],    false, "struct.Struct does not support **= — in-place power is undefined for a binary format descriptor"]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — Struct and error both lack all three dunders
# ---------------------------------------------------------------------------

table struct_extra2806.all_types_all_dunders_absent:
  description: "struct.Struct and struct.error both lack __ilshift__, __irshift__, and __ipow__ in __dict__ — neither struct type defines in-place shift or power operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2806

  columns: [id, function, args, expected]
  rows:
    - ["st2806-x-struct-ilshift", struct.Struct.__dict__.__contains__, ["__ilshift__"], false]
    - ["st2806-x-struct-irshift", struct.Struct.__dict__.__contains__, ["__irshift__"], false]
    - ["st2806-x-struct-ipow",    struct.Struct.__dict__.__contains__, ["__ipow__"],    false]
    - ["st2806-x-error-ilshift",  struct.error.__dict__.__contains__,  ["__ilshift__"], false]
    - ["st2806-x-error-irshift",  struct.error.__dict__.__contains__,  ["__irshift__"], false]
    - ["st2806-x-error-ipow",     struct.error.__dict__.__contains__,  ["__ipow__"],    false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra2806.struct_no_ilshift:
  description: "struct.Struct.__dict__.__contains__('__ilshift__') == False — struct.Struct does not define the <<= operator; it is a binary packing/unpacking tool with no shift semantics; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__ilshift__"]
  expected: false

invariant struct_extra2806.struct_no_irshift:
  description: "struct.Struct.__dict__.__contains__('__irshift__') == False — struct.Struct does not define the >>= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__irshift__"]
  expected: false

invariant struct_extra2806.struct_no_ipow:
  description: "struct.Struct.__dict__.__contains__('__ipow__') == False — struct.Struct does not define the **= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__ipow__"]
  expected: false

invariant struct_extra2806.error_no_ilshift:
  description: "struct.error.__dict__.__contains__('__ilshift__') == False — struct.error (Exception subclass) does not define the <<= operator; exception types carry no shift semantics; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
  args: ["__ilshift__"]
  expected: false

invariant struct_extra2806.error_no_irshift:
  description: "struct.error.__dict__.__contains__('__irshift__') == False — struct.error does not define the >>= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
  args: ["__irshift__"]
  expected: false

invariant struct_extra2806.error_no_ipow:
  description: "struct.error.__dict__.__contains__('__ipow__') == False — struct.error does not define the **= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
  args: ["__ipow__"]
  expected: false
