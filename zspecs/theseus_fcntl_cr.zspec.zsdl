spec: theseus_fcntl_cr
version: ">=3.8"
backend: python_cleanroom(theseus_fcntl_cr)
blocks: fcntl

docs: https://docs.python.org/3/library/fcntl.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/fcntl.html"
  not_derived_from:
    - "CPython source: Modules/fcntlmodule.c"
  notes:
    - "Clean-room fcntl module. Do NOT import fcntl."

error_model: python_exceptions

invariant theseus_fcntl_cr.fcntl2_getfl:
  description: "fcntl F_GETFL returns file flags as int"
  category: behavior
  kind: python_call_eq
  function: fcntl2_getfl
  args: []
  expected: true

invariant theseus_fcntl_cr.fcntl2_constants:
  description: "F_GETFL and F_SETFL constants exist as ints"
  category: behavior
  kind: python_call_eq
  function: fcntl2_constants
  args: []
  expected: true

invariant theseus_fcntl_cr.fcntl2_flock:
  description: "flock constants exist"
  category: behavior
  kind: python_call_eq
  function: fcntl2_flock
  args: []
  expected: true
