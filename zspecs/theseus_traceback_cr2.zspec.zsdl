spec: theseus_traceback_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_traceback_cr2)
blocks: traceback

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html"
  notes:
    - "Clean-room extended traceback utilities. Do NOT import traceback or linecache."
    - "TracebackException.from_exception(exc): create TracebackException from a live exception."
    - "format_list(extracted_list): format a list of FrameSummary objects to strings."
    - "extract_stack(): extract current call stack as StackSummary."
    - "traceback2_extract_stack(): isinstance(extract_stack(), list) — returns True."
    - "traceback2_format_list(): format_list([]) == []."
    - "traceback2_tb_exception(): TracebackException.from_exception(ValueError('test')).exc_type == ValueError."
    - "Zero-arg invariant signatures — def traceback2_extract_stack(): return bool"
    - "extract_stack uses sys._getframe() to walk the call stack."
    - "format_list converts FrameSummary items to 'File ..., line N, in fn\\n  code\\n' strings."
    - "TracebackException stores exc_type, exc_value, exc_tb from a caught exception."
    - "Export: TracebackException, format_list(lst), extract_stack(), format_exc()."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_traceback_cr2.extract_stack:
  description: "extract_stack() returns a list"
  category: extract_stack
  kind: python_call_eq
  function: traceback2_extract_stack
  args: []
  expected: true

invariant theseus_traceback_cr2.format_list:
  description: "format_list([]) == []"
  category: format_list
  kind: python_call_eq
  function: traceback2_format_list
  args: []
  expected: []

invariant theseus_traceback_cr2.tb_exception:
  description: "TracebackException.from_exception(ValueError('test')).exc_type == ValueError"
  category: TracebackException
  kind: python_call_eq
  function: traceback2_tb_exception
  args: []
  expected: true
