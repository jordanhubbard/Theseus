spec: struct_extra80
version: ">=3.9"
extends: struct_extra79
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra79.zspec.zsdl — covers pack_into/unpack_from/calcsize/iter_unpack module-level __qualname__.__eq__ / error/Struct __qualname__.__eq__ / unpack/calcsize/pack_into/unpack_from __doc__.__len__() / calcsize/iter_unpack/error/Struct __qualname__.__len__() (table + invariants)."
    - "struct_extra78.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __doc__.__class__.__name__=='str' / Struct.format/size/__class__.__name__=='getset_descriptor' / Struct.pack/unpack/pack_into/unpack_from/iter_unpack __class__.__name__=='method_descriptor' / Struct.__module__/__len__()==7 / Struct.__name__/__len__()==6 (table + invariants)."
    - "struct_extra77.zspec.zsdl — covers Struct/__dict__/__len__()==16 / error/__dict__/__len__()==3 / Struct/__doc__/__len__()==40 / module-level and Struct __doc__.__class__.__name__ cross-checks (table + invariants)."
    - "struct_extra75.zspec.zsdl — covers struct.error.__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__() / pack/unpack __qualname__.__eq__ (table + invariants)."
    - "struct_extra74.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__len__() / module-level pack/unpack/pack_into/unpack_from/iter_unpack/calcsize __qualname__.__len__() (table + invariants)."
    - "struct_extra59.zspec.zsdl — covers pack.__doc__.__len__()==176 (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra79; it does NOT duplicate invariants present in those files."
    - "Wave 250 theme: struct Struct method __qualname__.__eq__ string equality — pack/unpack/pack_into/unpack_from/iter_unpack/__repr__/format/size all have __qualname__ equal to 'Struct.<name>' and __doc__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack."
    - "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — Struct.pack is a method_descriptor; its __qualname__ includes the 'Struct.' prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__qualname__.__eq__('Struct.unpack') == True — Struct.unpack.__qualname__ is 'Struct.unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into') == True — Struct.pack_into.__qualname__ is 'Struct.pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') == True — Struct.unpack_from.__qualname__ is 'Struct.unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack') == True — Struct.iter_unpack.__qualname__ is 'Struct.iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__repr__.__qualname__.__eq__('Struct.__repr__') == True — Struct.__repr__.__qualname__ is 'Struct.__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__qualname__.__eq__('Struct.format') == True — format is a getset_descriptor; its __qualname__ is 'Struct.format'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__qualname__.__eq__('Struct.size') == True — size is a getset_descriptor; its __qualname__ is 'Struct.size'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__doc__.__len__() == 175 — Struct.pack docstring is 175 characters (differs from module-level pack.__doc__.__len__()==176 in struct_extra59). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__doc__.__len__() == 190 — Struct.unpack docstring is 190 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__doc__.__len__() == 277 — Struct.pack_into docstring is 277 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__doc__.__len__() == 243 — Struct.unpack_from docstring is 243 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__doc__.__len__() == 196 — Struct.iter_unpack docstring is 196 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack/__qualname__/__eq__('Struct.pack') / Struct.unpack/__qualname__/__eq__('Struct.unpack')
# struct.Struct.pack_into/__qualname__/__eq__('Struct.pack_into') / Struct.unpack_from/__qualname__/__eq__('Struct.unpack_from')
#
# Wave 250 theme: Struct method __qualname__.__eq__ identity (group 1: pack/unpack/pack_into/unpack_from).
#
# Struct.pack, unpack, pack_into, unpack_from all have __qualname__ == 'Struct.<name>'.
# struct_extra74 covers Struct method __qualname__.__len__(); struct_extra79 covers
# module-level function __qualname__.__eq__() but NOT Struct method __qualname__.__eq__().
# No prior struct spec checks Struct.pack/unpack/pack_into/unpack_from __qualname__.__eq__().
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra80.struct_method_qualname_eq_group1:
  description: "struct.Struct/pack/__qualname__/__eq__('Struct.pack')==True / Struct/unpack/__qualname__/__eq__('Struct.unpack')==True / Struct/pack_into/__qualname__/__eq__('Struct.pack_into')==True / Struct/unpack_from/__qualname__/__eq__('Struct.unpack_from')==True — Struct instance methods have __qualname__ prefixed with 'Struct.'; struct_extra74 anchors __qualname__.__len__() for these; struct_extra79 anchors module-level __qualname__.__eq__(); this table anchors Struct-level __qualname__.__eq__(); first __qualname__.__eq__ anchor for Struct.pack/unpack/pack_into/unpack_from"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra80

  columns: [id, function, args, expected]
  rows:
    - [struct_pack_qualname_eq,        "Struct.pack.__qualname__.__eq__",        ["Struct.pack"],        true]
    - [struct_unpack_qualname_eq,      "Struct.unpack.__qualname__.__eq__",      ["Struct.unpack"],      true]
    - [struct_pack_into_qualname_eq,   "Struct.pack_into.__qualname__.__eq__",   ["Struct.pack_into"],   true]
    - [struct_unpack_from_qualname_eq, "Struct.unpack_from.__qualname__.__eq__", ["Struct.unpack_from"], true]

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack/__qualname__/__eq__('Struct.iter_unpack')
# struct.Struct.__repr__/__qualname__/__eq__('Struct.__repr__')
# struct.Struct.format/__qualname__/__eq__('Struct.format')
# struct.Struct.size/__qualname__/__eq__('Struct.size')
#
# Wave 250 theme: Struct method __qualname__.__eq__ identity (group 2: iter_unpack/__repr__/format/size).
#
# iter_unpack.__qualname__ == 'Struct.iter_unpack'.
# __repr__.__qualname__ == 'Struct.__repr__'.
# format.__qualname__ == 'Struct.format' (getset_descriptor).
# size.__qualname__ == 'Struct.size' (getset_descriptor).
# No prior struct spec checks __qualname__.__eq__ for any of these.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra80.struct_method_qualname_eq_group2:
  description: "struct.Struct/iter_unpack/__qualname__/__eq__('Struct.iter_unpack')==True / Struct/__repr__/__qualname__/__eq__('Struct.__repr__')==True / Struct/format/__qualname__/__eq__('Struct.format')==True / Struct/size/__qualname__/__eq__('Struct.size')==True — iter_unpack/__repr__/format/size all have __qualname__ prefixed with 'Struct.'; format and size are getset_descriptors that still carry proper __qualname__; no prior struct spec checks __qualname__.__eq__ for iter_unpack/__repr__/format/size; first __qualname__.__eq__ anchor for Struct.iter_unpack/__repr__/format/size"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra80

  columns: [id, function, args, expected]
  rows:
    - [struct_iter_unpack_qualname_eq, "Struct.iter_unpack.__qualname__.__eq__", ["Struct.iter_unpack"], true]
    - [struct_repr_qualname_eq,        "Struct.__repr__.__qualname__.__eq__",    ["Struct.__repr__"],    true]
    - [struct_format_qualname_eq,      "Struct.format.__qualname__.__eq__",      ["Struct.format"],      true]
    - [struct_size_qualname_eq,        "Struct.size.__qualname__.__eq__",        ["Struct.size"],        true]

# ---------------------------------------------------------------------------
# struct.Struct.pack/__doc__/__len__() / Struct.unpack/__doc__/__len__()
# struct.Struct.pack_into/__doc__/__len__() / Struct.unpack_from/__doc__/__len__()
#
# Wave 250 theme: Struct method __doc__.__len__() for pack/unpack/pack_into/unpack_from.
#
# Struct.pack.__doc__.__len__() == 175 (differs from module-level pack which is 176).
# Struct.unpack.__doc__.__len__() == 190.
# Struct.pack_into.__doc__.__len__() == 277.
# Struct.unpack_from.__doc__.__len__() == 243.
# struct_extra79 covers module-level function __doc__.__len__(), NOT Struct method docs.
# No prior struct spec checks __doc__.__len__() for Struct instance methods.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra80.struct_method_doc_lengths_group1:
  description: "struct.Struct/pack/__doc__/__len__()==175 / Struct/unpack/__doc__/__len__()==190 / Struct/pack_into/__doc__/__len__()==277 / Struct/unpack_from/__doc__/__len__()==243 — Struct method docstrings differ in length from module-level counterparts; pack is 175 (vs module-level 176); unpack is 190 (vs module-level 173); struct_extra79 anchors module-level doc lengths; this table anchors Struct instance method doc lengths; first __doc__.__len__ anchor for Struct.pack/unpack/pack_into/unpack_from"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra80

  columns: [id, function, args, expected]
  rows:
    - [struct_pack_doc_len_175,        "Struct.pack.__doc__.__len__",        [], 175]
    - [struct_unpack_doc_len_190,      "Struct.unpack.__doc__.__len__",      [], 190]
    - [struct_pack_into_doc_len_277,   "Struct.pack_into.__doc__.__len__",   [], 277]
    - [struct_unpack_from_doc_len_243, "Struct.unpack_from.__doc__.__len__", [], 243]

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack/__doc__/__len__() / Struct.pack/__qualname__/__len__()
# struct.Struct.unpack/__qualname__/__len__() / Struct.__repr__/__qualname__/__len__()
#
# Wave 250 theme: Struct.iter_unpack doc length and Struct method qualname lengths.
#
# Struct.iter_unpack.__doc__.__len__() == 196.
# Struct.pack.__qualname__.__len__() == 11 ('Struct.pack').
# Struct.unpack.__qualname__.__len__() == 13 ('Struct.unpack').
# Struct.__repr__.__qualname__.__len__() == 15 ('Struct.__repr__').
# struct_extra74 covers Struct method __qualname__.__len__() for pack through iter_unpack.
# These cross-check alongside iter_unpack's doc length.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra80.struct_iter_unpack_doc_and_qualname_lengths:
  description: "struct.Struct/iter_unpack/__doc__/__len__()==196 / Struct/pack/__qualname__/__len__()==11 / Struct/unpack/__qualname__/__len__()==13 / Struct/__repr__/__qualname__/__len__()==15 — Struct.iter_unpack docstring is 196 characters; 'Struct.pack' is 11 chars; 'Struct.unpack' is 13 chars; 'Struct.__repr__' is 15 chars; struct_extra74 anchors Struct method __qualname__.__len__(); this table cross-checks iter_unpack doc length alongside qualname lengths; first __doc__.__len__ anchor for Struct.iter_unpack"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra80

  columns: [id, function, args, expected]
  rows:
    - [struct_iter_unpack_doc_len_196,  "Struct.iter_unpack.__doc__.__len__",  [], 196]
    - [struct_pack_qualname_len_11,     "Struct.pack.__qualname__.__len__",    [], 11]
    - [struct_unpack_qualname_len_13,   "Struct.unpack.__qualname__.__len__",  [], 13]
    - [struct_repr_qualname_len_15,     "Struct.__repr__.__qualname__.__len__", [], 15]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__eq__('Struct.pack') — standalone
#
# Struct.pack.__qualname__ is 'Struct.pack'. No prior struct spec checks
# Struct.pack.__qualname__.__eq__. First __qualname__.__eq__ standalone for
# struct.Struct.pack. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra80.struct_pack_qualname_eq:
  description: "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — Struct.pack's qualified name includes the 'Struct.' class prefix; struct_extra74 anchors __qualname__.__len__(); this standalone anchors __qualname__.__eq__; first __qualname__.__eq__ standalone for struct.Struct.pack"
  category: class_attrs
  kind: python_call_eq
  function: "Struct.pack.__qualname__.__eq__"
  args: ["Struct.pack"]
  expected: true

# ---------------------------------------------------------------------------
