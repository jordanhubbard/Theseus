spec: multiprocessing_extra721
version: ">=3.9"
backend: python_module(multiprocessing)
docs: Cover multiprocessing.Process class identity and method qualnames
provenance:
  derived_from: multiprocessing standard library documentation
  not_derived_from: any third-party process wrapper
  notes: Validates class identity and method qualname invariants for multiprocessing.Process
  created_at: "2026-04-12"
error_model: python_exceptions

table multiprocessing_extra721.process_class_identity:
  description: multiprocessing.Process class identity checks via qualname, module, and doc
  kind: python_call_eq
  category: class_identity
  id_prefix: mp721ci
  columns: [id, function, args, expected]
  mp721ci001: [multiprocessing.Process.__qualname__.__eq__, ["Process"], true]
  mp721ci002: [multiprocessing.Process.__module__.__eq__, ["multiprocessing.process"], true]
  mp721ci003: [multiprocessing.Process.__doc__.__class__.__name__.__eq__, ["str"], true]

table multiprocessing_extra721.process_method_qualnames:
  description: multiprocessing.Process method qualname checks
  kind: python_call_eq
  category: method_qualname
  id_prefix: mp721mq
  columns: [id, function, args, expected]
  mp721mq001: [multiprocessing.Process.start.__qualname__.__eq__, ["Process.start"], true]
  mp721mq002: [multiprocessing.Process.run.__qualname__.__eq__, ["Process.run"], true]
  mp721mq003: [multiprocessing.Process.join.__qualname__.__eq__, ["Process.join"], true]
  mp721mq004: [multiprocessing.Process.terminate.__qualname__.__eq__, ["Process.terminate"], true]
  mp721mq005: [multiprocessing.Process.kill.__qualname__.__eq__, ["Process.kill"], true]
  mp721mq006: [multiprocessing.Process.is_alive.__qualname__.__eq__, ["Process.is_alive"], true]
  mp721mq007: [multiprocessing.Process.close.__qualname__.__eq__, ["Process.close"], true]
  mp721mq008: [multiprocessing.Process.__init__.__qualname__.__eq__, ["Process.__init__"], true]
  mp721mq009: [multiprocessing.Process.__repr__.__qualname__.__eq__, ["Process.__repr__"], true]
