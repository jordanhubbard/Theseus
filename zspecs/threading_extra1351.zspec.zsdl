spec: threading_extra1351
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "Wave 537 (_extra1351): focuses on __slots__ and __weakref__ attribute checks for threading module classes."
    - "threading.Thread.__dict__.__contains__('__slots__') == False — Thread is a pure Python class without __slots__; instances have a __dict__."
    - "threading.Thread.__dict__.__contains__('__weakref__') == True — Thread has no __slots__, so Python adds a __weakref__ descriptor automatically."
    - "threading.Thread.__dict__.__contains__('__dict__') == True — Thread instances have a per-instance __dict__ as expected for a class without __slots__."
    - "threading.Lock.__dict__.__contains__('__slots__') == False — Lock is a C extension type; no __slots__ descriptor in class __dict__."
    - "threading.Lock.__dict__.__contains__('__weakref__') == False — C type; weakref support at C level via tp_weaklistoffset if present."
    - "threading.Event.__dict__.__contains__('__weakref__') == True — Event is a pure Python class without __slots__; __weakref__ descriptor present."
    - "threading.Condition.__dict__.__contains__('__weakref__') == True — Condition is a pure Python class without __slots__; __weakref__ descriptor present."
    - "threading.Barrier.__dict__.__contains__('__weakref__') == True — Barrier is a pure Python class without __slots__; __weakref__ descriptor present."
    - "threading.Semaphore.__dict__.__contains__('__weakref__') == True — Semaphore is a pure Python class without __slots__; __weakref__ descriptor present."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table threading_extra1351.thread_slot_weakref_dict_checks:
  description: "threading.Thread __dict__ containment checks for __slots__, __weakref__, and __dict__; Thread is a pure Python class without __slots__ so instances have both __dict__ and __weakref__"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: th1351th
  columns: [id, function, args, expected]
  rows:
    - [th1351th001, threading.Thread.__dict__.__contains__, ["__slots__"],    false]
    - [th1351th002, threading.Thread.__dict__.__contains__, ["__weakref__"],  true]
    - [th1351th003, threading.Thread.__dict__.__contains__, ["__dict__"],     true]
    - [th1351th004, threading.Lock.__dict__.__contains__,   ["__slots__"],    false]
    - [th1351th005, threading.Lock.__dict__.__contains__,   ["__weakref__"],  false]
    - [th1351th006, threading.Lock.__dict__.__contains__,   ["__dict__"],     false]

table threading_extra1351.event_condition_barrier_slot_checks:
  description: "threading.Event, Condition, and Barrier __dict__ containment checks for __slots__, __weakref__, and __dict__; all are pure Python classes without __slots__, enabling both __weakref__ and __dict__"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: th1351ec
  columns: [id, function, args, expected]
  rows:
    - [th1351ec001, threading.Event.__dict__.__contains__,     ["__slots__"],    false]
    - [th1351ec002, threading.Event.__dict__.__contains__,     ["__weakref__"],  true]
    - [th1351ec003, threading.Event.__dict__.__contains__,     ["__dict__"],     true]
    - [th1351ec004, threading.Condition.__dict__.__contains__, ["__slots__"],    false]
    - [th1351ec005, threading.Condition.__dict__.__contains__, ["__weakref__"],  true]
    - [th1351ec006, threading.Condition.__dict__.__contains__, ["__dict__"],     true]
    - [th1351ec007, threading.Barrier.__dict__.__contains__,   ["__slots__"],    false]
    - [th1351ec008, threading.Barrier.__dict__.__contains__,   ["__weakref__"],  true]

table threading_extra1351.semaphore_rlock_slot_checks:
  description: "threading.Semaphore, BoundedSemaphore, and RLock __dict__ containment checks for __slots__, __weakref__, and __dict__; Semaphore is a pure Python class, RLock and BoundedSemaphore differ in weakref support"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: th1351sr
  columns: [id, function, args, expected]
  rows:
    - [th1351sr001, threading.Semaphore.__dict__.__contains__,        ["__slots__"],    false]
    - [th1351sr002, threading.Semaphore.__dict__.__contains__,        ["__weakref__"],  true]
    - [th1351sr003, threading.Semaphore.__dict__.__contains__,        ["__dict__"],     true]
    - [th1351sr004, threading.RLock.__dict__.__contains__,            ["__slots__"],    false]
    - [th1351sr005, threading.RLock.__dict__.__contains__,            ["__weakref__"],  false]
    - [th1351sr006, threading.RLock.__dict__.__contains__,            ["__dict__"],     false]
    - [th1351sr007, threading.BoundedSemaphore.__dict__.__contains__, ["__slots__"],    false]
    - [th1351sr008, threading.BoundedSemaphore.__dict__.__contains__, ["__weakref__"],  false]
