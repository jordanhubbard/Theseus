#
# abstractclassmethod.__dict__.__contains__('__isabstractmethod__') == True
# abstractstaticmethod.__dict__.__contains__('__isabstractmethod__') == True
# ---------------------------------------------------------------------------

table abc_extra70.abstractclassmethod_abstractstaticmethod_isabstractmethod:
  description: "abc abstractclassmethod and abstractstaticmethod __dict__ __isabstractmethod__ content checks in abcmore70 namespace — wave 241 theme: abstract wrapper __dict__ content; abstractclassmethod.__dict__.__contains__('__isabstractmethod__')==True; abstractstaticmethod.__dict__.__contains__('__isabstractmethod__')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: abcmore70b

  columns: [id, function, args, expected, description]
  rows:
    - [abstractclassmethod_has_isabstractmethod,  abstractclassmethod.__dict__.__contains__,  ["__isabstractmethod__"], true, "abstractclassmethod.__dict__.__contains__('__isabstractmethod__') == True — abstractclassmethod stores __isabstractmethod__ in its own __dict__; verified with Python 3.14.3"]
    - [abstractstaticmethod_has_isabstractmethod, abstractstaticmethod.__dict__.__contains__, ["__isabstractmethod__"], true, "abstractstaticmethod.__dict__.__contains__('__isabstractmethod__') == True — abstractstaticmethod stores __isabstractmethod__ in its own __dict__; verified with Python 3.14.3"]

