spec: abc_extra70
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra69.zspec.zsdl."
    - "This spec covers: wave 241 theme — abc ABCMeta.__dict__ content + ABC subclasshook behavior. NEW in extra70: ABCMeta.__dict__.__class__.__name__=='mappingproxy'; ABCMeta.__dict__.__contains__('__new__')==True; ABCMeta.__dict__.__contains__('_abc_caches_clear')==True; ABCMeta.__dict__.__contains__('register')==True; abstractproperty.__dict__.__contains__('__isabstractmethod__')==True; abstractclassmethod.__dict__.__contains__('__isabstractmethod__')==True; abstractstaticmethod.__dict__.__contains__('__isabstractmethod__')==True; get_cache_token.__qualname__=='get_cache_token'."
    - "abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'. The __dict__ of any Python class is a read-only mappingproxy; ABCMeta.__dict__.__class__.__name__ is 'mappingproxy'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('__new__') == True. ABCMeta defines __new__ directly in its own __dict__ in Lib/abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('_abc_caches_clear') == True. ABCMeta exposes _abc_caches_clear as a public helper method directly in its __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('register') == True. ABCMeta defines the register method directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__dict__.__contains__('__isabstractmethod__') == True. abstractproperty stores __isabstractmethod__ as a class-level descriptor directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractclassmethod.__dict__.__contains__('__isabstractmethod__') == True. abstractclassmethod stores __isabstractmethod__ directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractstaticmethod.__dict__.__contains__('__isabstractmethod__') == True. abstractstaticmethod stores __isabstractmethod__ directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token.__qualname__ == 'get_cache_token'. get_cache_token is a module-level function in abc; __qualname__ is 'get_cache_token'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc ABCMeta.__dict__ class name and method content — extra70
#
# Wave 241 theme: ABCMeta.__dict__ content + ABC subclasshook behavior.
#
# ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'
# ABCMeta.__dict__.__contains__('__new__') == True
# ABCMeta.__dict__.__contains__('_abc_caches_clear') == True
# ABCMeta.__dict__.__contains__('register') == True
# ---------------------------------------------------------------------------

table abc_extra70.ABCMeta_dict_content:
  description: "abc ABCMeta.__dict__ class name and method content checks in abcmore70 namespace — wave 241 theme: ABCMeta.__dict__ content; ABCMeta.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is read-only mappingproxy in CPython); ABCMeta.__dict__.__contains__('__new__')==True; ABCMeta.__dict__.__contains__('_abc_caches_clear')==True; ABCMeta.__dict__.__contains__('register')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: abcmore70

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_dict_class_name,           ABCMeta.__dict__.__class__.__name__.__eq__, ["mappingproxy"],      true, "ABCMeta.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy in CPython; verified with Python 3.14.3"]
    - [abcmeta_dict_has_new,              ABCMeta.__dict__.__contains__,              ["__new__"],           true, "ABCMeta.__dict__.__contains__('__new__') == True — ABCMeta defines __new__ in Lib/abc.py; verified with Python 3.14.3"]
    - [abcmeta_dict_has_abc_caches_clear, ABCMeta.__dict__.__contains__,              ["_abc_caches_clear"], true, "ABCMeta.__dict__.__contains__('_abc_caches_clear') == True — ABCMeta exposes _abc_caches_clear as a public helper; verified with Python 3.14.3"]
    - [abcmeta_dict_has_register,         ABCMeta.__dict__.__contains__,              ["register"],          true, "ABCMeta.__dict__.__contains__('register') == True — ABCMeta defines register in its own __dict__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc abstractproperty __dict__ __isabstractmethod__ content — extra70
#
# abstractproperty.__dict__.__contains__('__isabstractmethod__') == True
# ---------------------------------------------------------------------------

table abc_extra70.abstractproperty_dict_content:
  description: "abc abstractproperty.__dict__ __isabstractmethod__ content checks in abcmore70 namespace — wave 241 theme: abstract wrapper __dict__ content; abstractproperty.__dict__.__contains__('__isabstractmethod__')==True (abstractproperty stores __isabstractmethod__ as a class-level descriptor directly in its own __dict__); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: abcmore70a

  columns: [id, function, args, expected, description]
  rows:
    - [abstractproperty_dict_has_isabstractmethod, abstractproperty.__dict__.__contains__, ["__isabstractmethod__"], true, "abstractproperty.__dict__.__contains__('__isabstractmethod__') == True — abstractproperty stores __isabstractmethod__ as class-level descriptor; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
