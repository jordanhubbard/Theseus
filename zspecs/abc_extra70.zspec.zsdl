# ---------------------------------------------------------------------------

table abc_extra70.get_cache_token_and_abcmeta_dict:
  description: "abc get_cache_token.__qualname__ and ABCMeta.__dict__.__class__.__name__ cross-check in abcmore70 namespace — wave 241 theme: ABCMeta.__dict__ content; get_cache_token.__qualname__=='get_cache_token' (module-level function); ABCMeta.__dict__.__class__.__name__=='mappingproxy'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmore70c

  columns: [id, function, args, expected, description]
  rows:
    - [get_cache_token_qualname, get_cache_token.__qualname__.__eq__,        ["get_cache_token"], true, "get_cache_token.__qualname__ == 'get_cache_token' — module-level function in abc; verified with Python 3.14.3"]
    - [abcmeta_dict_cls,         ABCMeta.__dict__.__class__.__name__.__eq__, ["mappingproxy"],    true, "ABCMeta.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra70
# ---------------------------------------------------------------------------

invariant abc_extra70.ABCMeta_dict_class_name:
  description: "abc.ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — class __dict__ objects are always mappingproxy in CPython; NEW in extra70: first standalone __dict__.__class__.__name__ invariant for ABCMeta in abcmore70 namespace; wave 241; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: ABCMeta.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra70.ABCMeta_dict_has_new:
  description: "abc.ABCMeta.__dict__.__contains__('__new__') returns True — ABCMeta defines __new__ directly in Lib/abc.py; NEW in extra70: first standalone __contains__('__new__') invariant for ABCMeta in abcmore70 namespace; wave 241; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: ABCMeta.__dict__.__contains__
  args: ["__new__"]
  expected: true

invariant abc_extra70.abstractproperty_dict_has_isabstractmethod:
  description: "abc.abstractproperty.__dict__.__contains__('__isabstractmethod__') returns True — abstractproperty stores __isabstractmethod__ as a class-level descriptor in its own __dict__; NEW in extra70: first standalone __contains__('__isabstractmethod__') invariant for abstractproperty in abcmore70 namespace; wave 241; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: abstractproperty.__dict__.__contains__
  args: ["__isabstractmethod__"]
  expected: true

invariant abc_extra70.abstractclassmethod_dict_has_isabstractmethod:
  description: "abc.abstractclassmethod.__dict__.__contains__('__isabstractmethod__') returns True — abstractclassmethod stores __isabstractmethod__ in its own __dict__; NEW in extra70: first standalone __contains__('__isabstractmethod__') invariant for abstractclassmethod in abcmore70 namespace; wave 241; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: abstractclassmethod.__dict__.__contains__
  args: ["__isabstractmethod__"]
  expected: true

invariant abc_extra70.get_cache_token_qualname:
  description: "abc.get_cache_token.__qualname__.__eq__('get_cache_token') returns True — get_cache_token is a module-level function in abc; __qualname__ is 'get_cache_token'; NEW in extra70: first standalone __qualname__ invariant for get_cache_token in abcmore70 namespace; wave 241; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: get_cache_token.__qualname__.__eq__
  args: ["get_cache_token"]
  expected: true
