spec: socket_extra37
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra36.zspec.zsdl — covers htonl/htons/ntohl/ntohs __qualname__.__len__()==5; socket.socket.dup/get_inheritable/set_inheritable __qualname__.__len__()."
    - "socket_extra35.zspec.zsdl — covers socket.socket __init__/__repr__/__enter__/__exit__ __qualname__.__len__(); AddressFamily/SocketKind __mro__.__len__()==6; AF_INET/SOCK_STREAM __class__.__qualname__.__len__()."
    - "socket_extra34.zspec.zsdl — covers socket.socket close/setblocking/getsockname/fileno/detach/shutdown/sendall __name__.__len__()."
    - "socket_extra33.zspec.zsdl — covers htonl/htons/ntohl/ntohs __name__.__len__()==5; create_server/gethostbyname __name__.__len__()==13."
    - "socket_extra32.zspec.zsdl — covers recvfrom/sendto/makefile/recvfrom_into/recv_into/connect_ex __qualname__.__len__(); getaddrinfo/getnameinfo/setdefaulttimeout/getdefaulttimeout/create_connection __name__.__len__()."
    - "socket_extra31.zspec.zsdl — covers close/setblocking/getsockname/fileno/detach/shutdown/sendall __qualname__.__len__()."
    - "socket_extra30.zspec.zsdl — covers socket.__all__.__len__()==238; AF_INET/AF_INET6 __class__.__name__=='AddressFamily'; SOCK_STREAM/SOCK_DGRAM __class__.__name__=='SocketKind'."
    - "socket_extra16.zspec.zsdl — covers AddressFamily/__name__.__len__()==13; SocketKind/__name__.__len__()==10; AF_INET6/__class__.__name__.__len__()==13; SOCK_DGRAM/__class__.__name__.__len__()==10."
  notes:
    - "This spec extends socket through socket_extra36; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: recvfrom/sendto/makefile/recvfrom_into/recv_into/connect_ex __qualname__.__len__() (extra32); dup/get_inheritable/set_inheritable __qualname__.__len__() (extra36). None of these methods have had their __name__.__len__() checked. The __name__ axis is distinct from __qualname__ (for method_descriptors __qualname__ includes the class prefix 'socket.', __name__ does not)."
    - "This spec covers: socket.socket.recvfrom/__name__.__len__() (NOVEL — extra32 covers recvfrom.__qualname__.__len__()==15; no prior spec checks recvfrom.__name__.__len__()==8); socket.socket.sendto/__name__.__len__() (NOVEL — extra32 covers qualname only; 'sendto' is 6 chars); socket.socket.makefile/__name__.__len__() (NOVEL — extra32 covers qualname only; 'makefile' is 8 chars); socket.socket.connect_ex/__name__.__len__() (NOVEL — extra32 covers qualname only; 'connect_ex' is 10 chars); socket.socket.recv_into/__name__.__len__() (NOVEL — extra32 covers qualname only; 'recv_into' is 9 chars); socket.socket.recvfrom_into/__name__.__len__() (NOVEL — extra32 covers qualname only; 'recvfrom_into' is 13 chars); socket.socket.dup/__name__.__len__() (NOVEL — extra36 covers dup.__qualname__.__len__()==10; no prior spec checks dup.__name__.__len__()==3); socket.socket.get_inheritable/__name__.__len__() (NOVEL — extra36 covers qualname only; 'get_inheritable' is 15 chars); socket.socket.set_inheritable/__name__.__len__() (NOVEL — extra36 covers qualname only; 'set_inheritable' is 15 chars); socket.gaierror/__module__.__len__() (NOVEL — no prior spec checks gaierror.__module__.__len__()==6); socket.herror/__module__.__len__() (NOVEL — no prior spec checks herror.__module__.__len__()==6); socket.timeout/__module__.__len__() (NOVEL — socket.timeout is TimeoutError from builtins; __module__=='builtins' is 8 chars; no prior spec checks timeout.__module__.__len__())."
    - "socket.socket.recvfrom.__name__ == 'recvfrom' (len 8). extra32 checks recvfrom.__qualname__.__len__()==15 ('socket.recvfrom'); __name__ gives the bare method name without class prefix. No prior spec checks __name__.__len__() for recvfrom. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.sendto.__name__ == 'sendto' (len 6). Same gap as recvfrom: extra32 covers qualname only. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__name__ == 'makefile' (len 8). extra32 covers qualname only. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.connect_ex.__name__ == 'connect_ex' (len 10). extra32 covers qualname only. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.recv_into.__name__ == 'recv_into' (len 9). extra32 covers qualname only. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom_into.__name__ == 'recvfrom_into' (len 13). extra32 covers qualname only. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.dup.__name__ == 'dup' (len 3). extra36 covers dup.__qualname__.__len__()==10 ('socket.dup'); __name__ is just 'dup' (3 chars). No prior spec checks dup.__name__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.get_inheritable.__name__ == 'get_inheritable' (len 15). extra36 covers qualname only ('socket.get_inheritable' len 22). __name__ == 'get_inheritable' without class prefix. No prior spec checks get_inheritable.__name__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.set_inheritable.__name__ == 'set_inheritable' (len 15). extra36 covers qualname only. Same as get_inheritable pattern. No prior spec checks set_inheritable.__name__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gaierror.__module__ == 'socket' (len 6). gaierror is an exception defined in the socket module. No prior spec checks gaierror.__module__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.herror.__module__ == 'socket' (len 6). herror is an exception defined in the socket module. No prior spec checks herror.__module__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.timeout.__module__ == 'builtins' (len 8). socket.timeout is an alias for the builtin TimeoutError class; its __module__ is 'builtins' (8 chars), not 'socket'. This is a notable behavioral difference from gaierror/herror. No prior spec checks timeout.__module__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket method __name__.__len__() for recvfrom/sendto/makefile set
#
# extra32 covers __qualname__.__len__() for recvfrom/sendto/makefile/
# recvfrom_into/recv_into/connect_ex but does NOT check __name__.__len__().
# The __name__ attribute of a method_descriptor gives the bare name without
# the 'socket.' class prefix used in __qualname__.
#
#   recvfrom.__name__      == 'recvfrom'      -> 8
#   sendto.__name__        == 'sendto'        -> 6
#   makefile.__name__      == 'makefile'      -> 8
#   connect_ex.__name__    == 'connect_ex'    -> 10
#   recv_into.__name__     == 'recv_into'     -> 9
#   recvfrom_into.__name__ == 'recvfrom_into' -> 13
# ---------------------------------------------------------------------------

table socket_extra37.socket_method_name_lens_recv_send:
  description: "socket.socket recvfrom/sendto/makefile/connect_ex/recv_into/recvfrom_into __name__.__len__() — novel __name__ axis; extra32 covers __qualname__.__len__() only for these methods"
  kind: python_call_eq
  category: function_names
  id_prefix: smnlrs37

  columns: [id, function, args, expected]
  rows:
    - [recvfrom_name_len,      "socket.recvfrom.__name__.__len__",      [], 8]
    - [sendto_name_len,        "socket.sendto.__name__.__len__",        [], 6]
    - [makefile_name_len,      "socket.makefile.__name__.__len__",      [], 8]
    - [connect_ex_name_len,    "socket.connect_ex.__name__.__len__",    [], 10]
    - [recv_into_name_len,     "socket.recv_into.__name__.__len__",     [], 9]
    - [recvfrom_into_name_len, "socket.recvfrom_into.__name__.__len__", [], 13]

# ---------------------------------------------------------------------------
# socket.socket method __name__.__len__() for dup/get_inheritable/set_inheritable
#
# extra36 covers __qualname__.__len__() for dup(10)/get_inheritable(22)/
# set_inheritable(22) but does NOT check __name__.__len__().
#
#   dup.__name__             == 'dup'             -> 3
#   get_inheritable.__name__ == 'get_inheritable' -> 15
#   set_inheritable.__name__ == 'set_inheritable' -> 15
# ---------------------------------------------------------------------------

table socket_extra37.socket_method_name_lens_fd_mgmt:
  description: "socket.socket dup/get_inheritable/set_inheritable __name__.__len__() — novel __name__ axis; extra36 covers __qualname__.__len__() only for these three methods"
  kind: python_call_eq
  category: function_names
  id_prefix: smnlfdm37

  columns: [id, function, args, expected]
  rows:
    - [dup_name_len,             "socket.dup.__name__.__len__",             [], 3]
    - [get_inheritable_name_len, "socket.get_inheritable.__name__.__len__", [], 15]
    - [set_inheritable_name_len, "socket.set_inheritable.__name__.__len__", [], 15]

# ---------------------------------------------------------------------------
# socket exception class __module__.__len__()
#
# socket.gaierror and socket.herror are exception classes defined in the socket
# module. socket.timeout is an alias for the builtin TimeoutError.
#
# gaierror.__module__ == 'socket'   (len 6)
# herror.__module__   == 'socket'   (len 6)
# timeout.__module__  == 'builtins' (len 8)
#
# No prior spec checks __module__.__len__() for any of these exception classes.
# The difference between gaierror/herror ('socket') and timeout ('builtins')
# is a structurally interesting invariant showing timeout's builtin origin.
# ---------------------------------------------------------------------------

table socket_extra37.exception_module_lens:
  description: "socket.gaierror/herror/__module__.__len__()==6 ('socket') and socket.timeout/__module__.__len__()==8 ('builtins') — novel; no prior spec checks __module__.__len__() for any socket exception; timeout is an alias for builtins.TimeoutError"
  kind: python_call_eq
  category: module_metadata
  id_prefix: seml37

  columns: [id, function, args, expected]
  rows:
    - [gaierror_module_len, gaierror.__module__.__len__, [], 6]
    - [herror_module_len,   herror.__module__.__len__,   [], 6]
    - [timeout_module_len,  timeout.__module__.__len__,  [], 8]
