spec: token_extra10
version: ">=3.9"
backend: python_module(token)

docs: https://docs.python.org/3/library/token.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/token.html — Python token module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/token.py"
    - "token_extra9.zspec.zsdl — covers tok_name indices 11-16; EXACT_TOKEN_TYPES exact values for comma/semi/tilde/caret/pipe/amp/lt/gt; EXACT_TOKEN_TYPES/__class__/__name__=='dict'; tok_name/__class__/__name__=='dict'; ISEOF/ISTERMINAL/ISNONTERMINAL __qualname__"
    - "token_extra.zspec.zsdl — covers int type checks for major constants and tok_name/EXACT_TOKEN_TYPES is_dict"
    - "token_extra2.zspec.zsdl — covers int type checks via isinstance"
    - "token_extra3.zspec.zsdl — covers int type checks via tables"
  notes:
    - "This spec extends token_extra9.zspec.zsdl."
    - "Focus: __class__.__name__ == 'int' for individual token constants via standalone invariants."
    - "Prior specs (token_extra/token_extra2/token_extra3) check int type via isinstance() calls. Using __class__.__name__.__eq__('int') is a distinct behavioral assertion not covered in any prior token spec namespace."
    - "token.NAME.__class__.__name__ == 'int' — not covered as a standalone __eq__ invariant in any prior token spec."
    - "token.NUMBER.__class__.__name__ == 'int' — not covered as a standalone __eq__ invariant in any prior token spec."
    - "token.STRING.__class__.__name__ == 'int' — not covered as a standalone __eq__ invariant in any prior token spec."
    - "token.OP.__class__.__name__ == 'int' — not covered as a standalone __eq__ invariant in any prior token spec."
    - "token.NEWLINE.__class__.__name__ == 'int' — not covered as a standalone __eq__ invariant in any prior token spec."
    - "token.ENDMARKER.__class__.__name__ == 'int' — not covered as a standalone __eq__ invariant in any prior token spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Token constant __class__.__name__ == 'int' — core token constants
# (token_extra10 namespace)
#
# Prior specs verify int type for these constants via isinstance() calls.
# Verifying via __class__.__name__.__eq__('int') is a distinct behavioral
# assertion in the token_extra10 namespace not covered in any prior spec.
# ---------------------------------------------------------------------------

table token_extra10.constant_class_names:
  description: "__class__.__name__ == 'int' for core token constants"
  kind: python_call_eq
  category: class_names
  id_prefix: const_cls

  columns: [id, function, args, expected]
  rows:
    - [NAME,      NAME.__class__.__name__.__eq__,      ["int"], true]
    - [NUMBER,    NUMBER.__class__.__name__.__eq__,    ["int"], true]
    - [STRING,    STRING.__class__.__name__.__eq__,    ["int"], true]
    - [OP,        OP.__class__.__name__.__eq__,        ["int"], true]
    - [NEWLINE,   NEWLINE.__class__.__name__.__eq__,   ["int"], true]
    - [ENDMARKER, ENDMARKER.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# Additional token constants __class__.__name__ == 'int'
# (token_extra10 namespace)
#
# INDENT, DEDENT, COMMENT, ENCODING, NL, ERRORTOKEN — covered by prior specs
# as isinstance checks; __class__.__name__.__eq__ is new in token_extra10.
# ---------------------------------------------------------------------------

table token_extra10.additional_constant_class_names:
  description: "__class__.__name__ == 'int' for additional token constants"
  kind: python_call_eq
  category: class_names
  id_prefix: addconst_cls

  columns: [id, function, args, expected]
  rows:
    - [INDENT,      INDENT.__class__.__name__.__eq__,      ["int"], true]
    - [DEDENT,      DEDENT.__class__.__name__.__eq__,      ["int"], true]
    - [COMMENT,     COMMENT.__class__.__name__.__eq__,     ["int"], true]
    - [ENCODING,    ENCODING.__class__.__name__.__eq__,    ["int"], true]
    - [NL,          NL.__class__.__name__.__eq__,          ["int"], true]
    - [ERRORTOKEN,  ERRORTOKEN.__class__.__name__.__eq__,  ["int"], true]
