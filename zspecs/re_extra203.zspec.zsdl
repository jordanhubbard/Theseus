spec: re_extra203
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub, findall, split, escape, and compile error cases"
    - "re_extra202.zspec.zsdl — covers re class and function __doc__.__class__.__name__ identity"
  notes:
    - "This spec covers re function __code__.co_name identity not covered by prior re_extra specs."
    - "re.compile.__code__.co_name == 'compile'; the code object's co_name records the function name as defined; confirmed Python 3.14.3 macOS."
    - "re.match.__code__.co_name == 'match'; the match() function code object name matches the function name; confirmed Python 3.14.3 macOS."
    - "re.search.__code__.co_name == 'search'; the search() function code object name matches the function name; confirmed Python 3.14.3 macOS."
    - "re.sub.__code__.co_name == 'sub'; the sub() function code object name matches the function name; confirmed Python 3.14.3 macOS."
    - "re.subn.__code__.co_name == 'subn'; the subn() function code object name matches the function name; confirmed Python 3.14.3 macOS."
    - "re.split.__code__.co_name == 'split'; the split() function code object name matches the function name; confirmed Python 3.14.3 macOS."
    - "re.findall.__code__.co_name == 'findall'; the findall() function code object name matches the function name; confirmed Python 3.14.3 macOS."
    - "re.finditer.__code__.co_name == 'finditer'; the finditer() function code object name matches the function name; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re pattern-matching function __code__.co_name identity
# compile, match, search — co_name matches function name
# ---------------------------------------------------------------------------

table re_extra203.pattern_match_conames:
  description: "re pattern-matching function __code__.co_name: compile, match, search — co_name matches function name"
  kind: python_call_eq
  category: coname_identity
  id_prefix: reconames203

  columns: [id, function, args, expected, description]
  rows:
    - [compile_co_name, re.compile.__code__.co_name.__eq__, ["compile"], true, "re.compile.__code__.co_name == 'compile'; the code object records the name defined in the source; confirmed Python 3.14.3 macOS"]
    - [match_co_name,   re.match.__code__.co_name.__eq__,   ["match"],   true, "re.match.__code__.co_name == 'match'; tries to apply the pattern at the start of the string; confirmed Python 3.14.3 macOS"]
    - [search_co_name,  re.search.__code__.co_name.__eq__,  ["search"],  true, "re.search.__code__.co_name == 'search'; scans through the string for the first location where the pattern matches; confirmed Python 3.14.3 macOS"]
    - [compile_co_name_len, re.compile.__code__.co_name.__len__, [], 7, "re.compile.__code__.co_name.__len__() == 7 — 'compile' has c(1)o(2)m(3)p(4)i(5)l(6)e(7); confirmed Python 3.14.3 macOS"]
    - [match_co_name_len,   re.match.__code__.co_name.__len__,   [], 5, "re.match.__code__.co_name.__len__() == 5 — 'match' has m(1)a(2)t(3)c(4)h(5); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re substitution and split function __code__.co_name identity
# sub, subn, split — co_name matches function name
# ---------------------------------------------------------------------------

table re_extra203.substitution_split_conames:
  description: "re substitution and split function __code__.co_name: sub, subn, split — co_name matches function name"
  kind: python_call_eq
  category: coname_identity
  id_prefix: reconames203

  columns: [id, function, args, expected, description]
  rows:
    - [sub_co_name,    re.sub.__code__.co_name.__eq__,   ["sub"],   true, "re.sub.__code__.co_name == 'sub'; replaces occurrences of the pattern in the string; confirmed Python 3.14.3 macOS"]
    - [subn_co_name,   re.subn.__code__.co_name.__eq__,  ["subn"],  true, "re.subn.__code__.co_name == 'subn'; like sub() but returns a (new_string, count) tuple; confirmed Python 3.14.3 macOS"]
    - [split_co_name,  re.split.__code__.co_name.__eq__, ["split"], true, "re.split.__code__.co_name == 'split'; splits the string by occurrences of the pattern; confirmed Python 3.14.3 macOS"]
    - [sub_co_name_len,  re.sub.__code__.co_name.__len__,  [], 3, "re.sub.__code__.co_name.__len__() == 3 — 'sub' has s(1)u(2)b(3); confirmed Python 3.14.3 macOS"]
    - [search_co_name_len, re.search.__code__.co_name.__len__, [], 6, "re.search.__code__.co_name.__len__() == 6 — 'search' has s(1)e(2)a(3)r(4)c(5)h(6); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re findall and finditer function __code__.co_name identity
# findall, finditer — co_name matches function name
# ---------------------------------------------------------------------------

table re_extra203.find_conames:
  description: "re find function __code__.co_name: findall, finditer — co_name matches function name"
  kind: python_call_eq
  category: coname_identity
  id_prefix: reconames203

  columns: [id, function, args, expected, description]
  rows:
    - [findall_co_name,  re.findall.__code__.co_name.__eq__,  ["findall"],  true, "re.findall.__code__.co_name == 'findall'; returns all non-overlapping matches as a list; confirmed Python 3.14.3 macOS"]
    - [finditer_co_name, re.finditer.__code__.co_name.__eq__, ["finditer"], true, "re.finditer.__code__.co_name == 'finditer'; returns an iterator yielding match objects; confirmed Python 3.14.3 macOS"]
    - [findall_co_name_len,  re.findall.__code__.co_name.__len__,  [], 7, "re.findall.__code__.co_name.__len__() == 7 — 'findall' has f(1)i(2)n(3)d(4)a(5)l(6)l(7); confirmed Python 3.14.3 macOS"]
    - [finditer_co_name_len, re.finditer.__code__.co_name.__len__, [], 8, "re.finditer.__code__.co_name.__len__() == 8 — 'finditer' has f(1)i(2)n(3)d(4)i(5)t(6)e(7)r(8); confirmed Python 3.14.3 macOS"]
    - [subn_co_name_len,     re.subn.__code__.co_name.__len__,     [], 4, "re.subn.__code__.co_name.__len__() == 4 — 'subn' has s(1)u(2)b(3)n(4); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra203.compile_co_name:
  description: "re.compile.__code__.co_name == 'compile' — the code object co_name records the function name as defined in source; confirmed Python 3.14.3 macOS"
  category: coname_identity
  kind: python_call_eq
  function: re.compile.__code__.co_name.__eq__
  args: ["compile"]
  expected: true

invariant re_extra203.match_co_name:
  description: "re.match.__code__.co_name == 'match' — tries to apply pattern at start of string; co_name matches; confirmed Python 3.14.3 macOS"
  category: coname_identity
  kind: python_call_eq
  function: re.match.__code__.co_name.__eq__
  args: ["match"]
  expected: true

invariant re_extra203.search_co_name:
  description: "re.search.__code__.co_name == 'search' — scans through string for first match; co_name matches; confirmed Python 3.14.3 macOS"
  category: coname_identity
  kind: python_call_eq
  function: re.search.__code__.co_name.__eq__
  args: ["search"]
  expected: true

invariant re_extra203.sub_co_name:
  description: "re.sub.__code__.co_name == 'sub' — replaces occurrences of pattern in string; co_name matches; confirmed Python 3.14.3 macOS"
  category: coname_identity
  kind: python_call_eq
  function: re.sub.__code__.co_name.__eq__
  args: ["sub"]
  expected: true

invariant re_extra203.subn_co_name:
  description: "re.subn.__code__.co_name == 'subn' — like sub() but also returns substitution count; co_name matches; confirmed Python 3.14.3 macOS"
  category: coname_identity
  kind: python_call_eq
  function: re.subn.__code__.co_name.__eq__
  args: ["subn"]
  expected: true

invariant re_extra203.split_co_name:
  description: "re.split.__code__.co_name == 'split' — splits string by pattern occurrences; co_name matches; confirmed Python 3.14.3 macOS"
  category: coname_identity
  kind: python_call_eq
  function: re.split.__code__.co_name.__eq__
  args: ["split"]
  expected: true

invariant re_extra203.findall_co_name:
  description: "re.findall.__code__.co_name == 'findall' — returns all non-overlapping matches as a list; co_name matches; confirmed Python 3.14.3 macOS"
  category: coname_identity
  kind: python_call_eq
  function: re.findall.__code__.co_name.__eq__
  args: ["findall"]
  expected: true

invariant re_extra203.finditer_co_name:
  description: "re.finditer.__code__.co_name == 'finditer' — returns an iterator yielding match objects over all matches; co_name matches; confirmed Python 3.14.3 macOS"
  category: coname_identity
  kind: python_call_eq
  function: re.finditer.__code__.co_name.__eq__
  args: ["finditer"]
  expected: true

