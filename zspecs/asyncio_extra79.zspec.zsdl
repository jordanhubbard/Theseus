invariant asyncio_extra79.Semaphore_acquire_co_name:
  description: "asyncio.Semaphore.acquire.__code__.co_name.__eq__('acquire') returns True — Semaphore.acquire is a coroutine method in asyncio/locks.py; code object co_name matches the method name; NEW in extra79: first standalone co_name invariant for Semaphore.acquire in asynciomore79 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Semaphore.acquire.__code__.co_name.__eq__
  args: ["acquire"]
  expected: true

invariant asyncio_extra79.Semaphore_acquire_co_argcount:
  description: "asyncio.Semaphore.acquire.__code__.co_argcount.__eq__(1) returns True — only self is a positional parameter; blocking and timeout are keyword-only (counted in co_kwonlyargcount); NEW in extra79: first standalone co_argcount invariant for Semaphore.acquire in asynciomore79 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
