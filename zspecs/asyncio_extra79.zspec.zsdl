table asyncio_extra79.Semaphore_acquire_and_release_code_attrs:
  description: "asyncio Semaphore.acquire and release code attribute checks in asynciomore79 namespace — wave 244 theme: Semaphore/BoundedSemaphore/Condition code attributes; Semaphore.acquire.__code__.co_name=='acquire' (code object co_name matches method name); Semaphore.acquire.__code__.co_argcount==1 (self only; blocking and timeout are keyword-only); Semaphore.release.__code__.co_name=='release'; Semaphore.release.__code__.co_argcount==1 (self only); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asynciomore79

  columns: [id, function, args, expected, description]
  rows:
    - [sem_acquire_co_name,     Semaphore.acquire.__code__.co_name.__eq__,     ["acquire"], true, "Semaphore.acquire.__code__.co_name == 'acquire' — code object co_name matches the method name; verified with Python 3.14.3"]
    - [sem_acquire_co_argcount, Semaphore.acquire.__code__.co_argcount.__eq__,  [1],         true, "Semaphore.acquire.__code__.co_argcount == 1 — only self is positional; blocking and timeout are keyword-only; verified with Python 3.14.3"]
    - [sem_release_co_name,     Semaphore.release.__code__.co_name.__eq__,     ["release"], true, "Semaphore.release.__code__.co_name == 'release' — code object co_name matches the method name; verified with Python 3.14.3"]
    - [sem_release_co_argcount, Semaphore.release.__code__.co_argcount.__eq__,  [1],         true, "Semaphore.release.__code__.co_argcount == 1 — only self is a positional parameter; verified with Python 3.14.3"]

