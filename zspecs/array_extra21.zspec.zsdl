spec: array_extra21
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
    - "array.zspec.zsdl — baseline typecode, itemsize, and instance vectors."
    - "array_extra.zspec.zsdl through array_extra20.zspec.zsdl — prior extras."
  notes:
    - "This spec extends array.zspec.zsdl through array_extra20.zspec.zsdl."
    - "Focus: array.array class method __qualname__ values."
    - "array_extra4 covers array.array.__qualname__ == 'array' (the class qualname)."
    - "array_extra6 covers array.array.__qualname__.__eq__ in a table row."
    - "array_extra14 covers array.array.__qualname__.__len__() == 5."
    - "No prior array spec checks __qualname__ on the individual bound methods of array.array."
    - "For methods defined on a class 'array', Python sets __qualname__ to 'array.<method>'."
    - "array.array.append.__qualname__ == 'array.append' — Verified Python 3.12 macOS."
    - "array.array.extend.__qualname__ == 'array.extend' — Verified."
    - "array.array.pop.__qualname__ == 'array.pop' — Verified."
    - "array.array.insert.__qualname__ == 'array.insert' — Verified."
    - "array.array.remove.__qualname__ == 'array.remove' — Verified."
    - "array.array.reverse.__qualname__ == 'array.reverse' — Verified."
    - "array.array.tolist.__qualname__ == 'array.tolist' — Verified."
    - "array.array.tobytes.__qualname__ == 'array.tobytes' — Verified."
    - "array.array.frombytes.__qualname__ == 'array.frombytes' — Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# array.array class method __qualname__ values
#
# array_extra4/extra6/extra14 check array.array.__qualname__ (the class qualname).
# No prior spec checks __qualname__ on individual methods of array.array.
# In CPython, array.array methods are slot wrapper descriptors or method
# descriptors; their __qualname__ is 'array.<method>'.
# Under python_module(array) backend, 'array.append.__qualname__.__eq__'
# resolves as array_module.array.append.__qualname__.__eq__.
# ---------------------------------------------------------------------------

table array_extra21.method_qualnames:
  description: "array.array class method __qualname__ attributes — all are of the form 'array.<method>'"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: aqn21

  columns: [id, function, args, expected]
  rows:
    - [append,    "array.append.__qualname__.__eq__",    ["array.append"],    true]
    - [extend,    "array.extend.__qualname__.__eq__",    ["array.extend"],    true]
    - [pop,       "array.pop.__qualname__.__eq__",       ["array.pop"],       true]
    - [insert,    "array.insert.__qualname__.__eq__",    ["array.insert"],    true]
    - [remove,    "array.remove.__qualname__.__eq__",    ["array.remove"],    true]
    - [reverse,   "array.reverse.__qualname__.__eq__",   ["array.reverse"],   true]
    - [tolist,    "array.tolist.__qualname__.__eq__",    ["array.tolist"],    true]
    - [tobytes,   "array.tobytes.__qualname__.__eq__",   ["array.tobytes"],   true]
    - [frombytes, "array.frombytes.__qualname__.__eq__", ["array.frombytes"], true]
