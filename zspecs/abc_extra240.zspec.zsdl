spec: abc_extra240
version: ">=3.4"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/library/abc.html#abc.ABC — ABC class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py and Objects/typeobject.c (internal C implementation)"
  notes:
    - "This spec covers abc.ABC __init__ and __new__ method identity."
    - "ABC.__init__ is inherited from object — __qualname__ == 'object.__init__' (len=15)."
    - "ABC.__new__ is inherited from object — __qualname__ == 'object.__new__' (len=14)."
    - "ABC.__init__.__class__.__name__ == 'wrapper_descriptor' (len=18) — C slot wrapper."
    - "ABC.__new__.__class__.__name__ == 'builtin_function_or_method' (len=26) — C builtin."
    - "ABC.__init__.__name__ == '__init__' (len=8); ABC.__new__.__name__ == '__new__' (len=7)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABC.__init__ method identity
#
# ABC.__init__ is inherited from object (C slot wrapper).
# __name__ == '__init__' (len=8)
# __qualname__ == 'object.__init__' (len=15)
# __class__.__name__ == 'wrapper_descriptor' (len=18)
# ---------------------------------------------------------------------------

table abc_extra240.abc_init_identity:
  description: "abc.ABC.__init__ method identity — ABC.__init__ is inherited from object (not overridden in ABC); ABC.__init__.__name__.__eq__('__init__')==True (len=8); ABC.__init__.__qualname__.__eq__('object.__init__')==True (len=15, reflects the defining class 'object'); ABC.__init__.__class__.__name__.__eq__('wrapper_descriptor')==True (len=18, C slot wrapper as opposed to a Python function); ABC.__init__.__name__.__len__()==8 ('__init__' = 8 chars including dunder underscores); ABC.__init__.__qualname__.__len__()==15; verified with Python 3.14.3"
  kind: python_call_eq
  category: abc_init_identity
  id_prefix: abc240init

  columns: [id, function, args, expected, description]
  rows:
    - [init_name_eq,    ABC.__init__.__name__.__eq__,          ["__init__"],        true, "abc.ABC.__init__.__name__ == '__init__'; verified with Python 3.14.3"]
    - [init_name_len,   ABC.__init__.__name__.__len__,         [],                  8,    "abc.ABC.__init__.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [init_qname_eq,   ABC.__init__.__qualname__.__eq__,      ["object.__init__"], true, "abc.ABC.__init__.__qualname__ == 'object.__init__' (inherited from object); verified with Python 3.14.3"]
    - [init_qname_len,  ABC.__init__.__qualname__.__len__,     [],                  15,   "abc.ABC.__init__.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [init_cls_nm_eq,  ABC.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true, "abc.ABC.__init__.__class__.__name__ == 'wrapper_descriptor' (C slot wrapper); verified with Python 3.14.3"]
    - [init_cls_nm_len, ABC.__init__.__class__.__name__.__len__, [],                18,   "abc.ABC.__init__.__class__.__name__.__len__() == 18 ('wrapper_descriptor'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABC.__new__ method identity
#
# ABC.__new__ is inherited from object (C builtin function).
# __name__ == '__new__' (len=7)
# __qualname__ == 'object.__new__' (len=14)
# __class__.__name__ == 'builtin_function_or_method' (len=26)
# ---------------------------------------------------------------------------

table abc_extra240.abc_new_identity:
  description: "abc.ABC.__new__ method identity — ABC.__new__ is inherited from object (not overridden in ABC); ABC.__new__.__name__.__eq__('__new__')==True (len=7); ABC.__new__.__qualname__.__eq__('object.__new__')==True (len=14, reflects the defining class 'object'; one char shorter than ABC.__init__.__qualname__.__len__()==15 because '__new__'=7 vs '__init__'=8); ABC.__new__.__class__.__name__.__eq__('builtin_function_or_method')==True (len=26, C builtin, different from ABC.__init__.__class__.__name__=='wrapper_descriptor'); ABC.__new__.__name__.__len__()==7; verified with Python 3.14.3"
  kind: python_call_eq
  category: abc_new_identity
  id_prefix: abc240init

  columns: [id, function, args, expected, description]
  rows:
    - [new_name_eq,    ABC.__new__.__name__.__eq__,          ["__new__"],        true, "abc.ABC.__new__.__name__ == '__new__'; verified with Python 3.14.3"]
    - [new_name_len,   ABC.__new__.__name__.__len__,         [],                 7,    "abc.ABC.__new__.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [new_qname_eq,   ABC.__new__.__qualname__.__eq__,      ["object.__new__"], true, "abc.ABC.__new__.__qualname__ == 'object.__new__' (inherited from object); verified with Python 3.14.3"]
    - [new_qname_len,  ABC.__new__.__qualname__.__len__,     [],                 14,   "abc.ABC.__new__.__qualname__.__len__() == 14; verified with Python 3.14.3"]
    - [new_cls_nm_eq,  ABC.__new__.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "abc.ABC.__new__.__class__.__name__ == 'builtin_function_or_method' (C builtin); verified with Python 3.14.3"]
    - [new_cls_nm_len, ABC.__new__.__class__.__name__.__len__, [],               26,   "abc.ABC.__new__.__class__.__name__.__len__() == 26 ('builtin_function_or_method'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra240
# ---------------------------------------------------------------------------

invariant abc_extra240.abc_init_qualname_from_object:
  description: "abc.ABC.__init__.__qualname__.__eq__('object.__init__') returns True — ABC does not override __init__, so it inherits the slot wrapper from the built-in 'object' type; __qualname__ == 'object.__init__' (len=15 = len('object.')+len('__init__') = 7+8); this qualname reveals the defining class is 'object', not 'ABC'; contrast with a Python method which would show 'ABC.__init__'; ABC.__init__.__class__.__name__ == 'wrapper_descriptor'; NEW in extra240: first standalone ABC init qualname invariant in abc240init namespace; verified with Python 3.14.3"
  category: abc_init_identity
  kind: python_call_eq
  function: ABC.__init__.__qualname__.__eq__
  args: ["object.__init__"]
  expected: true

invariant abc_extra240.abc_new_qualname_from_object:
  description: "abc.ABC.__new__.__qualname__.__eq__('object.__new__') returns True — ABC does not override __new__, so it inherits the C builtin from the built-in 'object' type; __qualname__ == 'object.__new__' (len=14 = len('object.')+len('__new__') = 7+7); one char shorter than ABC.__init__.__qualname__.__len__()==15 because '__new__'=7 vs '__init__'=8; this qualname reveals the defining class is 'object', not 'ABC'; ABC.__new__.__class__.__name__ == 'builtin_function_or_method'; NEW in extra240: first standalone ABC new qualname invariant; verified with Python 3.14.3"
  category: abc_new_identity
  kind: python_call_eq
  function: ABC.__new__.__qualname__.__eq__
  args: ["object.__new__"]
  expected: true

invariant abc_extra240.abc_init_class_is_wrapper_descriptor:
  description: "abc.ABC.__init__.__class__.__name__.__eq__('wrapper_descriptor') returns True — ABC.__init__ is a C slot wrapper (wrapper_descriptor), not a Python function (class='function') or a builtin function (class='builtin_function_or_method'); len('wrapper_descriptor')==18; contrast with ABC.__new__.__class__.__name__ == 'builtin_function_or_method' (len=26); wrapper_descriptor is the class of C slot wrappers in CPython; __name__ == '__init__' (len=8); __qualname__ == 'object.__init__' (len=15); NEW in extra240; verified with Python 3.14.3"
  category: abc_init_identity
  kind: python_call_eq
  function: ABC.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant abc_extra240.abc_new_class_is_builtin_function_or_method:
  description: "abc.ABC.__new__.__class__.__name__.__eq__('builtin_function_or_method') returns True — ABC.__new__ is a C builtin function (builtin_function_or_method, len=26), different from ABC.__init__.__class__.__name__ == 'wrapper_descriptor' (len=18); 'builtin_function_or_method' is the class of built-in functions and methods in CPython; __name__ == '__new__' (len=7); __qualname__ == 'object.__new__' (len=14); the difference in __class__.__name__ between __init__ and __new__ reflects different CPython implementation details; NEW in extra240; verified with Python 3.14.3"
  category: abc_new_identity
  kind: python_call_eq
  function: ABC.__new__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra240.abc_init_name_len_8:
  description: "abc.ABC.__init__.__name__.__len__() == 8 — '__init__' has 8 chars: _-_-i-n-i-t-_-_ (two leading and two trailing underscores around 'init'=4); compare ABC.__new__.__name__.__len__()==7 ('__new__' is 7 chars, one less because 'new'=3 vs 'init'=4); ABC.__init__.__qualname__.__len__()==15 ('object.__init__'); ABC.__init__.__class__.__name__ == 'wrapper_descriptor'; NEW in extra240: first standalone ABC init name length invariant; verified with Python 3.14.3"
  category: abc_init_identity
  kind: python_call_eq
  function: ABC.__init__.__name__.__len__
  args: []
  expected: 8

invariant abc_extra240.abc_new_name_len_7:
  description: "abc.ABC.__new__.__name__.__len__() == 7 — '__new__' has 7 chars: _-_-n-e-w-_-_ (two leading and two trailing underscores around 'new'=3); compare ABC.__init__.__name__.__len__()==8 ('__init__' is 8 chars, one more because 'init'=4 vs 'new'=3); ABC.__new__.__qualname__.__len__()==14 ('object.__new__'); ABC.__new__.__class__.__name__ == 'builtin_function_or_method' (len=26); NEW in extra240: first standalone ABC new name length invariant; verified with Python 3.14.3"
  category: abc_new_identity
  kind: python_call_eq
  function: ABC.__new__.__name__.__len__
  args: []
  expected: 7
