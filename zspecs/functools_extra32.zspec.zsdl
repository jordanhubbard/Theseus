spec: functools_extra32
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra31.zspec.zsdl."
    - "functools_extra31 covers: partial/lru_cache/update_wrapper/partialmethod __module__; update_wrapper/partialmethod __qualname__; partial/partialmethod __bases__[0].__name__; reduce __module__ and __qualname__ standalones."
    - "functools_extra30 covers: singledispatch/total_ordering/cached_property/wraps __module__; cmp_to_key __module__; total_ordering/cmp_to_key qualnames."
    - "functools_extra29 covers: partial/cached_property/singledispatch class-level qualnames."
    - "This spec covers: partial/__module__, partial/__qualname__, cached_property/__module__, cached_property/__qualname__, lru_cache/__module__, reduce/__module__, wraps/__module__, total_ordering/__module__, singledispatch/__module__, cmp_to_key/__module__, partial/__init__.__name__ — all in the extra32 namespace."
    - "Key findings: cmp_to_key.__module__ == '_functools' and reduce.__module__ == '_functools' (C extension); all others report 'functools'. partial.__init__.__name__ == '__init__' (inherited from object's slot wrapper)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__eq__ table — Python-attributed functools callables
#
# partial, cached_property, lru_cache, wraps, total_ordering, and singledispatch
# all report 'functools' as their __module__. partial and lru_cache are C-level
# types but are attributed to the public namespace. wraps, total_ordering, and
# singledispatch are Python-level. cached_property is Python-level. No prior
# functools spec records all six together in the extra32 namespace.
# ---------------------------------------------------------------------------

table functools_extra32.public_modules:
  kind: python_call_eq
  category: module_membership
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra32.public_modules.partial,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__ == 'functools'"]
    - [functools_extra32.public_modules.cached_property,
       cached_property.__module__.__eq__,
       ["functools"],
       true,
       "functools.cached_property.__module__ == 'functools'"]
    - [functools_extra32.public_modules.lru_cache,
       lru_cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.lru_cache.__module__ == 'functools'"]
    - [functools_extra32.public_modules.wraps,
       wraps.__module__.__eq__,
       ["functools"],
       true,
       "functools.wraps.__module__ == 'functools'"]
    - [functools_extra32.public_modules.total_ordering,
       total_ordering.__module__.__eq__,
       ["functools"],
       true,
       "functools.total_ordering.__module__ == 'functools'"]
    - [functools_extra32.public_modules.singledispatch,
       singledispatch.__module__.__eq__,
       ["functools"],
       true,
       "functools.singledispatch.__module__ == 'functools'"]

# ---------------------------------------------------------------------------
# __module__.__eq__ table — C-extension attributed functools callables
#
# functools.reduce and functools.cmp_to_key are both implemented in the
# _functoolsmodule.c C extension. Their __module__ is '_functools', not
# 'functools', distinguishing them from other functools callables. This table
# groups the two C-extension attributed callables. No prior functools spec
# records both together in the extra32 namespace.
# ---------------------------------------------------------------------------

table functools_extra32.cext_modules:
  kind: python_call_eq
  category: module_membership
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra32.cext_modules.reduce,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__ == '_functools'"]
    - [functools_extra32.cext_modules.cmp_to_key,
       cmp_to_key.__module__.__eq__,
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__ == '_functools'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — C-level class qualnames
#
# functools.partial and functools.cached_property both have simple qualnames
# equal to their class names, confirming they are defined at module scope.
# partial is a C-level type; cached_property is Python-level. extra29 records
# these qualnames in the extra29 namespace; this table records them in the
# extra32 namespace. No prior functools spec records both together in the
# extra32 namespace.
# ---------------------------------------------------------------------------

table functools_extra32.class_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra32.class_qualnames.partial,
       partial.__qualname__.__eq__,
       ["partial"],
       true,
       "functools.partial.__qualname__ == 'partial'"]
    - [functools_extra32.class_qualnames.cached_property,
       cached_property.__qualname__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__qualname__ == 'cached_property'"]

# ---------------------------------------------------------------------------
# partial.__init__.__name__.__eq__ — standalone method name
#
# functools.partial is a C-level type. Accessing partial.__init__ yields the
# slot wrapper '__init__' inherited from object. The __name__ of this slot
# wrapper is '__init__', confirming the standard initializer name. This
# distinguishes the C-level slot wrapper from a custom Python __init__ method.
# No prior functools spec records this standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra32.partial.init_name:
  description: "functools.partial.__init__.__name__ == '__init__'"
  category: method_names
  kind: python_call_eq
  function: partial.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# partial.__module__.__eq__ — standalone module membership
#
# functools.partial is a C-level type (defined in _functoolsmodule.c) but its
# __module__ is 'functools', the public module name. This contrasts with
# functools.reduce which is also C-level but reports '_functools'. The
# distinction reflects how each type was registered with the public namespace.
# No prior functools spec records this standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra32.partial.module:
  description: "functools.partial.__module__ == 'functools'"
  category: module_membership
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

# ---------------------------------------------------------------------------
# partial.__qualname__.__eq__ — standalone class qualname
#
# functools.partial is a C-level class defined at module scope. Its qualname is
# 'partial', a simple name with no enclosing scope. extra29 records this in the
# extra29 namespace; this standalone records it in the extra32 namespace.
# No prior functools spec records this standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra32.partial.qualname:
  description: "functools.partial.__qualname__ == 'partial'"
  category: qualnames
  kind: python_call_eq
  function: partial.__qualname__.__eq__
  args: ["partial"]
  expected: true
