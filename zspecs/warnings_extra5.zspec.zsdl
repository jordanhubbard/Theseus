spec: warnings_extra5
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Python/_warnings.c"
  notes:
    - "This spec extends warnings.zspec.zsdl, warnings_extra.zspec.zsdl, warnings_extra2.zspec.zsdl, and warnings_extra4.zspec.zsdl."
    - "Focus: __qualname__ for warn, warn_explicit, filterwarnings, simplefilter, resetwarnings, catch_warnings, WarningMessage; and __class__.__name__ for built-in warning categories."
    - "DeprecationWarning, UserWarning, FutureWarning, RuntimeWarning are built-in exception classes; their __class__ is 'type'."
    - "WarningMessage is a class defined in the warnings module; its __qualname__ == 'WarningMessage'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — table for warn, warn_explicit, filterwarnings,
#                        simplefilter, resetwarnings
# ---------------------------------------------------------------------------

table warnings_extra5.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [warn,             warn.__qualname__.__eq__,             ["warn"],             true]
    - [warn_explicit,    warn_explicit.__qualname__.__eq__,    ["warn_explicit"],    true]
    - [filterwarnings,   filterwarnings.__qualname__.__eq__,   ["filterwarnings"],   true]
    - [simplefilter,     simplefilter.__qualname__.__eq__,     ["simplefilter"],     true]
    - [resetwarnings,    resetwarnings.__qualname__.__eq__,    ["resetwarnings"],    true]

# ---------------------------------------------------------------------------
# __qualname__ checks — catch_warnings and WarningMessage (individual invariants)
# ---------------------------------------------------------------------------

invariant warnings_extra5.catch_warnings.qualname:
  description: "warnings.catch_warnings.__qualname__ == 'catch_warnings'"
  category: qualnames
  kind: python_call_eq
  function: catch_warnings.__qualname__.__eq__
  args: ["catch_warnings"]
  expected: true

invariant warnings_extra5.WarningMessage.qualname:
  description: "warnings.WarningMessage.__qualname__ == 'WarningMessage'"
  category: qualnames
  kind: python_call_eq
  function: WarningMessage.__qualname__.__eq__
  args: ["WarningMessage"]
  expected: true

# ---------------------------------------------------------------------------
# Built-in warning category classes — __class__.__name__ == 'type'
# ---------------------------------------------------------------------------

table warnings_extra5.warning_categories.class_names:
  kind: python_call_eq
  category: warning_categories
  id_prefix: category

  columns: [id, function, args, expected]
  rows:
    - [DeprecationWarning,  DeprecationWarning.__class__.__name__.__eq__,  ["type"], true]
    - [UserWarning,         UserWarning.__class__.__name__.__eq__,         ["type"], true]
    - [FutureWarning,       FutureWarning.__class__.__name__.__eq__,       ["type"], true]
    - [RuntimeWarning,      RuntimeWarning.__class__.__name__.__eq__,      ["type"], true]
