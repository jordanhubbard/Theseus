spec: in2866
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 638 (in2866): __rand__, __ror__, __rxor__ dict-presence checks for inspect module types."
    - "inspect classes are introspection/metadata types — none define reflected bitwise AND, OR, or XOR operators."
    - "Verified types: inspect.Parameter, inspect.BoundArguments, inspect.Signature, inspect.FullArgSpec, inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, inspect.ClosureVars."
    - "Several inspect types are namedtuples (FullArgSpec, FrameInfo, ArgInfo, Traceback, ClosureVars); namedtuples do not define bitwise operators."
    - "All values verified as False with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in2866.rand:
  description: "inspect types __rand__ dict-presence checks; wave 638"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2866
  columns: [id, function, args, expected]
  rows:
    - ["in2866001", operator.contains, [inspect.Parameter.__dict__,       "__rand__"], false]
    - ["in2866002", operator.contains, [inspect.BoundArguments.__dict__,  "__rand__"], false]
    - ["in2866003", operator.contains, [inspect.Signature.__dict__,       "__rand__"], false]
    - ["in2866004", operator.contains, [inspect.FullArgSpec.__dict__,     "__rand__"], false]
    - ["in2866005", operator.contains, [inspect.FrameInfo.__dict__,       "__rand__"], false]
    - ["in2866006", operator.contains, [inspect.ClosureVars.__dict__,     "__rand__"], false]

