    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio.Queue, asyncio.Lock, and asyncio.Event method qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra976.queue_method_qualnames:
  description: "asyncio.Queue method __qualname__ identity"
  kind: python_call_eq
  category: queue_method_qualnames
  id_prefix: as976qm
  columns: [id, function, args, expected]
  rows:
    - [as976qm001, asyncio.Queue.__init__.__qualname__.__eq__, ["Queue.__init__"], true]
    - [as976qm002, asyncio.Queue.get.__qualname__.__eq__,      ["Queue.get"],      true]
    - [as976qm003, asyncio.Queue.put.__qualname__.__eq__,      ["Queue.put"],      true]
    - [as976qm004, asyncio.Queue.empty.__qualname__.__eq__,    ["Queue.empty"],    true]
    - [as976qm005, asyncio.Queue.full.__qualname__.__eq__,     ["Queue.full"],     true]
    - [as976qm006, asyncio.Queue.get_nowait.__qualname__.__eq__, ["Queue.get_nowait"], true]
    - [as976qm007, asyncio.Queue.put_nowait.__qualname__.__eq__, ["Queue.put_nowait"], true]

