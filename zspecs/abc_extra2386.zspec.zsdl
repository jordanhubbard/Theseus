spec: abc_extra2386
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec classifies __str__ and __repr__ implementation types for abc module classes."
    - "abc.ABC is a helper class; both __str__ and __repr__ are inherited from object: 'wrapper_descriptor'."
    - "abc.ABCMeta is a metaclass inheriting from type; both __str__ and __repr__ are 'wrapper_descriptor'."
    - "abc.abstractmethod is a class whose instances are decorated functions. At the class level, __str__ and __repr__ are 'method-wrapper' — bound wrappers on the abstractmethod class object itself."
    - "abstractmethod.__str__.__class__.__name__ == 'method-wrapper' and __repr__.__class__.__name__ == 'method-wrapper'."
    - "'method-wrapper' length is 14 characters."
    - "'wrapper_descriptor' length is 18 characters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: abc.ABC __str__ and __repr__ implementation type
#
# ABC is a simple helper class. It defines no __str__ or __repr__, so both
# are inherited from object: 'wrapper_descriptor'.
# ---------------------------------------------------------------------------

table abc_extra2386.abc_str_repr:
  description: "abc.ABC __str__ and __repr__ implementation type classification; new to extra2386"
  kind: python_call_eq
  category: str_repr_type
  id_prefix: ab2386

  columns: [id, function, args, expected]
  rows:
    - ["ab2386001",
       ABC.__str__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["ab2386002",
       ABC.__repr__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["ab2386003",
       ABC.__str__.__class__.__name__.__len__,
       [],
       18]
    - ["ab2386004",
       ABC.__repr__.__class__.__name__.__len__,
       [],
       18]
    - ["ab2386005",
       ABC.__str__.__class__.__name__.__contains__,
       ["wrapper"],
       true]
    - ["ab2386006",
       ABC.__repr__.__class__.__name__.__contains__,
       ["descriptor"],
       true]

# ---------------------------------------------------------------------------
# Table 2: abc.ABCMeta __str__ and __repr__ implementation type
#
# ABCMeta is a metaclass inheriting from type. Neither __str__ nor __repr__
# is overridden; both resolve to 'wrapper_descriptor' inherited from object.
# ---------------------------------------------------------------------------

table abc_extra2386.abcmeta_str_repr:
  description: "abc.ABCMeta __str__ and __repr__ implementation type classification; new to extra2386"
  kind: python_call_eq
  category: str_repr_type
  id_prefix: ab2386

  columns: [id, function, args, expected]
  rows:
    - ["ab2386007",
       ABCMeta.__str__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["ab2386008",
       ABCMeta.__repr__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["ab2386009",
       ABCMeta.__str__.__class__.__name__.__len__,
       [],
       18]
    - ["ab2386010",
       ABCMeta.__repr__.__class__.__name__.__len__,
       [],
       18]
    - ["ab2386011",
       ABCMeta.__str__.__class__.__name__.__contains__,
       ["descriptor"],
       true]
    - ["ab2386012",
       ABCMeta.__repr__.__class__.__name__.__contains__,
       ["wrapper"],
       true]

# ---------------------------------------------------------------------------
# Table 3: abc.abstractmethod __str__ and __repr__ implementation type
#
# abstractmethod is a class (decorator factory). At the class level,
# __str__ and __repr__ are 'method-wrapper' — bound wrappers on the class
# object itself, not plain function or slot descriptors.
# This is distinct from the 'wrapper_descriptor' seen on ABC and ABCMeta.
# ---------------------------------------------------------------------------

table abc_extra2386.abstractmethod_str_repr:
  description: "abc.abstractmethod __str__ and __repr__ implementation type classification; new to extra2386"
  kind: python_call_eq
  category: str_repr_type
  id_prefix: ab2386

  columns: [id, function, args, expected]
  rows:
    - ["ab2386013",
       abstractmethod.__str__.__class__.__name__.__eq__,
       ["method-wrapper"],
       true]
    - ["ab2386014",
       abstractmethod.__repr__.__class__.__name__.__eq__,
       ["method-wrapper"],
       true]
    - ["ab2386015",
       abstractmethod.__str__.__class__.__name__.__len__,
       [],
       14]
    - ["ab2386016",
       abstractmethod.__repr__.__class__.__name__.__len__,
       [],
       14]
    - ["ab2386017",
       abstractmethod.__str__.__class__.__name__.__contains__,
       ["method"],
       true]
    - ["ab2386018",
       abstractmethod.__repr__.__class__.__name__.__contains__,
       ["wrapper"],
       true]

# ---------------------------------------------------------------------------
# Table 4: cross-class __str__ type comparison in abc module
#
# ABC and ABCMeta both yield 'wrapper_descriptor' for __str__ and __repr__,
# contrasting with abstractmethod which yields 'method-wrapper'.
# ---------------------------------------------------------------------------

table abc_extra2386.cross_class_str_repr:
  description: "Cross-class: ABC vs ABCMeta vs abstractmethod __str__/__repr__ type patterns; new to extra2386"
  kind: python_call_eq
  category: str_repr_type
  id_prefix: ab2386

  columns: [id, function, args, expected]
  rows:
    - ["ab2386019",
       ABC.__str__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["ab2386020",
       ABCMeta.__str__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["ab2386021",
       abstractmethod.__str__.__class__.__name__.__eq__,
       ["method-wrapper"],
       true]
    - ["ab2386022",
       abstractmethod.__repr__.__class__.__name__.__eq__,
       ["method-wrapper"],
       true]
