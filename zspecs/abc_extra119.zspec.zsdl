table abc_extra119.abc_instancecheck_subclasscheck_covarnames:
  description: "abc.ABCMeta.__instancecheck__ and __subclasscheck__ co_varnames checks in abccovar119 namespace — wave 255 theme: ABCMeta.__instancecheck__ is Python-defined in Lib/abc.py (class='function', unlike ABCMeta.__subclasshook__ which is C-level); ABCMeta.__instancecheck__.__class__.__name__.__eq__('function')==True; ABCMeta.__instancecheck__.__code__.co_varnames[0].__eq__('cls')==True (first param is the metaclass); ABCMeta.__instancecheck__.__code__.co_varnames[1].__eq__('instance')==True (second param is the object to test); ABCMeta.__instancecheck__.__code__.co_argcount.__eq__(2)==True (two parameters); ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__')==True; ABCMeta.__instancecheck__.__qualname__.__len__()==25 ('ABCMeta.'=8+'__instancecheck__'=17=25); similarly ABCMeta.__subclasscheck__.__class__.__name__.__eq__('function')==True; ABCMeta.__subclasscheck__.__code__.co_varnames[0].__eq__('cls')==True; ABCMeta.__subclasscheck__.__code__.co_varnames[1].__eq__('subclass')==True; ABCMeta.__subclasscheck__.__code__.co_argcount.__eq__(2)==True; ABCMeta.__subclasscheck__.__qualname__.__len__()==25 (same length as __instancecheck__: 'ABCMeta.'=8+'__subclasscheck__'=17=25); both check functions have exactly 2 co_varnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_inspection
  id_prefix: abccovar119a

  columns: [id, function, args, expected, description]
  rows:
    - [ic_cls,       abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__,          ["function"],              true, "ABCMeta.__instancecheck__.__class__.__name__ == 'function' (Python-defined); verified with Python 3.14.3"]
    - [ic_var0_eq,   abc.ABCMeta.__instancecheck__.__code__.co_varnames.__getitem__,   [0],                       "cls",      "ABCMeta.__instancecheck__.__code__.co_varnames[0] == 'cls'; verified with Python 3.14.3"]
    - [ic_var1_eq,   abc.ABCMeta.__instancecheck__.__code__.co_varnames.__getitem__,   [1],                       "instance", "ABCMeta.__instancecheck__.__code__.co_varnames[1] == 'instance'; verified with Python 3.14.3"]
    - [ic_argcount,  abc.ABCMeta.__instancecheck__.__code__.co_argcount.__eq__,         [2],                       true, "ABCMeta.__instancecheck__.__code__.co_argcount == 2 (cls, instance); verified with Python 3.14.3"]
    - [ic_qn_len,    abc.ABCMeta.__instancecheck__.__qualname__.__len__,                [],                        25,   "ABCMeta.__instancecheck__.__qualname__.__len__() == 25 ('ABCMeta.'=8+'__instancecheck__'=17=25); verified with Python 3.14.3"]
    - [sc_cls,       abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__,          ["function"],              true, "ABCMeta.__subclasscheck__.__class__.__name__ == 'function' (Python-defined); verified with Python 3.14.3"]
    - [sc_var0_eq,   abc.ABCMeta.__subclasscheck__.__code__.co_varnames.__getitem__,   [0],                       "cls",      "ABCMeta.__subclasscheck__.__code__.co_varnames[0] == 'cls'; verified with Python 3.14.3"]
    - [sc_var1_eq,   abc.ABCMeta.__subclasscheck__.__code__.co_varnames.__getitem__,   [1],                       "subclass", "ABCMeta.__subclasscheck__.__code__.co_varnames[1] == 'subclass'; verified with Python 3.14.3"]
    - [sc_argcount,  abc.ABCMeta.__subclasscheck__.__code__.co_argcount.__eq__,         [2],                       true, "ABCMeta.__subclasscheck__.__code__.co_argcount == 2 (cls, subclass); verified with Python 3.14.3"]
    - [sc_qn_len,    abc.ABCMeta.__subclasscheck__.__qualname__.__len__,                [],                        25,   "ABCMeta.__subclasscheck__.__qualname__.__len__() == 25 (same as __instancecheck__: 'ABCMeta.'=8+'__subclasscheck__'=17=25); verified with Python 3.14.3"]

