# ABCMeta._dump_registry.__code__.co_varnames[0] == 'cls'
# ABCMeta._dump_registry.__code__.co_varnames[1] == 'file'
# ABCMeta._dump_registry.__code__.co_varnames.__len__() == 6
# ABCMeta._dump_registry.__code__.co_argcount  == 2
# ---------------------------------------------------------------------------

table abc_extra119.abc_abstractmethod_dumpregistry_covarnames:
  description: "abc.abstractmethod and abc.ABCMeta._dump_registry co_varnames checks in abccovar119 namespace — wave 255 theme: abstractmethod is a Python function decorator (class='function'); abstractmethod.__code__.co_varnames[0].__eq__('funcobj')==True (the single parameter is named 'funcobj', not 'func' or 'fn', reflecting the full name 'function object'); abstractmethod.__code__.co_argcount.__eq__(1)==True (one parameter: funcobj); abstractmethod.__code__.co_varnames.__len__()==1 (exactly one varname, no local variables); ABCMeta._dump_registry is also a Python classmethod; _dump_registry.__code__.co_varnames[0].__eq__('cls')==True; _dump_registry.__code__.co_varnames[1].__eq__('file')==True (second parameter is the file to print to, defaults to sys.stdout); _dump_registry.__code__.co_argcount.__eq__(2)==True (cls, file); _dump_registry.__code__.co_varnames.__len__()==6 (6 total varnames: cls, file, plus 4 local loop variables: _abc_registry, _abc_cache, _abc_negative_cache, _abc_negative_cache_version); compare with register (2 varnames=2 params, no locals) and abstractmethod (1 varname=1 param, no locals); _dump_registry has the most local variables (4) of all abc functions in this spec; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_inspection
  id_prefix: abccovar119b

  columns: [id, function, args, expected, description]
  rows:
    - [am_var0_eq,   abc.abstractmethod.__code__.co_varnames.__getitem__,             [0],       "funcobj", "abstractmethod.__code__.co_varnames[0] == 'funcobj' (not 'func' or 'fn'; full name); verified with Python 3.14.3"]
    - [am_var0_len,  "abc.abstractmethod.__code__.co_varnames[0].__len__",              [],         7,         "abstractmethod.__code__.co_varnames[0].__len__() == 7 (len of 'funcobj'=7); verified with Python 3.14.3"]
    - [am_argcount,  abc.abstractmethod.__code__.co_argcount.__eq__,                  [1],        true,      "abstractmethod.__code__.co_argcount == 1 (single parameter: funcobj); verified with Python 3.14.3"]
    - [am_vlen,      abc.abstractmethod.__code__.co_varnames.__len__,                 [],         1,         "abstractmethod.__code__.co_varnames.__len__() == 1 (one varname, no local variables); verified with Python 3.14.3"]
    - [dr_var0_eq,   abc.ABCMeta._dump_registry.__code__.co_varnames.__getitem__,     [0],       "cls",     "_dump_registry.__code__.co_varnames[0] == 'cls' (classmethod param); verified with Python 3.14.3"]
    - [dr_var1_eq,   abc.ABCMeta._dump_registry.__code__.co_varnames.__getitem__,     [1],       "file",    "_dump_registry.__code__.co_varnames[1] == 'file' (file param, defaults to sys.stdout); verified with Python 3.14.3"]
    - [dr_argcount,  abc.ABCMeta._dump_registry.__code__.co_argcount.__eq__,           [2],       true,      "_dump_registry.__code__.co_argcount == 2 (cls, file); verified with Python 3.14.3"]
    - [dr_vlen,      abc.ABCMeta._dump_registry.__code__.co_varnames.__len__,         [],         6,         "_dump_registry.__code__.co_varnames.__len__() == 6 (2 params + 4 local vars); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra119
# ---------------------------------------------------------------------------

invariant abc_extra119.ABCMeta_register_varnames_len_2:
  description: "abc.ABCMeta.register.__code__.co_varnames.__len__() == 2 — ABCMeta.register.__code__.co_varnames is ('cls', 'subclass') with exactly 2 entries; co_argcount is also 2, confirming that all varnames are parameters with no additional local variables beyond the parameters; ABCMeta.register.__code__.co_varnames[0] is 'cls' (the metaclass parameter, since register is a classmethod); ABCMeta.register.__code__.co_varnames[1] is 'subclass' (the class to register as a virtual subclass); compare _dump_registry which has 6 co_varnames (2 params + 4 locals) — register is simpler with only 2 varnames=2 params; abstractmethod has 1 varname=1 param; NEW in extra119: first standalone ABCMeta.register co_varnames length invariant in abccovar119 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: abc.ABCMeta.register.__code__.co_varnames.__len__
  args: []
  expected: 2

invariant abc_extra119.ABCMeta_instancecheck_qualname_len_25:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — ABCMeta.__instancecheck__.__qualname__ is 'ABCMeta.__instancecheck__' (25 chars: 'ABCMeta.'=8 + '__instancecheck__'=17=25); ABCMeta.__instancecheck__ is a Python-defined function (class='function'), unlike ABCMeta.__subclasshook__ (class='builtin_function_or_method'); __instancecheck__ is called by isinstance() when the second argument is an ABCMeta instance; compare qualname lengths in extra99: ABCMeta.__subclasshook__=24, then ABCMeta.__instancecheck__=25 (one longer than __subclasshook__); compare with ABCMeta.__subclasscheck__.__qualname__.__len__()==25 (same length, both have 17-char dunder names: '__instancecheck__'=17, '__subclasscheck__'=17); NEW in extra119: first standalone ABCMeta.__instancecheck__ qualname length invariant in abccovar119 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__qualname__.__len__
  args: []
  expected: 25

invariant abc_extra119.ABCMeta_subclasscheck_varnames_1_is_subclass:
  description: "abc.ABCMeta.__subclasscheck__.__code__.co_varnames.__getitem__(1).__eq__('subclass') returns 'subclass' — ABCMeta.__subclasscheck__.__code__.co_varnames[1] is 'subclass'; compare with ABCMeta.__instancecheck__.__code__.co_varnames[1] which is 'instance' — the parameter names distinguish the check type: __instancecheck__ checks if an instance belongs to a class (second param='instance'), while __subclasscheck__ checks if a class is a subclass (second param='subclass'); both co_argcount values are 2; both qualnames have length 25; both are Python-defined functions (class='function'); __subclasscheck__ is called by issubclass() when the second argument is an ABCMeta instance; NEW in extra119: first standalone ABCMeta.__subclasscheck__ varnames[1] invariant in abccovar119 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: abc.ABCMeta.__subclasscheck__.__code__.co_varnames.__getitem__
  args: [1]
  expected: "subclass"

invariant abc_extra119.abstractmethod_varnames_0_is_funcobj:
  description: "abc.abstractmethod.__code__.co_varnames.__getitem__(0).__eq__('funcobj') returns 'funcobj' — abc.abstractmethod is a Python function decorator; its single parameter is named 'funcobj' (7 chars), not the more common 'func' (4 chars) or 'fn' (2 chars); this distinctive parameter name signals that abstractmethod expects a callable function object; abstractmethod.__code__.co_argcount is 1 (single parameter); abstractmethod.__code__.co_varnames.__len__() is 1 (no local variables beyond the parameter); abstractmethod.__code__.co_varnames[0].__len__() is 7; compare: ABCMeta.register.__code__.co_varnames[0] is 'cls' (3 chars), ABCMeta._dump_registry.__code__.co_varnames[1] is 'file' (4 chars); NEW in extra119: first standalone abstractmethod co_varnames[0] invariant in abccovar119 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_varnames.__getitem__
  args: [0]
  expected: "funcobj"

invariant abc_extra119.ABCMeta_dump_registry_varnames_len_6:
  description: "abc.ABCMeta._dump_registry.__code__.co_varnames.__len__() == 6 — _dump_registry.__code__.co_varnames is ('cls', 'file', '_abc_registry', '_abc_cache', '_abc_negative_cache', '_abc_negative_cache_version') with 6 entries; co_argcount is 2 (only cls and file are formal parameters); the remaining 4 entries are local variables unpacked from the C-level ABC cache query; _dump_registry has the most co_varnames among the abc functions in this spec: register=2, abstractmethod=1, __instancecheck__=2, __subclasscheck__=2, _dump_registry=6; the 4 extra local variables (prefixed with '_abc_') reflect the four cache structures maintained by the C-level ABC implementation in _abc.c; NEW in extra119: first standalone _dump_registry co_varnames length invariant in abccovar119 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: abc.ABCMeta._dump_registry.__code__.co_varnames.__len__
  args: []
  expected: 6
