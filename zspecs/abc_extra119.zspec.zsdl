spec: abc_extra119
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: wave 255 theme — abc ABCMeta method co_varnames for register, __instancecheck__, and __subclasscheck__. NEW in extra119: abc.ABCMeta.register.__code__.co_varnames[0]=='cls'; abc.ABCMeta.register.__code__.co_varnames[1]=='subclass'; abc.ABCMeta.register.__code__.co_varnames.__len__()==2; abc.ABCMeta.register.__code__.co_argcount==2 (cls, subclass); abc.ABCMeta.__instancecheck__.__class__.__name__=='function' (Python-defined in abc.py, unlike __subclasshook__ which is C-level); abc.ABCMeta.__instancecheck__.__code__.co_varnames[0]=='cls'; abc.ABCMeta.__instancecheck__.__code__.co_varnames[1]=='instance'; abc.ABCMeta.__instancecheck__.__code__.co_argcount==2; abc.ABCMeta.__instancecheck__.__qualname__.__len__()==25; abc.ABCMeta.__subclasscheck__.__class__.__name__=='function'; abc.ABCMeta.__subclasscheck__.__code__.co_varnames[0]=='cls'; abc.ABCMeta.__subclasscheck__.__code__.co_varnames[1]=='subclass'; abc.ABCMeta.__subclasscheck__.__code__.co_argcount==2; abc.ABCMeta.__subclasscheck__.__qualname__.__len__()==25; abc.abstractmethod.__code__.co_varnames[0]=='funcobj'; abc.ABCMeta._dump_registry.__code__.co_varnames.__len__()==6; abc.ABCMeta._dump_registry.__code__.co_varnames[1]=='file'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__instancecheck__ and __subclasscheck__ are Python functions (class='function'). Both are defined in Lib/abc.py (not C builtins), unlike ABCMeta.__subclasshook__ (class='builtin_function_or_method'). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25. 'ABCMeta.__instancecheck__' is 25 chars: 'ABCMeta.'=8 + '__instancecheck__'=17. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__subclasscheck__.__qualname__.__len__() == 25. 'ABCMeta.__subclasscheck__' is 25 chars: 'ABCMeta.'=8 + '__subclasscheck__'=17. Both __instancecheck__ and __subclasscheck__ qualnames have length 25. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta._dump_registry.__code__.co_varnames.__len__() == 6. The 6 varnames are: cls, file, _abc_registry, _abc_cache, _abc_negative_cache, _abc_negative_cache_version. co_argcount==2 (only cls and file are parameters; the other 4 are local variables). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta.register co_varnames — extra119
#
# Wave 255 theme: abc ABCMeta method co_varnames.
#
# ABCMeta.register.__code__.co_varnames[0]    == 'cls'
# ABCMeta.register.__code__.co_varnames[1]    == 'subclass'
# ABCMeta.register.__code__.co_varnames.__len__() == 2
# ABCMeta.register.__code__.co_argcount       == 2
# ABCMeta.register.__class__.__name__         == 'function'
# ABCMeta.register.__qualname__               == 'ABCMeta.register' (len=16)
# ---------------------------------------------------------------------------

table abc_extra119.abc_register_covarnames:
  description: "abc.ABCMeta.register __code__ co_varnames and identity checks in abccovar119 namespace — wave 255 theme: ABCMeta.register is a Python-defined classmethod (class='function'); ABCMeta.register.__code__.co_varnames[0].__eq__('cls')==True (first varname is cls, the class parameter for the classmethod; when called via @classmethod descriptor, cls receives the metaclass); ABCMeta.register.__code__.co_varnames[0].__len__()==3; ABCMeta.register.__code__.co_varnames[1].__eq__('subclass')==True (second varname is subclass, the class to register as a virtual subclass); ABCMeta.register.__code__.co_varnames[1].__len__()==8; ABCMeta.register.__code__.co_varnames.__len__()==2 (exactly 2 varnames, one per parameter; no local variables beyond the parameters); ABCMeta.register.__code__.co_argcount.__eq__(2)==True (two positional parameters: cls and subclass); ABCMeta.register.__class__.__name__.__eq__('function')==True (Python-defined, unlike C-level builtin_function_or_method); ABCMeta.register.__qualname__.__eq__('ABCMeta.register')==True (len=16: 'ABCMeta.'=8+'register'=8); ABCMeta.register.__qualname__.__len__()==16; register() is used to declare a class as a virtual subclass of an ABC without inheriting from it; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_inspection
  id_prefix: abccovar119

  columns: [id, function, args, expected, description]
  rows:
    - [reg_var0_eq,   abc.ABCMeta.register.__code__.co_varnames.__getitem__,  [0],            "cls",     "ABCMeta.register.__code__.co_varnames[0] == 'cls' (classmethod parameter); verified with Python 3.14.3"]
    - [reg_var0_len,  "abc.ABCMeta.register.__code__.co_varnames[0].__len__",   [],             3,         "ABCMeta.register.__code__.co_varnames[0].__len__() == 3 (len of 'cls'=3); verified with Python 3.14.3"]
    - [reg_var1_eq,   abc.ABCMeta.register.__code__.co_varnames.__getitem__,  [1],            "subclass", "ABCMeta.register.__code__.co_varnames[1] == 'subclass' (virtual subclass argument); verified with Python 3.14.3"]
    - [reg_var1_len,  "abc.ABCMeta.register.__code__.co_varnames[1].__len__",   [],             8,         "ABCMeta.register.__code__.co_varnames[1].__len__() == 8 (len of 'subclass'=8); verified with Python 3.14.3"]
    - [reg_vlen,      abc.ABCMeta.register.__code__.co_varnames.__len__,       [],             2,         "ABCMeta.register.__code__.co_varnames.__len__() == 2 (exactly 2 varnames, one per parameter); verified with Python 3.14.3"]
    - [reg_argcount,  abc.ABCMeta.register.__code__.co_argcount.__eq__,        [2],            true,      "ABCMeta.register.__code__.co_argcount == 2 (cls, subclass); verified with Python 3.14.3"]
    - [reg_cls,       abc.ABCMeta.register.__class__.__name__.__eq__,          ["function"],   true,      "ABCMeta.register.__class__.__name__ == 'function' (Python-defined classmethod); verified with Python 3.14.3"]
    - [reg_qn_eq,     abc.ABCMeta.register.__qualname__.__eq__,                ["ABCMeta.register"], true, "ABCMeta.register.__qualname__ == 'ABCMeta.register' (len=16); verified with Python 3.14.3"]

