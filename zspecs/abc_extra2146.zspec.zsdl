spec: abc_extra2146
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "abc_extra2131.zspec.zsdl — covers exception protocol dict-presence wave"
    - "abc_extra2116.zspec.zsdl — covers bitwise operator protocol dict-presence wave"
  notes:
    - "Wave (_extra2146): numeric conversion protocol dict-presence — checking __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__ in class __dict__."
    - "abc module classes (ABCMeta, ABC, abstractmethod) are abstract base class infrastructure; none define numeric conversion protocol methods."
    - "abc.ABCMeta.__dict__ contains __new__, register, __instancecheck__, __subclasscheck__, and related metaclass machinery — no numeric protocol dunders."
    - "abc.ABC.__dict__ contains __slots__, __abstractmethods__, and _abc_impl — no numeric protocol dunders."
    - "abc.abstractmethod is a function (not a class); its __dict__ is the function attribute namespace, which is empty — no numeric protocol dunders."
    - "Positive control rows confirm that ABCMeta and ABC __dict__ contain their own machinery entries, validating the lookup mechanism."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra2146.trunc_floor_ceil:
  description: "abc classes __dict__ numeric conversion dict-presence — __trunc__, __floor__, __ceil__ absent from ABCMeta, ABC, abstractmethod class dicts"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2146

  columns: [id, function, args, expected]
  rows:
    - ["ab2146001", "abc.ABCMeta.__dict__.__contains__", ["__trunc__"], false]
    - ["ab2146002", "abc.ABCMeta.__dict__.__contains__", ["__floor__"], false]
    - ["ab2146003", "abc.ABCMeta.__dict__.__contains__", ["__ceil__"], false]
    - ["ab2146004", "abc.ABC.__dict__.__contains__", ["__trunc__"], false]
    - ["ab2146005", "abc.ABC.__dict__.__contains__", ["__floor__"], false]
    - ["ab2146006", "abc.ABC.__dict__.__contains__", ["__ceil__"], false]
    - ["ab2146007", "abc.abstractmethod.__dict__.__contains__", ["__trunc__"], false]
    - ["ab2146008", "abc.abstractmethod.__dict__.__contains__", ["__floor__"], false]
    - ["ab2146009", "abc.abstractmethod.__dict__.__contains__", ["__ceil__"], false]

