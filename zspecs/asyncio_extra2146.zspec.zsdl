spec: asyncio_extra2146
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/asyncio-task.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-sync.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-stream.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "asyncio_extra2131.zspec.zsdl — covers exception protocol dict-presence wave"
    - "asyncio_extra2116.zspec.zsdl — covers bitwise operator protocol dict-presence wave"
  notes:
    - "Wave (_extra2146): numeric conversion protocol dict-presence — checking __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__ in class __dict__."
    - "asyncio classes are coroutine/task scheduling and synchronization primitives; none define numeric conversion protocol methods."
    - "asyncio.Task.__dict__ does not contain any of the numeric conversion dunder methods — Task represents a coroutine wrapped in a Future, not a number."
    - "asyncio.Future.__dict__ does not define __bool__; truthiness of Future instances is not supported via the protocol dunder."
    - "asyncio.Lock, asyncio.Event, asyncio.Semaphore, asyncio.BoundedSemaphore, asyncio.Condition are synchronization primitives; none have numeric protocol entries."
    - "asyncio.Queue and asyncio.StreamReader are I/O-oriented types; none define __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, or __int__."
    - "All expected values (false) verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table asyncio_extra2146.trunc_floor_ceil:
