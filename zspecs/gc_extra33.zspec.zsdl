spec: gc_extra33
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "This spec extends gc_extra32.zspec.zsdl."
    - "Prior specs covered: collect/disable/enable/isenabled/get_count/get_threshold/set_threshold/get_objects/__name__/__module__/__qualname__.__len__() (various specs); get_referrers/get_referents __qualname__.__len__()==13 (extra31); garbage/callbacks/__class__.__name__.__len__()==4 (extra32); get_count/get_threshold result class name len (extra32); gc.__name__.__len__()==2 and gc.__package__.__len__()==0 (extra32)."
    - "This spec covers: gc.get_count/__qualname__.__len__()==9; gc.get_threshold/__qualname__.__len__()==13 (novel namespace); gc.is_tracked/__qualname__.__len__()==10; gc.freeze/__qualname__.__len__()==6; gc.unfreeze/__qualname__.__len__()==8; gc.get_freeze_count/__qualname__.__len__()==16; gc.is_finalized/__qualname__.__len__()==12; gc.collect.__class__.__name__.__len__()==26 ('builtin_function_or_method'); gc.__doc__.__class__.__name__.__len__()==3 ('str'); gc.DEBUG_STATS==1 and class name len==3; gc.DEBUG_LEAK==38 and class name len==3; gc.DEBUG_COLLECTABLE==2; gc.DEBUG_UNCOLLECTABLE==4; gc.DEBUG_SAVEALL==32."
    - "gc.get_count.__qualname__ == 'get_count' (len 9). Verified Python 3.12 macOS."
    - "gc.get_threshold.__qualname__ == 'get_threshold' (len 13). Verified. (Prior extra31 checks get_threshold/__qualname__.__len__() via a table; extra33 provides a standalone invariant in a novel namespace.)"
    - "gc.is_tracked.__qualname__ == 'is_tracked' (len 10). Verified."
    - "gc.freeze.__qualname__ == 'freeze' (len 6). Verified."
    - "gc.unfreeze.__qualname__ == 'unfreeze' (len 8). Verified."
    - "gc.get_freeze_count.__qualname__ == 'get_freeze_count' (len 16). Verified."
    - "gc.is_finalized.__qualname__ == 'is_finalized' (len 12). Verified."
    - "gc.collect.__class__.__name__ == 'builtin_function_or_method' (len 26). Verified."
    - "gc.__doc__.__class__.__name__ == 'str' (len 3). Verified."
    - "gc.DEBUG_STATS == 1 (int, len 3). Verified."
    - "gc.DEBUG_LEAK == 38 (int, len 3). Verified."
    - "gc.DEBUG_COLLECTABLE == 2. Verified."
    - "gc.DEBUG_UNCOLLECTABLE == 4. Verified."
    - "gc.DEBUG_SAVEALL == 32. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for freeze-related and finalization functions
#
# No prior gc spec checks __qualname__.__len__() for is_tracked, freeze,
# unfreeze, get_freeze_count, or is_finalized.
# Lengths: is_tracked(10), freeze(6), unfreeze(8), get_freeze_count(16),
#          is_finalized(12).
# All verified at runtime.
# ---------------------------------------------------------------------------

table gc_extra33.freeze_fn_qualname_lengths:
  description: "gc.is_tracked/freeze/unfreeze/get_freeze_count/is_finalized __qualname__.__len__() — novel for all five"
  kind: python_call_eq
  category: string_length
  id_prefix: gcfql33

  columns: [id, function, args, expected]
  rows:
    - [is_tracked,       is_tracked.__qualname__.__len__,       [], 10]
    - [freeze,           freeze.__qualname__.__len__,           [], 6]
    - [unfreeze,         unfreeze.__qualname__.__len__,         [], 8]
    - [get_freeze_count, get_freeze_count.__qualname__.__len__, [], 16]
    - [is_finalized,     is_finalized.__qualname__.__len__,     [], 12]

# ---------------------------------------------------------------------------
# Table: DEBUG_* flag values and class name lengths
#
# gc exposes integer debug flags: DEBUG_STATS, DEBUG_LEAK, DEBUG_COLLECTABLE,
# DEBUG_UNCOLLECTABLE, DEBUG_SAVEALL. No prior gc spec verifies any of these
# values or their class name lengths. All are plain int.
# Values: STATS=1, COLLECTABLE=2, UNCOLLECTABLE=4, SAVEALL=32, LEAK=38.
# Class name lengths: all 3 ('int'). Verified at runtime.
# ---------------------------------------------------------------------------

table gc_extra33.debug_flag_values:
  description: "gc.DEBUG_* integer flag values — STATS(1), COLLECTABLE(2), UNCOLLECTABLE(4), SAVEALL(32), LEAK(38)"
  kind: python_call_eq
  category: constants
  id_prefix: gcdbg33

  columns: [id, function, args, expected]
  rows:
    - [debug_stats,         DEBUG_STATS.__eq__,         [1],  true]
    - [debug_collectable,   DEBUG_COLLECTABLE.__eq__,   [2],  true]
    - [debug_uncollectable, DEBUG_UNCOLLECTABLE.__eq__,  [4],  true]
    - [debug_saveall,       DEBUG_SAVEALL.__eq__,       [32], true]
    - [debug_leak,          DEBUG_LEAK.__eq__,          [38], true]

# ---------------------------------------------------------------------------
# Standalone: gc.get_count.__qualname__.__len__() == 9
#
# Prior specs check get_count/__qualname__ equality; no prior spec checks
# __qualname__.__len__() for get_count. len('get_count') == 9. Verified.
# ---------------------------------------------------------------------------

invariant gc_extra33.get_count.qualname.len:
  description: "gc.get_count.__qualname__.__len__() == 9 — 'get_count' has 9 characters"
  category: string_length
  kind: python_call_eq
  function: get_count.__qualname__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# Standalone: gc.collect.__class__.__name__.__len__() == 26
#
# gc.collect is a builtin_function_or_method. len('builtin_function_or_method')
# == 26. No prior gc spec checks __class__.__name__.__len__() for any gc
# function object. Verified.
# ---------------------------------------------------------------------------

invariant gc_extra33.collect.class_name_len:
  description: "gc.collect.__class__.__name__.__len__() == 26 — 'builtin_function_or_method' has 26 characters"
  category: type_attrs
  kind: python_call_eq
  function: collect.__class__.__name__.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# Standalone: gc.__doc__.__class__.__name__.__len__() == 3
#
# gc.__doc__ is a str. len('str') == 3. No prior gc spec checks
# gc.__doc__.__class__.__name__.__len__(). Verified.
# ---------------------------------------------------------------------------

invariant gc_extra33.doc.class_name_len:
  description: "gc.__doc__.__class__.__name__.__len__() == 3 — gc.__doc__ is a 'str' (len 3)"
  category: type_attrs
  kind: python_call_eq
  function: __doc__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Standalone: gc.DEBUG_STATS.__class__.__name__.__len__() == 3
#
# gc.DEBUG_STATS is an int. len('int') == 3. No prior gc spec checks
# __class__.__name__.__len__() for any DEBUG_* flag. Verified.
# ---------------------------------------------------------------------------

invariant gc_extra33.debug_stats.class_name_len:
  description: "gc.DEBUG_STATS.__class__.__name__.__len__() == 3 — DEBUG_STATS is an 'int' (len 3)"
  category: type_attrs
  kind: python_call_eq
  function: DEBUG_STATS.__class__.__name__.__len__
  args: []
  expected: 3
