spec: traceback_extra11
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends traceback.zspec.zsdl through traceback_extra10.zspec.zsdl."
    - "traceback_extra10 covers: TracebackException/StackSummary/FrameSummary MRO entries by index; StackSummary.format.__qualname__; TracebackException.__init__.__qualname__; FrameSummary.__getitem__/__len__ qualnames."
    - "traceback_extra8 covers: function __name__ via __eq__ predicate form for print_exc/print_tb/print_stack/format_exc/format_tb/format_stack/clear_frames."
    - "traceback_extra7 covers: function __module__ for format_exception/print_exception/walk_tb/walk_stack/clear_frames/format_exception_only/print_list/print_stack/format_list."
    - "traceback_extra5 covers: class __qualname__ for TracebackException/StackSummary/FrameSummary; function __qualname__ for print_exc/format_exc/format_tb/print_tb/extract_tb/extract_stack/format_stack."
    - "NOT yet covered: extract_tb.__name__.__eq__('extract_tb') predicate form — extra8 skipped extract_tb."
    - "NOT yet covered: extract_stack.__name__.__eq__('extract_stack') predicate form — extra8 skipped extract_stack."
    - "NOT yet covered: format_exception/__name__ via __eq__ predicate form."
    - "NOT yet covered: print_exception/__name__ via __eq__ predicate form."
    - "NOT yet covered: walk_tb/__name__ via __eq__ predicate form."
    - "NOT yet covered: walk_stack/__name__ via __eq__ predicate form."
    - "NOT yet covered: format_exc() return type as a method_chain invariant — checking __class__.__name__ == 'str'."
    - "traceback.format_exc() with no active exception returns 'NoneType\\n' as a str; the return type is always str."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# format_exc() return type check — method_chain form
#
# No prior traceback spec calls format_exc() and then inspects the return value's
# type. format_exc() always returns a str. This invariant uses the method_chain
# form to verify that the return value's __class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

invariant traceback_extra11.format_exc.returns_str:
  description: "traceback.format_exc() returns a str — __class__.__name__ == 'str'"
  category: return_types
  kind: python_call_eq
  function: format_exc
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ identity checks — __eq__ predicate form for remaining
# functions not covered by traceback_extra8
#
# traceback_extra8 covers: print_exc/print_tb/print_stack/format_exc/format_tb/
# format_stack/clear_frames. These remaining functions were covered earlier only
# via table rows with direct expected strings — the __eq__ predicate form (
# expected: true) is a distinct structural form not previously used for this set.
# ---------------------------------------------------------------------------

invariant traceback_extra11.extract_tb.name_eq:
  description: "traceback.extract_tb.__name__.__eq__('extract_tb') == True"
  category: function_names
  kind: python_call_eq
  function: extract_tb.__name__.__eq__
  args: ["extract_tb"]
  expected: true

invariant traceback_extra11.extract_stack.name_eq:
  description: "traceback.extract_stack.__name__.__eq__('extract_stack') == True"
  category: function_names
  kind: python_call_eq
  function: extract_stack.__name__.__eq__
  args: ["extract_stack"]
  expected: true

invariant traceback_extra11.format_exception.name_eq:
  description: "traceback.format_exception.__name__.__eq__('format_exception') == True"
  category: function_names
  kind: python_call_eq
  function: format_exception.__name__.__eq__
  args: ["format_exception"]
  expected: true

invariant traceback_extra11.print_exception.name_eq:
  description: "traceback.print_exception.__name__.__eq__('print_exception') == True"
  category: function_names
  kind: python_call_eq
  function: print_exception.__name__.__eq__
  args: ["print_exception"]
  expected: true

invariant traceback_extra11.walk_tb.name_eq:
  description: "traceback.walk_tb.__name__.__eq__('walk_tb') == True"
  category: function_names
  kind: python_call_eq
  function: walk_tb.__name__.__eq__
  args: ["walk_tb"]
  expected: true

invariant traceback_extra11.walk_stack.name_eq:
  description: "traceback.walk_stack.__name__.__eq__('walk_stack') == True"
  category: function_names
  kind: python_call_eq
  function: walk_stack.__name__.__eq__
  args: ["walk_stack"]
  expected: true

invariant traceback_extra11.format_exception_only.name_eq:
  description: "traceback.format_exception_only.__name__.__eq__('format_exception_only') == True"
  category: function_names
  kind: python_call_eq
  function: format_exception_only.__name__.__eq__
  args: ["format_exception_only"]
  expected: true

invariant traceback_extra11.format_list.name_eq:
  description: "traceback.format_list.__name__.__eq__('format_list') == True"
  category: function_names
  kind: python_call_eq
  function: format_list.__name__.__eq__
  args: ["format_list"]
  expected: true

invariant traceback_extra11.print_list.name_eq:
  description: "traceback.print_list.__name__.__eq__('print_list') == True"
  category: function_names
  kind: python_call_eq
  function: print_list.__name__.__eq__
  args: ["print_list"]
  expected: true

invariant traceback_extra11.print_stack.name_eq:
  description: "traceback.print_stack.__name__.__eq__('print_stack') == True"
  category: function_names
  kind: python_call_eq
  function: print_stack.__name__.__eq__
  args: ["print_stack"]
