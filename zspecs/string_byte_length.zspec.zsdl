spec: string_byte_length
version: ">=3.0.1"
backend: node(string-byte-length)

docs: https://www.npmjs.com/package/string-byte-length

provenance:
  derived_from:
    - "string-byte-length README — https://www.npmjs.com/package/string-byte-length"
    - "Test vectors verified with string-byte-length via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "string-byte-length source"
  notes:
    - "string-byte-length is an npm package. Install: npm install string-byte-length"
    - "Returns the byte length of a string when encoded as UTF-8."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an integer."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table string_byte_length.measure:
  kind: node_module_call_eq
  function: "default"
  category: string
  id_prefix: sblen

  columns: [id, args, expected]
  rows:
    - [ascii,    ["hello"],  5]
    - [unicode,  ["héllo"],  6]
    - [empty,    [""],       0]
