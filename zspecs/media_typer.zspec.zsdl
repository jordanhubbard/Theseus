spec: media_typer
version: ">=0.3.0"
backend: node(media-typer)

docs: https://github.com/jshttp/media-typer#readme

provenance:
  derived_from:
    - "media-typer README — https://github.com/jshttp/media-typer#readme"
    - "RFC 6838 — Media Type Specifications and Registration Procedures"
    - "Test vectors verified with media-typer@0.3.0 via Node.js 25.6.0 on macOS/Darwin 25.4.0, 2026-04-09"
    - "media-typer source: index.js (MIT; source inspection permitted)"
  not_derived_from:
    - "media-typer source: internal regex validation details"
  notes:
    - "media-typer exports parse() and format() as named methods on the module object."
    - "parse() splits a full media type string into {type, subtype, parameters} and optional suffix."
    - "For structured syntax types (e.g. application/vnd.api+json), suffix captures the +suffix part."
    - "format() recombines {type, subtype, suffix?} back into a media type string."
    - "format() with a structured suffix produces 'type/subtype+suffix'."
    - "format() throws TypeError if type or subtype are invalid (e.g. contain '+' in subtype without suffix field)."
    - "parameters field in parse result is always an empty object {}; parameters are not parsed by this library."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Throws TypeError for invalid input. node exits 0 for valid invariants."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# media-typer.parse — media type string to {type, subtype, parameters[, suffix]}
# ---------------------------------------------------------------------------

table media_typer.parse.basic:
  kind: node_module_call_eq
  function: parse
  id_prefix: parse

  columns: [id, category, args, expected]
  rows:
    - [text_html,             parse,    ["text/html"],                          {type: "text", subtype: "html", parameters: {}}]
    - [image_png,             parse,    ["image/png"],                          {type: "image", subtype: "png", parameters: {}}]
    - [application_json,      parse,    ["application/json"],                   {type: "application", subtype: "json", parameters: {}}]
    - [text_plain,            parse,    ["text/plain"],                         {type: "text", subtype: "plain", parameters: {}}]
    - [video_mp4,             parse,    ["video/mp4"],                          {type: "video", subtype: "mp4", parameters: {}}]
    - [form_urlencoded,       parse,    ["application/x-www-form-urlencoded"],  {type: "application", subtype: "x-www-form-urlencoded", parameters: {}}]
    - [vnd_structured,        parse,    ["application/vnd.api+json"],           {type: "application", subtype: "vnd.api", suffix: "json", parameters: {}}]
    - [octet_stream,          parse,    ["application/octet-stream"],           {type: "application", subtype: "octet-stream", parameters: {}}]

# ---------------------------------------------------------------------------
# media-typer.format — {type, subtype[, suffix]} to media type string
# ---------------------------------------------------------------------------

table media_typer.format.basic:
  kind: node_module_call_eq
  function: format
  id_prefix: format

  columns: [id, category, args, expected]
  rows:
    - [text_html,             format,   [{type: "text", subtype: "html"}],                          "text/html"]
    - [image_png,             format,   [{type: "image", subtype: "png"}],                          "image/png"]
    - [application_json,      format,   [{type: "application", subtype: "json"}],                   "application/json"]
    - [text_plain,            format,   [{type: "text", subtype: "plain"}],                         "text/plain"]
    - [video_mp4,             format,   [{type: "video", subtype: "mp4"}],                          "video/mp4"]
    - [form_urlencoded,       format,   [{type: "application", subtype: "x-www-form-urlencoded"}],  "application/x-www-form-urlencoded"]
    - [vnd_with_suffix,       format,   [{type: "application", subtype: "vnd.api", suffix: "json"}], "application/vnd.api+json"]
    - [octet_stream,          format,   [{type: "application", subtype: "octet-stream"}],           "application/octet-stream"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-04-15T07:59:09Z
  iterations: 1
  pass_count: 16
  fail_count: 0
  total_invariants: 16
  notes: Synthesis succeeded in 1 iteration(s). 16 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
