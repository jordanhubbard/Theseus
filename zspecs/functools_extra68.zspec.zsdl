spec: functools_extra68
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra67.zspec.zsdl."
    - "Wave 229 theme: __defaults__ and __kwdefaults__ checks for function parameters + __code__ attribute identity + __closure__ checks."
    - "wraps.__defaults__ is a tuple of 2 elements: the default for assigned (a tuple of str names) and the default for updated (a tuple of str names). wraps.__defaults__.__class__.__name__ == 'tuple'. Prior functools specs do not check __defaults__ for wraps."
    - "update_wrapper.__defaults__ is also a tuple of 2 elements — identical in content to wraps.__defaults__ because wraps calls update_wrapper with the same defaults. update_wrapper.__defaults__.__class__.__name__ == 'tuple'."
    - "reduce is a C builtin_function_or_method (Modules/_functoolsmodule.c). It has no __defaults__ attribute at all (hasattr returns False). Accessing reduce.__defaults__ raises AttributeError. No prior functools spec tests reduce.__defaults__."
    - "lru_cache.__defaults__ is a tuple of 2 elements: (128, False) — maxsize=128 and typed=False. lru_cache.__defaults__.__class__.__name__ == 'tuple'."
    - "partial is a C extension type (class). It has no __code__ attribute (hasattr returns False). Accessing partial.__code__ raises AttributeError."
    - "wraps.__code__.__class__.__name__ == 'code' — wraps is a pure-Python function; its __code__ is a code object. update_wrapper.__code__.__class__.__name__ == 'code'. lru_cache.__code__.__class__.__name__ == 'code'."
    - "wraps.__closure__ is None — wraps is a module-level function, not a closure. update_wrapper.__closure__ is None for the same reason."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "No prior functools spec checks __defaults__.__class__.__name__, __code__.__class__.__name__, or __closure__ for any functools function. All checks in this spec are new to extra68."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools __defaults__.__class__.__name__ — extra68
#
# Wave 229 theme: __defaults__ checks for function parameters.
#
# For Python functions, __defaults__ is a tuple of default values for
# positional parameters with defaults, or None if no defaults exist.
#
# wraps(wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES):
#   __defaults__ = (WRAPPER_ASSIGNMENTS_tuple, WRAPPER_UPDATES_tuple)
#   __defaults__.__class__.__name__ == 'tuple'
#
# update_wrapper(wrapper, wrapped, assigned=..., updated=...):
#   __defaults__ = (WRAPPER_ASSIGNMENTS_tuple, WRAPPER_UPDATES_tuple)
#   __defaults__.__class__.__name__ == 'tuple'
#
# lru_cache(maxsize=128, typed=False):
#   __defaults__ = (128, False)
#   __defaults__.__class__.__name__ == 'tuple'
#
# reduce is a C builtin — accessing reduce.__defaults__ raises AttributeError.
#
# No prior functools spec checks __defaults__.__class__.__name__ for any
# function. New to extra68.
# ---------------------------------------------------------------------------

table functools_extra68.defaults_class_name:
  description: "functools Python function __defaults__.__class__.__name__.__eq__('tuple')==true — __defaults__ is a tuple when function has positional defaults; wave 229 __defaults__ checks; new to extra68"
  kind: python_call_eq
  category: defaults_type
  id_prefix: functoolsdefault68

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_defaults_class_name_eq_tuple,
       wraps.__defaults__.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.wraps.__defaults__.__class__.__name__.__eq__('tuple') == True — wraps is a pure-Python decorator factory (Lib/functools.py) with signature wraps(wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES); both 'assigned' and 'updated' have default values so __defaults__ is a 2-element tuple containing the WRAPPER_ASSIGNMENTS tuple and the WRAPPER_UPDATES tuple; as a tuple object, __defaults__.__class__ is the built-in tuple type and tuple.__name__ == 'tuple'; no prior functools spec checks __defaults__.__class__.__name__ for wraps; new to extra68"]
    - [update_wrapper_defaults_class_name_eq_tuple,
       update_wrapper.__defaults__.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.update_wrapper.__defaults__.__class__.__name__.__eq__('tuple') == True — update_wrapper is a pure-Python function (Lib/functools.py) with signature update_wrapper(wrapper, wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES); both 'assigned' and 'updated' have positional defaults so __defaults__ is a 2-element tuple; as a tuple object, __defaults__.__class__.__name__ == 'tuple'; no prior functools spec checks __defaults__.__class__.__name__ for update_wrapper; new to extra68"]
    - [lru_cache_defaults_class_name_eq_tuple,
       lru_cache.__defaults__.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.lru_cache.__defaults__.__class__.__name__.__eq__('tuple') == True — lru_cache is a pure-Python function (Lib/functools.py) with signature lru_cache(maxsize=128, typed=False); both 'maxsize' and 'typed' have positional defaults so __defaults__ == (128, False), a 2-element tuple; __defaults__.__class__.__name__ == 'tuple'; no prior functools spec checks __defaults__.__class__.__name__ for lru_cache; new to extra68"]

# ---------------------------------------------------------------------------
# reduce.__defaults__ AttributeError — extra68
#
# Wave 229 theme: __defaults__ checks for C builtins.
#
# functools.reduce is a C builtin_function_or_method. C builtins do not
# have a __defaults__ attribute. Accessing reduce.__defaults__ raises
# AttributeError: 'builtin_function_or_method' object has no attribute
# '__defaults__'.
#
# No prior functools spec tests reduce.__defaults__. New to extra68.
# ---------------------------------------------------------------------------

table functools_extra68.reduce_defaults_raises:
  description: "reduce.__defaults__ raises AttributeError — C builtin has no __defaults__; wave 229 __defaults__ checks; new to extra68"
  kind: python_call_raises
  category: defaults_type
  id_prefix: functoolsdefault68

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_defaults_raises_AttributeError,
       reduce.__getattribute__,
       ["__defaults__"],
       AttributeError,
       "functools.reduce.__getattribute__('__defaults__') raises AttributeError — reduce is a C builtin_function_or_method (Modules/_functoolsmodule.c); C builtins do not expose __defaults__ because that attribute is only defined for Python function objects (PyFunctionObject); the C implementation of reduce stores its optional 'initial' argument in the C struct, not in a Python __defaults__ tuple; hasattr(reduce, '__defaults__') returns False; accessing the attribute via __getattribute__ raises AttributeError; no prior functools spec tests reduce.__defaults__; new to extra68"]

# ---------------------------------------------------------------------------
# functools __code__.__class__.__name__ — extra68
#
# Wave 229 theme: __code__ attribute identity.
#
# For pure-Python functions, __code__ is a code object (PyCodeObject).
# code.__class__.__name__ == 'code'.
#
# wraps, update_wrapper, lru_cache are all pure-Python functions in
# Lib/functools.py. Each has a __code__ attribute whose class is the
# built-in code type.
#
# partial is a C extension type (class). Accessing partial.__code__ raises
# AttributeError (type object 'functools.partial' has no attribute '__code__').
#
# No prior functools spec checks __code__.__class__.__name__. New to extra68.
# ---------------------------------------------------------------------------

table functools_extra68.code_class_name:
  description: "functools Python function __code__.__class__.__name__.__eq__('code')==true — pure-Python functions have a code object; wave 229 __code__ identity; new to extra68"
  kind: python_call_eq
  category: code_type
  id_prefix: functoolsdefault68

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_code_class_name_eq_code,
       wraps.__code__.__class__.__name__.__eq__,
       ["code"],
       true,
       "functools.wraps.__code__.__class__.__name__.__eq__('code') == True — wraps is a pure-Python function (Lib/functools.py); every Python function object (PyFunctionObject) carries a __code__ attribute pointing to its associated code object (PyCodeObject); the built-in code type has __name__ == 'code' (4 chars); this chain verifies the type identity of the code object; no prior functools spec checks __code__.__class__.__name__ for wraps; new to extra68"]
    - [update_wrapper_code_class_name_eq_code,
       update_wrapper.__code__.__class__.__name__.__eq__,
       ["code"],
       true,
       "functools.update_wrapper.__code__.__class__.__name__.__eq__('code') == True — update_wrapper is a pure-Python function (Lib/functools.py); its __code__ is a PyCodeObject; __code__.__class__.__name__ == 'code'; no prior functools spec checks __code__.__class__.__name__ for update_wrapper; new to extra68"]
    - [lru_cache_code_class_name_eq_code,
       lru_cache.__code__.__class__.__name__.__eq__,
       ["code"],
       true,
       "functools.lru_cache.__code__.__class__.__name__.__eq__('code') == True — lru_cache is a pure-Python function (Lib/functools.py) that returns a memoizing decorator; its __code__ is a PyCodeObject; __code__.__class__.__name__ == 'code'; no prior functools spec checks __code__.__class__.__name__ for lru_cache; new to extra68"]

# ---------------------------------------------------------------------------
# partial.__code__ AttributeError — extra68
#
# Wave 229 theme: C extension types have no __code__.
#
# functools.partial is a C extension type defined in Modules/_functoolsmodule.c.
# It is a type (class), not a function. Types do not have __code__ unless they
# define it explicitly. partial does not. Accessing partial.__code__ raises
# AttributeError.
#
# No prior functools spec tests partial.__code__. New to extra68.
# ---------------------------------------------------------------------------

table functools_extra68.partial_code_raises:
  description: "partial.__code__ raises AttributeError — C extension type has no __code__; wave 229 __code__ identity; new to extra68"
  kind: python_call_raises
  category: code_type
  id_prefix: functoolsdefault68

  columns: [id, function, args, expected, description]
  rows:
    - [partial_code_raises_AttributeError,
       partial.__getattribute__,
       ["__code__"],
       AttributeError,
       "functools.partial.__getattribute__('__code__') raises AttributeError — partial is a C extension type (Modules/_functoolsmodule.c), not a Python function; the __code__ attribute is only present on Python function objects (PyFunctionObject), not on C extension types or instances thereof; type object 'functools.partial' has no attribute '__code__'; this distinguishes C extension types from pure-Python functions in the functools module; no prior functools spec tests partial.__code__; new to extra68"]

# ---------------------------------------------------------------------------
# functools __closure__ checks — extra68
#
# Wave 229 theme: __closure__ checks.
#
# Module-level functions are not closures. Their __closure__ attribute is None.
# wraps and update_wrapper are defined at module scope in Lib/functools.py
# (not inside another function), so they capture no free variables.
# Therefore wraps.__closure__ is None and update_wrapper.__closure__ is None.
#
# __closure__ is None → __closure__.__class__.__name__ would fail, so we
# check via the function itself: wraps.__closure__.__class__.__name__
# CAUTION: None.__class__.__name__ == 'NoneType'. This chain works because
# None has a __class__ attribute.
#
# No prior functools spec checks __closure__ for any function. New to extra68.
# ---------------------------------------------------------------------------

table functools_extra68.closure_class_name:
  description: "wraps/update_wrapper __closure__.__class__.__name__.__eq__('NoneType')==true — module-level functions have no closure; wave 229 __closure__ checks; new to extra68"
  kind: python_call_eq
  category: closure_type
  id_prefix: functoolsdefault68

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_closure_class_name_eq_NoneType,
       wraps.__closure__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "functools.wraps.__closure__.__class__.__name__.__eq__('NoneType') == True — wraps is defined at module scope in Lib/functools.py; module-level functions are not closures and do not capture free variables from an enclosing scope; therefore wraps.__closure__ is None; None.__class__ is the NoneType type and NoneType.__name__ == 'NoneType' (8 chars); this chain verifies that wraps has no closure cells; no prior functools spec checks __closure__ for wraps; new to extra68"]
    - [update_wrapper_closure_class_name_eq_NoneType,
       update_wrapper.__closure__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "functools.update_wrapper.__closure__.__class__.__name__.__eq__('NoneType') == True — update_wrapper is defined at module scope in Lib/functools.py; it is not a nested function and captures no free variables; therefore update_wrapper.__closure__ is None; None.__class__.__name__ == 'NoneType'; no prior functools spec checks __closure__ for update_wrapper; new to extra68"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra68
# ---------------------------------------------------------------------------

invariant functools_extra68.wraps_defaults_is_tuple:
  description: "functools.wraps.__defaults__.__class__.__name__.__eq__('tuple') == True — wraps has two positional defaults (assigned and updated); __defaults__ is a tuple; wave 229 __defaults__ checks; new to extra68"
  kind: python_call_eq
  function: wraps.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra68.lru_cache_defaults_is_tuple:
  description: "functools.lru_cache.__defaults__.__class__.__name__.__eq__('tuple') == True — lru_cache has maxsize=128 and typed=False as positional defaults; __defaults__ == (128, False); wave 229 __defaults__ checks; new to extra68"
  kind: python_call_eq
  function: lru_cache.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra68.wraps_code_is_code:
  description: "functools.wraps.__code__.__class__.__name__.__eq__('code') == True — wraps is a pure-Python function; its __code__ is a PyCodeObject; wave 229 __code__ identity; new to extra68"
  kind: python_call_eq
  function: wraps.__code__.__class__.__name__.__eq__
  args: ["code"]
  expected: true

invariant functools_extra68.wraps_closure_is_None:
  description: "functools.wraps.__closure__.__class__.__name__.__eq__('NoneType') == True — wraps is a module-level function with no closure; __closure__ is None; wave 229 __closure__ checks; new to extra68"
  kind: python_call_eq
  function: wraps.__closure__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true
