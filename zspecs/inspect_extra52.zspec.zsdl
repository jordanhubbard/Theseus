spec: inspect_extra52
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra51.zspec.zsdl."
    - "Prior specs covered: __module__.__eq__('inspect') for ismodule/isclass/isfunction/isbuiltin/getmembers/getdoc/getfile/getsource/getmodule/signature/stack (various specs extra3..extra50); __module__.__len__()==7 for ismodule/isclass/isfunction/isbuiltin/signature/getmembers (extra28/extra40); __doc__.__class__.__name__.__eq__('str') for getmembers/getfile/getsource/getmodule/signature/stack (extra51); __doc__.__class__.__name__.__eq__('str') and __qualname__.__eq__('str') for module level (extra51)."
    - "This spec covers: inspect.isfunction.__module__.__class__.__name__.__eq__('str')==true; inspect.isbuiltin.__module__.__class__.__name__.__eq__('str')==true; inspect.isclass.__module__.__class__.__name__.__eq__('str')==true; inspect.ismodule.__module__.__class__.__name__.__eq__('str')==true; inspect.signature.__module__.__class__.__name__.__eq__('str')==true; inspect.getmembers.__module__.__class__.__name__.__eq__('str')==true; inspect.getdoc.__module__.__len__()==7; inspect.getfile.__module__.__len__()==7; inspect.getsource.__module__.__len__()==7."
    - "Key findings: inspect is a pure-Python module in Lib/inspect.py. All public inspect functions store their __module__ attribute as the Python string 'inspect' (7 chars). Since this string is a Python str object, its __class__ is the str built-in type, and str.__name__ == 'str' (3 chars). Prior specs extensively covered __module__.__eq__('inspect') for all major functions, and __module__.__len__()==7 for ismodule/isclass/isfunction/isbuiltin/signature/getmembers. No prior inspect spec records __module__.__class__.__name__.__eq__('str') for any inspect function. Additionally, getdoc/getfile/getsource __module__.__len__()==7 appeared only in comments in extra40 but not as explicit invariant rows. All nine invariants are new to extra52."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect function __module__.__class__.__name__ == 'str' — extra52 namespace
#
# Every inspect public function stores its __module__ as the Python string
# 'inspect' (7 chars). Because __module__ is a str object, its __class__ is
# the str built-in type, and str.__name__ == 'str' (3 chars). Prior specs
# confirmed __module__.__eq__('inspect') for all functions listed here, but
# no prior inspect spec records __module__.__class__.__name__.__eq__('str')
# for any inspect function. All six checks are new to extra52.
#
# Functions chosen span the major categories of inspect's API:
#   is-predicates: isfunction, isbuiltin, isclass, ismodule
#   introspection:  signature
#   membership:     getmembers
# ---------------------------------------------------------------------------

table inspect_extra52.function_module_class_name:
  description: "inspect function __module__.__class__.__name__ == 'str' — all inspect public functions store __module__ as a Python str object; str.__name__ == 'str' (3 chars); no prior inspect spec records this class-of-module-string dimension"
  kind: python_call_eq
  category: identity
  id_prefix: inspmod52

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_module_class_name,
       isfunction.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.isfunction.__module__.__class__.__name__ == 'str' — isfunction is a pure-Python function in Lib/inspect.py; __module__ is the Python string 'inspect' (7 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed isfunction.__module__.__eq__('inspect') and isfunction.__module__.__len__()==7; this is the first __module__.__class__.__name__ check for any inspect function; new to extra52"]
    - [isbuiltin_module_class_name,
       isbuiltin.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.isbuiltin.__module__.__class__.__name__ == 'str' — isbuiltin is a pure-Python function in Lib/inspect.py; __module__ is the Python string 'inspect' (7 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed isbuiltin.__module__.__eq__('inspect') and isbuiltin.__module__.__len__()==7; this is the first __module__.__class__.__name__ check for isbuiltin; new to extra52"]
    - [isclass_module_class_name,
       isclass.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.isclass.__module__.__class__.__name__ == 'str' — isclass is a pure-Python function in Lib/inspect.py; __module__ is the Python string 'inspect' (7 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed isclass.__module__.__eq__('inspect') and isclass.__module__.__len__()==7; this is the first __module__.__class__.__name__ check for isclass; new to extra52"]
    - [ismodule_module_class_name,
       ismodule.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.ismodule.__module__.__class__.__name__ == 'str' — ismodule is a pure-Python function in Lib/inspect.py; __module__ is the Python string 'inspect' (7 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed ismodule.__module__.__eq__('inspect') and ismodule.__module__.__len__()==7; this is the first __module__.__class__.__name__ check for ismodule; new to extra52"]
    - [signature_module_class_name,
       signature.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.signature.__module__.__class__.__name__ == 'str' — signature is a pure-Python function in Lib/inspect.py; __module__ is the Python string 'inspect' (7 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed signature.__module__.__eq__('inspect') and signature.__module__.__len__()==7; this is the first __module__.__class__.__name__ check for signature; new to extra52"]
    - [getmembers_module_class_name,
       getmembers.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.getmembers.__module__.__class__.__name__ == 'str' — getmembers is a pure-Python function in Lib/inspect.py; __module__ is the Python string 'inspect' (7 chars); string objects have __class__ == str; str.__name__ == 'str' (3 chars); prior specs confirmed getmembers.__module__.__eq__('inspect') and getmembers.__module__.__len__()==7; this is the first __module__.__class__.__name__ check for getmembers; new to extra52"]

# ---------------------------------------------------------------------------
# inspect function __module__.__len__() — extra52 namespace (getdoc/getfile/getsource)
#
# Prior specs confirmed __module__.__len__()==7 for ismodule, isclass,
# isfunction, isbuiltin, signature, and getmembers (extra28 and extra40).
# inspect_extra40 noted in a comment that getfile.__module__.__len__() == 7
# but did not record it as an explicit invariant row. getdoc and getsource
# are also confirmed as 7-char __module__ in prior __eq__ specs but their
# __len__ forms were not recorded as explicit rows. All three below are new
# to extra52 as explicit invariant rows.
# ---------------------------------------------------------------------------

table inspect_extra52.function_module_len:
  description: "inspect.getdoc, getfile, getsource __module__.__len__()==7 — 'inspect' is 7 chars; prior specs confirmed __module__.__eq__('inspect') for all three but did not record __len__()==7 as explicit rows; noted in comment in extra40 for getfile but not as an invariant"
  kind: python_call_eq
  category: identity
  id_prefix: inspmod52

  columns: [id, function, args, expected, description]
  rows:
    - [getdoc_module_len,
       getdoc.__module__.__len__,
       [],
       7,
       "inspect.getdoc.__module__.__len__() == 7 — 'inspect' has 7 characters; getdoc is a pure-Python function that returns the docstring for an object, cleaned up with cleandoc; prior specs confirmed getdoc.__module__.__eq__('inspect'); this is the first explicit __module__.__len__() row for getdoc; new to extra52"]
    - [getfile_module_len,
       getfile.__module__.__len__,
       [],
       7,
       "inspect.getfile.__module__.__len__() == 7 — 'inspect' has 7 characters; getfile is a pure-Python function that returns the file in which an object was defined; inspect_extra40 mentioned getfile.__module__.__len__()==7 in a comment but did not record it as an explicit invariant; this is the first explicit row; new to extra52"]
    - [getsource_module_len,
       getsource.__module__.__len__,
       [],
       7,
       "inspect.getsource.__module__.__len__() == 7 — 'inspect' has 7 characters; getsource is a pure-Python function that returns the text of the source code for an object; prior specs confirmed getsource.__module__.__eq__('inspect'); this is the first explicit __module__.__len__() row for getsource; new to extra52"]
