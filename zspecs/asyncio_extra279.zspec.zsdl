spec: asyncio_extra279
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-transport.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-transport.html — Python asyncio transport documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/transports.py"
    - "asyncio_extra278.zspec.zsdl — covers WriteTransport identity (__name__, __module__, __bases__[0].__name__, __mro__.__len__(), method qualnames); SubprocessProtocol and BufferedProtocol identity"
  notes:
    - "This spec covers: asyncio.Transport, asyncio.ReadTransport, and asyncio.BaseTransport class identity. NEW in extra279: asyncio.Transport.__name__=='Transport'; asyncio.Transport.__module__=='asyncio.transports'; asyncio.Transport.__bases__[0].__name__=='ReadTransport'; asyncio.Transport.__bases__[1].__name__=='WriteTransport'; asyncio.Transport.__mro__.__len__()==5 ([Transport, ReadTransport, WriteTransport, BaseTransport, object]); asyncio.Transport.__qualname__=='Transport'; asyncio.ReadTransport.__name__=='ReadTransport'; asyncio.ReadTransport.__module__=='asyncio.transports'; asyncio.ReadTransport.__bases__[0].__name__=='BaseTransport'; asyncio.ReadTransport.__mro__.__len__()==3 ([ReadTransport, BaseTransport, object]); asyncio.BaseTransport.__name__=='BaseTransport'; asyncio.BaseTransport.__module__=='asyncio.transports'; asyncio.BaseTransport.__bases__[0].__name__=='object'; asyncio.BaseTransport.__mro__.__len__()==2 ([BaseTransport, object]). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.Transport has two direct bases (ReadTransport and WriteTransport), giving it the deepest MRO (length=5) of any transport class: Transport.__mro__ == [Transport, ReadTransport, WriteTransport, BaseTransport, object]. ReadTransport and WriteTransport both inherit from BaseTransport; Python's C3 linearisation places WriteTransport after ReadTransport in Transport's MRO. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.Transport.__bases__[0].__name__ == 'ReadTransport' and asyncio.Transport.__bases__[1].__name__ == 'WriteTransport'. Transport is a bidirectional transport that inherits from both ReadTransport and WriteTransport; this multiple-inheritance design is the key structural difference from the single-parent ReadTransport and WriteTransport. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.BaseTransport.__mro__.__len__() == 2. BaseTransport is the root of the transport hierarchy; its MRO is [BaseTransport, object] (length=2, the shortest MRO in this spec). BaseTransport defines the shared interface: close(), is_closing(), get_extra_info(), set_protocol(), get_protocol(). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Transport class identity — extra279
#
# asyncio.Transport.__name__                       == 'Transport'
# asyncio.Transport.__module__                     == 'asyncio.transports'
# asyncio.Transport.__bases__[0].__name__          == 'ReadTransport'
# asyncio.Transport.__bases__[1].__name__          == 'WriteTransport'
# asyncio.Transport.__mro__.__len__()              == 5
# asyncio.Transport.__qualname__                   == 'Transport'
# asyncio.Transport.__name__.__len__()             == 9
# ---------------------------------------------------------------------------

table asyncio_extra279.asyncio_transport_identity:
  description: "asyncio.Transport class identity checks in asynciotransport279 namespace — Transport is defined in Lib/asyncio/transports.py; Transport is the bidirectional transport combining both ReadTransport and WriteTransport; Transport.__name__.__eq__('Transport')==True; Transport.__module__.__eq__('asyncio.transports')==True (len=18: 'asyncio.'=8+'transports'=10); Transport.__bases__[0].__name__.__eq__('ReadTransport')==True; Transport.__bases__[1].__name__.__eq__('WriteTransport')==True; Transport inherits from both ReadTransport and WriteTransport (multiple inheritance); Transport.__mro__.__len__()==5 ([Transport, ReadTransport, WriteTransport, BaseTransport, object]); Transport.__qualname__.__eq__('Transport')==True; Transport.__name__.__len__()==9 ('Transport'=9, the shortest class name in this spec); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotransport279

  columns: [id, function, args, expected, description]
  rows:
    - [t_name_eq,    asyncio.Transport.__name__.__eq__,                        ["Transport"],           true, "asyncio.Transport.__name__ == 'Transport'; verified with Python 3.14.3"]
    - [t_mod_eq,     asyncio.Transport.__module__.__eq__,                      ["asyncio.transports"],  true, "asyncio.Transport.__module__ == 'asyncio.transports' (len=18); verified with Python 3.14.3"]
    - [t_base0_eq,   "asyncio.Transport.__bases__[0].__name__.__eq__",         ["ReadTransport"],       true, "asyncio.Transport.__bases__[0].__name__ == 'ReadTransport'; verified with Python 3.14.3"]
    - [t_base1_eq,   "asyncio.Transport.__bases__[1].__name__.__eq__",         ["WriteTransport"],      true, "asyncio.Transport.__bases__[1].__name__ == 'WriteTransport'; verified with Python 3.14.3"]
    - [t_mro_len,    asyncio.Transport.__mro__.__len__,                        [],                      5,    "asyncio.Transport.__mro__.__len__() == 5 — [Transport, ReadTransport, WriteTransport, BaseTransport, object]; verified with Python 3.14.3"]
    - [t_qn_eq,      asyncio.Transport.__qualname__.__eq__,                    ["Transport"],           true, "asyncio.Transport.__qualname__ == 'Transport'; verified with Python 3.14.3"]
    - [t_name_len,   asyncio.Transport.__name__.__len__,                       [],                      9,    "asyncio.Transport.__name__.__len__() == 9 ('Transport'=9, shortest class name in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.ReadTransport and asyncio.BaseTransport class identity — extra279
#
# asyncio.ReadTransport.__name__                   == 'ReadTransport'
# asyncio.ReadTransport.__module__                 == 'asyncio.transports'
# asyncio.ReadTransport.__bases__[0].__name__      == 'BaseTransport'
# asyncio.ReadTransport.__mro__.__len__()          == 3
# asyncio.BaseTransport.__name__                   == 'BaseTransport'
# asyncio.BaseTransport.__module__                 == 'asyncio.transports'
# asyncio.BaseTransport.__bases__[0].__name__      == 'object'
# asyncio.BaseTransport.__mro__.__len__()          == 2
# ---------------------------------------------------------------------------

table asyncio_extra279.asyncio_read_base_transport_identity:
  description: "asyncio.ReadTransport and asyncio.BaseTransport class identity checks in asynciotransport279a namespace — ReadTransport and BaseTransport are both defined in Lib/asyncio/transports.py; ReadTransport.__name__.__eq__('ReadTransport')==True; ReadTransport.__module__.__eq__('asyncio.transports')==True (same module as Transport, WriteTransport, BaseTransport); ReadTransport.__bases__[0].__name__.__eq__('BaseTransport')==True (ReadTransport has a single direct base); ReadTransport.__mro__.__len__()==3 ([ReadTransport, BaseTransport, object]); ReadTransport.__qualname__.__eq__('ReadTransport')==True; BaseTransport is the root of the transport hierarchy; BaseTransport.__name__.__eq__('BaseTransport')==True; BaseTransport.__module__.__eq__('asyncio.transports')==True; BaseTransport.__bases__[0].__name__.__eq__('object')==True (direct subclass of object, root class); BaseTransport.__mro__.__len__()==2 ([BaseTransport, object], the shortest in this spec); compare MRO depths: BaseTransport=2, ReadTransport=3, WriteTransport=3, Transport=5; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotransport279a

  columns: [id, function, args, expected, description]
  rows:
    - [rt_name_eq,    asyncio.ReadTransport.__name__.__eq__,                    ["ReadTransport"],       true, "asyncio.ReadTransport.__name__ == 'ReadTransport'; verified with Python 3.14.3"]
    - [rt_mod_eq,     asyncio.ReadTransport.__module__.__eq__,                  ["asyncio.transports"],  true, "asyncio.ReadTransport.__module__ == 'asyncio.transports' (len=18, same as Transport); verified with Python 3.14.3"]
    - [rt_base0_eq,   "asyncio.ReadTransport.__bases__[0].__name__.__eq__",     ["BaseTransport"],       true, "asyncio.ReadTransport.__bases__[0].__name__ == 'BaseTransport'; verified with Python 3.14.3"]
    - [rt_mro_len,    asyncio.ReadTransport.__mro__.__len__,                    [],                      3,    "asyncio.ReadTransport.__mro__.__len__() == 3 — [ReadTransport, BaseTransport, object]; verified with Python 3.14.3"]
    - [rt_qn_eq,      asyncio.ReadTransport.__qualname__.__eq__,                ["ReadTransport"],       true, "asyncio.ReadTransport.__qualname__ == 'ReadTransport' (module-level class); verified with Python 3.14.3"]
    - [bt_name_eq,    asyncio.BaseTransport.__name__.__eq__,                    ["BaseTransport"],       true, "asyncio.BaseTransport.__name__ == 'BaseTransport'; verified with Python 3.14.3"]
    - [bt_mod_eq,     asyncio.BaseTransport.__module__.__eq__,                  ["asyncio.transports"],  true, "asyncio.BaseTransport.__module__ == 'asyncio.transports' (root transport class); verified with Python 3.14.3"]
    - [bt_base0_eq,   "asyncio.BaseTransport.__bases__[0].__name__.__eq__",     ["object"],              true, "asyncio.BaseTransport.__bases__[0].__name__ == 'object' — root transport, direct subclass of object; verified with Python 3.14.3"]
    - [bt_mro_len,    asyncio.BaseTransport.__mro__.__len__,                    [],                      2,    "asyncio.BaseTransport.__mro__.__len__() == 2 — [BaseTransport, object], shortest in spec; verified with Python 3.14.3"]
    - [bt_qn_eq,      asyncio.BaseTransport.__qualname__.__eq__,                ["BaseTransport"],       true, "asyncio.BaseTransport.__qualname__ == 'BaseTransport' (module-level class); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra279
# ---------------------------------------------------------------------------

invariant asyncio_extra279.Transport_bases_count_is_2:
  description: "asyncio.Transport.__bases__.__len__() == 2 — Transport has exactly two direct bases: ReadTransport and WriteTransport; this makes Transport the only class in the transport hierarchy with multiple inheritance; all other transports (ReadTransport, WriteTransport, BaseTransport) have exactly one direct base; Transport.__bases__.__len__() == 2 reflects the bidirectional design: Transport combines the read capability (ReadTransport) and write capability (WriteTransport) into a single class; the Python C3 linearisation for Transport with two bases [ReadTransport, WriteTransport] (both inheriting from BaseTransport) produces the 5-element MRO [Transport, ReadTransport, WriteTransport, BaseTransport, object]; NEW in extra279: first standalone Transport.__bases__.__len__ invariant in asynciotransport279 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Transport.__bases__.__len__
  args: []
  expected: 2

invariant asyncio_extra279.Transport_mro_len_is_5:
  description: "asyncio.Transport.__mro__.__len__() == 5 — Transport's MRO is [Transport, ReadTransport, WriteTransport, BaseTransport, object] (length=5); this is the deepest MRO in the asyncio transport hierarchy; compare MRO depths: BaseTransport=2, ReadTransport=3, WriteTransport=3, Transport=5; the length-5 MRO arises from Transport's dual inheritance from ReadTransport and WriteTransport, both of which inherit from BaseTransport; C3 linearisation inserts WriteTransport after ReadTransport and merges the shared BaseTransport tail; Transport.__module__ is 'asyncio.transports'; Transport.__bases__.__len__() is 2; NEW in extra279: first standalone Transport MRO length invariant in asynciotransport279 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Transport.__mro__.__len__
  args: []
  expected: 5

invariant asyncio_extra279.Transport_second_base_is_WriteTransport:
  description: "asyncio.Transport.__bases__[1].__name__.__eq__('WriteTransport') returns True — Transport's second direct base is WriteTransport; Transport.__bases__ == (ReadTransport, WriteTransport); the ordering (ReadTransport first, WriteTransport second) reflects the class definition order in Lib/asyncio/transports.py; asyncio.extra278 established WriteTransport.__bases__[0].__name__ == 'BaseTransport' and WriteTransport.__mro__.__len__() == 3; WriteTransport.__module__ is 'asyncio.transports'; this invariant verifies the second element of Transport.__bases__, complementing extra279's first-element check (Transport.__bases__[0].__name__ == 'ReadTransport'); NEW in extra279: first standalone Transport.__bases__[1].__name__ invariant in asynciotransport279 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "asyncio.Transport.__bases__[1].__name__.__eq__"
  args: ["WriteTransport"]
  expected: true

invariant asyncio_extra279.ReadTransport_base_is_BaseTransport:
  description: "asyncio.ReadTransport.__bases__[0].__name__.__eq__('BaseTransport') returns True — ReadTransport inherits from BaseTransport as its sole direct base; ReadTransport's MRO is [ReadTransport, BaseTransport, object] (length=3); BaseTransport defines the shared transport interface; ReadTransport adds read-specific methods (pause_reading, resume_reading); all four transport classes (BaseTransport, ReadTransport, WriteTransport, Transport) share __module__ 'asyncio.transports'; ReadTransport.__name__.__len__() is 13 ('ReadTransport'=13, tied with BaseTransport.__name__.__len__() == 13); NEW in extra279: first standalone ReadTransport base class invariant in asynciotransport279 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "asyncio.ReadTransport.__bases__[0].__name__.__eq__"
  args: ["BaseTransport"]
  expected: true

invariant asyncio_extra279.BaseTransport_module_is_asyncio_transports:
  description: "asyncio.BaseTransport.__module__.__eq__('asyncio.transports') returns True — BaseTransport is defined in Lib/asyncio/transports.py; its __module__ is 'asyncio.transports' (len=18: 'asyncio.'=8+'transports'=10); all four transport classes (BaseTransport, ReadTransport, WriteTransport, Transport) share the same __module__ 'asyncio.transports'; BaseTransport is the root of the transport hierarchy: BaseTransport.__bases__[0].__name__ is 'object' and BaseTransport.__mro__.__len__() is 2 ([BaseTransport, object]); BaseTransport defines the shared interface: close(), is_closing(), get_extra_info(), set_protocol(), get_protocol(); NEW in extra279: first standalone BaseTransport.__module__ invariant in asynciotransport279 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.BaseTransport.__module__.__eq__
  args: ["asyncio.transports"]
  expected: true

invariant asyncio_extra279.BaseTransport_mro_len_is_2:
  description: "asyncio.BaseTransport.__mro__.__len__() == 2 — BaseTransport's MRO is [BaseTransport, object] (length=2); this is the shortest MRO in the asyncio transport hierarchy; compare MRO depths: BaseTransport=2 (root), ReadTransport=3, WriteTransport=3, Transport=5 (deepest); BaseTransport is the single root from which all transport classes ultimately derive; BaseTransport.__bases__[0].__name__ is 'object'; BaseTransport.__module__ is 'asyncio.transports'; NEW in extra279: first standalone BaseTransport MRO length invariant in asynciotransport279 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.BaseTransport.__mro__.__len__
  args: []
  expected: 2
