# ---------------------------------------------------------------------------
# socket.socket.__name__.__eq__('socket') — standalone
#
# socket.socket.__name__ is 'socket' (6 chars). The Python socket.socket class is
# defined in Lib/socket.py with the statement: class socket(_socket.socket). The class
# name is 'socket'. Unusually, socket.socket.__name__ == socket.socket.__module__ ==
# socket.socket.__bases__[0].__name__ == 'socket'. All three attributes share the same
# string value 'socket'. This occurs because the Python class 'socket' wraps the C class
# '_socket.socket' (also named 'socket'), and both live in modules named 'socket' and
# '_socket' respectively. The module-level attribute socket.socket is the Python class,
# which is accessible as 'socket' in the 'socket' namespace.
# No prior socket spec anchors socket.socket.__name__ as a standalone under sockcls159.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra159.sock_name_socket:
  description: "socket.socket.__name__.__eq__('socket') == True — 6 chars; class name defined in Lib/socket.py as class socket(_socket.socket); unusual triple identity: __name__==__module__==__bases__[0].__name__=='socket' (all 6 chars); the Python socket.socket wraps the C _socket.socket class; socket.socket.__qualname__=='socket' (6 chars; same as __name__ for top-level class); extra155 anchors socket.socket.__doc__.__class__.__name__ but NOT __name__ string; no prior socket spec anchors socket.__name__ as a standalone; first standalone under sockcls159"
  category: identity
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__module__.__eq__('socket') — standalone
#
# socket.socket.__module__ is 'socket' (6 chars). socket.socket is defined in
# Lib/socket.py, which is the 'socket' module. The __module__ attribute of a class is
# the name of the module where the class is defined. For socket.socket, this is 'socket'
# (without leading underscore), not '_socket'. This contrasts with the base class
# socket.socket.__bases__[0].__module__ == '_socket' (7 chars; the C extension module).
# The Python-level class lives in 'socket' while the C-level base class lives in '_socket'.
# socket.socket.__name__ == socket.socket.__module__ == 'socket' (both 6 chars; same value).
# No prior socket spec anchors socket.socket.__module__ as a standalone under sockcls159.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra159.sock_module_socket:
  description: "socket.socket.__module__.__eq__('socket') == True — 6 chars; Python-level class defined in Lib/socket.py; __module__=='socket' (without underscore); contrasts with base class __bases__[0].__module__=='_socket' (7 chars; C extension); __name__==__module__=='socket' (same string value; both 6 chars); extra155 anchors module-level functions' __module__ but NOT socket.socket class __module__; no prior socket spec anchors socket.__module__ as a standalone; first standalone under sockcls159"
  category: identity
  kind: python_call_eq
  function: socket.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__init__.__qualname__.__eq__('socket.__init__') — standalone
#
# socket.socket.__init__.__qualname__ is 'socket.__init__' (15 chars = 'socket.'=7 + '__init__'=8).
# socket.socket.__init__ is a Python function (not a C wrapper_descriptor), because
# socket.socket is defined as a pure Python class in Lib/socket.py. The __init__ method
# sets up the Python-level socket object, calling the parent _socket.socket.__init__
# to initialize the C-level socket. 'socket.__init__' uses 'socket.' (7 chars) as the
# class prefix, 1 char longer than 'HASH.' (5 chars; hashlib) and 'UUID.' (5 chars; uuid),
# but equal to 'Struct.' (7 chars; struct). The __init__ method is the longest method
# qualname anchored in this spec: connect(14) < __init__(15).
# No prior socket spec anchors socket.__init__.__qualname__ as a standalone under sockcls159.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra159.sock_init_qualname_eq:
  description: "socket.socket.__init__.__qualname__.__eq__('socket.__init__') == True — 15 chars = 'socket.'=7 + '__init__'=8; pure Python function (__class__.__name__=='function'; contrasts with struct.Struct.__init__ wrapper_descriptor); socket.socket is defined in Lib/socket.py; 'socket.' prefix is 7 chars (= 'Struct.' for struct; longer than 'HASH.'=5 or 'UUID.'=5); connect(14) < __init__(15); extra156 anchors other socket method qualnames but NOT socket.__init__.__qualname__; no prior socket spec anchors this as a standalone; first standalone under sockcls159"
  category: identity
  kind: python_call_eq
  function: socket.__init__.__qualname__.__eq__
  args: ["socket.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.connect.__qualname__.__eq__('socket.connect') — standalone
#
# socket.socket.connect.__qualname__ is 'socket.connect' (14 chars = 'socket.'=7 + 'connect'=7).
# socket.socket.connect is a method_descriptor inherited from the C base class _socket.socket.
# Unlike socket.socket.__init__ (which is a pure Python function), connect is a C-level
# method (method_descriptor, same type as struct.Struct.pack). The connect() method
# initiates a connection to a remote address on the socket. 'connect' (7 chars) is one
# of the core socket operation methods. The qualname 'socket.connect' uses 'socket.' (7 chars)
# as the class prefix. length: 'socket.connect' (14 chars) < 'socket.__init__' (15 chars).
# extra156 anchors other socket method qualnames (makefile/__setblocking/__settimeout etc.);
# no prior socket spec anchors socket.connect.__qualname__ as a standalone under sockcls159.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra159.sock_connect_qualname_eq:
  description: "socket.socket.connect.__qualname__.__eq__('socket.connect') == True — 14 chars = 'socket.'=7 + 'connect'=7; method_descriptor inherited from _socket.socket (C class); contrasts with socket.__init__ which is pure Python 'function'; connect() initiates connection to remote address; 'connect'=7 chars; 'socket.connect'(14) < 'socket.__init__'(15); extra156 anchors makefile/__setblocking/__settimeout qualnames but NOT connect; no prior socket spec anchors socket.connect.__qualname__ as a standalone; first standalone under sockcls159"
  category: identity
  kind: python_call_eq
  function: socket.connect.__qualname__.__eq__
  args: ["socket.connect"]
  expected: true

