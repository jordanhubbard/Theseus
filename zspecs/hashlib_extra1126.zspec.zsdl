spec: hashlib_extra1126
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib.md5/__doc__/__class__/__name__, hashlib.sha1/__doc__/__class__/__name__, hashlib.sha256/__doc__/__class__/__name__, hashlib.sha512/__doc__/__class__/__name__, HASH blocksize/digest_size/name __class__.__name__, hashlib.new/__doc__/__class__/__name__"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1126.constructor_doc_class_names:
  description: "hashlib.md5, sha1, sha256, sha512 __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: constructor_doc_classnames
  id_prefix: hl1126cd
  columns: [id, function, args, expected]
  rows:
    - [hl1126cd001, hashlib.md5.__doc__.__class__.__name__.__eq__,              ["str"], true]
    - [hl1126cd002, hashlib.sha1.__doc__.__class__.__name__.__eq__,             ["str"], true]
    - [hl1126cd003, hashlib.sha256.__doc__.__class__.__name__.__eq__,           ["str"], true]
    - [hl1126cd004, hashlib.sha512.__doc__.__class__.__name__.__eq__,           ["str"], true]
    - [hl1126cd005, hashlib.md5.__doc__.__class__.__qualname__.__eq__,          ["str"], true]
    - [hl1126cd006, hashlib.sha1.__doc__.__class__.__qualname__.__eq__,         ["str"], true]
    - [hl1126cd007, hashlib.sha256.__doc__.__class__.__qualname__.__eq__,       ["str"], true]
    - [hl1126cd008, hashlib.sha512.__doc__.__class__.__qualname__.__eq__,       ["str"], true]
    - [hl1126cd009, hashlib.md5.__doc__.__class__.__module__.__eq__,            ["builtins"], true]
    - [hl1126cd010, hashlib.sha1.__doc__.__class__.__module__.__eq__,           ["builtins"], true]

table hashlib_extra1126.hash_attr_class_names:
  description: "HASH blocksize, digest_size, name __class__.__name__ identity via md5 and sha256"
  kind: python_call_eq
  category: hash_attr_classnames
  id_prefix: hl1126ha
  columns: [id, function, args, expected]
  rows:
    - [hl1126ha001, hashlib.md5.block_size.__class__.__name__.__eq__,           ["int"], true]
    - [hl1126ha002, hashlib.sha256.block_size.__class__.__name__.__eq__,        ["int"], true]
    - [hl1126ha003, hashlib.md5.digest_size.__class__.__name__.__eq__,          ["int"], true]
    - [hl1126ha004, hashlib.sha256.digest_size.__class__.__name__.__eq__,       ["int"], true]
    - [hl1126ha005, hashlib.md5.name.__class__.__name__.__eq__,                 ["str"], true]
    - [hl1126ha006, hashlib.sha256.name.__class__.__name__.__eq__,              ["str"], true]
    - [hl1126ha007, hashlib.md5.block_size.__class__.__qualname__.__eq__,       ["int"], true]
    - [hl1126ha008, hashlib.sha256.block_size.__class__.__qualname__.__eq__,    ["int"], true]
    - [hl1126ha009, hashlib.md5.digest_size.__class__.__qualname__.__eq__,      ["int"], true]
    - [hl1126ha010, hashlib.sha256.digest_size.__class__.__qualname__.__eq__,   ["int"], true]

table hashlib_extra1126.new_doc_and_sha512_attrs:
  description: "hashlib.new __doc__.__class__.__name__ and sha256/sha512 doc module identity"
  kind: python_call_eq
  category: new_doc_sha512_attrs
  id_prefix: hl1126nd
  columns: [id, function, args, expected]
  rows:
    - [hl1126nd001, hashlib.new.__doc__.__class__.__name__.__eq__,              ["str"],      true]
    - [hl1126nd002, hashlib.new.__doc__.__class__.__qualname__.__eq__,          ["str"],      true]
    - [hl1126nd003, hashlib.new.__doc__.__class__.__module__.__eq__,            ["builtins"], true]
    - [hl1126nd004, hashlib.sha256.__doc__.__class__.__module__.__eq__,         ["builtins"], true]
    - [hl1126nd005, hashlib.sha512.__doc__.__class__.__module__.__eq__,         ["builtins"], true]
    - [hl1126nd006, hashlib.sha512.__doc__.__class__.__qualname__.__eq__,       ["str"],      true]
    - [hl1126nd007, hashlib.md5.name.__class__.__module__.__eq__,               ["builtins"], true]
    - [hl1126nd008, hashlib.sha256.name.__class__.__module__.__eq__,            ["builtins"], true]
    - [hl1126nd009, hashlib.md5.block_size.__class__.__module__.__eq__,         ["builtins"], true]
    - [hl1126nd010, hashlib.sha256.block_size.__class__.__module__.__eq__,      ["builtins"], true]
