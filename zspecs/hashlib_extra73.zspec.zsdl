spec: hashlib_extra73
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra72.zspec.zsdl — covers __spec__.__class__/__name__=='ModuleSpec' / __file__.__contains__('hashlib') / __file__.__contains__('.py') / __name__.__class__.__name__=='str' / md5/sha256/sha1/sha512 __doc__.__contains__('hash') / pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac') (table + invariants)."
    - "hashlib_extra71.zspec.zsdl — covers pbkdf2_hmac/__class__/__name__=='builtin_function_or_method' / algorithms_guaranteed.__contains__ sha3_224/sha3_384/shake_128/shake_256 / new/__class__/__name__=='function' / file_digest/__class__/__name__=='function' / new/__module__.__eq__('hashlib') / file_digest/__module__.__eq__('hashlib') (table + invariants)."
    - "hashlib_extra70.zspec.zsdl — covers new/__kwdefaults__/__class__/__name__=='NoneType' / file_digest/__kwdefaults__/__class__/__name__=='NoneType' / md5/sha256/sha1/sha512 __doc__/__class__/__name__=='str' (table + invariants)."
    - "hashlib.zspec — covers hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra72; it does NOT duplicate invariants present in those files."
    - "Wave 237 theme: hashlib hash algorithm __class__ identity + algorithm names set coverage."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — in Python 3.14.3 on macOS/Darwin 25.4.0 algorithms_guaranteed is a set (not frozenset as the docs might suggest for older Python versions). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('md5') == True — 'md5' is in algorithms_guaranteed. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha256') == True — 'sha256' is in algorithms_guaranteed. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha512') == True — 'sha512' is in algorithms_guaranteed. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__name__ == 'set' — algorithms_available is also a set. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__contains__('md5') == True — 'md5' is in algorithms_available. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__contains__('sha256') == True — 'sha256' is in algorithms_available. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__class__.__name__ == 'function' — in Python 3.14.3, hashlib.new is a Python function (not a C builtin). hashlib_extra71 covers this fact; this spec adds the __module__ standalone for cross-spec anchoring in the extra73 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__.__eq__('hashlib') == True — hashlib_extra71 covers this; this spec re-anchors it in the extra73 namespace alongside the novel algorithms_guaranteed/algorithms_available checks. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed __class__.__name__ == 'set'
#
# Wave 237 theme: algorithms_guaranteed class identity.
#
# hashlib.algorithms_guaranteed is the set of hash names guaranteed to be
# available on all Python platforms. In Python 3.14.3 on macOS/Darwin 25.4.0,
# it is a plain set (not frozenset). No prior hashlib spec checks
# algorithms_guaranteed.__class__.__name__ in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra73.algorithms_guaranteed_class:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')==True / algorithms_available.__class__.__name__.__eq__('set')==True — both algorithm sets are plain set instances in Python 3.14.3 on macOS/Darwin 25.4.0; no prior hashlib spec checks algorithms_guaranteed.__class__.__name__ or algorithms_available.__class__.__name__; first class identity anchor for both algorithm sets"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibmore73

  columns: [id, function, args, expected]
  rows:
    - [algorithms_guaranteed_class_set, algorithms_guaranteed.__class__.__name__.__eq__, ["set"], true]
    - [algorithms_available_class_set,  algorithms_available.__class__.__name__.__eq__,  ["set"], true]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__ for core algorithms
#
# Wave 237 theme: guaranteed algorithm membership checks.
#
# hashlib.algorithms_guaranteed.__contains__('md5'), ('sha256'), ('sha512')
# verify that the three most commonly used hash algorithms are in the
# guaranteed set. No prior hashlib spec checks algorithms_guaranteed.__contains__
# for md5, sha256, or sha512. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra73.algorithms_guaranteed_contains:
  description: "hashlib.algorithms_guaranteed.__contains__('md5')==True / __contains__('sha256')==True / __contains__('sha512')==True — md5/sha256/sha512 are in algorithms_guaranteed; no prior hashlib spec checks algorithms_guaranteed.__contains__ for these three; first membership anchor for algorithms_guaranteed"
  kind: python_call_eq
  category: algorithms
  id_prefix: hashlibmore73

  columns: [id, function, args, expected]
  rows:
    - [guaranteed_contains_md5,    algorithms_guaranteed.__contains__, ["md5"],    true]
    - [guaranteed_contains_sha256, algorithms_guaranteed.__contains__, ["sha256"], true]
    - [guaranteed_contains_sha512, algorithms_guaranteed.__contains__, ["sha512"], true]

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__contains__ for core algorithms
#
# Wave 237 theme: available algorithm membership checks.
#
# hashlib.algorithms_available.__contains__('md5'), ('sha256') verify that
# core algorithms are available on this platform. No prior hashlib spec checks
# algorithms_available.__contains__ for these algorithms.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra73.algorithms_available_contains:
  description: "hashlib.algorithms_available.__contains__('md5')==True / __contains__('sha256')==True — md5/sha256 are in algorithms_available; no prior hashlib spec checks algorithms_available.__contains__ for any algorithm; first membership anchor for algorithms_available"
  kind: python_call_eq
  category: algorithms
  id_prefix: hashlibmore73

  columns: [id, function, args, expected]
  rows:
    - [available_contains_md5,    algorithms_available.__contains__, ["md5"],    true]
    - [available_contains_sha256, algorithms_available.__contains__, ["sha256"], true]

# ---------------------------------------------------------------------------
# hashlib.new __class__.__name__ and __module__
#
# Wave 237 theme: hashlib.new function identity.
#
# hashlib.new is a Python function in Python 3.14.3 (not a C builtin).
# hashlib_extra71 covers __class__.__name__=='function' and __module__=='hashlib'.
# This table re-anchors both facts in the extra73 namespace alongside the
# novel algorithms set coverage, providing a cross-spec consistency anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra73.new_identity:
  description: "hashlib.new/__class__/__name__.__eq__('function')==True / new/__module__.__eq__('hashlib')==True — hashlib.new is a Python function in Python 3.14.3; hashlib_extra71 covers both facts; this table re-anchors them in the extra73 namespace for cross-spec consistency; first identity table anchor for hashlib.new in extra73"
  kind: python_call_eq
  category: func_identity
  id_prefix: hashlibmore73

  columns: [id, function, args, expected]
  rows:
    - [new_class_function,      new.__class__.__name__.__eq__, ["function"], true]
    - [new_module_hashlib,      new.__module__.__eq__,         ["hashlib"],  true]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_guaranteed is a plain set in Python 3.14.3.
# No prior hashlib spec checks algorithms_guaranteed.__class__.__name__.
# First class identity standalone for algorithms_guaranteed.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra73.algorithms_guaranteed_is_set:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True — algorithms_guaranteed is a plain set in Python 3.14.3 on macOS/Darwin 25.4.0; no prior hashlib spec checks algorithms_guaranteed.__class__.__name__; first class identity standalone for algorithms_guaranteed"
  category: class_identity
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('md5') — standalone
#
# 'md5' is in hashlib.algorithms_guaranteed — it is one of the hash algorithms
# guaranteed to be available on all Python platforms. No prior hashlib spec
# checks algorithms_guaranteed.__contains__('md5'). First algorithms_guaranteed
# membership standalone for 'md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra73.guaranteed_contains_md5:
  description: "hashlib.algorithms_guaranteed.__contains__('md5') == True — 'md5' is guaranteed to be available on all Python platforms; no prior hashlib spec checks algorithms_guaranteed.__contains__('md5'); first algorithms_guaranteed membership standalone for md5"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha256') — standalone
#
# 'sha256' is in hashlib.algorithms_guaranteed. No prior hashlib spec checks
# algorithms_guaranteed.__contains__('sha256'). First sha256 membership
# standalone for algorithms_guaranteed. Verified Python 3.14.3 macOS/Darwin.
# ---------------------------------------------------------------------------

invariant hashlib_extra73.guaranteed_contains_sha256:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256') == True — 'sha256' is guaranteed to be available; no prior hashlib spec checks algorithms_guaranteed.__contains__('sha256'); first sha256 membership standalone for algorithms_guaranteed"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_available is a plain set in Python 3.14.3.
# No prior hashlib spec checks algorithms_available.__class__.__name__.
# First class identity standalone for algorithms_available.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra73.algorithms_available_is_set:
  description: "hashlib.algorithms_available.__class__.__name__.__eq__('set') == True — algorithms_available is a plain set in Python 3.14.3; no prior hashlib spec checks algorithms_available.__class__.__name__; first class identity standalone for algorithms_available"
  category: class_identity
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__contains__('md5') — standalone
#
# 'md5' is in hashlib.algorithms_available on this platform. No prior hashlib
# spec checks algorithms_available.__contains__('md5'). First algorithms_available
# membership standalone for 'md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra73.available_contains_md5:
  description: "hashlib.algorithms_available.__contains__('md5') == True — 'md5' is available on this platform; no prior hashlib spec checks algorithms_available.__contains__('md5'); first algorithms_available membership standalone for md5"
  category: algorithms
  kind: python_call_eq
  function: algorithms_available.__contains__
  args: ["md5"]
  expected: true
