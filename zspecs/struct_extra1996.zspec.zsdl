spec: struct_extra1996
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
    - "CPython source: Modules/_struct.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 580 (_extra1996): __index__, __complex__, __float__, __round__, __abs__ dict-presence checks."
    - "struct.Struct is a binary packing type; it defines no integer or floating-point conversion protocols."
    - "struct.error is an Exception subclass; it defines no numeric protocols in its own __dict__."
    - "All five numeric dunder methods are absent from both struct.Struct.__dict__ and struct.error.__dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra1996.struct_index_protocol:
  description: "struct.Struct __index__ dict-presence checks (Struct is not an integer type)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1996

  columns: [id, function, args, expected]
  rows:
    - ["st1996001", "struct.Struct.__dict__.__contains__", ["__index__"], false]
    - ["st1996002", "struct.Struct.__dict__.__contains__", ["__complex__"], false]
    - ["st1996003", "struct.Struct.__dict__.__contains__", ["__float__"], false]
    - ["st1996004", "struct.Struct.__dict__.__contains__", ["__round__"], false]
    - ["st1996005", "struct.Struct.__dict__.__contains__", ["__abs__"], false]

table struct_extra1996.struct_error_index_protocol:
  description: "struct.error __index__ dict-presence checks (error is not a numeric type)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1996

  columns: [id, function, args, expected]
  rows:
    - ["st1996006", "struct.error.__dict__.__contains__", ["__index__"], false]
    - ["st1996007", "struct.error.__dict__.__contains__", ["__complex__"], false]
    - ["st1996008", "struct.error.__dict__.__contains__", ["__float__"], false]
    - ["st1996009", "struct.error.__dict__.__contains__", ["__round__"], false]
    - ["st1996010", "struct.error.__dict__.__contains__", ["__abs__"], false]

table struct_extra1996.struct_float_round_checks:
  description: "struct.Struct __float__ and __round__ absence confirming non-numeric type"
