  description: "struct.error __float__ and __round__ absence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1996

  columns: [id, function, args, expected]
  rows:
    - ["st1996015", "struct.error.__dict__.__contains__", ["__float__"], false]
    - ["st1996016", "struct.error.__dict__.__contains__", ["__round__"], false]
    - ["st1996017", "struct.error.__dict__.__contains__", ["__complex__"], false]
