  columns: [id, function, args, expected]
  rows:
    - ["st1996011", "struct.Struct.__dict__.__contains__", ["__float__"], false]
    - ["st1996012", "struct.Struct.__dict__.__contains__", ["__round__"], false]
    - ["st1996013", "struct.Struct.__dict__.__contains__", ["__complex__"], false]
