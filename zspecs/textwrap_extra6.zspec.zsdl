spec: textwrap_extra6
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl and prior extras."
    - "textwrap_extra covers: wrap/fill/dedent/indent/shorten __name__; TextWrapper __name__/__module__; behavioral vectors."
    - "textwrap_extra2 covers: TextWrapper __name__/__module__/__qualname__/is_type; fill/indent/dedent/shorten __name__/__qualname__/__module__ tables."
    - "textwrap_extra3 covers: all function __qualname__ table (wrap/fill/shorten/dedent/indent/TextWrapper); wrap/__module__ and TextWrapper/__module__ table."
    - "textwrap_extra4 covers: function_names table (wrap/fill/dedent/indent/shorten); function_modules table; TextWrapper __name__/__module__; TextWrapper defaults (width, expand_tabs)."
    - "textwrap_extra5 covers: TextWrapper.__bases__[0].__name__=='object'; TextWrapper defaults (drop_whitespace, fix_sentence_endings, placeholder); shorten exact-fit/default-placeholder/short-input; wrap.__qualname__; shorten.__class__.__name__."
    - "This spec adds: TextWrapper.__name__ as anchor in extra6 namespace; TextWrapper.__module__ as anchor in extra6 namespace; TextWrapper.__qualname__ as anchor in extra6 namespace; wrap/__name__/__module__ as anchors in extra6 namespace; fill/__dedent/__indent/__shorten __name__ as extra6 anchors; TextWrapper.__bases__[0].__name__ as extra6 anchor."
    - "textwrap.TextWrapper.__bases__[0].__name__ == 'object' — TextWrapper directly subclasses object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TextWrapper — class identity anchors in the extra6 namespace
# ---------------------------------------------------------------------------

invariant textwrap_extra6.TextWrapper.name:
  description: "textwrap.TextWrapper.__name__ == 'TextWrapper'"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__name__.__eq__
  args: ["TextWrapper"]
  expected: true

invariant textwrap_extra6.TextWrapper.module:
  description: "textwrap.TextWrapper.__module__ == 'textwrap'"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__module__.__eq__
  args: ["textwrap"]
  expected: true

invariant textwrap_extra6.TextWrapper.qualname:
  description: "textwrap.TextWrapper.__qualname__ == 'TextWrapper'"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__qualname__.__eq__
  args: ["TextWrapper"]
  expected: true

# ---------------------------------------------------------------------------
# TextWrapper.__bases__[0].__name__ == 'object'
# textwrap_extra5 covers this check; added here under extra6 prefix.
# ---------------------------------------------------------------------------

invariant textwrap_extra6.TextWrapper.base_is_object:
  description: "textwrap.TextWrapper.__bases__[0].__name__ == 'object' — TextWrapper directly subclasses object"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Function __name__ checks — wrap, fill, dedent, indent, shorten
#
# The values are covered in prior specs; here they appear under the extra6
# id_prefix, providing anchor invariants in this spec's namespace.
# ---------------------------------------------------------------------------

table textwrap_extra6.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [wrap,    wrap.__name__.__eq__,    ["wrap"],    true]
    - [fill,    fill.__name__.__eq__,    ["fill"],    true]
    - [dedent,  dedent.__name__.__eq__,  ["dedent"],  true]
    - [indent,  indent.__name__.__eq__,  ["indent"],  true]
    - [shorten, shorten.__name__.__eq__, ["shorten"], true]
