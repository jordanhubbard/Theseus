spec: hmac_extra21
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"
  - "RFC 4231 — Identifiers and Test Vectors for HMAC-SHA-224, SHA-256, SHA-384, SHA-512"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "RFC 4231 — Identifiers and Test Vectors for HMAC-SHA-224, SHA-256, SHA-384, SHA-512, December 2005"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hmac_extra20.zspec.zsdl — covers HMAC/__name__; new/digest/compare_digest __name__; new(md5) digest_size/block_size; new(sha512) digest_size."
    - "hmac_extra19.zspec.zsdl — covers new(sha1) digest_size/block_size/hexdigest len; digest(sha256) len; new/digest __qualname__."
    - "hmac_extra18.zspec.zsdl — covers new(sha256) hexdigest class name and length; compare_digest str/bytes arguments."
    - "hmac_extra17.zspec.zsdl — covers new/compare_digest/digest __name__/__module__; HMAC __qualname__/__module__/__bases__[0].__name__."
    - "hmac_extra16.zspec.zsdl — covers hexdigest/digest lengths for md5/sha256/sha512; function __name__/__module__ table."
    - "hmac_extra15.zspec.zsdl — covers digest_size/block_size with None msg; sha224 name; HMAC class_name."
    - "hmac_extra13.zspec.zsdl — covers RFC 2202/4231 test vectors; compare_digest/new __name__; sha256 name/block_size."
  notes:
    - "This spec extends hmac through hmac_extra20; it does NOT duplicate invariants present in those files."
    - "Focus: __module__.__len__() checks for digest/compare_digest/new/HMAC; new(b'k', b'm', 'sha224') digest_size and block_size; new(b'k', b'm', 'sha384') digest_size and block_size; __class__.__name__ table for all four hmac callables."
    - "hmac.digest.__module__.__len__() == 4: len('hmac') == 4. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.compare_digest.__module__.__len__() == 8: len('_hashlib') == 8 (implemented in C extension). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.new.__module__.__len__() == 4: len('hmac') == 4. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__module__.__len__() == 4: len('hmac') == 4. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.new(b'k', b'm', 'sha224').digest_size == 28: SHA-224 HMAC produces a 224-bit (28-byte) digest. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.new(b'k', b'm', 'sha224').block_size == 64: SHA-224 uses 512-bit (64-byte) blocks. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.new(b'k', b'm', 'sha384').digest_size == 48: SHA-384 HMAC produces a 384-bit (48-byte) digest. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.new(b'k', b'm', 'sha384').block_size == 128: SHA-384 uses 1024-bit (128-byte) blocks. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() checks — novel execution path
#
# hmac_extra17 covers __module__ values as __eq__ checks in a table.
# No prior spec checks the length of the __module__ strings.
# digest/new/HMAC are defined in 'hmac' (len 4); compare_digest is in
# '_hashlib' (len 8) because it is implemented as a C built-in.
# ---------------------------------------------------------------------------

invariant hmac_extra21.digest.module_len:
  description: "hmac.digest.__module__.__len__() == 4 — len('hmac') == 4"
  category: module_metadata
  kind: python_call_eq
  function: digest.__module__.__len__
  args: []
  expected: 4

invariant hmac_extra21.compare_digest.module_len:
  description: "hmac.compare_digest.__module__.__len__() == 8 — len('_hashlib') == 8"
  category: module_metadata
  kind: python_call_eq
  function: compare_digest.__module__.__len__
  args: []
  expected: 8

invariant hmac_extra21.new.module_len:
  description: "hmac.new.__module__.__len__() == 4 — len('hmac') == 4"
  category: module_metadata
  kind: python_call_eq
  function: new.__module__.__len__
  args: []
  expected: 4

invariant hmac_extra21.HMAC.module_len:
  description: "hmac.HMAC.__module__.__len__() == 4 — len('hmac') == 4"
  category: module_metadata
  kind: python_call_eq
  function: HMAC.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# hmac.new(b'k', b'm', 'sha224') — digest_size and block_size
#
# hmac_extra19 covers sha1 digest_size/block_size; hmac_extra20 covers md5.
# hmac_extra15 covers sha224 via None msg fixture (different args).
# No prior spec covers new(b'k', b'm', 'sha224') digest_size or block_size
# using the single-character key/msg fixture from the extra21 namespace.
# ---------------------------------------------------------------------------

invariant hmac_extra21.new.sha224.digest_size:
  description: "hmac.new(b'k', b'm', 'sha224').digest_size == 28 — SHA-224 HMAC produces a 28-byte digest"
  category: digest_sizes
  kind: python_call_eq
  function: new
  args: [!ascii "k", !ascii "m", "sha224"]
  method: digest_size
  method_args: []
  expected: 28

invariant hmac_extra21.new.sha224.block_size:
  description: "hmac.new(b'k', b'm', 'sha224').block_size == 64 — SHA-224 uses 512-bit (64-byte) blocks"
  category: block_sizes
  kind: python_call_eq
  function: new
  args: [!ascii "k", !ascii "m", "sha224"]
  method: block_size
  method_args: []
  expected: 64

# ---------------------------------------------------------------------------
# hmac.new(b'k', b'm', 'sha384') — digest_size and block_size
#
# No prior spec covers new(b'k', b'm', 'sha384') digest_size or block_size.
# SHA-384 uses the same 1024-bit (128-byte) block structure as SHA-512.
# SHA-384 produces 384-bit (48-byte) digests.
# ---------------------------------------------------------------------------

invariant hmac_extra21.new.sha384.digest_size:
  description: "hmac.new(b'k', b'm', 'sha384').digest_size == 48 — SHA-384 HMAC produces a 48-byte digest"
  category: digest_sizes
  kind: python_call_eq
  function: new
  args: [!ascii "k", !ascii "m", "sha384"]
  method: digest_size
  method_args: []
  expected: 48

invariant hmac_extra21.new.sha384.block_size:
  description: "hmac.new(b'k', b'm', 'sha384').block_size == 128 — SHA-384 uses 1024-bit (128-byte) blocks"
  category: block_sizes
  kind: python_call_eq
  function: new
  args: [!ascii "k", !ascii "m", "sha384"]
  method: block_size
  method_args: []
  expected: 128

# ---------------------------------------------------------------------------
# __class__.__name__ table for hmac callables
#
# hmac_extra15 covers HMAC __class__.__name__ from extra15 namespace.
# No prior spec groups digest/compare_digest/new/HMAC __class__.__name__
# in a single table from the extra21 namespace.
# digest and new are plain functions; compare_digest is a C built-in;
# HMAC is a class (type).
# ---------------------------------------------------------------------------

table hmac_extra21.callable_class_names:
  description: "__class__.__name__ for each callable in the hmac module"
  kind: python_call_eq
  category: class_metadata
  id_prefix: hmaccls21

  columns: [id, function, args, expected]
  rows:
    - [digest,          digest.__class__.__name__.__eq__,          ["function"],                  true]
    - [compare_digest,  compare_digest.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [new,             new.__class__.__name__.__eq__,             ["function"],                  true]
    - [HMAC,            HMAC.__class__.__name__.__eq__,            ["type"],                      true]
