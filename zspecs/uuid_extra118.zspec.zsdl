spec: uuid_extra118
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__code__.co_name/co_argcount / UUID.__init__/__str__/__repr__/__eq__/__hash__/__lt__ __qualname__ equality and __len__() / UUID.__str__/__repr__/__eq__/__hash__ __class__.__name__=='function' (table + invariants)."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants (NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500) __class__.__name__, hex values, str() values, version attributes (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant/clock_seq_hi_variant / RFC field property qualname lengths / type(UUID.hex).__name__=='property' (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__.__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length (table + invariants)."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID __name__/__qualname__.__eq__ and __name__.__len__()==8 / SafeUUID.__bases__[0].__name__=='Enum' / UUID.hex/bytes/urn/fields/variant/version fget.__qualname__.__len__() (table + invariants)."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 / UUID.__setattr__.__class__.__name__=='function' / uuid3/uuid5/getnode __qualname__.__len__() / SafeUUID metaclass/module/MRO depth (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra99."
    - "Wave 278 theme: UUID comparison and arithmetic method qualnames and co_argcount — UUID.__int__/__gt__/__le__/__ge__ __qualname__ equality and __len__() / co_argcount cross-check for comparison methods."
    - "uuid.UUID.__int__.__qualname__ == 'UUID.__int__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(uuid.UUID.__int__.__qualname__) == 12. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__gt__.__qualname__ == 'UUID.__gt__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(uuid.UUID.__gt__.__qualname__) == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__qualname__ == 'UUID.__le__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(uuid.UUID.__le__.__qualname__) == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ge__.__qualname__ == 'UUID.__ge__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(uuid.UUID.__ge__.__qualname__) == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__gt__.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ge__.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: UUID.__gt__, UUID.__le__, UUID.__ge__ all have qualname length 11, the same as UUID.__eq__ and UUID.__lt__ (all 'UUID.__xx__' where __xx__ is 6 chars); they share the same pattern."
    - "Note: UUID.__int__ has qualname length 12 ('UUID.__int__' = 'UUID.'5 + '__int__'7) — one char longer than the 6-char dunder comparison methods."
    - "Note: UUID.__int__ has co_argcount==1 (only self); comparison methods (__gt__, __le__, __ge__) have co_argcount==2 (self + other). This matches extra99's UUID.__lt__ which also has co_argcount==2."
    - "Note: uuid_extra99 covers UUID.__lt__ qualname; this spec covers UUID.__gt__/__le__/__ge__ qualnames completing the ordering set."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__int__.__qualname__.__eq__('UUID.__int__')
# uuid.UUID.__int__.__qualname__.__len__()==12
# uuid.UUID.__int__.__class__.__name__.__eq__('function')
# uuid.UUID.__int__.__code__.co_argcount.__eq__(1)
#
# Wave 278 theme: UUID.__int__ method qualname and code attributes.
#
# UUID.__int__.__qualname__ is 'UUID.__int__' (12 chars: 'UUID.'=5 + '__int__'=7).
# UUID.__int__ converts a UUID to its 128-bit integer representation.
# Unlike comparison methods (__gt__, __le__, __ge__) which take 2 args (self + other),
# UUID.__int__ takes only 1 arg (self), so co_argcount==1. uuid_extra99 covers
# UUID.__lt__/__eq__/__hash__/__str__/__repr__ qualnames; no prior uuid spec
# anchors UUID.__int__ qualname or co_argcount under uuidmeth118.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra118.UUID_int_method_attrs:
  description: "UUID.__int__.__qualname__.__eq__('UUID.__int__')==True / UUID.__int__.__qualname__.__len__()==12 / UUID.__int__.__class__.__name__.__eq__('function')==True / UUID.__int__.__code__.co_argcount.__eq__(1)==True — UUID.__int__ converts UUID to 128-bit int; qualname is 12 chars ('UUID.'5 + '__int__'7); co_argcount==1 (only self, unlike comparison methods which take 2 args); extra99 covers __lt__/__eq__ qualnames; first uuidmeth118 anchor for UUID.__int__"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: uuidmeth118

  columns: [id, function, args, expected, description]
  rows:
    - [int_qualname_eq,    "UUID.__int__.__qualname__.__eq__",          ["UUID.__int__"], true, "UUID.__int__.__qualname__ is 'UUID.__int__' (12 chars: 'UUID.'5 + '__int__'7)"]
    - [int_qualname_len,   "UUID.__int__.__qualname__.__len__",          [],              12,   "UUID.__int__.__qualname__.__len__() is 12 (one more than 11-char comparison method qualnames)"]
    - [int_class_function, "UUID.__int__.__class__.__name__.__eq__",    ["function"],    true, "UUID.__int__ is a Python-level function (not a C builtin or method_descriptor)"]
    - [int_co_argcount,    "UUID.__int__.__code__.co_argcount.__eq__",  [1],             true, "UUID.__int__.__code__.co_argcount==1 (only self; no 'other' arg unlike comparison methods)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__gt__.__qualname__.__eq__('UUID.__gt__')
# uuid.UUID.__gt__.__qualname__.__len__()==11
# uuid.UUID.__le__.__qualname__.__eq__('UUID.__le__')
# uuid.UUID.__le__.__qualname__.__len__()==11
# uuid.UUID.__ge__.__qualname__.__eq__('UUID.__ge__')
#
# Wave 278 theme: UUID.__gt__, UUID.__le__, UUID.__ge__ method qualnames.
#
# All three have qualname length 11: 'UUID.__gt__'=11, 'UUID.__le__'=11,
# 'UUID.__ge__'=11. This matches UUID.__eq__ and UUID.__lt__ (also 11 chars,
# anchored in extra99). Together __lt__, __le__, __gt__, __ge__ form the full
# ordering comparison set for UUID instances. All are Python-level functions
# with co_argcount==2 (self + other). No prior uuid spec anchors UUID.__gt__,
# UUID.__le__, UUID.__ge__ qualname equality under uuidmeth118.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra118.UUID_gt_le_ge_qualnames:
  description: "UUID.__gt__/__qualname__.__eq__('UUID.__gt__')==True / UUID.__gt__/__qualname__/__len__()==11 / UUID.__le__/__qualname__.__eq__('UUID.__le__')==True / UUID.__le__/__qualname__/__len__()==11 / UUID.__ge__/__qualname__.__eq__('UUID.__ge__')==True — __gt__/__le__/__ge__ all have qualname length 11 (same as __lt__/__eq__ in extra99); together form full UUID ordering set; co_argcount==2 for all three; no prior uuid spec anchors these; first uuidmeth118 anchor for ordering method qualnames"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: uuidmeth118

  columns: [id, function, args, expected, description]
  rows:
    - [gt_qualname_eq,  "UUID.__gt__.__qualname__.__eq__",  ["UUID.__gt__"],  true, "UUID.__gt__.__qualname__ is 'UUID.__gt__' (11 chars; same length as __lt__/__eq__ in extra99)"]
    - [gt_qualname_len, "UUID.__gt__.__qualname__.__len__", [],               11,   "UUID.__gt__.__qualname__.__len__() is 11 ('UUID.'5 + '__gt__'6)"]
    - [le_qualname_eq,  "UUID.__le__.__qualname__.__eq__",  ["UUID.__le__"],  true, "UUID.__le__.__qualname__ is 'UUID.__le__' (11 chars; part of full ordering set)"]
    - [le_qualname_len, "UUID.__le__.__qualname__.__len__", [],               11,   "UUID.__le__.__qualname__.__len__() is 11 ('UUID.'5 + '__le__'6)"]
    - [ge_qualname_eq,  "UUID.__ge__.__qualname__.__eq__",  ["UUID.__ge__"],  true, "UUID.__ge__.__qualname__ is 'UUID.__ge__' (11 chars; part of full ordering set)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__ge__.__qualname__.__len__()==11
# uuid.UUID.__ge__.__class__.__name__.__eq__('function')
# uuid.UUID.__gt__.__code__.co_argcount.__eq__(2)
# uuid.UUID.__le__.__code__.co_argcount.__eq__(2)
# uuid.UUID.__ge__.__code__.co_argcount.__eq__(2)
#
# Wave 278 theme: UUID ordering method class names and co_argcount.
#
# All three ordering methods (__gt__, __le__, __ge__) are Python-level 'function'
# objects with co_argcount==2 (self + other). This matches UUID.__lt__ (anchored
# in extra99). Together these confirm the full UUID ordering implementation is
# pure Python, not C-level. No prior uuid spec anchors UUID.__ge__ qualname length
# or co_argcount for __gt__/__le__/__ge__ under uuidmeth118.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra118.UUID_ordering_co_argcount:
  description: "UUID.__ge__/__qualname__/__len__()==11 / UUID.__ge__/__class__.__name__.__eq__('function')==True / UUID.__gt__/__code__.co_argcount.__eq__(2)==True / UUID.__le__/__code__.co_argcount.__eq__(2)==True / UUID.__ge__/__code__.co_argcount.__eq__(2)==True — all three ordering methods are Python-level functions with co_argcount==2 (self + other); together with extra99 __lt__, confirm full UUID ordering is pure Python; first uuidmeth118 anchor for ordering co_argcount"
  kind: python_call_eq
  category: method_attributes
  id_prefix: uuidmeth118

  columns: [id, function, args, expected, description]
  rows:
    - [ge_qualname_len,    "UUID.__ge__.__qualname__.__len__",           [],  11,   "UUID.__ge__.__qualname__.__len__() is 11 (completes the ordering-method qualname-length group)"]
    - [ge_class_function,  "UUID.__ge__.__class__.__name__.__eq__",      ["function"], true, "UUID.__ge__ is a Python-level function (defined in Lib/uuid.py)"]
    - [gt_co_argcount,     "UUID.__gt__.__code__.co_argcount.__eq__",    [2],          true, "UUID.__gt__.__code__.co_argcount==2 (self + other; same pattern as __lt__ in extra99)"]
    - [le_co_argcount,     "UUID.__le__.__code__.co_argcount.__eq__",    [2],          true, "UUID.__le__.__code__.co_argcount==2 (self + other; binary comparison method)"]
    - [ge_co_argcount,     "UUID.__ge__.__code__.co_argcount.__eq__",    [2],          true, "UUID.__ge__.__code__.co_argcount==2 (self + other; completes the full ordering set co_argcount)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__int__.__qualname__.__eq__('UUID.__int__') — standalone
#
# uuid.UUID.__int__.__qualname__ is 'UUID.__int__'. UUID.__int__ converts a UUID
# instance to its 128-bit integer representation. The integer value is the raw
# numerical value of the UUID's 16 bytes interpreted as a big-endian unsigned
# integer. uuid_extra99 covers UUID.__str__/__repr__/__eq__/__hash__/__lt__
# qualnames; no prior uuid spec anchors UUID.__int__.__qualname__ as a standalone
# under uuidmeth118. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra118.UUID_int_qualname_eq:
  description: "uuid.UUID.__int__.__qualname__.__eq__('UUID.__int__') == True — qualname is 'UUID.__int__' (12 chars = 'UUID.'5 + '__int__'7); UUID.__int__ converts a UUID to its 128-bit integer representation; extra99 covers __str__/__repr__/__eq__/__hash__/__lt__ qualnames; first standalone for UUID.__int__.__qualname__ under uuidmeth118"
  category: method_qualnames
  kind: python_call_eq
  function: "UUID.__int__.__qualname__.__eq__"
  args: ["UUID.__int__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__gt__.__qualname__.__eq__('UUID.__gt__') — standalone
#
# uuid.UUID.__gt__.__qualname__ is 'UUID.__gt__'. UUID supports full ordering via
# __lt__, __le__, __gt__, __ge__ (all defined in Lib/uuid.py). uuid_extra99
# anchors UUID.__lt__ qualname; this standalone anchors UUID.__gt__ as the
# complementary greater-than comparison method. Both have qualname length 11.
# No prior uuid spec anchors UUID.__gt__.__qualname__ as a standalone under
# uuidmeth118. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra118.UUID_gt_qualname_eq:
  description: "uuid.UUID.__gt__.__qualname__.__eq__('UUID.__gt__') == True — qualname is 'UUID.__gt__' (11 chars = 'UUID.'5 + '__gt__'6); UUID.__gt__ is the greater-than comparison complement to UUID.__lt__ (anchored in extra99); both have qualname length 11; no prior uuid spec anchors UUID.__gt__ qualname as standalone; first standalone for UUID.__gt__.__qualname__ under uuidmeth118"
  category: method_qualnames
  kind: python_call_eq
  function: "UUID.__gt__.__qualname__.__eq__"
  args: ["UUID.__gt__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__le__.__qualname__.__len__()==11 — standalone
#
# uuid.UUID.__le__.__qualname__.__len__() is 11. The qualname 'UUID.__le__'
# has the same length as 'UUID.__lt__', 'UUID.__eq__', 'UUID.__gt__', and
# 'UUID.__ge__' — all 11 chars. UUID.__le__ enables less-than-or-equal
# comparisons between UUID instances. All five comparison-method qualnames
# share the same 11-char length pattern 'UUID.__xx__' where __xx__ is 6 chars.
# No prior uuid spec anchors UUID.__le__.__qualname__.__len__() as a standalone
# under uuidmeth118. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra118.UUID_le_qualname_len_11:
  description: "uuid.UUID.__le__.__qualname__.__len__() == 11 — 'UUID.__le__' is 11 chars ('UUID.'5 + '__le__'6); same length as UUID.__lt__, UUID.__eq__, UUID.__gt__, UUID.__ge__ (all 11); all five comparison-method qualnames share the 'UUID.__xx__' pattern; no prior uuid spec anchors UUID.__le__ qualname length as standalone; first standalone for UUID.__le__.__qualname__.__len__() under uuidmeth118"
  category: method_qualnames
  kind: python_call_eq
  function: "UUID.__le__.__qualname__.__len__"
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# uuid.UUID.__ge__.__qualname__.__eq__('UUID.__ge__') — standalone
#
# uuid.UUID.__ge__.__qualname__ is 'UUID.__ge__'. UUID.__ge__ enables
# greater-than-or-equal comparisons between UUID instances. Together with
# __lt__, __le__, __gt__, __ge__, UUID implements the full rich-comparison
# interface. uuid_extra99 anchors UUID.__lt__ qualname; this standalone
# completes the set by anchoring UUID.__ge__. Both have qualname length 11.
# No prior uuid spec anchors UUID.__ge__.__qualname__ as a standalone under
# uuidmeth118. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra118.UUID_ge_qualname_eq:
  description: "uuid.UUID.__ge__.__qualname__.__eq__('UUID.__ge__') == True — qualname is 'UUID.__ge__' (11 chars = 'UUID.'5 + '__ge__'6); completes the full UUID rich-comparison interface set (__lt__, __le__, __gt__, __ge__); extra99 anchors __lt__ qualname; no prior uuid spec anchors UUID.__ge__ qualname as standalone; first standalone for UUID.__ge__.__qualname__ under uuidmeth118"
  category: method_qualnames
  kind: python_call_eq
  function: "UUID.__ge__.__qualname__.__eq__"
  args: ["UUID.__ge__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__int__.__code__.co_argcount.__eq__(1) — standalone
#
# uuid.UUID.__int__.__code__.co_argcount is 1. UUID.__int__ takes only self —
# it converts the UUID instance to its 128-bit integer value with no other
# arguments. This contrasts with the comparison methods (__gt__, __le__, __ge__)
# which have co_argcount==2 (self + other). The integer value is used internally
# in UUID comparisons and hashing. No prior uuid spec anchors UUID.__int__
# co_argcount as a standalone under uuidmeth118.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra118.UUID_int_co_argcount_1:
  description: "uuid.UUID.__int__.__code__.co_argcount.__eq__(1) == True — UUID.__int__ takes only self (co_argcount==1); converts UUID instance to 128-bit integer; contrast with comparison methods (__gt__, __le__, __ge__) which have co_argcount==2 (self + other); no prior uuid spec anchors UUID.__int__ co_argcount as standalone; first standalone for UUID.__int__ co_argcount under uuidmeth118"
  category: method_attributes
  kind: python_call_eq
  function: "UUID.__int__.__code__.co_argcount.__eq__"
  args: [1]
  expected: true

