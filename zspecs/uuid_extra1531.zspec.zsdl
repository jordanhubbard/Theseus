spec: uuid_extra1531
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra1516.zspec.zsdl — covers arithmetic operator absence (__add__ through __pow__) for UUID and SafeUUID; comparison/string ops present (str, repr, int, eq, lt, hash)."
    - "uuid_extra1501.zspec.zsdl — covers bitwise operator absence on UUID and SafeUUID."
    - "uuid_extra15.zspec.zsdl — covers NAMESPACE_DNS/URL/OID __class__.__qualname__; UUID.__module__.__eq__; uuid3/uuid5 __qualname__ standalone."
  notes:
    - "This spec is wave 549 / suffix _extra1531. Theme: comparison operator dict-presence checks on uuid.UUID and uuid.SafeUUID."
    - "uuid.UUID implements a rich ordered comparison protocol: __eq__, __lt__, __le__, __gt__, __ge__ are all present in UUID.__dict__."
    - "uuid.UUID also defines __hash__ so UUIDs can be used as dict keys and in sets."
    - "__ne__ is NOT in UUID.__dict__ — Python derives it from __eq__ automatically (reflected negation)."
    - "uuid.SafeUUID is an Enum subclass. It inherits comparison semantics from Enum/object; none of __lt__, __le__, __gt__, __ge__, __eq__, __hash__, __ne__ appear in SafeUUID.__dict__."
    - "Verified: uuid.UUID.__dict__.__contains__('__lt__') == True."
    - "Verified: uuid.UUID.__dict__.__contains__('__le__') == True."
    - "Verified: uuid.UUID.__dict__.__contains__('__gt__') == True."
    - "Verified: uuid.UUID.__dict__.__contains__('__ge__') == True."
    - "Verified: uuid.UUID.__dict__.__contains__('__eq__') == True."
    - "Verified: uuid.UUID.__dict__.__contains__('__hash__') == True."
    - "Verified: uuid.UUID.__dict__.__contains__('__ne__') == False."
    - "Verified: uuid.SafeUUID.__dict__.__contains__('__lt__') == False (through __ne__) == False."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID — comparison operator presence checks
#
# uuid.UUID is an immutable value type wrapping a 128-bit integer. It
# implements a complete ordered comparison suite: __eq__, __lt__, __le__,
# __gt__, __ge__ are all explicitly defined in UUID.__dict__, enabling UUIDs
# to be sorted and compared directly. __hash__ is also defined, making UUIDs
# usable as dict keys and set members. __ne__ is the only standard comparison
# dunder absent — Python synthesises it from __eq__ automatically.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table uuid_extra1531.UUID_cmp_present:
  description: "Comparison and hash dunders present in uuid.UUID.__dict__ — UUID supports full ordering"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu1531cp

  columns: [id, function, args, expected]
  rows:
    - ["uu1531cp001", "UUID.__dict__.__contains__", ["__lt__"],   true]
    - ["uu1531cp002", "UUID.__dict__.__contains__", ["__le__"],   true]
    - ["uu1531cp003", "UUID.__dict__.__contains__", ["__gt__"],   true]
    - ["uu1531cp004", "UUID.__dict__.__contains__", ["__ge__"],   true]
    - ["uu1531cp005", "UUID.__dict__.__contains__", ["__eq__"],   true]
    - ["uu1531cp006", "UUID.__dict__.__contains__", ["__hash__"], true]
    - ["uu1531cp007", "UUID.__dict__.__contains__", ["__ne__"],   false]
    - ["uu1531cp008", "UUID.__dict__.__contains__", ["__init__"], true]
    - ["uu1531cp009", "UUID.__dict__.__contains__", ["__str__"],  true]

# ---------------------------------------------------------------------------
# uuid.UUID — property dict-presence checks
#
# uuid.UUID exposes many read-only properties (bytes, bytes_le, hex, int,
# fields, urn, variant, version, is_safe, node, time, clock_seq) all defined
# directly in UUID.__dict__. These contrast with the arithmetic dunders
# (__add__, __mul__, etc.) that are absent. This table validates that the
# property descriptors are present alongside the comparison operators.
# ---------------------------------------------------------------------------

table uuid_extra1531.UUID_properties_present:
  description: "Property descriptors present in uuid.UUID.__dict__ — UUID value accessors"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu1531pp

  columns: [id, function, args, expected]
  rows:
    - ["uu1531pp001", "UUID.__dict__.__contains__", ["bytes"],     true]
    - ["uu1531pp002", "UUID.__dict__.__contains__", ["bytes_le"],  true]
    - ["uu1531pp003", "UUID.__dict__.__contains__", ["hex"],       true]
    - ["uu1531pp004", "UUID.__dict__.__contains__", ["int"],       true]
    - ["uu1531pp005", "UUID.__dict__.__contains__", ["fields"],    true]
    - ["uu1531pp006", "UUID.__dict__.__contains__", ["urn"],       true]
    - ["uu1531pp007", "UUID.__dict__.__contains__", ["variant"],   true]
    - ["uu1531pp008", "UUID.__dict__.__contains__", ["version"],   true]
    - ["uu1531pp009", "UUID.__dict__.__contains__", ["is_safe"],   true]
    - ["uu1531pp010", "UUID.__dict__.__contains__", ["node"],      true]
    - ["uu1531pp011", "UUID.__dict__.__contains__", ["time"],      true]
    - ["uu1531pp012", "UUID.__dict__.__contains__", ["clock_seq"], true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID — comparison operator absence checks
#
# uuid.SafeUUID is defined as class SafeUUID(enum.Enum). Its MRO is
# [SafeUUID, Enum, object]. It inherits all comparison behaviour from
# Enum and object — none of the comparison dunders are overridden in
# SafeUUID's own __dict__. The True entries (safe, unsafe, unknown, __new__,
# __doc__, __module__) confirm that dict lookups on SafeUUID work correctly
# and that the False results for comparison ops are genuine absences.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table uuid_extra1531.SafeUUID_cmp_absent:
  description: "Comparison operator dunders absent from uuid.SafeUUID.__dict__ — inherited from Enum"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu1531sc

  columns: [id, function, args, expected]
  rows:
    - ["uu1531sc001", "SafeUUID.__dict__.__contains__", ["__lt__"],         false]
    - ["uu1531sc002", "SafeUUID.__dict__.__contains__", ["__le__"],         false]
    - ["uu1531sc003", "SafeUUID.__dict__.__contains__", ["__gt__"],         false]
    - ["uu1531sc004", "SafeUUID.__dict__.__contains__", ["__ge__"],         false]
    - ["uu1531sc005", "SafeUUID.__dict__.__contains__", ["__eq__"],         false]
    - ["uu1531sc006", "SafeUUID.__dict__.__contains__", ["__hash__"],       false]
    - ["uu1531sc007", "SafeUUID.__dict__.__contains__", ["__ne__"],         false]
    - ["uu1531sc008", "SafeUUID.__dict__.__contains__", ["safe"],           true]
    - ["uu1531sc009", "SafeUUID.__dict__.__contains__", ["unsafe"],         true]
    - ["uu1531sc010", "SafeUUID.__dict__.__contains__", ["unknown"],        true]
    - ["uu1531sc011", "SafeUUID.__dict__.__contains__", ["__new__"],        true]
    - ["uu1531sc012", "SafeUUID.__dict__.__contains__", ["__doc__"],        true]
