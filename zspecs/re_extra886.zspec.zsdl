spec: re_extra886
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from:
    - re module CPython source
    - Python documentation for re.Pattern and re.Match
  not_derived_from:
    - any third-party regex library
  notes:
    - Covers re.Pattern and re.Match method __doc__ class name assertions
    - Verifies that method docstrings are of type str
  created_at: "2026-04-12"

table re_extra886.pattern_method_docs:
  description: re.Pattern method __doc__ __class__.__name__ assertions
  kind: python_call_eq
  category: doctype
  id_prefix: re886pm
  columns: [id, function, args, expected]
  rows:
    - [re886pm001, re.Pattern.match.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re886pm002, re.Pattern.search.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re886pm003, re.Pattern.fullmatch.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re886pm004, re.Pattern.split.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re886pm005, re.Pattern.findall.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re886pm006, re.Pattern.finditer.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re886pm007, re.Pattern.sub.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re886pm008, re.Pattern.subn.__doc__.__class__.__name__.__eq__, ["str"], true]

table re_extra886.match_method_docs:
  description: re.Match method __doc__ __class__.__name__ assertions
  kind: python_call_eq
  category: doctype
  id_prefix: re886mm
  columns: [id, function, args, expected]
  rows:
    - [re886mm001, re.Match.group.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re886mm002, re.Match.groups.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re886mm003, re.Match.groupdict.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re886mm004, re.Match.span.__doc__.__class__.__name__.__eq__, ["str"], true]
