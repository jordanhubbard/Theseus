spec: unittest_extra10
version: ">=3.9"
backend: python_module(unittest)

docs: https://docs.python.org/3/library/unittest.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unittest.html — Python unittest module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/unittest/__init__.py"
    - "unittest_extra9.zspec.zsdl — covers __qualname__ standalone invariants for TestCase/TestSuite/TestLoader/TestResult/TextTestRunner/skip/skipIf/main; __qualname__ table with eight symbols"
    - "unittest_extra8.zspec.zsdl — covers unittest.mock classes/functions __name__/__module__/__qualname__; patch sub-function names; MagicMock/Mock/NonCallableMock/NonCallableMagicMock __bases__"
    - "unittest_extra5.zspec.zsdl — covers class_qualnames table; decorator_qualnames table"
  notes:
    - "This spec extends unittest_extra9.zspec.zsdl."
    - "Focus: unittest.__all__.__len__()==22 and __all__.__class__.__name__=='list'; __dict__.__class__.__name__.__len__()==12 for TestCase/TestSuite/TestLoader/TestResult; TestCase.__mro__.__len__()==2 and __bases__[0].__name__.__len__()==6 ('object'); TestSuite.__mro__.__len__()==3 and TestSuite.__bases__[0].__name__=='BaseTestSuite' (len 13); TestLoader/TestResult __mro__.__len__()==2; method __qualname__.__len__() for assertEqual/assertRaises/setUp/tearDown/run/skipTest/loadTestsFromName."
    - "unittest.__all__.__len__() == 22. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "unittest.__all__.__class__.__name__ == 'list'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "unittest.TestCase.__dict__.__class__.__name__ == 'mappingproxy' — len 12. Same for TestSuite, TestLoader, TestResult. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "unittest.TestCase.__mro__.__len__() == 2 (TestCase, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "unittest.TestCase.__bases__[0].__name__ == 'object' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "unittest.TestSuite.__mro__.__len__() == 3 (TestSuite, BaseTestSuite, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "unittest.TestSuite.__bases__[0].__name__ == 'BaseTestSuite' — len 13. NOT 'object' as suggested in the task brief; actual MRO has an intermediate base. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "unittest.TestLoader.__mro__.__len__() == 2 (TestLoader, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "unittest.TestResult.__mro__.__len__() == 2 (TestResult, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Method __qualname__.__len__() values: assertEqual 20, assertRaises 21, setUp 14, tearDown 17, run 12, skipTest 17, loadTestsFromName 28."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# unittest.__all__.__len__() and __all__.__class__.__name__
#
# No prior spec checks __all__.__len__() or __all__.__class__.__name__.
# unittest.__all__ is a list of 22 public names on Python 3.12.
# ---------------------------------------------------------------------------

invariant unittest_extra10.all_len:
  description: "unittest.__all__.__len__() == 22 — 22 public names exported"
  category: module_structure
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 22

invariant unittest_extra10.all_class_name:
  description: "unittest.__all__.__class__.__name__ == 'list' — __all__ is a plain list"
  category: module_structure
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() == 12 for core classes
#
# No prior spec checks __dict__.__class__.__name__.__len__() for unittest classes.
# Class __dict__ is a mappingproxy; len('mappingproxy') == 12.
# ---------------------------------------------------------------------------

table unittest_extra10.class_dict_proxy_name_lens:
  description: "TestCase/TestSuite/TestLoader/TestResult __dict__.__class__.__name__.__len__() == 12"
  kind: python_call_eq
  category: class_structure
  id_prefix: utdpnl10

  columns: [id, function, args, expected, description]
  rows:
    - [TestCase_dict_class_len,
       "TestCase.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len(unittest.TestCase.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"]
    - [TestSuite_dict_class_len,
       "TestSuite.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len(unittest.TestSuite.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"]
    - [TestLoader_dict_class_len,
       "TestLoader.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len(unittest.TestLoader.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"]
    - [TestResult_dict_class_len,
       "TestResult.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len(unittest.TestResult.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"]

# ---------------------------------------------------------------------------
# MRO lengths for core classes
#
# TestCase.__mro__.__len__() == 2 (TestCase, object).
# TestSuite.__mro__.__len__() == 3 (TestSuite, BaseTestSuite, object).
# TestLoader.__mro__.__len__() == 2 (TestLoader, object).
# TestResult.__mro__.__len__() == 2 (TestResult, object).
# No prior spec checks __mro__.__len__() for any unittest class.
# ---------------------------------------------------------------------------

table unittest_extra10.mro_lengths:
  description: "TestCase/TestSuite/TestLoader/TestResult __mro__.__len__()"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: utmrol10

  columns: [id, function, args, expected, description]
  rows:
    - [TestCase_mro_len,
       "TestCase.__mro__.__len__",
       [],
       2,
       "unittest.TestCase.__mro__.__len__() == 2 — (TestCase, object)"]
    - [TestSuite_mro_len,
       "TestSuite.__mro__.__len__",
       [],
       3,
       "unittest.TestSuite.__mro__.__len__() == 3 — (TestSuite, BaseTestSuite, object)"]
    - [TestLoader_mro_len,
       "TestLoader.__mro__.__len__",
       [],
       2,
       "unittest.TestLoader.__mro__.__len__() == 2 — (TestLoader, object)"]
    - [TestResult_mro_len,
       "TestResult.__mro__.__len__",
       [],
       2,
       "unittest.TestResult.__mro__.__len__() == 2 — (TestResult, object)"]

# ---------------------------------------------------------------------------
# TestCase.__bases__[0].__name__ and TestSuite.__bases__[0].__name__
#
# TestCase inherits directly from object — __bases__[0].__name__ == 'object' (len 6).
# TestSuite inherits from BaseTestSuite — __bases__[0].__name__ == 'BaseTestSuite' (len 13).
# NOTE: The task brief suggested TestSuite.__mro__.__len__()==2 and __bases__[0]=='object',
# but Python 3.12 shows __mro__.__len__()==3 and __bases__[0]=='BaseTestSuite'.
# No prior spec checks __bases__[0].__name__ for TestCase or TestSuite.
# ---------------------------------------------------------------------------

invariant unittest_extra10.TestCase.base_name:
  description: "unittest.TestCase.__bases__[0].__name__ == 'object' — TestCase inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: TestCase.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant unittest_extra10.TestCase.base_name_len:
  description: "unittest.TestCase.__bases__[0].__name__.__len__() == 6 — len('object') == 6"
  category: class_hierarchy
  kind: python_call_eq
  function: TestCase.__bases__.__getitem__
  args: [0]
  method_chain: __name__.__len__
  method_chain_args: []
  expected: 6

invariant unittest_extra10.TestSuite.base_name:
  description: "unittest.TestSuite.__bases__[0].__name__ == 'BaseTestSuite' — TestSuite inherits from BaseTestSuite"
  category: class_hierarchy
  kind: python_call_eq
  function: TestSuite.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseTestSuite"

# ---------------------------------------------------------------------------
# TestCase method __qualname__.__len__() values
#
# No prior spec checks __qualname__.__len__() for individual TestCase methods.
# assertEqual: 'TestCase.assertEqual' (len 20)
# assertRaises: 'TestCase.assertRaises' (len 21)
# setUp: 'TestCase.setUp' (len 14)
# tearDown: 'TestCase.tearDown' (len 17)
# run: 'TestCase.run' (len 12)
# skipTest: 'TestCase.skipTest' (len 17)
# ---------------------------------------------------------------------------

table unittest_extra10.TestCase_method_qualname_lens:
  description: "TestCase method __qualname__.__len__() values"
  kind: python_call_eq
  category: function_attrs
  id_prefix: utmql10

  columns: [id, function, args, expected, description]
  rows:
    - [assertEqual_qualname_len,
       TestCase.assertEqual.__qualname__.__len__,
       [],
       20,
       "len('TestCase.assertEqual') == 20"]
    - [assertRaises_qualname_len,
       TestCase.assertRaises.__qualname__.__len__,
       [],
       21,
       "len('TestCase.assertRaises') == 21"]
    - [setUp_qualname_len,
       TestCase.setUp.__qualname__.__len__,
       [],
       14,
       "len('TestCase.setUp') == 14"]
    - [tearDown_qualname_len,
       TestCase.tearDown.__qualname__.__len__,
       [],
       17,
       "len('TestCase.tearDown') == 17"]
    - [run_qualname_len,
       TestCase.run.__qualname__.__len__,
       [],
       12,
       "len('TestCase.run') == 12"]
    - [skipTest_qualname_len,
       TestCase.skipTest.__qualname__.__len__,
       [],
       17,
       "len('TestCase.skipTest') == 17"]

# ---------------------------------------------------------------------------
# TestLoader.loadTestsFromName.__qualname__.__len__() == 28
#
# No prior spec checks __qualname__.__len__() for TestLoader methods.
# 'TestLoader.loadTestsFromName' has 28 characters.
# ---------------------------------------------------------------------------

invariant unittest_extra10.TestLoader.loadTestsFromName_qualname_len:
  description: "unittest.TestLoader.loadTestsFromName.__qualname__.__len__() == 28"
  category: function_attrs
  kind: python_call_eq
  function: TestLoader.loadTestsFromName.__qualname__.__len__
  args: []
  expected: 28
