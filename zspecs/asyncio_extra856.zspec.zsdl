spec: asyncio_extra856
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - asyncio standard library module
    - CPython source: Lib/asyncio/__init__.py
  not_derived_from:
    - any third-party asyncio extension
    - uvloop or other event loop replacements
  notes:
    - Covers event loop factory function qualnames and module attributes
    - Covers coroutine-checking function qualnames and module attributes
    - All functions are top-level exports of the asyncio package
  created_at: "2026-04-12"

table asyncio_extra856.event_loop_factory:
  description: asyncio event loop factory functions - qualname and module identity
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: as856el
  columns: [id, function, args, expected]
  rows:
    - [as856el001, asyncio.get_event_loop.__qualname__.__eq__, ["get_event_loop"], true]
    - [as856el002, asyncio.get_event_loop.__module__.__eq__, ["asyncio"], true]
    - [as856el003, asyncio.new_event_loop.__qualname__.__eq__, ["new_event_loop"], true]
    - [as856el004, asyncio.new_event_loop.__module__.__eq__, ["asyncio"], true]
    - [as856el005, asyncio.set_event_loop.__qualname__.__eq__, ["set_event_loop"], true]
    - [as856el006, asyncio.set_event_loop.__module__.__eq__, ["asyncio"], true]
    - [as856el007, asyncio.get_running_loop.__qualname__.__eq__, ["get_running_loop"], true]
    - [as856el008, asyncio.get_running_loop.__module__.__eq__, ["asyncio"], true]

table asyncio_extra856.coroutine_checkers:
  description: asyncio coroutine-checking function qualnames and module attributes
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: as856cc
  columns: [id, function, args, expected]
  rows:
    - [as856cc001, asyncio.iscoroutine.__qualname__.__eq__, ["iscoroutine"], true]
    - [as856cc002, asyncio.iscoroutine.__module__.__eq__, ["asyncio"], true]
    - [as856cc003, asyncio.iscoroutinefunction.__qualname__.__eq__, ["iscoroutinefunction"], true]
    - [as856cc004, asyncio.iscoroutinefunction.__module__.__eq__, ["asyncio"], true]
