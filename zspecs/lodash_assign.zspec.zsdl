spec: lodash_assign
version: ">=4.0.0"
backend: node(lodash.assign)

docs: https://lodash.com/docs/#assign

provenance:
  derived_from:
    - "lodash.assign README — https://www.npmjs.com/package/lodash.assign"
    - "Test vectors verified with lodash.assign@4.2.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.assign exports the _.assign function directly as module.exports."
    - "assign(object, ...sources) assigns own enumerable properties from sources."
    - "Later sources overwrite earlier ones. Mutates and returns the first object."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns mutated object with source properties assigned."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_assign.assign:
  kind: node_module_call_eq
  function: ~
  category: assign
  id_prefix: lasgn

  columns: [id, args, expected]
  rows:
    - [merge_two,   [{"a": 1}, {"b": 2}],            {"a": 1, "b": 2}]
    - [overwrite,   [{"a": 1}, {"a": 2, "b": 3}],    {"a": 2, "b": 3}]
    - [empty_src,   [{"a": 1}, {}],                  {"a": 1}]
