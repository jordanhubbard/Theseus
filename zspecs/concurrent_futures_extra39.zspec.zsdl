spec: concurrent_futures_extra39
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra38.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__.__class__.__name__.__len__() tables, as_completed/wait __module__.__len__(), __all__.__len__()==14, __mro__.__len__() tables, __bases__[0].__name__.__len__() for all classes, Executor context manager qualname lens, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, map/__qualname__.__len__() for both executors, Future method __name__/__qualname__.__len__() tables, ThreadPoolExecutor submit/shutdown __name__/__qualname__.__len__() tables, InvalidStateError/__name__.__len__()==17, CancelledError/__qualname__.__len__()==14, BrokenExecutor/__name__/__qualname__.__len__()==14, BrokenExecutor/__module__.__len__()==24, CancelledError/__module__.__len__()==24, BrokenExecutor/__bases__[0].__name__.__len__()==12, TimeoutError/__name__/__module__.__len__(), concurrent.futures.__package__.__len__()==18, __spec__.__class__.__name__.__len__()==10, ThreadPoolExecutor/__name__=='ThreadPoolExecutor' (extra36), ProcessPoolExecutor/__name__=='ProcessPoolExecutor' (extra36), executor __module__ string equality (extra36), wait/__name__=='wait' (extra36), function __module__ string equality (extra36), Executor/__name__=='Executor'/__module__==concurrent.futures._base (extra37), Executor map/submit qualname lengths (extra37), InvalidStateError/BrokenExecutor __name__/__module__ string equality (extra37), ProcessPoolExecutor/ThreadPoolExecutor/__bases__[0].__name__=='Executor', Future/__bases__[0].__name__=='object', exception MRO depths all 5 (extra38)."
    - "This spec covers: ProcessPoolExecutor.__mro__.__len__()==3; ThreadPoolExecutor.__mro__.__len__()==3; Future.__mro__.__len__()==2; Executor.__mro__.__len__()==2; Executor.__bases__[0].__name__=='object'; FIRST_COMPLETED.__class__.__name__=='str'; FIRST_EXCEPTION.__class__.__name__=='str'; ALL_COMPLETED.__class__.__name__=='str'."
    - "ProcessPoolExecutor and ThreadPoolExecutor each have MRO depth 3: [ConcreteExecutor, Executor, object]. Both concrete executors have identical MRO structure. Executor itself has depth 2: [Executor, object] — it inherits directly from object with no intermediate base. Future also has depth 2: [Future, object]."
    - "Executor.__bases__[0].__name__ == 'object'. The abstract Executor class inherits directly from object; it has no domain-specific parent. This is the abstract base at the top of the concrete executor hierarchy."
    - "FIRST_COMPLETED, FIRST_EXCEPTION, and ALL_COMPLETED are string constants used as return_when sentinels for concurrent.futures.wait(). Their __class__.__name__ == 'str'. Prior specs measured their string values and __len__() as integers; extra39 confirms their Python type via __class__.__name__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures class MRO depths — extra39 namespace
#
# MRO depths for the four core classes:
#   ProcessPoolExecutor.__mro__.__len__() == 3   [ProcessPoolExecutor, Executor, object]
#   ThreadPoolExecutor.__mro__.__len__()  == 3   [ThreadPoolExecutor, Executor, object]
#   Future.__mro__.__len__()              == 2   [Future, object]
#   Executor.__mro__.__len__()            == 2   [Executor, object]
# Both concrete executors have depth 3 (passing through Executor).
# Future and Executor themselves have depth 2 (one step above object).
# Prior exception-class MRO depths (all == 5) were captured in extra38.
# ---------------------------------------------------------------------------

table concurrent_futures_extra39.class_mro_depths:
  description: "concurrent.futures core class MRO depths in extra39 namespace — executor classes (3) vs Future/Executor base (2)"
  kind: python_call_eq
  category: class_names
  id_prefix: cfclassmrolen39

  columns: [id, function, args, expected, description]
  rows:
    - [ProcessPoolExecutor, ProcessPoolExecutor.__mro__.__len__, [], 3, "ProcessPoolExecutor.__mro__.__len__() == 3 — MRO: [ProcessPoolExecutor, Executor, object]"]
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__mro__.__len__,  [], 3, "ThreadPoolExecutor.__mro__.__len__() == 3 — MRO: [ThreadPoolExecutor, Executor, object]"]
    - [Future,              Future.__mro__.__len__,              [], 2, "Future.__mro__.__len__() == 2 — MRO: [Future, object] — no domain-specific base"]
    - [Executor,            Executor.__mro__.__len__,            [], 2, "Executor.__mro__.__len__() == 2 — MRO: [Executor, object] — abstract base with no parent"]

# ---------------------------------------------------------------------------
# concurrent.futures Executor base class — extra39 namespace
#
# Executor.__bases__[0].__name__ == 'object'
# The abstract Executor class itself inherits directly from object; it has
# no domain-specific parent class. This is the top of the concrete executor
# hierarchy: object -> Executor -> {ThreadPoolExecutor, ProcessPoolExecutor}.
# Prior specs confirmed that both concrete executors have 'Executor' as their
# __bases__[0].__name__. This invariant captures the root: Executor's own base.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra39.Executor_bases0_name_eq:
  description: "concurrent.futures.Executor.__bases__[0].__name__ == 'object' — the abstract Executor base class inherits directly from object with no intermediate parent"
  category: class_names
  kind: python_call_eq
  function: "Executor.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# concurrent.futures wait() sentinel constant types — extra39 namespace
#
# The three return_when sentinel constants are plain Python strings:
#   FIRST_COMPLETED.__class__.__name__ == 'str'
#   FIRST_EXCEPTION.__class__.__name__ == 'str'
#   ALL_COMPLETED.__class__.__name__   == 'str'
# The sentinel values themselves equal their own names (e.g. FIRST_COMPLETED
# == 'FIRST_COMPLETED'). Prior specs captured the string values and __len__()
# as integers. Extra39 confirms the Python type via __class__.__name__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra39.wait_sentinel_types:
  description: "concurrent.futures wait() sentinel constant types in extra39 namespace — FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED are all plain str"
  kind: python_call_eq
  category: class_names
  id_prefix: cfsentineltype39

  columns: [id, function, args, expected, description]
  rows:
    - [FIRST_COMPLETED, FIRST_COMPLETED.__class__.__name__.__eq__, ["str"], true, "FIRST_COMPLETED.__class__.__name__ == 'str' — the sentinel is a plain Python string constant"]
    - [FIRST_EXCEPTION, FIRST_EXCEPTION.__class__.__name__.__eq__, ["str"], true, "FIRST_EXCEPTION.__class__.__name__ == 'str' — the sentinel is a plain Python string constant"]
    - [ALL_COMPLETED,   ALL_COMPLETED.__class__.__name__.__eq__,   ["str"], true, "ALL_COMPLETED.__class__.__name__ == 'str' — the sentinel is a plain Python string constant"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra39
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra39.ProcessPoolExecutor_mro_len:
  description: "concurrent.futures.ProcessPoolExecutor.__mro__.__len__() == 3 — MRO is [ProcessPoolExecutor, Executor, object]; one intermediate class above object"
  category: class_names
  kind: python_call_eq
  function: ProcessPoolExecutor.__mro__.__len__
  args: []
  expected: 3

invariant concurrent_futures_extra39.ThreadPoolExecutor_mro_len:
  description: "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3 — MRO is [ThreadPoolExecutor, Executor, object]; same depth as ProcessPoolExecutor"
  category: class_names
  kind: python_call_eq
  function: ThreadPoolExecutor.__mro__.__len__
  args: []
  expected: 3

invariant concurrent_futures_extra39.Future_mro_len:
  description: "concurrent.futures.Future.__mro__.__len__() == 2 — MRO is [Future, object]; Future has no domain-specific parent class"
  category: class_names
  kind: python_call_eq
  function: Future.__mro__.__len__
  args: []
  expected: 2

invariant concurrent_futures_extra39.Executor_mro_len:
  description: "concurrent.futures.Executor.__mro__.__len__() == 2 — MRO is [Executor, object]; the abstract base class inherits directly from object"
  category: class_names
  kind: python_call_eq
  function: Executor.__mro__.__len__
  args: []
  expected: 2

invariant concurrent_futures_extra39.FIRST_COMPLETED_class_name_eq:
  description: "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str' — the wait() sentinel is a plain Python string (value: 'FIRST_COMPLETED')"
  category: class_names
  kind: python_call_eq
  function: FIRST_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra39.FIRST_EXCEPTION_class_name_eq:
  description: "concurrent.futures.FIRST_EXCEPTION.__class__.__name__ == 'str' — the wait() sentinel is a plain Python string (value: 'FIRST_EXCEPTION')"
  category: class_names
  kind: python_call_eq
  function: FIRST_EXCEPTION.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra39.ALL_COMPLETED_class_name_eq:
  description: "concurrent.futures.ALL_COMPLETED.__class__.__name__ == 'str' — the wait() sentinel is a plain Python string (value: 'ALL_COMPLETED')"
  category: class_names
  kind: python_call_eq
  function: ALL_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true
