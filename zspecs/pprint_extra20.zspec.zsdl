spec: pprint_extra20
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "This spec extends pprint_extra19.zspec.zsdl."
    - "Prior specs covered: pprint.__name__/__package__; pprint/__name__/__module__; pformat/__name__/__module__; PrettyPrinter/__name__/__module__/__qualname__; isreadable/__name__; isrecursive/__name__; saferepr/__name__; pp/__name__; PrettyPrinter.__bases__[0].__name__; various __qualname__ checks; pprint.__all__ type/length; PrettyPrinter.__init__/__repr__ qualnames; PrettyPrinter method qualnames."
    - "This spec covers: pprint.pprint.__qualname__, pprint.pformat.__qualname__, pprint.isreadable.__qualname__, pprint.isrecursive.__qualname__, pprint.saferepr.__qualname__, pprint.pp.__qualname__, pprint.pprint.__module__.__len__(), pprint.pformat.__module__.__len__(), pprint.isreadable.__module__.__len__(), pprint.PrettyPrinter.__init__.__name__, pprint.PrettyPrinter.__module__.__len__()."
    - "pprint.pprint.__qualname__ == 'pprint' — flat qualname, function is at module level. Verified at runtime."
    - "pprint.pformat.__qualname__ == 'pformat' — flat qualname, function is at module level. Verified at runtime."
    - "pprint.isreadable.__qualname__ == 'isreadable' — flat qualname, function is at module level. Verified at runtime."
    - "pprint.isrecursive.__qualname__ == 'isrecursive' — flat qualname, function is at module level. Verified at runtime."
    - "pprint.saferepr.__qualname__ == 'saferepr' — flat qualname, function is at module level. Verified at runtime."
    - "pprint.pp.__qualname__ == 'pp' — flat qualname, function is at module level. Verified at runtime."
    - "pprint.pprint.__module__ == 'pprint'; len == 6. Verified at runtime."
    - "pprint.pformat.__module__ == 'pprint'; len == 6. Verified at runtime."
    - "pprint.isreadable.__module__ == 'pprint'; len == 6. Verified at runtime."
    - "pprint.PrettyPrinter.__init__.__name__ == '__init__' — the dunder name of the constructor method. Verified at runtime."
    - "pprint.PrettyPrinter.__module__ == 'pprint'; len == 6. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __qualname__ attributes
#
# pprint_extra14 and prior specs noted qualname values but no prior spec
# assembles all six module-level function __qualname__ checks as standalone
# invariants focused on the flat (non-dotted) qualname form. Verified
# at runtime: all six functions have flat qualnames equal to their bare name.
# ---------------------------------------------------------------------------

invariant pprint_extra20.pprint_func.qualname:
  description: "pprint.pprint.__qualname__ == 'pprint' — flat qualname for module-level function"
  category: function_identity
  kind: python_call_eq
  function: pprint.__qualname__.__eq__
  args: ["pprint"]
  expected: true

invariant pprint_extra20.pformat.qualname:
  description: "pprint.pformat.__qualname__ == 'pformat' — flat qualname for module-level function"
  category: function_identity
  kind: python_call_eq
  function: pformat.__qualname__.__eq__
  args: ["pformat"]
  expected: true

invariant pprint_extra20.isreadable.qualname:
  description: "pprint.isreadable.__qualname__ == 'isreadable' — flat qualname for module-level function"
  category: function_identity
  kind: python_call_eq
  function: isreadable.__qualname__.__eq__
  args: ["isreadable"]
  expected: true

invariant pprint_extra20.isrecursive.qualname:
  description: "pprint.isrecursive.__qualname__ == 'isrecursive' — flat qualname for module-level function"
  category: function_identity
  kind: python_call_eq
  function: isrecursive.__qualname__.__eq__
  args: ["isrecursive"]
  expected: true

invariant pprint_extra20.saferepr.qualname:
  description: "pprint.saferepr.__qualname__ == 'saferepr' — flat qualname for module-level function"
  category: function_identity
  kind: python_call_eq
  function: saferepr.__qualname__.__eq__
  args: ["saferepr"]
  expected: true

invariant pprint_extra20.pp.qualname:
  description: "pprint.pp.__qualname__ == 'pp' — flat qualname for module-level function"
  category: function_identity
  kind: python_call_eq
  function: pp.__qualname__.__eq__
  args: ["pp"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function __module__.__len__()
#
# pprint_extra20 introduces __module__ string length checks for module-level
# functions. All three checked functions have __module__ == 'pprint',
# a 6-character string. No prior spec verifies these lengths.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant pprint_extra20.pprint_func.module_len:
  description: "len(pprint.pprint.__module__) == 6 — 'pprint' is 6 characters"
  category: function_identity
  kind: python_call_eq
  function: pprint.__module__.__len__
  args: []
  expected: 6

invariant pprint_extra20.pformat.module_len:
  description: "len(pprint.pformat.__module__) == 6 — 'pprint' is 6 characters"
  category: function_identity
  kind: python_call_eq
  function: pformat.__module__.__len__
  args: []
  expected: 6

invariant pprint_extra20.isreadable.module_len:
  description: "len(pprint.isreadable.__module__) == 6 — 'pprint' is 6 characters"
  category: function_identity
  kind: python_call_eq
  function: isreadable.__module__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# PrettyPrinter.__init__.__name__
#
# No prior spec verifies PrettyPrinter.__init__.__name__ as a standalone
# invariant (prior extra19 covers __qualname__ only). The __name__ attribute
# of the constructor is the bare dunder string '__init__'.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant pprint_extra20.PrettyPrinter.__init__.name:
  description: "pprint.PrettyPrinter.__init__.__name__ == '__init__' — the dunder name of the constructor method"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# PrettyPrinter.__module__.__len__()
#
# PrettyPrinter.__module__ == 'pprint', a 6-character string. No prior spec
# verifies this length as a standalone invariant.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant pprint_extra20.PrettyPrinter.module_len:
  description: "len(pprint.PrettyPrinter.__module__) == 6 — 'pprint' is 6 characters"
  category: class_identity
  kind: python_call_eq
  function: PrettyPrinter.__module__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Table: module-level function __qualname__ attributes
#
# Groups all six module-level function __qualname__ checks in one indexed
# table. All qualnames are flat (equal to the bare function name).
# All verified at runtime.
# ---------------------------------------------------------------------------

table pprint_extra20.module_level_function_qualnames:
  description: "pprint module-level function __qualname__ attributes — all flat, equal to bare function name"
  kind: python_call_eq
  category: function_identity
  id_prefix: pp20lfq

  columns: [id, function, args, expected]
  rows:
    - [pprint_func, pprint.__qualname__.__eq__,    ["pprint"],      true]
    - [pformat,     pformat.__qualname__.__eq__,    ["pformat"],     true]
    - [isreadable,  isreadable.__qualname__.__eq__,  ["isreadable"],  true]
    - [isrecursive, isrecursive.__qualname__.__eq__, ["isrecursive"], true]
    - [saferepr,    saferepr.__qualname__.__eq__,    ["saferepr"],    true]
    - [pp,          pp.__qualname__.__eq__,          ["pp"],          true]

# ---------------------------------------------------------------------------
# Table: module-level function and class __module__ string lengths
#
# Groups __module__.__len__() checks for pprint, pformat, isreadable, and
# PrettyPrinter in one indexed table. All __module__ values are 'pprint'
# with length 6. No prior table covers these length checks.
# All verified at runtime.
# ---------------------------------------------------------------------------

table pprint_extra20.module_string_lengths:
  description: "pprint function and class __module__.__len__() checks — all 'pprint', length 6"
  kind: python_call_eq
  category: function_identity
  id_prefix: pp20msl

  columns: [id, function, args, expected]
  rows:
    - [pprint_func,    pprint.__module__.__len__,          [], 6]
    - [pformat,        pformat.__module__.__len__,         [], 6]
    - [isreadable,     isreadable.__module__.__len__,      [], 6]
    - [PrettyPrinter,  PrettyPrinter.__module__.__len__,   [], 6]
