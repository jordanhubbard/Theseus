spec: abc_extra68
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra67.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, length tables for all identifiers, ABCMeta.register/__new__/__instancecheck__/__subclasscheck__ qualname lengths, __mro__.__len__() for ABC(2) and ABCMeta(3), MRO entry name lengths, __dict__.__class__.__name__.__len__() for ABC/ABCMeta."
    - "This spec covers (abcmore68 namespace): wave 239 theme — ABC class __dict__ deeper content + ABCMeta subclasshook code. NEW in extra68: ABC.__dict__.__contains__('__doc__')==True (ABC has __doc__ in its own __dict__); ABC.__dict__.__contains__('__slots__')==True (ABC defines __slots__=()); ABC.__dict__.__contains__('__abstractmethods__')==True (ABC declares __abstractmethods__); ABC.__dict__.__contains__('_abc_impl')==True; ABCMeta.__dict__.__class__.__name__=='mappingproxy'; ABCMeta.__dict__.__contains__('register')==True; ABCMeta.__dict__.__contains__('__instancecheck__')==True; ABCMeta.__dict__.__contains__('__subclasscheck__')==True."
    - "abc.ABC.__dict__.__contains__('__doc__') == True. ABC defines __doc__ directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__contains__('__slots__') == True. ABC defines __slots__ = () in its class body; __slots__ appears in ABC.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__contains__('__abstractmethods__') == True. ABC.__abstractmethods__ is declared on the class directly; it appears in ABC.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__contains__('_abc_impl') == True. _abc_impl is the C-level ABC implementation handle stored directly in ABC.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'. The __dict__ of any Python class is a mappingproxy; ABCMeta.__dict__.__class__.__name__ is 'mappingproxy'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('register') == True. ABCMeta defines the register() method directly; it appears in ABCMeta.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True. ABCMeta overrides __instancecheck__ to support isinstance() against ABCs; it appears in ABCMeta.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('__subclasscheck__') == True. ABCMeta overrides __subclasscheck__ to support issubclass() against ABCs; it appears in ABCMeta.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABC.__dict__ content checks — extra68
#
# Wave 239 theme: ABC class __dict__ deeper content.
#
# ABC.__dict__.__contains__('__doc__') == True
# ABC.__dict__.__contains__('__slots__') == True
# ABC.__dict__.__contains__('__abstractmethods__') == True
# ABC.__dict__.__contains__('_abc_impl') == True
# ---------------------------------------------------------------------------

table abc_extra68.ABC_dict_contains:
  description: "abc ABC.__dict__.__contains__ checks in abcmore68 namespace — wave 239 theme: ABC __dict__ content; ABC.__dict__.__contains__('__doc__')==True; ABC.__dict__.__contains__('__slots__')==True (ABC defines __slots__=()); ABC.__dict__.__contains__('__abstractmethods__')==True; ABC.__dict__.__contains__('_abc_impl')==True (C-level ABC handle); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: abcmore68

  columns: [id, function, args, expected, description]
  rows:
    - [abc_dict_has_doc,              ABC.__dict__.__contains__, ["__doc__"],              true, "ABC.__dict__.__contains__('__doc__') == True — ABC defines __doc__ in its own __dict__; verified with Python 3.14.3"]
    - [abc_dict_has_slots,            ABC.__dict__.__contains__, ["__slots__"],            true, "ABC.__dict__.__contains__('__slots__') == True — ABC defines __slots__=() in class body; verified with Python 3.14.3"]
    - [abc_dict_has_abstractmethods,  ABC.__dict__.__contains__, ["__abstractmethods__"],  true, "ABC.__dict__.__contains__('__abstractmethods__') == True — ABC.__abstractmethods__ declared on class; verified with Python 3.14.3"]
    - [abc_dict_has_abc_impl,         ABC.__dict__.__contains__, ["_abc_impl"],            true, "ABC.__dict__.__contains__('_abc_impl') == True — C-level ABC implementation handle in ABC.__dict__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABCMeta.__dict__ class name and register/hook checks — extra68
#
# ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'
# ABCMeta.__dict__.__contains__('register') == True
# ABCMeta.__dict__.__contains__('__instancecheck__') == True
# ABCMeta.__dict__.__contains__('__subclasscheck__') == True
# ---------------------------------------------------------------------------

table abc_extra68.ABCMeta_dict_class_and_contains:
  description: "abc ABCMeta.__dict__.__class__.__name__ and __contains__ checks in abcmore68 namespace — wave 239 theme: ABCMeta __dict__ content; ABCMeta.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is always a mappingproxy); ABCMeta.__dict__.__contains__('register')==True; ABCMeta.__dict__.__contains__('__instancecheck__')==True; ABCMeta.__dict__.__contains__('__subclasscheck__')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: abcmore68a

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_dict_class_name,         ABCMeta.__dict__.__class__.__name__.__eq__, ["mappingproxy"],   true, "ABCMeta.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is a mappingproxy; verified with Python 3.14.3"]
    - [abcmeta_dict_has_register,       ABCMeta.__dict__.__contains__,              ["register"],        true, "ABCMeta.__dict__.__contains__('register') == True — register() defined directly on ABCMeta; verified with Python 3.14.3"]
    - [abcmeta_dict_has_instancecheck,  ABCMeta.__dict__.__contains__,              ["__instancecheck__"], true, "ABCMeta.__dict__.__contains__('__instancecheck__') == True — ABCMeta overrides __instancecheck__; verified with Python 3.14.3"]
    - [abcmeta_dict_has_subclasscheck,  ABCMeta.__dict__.__contains__,              ["__subclasscheck__"], true, "ABCMeta.__dict__.__contains__('__subclasscheck__') == True — ABCMeta overrides __subclasscheck__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABCMeta.__dict__.__contains__ for __new__ and additional ABC dict checks — extra68
# ---------------------------------------------------------------------------

table abc_extra68.ABCMeta_dict_new_and_ABC_module:
  description: "abc ABCMeta.__dict__ __new__ and ABC.__dict__ __module__ checks in abcmore68 namespace — wave 239 theme: ABCMeta/ABC __dict__ additional content; ABCMeta.__dict__.__contains__('__new__')==True (ABCMeta overrides __new__ for metaclass creation); ABC.__dict__.__contains__('__module__')==True (ABC records its module in __dict__); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: abcmore68b

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_dict_has_new,    ABCMeta.__dict__.__contains__, ["__new__"],    true, "ABCMeta.__dict__.__contains__('__new__') == True — ABCMeta overrides __new__; verified with Python 3.14.3"]
    - [abc_dict_has_module,     ABC.__dict__.__contains__,     ["__module__"], true, "ABC.__dict__.__contains__('__module__') == True — ABC stores __module__ in its own __dict__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABC.__dict__.__class__.__name__ check — extra68
#
# ABC.__dict__.__class__.__name__ == 'mappingproxy'
# Parallels the ABCMeta check above; both class __dict__s are mappingproxy.
# ---------------------------------------------------------------------------

table abc_extra68.ABC_dict_class_name:
  description: "abc ABC.__dict__.__class__.__name__ check in abcmore68 namespace — wave 239 theme: ABC __dict__ type identity; ABC.__dict__.__class__.__name__=='mappingproxy' (ABC class __dict__ is a read-only mappingproxy like all class __dict__s); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: abcmore68c

  columns: [id, function, args, expected, description]
  rows:
    - [abc_dict_class_name, ABC.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "ABC.__dict__.__class__.__name__ == 'mappingproxy' — ABC class __dict__ is a mappingproxy; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra68
# ---------------------------------------------------------------------------

invariant abc_extra68.ABC_dict_has_slots:
  description: "abc.ABC.__dict__.__contains__('__slots__') returns True — ABC defines __slots__=() in its class body; '__slots__' appears directly in ABC.__dict__; NEW in extra68: first standalone __contains__('__slots__') invariant for ABC in abcmore68 namespace; wave 239; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: ABC.__dict__.__contains__
  args: ["__slots__"]
  expected: true

invariant abc_extra68.ABC_dict_has_abstractmethods:
  description: "abc.ABC.__dict__.__contains__('__abstractmethods__') returns True — ABC.__abstractmethods__ is declared on the ABC class directly; NEW in extra68: first standalone __contains__('__abstractmethods__') invariant for ABC in abcmore68 namespace; wave 239; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: ABC.__dict__.__contains__
  args: ["__abstractmethods__"]
  expected: true

invariant abc_extra68.ABCMeta_dict_class_name:
  description: "abc.ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — class __dict__ objects are always mappingproxy in CPython; NEW in extra68: first standalone __class__.__name__ invariant for ABCMeta.__dict__ in abcmore68 namespace; wave 239; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: ABCMeta.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra68.ABCMeta_dict_has_instancecheck:
  description: "abc.ABCMeta.__dict__.__contains__('__instancecheck__') returns True — ABCMeta overrides __instancecheck__ to support isinstance() checks against abstract base classes; NEW in extra68: first standalone __contains__('__instancecheck__') invariant for ABCMeta in abcmore68 namespace; wave 239; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: ABCMeta.__dict__.__contains__
  args: ["__instancecheck__"]
  expected: true

invariant abc_extra68.ABCMeta_dict_has_subclasscheck:
  description: "abc.ABCMeta.__dict__.__contains__('__subclasscheck__') returns True — ABCMeta overrides __subclasscheck__ to support issubclass() checks against abstract base classes; NEW in extra68: first standalone __contains__('__subclasscheck__') invariant for ABCMeta in abcmore68 namespace; wave 239; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: ABCMeta.__dict__.__contains__
  args: ["__subclasscheck__"]
  expected: true
