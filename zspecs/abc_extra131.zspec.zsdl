spec: abc_extra131
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers: wave 259 theme — abc.abstractproperty __dict__ proxy, abc.abstractmethod code object introspection. abc.abstractproperty.__dict__.__class__.__name__=='mappingproxy' (len=12); abc.abstractproperty.__dict__.__len__()==7; abc.abstractmethod.__code__.co_varnames.__len__()==1; abc.abstractmethod.__code__.co_varnames.__contains__('funcobj')==True (the sole parameter variable is named 'funcobj'); abc.abstractmethod.__code__.co_name=='abstractmethod' (len=14); abc.abstractmethod.__code__.co_argcount==1; abc.abstractmethod.__name__=='abstractmethod' (len=14); abc.abstractmethod.__module__=='abc' (len=3); abc.abstractproperty.__name__=='abstractproperty' (len=16); abc.abstractproperty.__module__=='abc' (len=3); abc.abstractproperty.__bases__[0].__name__=='property' (len=8). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractmethod.__code__.co_varnames is ('funcobj',) — the single parameter of abstractmethod is named 'funcobj', not 'func' or 'f' or 'method'. This is the CPython implementation detail. co_varnames.__len__()==1; co_argcount==1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractproperty.__dict__.__len__()==7 — the abstractproperty class dict contains: __isabstractmethod__ descriptor, __doc__, __module__, __dict__, __weakref__, __abstractmethods__, and __dict__ slot. abc.abstractproperty.__bases__[0].__name__=='property' (abstractproperty inherits from the built-in property descriptor). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.abstractproperty __dict__ proxy checks — extra131
#
# abc.abstractproperty.__dict__.__class__.__name__ == 'mappingproxy' (len=12)
# abc.abstractproperty.__dict__.__len__()          == 7
# ---------------------------------------------------------------------------

table abc_extra131.abc_abstractproperty_dict:
  description: "abc.abstractproperty __dict__ proxy type and size checks in abcap131 namespace — wave 259 theme: abstractproperty.__dict__.__class__.__name__.__eq__('mappingproxy')==True (len=12: all class __dict__ objects in CPython are mappingproxy instances); abstractproperty.__dict__.__len__()==7 (the class dict has 7 entries: __isabstractmethod__, __doc__, __module__, __dict__, __weakref__, __abstractmethods__, and __dict__ slot or similar); abstractproperty.__name__.__eq__('abstractproperty')==True (len=16); abstractproperty.__module__.__eq__('abc')==True (len=3); abstractproperty.__bases__[0].__name__.__eq__('property')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcap131

  columns: [id, function, args, expected, description]
  rows:
    - [dict_cls_eq,  abc.abstractproperty.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true, "abc.abstractproperty.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]
    - [dict_cls_len, abc.abstractproperty.__dict__.__class__.__name__.__len__,  [],              12,   "abc.abstractproperty.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy'=12); verified with Python 3.14.3"]
    - [dict_len,     abc.abstractproperty.__dict__.__len__,                      [],              7,    "abc.abstractproperty.__dict__.__len__() == 7; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
