# ---------------------------------------------------------------------------

table abc_extra131.abc_abstractproperty_identity:
  description: "abc.abstractproperty class identity checks in abcap131 namespace — wave 259 theme: abstractproperty.__name__.__eq__('abstractproperty')==True (len=16: 'abstract'=8+'property'=8=16); abstractproperty.__module__.__eq__('abc')==True (len=3); abstractproperty.__bases__[0].__name__.__eq__('property')==True (len=8: abstractproperty inherits from the built-in property descriptor — it IS a property with an additional __isabstractmethod__ descriptor); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcapid131

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,    abc.abstractproperty.__name__.__eq__,                    ["abstractproperty"], true, "abc.abstractproperty.__name__ == 'abstractproperty' (len=16); verified with Python 3.14.3"]
    - [name_len,   abc.abstractproperty.__name__.__len__,                   [],                  16,   "abc.abstractproperty.__name__.__len__() == 16; verified with Python 3.14.3"]
    - [mod_eq,     abc.abstractproperty.__module__.__eq__,                  ["abc"],              true, "abc.abstractproperty.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [mod_len,    abc.abstractproperty.__module__.__len__,                 [],                  3,    "abc.abstractproperty.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [base0_eq,   "abc.abstractproperty.__bases__[0].__name__.__eq__",     ["property"],         true, "abc.abstractproperty.__bases__[0].__name__ == 'property' (len=8); verified with Python 3.14.3"]
    - [base0_len,  "abc.abstractproperty.__bases__[0].__name__.__len__",    [],                  8,    "abc.abstractproperty.__bases__[0].__name__.__len__() == 8 ('property'=8); verified with Python 3.14.3"]

