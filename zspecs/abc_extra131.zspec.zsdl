# abc.abstractmethod.__code__.co_argcount                   == 1
# ---------------------------------------------------------------------------

table abc_extra131.abc_abstractmethod_code:
  description: "abc.abstractmethod code object introspection checks in abcam131 namespace — wave 259 theme: abstractmethod.__code__.co_varnames.__len__()==1 (abstractmethod has exactly one local variable: 'funcobj'); abstractmethod.__code__.co_varnames.__contains__('funcobj')==True (the parameter is named 'funcobj', not 'func' or 'f'); abstractmethod.__code__.co_name.__eq__('abstractmethod')==True (len=14: 'abstractmethod'=14); abstractmethod.__code__.co_argcount.__eq__(1)==True (one positional argument: funcobj); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcamcode131

  columns: [id, function, args, expected, description]
  rows:
    - [co_varnames_len,      abc.abstractmethod.__code__.co_varnames.__len__,        [],          1,    "abc.abstractmethod.__code__.co_varnames.__len__() == 1 (sole variable is 'funcobj'); verified with Python 3.14.3"]
    - [co_varnames_funcobj,  abc.abstractmethod.__code__.co_varnames.__contains__,   ["funcobj"], true, "abc.abstractmethod.__code__.co_varnames.__contains__('funcobj') == True; verified with Python 3.14.3"]
    - [co_name_eq,           abc.abstractmethod.__code__.co_name.__eq__,             ["abstractmethod"], true, "abc.abstractmethod.__code__.co_name == 'abstractmethod' (len=14); verified with Python 3.14.3"]
    - [co_name_len,          abc.abstractmethod.__code__.co_name.__len__,            [],          14,   "abc.abstractmethod.__code__.co_name.__len__() == 14; verified with Python 3.14.3"]
    - [co_argcount_eq,       abc.abstractmethod.__code__.co_argcount.__eq__,         [1],         true, "abc.abstractmethod.__code__.co_argcount == 1 (one positional arg: funcobj); verified with Python 3.14.3"]

