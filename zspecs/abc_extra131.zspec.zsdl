table abc_extra131.abc_abstractmethod_identity:
  description: "abc.abstractmethod identity checks in abcam131 namespace — wave 259 theme: abstractmethod.__name__.__eq__('abstractmethod')==True (len=14); abstractmethod.__module__.__eq__('abc')==True (len=3); abstractmethod.__qualname__.__eq__('abstractmethod')==True (len=14, same as __name__ — module-level class so qualname equals name); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcamid131

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,      abc.abstractmethod.__name__.__eq__,      ["abstractmethod"], true, "abc.abstractmethod.__name__ == 'abstractmethod' (len=14); verified with Python 3.14.3"]
