# ---------------------------------------------------------------------------
# Standalone invariants — extra131
# ---------------------------------------------------------------------------

invariant abc_extra131.abstractproperty_dict_len_7:
  description: "abc.abstractproperty.__dict__.__len__() == 7 — abc.abstractproperty's class __dict__ has 7 entries; abstractproperty is deprecated since Python 3.3 (use @property + @abstractmethod instead) but still present; abstractproperty inherits from the built-in property (abstractproperty.__bases__[0].__name__=='property'); abstractproperty.__dict__.__class__.__name__ is 'mappingproxy'; abstractproperty.__name__.__len__()==16; NEW in extra131: first standalone abstractproperty dict length invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.abstractproperty.__dict__.__len__
  args: []
  expected: 7

invariant abc_extra131.abstractmethod_co_varnames_contains_funcobj:
  description: "abc.abstractmethod.__code__.co_varnames.__contains__('funcobj') returns True — the sole parameter of abstractmethod is named 'funcobj' (not 'func', 'f', or 'method'); this is an implementation detail of CPython's Lib/abc.py where the decorator is defined as 'def abstractmethod(funcobj):'; co_varnames.__len__()==1; co_argcount==1; co_name=='abstractmethod' (len=14); NEW in extra131: first standalone abstractmethod co_varnames funcobj invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_varnames.__contains__
  args: ["funcobj"]
  expected: true

invariant abc_extra131.abstractmethod_co_name_len_14:
  description: "abc.abstractmethod.__code__.co_name.__len__() == 14 — abstractmethod.__code__.co_name is 'abstractmethod' (14 chars: 'abstract'=8 + 'method'=6 = 14); co_name is the name of the function as it appears in the bytecode (same as __name__ for a top-level function); abstractmethod.__name__.__len__()==14 (same value — module-level class so qualname equals name); abstractproperty.__name__.__len__()==16 ('abstract'=8+'property'=8=16, two more chars); NEW in extra131: first standalone abstractmethod co_name length invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_name.__len__
  args: []
  expected: 14

invariant abc_extra131.abstractproperty_base_is_property:
  description: "abc.abstractproperty.__bases__[0].__name__.__eq__('property') returns True — abstractproperty inherits directly from the built-in property descriptor; abstractproperty is a subclass of property that adds __isabstractmethod__ support; abstractproperty.__dict__.__len__()==7; abstractproperty.__name__.__len__()==16 ('abstractproperty'=16); abstractproperty.__module__ is 'abc' (len=3); abstractproperty was deprecated in Python 3.3 — use @property combined with @abstractmethod instead; NEW in extra131: first standalone abstractproperty base class name invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abc.abstractproperty.__bases__[0].__name__.__eq__"
  args: ["property"]
  expected: true

invariant abc_extra131.abstractproperty_dict_class_name_mappingproxy:
  description: "abc.abstractproperty.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — every Python class's __dict__ is a mappingproxy (read-only view of the class namespace, 12 chars: 'mapping'=7+'proxy'=5=12); abc.abstractproperty.__dict__.__len__()==7; abc.abstractmethod.__module__ is 'abc' (len=3); abc.abstractproperty.__name__.__len__()==16; abc.ABCMeta.__bases__[0].__name__ is 'type' (ABCMeta inherits from type, making it a metaclass); NEW in extra131: first standalone abstractproperty dict class name invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.abstractproperty.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

