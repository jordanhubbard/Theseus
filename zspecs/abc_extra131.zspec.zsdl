    - [mod_eq,       abc.abstractmethod.__module__.__eq__,    ["abc"],            true, "abc.abstractmethod.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [mod_len,      abc.abstractmethod.__module__.__len__,   [],                 3,    "abc.abstractmethod.__module__.__len__() == 3; verified with Python 3.14.3"]
