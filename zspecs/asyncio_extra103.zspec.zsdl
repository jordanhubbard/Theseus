spec: asyncio_extra103
version: ">=3.9"
backend: python_module(asyncio)
extends: asyncio_extra102

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec extends asyncio_extra102.zspec.zsdl."
    - "This spec covers: wave 254 theme — asyncio Task and Future method __qualname__ string equality for the full method set. NEW in extra103: asyncio.Task.cancel.__qualname__=='Task.cancel' (len=11); asyncio.Task.result.__qualname__=='Task.result' (len=11); asyncio.Task.done.__qualname__=='Task.done' (len=9); asyncio.Task.exception.__qualname__=='Task.exception' (len=14); asyncio.Task.add_done_callback.__qualname__=='Task.add_done_callback' (len=22, longest Task method qualname); asyncio.Future.cancel.__qualname__=='Future.cancel' (len=13); asyncio.Future.result.__qualname__=='Future.result' (len=13); asyncio.Future.done.__qualname__=='Future.done' (len=11); asyncio.Future.exception.__qualname__=='Future.exception' (len=16); asyncio.Future.add_done_callback.__qualname__=='Future.add_done_callback' (len=24, longest Future method qualname). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.add_done_callback.__qualname__.__len__() == 22. 'Task.add_done_callback' is 22 chars: 'Task.'=5 + 'add_done_callback'=17. This is the longest Task method qualname in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.add_done_callback.__qualname__.__len__() == 24. 'Future.add_done_callback' is 24 chars: 'Future.'=7 + 'add_done_callback'=17. This is the longest Future method qualname in this spec, and the overall longest qualname in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.exception.__qualname__ == 'Task.exception' (len=14). Future.exception.__qualname__ == 'Future.exception' (len=16). The Future variant is two chars longer ('Future.'=7 vs 'Task.'=5). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Task method __qualname__ equality — extra103
#
# Wave 254 theme: asyncio Task method __qualname__ string equality (full set).
#
# asyncio.Task.cancel.__qualname__           == 'Task.cancel'            (len=11)
# asyncio.Task.result.__qualname__           == 'Task.result'            (len=11)
# asyncio.Task.done.__qualname__             == 'Task.done'              (len=9)
# asyncio.Task.exception.__qualname__        == 'Task.exception'         (len=14)
# asyncio.Task.add_done_callback.__qualname__ == 'Task.add_done_callback' (len=22)
# ---------------------------------------------------------------------------

table asyncio_extra103.asyncio_task_method_qualnames:
  description: "asyncio.Task method __qualname__ equality checks in asynciotaskmq103 namespace — wave 254 theme: all Task methods are C-level method_descriptors (module='_asyncio') and their __qualname__ values use 'Task.' prefix; Task.cancel.__qualname__.__eq__('Task.cancel')==True (len=11: 'Task.'=5 + 'cancel'=6); Task.result.__qualname__.__eq__('Task.result')==True (len=11: tied with cancel); Task.done.__qualname__.__eq__('Task.done')==True (len=9: shortest Task method qualname, 'Task.'=5 + 'done'=4); Task.exception.__qualname__.__eq__('Task.exception')==True (len=14: 'Task.'=5 + 'exception'=9); Task.add_done_callback.__qualname__.__eq__('Task.add_done_callback')==True (len=22: 'Task.'=5 + 'add_done_callback'=17, the longest Task method qualname); Task.cancel.__qualname__.__len__()==11; Task.done.__qualname__.__len__()==9; Task.exception.__qualname__.__len__()==14; Task.add_done_callback.__qualname__.__len__()==22; all Task method qualnames use 'Task.' prefix (5 chars) unlike Future methods which use 'Future.' prefix (7 chars); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: asynciotaskmq103

  columns: [id, function, args, expected, description]
  rows:
    - [task_cancel_eq,   asyncio.Task.cancel.__qualname__.__eq__,            ["Task.cancel"],            true, "asyncio.Task.cancel.__qualname__ == 'Task.cancel' (len=11); verified with Python 3.14.3"]
    - [task_cancel_len,  asyncio.Task.cancel.__qualname__.__len__,           [],                         11,   "asyncio.Task.cancel.__qualname__.__len__() == 11; verified with Python 3.14.3"]
    - [task_result_eq,   asyncio.Task.result.__qualname__.__eq__,            ["Task.result"],            true, "asyncio.Task.result.__qualname__ == 'Task.result' (len=11, tied with cancel); verified with Python 3.14.3"]
    - [task_result_len,  asyncio.Task.result.__qualname__.__len__,           [],                         11,   "asyncio.Task.result.__qualname__.__len__() == 11 (tied with cancel); verified with Python 3.14.3"]
    - [task_done_eq,     asyncio.Task.done.__qualname__.__eq__,              ["Task.done"],              true, "asyncio.Task.done.__qualname__ == 'Task.done' (len=9, shortest Task method qualname); verified with Python 3.14.3"]
    - [task_done_len,    asyncio.Task.done.__qualname__.__len__,             [],                         9,    "asyncio.Task.done.__qualname__.__len__() == 9 (shortest Task method qualname); verified with Python 3.14.3"]
    - [task_exc_eq,      asyncio.Task.exception.__qualname__.__eq__,         ["Task.exception"],         true, "asyncio.Task.exception.__qualname__ == 'Task.exception' (len=14); verified with Python 3.14.3"]
    - [task_exc_len,     asyncio.Task.exception.__qualname__.__len__,        [],                         14,   "asyncio.Task.exception.__qualname__.__len__() == 14 ('Task.'=5 + 'exception'=9); verified with Python 3.14.3"]
    - [task_adc_eq,      asyncio.Task.add_done_callback.__qualname__.__eq__, ["Task.add_done_callback"], true, "asyncio.Task.add_done_callback.__qualname__ == 'Task.add_done_callback' (len=22, longest Task method); verified with Python 3.14.3"]
    - [task_adc_len,     asyncio.Task.add_done_callback.__qualname__.__len__, [],                        22,   "asyncio.Task.add_done_callback.__qualname__.__len__() == 22 ('Task.'=5 + 'add_done_callback'=17); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Future method __qualname__ equality — extra103
#
# Wave 254 theme: asyncio Future method __qualname__ string equality (full set).
#
# asyncio.Future.cancel.__qualname__            == 'Future.cancel'            (len=13)
# asyncio.Future.result.__qualname__            == 'Future.result'            (len=13)
# asyncio.Future.done.__qualname__              == 'Future.done'              (len=11)
# asyncio.Future.exception.__qualname__         == 'Future.exception'         (len=16)
# asyncio.Future.add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24)
# ---------------------------------------------------------------------------

table asyncio_extra103.asyncio_future_method_qualnames:
  description: "asyncio.Future method __qualname__ equality checks in asynciotaskmq103 namespace — wave 254 theme: all Future methods are C-level method_descriptors (module='_asyncio') and their __qualname__ values use 'Future.' prefix (7 chars, two more than 'Task.' prefix of 5 chars); Future.cancel.__qualname__.__eq__('Future.cancel')==True (len=13: 'Future.'=7 + 'cancel'=6); Future.result.__qualname__.__eq__('Future.result')==True (len=13: tied with cancel); Future.done.__qualname__.__eq__('Future.done')==True (len=11: shortest Future method qualname, 'Future.'=7 + 'done'=4); Future.exception.__qualname__.__eq__('Future.exception')==True (len=16: 'Future.'=7 + 'exception'=9); Future.add_done_callback.__qualname__.__eq__('Future.add_done_callback')==True (len=24: 'Future.'=7 + 'add_done_callback'=17, the longest qualname in this entire spec); Future.cancel.__qualname__.__len__()==13; Future.done.__qualname__.__len__()==11; Future.exception.__qualname__.__len__()==16; Future.add_done_callback.__qualname__.__len__()==24; each Future method qualname is exactly 2 chars longer than its Task counterpart because 'Future.'=7 vs 'Task.'=5; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: asynciotaskmq103a

  columns: [id, function, args, expected, description]
  rows:
    - [fut_cancel_eq,   asyncio.Future.cancel.__qualname__.__eq__,            ["Future.cancel"],            true, "asyncio.Future.cancel.__qualname__ == 'Future.cancel' (len=13); verified with Python 3.14.3"]
    - [fut_cancel_len,  asyncio.Future.cancel.__qualname__.__len__,           [],                           13,   "asyncio.Future.cancel.__qualname__.__len__() == 13; verified with Python 3.14.3"]
    - [fut_result_eq,   asyncio.Future.result.__qualname__.__eq__,            ["Future.result"],            true, "asyncio.Future.result.__qualname__ == 'Future.result' (len=13, tied with cancel); verified with Python 3.14.3"]
    - [fut_result_len,  asyncio.Future.result.__qualname__.__len__,           [],                           13,   "asyncio.Future.result.__qualname__.__len__() == 13 (tied with cancel); verified with Python 3.14.3"]
    - [fut_done_eq,     asyncio.Future.done.__qualname__.__eq__,              ["Future.done"],              true, "asyncio.Future.done.__qualname__ == 'Future.done' (len=11, shortest Future method qualname); verified with Python 3.14.3"]
    - [fut_done_len,    asyncio.Future.done.__qualname__.__len__,             [],                           11,   "asyncio.Future.done.__qualname__.__len__() == 11 (shortest Future method qualname); verified with Python 3.14.3"]
    - [fut_exc_eq,      asyncio.Future.exception.__qualname__.__eq__,         ["Future.exception"],         true, "asyncio.Future.exception.__qualname__ == 'Future.exception' (len=16); verified with Python 3.14.3"]
    - [fut_exc_len,     asyncio.Future.exception.__qualname__.__len__,        [],                           16,   "asyncio.Future.exception.__qualname__.__len__() == 16 ('Future.'=7 + 'exception'=9); verified with Python 3.14.3"]
    - [fut_adc_eq,      asyncio.Future.add_done_callback.__qualname__.__eq__, ["Future.add_done_callback"], true, "asyncio.Future.add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24, longest in spec); verified with Python 3.14.3"]
    - [fut_adc_len,     asyncio.Future.add_done_callback.__qualname__.__len__, [],                          24,   "asyncio.Future.add_done_callback.__qualname__.__len__() == 24 ('Future.'=7 + 'add_done_callback'=17); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra103
# ---------------------------------------------------------------------------

invariant asyncio_extra103.Task_add_done_callback_qualname_longest:
  description: "asyncio.Task.add_done_callback.__qualname__.__len__() == 22 — Task.add_done_callback.__qualname__ is 'Task.add_done_callback' (22 chars: 'Task.'=5 + 'add_done_callback'=17); this is the longest Task method qualname in this spec; compare all five Task method qualname lengths: done=9, cancel=11, result=11, exception=14, add_done_callback=22; the compound name 'add_done_callback' contributes 17 chars; Task.add_done_callback registers a callback to be invoked when the Task completes, regardless of success or cancellation; Task.add_done_callback.__class__.__name__ is 'method_descriptor' (C-level method in _asyncio); NEW in extra103: first standalone Task.add_done_callback qualname length invariant in asynciotaskmq103 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: asyncio.Task.add_done_callback.__qualname__.__len__
  args: []
  expected: 22

invariant asyncio_extra103.Future_add_done_callback_qualname_longest:
  description: "asyncio.Future.add_done_callback.__qualname__.__len__() == 24 — Future.add_done_callback.__qualname__ is 'Future.add_done_callback' (24 chars: 'Future.'=7 + 'add_done_callback'=17); this is the longest qualname in this entire spec, and among all asyncio method qualnames covered in this series; compare: Task.add_done_callback.__qualname__.__len__()==22 (two fewer because 'Task.'=5 vs 'Future.'=7); all Future method qualnames are exactly 2 chars longer than their Task counterparts because of this prefix length difference; Future.add_done_callback registers a callback function to be invoked when the Future completes; NEW in extra103: first standalone Future.add_done_callback qualname length invariant in asynciotaskmq103 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: asyncio.Future.add_done_callback.__qualname__.__len__
  args: []
  expected: 24

invariant asyncio_extra103.Task_exception_qualname_eq:
  description: "asyncio.Task.exception.__qualname__.__eq__('Task.exception') returns True — Task.exception.__qualname__ is 'Task.exception' (14 chars: 'Task.'=5 + 'exception'=9); Task.exception returns the exception set on the Task if it raised, otherwise raises InvalidStateError (if not done) or CancelledError (if cancelled); Task.exception.__class__.__name__ is 'method_descriptor' (C-level method in _asyncio); compare: Future.exception.__qualname__ is 'Future.exception' (len=16, two more chars because 'Future.'=7 prefix); Task.exception.__qualname__.__len__()==14 while Future.exception.__qualname__.__len__()==16; NEW in extra103: first standalone Task.exception qualname invariant in asynciotaskmq103 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: asyncio.Task.exception.__qualname__.__eq__
  args: ["Task.exception"]
  expected: true

invariant asyncio_extra103.Future_done_qualname_len_is_11:
  description: "asyncio.Future.done.__qualname__.__len__() == 11 — Future.done.__qualname__ is 'Future.done' (11 chars: 'Future.'=7 + 'done'=4); this is the shortest Future method qualname in this spec; compare with Task.done.__qualname__.__len__()==9 (shortest Task method); Future.done() returns True if the Future is done (i.e. has a result, an exception, or has been cancelled); Future.done.__class__.__name__ is 'method_descriptor' (C-level); the 'Future.' prefix (7 chars) vs 'Task.' prefix (5 chars) means each Future method qualname is two chars longer than its Task counterpart; NEW in extra103: first standalone Future.done qualname length invariant in asynciotaskmq103 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: asyncio.Future.done.__qualname__.__len__
  args: []
  expected: 11

invariant asyncio_extra103.Task_done_qualname_shortest:
  description: "asyncio.Task.done.__qualname__.__len__() == 9 — Task.done.__qualname__ is 'Task.done' (9 chars: 'Task.'=5 + 'done'=4); this is the shortest Task method qualname in this spec; the ranking of Task method qualname lengths is: done=9, cancel=11, result=11, exception=14, add_done_callback=22; Task.done() returns True if the Task is done (finished, cancelled, or has an exception); Task.done.__class__.__name__ is 'method_descriptor' (C-level in _asyncio); compare: Future.done.__qualname__.__len__()==11 (two more chars due to 'Future.' prefix vs 'Task.' prefix); NEW in extra103: first standalone Task.done qualname shortest invariant in asynciotaskmq103 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: asyncio.Task.done.__qualname__.__len__
  args: []
  expected: 9
