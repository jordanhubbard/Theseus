spec: errno_extra
version: ">=3.0"
backend: python_module(errno)

docs: https://docs.python.org/3/library/errno.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/errno.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/errnomodule.c"
  notes:
    - "This spec covers errno module constants and the errorcode dictionary."
    - "errno.ENOENT == 2 — No such file or directory (POSIX standard value)."
    - "errno.EACCES == 13 — Permission denied (POSIX standard value)."
    - "errno.EEXIST == 17 — File exists (POSIX standard value; verified on macOS/Darwin 25.4.0)."
    - "errno.EPERM == 1 — Operation not permitted (POSIX standard value)."
    - "All error constants are plain int values."
    - "errno.errorcode is a dict mapping integer error codes to string constant names."
    - "errno.strerror does not exist in the errno module; os.strerror() provides that functionality."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ENOENT — class type is int, value is 2
# ---------------------------------------------------------------------------

invariant errno_extra.ENOENT.class_name:
  description: "errno.ENOENT.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: ENOENT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant errno_extra.ENOENT.value:
  description: "errno.ENOENT == 2"
  category: constants
  kind: python_call_eq
  function: ENOENT.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# EACCES — class type is int, value is 13
# ---------------------------------------------------------------------------

invariant errno_extra.EACCES.class_name:
  description: "errno.EACCES.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: EACCES.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant errno_extra.EACCES.value:
  description: "errno.EACCES == 13"
  category: constants
  kind: python_call_eq
  function: EACCES.__eq__
  args: [13]
  expected: true

# ---------------------------------------------------------------------------
# EEXIST — class type is int, value is 17
# ---------------------------------------------------------------------------

invariant errno_extra.EEXIST.class_name:
  description: "errno.EEXIST.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: EEXIST.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant errno_extra.EEXIST.value:
  description: "errno.EEXIST == 17"
  category: constants
  kind: python_call_eq
  function: EEXIST.__eq__
  args: [17]
  expected: true

# ---------------------------------------------------------------------------
# EPERM — class type is int
# ---------------------------------------------------------------------------

invariant errno_extra.EPERM.class_name:
  description: "errno.EPERM.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: EPERM.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# errorcode — dict mapping int codes to string names
# ---------------------------------------------------------------------------

invariant errno_extra.errorcode.class_name:
  description: "errno.errorcode.__class__.__name__ == 'dict'"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant errno_extra.errorcode.contains_ENOENT_key:
  description: "2 in errno.errorcode — error code 2 maps to ENOENT"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [2]
  expected: true

invariant errno_extra.errorcode.ENOENT_value:
  description: "errno.errorcode[2] == 'ENOENT'"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [2]
  method: __eq__
  method_args: ["ENOENT"]
  expected: true
