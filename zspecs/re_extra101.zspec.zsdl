spec: re_extra101
version: ">=3.9"
backend: python_module(re)
extends: re_extra100

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra100.zspec.zsdl."
    - "This spec covers: re module-level constants and flag identity (re.RegexFlag enum class and individual flag values)."
    - "re.RegexFlag.__class__.__name__ = 'EnumType' — the RegexFlag enum class itself is an instance of the EnumType metaclass (not plain 'type')."
    - "re.RegexFlag.__module__ = 're' — the RegexFlag enum is defined in the re module."
    - "re.RegexFlag.__name__ = 'RegexFlag', __qualname__ = 'RegexFlag' (length 9)."
    - "re.RegexFlag.__bases__[0].__name__ = 'IntFlag' — RegexFlag extends IntFlag, making each flag both an enum member and an int."
    - "re.RegexFlag.__mro__.__len__() = 7 — MRO is [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object]."
    - "re.IGNORECASE.__class__.__name__ = 'RegexFlag' — individual flags are instances of RegexFlag."
    - "re.IGNORECASE.value = 2 — the numeric value used in the C regex engine."
    - "re.MULTILINE.value = 8."
    - "re.DOTALL.value = 16."
    - "re.UNICODE.value = 32."
    - "re.VERBOSE.value = 64."
    - "re.DEBUG.value = 128."
    - "re.ASCII.value = 256."
    - "re.LOCALE.value = 4."
    - "re.NOFLAG.value = 0 — the zero-valued flag representing no flags set."
    - "re.I is re.IGNORECASE — the short alias is the same object (identity, not just equality)."
    - "re.IGNORECASE.name = 'IGNORECASE' — the enum member name attribute."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.RegexFlag class identity
# re.RegexFlag is an IntFlag enum. Its metaclass is 'EnumType' (not 'type').
# It extends IntFlag, making flags behave both as enum members and integers.
# MRO length == 7: [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object].
# ---------------------------------------------------------------------------

table re_extra101.RegexFlag_class_identity:
  description: "re.RegexFlag class identity: __class__.__name__ (EnumType), __module__, __name__, __qualname__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: reregexflag101

  columns: [id, function, args, expected, description]
  rows:
    - [rf_meta_eq,       RegexFlag.__class__.__name__.__eq__,           ["EnumType"],  true,  "RegexFlag.__class__.__name__ == 'EnumType' (RegexFlag uses the EnumType metaclass, not plain 'type')"]
    - [rf_meta_not_type, RegexFlag.__class__.__name__.__eq__,           ["type"],      false, "RegexFlag.__class__.__name__ is NOT 'type' (enum classes use EnumType as their metaclass)"]
    - [rf_module_eq,     RegexFlag.__module__.__eq__,                   ["re"],        true,  "RegexFlag.__module__ == 're' (defined in the public re module)"]
    - [rf_name_eq,       RegexFlag.__name__.__eq__,                     ["RegexFlag"], true,  "RegexFlag.__name__ == 'RegexFlag' (bare class name)"]
    - [rf_qualname_eq,   RegexFlag.__qualname__.__eq__,                 ["RegexFlag"], true,  "RegexFlag.__qualname__ == 'RegexFlag' (no enclosing class)"]
    - [rf_qualname_len,  RegexFlag.__qualname__.__len__,                [],            9,     "RegexFlag.__qualname__.__len__() == 9 ('RegexFlag' has 9 characters)"]
    - [rf_base_eq,       "RegexFlag.__bases__[0].__name__.__eq__",        ["IntFlag"],   true,  "RegexFlag.__bases__[0].__name__ == 'IntFlag' (RegexFlag extends IntFlag, so flags are integers)"]
    - [rf_mro_len,       RegexFlag.__mro__.__len__,                     [],            7,     "RegexFlag.__mro__.__len__() == 7 (MRO is [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object])"]
    - [rf_mro_not_2,     RegexFlag.__mro__.__len__.__eq__,              [2],           false, "RegexFlag.__mro__.__len__() is NOT 2 (RegexFlag has a deep inheritance chain through IntFlag, int, Flag, Enum)"]

# ---------------------------------------------------------------------------
# re.RegexFlag individual flag values
# Each flag constant is an instance of RegexFlag (an IntFlag subclass).
# Values are powers of 2 (except LOCALE=4 and NOFLAG=0).
# IGNORECASE=2, LOCALE=4, MULTILINE=8, DOTALL=16, UNICODE=32, VERBOSE=64,
# DEBUG=128, ASCII=256, NOFLAG=0.
# ---------------------------------------------------------------------------

table re_extra101.flag_instance_class_names:
  description: "re flag constants (IGNORECASE, MULTILINE, DOTALL, VERBOSE, UNICODE, ASCII, LOCALE, DEBUG) all have __class__.__name__ == 'RegexFlag'"
  kind: python_call_eq
  category: flag_values
  id_prefix: reregexflag101

  columns: [id, function, args, expected, description]
  rows:
    - [ignc_cls,  IGNORECASE.__class__.__name__.__eq__, ["RegexFlag"], true,  "re.IGNORECASE.__class__.__name__ == 'RegexFlag' (IGNORECASE is an instance of the RegexFlag IntFlag enum)"]
    - [mult_cls,  MULTILINE.__class__.__name__.__eq__,  ["RegexFlag"], true,  "re.MULTILINE.__class__.__name__ == 'RegexFlag'"]
    - [dots_cls,  DOTALL.__class__.__name__.__eq__,     ["RegexFlag"], true,  "re.DOTALL.__class__.__name__ == 'RegexFlag'"]
    - [verb_cls,  VERBOSE.__class__.__name__.__eq__,    ["RegexFlag"], true,  "re.VERBOSE.__class__.__name__ == 'RegexFlag'"]
    - [uni_cls,   UNICODE.__class__.__name__.__eq__,    ["RegexFlag"], true,  "re.UNICODE.__class__.__name__ == 'RegexFlag'"]
    - [asc_cls,   ASCII.__class__.__name__.__eq__,      ["RegexFlag"], true,  "re.ASCII.__class__.__name__ == 'RegexFlag'"]
    - [loc_cls,   LOCALE.__class__.__name__.__eq__,     ["RegexFlag"], true,  "re.LOCALE.__class__.__name__ == 'RegexFlag'"]
    - [dbg_cls,   DEBUG.__class__.__name__.__eq__,      ["RegexFlag"], true,  "re.DEBUG.__class__.__name__ == 'RegexFlag'"]
    - [noflag_cls,NOFLAG.__class__.__name__.__eq__,     ["RegexFlag"], true,  "re.NOFLAG.__class__.__name__ == 'RegexFlag' (NOFLAG is also a member of RegexFlag, representing the zero-value state)"]
    - [ignc_not_int, IGNORECASE.__class__.__name__.__eq__, ["int"],    false, "re.IGNORECASE.__class__.__name__ is NOT 'int' (although RegexFlag extends IntFlag which extends int, the direct class is RegexFlag)"]

# ---------------------------------------------------------------------------
# re.RegexFlag flag integer values
# IGNORECASE=2, LOCALE=4, MULTILINE=8, DOTALL=16, UNICODE=32, VERBOSE=64,
# DEBUG=128, ASCII=256, NOFLAG=0.
# These are the bit-flag values passed to the underlying C regex engine.
# ---------------------------------------------------------------------------

table re_extra101.flag_integer_values:
  description: "re flag integer values: NOFLAG=0, IGNORECASE=2, LOCALE=4, MULTILINE=8, DOTALL=16, UNICODE=32, VERBOSE=64, DEBUG=128, ASCII=256"
  kind: python_call_eq
  category: flag_values
  id_prefix: reregexflag101

  columns: [id, function, args, expected, description]
  rows:
    - [noflag_val,  NOFLAG.value.__eq__,     [0],   true,  "re.NOFLAG.value == 0 (the zero-value flag; no regex flags are set)"]
    - [ignc_val,    IGNORECASE.value.__eq__,  [2],   true,  "re.IGNORECASE.value == 2 (bit 1 in the flags integer)"]
    - [loc_val,     LOCALE.value.__eq__,      [4],   true,  "re.LOCALE.value == 4 (bit 2; locale-aware matching)"]
    - [mult_val,    MULTILINE.value.__eq__,   [8],   true,  "re.MULTILINE.value == 8 (bit 3; ^ and $ match at each line)"]
    - [dots_val,    DOTALL.value.__eq__,      [16],  true,  "re.DOTALL.value == 16 (bit 4; . matches any character including newline)"]
    - [uni_val,     UNICODE.value.__eq__,     [32],  true,  "re.UNICODE.value == 32 (bit 5; enable Unicode matching; default for str patterns)"]
    - [verb_val,    VERBOSE.value.__eq__,     [64],  true,  "re.VERBOSE.value == 64 (bit 6; allow whitespace and comments in patterns)"]
    - [dbg_val,     DEBUG.value.__eq__,       [128], true,  "re.DEBUG.value == 128 (bit 7; display debug information about the compiled pattern)"]
    - [asc_val,     ASCII.value.__eq__,       [256], true,  "re.ASCII.value == 256 (bit 8; restrict \\w, \\b, \\d, \\s to ASCII equivalents)"]
    - [ignc_name,   IGNORECASE.name.__eq__,   ["IGNORECASE"], true, "re.IGNORECASE.name == 'IGNORECASE' (the enum member's canonical name attribute)"]
    - [mult_name,   MULTILINE.name.__eq__,    ["MULTILINE"],  true, "re.MULTILINE.name == 'MULTILINE'"]
    - [noflag_name, NOFLAG.name.__eq__,       ["NOFLAG"],     true, "re.NOFLAG.name == 'NOFLAG' (the zero-value flag has the name 'NOFLAG')"]
    - [ignc_not_8,  IGNORECASE.value.__eq__,  [8],   false, "re.IGNORECASE.value is NOT 8 (that is MULTILINE's value; IGNORECASE is 2)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra101.RegexFlag.metaclass_is_EnumType:
  description: "re.RegexFlag.__class__.__name__ == 'EnumType' (the RegexFlag class is an IntFlag enum; Python's enum machinery uses 'EnumType' as the metaclass for all enum classes, replacing the plain 'type' metaclass)"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__class__.__name__.__eq__
  args: ["EnumType"]
  expected: true

invariant re_extra101.RegexFlag.base_is_IntFlag:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (RegexFlag extends IntFlag, which means each flag constant is simultaneously a RegexFlag enum member and an integer; this allows flags to be OR-combined with the | operator)"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__bases__[0].__name__.__eq__
  args: ["IntFlag"]
  expected: true

invariant re_extra101.RegexFlag.mro_len_7:
  description: "re.RegexFlag.__mro__.__len__() == 7 (MRO is [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object]; the deep MRO reflects RegexFlag's inheritance from the full enum hierarchy)"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__mro__.__len__
  args: []
  expected: 7

invariant re_extra101.IGNORECASE.value_is_2:
  description: "re.IGNORECASE.value == 2 (IGNORECASE is bit flag 1, represented as the integer 2; the underlying C regex engine uses this bitmask to enable case-insensitive matching)"
  category: flag_values
  kind: python_call_eq
  function: IGNORECASE.value.__eq__
  args: [2]
  expected: true

invariant re_extra101.DOTALL.value_is_16:
  description: "re.DOTALL.value == 16 (DOTALL is bit flag 4, represented as 16; when set, the dot metacharacter '.' matches any character including newline, which it does not match by default)"
  category: flag_values
  kind: python_call_eq
  function: DOTALL.value.__eq__
  args: [16]
  expected: true

