spec: re_extra601
version: ">=3.9"
backend: python_module(re)
docs: "Behavioral spec for re function __doc__ type and re.error attribute identity"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers re function __doc__ attribute type and re.error class attribute identity"
  created_at: "2026-04-12T00:00:00Z"

table re_extra601.re601dc:
  id_prefix: re601dc

  description: "re function __doc__ attributes are str instances"
  columns: [id, function, args, expected]
  rows:
    - [re601dc01, "re.compile.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [re601dc02, "re.match.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [re601dc03, "re.search.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [re601dc04, "re.fullmatch.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [re601dc05, "re.findall.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [re601dc06, "re.sub.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [re601dc07, "re.split.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [re601dc08, "re.Pattern.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [re601dc09, "re.Match.__doc__.__class__.__name__.__eq__", ["str"], true]

table re_extra601.re601fn:
  id_prefix: re601fn

  description: "re.error class attribute identity"
  columns: [id, function, args, expected]
  rows:
    - [re601fn01, "re.error.__module__.__eq__", ["re"], true]
    - [re601fn02, "re.error.__init__.__qualname__.__eq__", ["error.__init__"], true]
    - [re601fn03, "re.error.__str__.__qualname__.__eq__", ["error.__str__"], true]
