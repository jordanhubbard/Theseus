spec: typing_extra10
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "PEP 484 — Type Hints"
    - "PEP 647 — User-Defined Type Guards"
    - "PEP 655 — Marking individual TypedDict items as required or potentially-missing"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing.zspec.zsdl through typing_extra9.zspec.zsdl."
    - "typing_extra8 covers __module__ for get_type_hints/cast/overload/get_args/get_origin."
    - "typing_extra9 covers runtime_checkable.__name__, is_typeddict.__qualname__, get_overloads.__qualname__."
    - "NOT yet covered: assert_never.__qualname__/__module__; assert_type.__qualname__/__module__ (3.11+)."
    - "NOT yet covered: no_type_check.__qualname__/__module__; no_type_check_decorator.__qualname__/__module__."
    - "NOT yet covered: final.__qualname__/__module__ as standalone invariants."
    - "NOT yet covered: ParamSpec.__bases__[0].__name__ == 'object'; ParamSpec.__bases__.__len__ == 1."
    - "NOT yet covered: TypeVarTuple.__bases__[0].__name__ == 'object'; TypeVarTuple.__class__.__name__ == 'type' (3.11+)."
    - "NOT yet covered: Never/__class__.__name__; Self/__class__.__name__; LiteralString/__class__.__name__ (3.11+)."
    - "typing.assert_never.__qualname__ == 'assert_never' (Python 3.11+) — module-level function."
    - "typing.assert_never.__module__ == 'typing' (Python 3.11+)."
    - "typing.assert_type.__qualname__ == 'assert_type' (Python 3.11+) — module-level function."
    - "typing.no_type_check.__qualname__ == 'no_type_check' — decorator defined in typing module."
    - "typing.no_type_check.__module__ == 'typing'."
    - "typing.no_type_check_decorator.__qualname__ == 'no_type_check_decorator'."
    - "typing.final.__qualname__ == 'final' — module-level function."
    - "typing.final.__module__ == 'typing'."
    - "typing.ParamSpec.__bases__[0].__name__ == 'object' — ParamSpec is a plain class (Python 3.10+)."
    - "typing.ParamSpec.__bases__.__len__() == 1 — exactly one direct base."
    - "typing.TypeVarTuple.__bases__[0].__name__ == 'object' — TypeVarTuple is a plain class (Python 3.11+)."
    - "typing.Never.__class__.__name__ == '_SpecialForm' (Python 3.11+)."
    - "typing.Self.__class__.__name__ == '_SpecialForm' (Python 3.11+)."
    - "typing.LiteralString.__class__.__name__ == '_SpecialForm' (Python 3.11+)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# assert_never — __qualname__ and __module__ (Python 3.11+)
#
# typing.assert_never is a module-level function added in Python 3.11 (PEP 647
# companion). Prior specs verify assert_never is not yet given its own
# __qualname__ or __module__ invariant.
# ---------------------------------------------------------------------------

invariant typing_extra10.assert_never.qualname:
  description: "typing.assert_never.__qualname__ == 'assert_never' (Python 3.11+)"
  category: function_qualnames
  version: ">=3.11"
  kind: python_call_eq
  function: assert_never.__qualname__.__eq__
  args: ["assert_never"]
  expected: true

invariant typing_extra10.assert_never.module:
  description: "typing.assert_never.__module__ == 'typing' (Python 3.11+)"
  category: function_modules
  version: ">=3.11"
  kind: python_call_eq
  function: assert_never.__module__.__eq__
  args: ["typing"]
  expected: true

# ---------------------------------------------------------------------------
# assert_type — __qualname__ and __module__ (Python 3.11+)
#
# typing.assert_type was added in Python 3.11. Neither __qualname__ nor
# __module__ have been verified in any prior spec.
# ---------------------------------------------------------------------------

invariant typing_extra10.assert_type.qualname:
  description: "typing.assert_type.__qualname__ == 'assert_type' (Python 3.11+)"
  category: function_qualnames
  version: ">=3.11"
  kind: python_call_eq
  function: assert_type.__qualname__.__eq__
  args: ["assert_type"]
  expected: true

invariant typing_extra10.assert_type.module:
  description: "typing.assert_type.__module__ == 'typing' (Python 3.11+)"
  category: function_modules
  version: ">=3.11"
  kind: python_call_eq
  function: assert_type.__module__.__eq__
  args: ["typing"]
  expected: true

# ---------------------------------------------------------------------------
# no_type_check — __qualname__ and __module__
#
# typing.no_type_check is a decorator that marks a function so type checkers
# ignore its body. Prior specs do not cover its __qualname__ or __module__.
# ---------------------------------------------------------------------------

invariant typing_extra10.no_type_check.qualname:
  description: "typing.no_type_check.__qualname__ == 'no_type_check'"
  category: function_qualnames
  kind: python_call_eq
  function: no_type_check.__qualname__.__eq__
  args: ["no_type_check"]
  expected: true

invariant typing_extra10.no_type_check.module:
  description: "typing.no_type_check.__module__ == 'typing'"
  category: function_modules
  kind: python_call_eq
  function: no_type_check.__module__.__eq__
  args: ["typing"]
  expected: true

# ---------------------------------------------------------------------------
# final — __qualname__ and __module__
#
# typing.final is the @final decorator (PEP 591). typing_extra verified
# final.__module__ in a table row but no standalone invariant covers
# final.__qualname__.
# ---------------------------------------------------------------------------

invariant typing_extra10.final.qualname:
  description: "typing.final.__qualname__ == 'final'"
  category: function_qualnames
  kind: python_call_eq
  function: final.__qualname__.__eq__
  args: ["final"]
  expected: true

invariant typing_extra10.final.module:
  description: "typing.final.__module__ == 'typing'"
  category: function_modules
  kind: python_call_eq
  function: final.__module__.__eq__
  args: ["typing"]
  expected: true

# ---------------------------------------------------------------------------
# ParamSpec class hierarchy (Python 3.10+)
#
# typing.ParamSpec is a plain class whose sole base is object. typing_extra7
# verified ParamSpec.__class__.__name__ == 'type'. No prior spec has tested
# ParamSpec.__bases__[0].__name__ or ParamSpec.__bases__.__len__.
# ---------------------------------------------------------------------------

invariant typing_extra10.ParamSpec.base_is_object:
  description: "typing.ParamSpec.__bases__[0].__name__ == 'object' — ParamSpec is a plain class (Python 3.10+)"
  category: ParamSpec
  version: ">=3.10"
  kind: python_call_eq
  function: ParamSpec.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant typing_extra10.ParamSpec.bases_len:
  description: "typing.ParamSpec.__bases__.__len__() == 1 — ParamSpec has exactly one direct base (Python 3.10+)"
  category: ParamSpec
  version: ">=3.10"
  kind: python_call_eq
  function: ParamSpec.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# TypeVarTuple class hierarchy (Python 3.11+)
#
# typing.TypeVarTuple is a plain class (metaclass 'type') whose sole base is
# object. typing_extra7 covers TypeVarTuple.__qualname__ and extra9 notes it
# as uncovered. No prior spec has tested TypeVarTuple.__bases__[0].__name__.
# ---------------------------------------------------------------------------

invariant typing_extra10.TypeVarTuple.base_is_object:
  description: "typing.TypeVarTuple.__bases__[0].__name__ == 'object' — TypeVarTuple is a plain class (Python 3.11+)"
  category: TypeVarTuple
  version: ">=3.11"
  kind: python_call_eq
  function: TypeVarTuple.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Python 3.11+ _SpecialForm additions: Never, Self, LiteralString
#
# typing_extra8 covers Callable/NoReturn/Annotated as _SpecialForm.
# typing_extra6 covers Union/Optional/ClassVar/Final/Literal as _SpecialForm.
# Never (PEP 655 / Python 3.11), Self (PEP 673 / Python 3.11), and
# LiteralString (PEP 675 / Python 3.11) are uncovered.
# ---------------------------------------------------------------------------

invariant typing_extra10.Never.class_name:
  description: "typing.Never.__class__.__name__ == '_SpecialForm' (Python 3.11+)"
  category: special_forms
  version: ">=3.11"
  kind: python_call_eq
  function: Never.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true

invariant typing_extra10.Self.class_name:
  description: "typing.Self.__class__.__name__ == '_SpecialForm' (Python 3.11+)"
  category: special_forms
  version: ">=3.11"
  kind: python_call_eq
  function: Self.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true

invariant typing_extra10.LiteralString.class_name:
  description: "typing.LiteralString.__class__.__name__ == '_SpecialForm' (Python 3.11+)"
  category: special_forms
  version: ">=3.11"
  kind: python_call_eq
  function: LiteralString.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true
