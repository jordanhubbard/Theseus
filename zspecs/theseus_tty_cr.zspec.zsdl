spec: theseus_tty_cr
version: ">=3.8"
backend: python_cleanroom(theseus_tty_cr)
blocks: tty

docs: https://docs.python.org/3/library/tty.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/tty.html"
  not_derived_from:
    - "CPython source: Lib/tty.py"
  notes:
    - "Clean-room tty module. Do NOT import tty."

error_model: python_exceptions

invariant theseus_tty_cr.tty2_constants:
  description: "IFLAG, OFLAG, CFLAG, LFLAG constants are ints"
  category: behavior
  kind: python_call_eq
  function: tty2_constants
  args: []
  expected: true

invariant theseus_tty_cr.tty2_setraw_callable:
  description: "setraw and setcbreak are callable"
  category: behavior
  kind: python_call_eq
  function: tty2_setraw_callable
  args: []
  expected: true

invariant theseus_tty_cr.tty2_mode_indices:
  description: "ISPEED, OSPEED, CC mode indices are ints"
  category: behavior
  kind: python_call_eq
  function: tty2_mode_indices
  args: []
  expected: true
