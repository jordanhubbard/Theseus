spec: dc3346
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 670 (dc3346): __neg__, __pos__, __abs__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "Theme: __neg__, __pos__, __abs__ dict-presence (unary operators: -x, +x, abs(x))."
    - "decimal.Decimal DOES define __neg__ in its own __dict__: true. Decimal is a complete IEEE 754 arbitrary-precision decimal numeric type; unary negation (-d) is defined and returns a Decimal with the sign flipped."
    - "decimal.Decimal DOES define __pos__ in its own __dict__: true. Unary plus (+d) is defined and canonicalizes the Decimal value (applies the current context's precision and rounding)."
    - "decimal.Decimal DOES define __abs__ in its own __dict__: true. abs(d) is defined and returns the absolute value of the Decimal, respecting the current context."
    - "decimal.Context does NOT define __neg__, __pos__, or __abs__ in its own __dict__: Context is a precision/rounding configuration object, not a numeric operand."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow are exception subclasses with no arithmetic protocol defined in their own __dict__."
    - "decimal.Decimal is unique among the covered types in this wave: it is the only complete IEEE 754 numeric type in this set, defining all three unary arithmetic operators. Contrast with io, pathlib, and re types, which define none."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __neg__ dict-presence — operator.contains(Cls.__dict__, '__neg__')
#
# decimal.Decimal DOES define __neg__ in its own __dict__: true.
# Decimal is an IEEE 754 arbitrary-precision decimal numeric type; unary
# negation (-d) flips the sign bit and is a core arithmetic operation.
# All other decimal classes: false.
# ---------------------------------------------------------------------------

table dc3346.neg:
  description: "decimal types __neg__ dict-presence checks; wave 670"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3346

  columns: [id, function, args, expected]
  rows:
    - ["dc3346001", operator.contains, [decimal.Decimal.__dict__,          "__neg__"], true]
    - ["dc3346002", operator.contains, [decimal.Context.__dict__,           "__neg__"], false]
    - ["dc3346003", operator.contains, [decimal.DecimalException.__dict__,  "__neg__"], false]
    - ["dc3346004", operator.contains, [decimal.InvalidOperation.__dict__,  "__neg__"], false]
    - ["dc3346005", operator.contains, [decimal.Overflow.__dict__,          "__neg__"], false]
    - ["dc3346006", operator.contains, [decimal.Underflow.__dict__,         "__neg__"], false]

# ---------------------------------------------------------------------------
# __pos__ dict-presence — operator.contains(Cls.__dict__, '__pos__')
#
# decimal.Decimal DOES define __pos__ in its own __dict__: true.
# Unary plus (+d) canonicalizes the Decimal value by applying the current
# context's precision and rounding rules; this is a meaningful arithmetic
# operation distinct from a no-op.
# All other decimal classes: false.
# ---------------------------------------------------------------------------

