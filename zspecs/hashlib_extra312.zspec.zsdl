spec: hashlib_extra312
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "pbkdf2_hmac and scrypt are C-level built-in functions in _hashlib: __class__.__name__ == 'builtin_function_or_method'."
    - "hashlib.md5 on macOS with OpenSSL is the openssl_md5 constructor: __name__ == 'openssl_md5', __module__ == '_hashlib'."
    - "hashlib.sha256 on macOS with OpenSSL: __name__ == 'openssl_sha256', __module__ == '_hashlib'."
    - "hashlib.sha512 on macOS with OpenSSL: __name__ == 'openssl_sha512', __module__ == '_hashlib'."
    - "hashlib.sha3_256 on macOS with OpenSSL: __name__ == 'openssl_sha3_256', __module__ == '_hashlib'."
    - "hashlib.blake2b and hashlib.blake2s are type objects from _blake2: __module__ == '_blake2'."
    - "algorithms_guaranteed.__len__() == 14 on Python 3.14 macOS: blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pbkdf2_hmac — C-level built-in for password hashing (RFC 2898)
# ---------------------------------------------------------------------------

invariant hashlib_extra312.pbkdf2_hmac.name:
  description: "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac'"
  category: functions
  kind: python_call_eq
  function: pbkdf2_hmac.__name__.__eq__
  args: ["pbkdf2_hmac"]
  expected: true

invariant hashlib_extra312.pbkdf2_hmac.module:
  description: "hashlib.pbkdf2_hmac.__module__ == '_hashlib' — implemented in the C extension"
  category: functions
  kind: python_call_eq
  function: pbkdf2_hmac.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# scrypt — C-level built-in (available on macOS with OpenSSL)
# ---------------------------------------------------------------------------

invariant hashlib_extra312.scrypt.name:
  description: "hashlib.scrypt.__name__ == 'scrypt'"
  category: functions
  kind: python_call_eq
  function: scrypt.__name__.__eq__
  args: ["scrypt"]
  expected: true

invariant hashlib_extra312.scrypt.module:
  description: "hashlib.scrypt.__module__ == '_hashlib' — implemented in the C extension"
  category: functions
  kind: python_call_eq
  function: scrypt.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5 — on macOS with OpenSSL, resolves to openssl_md5
# ---------------------------------------------------------------------------

invariant hashlib_extra312.md5.name:
  description: "hashlib.md5.__name__ == 'openssl_md5' on macOS (OpenSSL-backed)"
  category: functions
  kind: python_call_eq
  function: md5.__name__.__eq__
  args: ["openssl_md5"]
  expected: true

invariant hashlib_extra312.md5.module:
  description: "hashlib.md5.__module__ == '_hashlib' — OpenSSL-backed md5 is in the C extension"
  category: functions
  kind: python_call_eq
  function: md5.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256 — on macOS with OpenSSL, resolves to openssl_sha256
# ---------------------------------------------------------------------------

invariant hashlib_extra312.sha256.name:
  description: "hashlib.sha256.__name__ == 'openssl_sha256' on macOS (OpenSSL-backed)"
  category: functions
  kind: python_call_eq
  function: sha256.__name__.__eq__
  args: ["openssl_sha256"]
  expected: true

invariant hashlib_extra312.sha256.module:
  description: "hashlib.sha256.__module__ == '_hashlib' — OpenSSL-backed sha256 is in the C extension"
  category: functions
  kind: python_call_eq
  function: sha256.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha512 — on macOS with OpenSSL, resolves to openssl_sha512
# ---------------------------------------------------------------------------

invariant hashlib_extra312.sha512.name:
  description: "hashlib.sha512.__name__ == 'openssl_sha512' on macOS (OpenSSL-backed)"
  category: functions
  kind: python_call_eq
  function: sha512.__name__.__eq__
  args: ["openssl_sha512"]
  expected: true

invariant hashlib_extra312.sha512.module:
  description: "hashlib.sha512.__module__ == '_hashlib' — OpenSSL-backed sha512 is in the C extension"
  category: functions
  kind: python_call_eq
  function: sha512.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256 — on macOS with OpenSSL, resolves to openssl_sha3_256
# ---------------------------------------------------------------------------

invariant hashlib_extra312.sha3_256.name:
  description: "hashlib.sha3_256.__name__ == 'openssl_sha3_256' on macOS (OpenSSL-backed)"
  category: functions
  kind: python_call_eq
  function: sha3_256.__name__.__eq__
  args: ["openssl_sha3_256"]
  expected: true

invariant hashlib_extra312.sha3_256.module:
  description: "hashlib.sha3_256.__module__ == '_hashlib' — OpenSSL-backed sha3_256 is in the C extension"
  category: functions
  kind: python_call_eq
  function: sha3_256.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b — type object from _blake2 extension
# ---------------------------------------------------------------------------

invariant hashlib_extra312.blake2b.name:
  description: "hashlib.blake2b.__name__ == 'blake2b' — from the _blake2 C extension"
  category: functions
  kind: python_call_eq
  function: blake2b.__name__.__eq__
  args: ["blake2b"]
  expected: true

invariant hashlib_extra312.blake2b.module:
  description: "hashlib.blake2b.__module__ == '_blake2' — blake2b is in its own C extension"
  category: functions
  kind: python_call_eq
  function: blake2b.__module__.__eq__
  args: ["_blake2"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s — type object from _blake2 extension
# ---------------------------------------------------------------------------

invariant hashlib_extra312.blake2s.name:
  description: "hashlib.blake2s.__name__ == 'blake2s' — from the _blake2 C extension"
  category: functions
  kind: python_call_eq
  function: blake2s.__name__.__eq__
  args: ["blake2s"]
  expected: true

invariant hashlib_extra312.blake2s.module:
  description: "hashlib.blake2s.__module__ == '_blake2' — blake2s is in its own C extension"
  category: functions
  kind: python_call_eq
  function: blake2s.__module__.__eq__
  args: ["_blake2"]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_guaranteed — length check
# Python 3.14 macOS: 14 algorithms guaranteed
# ---------------------------------------------------------------------------

invariant hashlib_extra312.algorithms_guaranteed.len:
  description: "len(hashlib.algorithms_guaranteed) == 14 on Python 3.14 macOS"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__len__
  args: []
  expected: 14
