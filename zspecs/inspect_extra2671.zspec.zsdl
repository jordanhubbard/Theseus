spec: inspect_extra2671
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 625 theme: __sub__, __floordiv__, and __mod__ dict-presence checks (subtraction and integer division arithmetic)."
    - "inspect.Parameter is an introspection value object; it does not implement subtraction or integer division arithmetic."
    - "inspect.BoundArguments wraps a signature binding; it exposes .args and .kwargs but does not define __sub__, __floordiv__, or __mod__ itself."
    - "inspect.Signature is a callable signature descriptor; it defines __eq__ and __hash__ but not __sub__, __floordiv__, or __mod__."
    - "inspect.FullArgSpec is a namedtuple subclass; namedtuples inherit tuple methods but do not define __sub__, __floordiv__, or __mod__ in their own __dict__."
    - "None of these four inspect types define __sub__, __floordiv__, or __mod__ in their own class __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __sub__ dict-presence — absent from all four inspect types
# ---------------------------------------------------------------------------

table inspect_extra2671.sub_protocol:
  description: "__sub__ is absent from all inspect type __dict__s — none define subtraction directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2671

  columns: [id, function, args, expected]
  rows:
    - ["in2671001", "inspect.Parameter.__dict__.__contains__",       ["__sub__"], false]
    - ["in2671002", "inspect.BoundArguments.__dict__.__contains__",  ["__sub__"], false]
    - ["in2671003", "inspect.Signature.__dict__.__contains__",       ["__sub__"], false]
    - ["in2671004", "inspect.FullArgSpec.__dict__.__contains__",     ["__sub__"], false]

# ---------------------------------------------------------------------------
# __floordiv__ dict-presence — absent from all four inspect types
# ---------------------------------------------------------------------------

table inspect_extra2671.floordiv_protocol:
  description: "__floordiv__ is absent from all inspect type __dict__s — none define floor division directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2671

  columns: [id, function, args, expected]
  rows:
    - ["in2671005", "inspect.Parameter.__dict__.__contains__",       ["__floordiv__"], false]
    - ["in2671006", "inspect.BoundArguments.__dict__.__contains__",  ["__floordiv__"], false]
    - ["in2671007", "inspect.Signature.__dict__.__contains__",       ["__floordiv__"], false]
    - ["in2671008", "inspect.FullArgSpec.__dict__.__contains__",     ["__floordiv__"], false]

# ---------------------------------------------------------------------------
# __mod__ dict-presence — absent from all four inspect types
# ---------------------------------------------------------------------------

table inspect_extra2671.mod_protocol:
  description: "__mod__ is absent from all inspect type __dict__s — none define modulo directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2671

  columns: [id, function, args, expected]
  rows:
    - ["in2671009",  "inspect.Parameter.__dict__.__contains__",       ["__mod__"], false]
    - ["in2671010",  "inspect.BoundArguments.__dict__.__contains__",  ["__mod__"], false]
    - ["in2671011",  "inspect.Signature.__dict__.__contains__",       ["__mod__"], false]
    - ["in2671012",  "inspect.FullArgSpec.__dict__.__contains__",     ["__mod__"], false]

# ---------------------------------------------------------------------------
# Combined per-type view — all four inspect types vs. all three protocols
# ---------------------------------------------------------------------------

table inspect_extra2671.signature_combined:
  description: "inspect.Parameter, inspect.Signature, inspect.BoundArguments, and inspect.FullArgSpec define none of __sub__, __floordiv__, __mod__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2671

  columns: [id, function, args, expected]
  rows:
    - ["in2671013", "inspect.Parameter.__dict__.__contains__",       ["__sub__"],      false]
    - ["in2671014", "inspect.Parameter.__dict__.__contains__",       ["__floordiv__"], false]
    - ["in2671015", "inspect.Parameter.__dict__.__contains__",       ["__mod__"],      false]
    - ["in2671016", "inspect.Signature.__dict__.__contains__",       ["__sub__"],      false]
    - ["in2671017", "inspect.Signature.__dict__.__contains__",       ["__floordiv__"], false]
    - ["in2671018", "inspect.Signature.__dict__.__contains__",       ["__mod__"],      false]
    - ["in2671019", "inspect.BoundArguments.__dict__.__contains__",  ["__sub__"],      false]
    - ["in2671020", "inspect.BoundArguments.__dict__.__contains__",  ["__floordiv__"], false]
    - ["in2671021", "inspect.BoundArguments.__dict__.__contains__",  ["__mod__"],      false]
    - ["in2671022", "inspect.FullArgSpec.__dict__.__contains__",     ["__sub__"],      false]
    - ["in2671023", "inspect.FullArgSpec.__dict__.__contains__",     ["__floordiv__"], false]
    - ["in2671024", "inspect.FullArgSpec.__dict__.__contains__",     ["__mod__"],      false]
