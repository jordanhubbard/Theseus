spec: io_extra159
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: the io class hierarchy — abstract base classes RawIOBase, BufferedIOBase, TextIOBase, IOBase and their __name__ and __module__ values; and the base classes of concrete classes FileIO and BufferedReader."
    - "io.RawIOBase.__module__ == 'io' and io.IOBase.__module__ == 'io'. The public Python ABC wrappers (IOBase, RawIOBase, BufferedIOBase, TextIOBase) are defined in Lib/io.py and have __module__ == 'io'. The private C ABCs (_IOBase, _RawIOBase, _BufferedIOBase, _TextIOBase) live in _io but are NOT accessible as io.RawIOBase etc."
    - "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — FileIO inherits directly from the private C type _RawIOBase (not the public Python wrapper RawIOBase). The public io.RawIOBase is a Python wrapper that itself wraps _RawIOBase."
    - "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — same pattern: BufferedReader inherits from the private C type _BufferedIOBase, not the public Python wrapper BufferedIOBase."
    - "This reveals a two-layer architecture: public ABC wrappers (io.IOBase, io.RawIOBase, etc.) wrap private C ABCs (_IOBase, _RawIOBase, etc.), and concrete classes (FileIO, BufferedReader) inherit from the private C ABCs directly."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io ABC class names and __module__ values
# RawIOBase.__name__ == 'RawIOBase' (len=10), __module__ == 'io'
# BufferedIOBase.__name__ == 'BufferedIOBase' (len=14), __module__ == 'io'
# TextIOBase.__name__ == 'TextIOBase' (len=10), __module__ == 'io'
# IOBase.__name__ == 'IOBase' (len=6), __module__ == 'io'
# All four public ABC wrappers have __module__ == 'io' (not '_io').
# ---------------------------------------------------------------------------

table io_extra159.abc_class_names:
  description: "io ABC __name__ values: IOBase, RawIOBase, BufferedIOBase, TextIOBase — all have __module__=='io' (not '_io'); these are public Python wrappers over private C ABCs"
  kind: python_call_eq
  category: identity
  id_prefix: iohier159

  columns: [id, function, args, expected, description]
  rows:
    - [rawio_name_eq,    RawIOBase.__name__.__eq__,       ["RawIOBase"],     true, "io.RawIOBase.__name__ == 'RawIOBase' (len=9; the abstract base class for raw binary I/O; raw I/O does not buffer — reads/writes go directly to the OS; FileIO is the primary concrete subclass of RawIOBase)"]
    - [rawio_module_eq,  RawIOBase.__module__.__eq__,     ["io"],            true, "io.RawIOBase.__module__ == 'io' (the public Python ABC wrapper is defined in Lib/io.py so its __module__ is 'io', not '_io'; contrast with FileIO which has __module__=='_io' because it is a C concrete class)"]
    - [bufio_name_eq,    BufferedIOBase.__name__.__eq__,  ["BufferedIOBase"],true, "io.BufferedIOBase.__name__ == 'BufferedIOBase' (len=14; the longest ABC name in io; abstract base for buffered binary I/O; concrete subclasses include BufferedReader, BufferedWriter, BufferedRandom, BufferedRWPair, BytesIO)"]
    - [textio_name_eq,   TextIOBase.__name__.__eq__,      ["TextIOBase"],    true, "io.TextIOBase.__name__ == 'TextIOBase' (len=10; the abstract base for text I/O streams; concrete subclasses are TextIOWrapper (wraps a binary stream) and StringIO (in-memory text); 1 char longer than RawIOBase (9))"]
    - [iobase_name_eq,   IOBase.__name__.__eq__,          ["IOBase"],        true, "io.IOBase.__name__ == 'IOBase' (len=6; the root abstract base class for all I/O streams; the shortest of the four ABC names; IOBase defines the core interface: readable/writable/seekable predicates, seek/tell, close, flush, readline/readlines/writelines)"]
    - [iobase_module_eq, IOBase.__module__.__eq__,        ["io"],            true, "io.IOBase.__module__ == 'io' (IOBase is the root of the io class hierarchy; as a public Python wrapper it has __module__=='io', same as all four public io ABCs; contrast with BytesIO whose __module__=='_io')"]

# ---------------------------------------------------------------------------
# io.FileIO and io.BufferedReader base classes
# FileIO.__bases__[0].__name__ == '_RawIOBase' (private C ABC, NOT 'RawIOBase')
# BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' (private C ABC)
# This reveals two layers: public ABC wrappers (io.RawIOBase) over private C
# ABCs (_RawIOBase), with concrete classes inheriting the private C ABCs.
# ---------------------------------------------------------------------------

table io_extra159.concrete_class_bases:
  description: "io.FileIO.__bases__[0].__name__=='_RawIOBase' (private C ABC); io.BufferedReader.__bases__[0].__name__=='_BufferedIOBase' (private C ABC) — concrete I/O classes inherit private C ABCs, not the public Python wrappers"
  kind: python_call_eq
  category: identity
  id_prefix: iohier159

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_base0_eq,   "FileIO.__bases__[0].__name__.__eq__",         ["_RawIOBase"],     true, "io.FileIO.__bases__[0].__name__ == '_RawIOBase' (FileIO inherits from the private C type _RawIOBase, not the public Python wrapper io.RawIOBase; io.RawIOBase itself wraps _RawIOBase; this two-layer architecture means FileIO's actual base is the underscore-prefixed private C ABC)"]
    - [fileio_not_rawio,  "FileIO.__bases__[0].__name__.__eq__",         ["RawIOBase"],      false,"io.FileIO.__bases__[0].__name__.__eq__('RawIOBase') == False (FileIO does NOT directly inherit from the public io.RawIOBase Python wrapper; it inherits from _RawIOBase (the private C ABC); the public wrapper io.RawIOBase is a separate class that wraps _RawIOBase)"]
    - [bufrd_base0_eq,    "BufferedReader.__bases__[0].__name__.__eq__", ["_BufferedIOBase"],true, "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' (BufferedReader inherits from the private C type _BufferedIOBase, not the public Python wrapper io.BufferedIOBase; this is the same two-layer pattern seen with FileIO and _RawIOBase)"]
    - [bufrd_not_bufio,   "BufferedReader.__bases__[0].__name__.__eq__", ["BufferedIOBase"], false,"io.BufferedReader.__bases__[0].__name__.__eq__('BufferedIOBase') == False (BufferedReader does NOT inherit from the public io.BufferedIOBase Python wrapper; like FileIO with _RawIOBase, it inherits from the private C ABC _BufferedIOBase)"]
    - [fileio_module_eq,  FileIO.__module__.__eq__,                       ["_io"],            true, "io.FileIO.__module__ == '_io' (FileIO is implemented in the _io C extension; its __module__ is '_io' unlike the public ABC wrappers (IOBase, RawIOBase, etc.) whose __module__ is 'io')"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra159.RawIOBase_module_is_io:
  description: "io.RawIOBase.__module__ == 'io' — the public Python wrapper RawIOBase has __module__ == 'io' (defined in Lib/io.py), NOT '_io'; this distinguishes the public ABC wrappers from concrete I/O classes like FileIO and BufferedReader which have __module__ == '_io'; IOBase, RawIOBase, BufferedIOBase, and TextIOBase all share __module__ == 'io' because they are pure-Python wrappers"
  category: identity
  kind: python_call_eq
  function: RawIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra159.IOBase_module_is_io:
  description: "io.IOBase.__module__ == 'io' — IOBase is the root ABC of the entire io hierarchy and has __module__ == 'io'; it is a Python wrapper over the private C type _IOBase; all four public io ABCs (IOBase, RawIOBase, BufferedIOBase, TextIOBase) share __module__ == 'io' while all concrete classes (FileIO, BytesIO, StringIO, BufferedReader, TextIOWrapper) have __module__ == '_io'"
  category: identity
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra159.FileIO_base_is_private_RawIOBase:
  description: "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — FileIO's direct base is the private C ABC _RawIOBase (with underscore prefix), NOT the public Python wrapper io.RawIOBase; the io module uses a two-layer architecture: public wrappers (io.RawIOBase) over private C types (_RawIOBase), with concrete classes (FileIO) inheriting the private C types directly; this is why FileIO is accessible as both io.FileIO and _io.FileIO"
  category: identity
  kind: python_call_eq
  function: "FileIO.__bases__[0].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

invariant io_extra159.BufferedReader_base_is_private_BufferedIOBase:
  description: "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — BufferedReader's direct base is the private C ABC _BufferedIOBase, NOT the public Python wrapper io.BufferedIOBase; same two-layer pattern as FileIO/_RawIOBase; BufferedReader is a concrete buffered reader for RawIOBase streams, wrapping a RawIOBase instance and providing buffering on top of it"
  category: identity
  kind: python_call_eq
  function: "BufferedReader.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra159.BufferedIOBase_name_eq:
  description: "io.BufferedIOBase.__name__ == 'BufferedIOBase' — the longest ABC name in the io module (14 characters: 'Buffered' (8) + 'IO' (2) + 'Base' (4) = 14); the abstract base for all buffered binary I/O classes; BufferedReader, BufferedWriter, BufferedRandom, BufferedRWPair, and BytesIO all satisfy the BufferedIOBase interface"
  category: identity
  kind: python_call_eq
  function: BufferedIOBase.__name__.__eq__
  args: ["BufferedIOBase"]
  expected: true

