spec: abbrev
version: ">=1.0.0"
backend: node(abbrev)

docs: https://github.com/npm/abbrev-js#readme

provenance:
  derived_from:
    - "abbrev README — https://github.com/npm/abbrev-js#readme"
    - "Test vectors verified with abbrev@2.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "abbrev source"
  notes:
    - "abbrev exports a single function that takes string arguments or an array."
    - "Returns an object mapping every unambiguous abbreviation to the full word."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns object. No errors for valid string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table abbrev.abbrev:
  kind: node_module_call_eq
  function: ~
  category: abbrev
  id_prefix: abbrev

  columns: [id, args, expected]
  rows:
    - [two,  [["foo", "bar"]],  {"b": "bar", "ba": "bar", "bar": "bar", "f": "foo", "fo": "foo", "foo": "foo"}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:24:27Z
  iterations: 1
  pass_count: 1
  fail_count: 0
  total_invariants: 1
  notes: Synthesis succeeded in 1 iteration(s). 1 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
