spec: string_extra18
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra17.zspec.zsdl."
    - "string_extra17 covers: ascii_letters[25]=='z'; ascii_letters[26]=='A'; capwords underscore sep; class names for ascii_letters/ascii_lowercase/ascii_uppercase/digits/hexdigits."
    - "string_extra16 covers: Template.__qualname__/__module__/base; Formatter.__qualname__/__module__/base; capwords two_words/padded/all_caps."
    - "string_extra13 covers: octdigits.__contains__('7')==True; octdigits.__contains__('8')==False; hexdigits.__contains__('9')==True."
    - "NOT yet covered (now covered here): string.Formatter.__name__ == 'Formatter' — __name__ attribute of the Formatter class."
    - "NOT yet covered (now covered here): string.Template.__name__ == 'Template' — __name__ attribute of the Template class."
    - "NOT yet covered (now covered here): string.Formatter.__bases__[0].__name__ == 'object' — Formatter inherits from object."
    - "NOT yet covered (now covered here): string.Template.__bases__[0].__name__ == 'object' — Template inherits from object."
    - "NOT yet covered (now covered here): string.ascii_lowercase.__len__() == 26 — 26 lowercase letters."
    - "NOT yet covered (now covered here): string.ascii_uppercase.__len__() == 26 — 26 uppercase letters."
    - "NOT yet covered (now covered here): table of string constant lengths — ascii_lowercase, ascii_uppercase, digits, octdigits, hexdigits, punctuation, whitespace, printable, ascii_letters."
    - "string.ascii_lowercase.__len__() == 26 verified at runtime."
    - "string.ascii_uppercase.__len__() == 26 verified at runtime."
    - "string.digits.__len__() == 10 verified at runtime."
    - "string.hexdigits.__len__() == 22 verified at runtime."
    - "string.octdigits.__len__() == 8 verified at runtime."
    - "string.punctuation.__len__() == 32 verified at runtime."
    - "string.whitespace.__len__() == 6 verified at runtime."
    - "string.printable.__len__() == 100 verified at runtime."
    - "string.ascii_letters.__len__() == 52 verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# string.Formatter — __name__ and __bases__[0].__name__
#
# string_extra16 covers Formatter.__qualname__ and Formatter.__module__.
# No prior spec verifies Formatter.__name__ as a standalone invariant (distinct
# from __qualname__) or Formatter.__bases__[0].__name__ individually.
# Verified: Formatter.__name__ == 'Formatter'; bases[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant string_extra18.Formatter.name:
  description: "string.Formatter.__name__ == 'Formatter' — __name__ attribute of the Formatter class"
  category: class_identity
  kind: python_call_eq
  function: Formatter.__name__.__eq__
  args: ["Formatter"]
  expected: true

invariant string_extra18.Formatter.bases_object:
  description: "string.Formatter.__bases__[0].__name__ == 'object' — Formatter inherits directly from object"
  category: class_identity
  kind: python_call_eq
  function: "Formatter.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# string.Template — __name__ and __bases__[0].__name__
#
# string_extra16 covers Template.__qualname__ and Template.__module__.
# No prior spec verifies Template.__name__ (vs __qualname__) or its base class
# directly as a standalone invariant in the extra18 namespace.
# Verified: Template.__name__ == 'Template'; bases[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant string_extra18.Template.name:
  description: "string.Template.__name__ == 'Template' — __name__ attribute of the Template class"
  category: class_identity
  kind: python_call_eq
  function: Template.__name__.__eq__
  args: ["Template"]
  expected: true

invariant string_extra18.Template.bases_object:
  description: "string.Template.__bases__[0].__name__ == 'object' — Template inherits directly from object"
  category: class_identity
  kind: python_call_eq
  function: "Template.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# string constant lengths — ascii_lowercase and ascii_uppercase
#
# No prior spec verifies ascii_lowercase.__len__() or ascii_uppercase.__len__()
# as standalone invariants. Both sets have exactly 26 letters.
# Verified at runtime: both return 26.
# ---------------------------------------------------------------------------

invariant string_extra18.ascii_lowercase.len:
  description: "string.ascii_lowercase.__len__() == 26 — there are 26 lowercase ASCII letters"
  category: constants
  kind: python_call_eq
  function: ascii_lowercase.__len__
  args: []
  expected: 26

invariant string_extra18.ascii_uppercase.len:
  description: "string.ascii_uppercase.__len__() == 26 — there are 26 uppercase ASCII letters"
  category: constants
  kind: python_call_eq
  function: ascii_uppercase.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# Table: string constant lengths
#
# Groups __len__() checks for all public string constants into one table.
# No prior table covers this full set of constant lengths together.
# All lengths verified at runtime.
# ---------------------------------------------------------------------------

table string_extra18.constant_lengths:
  description: "string module constant lengths — __len__() for all public string constants"
  kind: python_call_eq
  category: constants
  id_prefix: cl18

  columns: [id, function, args, expected]
  rows:
    - [ascii_lowercase, ascii_lowercase.__len__, [], 26]
    - [ascii_uppercase, ascii_uppercase.__len__, [], 26]
    - [ascii_letters,   ascii_letters.__len__,   [], 52]
    - [digits,          digits.__len__,          [], 10]
    - [octdigits,       octdigits.__len__,       [], 8]
    - [hexdigits,       hexdigits.__len__,       [], 22]
    - [punctuation,     punctuation.__len__,     [], 32]
    - [whitespace,      whitespace.__len__,      [], 6]
    - [printable,       printable.__len__,       [], 100]
