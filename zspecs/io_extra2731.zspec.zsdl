spec: io_extra2731
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
    - "io_extra.zspec.zsdl — covers existing io invariants"
    - "io_extra2701.zspec.zsdl — covers __lshift__/__rshift__/__invert__ dict-presence"
    - "io_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 629 (io_extra2731) theme: __trunc__, __floor__, and __ceil__ dict-presence checks."
    - "None of the io classes define __trunc__, __floor__, or __ceil__ in their own __dict__."
    - "__trunc__ supports math.trunc(); io stream classes are sequential I/O objects, not numeric types."
    - "__floor__ supports math.floor(); io stream classes do not implement floor-division numeric semantics."
    - "__ceil__ supports math.ceil(); io stream classes do not implement ceiling numeric semantics."
    - "Covers io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, and io.TextIOWrapper."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2731.no_trunc_in_io_classes:
  description: "__trunc__ is absent from all io class __dict__s — io stream classes do not implement the math.trunc() protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2731

  columns: [id, function, args, expected]
  rows:
    - ["io2731001", "io.IOBase.__dict__.__contains__",         ["__trunc__"], false]
    - ["io2731002", "io.RawIOBase.__dict__.__contains__",      ["__trunc__"], false]
    - ["io2731003", "io.BufferedIOBase.__dict__.__contains__", ["__trunc__"], false]
    - ["io2731004", "io.TextIOBase.__dict__.__contains__",     ["__trunc__"], false]
    - ["io2731005", "io.BytesIO.__dict__.__contains__",        ["__trunc__"], false]
    - ["io2731006", "io.StringIO.__dict__.__contains__",       ["__trunc__"], false]

# ---------------------------------------------------------------------------
# __floor__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2731.no_floor_in_io_classes:
  description: "__floor__ is absent from all io class __dict__s — io stream classes do not implement the math.floor() protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2731

  columns: [id, function, args, expected]
  rows:
    - ["io2731007", "io.IOBase.__dict__.__contains__",          ["__floor__"], false]
    - ["io2731008", "io.FileIO.__dict__.__contains__",          ["__floor__"], false]
    - ["io2731009", "io.BufferedReader.__dict__.__contains__",  ["__floor__"], false]
    - ["io2731010", "io.BufferedWriter.__dict__.__contains__",  ["__floor__"], false]
    - ["io2731011", "io.BufferedRandom.__dict__.__contains__",  ["__floor__"], false]
    - ["io2731012", "io.TextIOWrapper.__dict__.__contains__",   ["__floor__"], false]

# ---------------------------------------------------------------------------
# __ceil__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2731.no_ceil_in_io_classes:
  description: "__ceil__ is absent from all io class __dict__s — io stream classes do not implement the math.ceil() protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2731

  columns: [id, function, args, expected]
  rows:
    - ["io2731013", "io.IOBase.__dict__.__contains__",         ["__ceil__"], false]
    - ["io2731014", "io.BytesIO.__dict__.__contains__",        ["__ceil__"], false]
    - ["io2731015", "io.StringIO.__dict__.__contains__",       ["__ceil__"], false]
    - ["io2731016", "io.FileIO.__dict__.__contains__",         ["__ceil__"], false]
    - ["io2731017", "io.BufferedReader.__dict__.__contains__", ["__ceil__"], false]
    - ["io2731018", "io.BufferedWriter.__dict__.__contains__", ["__ceil__"], false]

# ---------------------------------------------------------------------------
# Complementary: io stream classes have I/O methods but not rounding numeric hooks
# Confirms that io classes are sequential I/O objects, not numeric types
# ---------------------------------------------------------------------------

table io_extra2731.io_has_stream_methods_not_rounding_numeric_hooks:
  description: "io.BytesIO defines read/write/seek/tell but NOT __trunc__/__floor__/__ceil__; io.StringIO similarly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2731

  columns: [id, function, args, expected]
  rows:
    - ["io2731019", "io.BytesIO.__dict__.__contains__",  ["read"],      true]
    - ["io2731020", "io.BytesIO.__dict__.__contains__",  ["write"],     true]
    - ["io2731021", "io.BytesIO.__dict__.__contains__",  ["seek"],      true]
    - ["io2731022", "io.BytesIO.__dict__.__contains__",  ["tell"],      true]
    - ["io2731023", "io.BytesIO.__dict__.__contains__",  ["__trunc__"], false]
    - ["io2731024", "io.BytesIO.__dict__.__contains__",  ["__floor__"], false]
    - ["io2731025", "io.BytesIO.__dict__.__contains__",  ["__ceil__"],  false]
    - ["io2731026", "io.StringIO.__dict__.__contains__", ["read"],      true]
    - ["io2731027", "io.StringIO.__dict__.__contains__", ["write"],     true]
    - ["io2731028", "io.StringIO.__dict__.__contains__", ["seek"],      true]
    - ["io2731029", "io.StringIO.__dict__.__contains__", ["tell"],      true]
    - ["io2731030", "io.StringIO.__dict__.__contains__", ["__trunc__"], false]
    - ["io2731031", "io.StringIO.__dict__.__contains__", ["__floor__"], false]
    - ["io2731032", "io.StringIO.__dict__.__contains__", ["__ceil__"],  false]
