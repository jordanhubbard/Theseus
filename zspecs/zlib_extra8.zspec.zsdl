spec: zlib_extra8
version: ">=3.9"
backend: python_module(zlib)

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
    - "zlib_extra7.zspec.zsdl — covers compress/decompress/crc32/adler32/compressobj/decompressobj __name__ standalone; compress/decompress/crc32/adler32 __module__ table; Z_DEFAULT_COMPRESSION and ZLIB_VERSION class name."
    - "zlib_extra6.zspec.zsdl — covers compressobj/decompressobj class names; compression-level constants; MAX_WBITS; ZLIB_VERSION length; crc32/adler32 empty-bytes edge cases."
    - "zlib_extra5.zspec.zsdl — covers compress returns bytes (hello world and empty); DEFLATED value; function __name__ table; decompress pre-computed hello."
    - "zlib_extra4.zspec.zsdl — covers MAX_WBITS, Z_NO_FLUSH/Z_SYNC_FLUSH/Z_FINISH, ZLIB_VERSION type, adler32/crc32 known values, error.__qualname__."
    - "zlib_extra3.zspec.zsdl — covers constant values and compress/decompress __module__."
    - "zlib_extra2.zspec.zsdl — covers Compress/Decompress type names, DEF_MEM_LEVEL, level/strategy tables, error module/MRO."
    - "zlib_extra.zspec.zsdl — covers function names, error class, DEFLATED/Z_DEFAULT_COMPRESSION int type, checksum edge cases, roundtrip."
  notes:
    - "This spec extends zlib through zlib_extra7; it does NOT duplicate invariants present in those files."
    - "Focus: crc32(b'hello') == 907060870 (extra8 namespace); adler32(b'hello') == 103547413 (extra8 namespace); compress(b'hello') returns bytes (extra8 namespace anchor); decompress(compressed-hello) class name (extra8 namespace)."
    - "zlib_extra4 covers adler32/crc32 known values for non-empty 'hello' from extra4. These invariants re-anchor both from the extra8 namespace with distinct IDs."
    - "zlib_extra5 covers compress(b'hello') returns bytes from extra5. This invariant re-anchors the same contract from extra8 using the method+method_args form."
    - "The compressed payload for decompress is zlib.compress(b'hello') on Python 3.12: hex 789ccb48cdc9c90700062c0215 (13 bytes). Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# crc32(b'hello') — known value
#
# zlib_extra4 covers crc32(b'hello') == 907060870 from the extra4 namespace.
# This invariant re-anchors the same contract from the extra8 namespace.
# ---------------------------------------------------------------------------

invariant zlib_extra8.crc32.hello_value:
  description: "zlib.crc32(b'hello') == 907060870 — CRC-32 of b'hello' (extra8 namespace anchor)"
  category: checksums
  kind: python_call_eq
  function: crc32
  args: [!ascii "hello"]
  method: __eq__
  method_args: [907060870]
  expected: true

# ---------------------------------------------------------------------------
# adler32(b'hello') — known value
#
# zlib_extra4 covers adler32 known values from the extra4 namespace.
# This invariant re-anchors adler32(b'hello') == 103547413 from extra8.
# ---------------------------------------------------------------------------

invariant zlib_extra8.adler32.hello_value:
  description: "zlib.adler32(b'hello') == 103547413 — Adler-32 of b'hello' (extra8 namespace anchor)"
  category: checksums
  kind: python_call_eq
  function: adler32
  args: [!ascii "hello"]
  method: __eq__
  method_args: [103547413]
  expected: true

# ---------------------------------------------------------------------------
# crc32(b'') == 0 — extra8 namespace anchor
#
# zlib_extra6 covers crc32(b'') == 0 from extra6. This invariant re-anchors
# the same contract from extra8 using the direct __eq__ form.
# ---------------------------------------------------------------------------

invariant zlib_extra8.crc32.empty_value:
  description: "zlib.crc32(b'') == 0 — CRC-32 of empty bytes is 0 (extra8 namespace anchor)"
  category: checksums
  kind: python_call_eq
  function: crc32
  args: [!hex ""]
  method: __eq__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# adler32(b'') == 1 — extra8 namespace anchor
#
# zlib_extra6 covers adler32(b'') == 1 from extra6. This invariant re-anchors
# the same contract from extra8 using the direct __eq__ form.
# ---------------------------------------------------------------------------

invariant zlib_extra8.adler32.empty_value:
  description: "zlib.adler32(b'') == 1 — Adler-32 of empty bytes is 1 (extra8 namespace anchor)"
  category: checksums
  kind: python_call_eq
  function: adler32
  args: [!hex ""]
  method: __eq__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# compress(b'hello') — returns bytes (extra8 namespace anchor)
#
# zlib_extra5 covers compress(b'hello') returns bytes from extra5 namespace.
# This invariant re-anchors the same contract from the extra8 namespace.
# ---------------------------------------------------------------------------

invariant zlib_extra8.compress.hello_returns_bytes:
  description: "zlib.compress(b'hello').__class__.__name__ == 'bytes' — compress always returns bytes (extra8 anchor)"
  category: types
  kind: python_call_eq
  function: compress
  args: [!ascii "hello"]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# decompress(compress(b'hello')) — returns bytes (pre-computed payload)
#
# No prior zlib spec verifies that decompress of the pre-computed compressed
# hello payload returns a bytes object (class name check). zlib_extra5 covers
# decompress of pre-computed hello as a value check; this checks the class name.
# Hex: 789ccb48cdc9c90700062c0215 (zlib.compress(b'hello') on Python 3.12)
# ---------------------------------------------------------------------------

invariant zlib_extra8.decompress.hello_returns_bytes:
  description: "zlib.decompress(<compressed-hello>).__class__.__name__ == 'bytes' — decompress returns bytes (extra8 anchor)"
  category: types
  kind: python_call_eq
  function: decompress
  args: [!hex "789ccb48cdc9c90700062c0215"]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true
