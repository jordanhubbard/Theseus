spec: pathlib_extra97
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra96

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra96."
    - "Prior specs covered: PurePath/Path class identity; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes; PurePath/__dict__ membership; Path/__dict__ membership; Path properties as descriptors; Path method co_name and co_argcount; PurePath/__name__/__module__/__bases__/__mro__; PosixPath identity; Path/__init__/__new__ co_name and co_argcount; Path.is_dir/is_file/is_symlink/etc __code__ attributes; Path/__dict__.__contains__; Path/__qualname__/__name__/__module__; Path method __qualname__ string equality; Path method __qualname__ string lengths; pathlib_extra93 covered exists/stat/open/read_text/write_text/read_bytes/write_bytes/mkdir/rmdir/unlink/rename/replace."
    - "This spec covers: pathlib.Path and pathlib.PurePath __dict__ membership for methods and properties not yet covered."
    - "In Python 3.12+, Path's public non-underscore methods are defined directly on Path (not PurePath). PurePath holds the pure path manipulation methods (name, parent, stem, suffix, etc.)."
    - "pathlib.Path.__dict__.__contains__('absolute') == True — absolute is defined on Path (Python 3.11+ method)."
    - "pathlib.Path.__dict__.__contains__('resolve') == True — resolve is defined on Path."
    - "pathlib.Path.__dict__.__contains__('symlink_to') == True — symlink_to is defined on Path."
    - "pathlib.Path.__dict__.__contains__('hardlink_to') == True — hardlink_to is defined on Path (Python 3.10+)."
    - "pathlib.Path.__dict__.__contains__('touch') == True — touch is defined on Path."
    - "pathlib.Path.__dict__.__contains__('iterdir') == True — iterdir is defined on Path."
    - "pathlib.Path.__dict__.__contains__('is_file') == True — is_file is defined on Path."
    - "pathlib.Path.__dict__.__contains__('is_dir') == True — is_dir is defined on Path."
    - "pathlib.Path.__dict__.__contains__('is_symlink') == True — is_symlink is defined on Path."
    - "pathlib.Path.__dict__.__contains__('is_absolute') == False — is_absolute is defined on PurePath, not Path."
    - "pathlib.PurePath.__dict__.__contains__('parent') == True — parent property is defined on PurePath."
    - "pathlib.PurePath.__dict__.__contains__('name') == True — name property is defined on PurePath."
    - "pathlib.Path.__dict__.__contains__('parent') == False — parent is NOT redefined on Path; it is inherited from PurePath."
    - "pathlib.Path.__dict__.__contains__('name') == False — name is NOT redefined on Path; it is inherited from PurePath."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ membership: navigation/resolution methods
# absolute, resolve are defined on Path; is_absolute is defined on PurePath.
# ---------------------------------------------------------------------------

table pathlib_extra97.Path_dict_navigation_methods:
  description: "pathlib.Path.__dict__.__contains__ for navigation/resolution methods"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibdictextra97

  columns: [id, function, args, expected]
  rows:
    - [path_absolute,      Path.__dict__.__contains__, ["absolute"],    true]
    - [path_resolve,       Path.__dict__.__contains__, ["resolve"],     true]
    - [path_is_file,       Path.__dict__.__contains__, ["is_file"],     true]
    - [path_is_dir,        Path.__dict__.__contains__, ["is_dir"],      true]
    - [path_is_symlink,    Path.__dict__.__contains__, ["is_symlink"],  true]
    - [path_no_is_abs,     Path.__dict__.__contains__, ["is_absolute"], false]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ membership: creation/link methods
# symlink_to, hardlink_to, touch, iterdir are all defined on Path.
# ---------------------------------------------------------------------------

table pathlib_extra97.Path_dict_creation_link_methods:
  description: "pathlib.Path.__dict__.__contains__ for creation/link/iteration methods (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibdictextra97

  columns: [id, function, args, expected]
  rows:
    - [path_symlink_to,  Path.__dict__.__contains__, ["symlink_to"],  true]
    - [path_hardlink_to, Path.__dict__.__contains__, ["hardlink_to"], true]
    - [path_touch,       Path.__dict__.__contains__, ["touch"],       true]
    - [path_iterdir,     Path.__dict__.__contains__, ["iterdir"],     true]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__ membership: is_absolute and properties
# is_absolute is defined on PurePath; parent and name are PurePath properties.
# ---------------------------------------------------------------------------

table pathlib_extra97.PurePath_dict_is_absolute_and_props:
  description: "pathlib.PurePath.__dict__.__contains__ for is_absolute, parent, name (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibdictextra97

  columns: [id, function, args, expected]
  rows:
    - [purepath_is_absolute, PurePath.__dict__.__contains__, ["is_absolute"], true]
    - [purepath_parent,      PurePath.__dict__.__contains__, ["parent"],      true]
    - [purepath_name,        PurePath.__dict__.__contains__, ["name"],        true]
    - [purepath_stem,        PurePath.__dict__.__contains__, ["stem"],        true]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ does NOT have parent/name (inherited from PurePath)
# Cross-checks: Path.__dict__ missing PurePath-defined items.
# ---------------------------------------------------------------------------

table pathlib_extra97.Path_dict_purepath_props_absent:
  description: "pathlib.Path.__dict__.__contains__ for PurePath-owned properties (all False)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibdictextra97

  columns: [id, function, args, expected]
  rows:
    - [path_no_parent,  Path.__dict__.__contains__, ["parent"],  false]
    - [path_no_name,    Path.__dict__.__contains__, ["name"],    false]
    - [path_no_stem,    Path.__dict__.__contains__, ["stem"],    false]
    - [path_no_suffix,  Path.__dict__.__contains__, ["suffix"],  false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra97.Path_dict.contains_absolute:
  description: "pathlib.Path.__dict__.__contains__('absolute') == True (absolute is defined on Path; added in Python 3.11)"
  category: dict_membership
  kind: python_call_eq
  function: Path.__dict__.__contains__
  args: ["absolute"]
  expected: true

invariant pathlib_extra97.Path_dict.contains_symlink_to:
  description: "pathlib.Path.__dict__.__contains__('symlink_to') == True (symlink_to is defined on Path)"
  category: dict_membership
  kind: python_call_eq
  function: Path.__dict__.__contains__
  args: ["symlink_to"]
  expected: true

invariant pathlib_extra97.Path_dict.no_is_absolute:
  description: "pathlib.Path.__dict__.__contains__('is_absolute') == False (is_absolute is defined on PurePath, not Path)"
  category: dict_membership
  kind: python_call_eq
  function: Path.__dict__.__contains__
  args: ["is_absolute"]
  expected: false

invariant pathlib_extra97.PurePath_dict.contains_parent:
  description: "pathlib.PurePath.__dict__.__contains__('parent') == True (parent property is defined on PurePath)"
  category: dict_membership
  kind: python_call_eq
  function: PurePath.__dict__.__contains__
  args: ["parent"]
  expected: true

invariant pathlib_extra97.Path_dict.no_parent:
  description: "pathlib.Path.__dict__.__contains__('parent') == False (parent is inherited from PurePath, not redefined on Path)"
  category: dict_membership
  kind: python_call_eq
  function: Path.__dict__.__contains__
  args: ["parent"]
  expected: false
