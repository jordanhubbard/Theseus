spec: asyncio_extra1351
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio: Asynchronous I/O"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Wave 537 (_extra1351): focuses on __slots__ and __weakref__ attribute checks at the class __dict__ level."
    - "asyncio.Queue, Task, Future, Lock, Semaphore, Event, Condition are all pure-Python classes with no __slots__."
    - "None of asyncio's synchronization primitives define __slots__ in their own __dict__."
    - "None of asyncio's core classes define __weakref__ directly (inherited from object hierarchy)."
    - "asyncio.StreamReader and asyncio.StreamWriter are regular classes; they expose __weakref__ and __dict__ in their own __dict__."
    - "Queue.__dict__.__contains__('__slots__') is False — Queue uses instance __dict__ via normal class machinery."
    - "StreamReader and StreamWriter are top-level classes in their own hierarchy, hence __weakref__ and __dict__ appear."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table asyncio_extra1351.Queue_slots_weakref_dict:
  description: "asyncio.Queue __slots__, __weakref__, and __dict__ membership in class __dict__: Queue defines none of these"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: as1351qu
  columns: [id, function, args, expected]
  rows:
    - [as1351qu001, asyncio.Queue.__dict__.__contains__, ["__slots__"],    false]
    - [as1351qu002, asyncio.Queue.__dict__.__contains__, ["__weakref__"],  false]
    - [as1351qu003, asyncio.Queue.__dict__.__contains__, ["__dict__"],     false]
    - [as1351qu004, asyncio.Task.__dict__.__contains__,  ["__slots__"],    false]
    - [as1351qu005, asyncio.Task.__dict__.__contains__,  ["__weakref__"],  false]
    - [as1351qu006, asyncio.Task.__dict__.__contains__,  ["__dict__"],     false]

table asyncio_extra1351.Future_Lock_slots_weakref_dict:
  description: "asyncio.Future and asyncio.Lock __slots__, __weakref__, and __dict__ checks: neither defines these in its own __dict__"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: as1351fl
  columns: [id, function, args, expected]
  rows:
    - [as1351fl001, asyncio.Future.__dict__.__contains__, ["__slots__"],   false]
    - [as1351fl002, asyncio.Future.__dict__.__contains__, ["__weakref__"], false]
    - [as1351fl003, asyncio.Future.__dict__.__contains__, ["__dict__"],    false]
    - [as1351fl004, asyncio.Lock.__dict__.__contains__,   ["__slots__"],   false]
    - [as1351fl005, asyncio.Lock.__dict__.__contains__,   ["__weakref__"], false]
    - [as1351fl006, asyncio.Lock.__dict__.__contains__,   ["__dict__"],    false]

table asyncio_extra1351.StreamReader_StreamWriter_slots_weakref_dict:
  description: "asyncio.StreamReader and StreamWriter define __weakref__ and __dict__ in their own class __dict__ (top-level classes)"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: as1351sr
  columns: [id, function, args, expected]
  rows:
    - [as1351sr001, asyncio.StreamReader.__dict__.__contains__, ["__slots__"],   false]
    - [as1351sr002, asyncio.StreamReader.__dict__.__contains__, ["__weakref__"], true]
    - [as1351sr003, asyncio.StreamReader.__dict__.__contains__, ["__dict__"],    true]
    - [as1351sr004, asyncio.StreamWriter.__dict__.__contains__, ["__slots__"],   false]
    - [as1351sr005, asyncio.StreamWriter.__dict__.__contains__, ["__weakref__"], true]
    - [as1351sr006, asyncio.StreamWriter.__dict__.__contains__, ["__dict__"],    true]
