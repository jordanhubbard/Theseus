spec: itertools_extra124
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra123.zspec.zsdl."
    - "This spec covers: itertools.chain class slot qualnames and identity — chain.__iter__ and __next__ qualnames (both 'chain.__iter__'/'chain.__next__', len=14), chain.__new__ qualname ('chain.__new__', len=13), chain.from_iterable qualname ('chain.from_iterable', len=19); chain class identity; wave 275."
    - "itertools.chain.__iter__.__qualname__ == 'chain.__iter__' (len 14). Verified with Python 3.14.3."
    - "itertools.chain.__next__.__qualname__ == 'chain.__next__' (len 14). Verified with Python 3.14.3."
    - "itertools.chain.__new__.__qualname__ == 'chain.__new__' (len 13). Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' (len 19). Verified with Python 3.14.3."
    - "itertools.chain.__iter__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.chain.__next__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.chain.__new__.__class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "itertools.chain.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.chain.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.chain.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "len(itertools.chain.__mro__) == 2 — MRO is [chain, object]. Verified with Python 3.14.3."
    - "chain(5) + dot(1) + __iter__(8) = 14; chain(5) + dot(1) + __next__(8) = 14; both 8-char slot names give equal qualname length."
    - "chain(5) + dot(1) + __new__(7) = 13; one less than __iter__/__next__ because '__new__' is 7 chars."
    - "chain(5) + dot(1) + from_iterable(13) = 19; 'from_iterable' is 13 chars."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain.__iter__ and __next__ slot qualnames
#
# Wave 275 theme: itertools.chain is a C-extension type defined in
# Modules/itertoolsmodule.c. It exposes two iterator protocol slots:
# __iter__ (tp_iter) and __next__ (tp_iternext), both as wrapper_descriptor
# objects. Their qualnames follow the pattern <classname>.<slotname>:
#   chain(5) + dot(1) + __iter__(8) = 14
#   chain(5) + dot(1) + __next__(8) = 14
# Both qualnames have length 14 because '__iter__' and '__next__' each have
# 8 chars and 'chain' has 5. Compare: zip_longest slots are length 20 (extra123).
#
# chain.__iter__.__qualname__ == 'chain.__iter__'  (len 14)
# chain.__next__.__qualname__ == 'chain.__next__'  (len 14)
#
# New to extra124.
# ---------------------------------------------------------------------------

table itertools_extra124.chain_iter_next_qualname:
  description: "itertools.chain slot qualnames: __iter__='chain.__iter__'(14), __next__='chain.__next__'(14); both 5+1+8=14; both wrapper_descriptor; shorter than zip_longest (20, extra123) because 'chain'(5) vs 'zip_longest'(11); wave 275; new to extra124"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolschniq124

  columns: [id, function, args, expected, description]
  rows:
    - [chain_iter_qualname_eq,
       "chain.__iter__.__qualname__.__eq__",
       ["chain.__iter__"],
       true,
       "itertools.chain.__iter__.__qualname__.__eq__('chain.__iter__') == True — chain exposes its tp_iter slot as __iter__; qualname is 'chain.__iter__' (14 chars = 5+1+8); str.__eq__('chain.__iter__') returns True; new to extra124"]
    - [chain_iter_qualname_len,
       "chain.__iter__.__qualname__.__len__",
       [],
       14,
       "itertools.chain.__iter__.__qualname__.__len__() == 14 — 'chain.__iter__' = chain(5)+dot(1)+__iter__(8)=14; shorter than zip_longest.__iter__ qualname (20, extra123) by 6 because 'chain' is 6 chars shorter than 'zip_longest'; str.__len__() returns 14; new to extra124"]
    - [chain_next_qualname_eq,
       "chain.__next__.__qualname__.__eq__",
       ["chain.__next__"],
       true,
       "itertools.chain.__next__.__qualname__.__eq__('chain.__next__') == True — chain exposes its tp_iternext slot as __next__; qualname is 'chain.__next__' (14 chars = 5+1+8); str.__eq__('chain.__next__') returns True; new to extra124"]
    - [chain_next_qualname_len,
       "chain.__next__.__qualname__.__len__",
       [],
       14,
       "itertools.chain.__next__.__qualname__.__len__() == 14 — 'chain.__next__' = chain(5)+dot(1)+__next__(8)=14; equal to chain.__iter__ qualname length because both '__next__' and '__iter__' are 8-char slot names; str.__len__() returns 14; new to extra124"]
    - [chain_iter_class_name_eq,
       "chain.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.chain.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — tp_iter slot on chain is a wrapper_descriptor when accessed on the type; consistent with all itertools C-iterator __iter__ slots; str.__eq__('wrapper_descriptor') returns True; new to extra124"]
    - [chain_next_class_name_eq,
       "chain.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.chain.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — tp_iternext slot on chain is a wrapper_descriptor; consistent with all itertools C-iterator __next__ slots; str.__eq__('wrapper_descriptor') returns True; new to extra124"]

# ---------------------------------------------------------------------------
# Table 2: itertools.chain.__new__ and from_iterable slot qualnames
#
# Wave 275 theme: chain.__new__.__qualname__ == 'chain.__new__' (len 13):
# chain(5) + dot(1) + __new__(7) = 13. One less than __iter__/__next__ (14)
# because '__new__' has 7 chars vs 8. chain.from_iterable is a C-level
# classmethod alternative constructor. Its qualname is 'chain.from_iterable'
# (len 19): chain(5) + dot(1) + from_iterable(13) = 19.
# Both __new__ and from_iterable are builtin_function_or_method objects.
#
# chain.__new__.__qualname__           == 'chain.__new__'        (len 13)
# chain.from_iterable.__qualname__     == 'chain.from_iterable'  (len 19)
#
# New to extra124.
# ---------------------------------------------------------------------------

table itertools_extra124.chain_new_from_iterable_qualname:
  description: "itertools.chain.__new__ qualname: 'chain.__new__'(13); 5+1+7=13, one less than __iter__/__next__ (14); from_iterable qualname: 'chain.from_iterable'(19); 5+1+13=19; both builtin_function_or_method; wave 275; new to extra124"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolschnnfq124

  columns: [id, function, args, expected, description]
  rows:
    - [chain_new_qualname_eq,
       "chain.__new__.__qualname__.__eq__",
       ["chain.__new__"],
       true,
       "itertools.chain.__new__.__qualname__.__eq__('chain.__new__') == True — chain exposes its tp_new slot as __new__; qualname is 'chain.__new__' (13 chars = 5+1+7); str.__eq__('chain.__new__') returns True; new to extra124"]
    - [chain_new_qualname_len,
       "chain.__new__.__qualname__.__len__",
       [],
       13,
       "itertools.chain.__new__.__qualname__.__len__() == 13 — 'chain.__new__' = chain(5)+dot(1)+__new__(7)=13; one less than chain.__iter__/__next__ (both 14) because '__new__' is 7 chars vs 8; str.__len__() returns 13; new to extra124"]
    - [chain_new_class_name_eq,
       "chain.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.chain.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — chain.__new__ is exposed as a builtin_function_or_method; str.__eq__('builtin_function_or_method') returns True; new to extra124"]
    - [chain_from_iterable_qualname_eq,
       "chain.from_iterable.__qualname__.__eq__",
       ["chain.from_iterable"],
       true,
       "itertools.chain.from_iterable.__qualname__.__eq__('chain.from_iterable') == True — from_iterable is the C-level classmethod alternative constructor on chain; qualname is 'chain.from_iterable' (19 chars = 5+1+13); str.__eq__('chain.from_iterable') returns True; new to extra124"]
    - [chain_from_iterable_qualname_len,
       "chain.from_iterable.__qualname__.__len__",
       [],
       19,
       "itertools.chain.from_iterable.__qualname__.__len__() == 19 — 'chain.from_iterable' = chain(5)+dot(1)+from_iterable(13)=19; the longest qualname among chain slots because 'from_iterable' has 13 chars; str.__len__() returns 19; new to extra124"]
    - [chain_from_iterable_class_name_eq,
       "chain.from_iterable.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.chain.from_iterable.__class__.__name__.__eq__('builtin_function_or_method') == True — from_iterable is a C-level builtin_function_or_method; str.__eq__('builtin_function_or_method') returns True; new to extra124"]

# ---------------------------------------------------------------------------
# Table 3: itertools.chain class identity (__class__.__name__, __bases__, __mro__ len)
#
# Wave 275 theme: itertools.chain class type identity.
#
# chain.__class__.__name__ == 'type'
# chain.__module__ == 'itertools'
# chain.__bases__[0].__name__ == 'object'
# len(chain.__mro__) == 2
# chain.__name__ == 'chain'  (len 5)
# chain.__qualname__ == 'chain'  (len 5)
#
# chain is a C extension type whose metaclass is 'type'. It inherits directly
# from object (no intermediate bases). MRO is [chain, object] (length 2).
# New to extra124.
# ---------------------------------------------------------------------------

table itertools_extra124.chain_class_identity:
  description: "itertools.chain class identity: __class__.__name__=='type', __module__=='itertools', __bases__[0]=='object', MRO len==2; C extension type; wave 275; new to extra124"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolschncid124

  columns: [id, function, args, expected, description]
  rows:
    - [chain_class_name_eq_type,
       "chain.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.chain.__class__.__name__.__eq__('type') == True — itertools.chain is a C extension type defined in Modules/itertoolsmodule.c; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra124"]
    - [chain_bases_first_eq_object,
       "chain.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.chain.__bases__[0].__name__.__eq__('object') == True — chain inherits directly from object with no intermediate C base; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra124"]
    - [chain_mro_len_eq_2,
       "chain.__mro__.__len__",
       [],
       2,
       "itertools.chain.__mro__.__len__() == 2 — MRO of chain is [chain, object]; as a C extension type inheriting directly from object it has exactly 2 MRO entries; tuple.__len__() returns 2; new to extra124"]
    - [chain_name_len_eq_5,
       "chain.__name__.__len__",
       [],
       5,
       "itertools.chain.__name__.__len__() == 5 — 'chain' has 5 chars: c-h-a-i-n; the chain class name; this drives the slot qualname formula (chain(5) + dot(1) + slotname); str.__len__() returns 5; new to extra124"]
    - [chain_qualname_eq_chain,
       "chain.__qualname__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__qualname__.__eq__('chain') == True — chain is defined at module scope in the C extension; its __qualname__ is the simple class name 'chain'; str.__eq__('chain') returns True; new to extra124"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra124
# ---------------------------------------------------------------------------

invariant itertools_extra124.chain_iter_qualname:
  description: "itertools.chain.__iter__.__qualname__ == 'chain.__iter__' — tp_iter slot; len=14; 5+1+8=14; wrapper_descriptor; wave 275; new to extra124"
  kind: python_call_eq
  function: chain.__iter__.__qualname__.__eq__
  args: ["chain.__iter__"]
  expected: true

invariant itertools_extra124.chain_next_qualname:
  description: "itertools.chain.__next__.__qualname__ == 'chain.__next__' — tp_iternext slot; len=14; equal to __iter__ qualname length; both wrapper_descriptor; wave 275; new to extra124"
  kind: python_call_eq
  function: chain.__next__.__qualname__.__eq__
  args: ["chain.__next__"]
  expected: true

invariant itertools_extra124.chain_new_qualname_len:
  description: "itertools.chain.__new__.__qualname__.__len__() == 13 — 'chain.__new__' = 5+1+7=13; one less than __iter__/__next__ (14); wave 275; new to extra124"
  kind: python_call_eq
  function: chain.__new__.__qualname__.__len__
  args: []
  expected: 13

invariant itertools_extra124.chain_from_iterable_qualname:
  description: "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — C-level classmethod alternative constructor; len=19; 5+1+13=19; wave 275; new to extra124"
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__eq__
  args: ["chain.from_iterable"]
  expected: true

invariant itertools_extra124.chain_mro_len:
  description: "len(itertools.chain.__mro__) == 2 — MRO is [chain, object]; C extension type inheriting directly from object; wave 275; new to extra124"
  kind: python_call_eq
  function: chain.__mro__.__len__
  args: []
  expected: 2
