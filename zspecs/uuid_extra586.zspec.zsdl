spec: uuid_extra586
version: ">=3.9"
backend: python_module(uuid)
docs: "https://docs.python.org/3/library/uuid.html"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module constants and SafeUUID enum"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers namespace constants, SafeUUID enum identity, UUID.__doc__, and uuid function module identity"
  created_at: "2026-04-12T00:00:00Z"

table uuid_extra586.namespace_constants:
  description: "uuid namespace constants are UUID instances"
  columns: [id, function, args, expected]
  rows:
    - [uu586md01, uuid.NAMESPACE_DNS.__class__.__name__.__eq__, ["UUID"], true]
    - [uu586md02, uuid.NAMESPACE_URL.__class__.__name__.__eq__, ["UUID"], true]
    - [uu586md03, uuid.NAMESPACE_OID.__class__.__name__.__eq__, ["UUID"], true]
    - [uu586md04, uuid.NAMESPACE_X500.__class__.__name__.__eq__, ["UUID"], true]

table uuid_extra586.safeuuid_identity:
  description: "SafeUUID enum type and qualname identity"
  columns: [id, function, args, expected]
  rows:
    - [uu586qn01, uuid.SafeUUID.__class__.__name__.__eq__, ["EnumType"], true]
    - [uu586qn02, uuid.SafeUUID.__qualname__.__eq__, ["SafeUUID"], true]
    - [uu586qn03, uuid.SafeUUID.__module__.__eq__, ["uuid"], true]

table uuid_extra586.uuid_class_and_functions:
  description: "UUID class doc is a str, and uuid function module identity"
  columns: [id, function, args, expected]
  rows:
    - [uu586qn04, uuid.UUID.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu586qn05, uuid.uuid1.__module__.__eq__, ["uuid"], true]
    - [uu586qn06, uuid.uuid3.__module__.__eq__, ["uuid"], true]
    - [uu586qn07, uuid.uuid4.__module__.__eq__, ["uuid"], true]
    - [uu586qn08, uuid.uuid5.__module__.__eq__, ["uuid"], true]
