spec: re_extra7
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub, findall, split, escape vectors, compile error cases"
    - "re_extra.zspec.zsdl — covers Pattern/Match class name via instance, flag integer values, match/search/sub/split/findall variants, error.__name__, error base"
    - "re_extra2.zspec.zsdl — covers RegexFlag class name, flag class membership, compile pattern/flags, fullmatch/purge/escape __name__"
    - "re_extra3.zspec.zsdl — covers Pattern.__name__, Match.__name__ (type objects), error.__name__ (PatternError), error base, DOTALL/MULTILINE class names, fullmatch returns Match"
    - "re_extra4.zspec.zsdl — covers Match/Pattern type_name anchors, compile.__module__, all function __name__ checks, function __module__ table, subn, finditer class name"
    - "re_extra5.zspec.zsdl — covers compile flags type, match groups/groupdict, search start/end, findall three singles, split whitespace, subn result/count, escape dot, fullmatch match class"
    - "re_extra6.zspec.zsdl — covers purge/escape/error/Pattern/Match __module__, Pattern base is object, error base, function_modules table, RegexFlag.__module__, VERBOSE/ASCII values, compile.__name__"
  notes:
    - "This spec extends all prior re specs and does NOT duplicate invariants present in those files."
    - "re.compile('.').pattern == '.' — dot pattern stored as-given (re_extra2 covers 'a|b', re_patterns covers '\\d+'; '.' is new)."
    - "re.compile('.', re.IGNORECASE).flags is an int subclass (RegexFlag); its __class__.__name__ == 'RegexFlag', NOT 'int' (re_extra2 covers RegexFlag; this spec skips re-asserting that)."
    - "re.RegexFlag.IGNORECASE.value == 2 — the .value attribute of the enum member gives the raw integer (not covered in any prior spec)."
    - "re.RegexFlag.MULTILINE.value == 8 — same dimension."
    - "re.RegexFlag.DOTALL.value == 16 — same dimension."
    - "re.RegexFlag.VERBOSE.value == 64 — same dimension."
    - "re.RegexFlag.ASCII.value == 256 — same dimension."
    - "re.Pattern.__qualname__ == 'Pattern' — the qualified name equals the simple name for a top-level C-extension type."
    - "re.Match.__qualname__ == 'Match' — likewise."
    - "re.RegexFlag.__qualname__ == 'RegexFlag' — likewise for the enum class."
    - "re.error.__qualname__ == 'error' (or 'PatternError' on 3.12+) — covered indirectly; here we add __qualname__ check for the pre-3.12 alias."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile('.').pattern == '.'
# re_extra2 covers 'a|b'; re_patterns covers r'\d+'.
# A single-char dot pattern is new and distinct.
# ---------------------------------------------------------------------------

invariant re_extra7.compile.dot_pattern:
  description: "re.compile('.').pattern == '.'"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["."]
  method: pattern.__eq__
  method_args: ["."]
  expected: true

# ---------------------------------------------------------------------------
# re.RegexFlag enum member .value attributes
# re_extra and re_extra5 cover the integer value of the module-level aliases
# (re.IGNORECASE == 2 etc.) via __eq__.
# Here we check the .value attribute of the RegexFlag enum MEMBERS directly —
# a new dimension not present in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra7.RegexFlag.member_values:
  description: "re.RegexFlag member .value attributes equal the documented integer constants"
  kind: python_call_eq
  category: RegexFlag_values
  id_prefix: value

  columns: [id, function, args, expected]
  rows:
    - [IGNORECASE, RegexFlag.IGNORECASE.value.__eq__, [2],   true]
    - [MULTILINE,  RegexFlag.MULTILINE.value.__eq__,  [8],   true]
    - [DOTALL,     RegexFlag.DOTALL.value.__eq__,     [16],  true]
    - [VERBOSE,    RegexFlag.VERBOSE.value.__eq__,    [64],  true]
    - [ASCII,      RegexFlag.ASCII.value.__eq__,      [256], true]

# ---------------------------------------------------------------------------
# __qualname__ checks
# No prior re spec checks __qualname__ on Pattern, Match, RegexFlag, or error.
# ---------------------------------------------------------------------------

table re_extra7.class_qualnames:
  description: "Top-level re types have __qualname__ equal to their simple name"
  kind: python_call_eq
  category: class_metadata
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Pattern,   Pattern.__qualname__.__eq__,   ["Pattern"],   true]
    - [Match,     Match.__qualname__.__eq__,     ["Match"],     true]
    - [RegexFlag, RegexFlag.__qualname__.__eq__, ["RegexFlag"], true]

# ---------------------------------------------------------------------------
# re.RegexFlag.NOFLAG — integer value 0 (Python 3.11+)
# re_extra2 covers NOFLAG.__class__.__name__; no spec checks NOFLAG.value.
# ---------------------------------------------------------------------------

invariant re_extra7.RegexFlag.NOFLAG.value:
  description: "re.RegexFlag.NOFLAG.value == 0 — NOFLAG is the identity element of the flag algebra"
  category: RegexFlag_values
  kind: python_call_eq
  function: RegexFlag.NOFLAG.value.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# re.RegexFlag class hierarchy
# re_extra2 covers RegexFlag.__name__; re_extra6 covers RegexFlag.__module__.
# Here we add __bases__[0].__name__ — new coverage.
# RegexFlag is an IntFlag; its first base is IntFlag (Python 3.11+).
# ---------------------------------------------------------------------------

invariant re_extra7.RegexFlag.base_class:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag is an IntFlag subclass"
  category: class_hierarchy
  kind: python_call_eq
  function: RegexFlag.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IntFlag"

# ---------------------------------------------------------------------------
# re.compile — group count attribute
# A freshly compiled pattern with no capture groups has .groups == 0.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

invariant re_extra7.compile.groups_zero:
  description: "re.compile('.').groups == 0 — no capture groups in a plain dot pattern"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["."]
  method: groups.__eq__
  method_args: [0]
  expected: true

invariant re_extra7.compile.groups_one:
  description: "re.compile('(.)').groups == 1 — one capture group"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["(.)"]
  method: groups.__eq__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# re.Match — span() returns a 2-tuple
# re_patterns covers .start() and .end() individually; no spec checks that
# span()[0] and span()[1] equal start/end directly on a simple match.
# ---------------------------------------------------------------------------

invariant re_extra7.match.span_start:
  description: "re.match(r'ab', 'abc').span()[0] == 0"
  category: match_attrs
  kind: python_call_eq
  function: match
  args: ["ab", "abc"]
  method: span().__getitem__
  method_args: [0]
  expected: 0

invariant re_extra7.match.span_end:
  description: "re.match(r'ab', 'abc').span()[1] == 2"
  category: match_attrs
  kind: python_call_eq
  function: match
  args: ["ab", "abc"]
  method: span().__getitem__
  method_args: [1]
  expected: 2
