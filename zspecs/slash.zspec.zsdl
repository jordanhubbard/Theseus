spec: slash
version: ">=3.0.0"
backend: node(slash)

docs: https://github.com/sindresorhus/slash#readme

provenance:
  derived_from:
    - "slash README — https://github.com/sindresorhus/slash#readme"
    - "Test vectors verified with slash@3.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "slash source: index.js"
  notes:
    - "slash@3 (CJS) exports the slash function directly as module.exports."
    - "slash(path) converts Windows backslashes to POSIX forward slashes."
    - "Paths already using forward slashes are returned unchanged."
    - "In YAML args, a single backslash is written as \\ (YAML double-quoted escape)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string with backslashes replaced by forward slashes. No errors."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table slash.convert:
  kind: node_module_call_eq
  function: ~
  category: convert
  id_prefix: sl

  columns: [id, args, expected]
  rows:
    - [forward,    ["foo/bar"],      "foo/bar"]
    - [backslash,  ["foo\\bar"],     "foo/bar"]
    - [win_path,   ["C:\\Users\\foo"], "C:/Users/foo"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:55:03Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
