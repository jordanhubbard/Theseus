spec: uuid_extra17
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Extends uuid.zspec.zsdl through uuid_extra16.zspec.zsdl."
    - "uuid_extra5 covers: UUID.__qualname__.__eq__ and uuid1/3/4/5 __qualname__.__eq__ in a table."
    - "uuid_extra7 covers: NAMESPACE_* .version table (all == 1)."
    - "uuid_extra15 covers: NAMESPACE_DNS/URL/OID.__class__.__qualname__.__eq__('UUID'); uuid3/uuid5 __qualname__ standalone."
    - "uuid_extra16 covers: UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__ method __qualname__.__eq__ and __qualname__.__len__()."
    - "This spec adds: UUID comparison method __qualname__ values (__lt__/__gt__/__le__/__ge__) — no prior uuid spec checks qualnames for any comparison dunder; NAMESPACE_X500.__class__.__qualname__ — extra15 covers DNS/URL/OID but NOT X500; NAMESPACE_DNS.version.__class__.__name__ type (int) — extra7/extra13 check the integer value but no prior spec checks the type of the .version attribute; NAMESPACE_DNS.variant.__class__.__name__ type (str) — no prior uuid spec checks the .variant attribute at all."
    - "UUID.__lt__.__qualname__ == 'UUID.__lt__' (length 11) — defined directly on UUID. No prior uuid spec checks any comparison method qualname."
    - "UUID.__gt__.__qualname__ == 'UUID.__gt__' (length 11) — defined directly on UUID."
    - "UUID.__le__.__qualname__ == 'UUID.__le__' (length 11) — defined directly on UUID."
    - "UUID.__ge__.__qualname__ == 'UUID.__ge__' (length 11) — defined directly on UUID."
    - "uuid.NAMESPACE_X500.__class__.__qualname__ == 'UUID' — uuid_extra15 checks DNS/URL/OID via __class__.__qualname__; X500 is the remaining NAMESPACE constant not yet covered by that attribute path."
    - "uuid.NAMESPACE_DNS.version.__class__.__name__ == 'int' — extra7 checks NAMESPACE_DNS.version==1 (value); no prior spec checks the type of the .version attribute via __class__.__name__."
    - "uuid.NAMESPACE_DNS.variant.__class__.__name__ == 'str' — the .variant property returns a human-readable string; no prior uuid spec touches .variant at all."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID comparison method __qualname__ values
#
# uuid_extra16 covers __str__/__repr__/__eq__/__hash__/__init__/__int__.
# No prior uuid spec checks __qualname__ for any comparison method
# (__lt__, __gt__, __le__, __ge__). All four are defined directly on the
# UUID class with qualnames following the 'UUID.<method>' pattern.
# Each qualname string has length 11.
# ---------------------------------------------------------------------------

table uuid_extra17.UUID_comparison_qualnames:
  description: "UUID comparison method __qualname__ values — no prior uuid spec covers comparison dunder qualnames"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: uuidcqname17

  columns: [id, function, args, expected]
  rows:
    - [lt, "UUID.__lt__.__qualname__.__eq__", ["UUID.__lt__"], true]
    - [gt, "UUID.__gt__.__qualname__.__eq__", ["UUID.__gt__"], true]
    - [le, "UUID.__le__.__qualname__.__eq__", ["UUID.__le__"], true]
    - [ge, "UUID.__ge__.__qualname__.__eq__", ["UUID.__ge__"], true]

# ---------------------------------------------------------------------------
# UUID comparison method __qualname__ string lengths
#
# All four comparison method qualnames are 11 characters long:
# len('UUID.__lt__') == len('UUID.__gt__') == len('UUID.__le__') ==
# len('UUID.__ge__') == 11. No prior uuid spec checks __qualname__.__len__()
# for any comparison method.
# ---------------------------------------------------------------------------

table uuid_extra17.UUID_comparison_qualname_lengths:
  description: "UUID comparison method __qualname__ string lengths — all 11 characters"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: uuidcqlen17

  columns: [id, function, args, expected]
  rows:
    - [lt, UUID.__lt__.__qualname__.__len__, [], 11]
    - [gt, UUID.__gt__.__qualname__.__len__, [], 11]
    - [le, UUID.__le__.__qualname__.__len__, [], 11]
    - [ge, UUID.__ge__.__qualname__.__len__, [], 11]

# ---------------------------------------------------------------------------
# NAMESPACE_X500.__class__.__qualname__ == 'UUID'
#
# uuid_extra15 checks NAMESPACE_DNS, NAMESPACE_URL, and NAMESPACE_OID via
# __class__.__qualname__. NAMESPACE_X500 is the only remaining NAMESPACE
# constant not yet checked by that attribute path. All NAMESPACE constants
# are UUID instances, so __class__.__qualname__ == 'UUID'.
# ---------------------------------------------------------------------------

invariant uuid_extra17.NAMESPACE_X500.class_qualname:
  description: "uuid.NAMESPACE_X500.__class__.__qualname__ == 'UUID' — extra15 covers DNS/URL/OID; X500 is new"
  category: namespace_metadata
  kind: python_call_eq
  function: NAMESPACE_X500.__class__.__qualname__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# NAMESPACE_DNS.version attribute type
#
# uuid_extra7 checks NAMESPACE_DNS.version == 1 (the integer value) in a
# table; uuid_extra13 checks it as a standalone invariant. No prior uuid
# spec checks the *type* of the .version attribute via __class__.__name__.
# The .version property returns an int for valid RFC 4122 versioned UUIDs.
# ---------------------------------------------------------------------------

invariant uuid_extra17.NAMESPACE_DNS.version_type:
  description: "uuid.NAMESPACE_DNS.version.__class__.__name__ == 'int' — .version type not checked by any prior spec"
  category: instance_attribute_types
  kind: python_call_eq
  function: NAMESPACE_DNS.version.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# NAMESPACE_DNS.variant attribute type
#
# No prior uuid spec touches the .variant attribute at all. The .variant
# property returns a human-readable string describing the UUID variant
# (e.g., 'specified in RFC 4122'). Its type is str. Verifying the type
# via __class__.__name__ is a novel invariant distinct from the value.
# ---------------------------------------------------------------------------

invariant uuid_extra17.NAMESPACE_DNS.variant_type:
  description: "uuid.NAMESPACE_DNS.variant.__class__.__name__ == 'str' — .variant attribute not checked by any prior uuid spec"
  category: instance_attribute_types
  kind: python_call_eq
  function: NAMESPACE_DNS.variant.__class__.__name__.__eq__
  args: ["str"]
  expected: true
