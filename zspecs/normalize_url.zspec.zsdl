spec: normalize_url
version: ">=4.0.0"
backend: node(normalize-url)

docs: https://www.npmjs.com/package/normalize-url

provenance:
  derived_from:
    - "normalize-url README — https://www.npmjs.com/package/normalize-url"
    - "Test vectors verified with normalize-url@4 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "normalize-url source"
  notes:
    - "normalize-url is an npm package. Install: npm install normalize-url@4"
    - "normalize-url v4 is CommonJS. v5+ is ESM-only."
    - "normalizeUrl(url) lowercases scheme/host, removes trailing slashes, and strips www by default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns normalized URL string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table normalize_url.normalize:
  kind: node_module_call_eq
  function: ~
  category: normalize
  id_prefix: nurl

  columns: [id, args, expected]
  rows:
    - [uppercase,  ["HTTP://EXAMPLE.COM/"],         "http://example.com"]
    - [trailing,   ["http://example.com/path/"],    "http://example.com/path"]
    - [www,        ["http://www.example.com"],      "http://example.com"]
    - [clean,      ["http://example.com/path"],     "http://example.com/path"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:03:52Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
