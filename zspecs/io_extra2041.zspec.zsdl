spec: io_extra2041
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2041): __lshift__, __rlshift__, __ilshift__, __rshift__, __rrshift__, __irshift__, __and__, __rand__, __iand__, __or__, __ror__, __ior__, __xor__, __rxor__, __ixor__, __invert__ dict-presence checks."
    - "io.IOBase, io.BytesIO, io.StringIO, io.FileIO, io.RawIOBase are I/O stream classes; none defines any bitwise operator."
    - "All five io classes are C types (from the _io extension); bitwise operators are absent from their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __lshift__ / __rlshift__ / __ilshift__ — left shift dict-presence
# ---------------------------------------------------------------------------

table io_extra2041.lshift_protocol:
  description: "io types __lshift__/__rlshift__/__ilshift__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2041

  columns: [id, function, args, expected]
  rows:
    - ["io2041001", "io.IOBase.__dict__.__contains__",    ["__lshift__"],  false]
    - ["io2041002", "io.IOBase.__dict__.__contains__",    ["__rlshift__"], false]
