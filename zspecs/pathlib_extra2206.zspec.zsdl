    - ["pl2206008", "pathlib.PurePosixPath.__dict__.__contains__", ["__le__"], false]
    - ["pl2206009", "pathlib.PurePosixPath.__dict__.__contains__", ["__gt__"], false]
    - ["pl2206010", "pathlib.PurePosixPath.__dict__.__contains__", ["__ge__"], false]
    - ["pl2206011", "pathlib.PurePosixPath.__dict__.__contains__", ["__eq__"], false]
    - ["pl2206012", "pathlib.PurePosixPath.__dict__.__contains__", ["__ne__"], false]

