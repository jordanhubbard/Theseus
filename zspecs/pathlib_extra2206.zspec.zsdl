spec: pathlib_extra2206
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2206 (pathlib_extra2206): rich comparison operator protocol dict-presence checks — __lt__, __le__, __gt__, __ge__, __eq__, __ne__."
    - "pathlib.PurePath defines __lt__, __le__, __gt__, __ge__, __eq__ in its own __dict__ — PurePath implements lexicographic path comparison for sorting and ordering."
    - "pathlib.PurePath does NOT define __ne__ in its own __dict__ — Python derives __ne__ automatically from __eq__ via object.__ne__ when __eq__ is defined."
    - "pathlib.PurePosixPath does NOT define any of the six comparison dunders in its own __dict__ — it inherits all comparison behaviour from PurePath."
    - "pathlib.PureWindowsPath does NOT define any of the six comparison dunders in its own __dict__ — it inherits all comparison behaviour from PurePath."
    - "pathlib.Path does NOT define any of the six comparison dunders in its own __dict__ — it inherits all comparison behaviour from PurePath through PurePosixPath or PureWindowsPath."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table pathlib_extra2206.purepath_comparison_protocol:
  description: "pathlib.PurePath rich comparison operator dict-presence checks — base path class defines ordering operators but not __ne__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2206

  columns: [id, function, args, expected]
  rows:
    - ["pl2206001", "pathlib.PurePath.__dict__.__contains__", ["__lt__"], true]
    - ["pl2206002", "pathlib.PurePath.__dict__.__contains__", ["__le__"], true]
    - ["pl2206003", "pathlib.PurePath.__dict__.__contains__", ["__gt__"], true]
    - ["pl2206004", "pathlib.PurePath.__dict__.__contains__", ["__ge__"], true]
    - ["pl2206005", "pathlib.PurePath.__dict__.__contains__", ["__eq__"], true]
    - ["pl2206006", "pathlib.PurePath.__dict__.__contains__", ["__ne__"], false]

