spec: asyncio_extra187
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
  notes:
    - "asyncio.__name__ == 'asyncio' (len=7)."
    - "asyncio.sleep, asyncio.gather, asyncio.wait, asyncio.create_task all live in asyncio.tasks module."
    - "asyncio.sleep.__name__ == 'sleep' (len=5); asyncio.gather.__name__ == 'gather' (len=6)."
    - "asyncio.wait.__name__ == 'wait' (len=4); asyncio.create_task.__name__ == 'create_task' (len=11)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio module-level name and top-level function name equality
#
# asyncio.__name__.__eq__('asyncio') == True (len=7)
# asyncio.sleep.__name__.__eq__('sleep') == True (len=5)
# asyncio.gather.__name__.__eq__('gather') == True (len=6)
# ---------------------------------------------------------------------------

table asyncio_extra187.module_and_short_function_names:
  description: "asyncio module __name__ identity and short function name equality: asyncio(7), sleep(5), gather(6); new to asyncio_extra187"
  kind: python_call_eq
  category: identity
  id_prefix: asynciomodule187

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,
       __name__.__eq__,
       ["asyncio"],
       true,
       "asyncio.__name__.__eq__('asyncio') == True — module name string identity; str.__eq__ returns True; new to asyncio_extra187"]
    - [module_name_len_7,
       __name__.__len__,
       [],
       7,
       "asyncio.__name__.__len__() == 7 — 'asyncio' has 7 characters: a-s-y-n-c-i-o; str.__len__() returns 7; new to asyncio_extra187"]
    - [sleep_name_eq,
       sleep.__name__.__eq__,
       ["sleep"],
       true,
       "asyncio.sleep.__name__.__eq__('sleep') == True — function name string identity; str.__eq__ returns True; new to asyncio_extra187"]
    - [sleep_name_len_5,
       sleep.__name__.__len__,
       [],
       5,
       "asyncio.sleep.__name__.__len__() == 5 — 'sleep' has 5 characters: s-l-e-e-p; str.__len__() returns 5; new to asyncio_extra187"]
    - [gather_name_eq,
       gather.__name__.__eq__,
       ["gather"],
       true,
       "asyncio.gather.__name__.__eq__('gather') == True — function name string identity; str.__eq__ returns True; new to asyncio_extra187"]

# ---------------------------------------------------------------------------
# Table 2: asyncio top-level function module attribution
#
# asyncio.sleep.__module__.__eq__('asyncio.tasks') == True
# asyncio.gather.__module__.__eq__('asyncio.tasks') == True
# asyncio.wait.__module__.__eq__('asyncio.tasks') == True
# asyncio.create_task.__module__.__eq__('asyncio.tasks') == True
# ---------------------------------------------------------------------------

table asyncio_extra187.function_module_attrs:
  description: "asyncio top-level functions all defined in asyncio.tasks module; new to asyncio_extra187"
  kind: python_call_eq
  category: identity
  id_prefix: asynciomodule187

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_module_eq,
       sleep.__module__.__eq__,
       ["asyncio.tasks"],
       true,
       "asyncio.sleep.__module__.__eq__('asyncio.tasks') == True — sleep is defined in asyncio.tasks; str.__eq__ returns True; new to asyncio_extra187"]
    - [gather_module_eq,
       gather.__module__.__eq__,
       ["asyncio.tasks"],
       true,
       "asyncio.gather.__module__.__eq__('asyncio.tasks') == True — gather is defined in asyncio.tasks; str.__eq__ returns True; new to asyncio_extra187"]
    - [wait_module_eq,
       wait.__module__.__eq__,
       ["asyncio.tasks"],
       true,
       "asyncio.wait.__module__.__eq__('asyncio.tasks') == True — wait is defined in asyncio.tasks; str.__eq__ returns True; new to asyncio_extra187"]
    - [create_task_module_eq,
       create_task.__module__.__eq__,
       ["asyncio.tasks"],
       true,
       "asyncio.create_task.__module__.__eq__('asyncio.tasks') == True — create_task is defined in asyncio.tasks; str.__eq__ returns True; new to asyncio_extra187"]
    - [gather_name_len_6,
       gather.__name__.__len__,
       [],
       6,
       "asyncio.gather.__name__.__len__() == 6 — 'gather' has 6 characters: g-a-t-h-e-r; str.__len__() returns 6; new to asyncio_extra187"]

# ---------------------------------------------------------------------------
# Table 3: asyncio wait and create_task name equality and length
#
# asyncio.wait.__name__.__eq__('wait') == True (len=4)
# asyncio.create_task.__name__.__eq__('create_task') == True (len=11)
# Length ordering: wait(4) < sleep(5) < gather(6) < create_task(11)
# ---------------------------------------------------------------------------

table asyncio_extra187.wait_and_create_task_names:
  description: "asyncio.wait (len=4) and asyncio.create_task (len=11) name equality and length ordering; new to asyncio_extra187"
  kind: python_call_eq
  category: identity
  id_prefix: asynciomodule187

  columns: [id, function, args, expected, description]
  rows:
    - [wait_name_eq,
       wait.__name__.__eq__,
       ["wait"],
       true,
       "asyncio.wait.__name__.__eq__('wait') == True — function name string identity; str.__eq__ returns True; new to asyncio_extra187"]
    - [wait_name_len_4,
       wait.__name__.__len__,
       [],
       4,
       "asyncio.wait.__name__.__len__() == 4 — 'wait' has 4 characters: w-a-i-t; shortest of the four functions; str.__len__() returns 4; new to asyncio_extra187"]
    - [create_task_name_eq,
       create_task.__name__.__eq__,
       ["create_task"],
       true,
       "asyncio.create_task.__name__.__eq__('create_task') == True — function name string identity; str.__eq__ returns True; new to asyncio_extra187"]
    - [create_task_name_len_11,
       create_task.__name__.__len__,
       [],
       11,
       "asyncio.create_task.__name__.__len__() == 11 — 'create_task' has 11 characters: c-r-e-a-t-e-_-t-a-s-k; longest of the four functions; str.__len__() returns 11; new to asyncio_extra187"]
    - [wait_name_len_4b,
       wait.__name__.__len__,
       [],
       4,
       "asyncio.wait.__name__.__len__() == 4 — ordering anchor: wait(4) < sleep(5) < gather(6) < create_task(11); str.__len__() returns 4; new to asyncio_extra187"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra187
# ---------------------------------------------------------------------------

invariant asyncio_extra187.module_name_eq:
  description: "asyncio.__name__.__eq__('asyncio') == True — module name identity; new to asyncio_extra187"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra187.module_name_len_7:
  description: "asyncio.__name__.__len__() == 7 — 'asyncio' has 7 characters; new to asyncio_extra187"
  category: identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 7

invariant asyncio_extra187.sleep_name_eq:
  description: "asyncio.sleep.__name__.__eq__('sleep') == True — function name identity; len=5; new to asyncio_extra187"
  category: identity
  kind: python_call_eq
  function: sleep.__name__.__eq__
  args: ["sleep"]
  expected: true

invariant asyncio_extra187.sleep_module_tasks:
  description: "asyncio.sleep.__module__.__eq__('asyncio.tasks') == True — sleep is defined in asyncio.tasks; new to asyncio_extra187"
  category: identity
  kind: python_call_eq
  function: sleep.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra187.gather_name_eq:
  description: "asyncio.gather.__name__.__eq__('gather') == True — function name identity; len=6; new to asyncio_extra187"
  category: identity
  kind: python_call_eq
  function: gather.__name__.__eq__
  args: ["gather"]
  expected: true

invariant asyncio_extra187.gather_module_tasks:
  description: "asyncio.gather.__module__.__eq__('asyncio.tasks') == True — gather is defined in asyncio.tasks; new to asyncio_extra187"
  category: identity
  kind: python_call_eq
  function: gather.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra187.wait_name_len_4:
  description: "asyncio.wait.__name__.__len__() == 4 — 'wait' has 4 characters; shortest of the four; ordering: wait(4)<sleep(5)<gather(6)<create_task(11); new to asyncio_extra187"
  category: identity
  kind: python_call_eq
  function: wait.__name__.__len__
  args: []
  expected: 4

invariant asyncio_extra187.create_task_name_len_11:
  description: "asyncio.create_task.__name__.__len__() == 11 — 'create_task' has 11 characters; longest of the four; new to asyncio_extra187"
  category: identity
  kind: python_call_eq
  function: create_task.__name__.__len__
  args: []
  expected: 11
