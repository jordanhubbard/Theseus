spec: dc2956
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal class __dict__ bitwise invert / round / trunc presence"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "decimal.Decimal is a full numeric type. It does NOT define __invert__ (bitwise ops unsupported on Decimal)."
    - "operator.contains(decimal.Decimal.__dict__, '__invert__') is False — Decimal raises TypeError on ~."
    - "operator.contains(decimal.Decimal.__dict__, '__round__') is True — Decimal owns __round__ for round() support."
    - "operator.contains(decimal.Decimal.__dict__, '__trunc__') is True — Decimal owns __trunc__ for math.trunc() support."
    - "decimal.Context is a configuration object; it defines none of these operators."
    - "DecimalException and all subclasses are exception types derived from ArithmeticError; none define these operators."
    - "Subclasses verified: InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded, Subnormal, FloatOperation, Clamped, DivisionImpossible, DivisionUndefined, InvalidContext."
    - "All values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __invert__ dict-presence — bitwise invert operator in own __dict__
#
# decimal.Decimal does NOT define __invert__ (False) — Decimal does not
# support bitwise operations; ~d raises TypeError. Context and all exception
# subclasses also do not define it.
# ---------------------------------------------------------------------------

table dc2956.invert:
  description: "operator.contains(cls.__dict__, '__invert__') is False for all decimal classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: dci2956

  columns: [id, function, args, expected]
  rows:
    - ["dci2956_001", operator.contains, [decimal.Decimal.__dict__,           "__invert__"], false]
    - ["dci2956_002", operator.contains, [decimal.Context.__dict__,           "__invert__"], false]
    - ["dci2956_003", operator.contains, [decimal.DecimalException.__dict__,  "__invert__"], false]
    - ["dci2956_004", operator.contains, [decimal.InvalidOperation.__dict__,  "__invert__"], false]
    - ["dci2956_005", operator.contains, [decimal.DivisionByZero.__dict__,    "__invert__"], false]
    - ["dci2956_006", operator.contains, [decimal.Overflow.__dict__,          "__invert__"], false]
    - ["dci2956_007", operator.contains, [decimal.Underflow.__dict__,         "__invert__"], false]
    - ["dci2956_008", operator.contains, [decimal.Inexact.__dict__,           "__invert__"], false]
    - ["dci2956_009", operator.contains, [decimal.Rounded.__dict__,           "__invert__"], false]
    - ["dci2956_010", operator.contains, [decimal.Subnormal.__dict__,         "__invert__"], false]
    - ["dci2956_011", operator.contains, [decimal.FloatOperation.__dict__,    "__invert__"], false]
    - ["dci2956_012", operator.contains, [decimal.Clamped.__dict__,           "__invert__"], false]

# ---------------------------------------------------------------------------
# __round__ dict-presence — round() protocol in own __dict__
#
# decimal.Decimal defines __round__ directly in its own __dict__ (True) —
# round(Decimal('1.5')) is supported. Context and all exception subclasses
# do not define __round__ (False).
# ---------------------------------------------------------------------------

table dc2956.round:
  description: "operator.contains(cls.__dict__, '__round__'): True for Decimal, False for all others"
  kind: python_call_eq
  category: dict_presence
  id_prefix: dcr2956

  columns: [id, function, args, expected]
  rows:
    - ["dcr2956_001", operator.contains, [decimal.Decimal.__dict__,           "__round__"], true]
    - ["dcr2956_002", operator.contains, [decimal.Context.__dict__,           "__round__"], false]
    - ["dcr2956_003", operator.contains, [decimal.DecimalException.__dict__,  "__round__"], false]
    - ["dcr2956_004", operator.contains, [decimal.InvalidOperation.__dict__,  "__round__"], false]
    - ["dcr2956_005", operator.contains, [decimal.DivisionByZero.__dict__,    "__round__"], false]
    - ["dcr2956_006", operator.contains, [decimal.Overflow.__dict__,          "__round__"], false]
    - ["dcr2956_007", operator.contains, [decimal.Underflow.__dict__,         "__round__"], false]
    - ["dcr2956_008", operator.contains, [decimal.Inexact.__dict__,           "__round__"], false]
    - ["dcr2956_009", operator.contains, [decimal.Rounded.__dict__,           "__round__"], false]
    - ["dcr2956_010", operator.contains, [decimal.Subnormal.__dict__,         "__round__"], false]
    - ["dcr2956_011", operator.contains, [decimal.FloatOperation.__dict__,    "__round__"], false]
    - ["dcr2956_012", operator.contains, [decimal.Clamped.__dict__,           "__round__"], false]

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — math.trunc() protocol in own __dict__
#
# decimal.Decimal defines __trunc__ directly in its own __dict__ (True) —
# math.trunc(Decimal('1.9')) is supported. Context and all exception
# subclasses do not define __trunc__ (False).
# ---------------------------------------------------------------------------

table dc2956.trunc:
  description: "operator.contains(cls.__dict__, '__trunc__'): True for Decimal, False for all others"
  kind: python_call_eq
  category: dict_presence
  id_prefix: dct2956

  columns: [id, function, args, expected]
  rows:
    - ["dct2956_001", operator.contains, [decimal.Decimal.__dict__,           "__trunc__"], true]
    - ["dct2956_002", operator.contains, [decimal.Context.__dict__,           "__trunc__"], false]
    - ["dct2956_003", operator.contains, [decimal.DecimalException.__dict__,  "__trunc__"], false]
    - ["dct2956_004", operator.contains, [decimal.InvalidOperation.__dict__,  "__trunc__"], false]
    - ["dct2956_005", operator.contains, [decimal.DivisionByZero.__dict__,    "__trunc__"], false]
    - ["dct2956_006", operator.contains, [decimal.Overflow.__dict__,          "__trunc__"], false]
    - ["dct2956_007", operator.contains, [decimal.Underflow.__dict__,         "__trunc__"], false]
    - ["dct2956_008", operator.contains, [decimal.Inexact.__dict__,           "__trunc__"], false]
    - ["dct2956_009", operator.contains, [decimal.Rounded.__dict__,           "__trunc__"], false]
    - ["dct2956_010", operator.contains, [decimal.Subnormal.__dict__,         "__trunc__"], false]
    - ["dct2956_011", operator.contains, [decimal.FloatOperation.__dict__,    "__trunc__"], false]
    - ["dct2956_012", operator.contains, [decimal.Clamped.__dict__,           "__trunc__"], false]

# ---------------------------------------------------------------------------
# combined — full cross-check focusing on the True/False split
#
# Decimal: __invert__=False, __round__=True, __trunc__=True.
# Context: all False. DecimalException: all False.
# Also includes a representative sample of exception subclasses.
# ---------------------------------------------------------------------------

table dc2956.combined:
  description: "Combined: Decimal owns __round__ and __trunc__ but not __invert__; Context and exceptions own none"
  kind: python_call_eq
  category: dict_presence
  id_prefix: dcx2956

  columns: [id, function, args, expected]
  rows:
    - ["dcx2956_001", operator.contains, [decimal.Decimal.__dict__,           "__invert__"], false]
    - ["dcx2956_002", operator.contains, [decimal.Decimal.__dict__,           "__round__"],  true]
    - ["dcx2956_003", operator.contains, [decimal.Decimal.__dict__,           "__trunc__"],  true]
    - ["dcx2956_004", operator.contains, [decimal.Context.__dict__,           "__invert__"], false]
    - ["dcx2956_005", operator.contains, [decimal.Context.__dict__,           "__round__"],  false]
    - ["dcx2956_006", operator.contains, [decimal.Context.__dict__,           "__trunc__"],  false]
    - ["dcx2956_007", operator.contains, [decimal.DecimalException.__dict__,  "__invert__"], false]
    - ["dcx2956_008", operator.contains, [decimal.DecimalException.__dict__,  "__round__"],  false]
