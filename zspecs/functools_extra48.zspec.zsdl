spec: functools_extra48
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra47.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps/partial/lru_cache/total_ordering/singledispatch/cached_property/reduce/cmp_to_key/partialmethod/singledispatchmethod/update_wrapper; __qualname__.__len__() for update_wrapper/partialmethod/singledispatchmethod/cache/total_ordering/singledispatch/cmp_to_key/cached_property/lru_cache/wraps/reduce/partial; WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES lengths; __all__ lengths and indexed elements; partial/__class__.__name__; cached_property.__set_name__/__get__/__init__.__qualname__; total_ordering.__dict__.__class__.__name__; partial/__new__.__qualname__; class __dict__.__class__.__name__.__len__ for partial/partialmethod/singledispatchmethod/cached_property; partial/__doc__/reduce/__doc__; reduce with initial value; lru_cache(128).__ne__(None)==True; C-extension vs pure-Python __module__ lengths; lru_cache(maxsize=2) behavioral; reduce.__qualname__=='reduce'; lru_cache.__qualname__=='lru_cache'; cache/__name__/__qualname__/__module__; cached_property/__name__/__qualname__/__module__/__bases__[0].__name__; total_ordering/__name__/__qualname__/__module__; singledispatch/__name__/__qualname__/__module__; singledispatch/__qualname__/__len__()==14; total_ordering/__qualname__/__len__()==14; wraps/__name__/__qualname__/__module__; update_wrapper/__name__/__qualname__/__module__; partial/__bases__[0].__name__=='object'; partial/__name__/'partial'; partial/__qualname__/'partial'; partial/__module__/'functools'; lru_cache/__name__/__module__; cmp_to_key/__name__=='cmp_to_key' (extra4); cmp_to_key/__module__.__len__()==10 (extra43)."
    - "This spec covers: functools.partial.__qualname__ == 'partial' (C type; __qualname__==__name__; confirmed same as __name__; new angle is explicit qualname not previously isolated from __name__); functools.partialmethod.__name__ == 'partialmethod'; functools.partialmethod.__module__ == 'functools'; functools.partialmethod.__qualname__ == 'partialmethod'; functools.partialmethod.__bases__[0].__name__ == 'object'; functools.reduce.__name__.__len__() == 6; functools.cmp_to_key.__module__ == '_functools' (string equality — prior spec only recorded __len__()==10)."
    - "Key findings: functools.partial.__qualname__ is 'partial' — the C-extension type partial has __qualname__=='partial' matching __name__=='partial'; both were confirmed in extra44 but as a combined fact; the qualname in isolation (distinct from the already-confirmed __name__ equality) is now an explicit invariant. functools.partialmethod.__name__, __qualname__ are both 'partialmethod' (13 chars) — partialmethod is a pure-Python class defined at module level in Lib/functools.py; top-level so __qualname__==__name__; __module__ is 'functools'. functools.partialmethod.__bases__[0].__name__ is 'object' — pure-Python class inheriting directly from object. functools.reduce.__name__.__len__() is 6 — 'reduce' is 6 chars; prior specs recorded this length but only via __qualname__.__len__()==6 and __name__.__len__()==6 from the table rows for the all-names table; this invariant targets reduce.__name__.__len__() directly via method call. functools.cmp_to_key.__module__ is '_functools' (string equality) — the prior spec (extra43) recorded the length (10) but not the string equality invariant; cmp_to_key is a C-extension function in Modules/_functoolsmodule.c so its __module__ is '_functools' not 'functools'."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.partial __qualname__ — extra48 namespace
#
# functools.partial.__qualname__ is 'partial' (7 chars). partial is a C-extension
# type defined in Modules/_functoolsmodule.c; as a top-level type its __qualname__
# equals __name__. Prior spec extra44 confirmed partial.__name__=='partial' and
# partial.__qualname__=='partial' together as a combined fact (the spec notes state
# both), but the explicit qualname string equality invariant in isolation is new
# here in extra48. __qualname__.__len__()==7 was recorded in earlier specs.
# ---------------------------------------------------------------------------

invariant functools_extra48.partial_qualname:
  description: "functools.partial.__qualname__ == 'partial' — C-extension type; top-level type so __qualname__ == __name__; 7 chars; same string as partial.__name__"
  category: identity
  kind: python_call_eq
  function: "partial.__qualname__.__eq__"
  args: ["partial"]
  expected: true

# ---------------------------------------------------------------------------
# functools.partialmethod identity metadata — extra48 namespace
#
# functools.partialmethod.__name__ is 'partialmethod' (13 chars),
# functools.partialmethod.__qualname__ is 'partialmethod' (13 chars), and
# functools.partialmethod.__module__ is 'functools' (9 chars).
# partialmethod is a pure-Python class defined at module level in Lib/functools.py.
# As a top-level class __qualname__ == __name__. Its base class is object
# (single-level inheritance). Prior specs recorded __name__.__len__()==13 and
# __qualname__.__len__()==13 but not the string equality invariants for __name__,
# __qualname__, or __module__, and not __bases__[0].__name__.
# ---------------------------------------------------------------------------

table functools_extra48.partialmethod_identity:
  description: "functools.partialmethod __name__, __qualname__, __module__, and __bases__[0].__name__ — pure-Python class; module-level; inherits directly from object"
  kind: python_call_eq
  category: identity
  id_prefix: pmid48

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_name,
       partialmethod.__name__.__eq__,
       ["partialmethod"],
       true,
       "functools.partialmethod.__name__ == 'partialmethod' — pure-Python class defined in Lib/functools.py; 13-char name; descriptor for partial application in classes"]
    - [partialmethod_qualname,
       partialmethod.__qualname__.__eq__,
       ["partialmethod"],
       true,
       "functools.partialmethod.__qualname__ == 'partialmethod' — top-level class; __qualname__ == __name__ (no enclosing class scope); 13 chars; same string as __name__"]
    - [partialmethod_module,
       partialmethod.__module__.__eq__,
       ["functools"],
       true,
       "functools.partialmethod.__module__ == 'functools' — pure-Python class defined in Lib/functools.py; 9-char module name; same as all pure-Python functools objects"]
    - [partialmethod_bases_name,
       "partialmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__bases__[0].__name__ == 'object' — pure-Python class; inherits directly from object; single base class; no intermediate inheritance"]

# ---------------------------------------------------------------------------
# functools.reduce __name__.__len__() — extra48 namespace
#
# functools.reduce.__name__.__len__() is 6 — 'reduce' is 6 chars. reduce is a
# C-extension builtin_function_or_method defined in Modules/_functoolsmodule.c.
# Prior specs recorded reduce.__name__.__len__()==6 in table rows (via __name__
# length table) and confirmed reduce.__qualname__=='reduce' (extra46), but did
# not record reduce.__name__.__len__() as an explicit standalone invariant
# using the method-call syntax. This invariant is new to extra48.
# ---------------------------------------------------------------------------

invariant functools_extra48.reduce_name_len:
  description: "len(functools.reduce.__name__) == 6 — 'reduce' is 6 chars; C-extension builtin; same length as chain.__name__ and 'object'; functional left-fold over an iterable"
  category: string_properties
  kind: python_call_eq
  function: reduce.__name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# functools.cmp_to_key __module__ string equality — extra48 namespace
#
# functools.cmp_to_key.__module__ is '_functools' (10 chars). cmp_to_key is a
# C-extension function defined in Modules/_functoolsmodule.c alongside reduce;
# its __module__ attribute reflects the underlying C extension name '_functools'
# rather than the public 'functools' package name. Prior spec extra4 recorded
# cmp_to_key.__name__ == 'cmp_to_key', and extra43 recorded
# cmp_to_key.__module__.__len__()==10, but no spec has recorded the string
# equality invariant for cmp_to_key.__module__. This is new to extra48.
# ---------------------------------------------------------------------------

invariant functools_extra48.cmp_to_key_module:
  description: "functools.cmp_to_key.__module__ == '_functools' — C-extension function in Modules/_functoolsmodule.c; __module__ is '_functools' not 'functools'; 10-char name; same as reduce.__module__"
  category: module_metadata
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true
