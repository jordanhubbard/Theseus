spec: multiprocessing_extra101
version: ">=3.9"
backend: python_module(multiprocessing)
extends: multiprocessing_extra99

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra99.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing.Process method __qualname__ string equality for the full set (including __init__ and close) plus multiprocessing.pool.Pool method __qualname__ values. NEW in extra101: multiprocessing.Process.start.__qualname__=='BaseProcess.start' (len=17); multiprocessing.Process.run.__qualname__=='BaseProcess.run' (len=15, shortest); multiprocessing.Process.join.__qualname__=='BaseProcess.join' (len=16); multiprocessing.Process.terminate.__qualname__=='BaseProcess.terminate' (len=21, longest Process method); multiprocessing.Process.is_alive.__qualname__=='BaseProcess.is_alive' (len=20); multiprocessing.Process.__init__.__qualname__=='BaseProcess.__init__' (len=20, tied with is_alive); multiprocessing.Process.kill.__qualname__=='BaseProcess.kill' (len=16, tied with join); multiprocessing.Process.close.__qualname__=='BaseProcess.close' (len=17, tied with start); multiprocessing.pool.Pool.map.__qualname__=='Pool.map' (len=8); multiprocessing.pool.Pool.apply.__qualname__=='Pool.apply' (len=10); multiprocessing.pool.Pool.starmap.__qualname__=='Pool.starmap' (len=12). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__init__.__qualname__ == 'BaseProcess.__init__' (len=20). Although Process is the class being accessed, all core methods (including __init__) are defined in BaseProcess, so their qualnames use 'BaseProcess.' prefix. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.close.__qualname__ == 'BaseProcess.close' (len=17). Process.close() releases resources; it is also inherited from BaseProcess. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.starmap.__qualname__ == 'Pool.starmap' (len=12). Pool.map qualname length is 8, Pool.apply is 10, Pool.starmap is 12 — each 2 chars longer. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process method __qualname__ full set — extra101
#
# Wave 254 theme: multiprocessing.Process method __qualname__ string equality.
# All Process core methods are inherited from BaseProcess, so qualnames use
# 'BaseProcess.' prefix (12 chars).
#
# Process.start.__qualname__     == 'BaseProcess.start'     (len=17)
# Process.run.__qualname__       == 'BaseProcess.run'       (len=15, shortest)
# Process.join.__qualname__      == 'BaseProcess.join'      (len=16)
# Process.terminate.__qualname__ == 'BaseProcess.terminate' (len=21, longest)
# Process.is_alive.__qualname__  == 'BaseProcess.is_alive'  (len=20)
# Process.__init__.__qualname__  == 'BaseProcess.__init__'  (len=20, tied)
# Process.kill.__qualname__      == 'BaseProcess.kill'      (len=16, tied)
# Process.close.__qualname__     == 'BaseProcess.close'     (len=17, tied)
# ---------------------------------------------------------------------------

table multiprocessing_extra101.mp_process_method_qualnames:
  description: "multiprocessing.Process method __qualname__ equality checks in mprocmq101 namespace — wave 254 theme: all Process core methods are inherited from BaseProcess (Lib/multiprocessing/process.py) so their __qualname__ uses 'BaseProcess.' prefix (12 chars); Process.run.__qualname__.__eq__('BaseProcess.run')==True (len=15: 'BaseProcess.'=12 + 'run'=3, shortest); Process.join.__qualname__.__eq__('BaseProcess.join')==True (len=16: 'BaseProcess.'=12 + 'join'=4); Process.kill.__qualname__.__eq__('BaseProcess.kill')==True (len=16: tied with join); Process.start.__qualname__.__eq__('BaseProcess.start')==True (len=17: 'BaseProcess.'=12 + 'start'=5); Process.close.__qualname__.__eq__('BaseProcess.close')==True (len=17: tied with start); Process.is_alive.__qualname__.__eq__('BaseProcess.is_alive')==True (len=20: 'BaseProcess.'=12 + 'is_alive'=8); Process.__init__.__qualname__.__eq__('BaseProcess.__init__')==True (len=20: 'BaseProcess.'=12 + '__init__'=8, tied with is_alive); Process.terminate.__qualname__.__eq__('BaseProcess.terminate')==True (len=21: 'BaseProcess.'=12 + 'terminate'=9, the longest); all are pure-Python functions (class='function'); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: mprocmq101

  columns: [id, function, args, expected, description]
  rows:
    - [run_qn_eq,      multiprocessing.Process.run.__qualname__.__eq__,       ["BaseProcess.run"],       true, "Process.run.__qualname__ == 'BaseProcess.run' (len=15, shortest); verified with Python 3.14.3"]
    - [run_qn_len,     multiprocessing.Process.run.__qualname__.__len__,       [],                        15,   "Process.run.__qualname__.__len__() == 15 (shortest Process method qualname); verified with Python 3.14.3"]
    - [join_qn_eq,     multiprocessing.Process.join.__qualname__.__eq__,       ["BaseProcess.join"],      true, "Process.join.__qualname__ == 'BaseProcess.join' (len=16); verified with Python 3.14.3"]
    - [join_qn_len,    multiprocessing.Process.join.__qualname__.__len__,       [],                       16,   "Process.join.__qualname__.__len__() == 16 (tied with kill); verified with Python 3.14.3"]
    - [kill_qn_eq,     multiprocessing.Process.kill.__qualname__.__eq__,       ["BaseProcess.kill"],      true, "Process.kill.__qualname__ == 'BaseProcess.kill' (len=16, tied with join); verified with Python 3.14.3"]
    - [kill_qn_len,    multiprocessing.Process.kill.__qualname__.__len__,       [],                       16,   "Process.kill.__qualname__.__len__() == 16 (tied with join); verified with Python 3.14.3"]
    - [start_qn_eq,    multiprocessing.Process.start.__qualname__.__eq__,      ["BaseProcess.start"],     true, "Process.start.__qualname__ == 'BaseProcess.start' (len=17); verified with Python 3.14.3"]
    - [start_qn_len,   multiprocessing.Process.start.__qualname__.__len__,      [],                       17,   "Process.start.__qualname__.__len__() == 17 (tied with close); verified with Python 3.14.3"]
    - [close_qn_eq,    multiprocessing.Process.close.__qualname__.__eq__,      ["BaseProcess.close"],     true, "Process.close.__qualname__ == 'BaseProcess.close' (len=17, tied with start); verified with Python 3.14.3"]
    - [close_qn_len,   multiprocessing.Process.close.__qualname__.__len__,      [],                       17,   "Process.close.__qualname__.__len__() == 17 (tied with start); verified with Python 3.14.3"]
    - [alive_qn_eq,    multiprocessing.Process.is_alive.__qualname__.__eq__,   ["BaseProcess.is_alive"],  true, "Process.is_alive.__qualname__ == 'BaseProcess.is_alive' (len=20); verified with Python 3.14.3"]
    - [alive_qn_len,   multiprocessing.Process.is_alive.__qualname__.__len__,   [],                       20,   "Process.is_alive.__qualname__.__len__() == 20 (tied with __init__); verified with Python 3.14.3"]
    - [init_qn_eq,     multiprocessing.Process.__init__.__qualname__.__eq__,   ["BaseProcess.__init__"],  true, "Process.__init__.__qualname__ == 'BaseProcess.__init__' (len=20, tied with is_alive); verified with Python 3.14.3"]
    - [init_qn_len,    multiprocessing.Process.__init__.__qualname__.__len__,   [],                       20,   "Process.__init__.__qualname__.__len__() == 20 (tied with is_alive); verified with Python 3.14.3"]
    - [term_qn_eq,     multiprocessing.Process.terminate.__qualname__.__eq__,  ["BaseProcess.terminate"], true, "Process.terminate.__qualname__ == 'BaseProcess.terminate' (len=21, longest); verified with Python 3.14.3"]
    - [term_qn_len,    multiprocessing.Process.terminate.__qualname__.__len__,  [],                       21,   "Process.terminate.__qualname__.__len__() == 21 (longest Process method qualname); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool method __qualname__ values — extra101
#
# Wave 254 theme: Pool method __qualname__ values (contrast with Process).
# Pool methods are defined directly in Pool, so qualnames use 'Pool.' prefix.
#
# Pool.map.__qualname__     == 'Pool.map'     (len=8)
# Pool.apply.__qualname__   == 'Pool.apply'   (len=10)
# Pool.starmap.__qualname__ == 'Pool.starmap' (len=12)
# ---------------------------------------------------------------------------

table multiprocessing_extra101.mp_pool_method_qualnames:
  description: "multiprocessing.pool.Pool method __qualname__ equality checks in mprocmq101 namespace — wave 254 theme: Pool methods are defined directly in Pool (not inherited from a base class), so their qualnames use 'Pool.' prefix (5 chars) unlike Process methods which use 'BaseProcess.' prefix (12 chars); Pool.map.__qualname__.__eq__('Pool.map')==True (len=8: 'Pool.'=5 + 'map'=3); Pool.map.__qualname__.__len__()==8; Pool.apply.__qualname__.__eq__('Pool.apply')==True (len=10: 'Pool.'=5 + 'apply'=5); Pool.apply.__qualname__.__len__()==10; Pool.starmap.__qualname__.__eq__('Pool.starmap')==True (len=12: 'Pool.'=5 + 'starmap'=7); Pool.starmap.__qualname__.__len__()==12; Pool.map, Pool.apply, and Pool.starmap are the three core data-parallel methods; each method name adds 2 chars over the previous (map=3, apply=5, starmap=7); all are pure-Python functions (class='function'); Pool methods use 'Pool.' prefix (5 chars) vs Process methods using 'BaseProcess.' prefix (12 chars); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: mprocmq101a

  columns: [id, function, args, expected, description]
  rows:
    - [map_qn_eq,      "multiprocessing.pool.Pool.map.__qualname__.__eq__",     ["Pool.map"],     true, "Pool.map.__qualname__ == 'Pool.map' (len=8); verified with Python 3.14.3"]
    - [map_qn_len,     "multiprocessing.pool.Pool.map.__qualname__.__len__",    [],               8,    "Pool.map.__qualname__.__len__() == 8; verified with Python 3.14.3"]
    - [apply_qn_eq,    "multiprocessing.pool.Pool.apply.__qualname__.__eq__",   ["Pool.apply"],   true, "Pool.apply.__qualname__ == 'Pool.apply' (len=10); verified with Python 3.14.3"]
    - [apply_qn_len,   "multiprocessing.pool.Pool.apply.__qualname__.__len__",  [],               10,   "Pool.apply.__qualname__.__len__() == 10; verified with Python 3.14.3"]
    - [stmap_qn_eq,    "multiprocessing.pool.Pool.starmap.__qualname__.__eq__", ["Pool.starmap"], true, "Pool.starmap.__qualname__ == 'Pool.starmap' (len=12); verified with Python 3.14.3"]
    - [stmap_qn_len,   "multiprocessing.pool.Pool.starmap.__qualname__.__len__", [],              12,   "Pool.starmap.__qualname__.__len__() == 12; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra101
# ---------------------------------------------------------------------------

invariant multiprocessing_extra101.Process_terminate_qualname_longest_in_spec:
  description: "multiprocessing.Process.terminate.__qualname__.__len__() == 21 — Process.terminate.__qualname__ is 'BaseProcess.terminate' (21 chars: 'BaseProcess.'=12 + 'terminate'=9); this is the longest Process method qualname in this spec; the full ranking of Process method qualname lengths (ordered): run=15, join=16, kill=16, start=17, close=17, is_alive=20, __init__=20, terminate=21; Process.terminate sends SIGTERM (Unix) or calls TerminateProcess (Windows); Process.terminate.__class__.__name__ is 'function' (pure Python in Lib/multiprocessing/process.py); all Process methods use 'BaseProcess.' prefix because the implementations live in BaseProcess; NEW in extra101: first standalone Process.terminate qualname longest invariant in mprocmq101 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: multiprocessing.Process.terminate.__qualname__.__len__
  args: []
  expected: 21

invariant multiprocessing_extra101.Process_init_qualname_eq:
  description: "multiprocessing.Process.__init__.__qualname__.__eq__('BaseProcess.__init__') returns True — Process.__init__ has qualname 'BaseProcess.__init__' (len=20: 'BaseProcess.'=12 + '__init__'=8); even __init__ is inherited from BaseProcess rather than defined in Process itself; Process.__init__ is tied in length with Process.is_alive.__qualname__ (both len=20); both 'BaseProcess.__init__' and 'BaseProcess.is_alive' have 20 chars because '__init__'=8 and 'is_alive'=8 are equal length; Process.__init__ handles creation of Process attributes like _name, _args, _kwargs, _target, _daemon; Process.__init__.__class__.__name__ is 'function'; NEW in extra101: first standalone Process.__init__ qualname invariant in mprocmq101 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__qualname__.__eq__
  args: ["BaseProcess.__init__"]
  expected: true

invariant multiprocessing_extra101.Process_run_qualname_shortest:
  description: "multiprocessing.Process.run.__qualname__.__len__() == 15 — Process.run.__qualname__ is 'BaseProcess.run' (15 chars: 'BaseProcess.'=12 + 'run'=3); this is the shortest Process method qualname in this spec because 'run' is the shortest 3-char method name; the full length ranking: run=15, join=16, kill=16, start=17, close=17, is_alive=20, __init__=20, terminate=21; Process.run is the method that runs in the child process — users override it to define process behavior; Process.run.__class__.__name__ is 'function'; all Process methods inherit from BaseProcess so the minimum qualname length is 12 (prefix) + len(method_name); NEW in extra101: first standalone Process.run qualname shortest invariant in mprocmq101 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: multiprocessing.Process.run.__qualname__.__len__
  args: []
  expected: 15

invariant multiprocessing_extra101.Pool_starmap_qualname_len_12:
  description: "multiprocessing.pool.Pool.starmap.__qualname__.__len__() == 12 — Pool.starmap.__qualname__ is 'Pool.starmap' (12 chars: 'Pool.'=5 + 'starmap'=7); Pool.starmap is defined directly in Pool (not inherited) so the qualname uses 'Pool.' prefix (5 chars, much shorter than 'BaseProcess.' = 12 chars); Pool.starmap applies a function to each element of an iterable where each element is an iterable of arguments (unpacked via *); compare Pool method qualname lengths: map=8, apply=10, starmap=12 — each 2 chars longer; Pool.starmap.__class__.__name__ is 'function' (pure Python in Lib/multiprocessing/pool.py); NEW in extra101: first standalone Pool.starmap qualname length invariant in mprocmq101 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: "multiprocessing.pool.Pool.starmap.__qualname__.__len__"
  args: []
  expected: 12

invariant multiprocessing_extra101.Process_close_qualname_tied_with_start:
  description: "multiprocessing.Process.close.__qualname__.__eq__('BaseProcess.close') returns True — Process.close.__qualname__ is 'BaseProcess.close' (len=17: 'BaseProcess.'=12 + 'close'=5); this is tied in length with Process.start.__qualname__.__len__()==17 ('BaseProcess.'=12 + 'start'=5); both 'close' and 'start' are 5-char words; Process.close() releases resources associated with a process — it must be called on processes that were not joined; Process.close is inherited from BaseProcess; Process.close.__class__.__name__ is 'function'; the tie cluster at len=17 is: start and close; at len=16: join and kill; at len=20: is_alive and __init__; NEW in extra101: first standalone Process.close qualname invariant in mprocmq101 namespace; wave 254; verified with Python 3.14.3"
  category: method_names
  kind: python_call_eq
  function: multiprocessing.Process.close.__qualname__.__eq__
  args: ["BaseProcess.close"]
  expected: true

