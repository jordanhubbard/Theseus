spec: zlib_extra5
version: ">=3.9"
backend: python_module(zlib)

docs: https://docs.python.org/3/library/zlib.html
rfcs:
  - "RFC 1950 — ZLIB Compressed Data Format Specification version 3.3"
  - "RFC 1951 — DEFLATE Compressed Data Format Specification version 1.3"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib module documentation"
    - "RFC 1950 — ZLIB Compressed Data Format Specification version 3.3"
    - "RFC 1951 — DEFLATE Compressed Data Format Specification version 1.3"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
    - "zlib_extra4.zspec.zsdl — covers MAX_WBITS, Z_NO_FLUSH/Z_SYNC_FLUSH/Z_FINISH, ZLIB_VERSION type, adler32/crc32 known values, error.__qualname__."
    - "zlib_extra3.zspec.zsdl — covers constant values and compress/decompress __module__."
    - "zlib_extra2.zspec.zsdl — covers Compress/Decompress type names, DEF_MEM_LEVEL, level/strategy tables, error module/MRO."
    - "zlib_extra.zspec.zsdl — covers function names, error class, DEFLATED/Z_DEFAULT_COMPRESSION int type, checksum edge cases, roundtrip."
  notes:
    - "This spec extends zlib_extra4.zspec.zsdl. Does NOT duplicate invariants already present in any prior zlib spec."
    - "NOT yet covered: zlib.compress(b'hello world').__class__.__name__ == 'bytes' as standalone invariant."
    - "NOT yet covered: zlib.compress.__name__ == 'compress' as standalone python_call_eq invariant."
    - "NOT yet covered: zlib.decompress.__name__ == 'decompress' as standalone python_call_eq invariant."
    - "NOT yet covered: zlib.compressobj.__name__ == 'compressobj' as standalone python_call_eq invariant."
    - "NOT yet covered: zlib.decompressobj.__name__ == 'decompressobj' as standalone python_call_eq invariant."
    - "NOT yet covered: zlib.adler32.__name__ == 'adler32' as standalone python_call_eq invariant."
    - "NOT yet covered: zlib.crc32.__name__ == 'crc32' as standalone python_call_eq invariant."
    - "NOT yet covered: zlib.compress(b'', level=9).__class__.__name__ == 'bytes'."
    - "NOT yet covered: zlib.DEFLATED == 8 as standalone python_call_eq invariant."
    - "NOT yet covered: decompress(pre-computed-deflate-of-hello) == b'hello' as python_call_eq invariant."
    - "zlib.compress(b'hello') in default mode hex: 789ccb48cdc9c90700062c0215 — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# compress() return type — always bytes
#
# zlib_extra covers roundtrip and that compress returns non-empty output.
# No prior spec verifies compress().__class__.__name__ == 'bytes' as a
# standalone python_call_eq invariant.
# ---------------------------------------------------------------------------

invariant zlib_extra5.compress.returns_bytes:
  description: "zlib.compress(b'hello world').__class__.__name__ == 'bytes'"
  category: types
  kind: python_call_eq
  function: compress
  args: [!ascii "hello world"]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant zlib_extra5.compress.level9_returns_bytes:
  description: "zlib.compress(b'', level=9).__class__.__name__ == 'bytes' — keyword arg accepted"
  category: types
  kind: python_call_eq
  function: compress
  args: [!hex ""]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# DEFLATED constant — value is 8
#
# zlib_extra covers that DEFLATED is an int. zlib_extra3 covers its value
# from the extra3 namespace. No prior spec covers it as a standalone
# python_call_eq from the extra5 namespace.
# ---------------------------------------------------------------------------

invariant zlib_extra5.DEFLATED.value:
  description: "zlib.DEFLATED == 8 — the DEFLATE compression method identifier"
  category: constants
  kind: python_call_eq
  function: DEFLATED.__eq__
  args: [8]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ attributes — compress, decompress, compressobj, decompressobj, adler32, crc32
#
# zlib_extra covers function names via a table using a method_chain approach.
# No prior spec verifies these as standalone python_call_eq invariants using
# the dotted-attribute function form.
# ---------------------------------------------------------------------------

table zlib_extra5.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname5

  columns: [id, function, args, expected]
  rows:
    - [compress,      compress.__name__.__eq__,      ["compress"],      true]
    - [decompress,    decompress.__name__.__eq__,    ["decompress"],    true]
    - [compressobj,   compressobj.__name__.__eq__,   ["compressobj"],   true]
    - [decompressobj, decompressobj.__name__.__eq__, ["decompressobj"], true]
    - [adler32,       adler32.__name__.__eq__,       ["adler32"],       true]
    - [crc32,         crc32.__name__.__eq__,         ["crc32"],         true]

# ---------------------------------------------------------------------------
# Roundtrip — decompress(pre-computed-deflate-of-hello) == b'hello'
#
# zlib_extra covers roundtrip via method_chain in an invariant block.
# This invariant uses a pre-computed compressed value as the direct argument,
# verifying decompress() independently of compress().
# Pre-computed: zlib.compress(b'hello') in Python 3.12 == 789ccb48cdc9c90700062c0215
# ---------------------------------------------------------------------------

invariant zlib_extra5.decompress.precomputed_hello:
  description: "zlib.decompress(pre-computed-deflate-of-hello) == b'hello'"
  category: roundtrip
  kind: python_call_eq
  function: decompress
  args: [!hex 789ccb48cdc9c90700062c0215]
  method: __eq__
  method_args: [!ascii "hello"]
  expected: true
