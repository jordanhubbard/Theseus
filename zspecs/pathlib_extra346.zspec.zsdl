spec: pathlib_extra346
version: ">=3.4"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "pathlib.__name__ == 'pathlib' — the module name attribute."
    - "pathlib.__package__ == 'pathlib' — pathlib is a package (contains sub-modules); verified with Python 3.14.3."
    - "pathlib.__spec__.name == 'pathlib' — the ModuleSpec name matches the module name."
    - "pathlib.__all__ is a list with 7 elements; verified with Python 3.14.3."
    - "pathlib.__all__.__contains__('Path') == True — Path is in the public API."
    - "pathlib.__all__.__contains__('PurePath') == True — PurePath is in the public API."
    - "pathlib.__all__.__contains__('PurePosixPath') == True — PurePosixPath is in the public API."
    - "pathlib.__doc__.__class__.__name__ == 'str' — the module has a docstring."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.__name__ — module identity
# ---------------------------------------------------------------------------

invariant pathlib_extra346.module_name:
  description: "pathlib.__name__ == 'pathlib'"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__eq__
  args: ["pathlib"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.__package__ — pathlib is itself a package
# ---------------------------------------------------------------------------

invariant pathlib_extra346.module_package:
  description: "pathlib.__package__ == 'pathlib' — pathlib is a package"
  category: module_metadata
  kind: python_call_eq
  function: __package__.__eq__
  args: ["pathlib"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.__spec__.name — ModuleSpec name
# ---------------------------------------------------------------------------

invariant pathlib_extra346.spec_name:
  description: "pathlib.__spec__.name == 'pathlib'"
  category: module_metadata
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["pathlib"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.__all__ — class and length
# ---------------------------------------------------------------------------

invariant pathlib_extra346.all_is_list:
  description: "pathlib.__all__.__class__.__name__ == 'list'"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant pathlib_extra346.all_len:
  description: "len(pathlib.__all__) == 7"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# pathlib.__all__ membership — selected public names
# ---------------------------------------------------------------------------

invariant pathlib_extra346.all_contains_Path:
  description: "pathlib.__all__.__contains__('Path') == True"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Path"]
  expected: true

invariant pathlib_extra346.all_contains_PurePath:
  description: "pathlib.__all__.__contains__('PurePath') == True"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__contains__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra346.all_contains_PurePosixPath:
  description: "pathlib.__all__.__contains__('PurePosixPath') == True"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__contains__
  args: ["PurePosixPath"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.__doc__ — module has a docstring (type check)
# ---------------------------------------------------------------------------

invariant pathlib_extra346.doc_is_str:
  description: "pathlib.__doc__.__class__.__name__ == 'str'"
  category: module_metadata
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
