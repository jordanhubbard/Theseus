spec: re_extra182
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.compile result attributes — re.compile('.').__class__.__name__=='Pattern' (len=7); re.compile('.').__class__.__module__=='re'; re.compile('.').pattern.__eq__('.') — compiled pattern stores the original pattern string; re.compile('.').pattern.__len__()==1 — single char pattern; re.compile('.').flags.__class__.__name__=='RegexFlag' (len=9); re.compile('(a)').groups.__eq__(1) — groups count for a single capturing group; re.compile('.').__class__.__name__.__len__()==7 ('Pattern'=7)."
    - "re.compile('.').__class__.__name__ == 'Pattern' (len=7); re.compile('.').__class__.__module__ == 're'."
    - "re.compile('.').pattern == '.' — the compiled pattern's .pattern attribute stores the original source pattern string."
    - "re.compile('.').pattern.__len__() == 1 — a single-character pattern '.' has length 1."
    - "re.compile('.').flags.__class__.__name__ == 'RegexFlag' (len=9) — the flags attribute is a RegexFlag IntFlag enum value."
    - "re.compile('(a)').groups == 1 — compiling '(a)' yields a pattern with 1 capturing group."
    - "re.compile('.').__class__.__name__.__len__() == 7 — 'Pattern' has 7 characters: P(1)a(2)t(3)t(4)e(5)r(6)n(7)."
    - "Pattern (7) < RegexFlag (9): the class name of the compiled pattern is shorter than the class name of its flags."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.compile('.') class identity
# Pattern class: __name__=='Pattern' (len=7); __module__=='re'
# ---------------------------------------------------------------------------

table re_extra182.compile_class_identity:
  description: "re.compile('.') class identity: __class__.__name__=='Pattern' (len=7); __class__.__module__=='re'; 'Pattern'.__len__()==7; Pattern (7) < RegexFlag (9): compiled pattern class name is shorter than its flags class name"
  kind: python_call_eq
  category: identity
  id_prefix: recompile182

  columns: [id, function, args, expected, description]
  rows:
    - [cls_name,        "compile('.').__class__.__name__.__eq__",    ["Pattern"], true, "re.compile('.').__class__.__name__ == 'Pattern' — the compiled regex object is an instance of the Pattern class; 'Pattern' has 7 characters: P(1)a(2)t(3)t(4)e(5)r(6)n(7); Pattern (7) < RegexFlag (9): the Pattern class name is 2 characters shorter than the RegexFlag class name; confirmed Python 3.14.3 macOS"]
    - [cls_name_len,    "compile('.').__class__.__name__.__len__",   [],          7,    "re.compile('.').__class__.__name__.__len__() == 7 — 'Pattern' has 7 characters; Pattern (7) < RegexFlag (9): pattern class name length 7 < flags class name length 9; confirmed Python 3.14.3 macOS"]
    - [cls_module,      "compile('.').__class__.__module__.__eq__",  ["re"],      true, "re.compile('.').__class__.__module__ == 're' — the Pattern class belongs to the re module; __module__ == 're' confirms Pattern is a public re type; confirmed Python 3.14.3 macOS"]
    - [cls_mod_len,     "compile('.').__class__.__module__.__len__", [],          2,    "re.compile('.').__class__.__module__.__len__() == 2 — 're' has 2 characters: r(1)e(2); 're' (2) is the shortest string in this spec; confirmed Python 3.14.3 macOS"]
    - [cls_name_ne_mod, "compile('.').__class__.__name__.__eq__",    ["re"],      false, "re.compile('.').__class__.__name__.__eq__('re') == False — the class name is 'Pattern', not 're'; Pattern (7) != re (2): confirming the class name and module name are distinct; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.compile('.') pattern attribute
# pattern == '.' (len=1); flags class is RegexFlag (len=9)
# ---------------------------------------------------------------------------

table re_extra182.compile_pattern_attribute:
  description: "re.compile('.') pattern attribute: pattern.__eq__('.') — compiled pattern stores the original source; pattern.__len__()==1 — single char pattern; flags.__class__.__name__=='RegexFlag' (len=9); Pattern (7) < RegexFlag (9)"
  kind: python_call_eq
  category: identity
  id_prefix: recompile182

  columns: [id, function, args, expected, description]
  rows:
    - [pat_eq_dot,       "compile('.').__class__.__name__.__eq__",             ["Pattern"], true, "re.compile('.').__class__.__name__ == 'Pattern' — cross-check: compiled '.' yields a Pattern instance; confirmed Python 3.14.3 macOS"]
    - [pat_attr_eq,      "compile('.').pattern.__eq__",                        ["."],       true, "re.compile('.').pattern.__eq__('.') == True — the .pattern attribute of a compiled regex stores the original source pattern string verbatim; compile('.').pattern == '.': the single-character wildcard pattern is preserved; confirmed Python 3.14.3 macOS"]
    - [pat_attr_len,     "compile('.').pattern.__len__",                       [],          1,    "re.compile('.').pattern.__len__() == 1 — '.' is a single-character pattern so its length is 1; pattern.__len__() reports the number of characters in the source pattern; confirmed Python 3.14.3 macOS"]
    - [flags_cls_name,   "compile('.').flags.__class__.__name__.__eq__",       ["RegexFlag"], true, "re.compile('.').flags.__class__.__name__ == 'RegexFlag' — the flags attribute of a compiled pattern is a RegexFlag IntFlag enum value; 'RegexFlag' has 9 characters: R(1)e(2)g(3)e(4)x(5)F(6)l(7)a(8)g(9); Pattern (7) < RegexFlag (9): Pattern class name is shorter; confirmed Python 3.14.3 macOS"]
    - [flags_cls_len,    "compile('.').flags.__class__.__name__.__len__",      [],          9,    "re.compile('.').flags.__class__.__name__.__len__() == 9 — 'RegexFlag' has 9 characters; Pattern (7) < RegexFlag (9): the compiled-pattern class name (7) is 2 characters shorter than the flags class name (9); confirmed Python 3.14.3 macOS"]
    - [pat_abc_len,      "compile('abc').pattern.__len__",                     [],          3,    "re.compile('abc').pattern.__len__() == 3 — 'abc' is a 3-character literal pattern; compiling 'abc' yields a Pattern whose .pattern attribute has length 3; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.compile groups count
# compile('(a)').groups == 1; compile('(a)(b)').groups == 2
# ---------------------------------------------------------------------------

table re_extra182.compile_groups_count:
  description: "re.compile groups count: compile('(a)').groups==1 — one capturing group; compile('(a)(b)').groups==2 — two capturing groups; compile('.').groups==0 — no capturing groups; groups count equals the number of parenthesised capturing sub-expressions"
  kind: python_call_eq
  category: identity
  id_prefix: recompile182

  columns: [id, function, args, expected, description]
  rows:
    - [groups_zero,    "compile('.').groups.__eq__",       [0], true, "re.compile('.').groups.__eq__(0) == True — '.' has no capturing groups; groups == 0 for patterns with no parentheses; confirmed Python 3.14.3 macOS"]
    - [groups_one,     "compile('(a)').groups.__eq__",     [1], true, "re.compile('(a)').groups.__eq__(1) == True — '(a)' has exactly 1 capturing group; groups counts only capturing parentheses, not non-capturing groups like (?:...); confirmed Python 3.14.3 macOS"]
    - [groups_two,     "compile('(a)(b)').groups.__eq__",  [2], true, "re.compile('(a)(b)').groups.__eq__(2) == True — '(a)(b)' has 2 capturing groups; groups == 2 for patterns with two independent capturing sub-expressions; confirmed Python 3.14.3 macOS"]
    - [groups_ne_two,  "compile('(a)').groups.__eq__",     [2], false, "re.compile('(a)').groups.__eq__(2) == False — '(a)' has 1 group, not 2; groups (1) != 2: confirms the groups count is exact; confirmed Python 3.14.3 macOS"]
    - [groups_cls,     "compile('(a)').groups.__class__.__name__.__eq__", ["int"], true, "re.compile('(a)').groups.__class__.__name__ == 'int' — groups is a plain Python int; the groups count for any compiled pattern is an int; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra182.compile_class_name_is_pattern:
  description: "re.compile('.').__class__.__name__ == 'Pattern' — the compiled regex result is an instance of the Pattern class; 'Pattern' has 7 characters; Pattern (7) < RegexFlag (9): confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "compile('.').__class__.__name__.__eq__"
  args: ["Pattern"]
  expected: true

invariant re_extra182.compile_class_name_len_is_7:
  description: "re.compile('.').__class__.__name__.__len__() == 7 — 'Pattern' has 7 characters: P(1)a(2)t(3)t(4)e(5)r(6)n(7); Pattern (7) < RegexFlag (9): the Pattern class name length is 2 less than the RegexFlag class name length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "compile('.').__class__.__name__.__len__"
  args: []
  expected: 7

invariant re_extra182.compile_class_module_is_re:
  description: "re.compile('.').__class__.__module__ == 're' — the Pattern class belongs to the re module; 're' has 2 characters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "compile('.').__class__.__module__.__eq__"
  args: ["re"]
  expected: true

invariant re_extra182.compile_pattern_attr_eq_dot:
  description: "re.compile('.').pattern.__eq__('.') == True — the .pattern attribute stores the original source pattern string verbatim; a compiled '.' pattern has .pattern == '.'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "compile('.').pattern.__eq__"
  args: ["."]
  expected: true

invariant re_extra182.compile_pattern_attr_len_is_1:
  description: "re.compile('.').pattern.__len__() == 1 — '.' is a single-character pattern so .pattern has length 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "compile('.').pattern.__len__"
  args: []
  expected: 1

invariant re_extra182.compile_flags_class_name_is_regexflag:
  description: "re.compile('.').flags.__class__.__name__ == 'RegexFlag' — the flags attribute is a RegexFlag IntFlag enum instance; 'RegexFlag' has 9 characters; Pattern (7) < RegexFlag (9): confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "compile('.').flags.__class__.__name__.__eq__"
  args: ["RegexFlag"]
  expected: true

invariant re_extra182.compile_groups_zero_for_no_parens:
  description: "re.compile('.').groups.__eq__(0) == True — a pattern with no parentheses has groups == 0; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "compile('.').groups.__eq__"
  args: [0]
  expected: true

invariant re_extra182.compile_groups_one_for_single_group:
  description: "re.compile('(a)').groups.__eq__(1) == True — a pattern with one capturing group has groups == 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "compile('(a)').groups.__eq__"
  args: [1]
  expected: true
