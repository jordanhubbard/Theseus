spec: decimal_extra266
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "decimal.Decimal is a C-extension class; its conversion dunder methods are wrapper_descriptor objects."
    - "Decimal conversion methods: __int__, __float__, __str__, __repr__, __bool__, __neg__, __pos__, __abs__ all have __class__.__name__ == 'wrapper_descriptor'."
    - "Decimal conversion method qualnames follow 'Decimal.<method_name>' pattern."
    - "decimal.Decimal.__name__ == 'Decimal' and decimal.Decimal.__module__ == 'decimal'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: Decimal conversion method __name__ identity
# ---------------------------------------------------------------------------

table decimal_extra266.decimal_conversion_method_names:
  description: "decimal.Decimal conversion dunder method __name__ for __int__, __float__, __str__, __repr__, __bool__, __neg__, __pos__, __abs__"
  kind: python_call_eq
  category: identity
  id_prefix: nm

  columns: [id, function, args, expected, description]
  rows:
    - [int_name,   Decimal.__int__.__name__.__eq__,   ["__int__"],   true, "decimal.Decimal.__int__.__name__ == '__int__'"]
    - [float_name, Decimal.__float__.__name__.__eq__, ["__float__"], true, "decimal.Decimal.__float__.__name__ == '__float__'"]
    - [str_name,   Decimal.__str__.__name__.__eq__,   ["__str__"],   true, "decimal.Decimal.__str__.__name__ == '__str__'"]
    - [repr_name,  Decimal.__repr__.__name__.__eq__,  ["__repr__"],  true, "decimal.Decimal.__repr__.__name__ == '__repr__'"]
    - [bool_name,  Decimal.__bool__.__name__.__eq__,  ["__bool__"],  true, "decimal.Decimal.__bool__.__name__ == '__bool__'"]
    - [neg_name,   Decimal.__neg__.__name__.__eq__,   ["__neg__"],   true, "decimal.Decimal.__neg__.__name__ == '__neg__'"]
    - [pos_name,   Decimal.__pos__.__name__.__eq__,   ["__pos__"],   true, "decimal.Decimal.__pos__.__name__ == '__pos__'"]
    - [abs_name,   Decimal.__abs__.__name__.__eq__,   ["__abs__"],   true, "decimal.Decimal.__abs__.__name__ == '__abs__'"]

# ---------------------------------------------------------------------------
# Table: Decimal conversion method __class__.__name__ (all wrapper_descriptor)
# ---------------------------------------------------------------------------

table decimal_extra266.decimal_conversion_method_classes:
  description: "decimal.Decimal conversion dunder method __class__.__name__ for __int__, __float__, __str__, __repr__, __bool__, __neg__, __pos__, __abs__ (all wrapper_descriptor)"
  kind: python_call_eq
  category: identity
  id_prefix: cls

  columns: [id, function, args, expected, description]
  rows:
    - [int_class,   Decimal.__int__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "decimal.Decimal.__int__.__class__.__name__ == 'wrapper_descriptor'"]
    - [float_class, Decimal.__float__.__class__.__name__.__eq__, ["wrapper_descriptor"], true, "decimal.Decimal.__float__.__class__.__name__ == 'wrapper_descriptor'"]
    - [str_class,   Decimal.__str__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "decimal.Decimal.__str__.__class__.__name__ == 'wrapper_descriptor'"]
    - [repr_class,  Decimal.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true, "decimal.Decimal.__repr__.__class__.__name__ == 'wrapper_descriptor'"]
    - [bool_class,  Decimal.__bool__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true, "decimal.Decimal.__bool__.__class__.__name__ == 'wrapper_descriptor'"]
    - [neg_class,   Decimal.__neg__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "decimal.Decimal.__neg__.__class__.__name__ == 'wrapper_descriptor'"]
    - [pos_class,   Decimal.__pos__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "decimal.Decimal.__pos__.__class__.__name__ == 'wrapper_descriptor'"]
    - [abs_class,   Decimal.__abs__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "decimal.Decimal.__abs__.__class__.__name__ == 'wrapper_descriptor'"]

# ---------------------------------------------------------------------------
# Standalone invariants: qualnames and Decimal class identity
# ---------------------------------------------------------------------------

invariant decimal_extra266.Decimal.__int__.qualname:
  description: "decimal.Decimal.__int__.__qualname__ == 'Decimal.__int__'"
  category: identity
  kind: python_call_eq
  function: Decimal.__int__.__qualname__.__eq__
  args: ["Decimal.__int__"]
  expected: true

invariant decimal_extra266.Decimal.__float__.qualname:
  description: "decimal.Decimal.__float__.__qualname__ == 'Decimal.__float__'"
  category: identity
  kind: python_call_eq
  function: Decimal.__float__.__qualname__.__eq__
  args: ["Decimal.__float__"]
  expected: true

invariant decimal_extra266.Decimal.__str__.qualname:
  description: "decimal.Decimal.__str__.__qualname__ == 'Decimal.__str__'"
  category: identity
  kind: python_call_eq
  function: Decimal.__str__.__qualname__.__eq__
  args: ["Decimal.__str__"]
  expected: true

invariant decimal_extra266.Decimal.__bool__.qualname:
  description: "decimal.Decimal.__bool__.__qualname__ == 'Decimal.__bool__'"
  category: identity
  kind: python_call_eq
  function: Decimal.__bool__.__qualname__.__eq__
  args: ["Decimal.__bool__"]
  expected: true

invariant decimal_extra266.Decimal.__neg__.qualname:
  description: "decimal.Decimal.__neg__.__qualname__ == 'Decimal.__neg__'"
  category: identity
  kind: python_call_eq
  function: Decimal.__neg__.__qualname__.__eq__
  args: ["Decimal.__neg__"]
  expected: true

invariant decimal_extra266.Decimal.__abs__.qualname:
  description: "decimal.Decimal.__abs__.__qualname__ == 'Decimal.__abs__'"
  category: identity
  kind: python_call_eq
  function: Decimal.__abs__.__qualname__.__eq__
  args: ["Decimal.__abs__"]
  expected: true

invariant decimal_extra266.Decimal.name:
  description: "decimal.Decimal.__name__ == 'Decimal'"
  category: identity
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra266.Decimal.module:
  description: "decimal.Decimal.__module__ == 'decimal'"
  category: identity
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true
