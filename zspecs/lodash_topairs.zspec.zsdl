spec: lodash_topairs
version: ">=4.0.0"
backend: node(lodash.topairs)

docs: https://lodash.com/docs/#toPairs

provenance:
  derived_from:
    - "lodash.topairs README — https://www.npmjs.com/package/lodash.topairs"
    - "Test vectors verified with lodash.topairs@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.topairs exports the _.toPairs function directly as module.exports."
    - "toPairs(object) returns an array of [key, value] pairs."
    - "Equivalent to Object.entries()."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of [key, value] pairs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_topairs.topairs:
  kind: node_module_call_eq
  function: ~
  category: topairs
  id_prefix: ltp

  columns: [id, args, expected]
  rows:
    - [basic,  [{"a": 1, "b": 2}],   [["a", 1], ["b", 2]]]
    - [one,    [{"x": 42}],           [["x", 42]]]
    - [empty,  [{}],                   []]
