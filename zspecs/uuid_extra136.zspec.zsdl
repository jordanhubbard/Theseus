spec: uuid_extra136
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra135.zspec.zsdl — covers uuid.UUID.hex/urn/variant/version/bytes/fields/__class__.__name__=='property' / UUID.int/__class__.__name__=='member_descriptor' / UUID.int/__qualname__.__eq__('UUID.int') / property fget __qualname__ lengths for hex/urn/variant/version/fields/node/time (table + invariants)."
    - "uuid_extra134.zspec.zsdl — covers uuid.UUID.__init__/__str__/__repr__/__hash__/__eq__/__lt__ __qualname__ lengths (13/12/13/13/11/11) / __qualname__ equality strings / __slots__ class name/length / UUID.__bases__[0].__name__=='object' (table + invariants)."
    - "uuid_extra133.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5/UUID __doc__.__class__.__name__=='str' / uuid3 vs uuid5 __doc__ inequality and gap (2) / uuid1 vs uuid4 gap (235) / UUID class vs __init__ doc gap (1367)."
    - "uuid_extra132.zspec.zsdl — covers uuid1/uuid4/uuid3/uuid5/getnode __code__.co_consts lengths / co_varnames lengths / UUID.__init__.__code__ attribute counts."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/qualname / UUID method qualname equality and length."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants __class__.__name__, hex values, str() values, version attributes."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant / type(UUID.hex).__name__=='property'."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality / UUID.__module__.__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__.__eq__ / SafeUUID.__bases__[0].__name__=='Enum'."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 / uuid3/uuid5/getnode __qualname__.__len__()."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra135."
    - "Wave 303 theme: uuid.UUID.__lt__/__gt__/__le__/__ge__ comparison operator __qualname__ string equality (all 'UUID.<method>', len 11) / UUID.__int__ __qualname__.__eq__('UUID.__int__') and __len__()==12 / __lt__/__gt__/__le__/__ge__/__eq__ all __class__.__name__=='function' / UUID.__ne__.__class__.__name__=='wrapper_descriptor' (inherited from object)."
    - "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__gt__.__qualname__ == 'UUID.__gt__' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__qualname__ == 'UUID.__le__' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ge__.__qualname__ == 'UUID.__ge__' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__qualname__ == 'UUID.__int__' (len 12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__class__.__name__ == 'function' (Python-level in Lib/uuid.py). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__gt__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ge__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ne__.__qualname__ == 'object.__ne__' (len 13; inherited from object, not overridden). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ne__.__class__.__name__ == 'wrapper_descriptor' (not 'function'; C-level slot wrapper from object). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID defines __lt__, __gt__, __le__, __ge__, __eq__ as Python functions (for ordering UUIDs by their integer value). It does NOT define __ne__ — that is inherited from object as a wrapper_descriptor. __ne__ has qualname 'object.__ne__' (13 chars) rather than 'UUID.__ne__'. This is a key behavioral distinction: UUID overrides all ordering operators but relies on object's __ne__ implementation."
    - "Note: uuid.UUID.__int__.__qualname__ is 'UUID.__int__' (12 chars = 5-char 'UUID.' prefix + 7-char '__int__'). At 12 chars it is one char longer than the comparison operator qualnames (11 chars = 5 + 6) because '__int__' (7 chars) is one char longer than '__lt__'/'__gt__'/'__le__'/'__ge__'/__eq__' (6 chars each)."
    - "Note: The four ordering operators __lt__/__gt__/__le__/__ge__ all have qualname length 11 ('UUID.' + 6-char dunder). They are defined in Lib/uuid.py and compare UUIDs by converting to int and using integer comparison. extra134 anchors __lt__ and __eq__ qualname lengths at 11; this spec anchors the full set of comparison operators including __gt__/__le__/__ge__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__lt__.__qualname__.__eq__('UUID.__lt__')
# uuid.UUID.__gt__.__qualname__.__eq__('UUID.__gt__')
# uuid.UUID.__le__.__qualname__.__eq__('UUID.__le__')
# uuid.UUID.__ge__.__qualname__.__eq__('UUID.__ge__')
# all four __qualname__.__len__()==11
#
# Wave 303 theme: UUID comparison operator __qualname__ string equality.
#
# All four ordering operators follow the 'UUID.<method>' qualname pattern with the
# 5-char 'UUID.' prefix plus the 6-char dunder name, giving qualname length 11.
# extra134 anchors __lt__ and __eq__ qualname lengths; no prior uuid spec anchors
# __gt__/__le__/__ge__ qualname equality strings as a table under uuidcmp136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra136.UUID_comparison_qualname_equality:
  description: "uuid.UUID.__lt__/__qualname__.__eq__('UUID.__lt__')==True / __gt__/__qualname__.__eq__('UUID.__gt__')==True / __le__/__qualname__.__eq__('UUID.__le__')==True / __ge__/__qualname__.__eq__('UUID.__ge__')==True / all four __qualname__.__len__()==11 — all follow 'UUID.<method>' pattern (5-char prefix + 6-char dunder); Python functions in Lib/uuid.py; extra134 anchors __lt__ length; first uuidcmp136 anchor for __gt__/__le__/__ge__ equality strings"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: uuidcmp136

  columns: [id, function, args, expected, description]
  rows:
    - [lt_qualname_eq,  UUID.__lt__.__qualname__.__eq__, ["UUID.__lt__"], true, "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__' (11 chars; 5-char prefix + 6-char '__lt__')"]
    - [gt_qualname_eq,  UUID.__gt__.__qualname__.__eq__, ["UUID.__gt__"], true, "uuid.UUID.__gt__.__qualname__ == 'UUID.__gt__' (11 chars; same pattern as __lt__)"]
    - [le_qualname_eq,  UUID.__le__.__qualname__.__eq__, ["UUID.__le__"], true, "uuid.UUID.__le__.__qualname__ == 'UUID.__le__' (11 chars; less-than-or-equal operator)"]
    - [ge_qualname_eq,  UUID.__ge__.__qualname__.__eq__, ["UUID.__ge__"], true, "uuid.UUID.__ge__.__qualname__ == 'UUID.__ge__' (11 chars; greater-than-or-equal operator)"]
    - [lt_qualname_len, UUID.__lt__.__qualname__.__len__, [],             11,   "uuid.UUID.__lt__.__qualname__.__len__() is 11 ('UUID.__lt__' = 5 + 6 chars)"]
    - [gt_qualname_len, UUID.__gt__.__qualname__.__len__, [],             11,   "uuid.UUID.__gt__.__qualname__.__len__() is 11 (ties with __lt__/__le__/__ge__)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__int__.__qualname__.__eq__('UUID.__int__')
# uuid.UUID.__int__.__qualname__.__len__()==12
# uuid.UUID.__int__.__class__.__name__.__eq__('function')
# uuid.UUID.__ne__.__class__.__name__.__eq__('wrapper_descriptor')
#
# Wave 303 theme: UUID.__int__ (Python function, len 12) vs __ne__ (inherited, wrapper_descriptor).
#
# UUID.__int__ has qualname 'UUID.__int__' (12 chars = 5 + 7) — one char longer than
# the 6-char comparison dunders (11 chars). UUID.__ne__ is NOT defined on UUID; it is
# inherited from object as a wrapper_descriptor with qualname 'object.__ne__'. This
# contrast shows that UUID defines all ordering operators but not __ne__.
# No prior uuid spec anchors UUID.__int__ qualname equality or UUID.__ne__
# class name as a table under uuidcmp136. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra136.UUID_int_and_ne_identity:
  description: "uuid.UUID.__int__/__qualname__.__eq__('UUID.__int__')==True / __qualname__.__len__()==12 / __class__.__name__.__eq__('function')==True / UUID.__ne__/__class__.__name__.__eq__('wrapper_descriptor')==True — __int__ is a 12-char-qualname Python function (5 + 7); __ne__ is inherited from object as wrapper_descriptor (not overridden by UUID); qualname is 'object.__ne__' (13 chars); no prior uuid spec anchors these under uuidcmp136"
  kind: python_call_eq
  category: identity
  id_prefix: uuidcmp136

  columns: [id, function, args, expected, description]
  rows:
    - [int_qualname_eq,       UUID.__int__.__qualname__.__eq__,       ["UUID.__int__"],      true, "uuid.UUID.__int__.__qualname__ == 'UUID.__int__' (12 chars = 5-char prefix + 7-char '__int__')"]
    - [int_qualname_len,      UUID.__int__.__qualname__.__len__,      [],                   12,   "uuid.UUID.__int__.__qualname__.__len__() is 12 (one char longer than comparison operators at 11)"]
    - [int_class_function,    UUID.__int__.__class__.__name__.__eq__, ["function"],          true, "uuid.UUID.__int__.__class__.__name__ == 'function' (Python-level in Lib/uuid.py)"]
    - [ne_class_wrapper,      UUID.__ne__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true, "uuid.UUID.__ne__.__class__.__name__ == 'wrapper_descriptor' (inherited from object; NOT overridden by UUID)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__lt__.__class__.__name__.__eq__('function')
# uuid.UUID.__gt__.__class__.__name__.__eq__('function')
# uuid.UUID.__le__.__class__.__name__.__eq__('function')
# uuid.UUID.__ge__.__class__.__name__.__eq__('function')
#
# Wave 303 theme: all four ordering operators are Python functions.
#
# uuid.UUID defines __lt__, __gt__, __le__, __ge__ as Python-level functions in
# Lib/uuid.py. This is in contrast to __ne__ which is a wrapper_descriptor inherited
# from object. extra134 anchors __init__/__str__/__repr__ as 'function'; no prior
# uuid spec anchors the four ordering operators as a class-name table under uuidcmp136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra136.UUID_ordering_operator_class_names:
  description: "uuid.UUID.__lt__/__class__.__name__.__eq__('function')==True / __gt__/__class__.__name__.__eq__('function')==True / __le__/__class__.__name__.__eq__('function')==True / __ge__/__class__.__name__.__eq__('function')==True — all four ordering operators are Python-level functions in Lib/uuid.py (not wrapper_descriptor); contrast with __ne__ which is wrapper_descriptor inherited from object; extra134 anchors __init__/__str__/__repr__ as 'function'; first uuidcmp136 anchor for ordering operator class names"
  kind: python_call_eq
  category: identity
  id_prefix: uuidcmp136

  columns: [id, function, args, expected, description]
  rows:
    - [lt_class_function, UUID.__lt__.__class__.__name__.__eq__, ["function"], true, "uuid.UUID.__lt__.__class__.__name__ == 'function' (Python-level; compares UUID integers)"]
    - [gt_class_function, UUID.__gt__.__class__.__name__.__eq__, ["function"], true, "uuid.UUID.__gt__.__class__.__name__ == 'function' (Python-level; mirrors __lt__)"]
    - [le_class_function, UUID.__le__.__class__.__name__.__eq__, ["function"], true, "uuid.UUID.__le__.__class__.__name__ == 'function' (Python-level; less-than-or-equal)"]
    - [ge_class_function, UUID.__ge__.__class__.__name__.__eq__, ["function"], true, "uuid.UUID.__ge__.__class__.__name__ == 'function' (Python-level; greater-than-or-equal)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__lt__.__qualname__.__eq__('UUID.__lt__') — standalone
#
# uuid.UUID.__lt__.__qualname__ is 'UUID.__lt__' (11 chars). UUID.__lt__ is a
# Python-level function that orders UUIDs by their 128-bit integer value. It is
# defined in Lib/uuid.py rather than inherited from a base class. The qualname
# 'UUID.__lt__' uses the 5-char 'UUID.' prefix plus '__lt__' (6 chars).
# extra134 anchors __lt__ qualname length (11); no prior uuid spec anchors
# UUID.__lt__.__qualname__ == 'UUID.__lt__' as a standalone under uuidcmp136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra136.UUID_lt_qualname_eq:
  description: "uuid.UUID.__lt__.__qualname__.__eq__('UUID.__lt__') == True — 'UUID.__lt__' (11 chars = 5-char 'UUID.' + 6-char '__lt__'); Python-level function ordering UUIDs by integer value; defined in Lib/uuid.py; extra134 anchors length (11); first standalone under uuidcmp136"
  category: qualname_identity
  kind: python_call_eq
  function: UUID.__lt__.__qualname__.__eq__
  args: ["UUID.__lt__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__gt__.__qualname__.__eq__('UUID.__gt__') — standalone
#
# uuid.UUID.__gt__.__qualname__ is 'UUID.__gt__' (11 chars). UUID.__gt__ is the
# greater-than comparison operator for UUIDs, implemented in Lib/uuid.py. It ties
# in qualname length with __lt__, __le__, and __ge__ (all 11 chars = 5 + 6). No
# prior uuid spec anchors UUID.__gt__.__qualname__ == 'UUID.__gt__' as a standalone
# under uuidcmp136. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra136.UUID_gt_qualname_eq:
  description: "uuid.UUID.__gt__.__qualname__.__eq__('UUID.__gt__') == True — 'UUID.__gt__' (11 chars = 5-char 'UUID.' + 6-char '__gt__'); greater-than comparison operator; Python-level function in Lib/uuid.py; ties in length with __lt__/__le__/__ge__ (all 11 chars); first standalone under uuidcmp136"
  category: qualname_identity
  kind: python_call_eq
  function: UUID.__gt__.__qualname__.__eq__
  args: ["UUID.__gt__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__int__.__qualname__.__len__()==12 — standalone
#
# uuid.UUID.__int__.__qualname__.__len__() is 12. The qualname 'UUID.__int__'
# consists of the 5-char 'UUID.' prefix plus the 7-char '__int__'. At 12 chars
# it is one char longer than the comparison operator qualnames (11 chars each),
# because '__int__' (7 chars) is one char longer than the comparison dunders
# '__lt__'/'__gt__'/'__le__'/'__ge__'/'__eq__' (6 chars each). UUID.__int__
# converts the UUID to its 128-bit integer value. No prior uuid spec anchors
# UUID.__int__.__qualname__.__len__()==12 as a standalone under uuidcmp136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra136.UUID_int_qualname_len_12:
  description: "uuid.UUID.__int__.__qualname__.__len__() == 12 — 'UUID.__int__' (12 chars = 5-char 'UUID.' + 7-char '__int__'); one char longer than comparison operator qualnames (11); '__int__' (7) is one char longer than '__lt__'/'__gt__' etc. (6 each); converts UUID to 128-bit integer; first standalone under uuidcmp136"
  category: qualname_lengths
  kind: python_call_eq
  function: UUID.__int__.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# uuid.UUID.__ne__.__class__.__name__.__eq__('wrapper_descriptor') — standalone
#
# uuid.UUID.__ne__.__class__.__name__ is 'wrapper_descriptor'. UUID does NOT
# define __ne__ — it is inherited from object as a C-level slot wrapper. The
# qualname 'object.__ne__' (13 chars) reveals the inheritance: the 7-char 'object.'
# prefix rather than the 5-char 'UUID.' prefix. This means UUID equality testing
# uses __eq__ (Python function, qualname 'UUID.__eq__', 11 chars) but inequality
# testing falls back to object's C-level __ne__ implementation. No prior uuid spec
# anchors UUID.__ne__.__class__.__name__ == 'wrapper_descriptor' as a standalone
# under uuidcmp136. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra136.UUID_ne_class_wrapper_descriptor:
  description: "uuid.UUID.__ne__.__class__.__name__.__eq__('wrapper_descriptor') == True — UUID does NOT define __ne__; inherited from object as C-level slot wrapper; qualname is 'object.__ne__' (13 chars) not 'UUID.__ne__'; contrast with __eq__/__lt__/__gt__/__le__/__ge__ which are Python functions; first standalone under uuidcmp136"
  category: identity
  kind: python_call_eq
  function: UUID.__ne__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__le__.__qualname__.__eq__('UUID.__le__') — standalone
#
# uuid.UUID.__le__.__qualname__ is 'UUID.__le__' (11 chars). __le__ is the
# less-than-or-equal operator: it returns True if the UUID's integer value is
# less than or equal to the other UUID's integer value. It is defined in
# Lib/uuid.py as a Python function, giving it the 'UUID.__le__' qualname rather
# than an inherited wrapper qualname. No prior uuid spec anchors
# UUID.__le__.__qualname__ == 'UUID.__le__' as a standalone under uuidcmp136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra136.UUID_le_qualname_eq:
  description: "uuid.UUID.__le__.__qualname__.__eq__('UUID.__le__') == True — 'UUID.__le__' (11 chars = 5 + 6); less-than-or-equal operator; Python-level function in Lib/uuid.py; same length as __lt__/__gt__/__ge__/__eq__ (all 6-char dunders = len 11); first standalone under uuidcmp136"
  category: qualname_identity
  kind: python_call_eq
  function: UUID.__le__.__qualname__.__eq__
  args: ["UUID.__le__"]
  expected: true
