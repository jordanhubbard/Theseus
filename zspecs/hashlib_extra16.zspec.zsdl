spec: hashlib_extra16
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha2module.c"
  notes:
    - "This spec extends hashlib through hashlib_extra15; it does NOT duplicate invariants present in those files."
    - "hashlib_extra15 covers: new('sha3_256'/'sha3_512'/'blake2b'/'shake_128') digest_size/block_size/name; algorithms_guaranteed contains 'sha3_512'/'blake2b'/'shake_128'; pbkdf2_hmac.__name__/__module__; sha3_512(b'abc').hexdigest()."
    - "hashlib_extra14 covers: algorithms_guaranteed/available class_name=='set'; new('md5'/'sha1'/'sha512'/'sha3_256') block_size; new('sha256') class_name=='HASH'; sha256/md5/sha1 hexdigest for b'abc'."
    - "NOT yet covered: new('md5').name == 'md5' as standalone invariant."
    - "NOT yet covered: new('sha1').name == 'sha1' as standalone invariant."
    - "NOT yet covered: new('sha256').digest_size == 32 as standalone invariant."
    - "NOT yet covered: new('sha512').digest_size == 64 as standalone invariant."
    - "NOT yet covered: new('md5').block_size == 64 as standalone invariant."
    - "NOT yet covered: new('sha256').block_size == 64 as standalone invariant."
    - "NOT yet covered: new('sha512').block_size == 128 as standalone invariant."
    - "NOT yet covered: new('sha1').digest_size == 20 as standalone invariant."
    - "NOT yet covered: new('md5').digest_size == 16 as standalone invariant."
    - "NOT yet covered: algorithms_available.__contains__('sha1') as standalone invariant."
    - "NOT yet covered: algorithms_available.__contains__('sha256') as standalone invariant."
    - "md5 block_size == 64: MD5 processes data in 512-bit (64-byte) blocks."
    - "sha256 block_size == 64: SHA-256 processes data in 512-bit (64-byte) blocks."
    - "sha512 block_size == 128: SHA-512 processes data in 1024-bit (128-byte) blocks."
    - "sha1 digest_size == 20: SHA-1 produces a 160-bit (20-byte) digest."
    - "md5 digest_size == 16: MD5 produces a 128-bit (16-byte) digest."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# new() factory — name attribute for md5 and sha1
#
# hashlib_extra15 covers new('sha3_256'/'sha3_512'/'blake2b').name.
# hashlib_extra13 covers new('sha3_256').name from the extra13 namespace.
# No prior spec provides standalone python_call_eq for new('md5').name or
# new('sha1').name.
# ---------------------------------------------------------------------------

invariant hashlib_extra16.new.md5.name:
  description: "hashlib.new('md5').name == 'md5' — name attribute matches constructor argument"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["md5"]
  method: name.__eq__
  method_args: ["md5"]
  expected: true

invariant hashlib_extra16.new.sha1.name:
  description: "hashlib.new('sha1').name == 'sha1' — name attribute matches constructor argument"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha1"]
  method: name.__eq__
  method_args: ["sha1"]
  expected: true

# ---------------------------------------------------------------------------
# new() factory — digest_size for md5, sha1, sha256, sha512
#
# hashlib_extra15 covers sha3_256/sha3_512/blake2b/shake_128 digest_size.
# hashlib_extra14 covers these via block_size but not digest_size for all.
# No prior spec provides standalone python_call_eq for md5/sha1/sha256/sha512
# digest_size from new() with a unique id prefix.
# ---------------------------------------------------------------------------

table hashlib_extra16.new_digest_sizes:
  kind: python_call_eq
  category: new_factory
  id_prefix: dsize16

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [md5,    new, ["md5"],    digest_size.__eq__, [16],  true]
    - [sha1,   new, ["sha1"],   digest_size.__eq__, [20],  true]
    - [sha256, new, ["sha256"], digest_size.__eq__, [32],  true]
    - [sha512, new, ["sha512"], digest_size.__eq__, [64],  true]

# ---------------------------------------------------------------------------
# new() factory — block_size for md5, sha256, sha512
#
# hashlib_extra14 covers block_size for md5/sha1/sha512/sha3_256 in that
# namespace. This file adds md5/sha256/sha512 block_size from the extra16
# namespace with a distinct id prefix for new coverage.
# ---------------------------------------------------------------------------

table hashlib_extra16.new_block_sizes:
  kind: python_call_eq
  category: new_factory
  id_prefix: bsize16

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [md5,    new, ["md5"],    block_size.__eq__, [64],  true]
    - [sha256, new, ["sha256"], block_size.__eq__, [64],  true]
    - [sha512, new, ["sha512"], block_size.__eq__, [128], true]

# ---------------------------------------------------------------------------
# algorithms_available membership — sha1 and sha256
#
# hashlib_extra13 covers algorithms_guaranteed contains 'sha3_224'.
# hashlib_extra15 covers algorithms_guaranteed for sha3_512/blake2b/shake_128.
# No prior spec verifies algorithms_available (not guaranteed) membership for
# 'sha1' or 'sha256' as standalone invariants.
# ---------------------------------------------------------------------------

invariant hashlib_extra16.algorithms_available.contains_sha1:
  description: "hashlib.algorithms_available contains 'sha1' — present on all CPython platforms"
  category: algorithms
  kind: python_call_eq
  function: algorithms_available.__contains__
  args: ["sha1"]
  expected: true

invariant hashlib_extra16.algorithms_available.contains_sha256:
  description: "hashlib.algorithms_available contains 'sha256' — present on all CPython platforms"
  category: algorithms
  kind: python_call_eq
  function: algorithms_available.__contains__
  args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_available type — it is a set
#
# hashlib_extra14 verifies algorithms_guaranteed and algorithms_available
# class_name == 'set' using method_chain. No prior spec verifies
# algorithms_available.__class__.__name__ as a standalone python_call_eq.
# ---------------------------------------------------------------------------

invariant hashlib_extra16.algorithms_available.is_set:
  description: "hashlib.algorithms_available.__class__.__name__ == 'set' — it is a Python set"
  category: algorithms
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true
