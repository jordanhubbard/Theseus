spec: os_extra7
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "CPython source: Lib/os.py"
  notes:
    - "This spec extends os.zspec.zsdl, os_environ.zspec.zsdl, os_extra.zspec.zsdl, os_extra2.zspec.zsdl, os_extra3.zspec.zsdl, os_extra4.zspec.zsdl, os_extra5.zspec.zsdl, os_extra6.zspec.zsdl."
    - "os_extra6.zspec.zsdl covers: PathLike.__name__=='PathLike', sep=='/' (POSIX), linesep=='\\n' (POSIX)."
    - "This spec adds: PathLike.__module__, stat_result class name and module, DirEntry class name, terminal_size class name, cpu_count/__name__, get_terminal_size/__name__, urandom/__name__, urandom(4) returns bytes of length 4, sep class name, linesep class name."
    - "os.PathLike.__module__ == 'os' — PathLike is defined in the os module."
    - "os.stat_result.__name__ == 'stat_result' — namedtuple-like class for stat() results."
    - "os.stat_result.__module__ == 'os' — stat_result is exported from the os module."
    - "os.DirEntry.__name__ == 'DirEntry' — class returned by scandir()."
    - "os.terminal_size.__name__ == 'terminal_size' — namedtuple subclass with columns/lines fields."
    - "os.cpu_count.__name__ == 'cpu_count' — returns number of logical CPUs or None."
    - "os.get_terminal_size.__name__ == 'get_terminal_size' — returns os.terminal_size."
    - "os.urandom.__name__ == 'urandom' — returns cryptographically strong random bytes."
    - "os.urandom(4).__class__.__name__ == 'bytes' — urandom always returns a bytes object."
    - "os.urandom(4).__len__() == 4 — urandom returns exactly as many bytes as requested."
    - "os.sep.__class__.__name__ == 'str' — the path separator is always a str."
    - "os.linesep.__class__.__name__ == 'str' — the line separator is always a str."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class names table — PathLike, stat_result, DirEntry, terminal_size
# ---------------------------------------------------------------------------

table os_extra7.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [PathLike,     PathLike.__name__.__eq__,     ["PathLike"],     true]
    - [stat_result,  stat_result.__name__.__eq__,  ["stat_result"],  true]
    - [DirEntry,     DirEntry.__name__.__eq__,     ["DirEntry"],     true]
    - [terminal_size, terminal_size.__name__.__eq__, ["terminal_size"], true]

# ---------------------------------------------------------------------------
# PathLike — __module__
# os_extra6 covers PathLike.__name__; this spec adds PathLike.__module__.
# ---------------------------------------------------------------------------

invariant os_extra7.PathLike.module:
  description: "os.PathLike.__module__ == 'os'"
  category: class_metadata
  kind: python_call_eq
  function: PathLike.__module__.__eq__
  args: ["os"]
  expected: true

# ---------------------------------------------------------------------------
# stat_result — class name and module
# ---------------------------------------------------------------------------

invariant os_extra7.stat_result.module:
  description: "os.stat_result.__module__ == 'os'"
  category: class_metadata
  kind: python_call_eq
  function: stat_result.__module__.__eq__
  args: ["os"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ checks — cpu_count, get_terminal_size, urandom
# os.zspec.zsdl table covers urandom and cpu_count as rows, but not as
# individually named invariants; this spec provides named invariants.
# ---------------------------------------------------------------------------

invariant os_extra7.cpu_count.name:
  description: "os.cpu_count.__name__ == 'cpu_count'"
  category: function_names
  kind: python_call_eq
  function: cpu_count.__name__.__eq__
  args: ["cpu_count"]
  expected: true

invariant os_extra7.get_terminal_size.name:
  description: "os.get_terminal_size.__name__ == 'get_terminal_size'"
  category: function_names
  kind: python_call_eq
  function: get_terminal_size.__name__.__eq__
  args: ["get_terminal_size"]
  expected: true

invariant os_extra7.urandom.name:
  description: "os.urandom.__name__ == 'urandom'"
  category: function_names
  kind: python_call_eq
  function: urandom.__name__.__eq__
  args: ["urandom"]
  expected: true

# ---------------------------------------------------------------------------
# urandom(4) — returns bytes of exactly the requested length
# ---------------------------------------------------------------------------

invariant os_extra7.urandom.returns_bytes:
  description: "os.urandom(4).__class__.__name__ == 'bytes' — urandom always returns a bytes object"
  category: urandom
  kind: python_call_eq
  function: urandom
  args: [4]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bytes"]
  expected: true

invariant os_extra7.urandom.length_four:
  description: "len(os.urandom(4)) == 4 — urandom returns exactly the requested number of bytes"
  category: urandom
  kind: python_call_eq
  function: urandom
  args: [4]
  method: __len__
  method_args: []
  expected: 4

# ---------------------------------------------------------------------------
# sep and linesep — class name (value checks are in os_extra6)
# ---------------------------------------------------------------------------

invariant os_extra7.sep.class_name:
  description: "os.sep.__class__.__name__ == 'str' — path separator is always a str"
  category: constants
  kind: python_call_eq
  function: sep.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_extra7.linesep.class_name:
  description: "os.linesep.__class__.__name__ == 'str' — line separator is always a str"
  category: constants
  kind: python_call_eq
  function: linesep.__class__.__name__.__eq__
  args: ["str"]
  expected: true
