spec: io_extra80
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra79."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths; FileIO/BytesIO/StringIO __dict__ membership."
    - "io_extra79 covers FileIO/BytesIO/StringIO __dict__.__class__.__name__ == 'mappingproxy'; FileIO.__bases__[0].__name__ == '_RawIOBase'; BytesIO.__bases__[0].__name__ == '_BufferedIOBase'; StringIO.__bases__[0].__name__ == '_TextIOBase'; __dict__.__contains__ for read/readinto/write."
    - "This spec covers: BufferedReader/BufferedWriter/TextIOWrapper class hierarchy — __name__, __module__, __bases__[0].__name__, and MRO lengths; BufferedReader/BufferedWriter/TextIOWrapper __dict__ membership for key methods."
    - "io.BufferedReader.__name__ == 'BufferedReader' — C extension class in _io."
    - "io.BufferedReader.__module__ == '_io' — defined in the C _io extension."
    - "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — private C base class name."
    - "io.BufferedReader.__mro__.__len__() == 4 — MRO is [BufferedReader, _BufferedIOBase, _IOBase, object]."
    - "io.BufferedWriter.__name__ == 'BufferedWriter' — C extension class in _io."
    - "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — same C base as BufferedReader."
    - "io.BufferedWriter.__mro__.__len__() == 4 — MRO is [BufferedWriter, _BufferedIOBase, _IOBase, object]."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' — C extension class in _io."
    - "io.TextIOWrapper.__module__ == '_io' — defined in the C _io extension."
    - "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — private C base class name."
    - "io.TextIOWrapper.__mro__.__len__() == 4 — MRO is [TextIOWrapper, _TextIOBase, _IOBase, object]."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BufferedReader class identity
# BufferedReader is a C extension type in _io.  Its name and module confirm
# the C-level definition; its direct base is the private _BufferedIOBase type.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra80.BufferedReader_identity:
  description: "BufferedReader __name__, __module__, and __bases__[0].__name__"
  kind: python_call_eq
  category: class_names
  id_prefix: iomore80

  columns: [id, function, args, expected]
  rows:
    - [br_name,   BufferedReader.__name__.__eq__,                      ["BufferedReader"],  true]
    - [br_module, BufferedReader.__module__.__eq__,                    ["_io"],             true]
    - [br_base,   "BufferedReader.__bases__[0].__name__.__eq__",       ["_BufferedIOBase"], true]

# ---------------------------------------------------------------------------
# BufferedWriter class identity
# BufferedWriter is also in _io and shares _BufferedIOBase as its C base.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra80.BufferedWriter_identity:
  description: "BufferedWriter __name__, __module__, and __bases__[0].__name__"
  kind: python_call_eq
  category: class_names
  id_prefix: iomore80

  columns: [id, function, args, expected]
  rows:
    - [bw_name,   BufferedWriter.__name__.__eq__,                      ["BufferedWriter"],  true]
    - [bw_module, BufferedWriter.__module__.__eq__,                    ["_io"],             true]
    - [bw_base,   "BufferedWriter.__bases__[0].__name__.__eq__",       ["_BufferedIOBase"], true]

# ---------------------------------------------------------------------------
# TextIOWrapper class identity
# TextIOWrapper is in _io; its direct base is the private _TextIOBase C type.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra80.TextIOWrapper_identity:
  description: "TextIOWrapper __name__, __module__, and __bases__[0].__name__"
  kind: python_call_eq
  category: class_names
  id_prefix: iomore80

  columns: [id, function, args, expected]
  rows:
    - [tw_name,   TextIOWrapper.__name__.__eq__,                       ["TextIOWrapper"], true]
    - [tw_module, TextIOWrapper.__module__.__eq__,                     ["_io"],           true]
    - [tw_base,   "TextIOWrapper.__bases__[0].__name__.__eq__",        ["_TextIOBase"],   true]

# ---------------------------------------------------------------------------
# MRO lengths for BufferedReader, BufferedWriter, TextIOWrapper
# All three C types share the same MRO depth: [C_class, _B/T_IOBase, _IOBase, object].
# Function values containing [ must be double-quoted.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra80.buffered_tw_mro_lengths:
  description: "BufferedReader/BufferedWriter/TextIOWrapper MRO lengths are all 4"
  kind: python_call_eq
  category: class_bases
  id_prefix: iomore80

  columns: [id, function, args, expected]
  rows:
    - [br_mro_len, BufferedReader.__mro__.__len__,  [], 4]
    - [bw_mro_len, BufferedWriter.__mro__.__len__,  [], 4]
    - [tw_mro_len, TextIOWrapper.__mro__.__len__,   [], 4]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra80.BufferedReader.name:
  description: "io.BufferedReader.__name__ == 'BufferedReader'"
  category: class_names
  kind: python_call_eq
  function: BufferedReader.__name__.__eq__
  args: ["BufferedReader"]
  expected: true

invariant io_extra80.BufferedReader.module:
  description: "io.BufferedReader.__module__ == '_io'"
  category: class_names
  kind: python_call_eq
  function: BufferedReader.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra80.BufferedReader.base_is_BufferedIOBase:
  description: "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase'"
  category: class_bases
  kind: python_call_eq
  function: "BufferedReader.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra80.BufferedReader.mro_len_4:
  description: "io.BufferedReader.__mro__.__len__() == 4 — MRO is [BufferedReader, _BufferedIOBase, _IOBase, object]"
  category: class_bases
  kind: python_call_eq
  function: BufferedReader.__mro__.__len__
  args: []
  expected: 4

invariant io_extra80.TextIOWrapper.base_is_TextIOBase:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase'"
  category: class_bases
  kind: python_call_eq
  function: "TextIOWrapper.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true
