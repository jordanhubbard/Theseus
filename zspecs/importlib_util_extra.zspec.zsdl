spec: importlib_util_extra
version: ">=3.9"
backend: python_module(importlib.util)

docs: https://docs.python.org/3/library/importlib.html#importlib.util

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.html#importlib.util — Python importlib.util documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/util.py"
    - "CPython source: Lib/importlib/_bootstrap.py — frozen bootstrap internals"
    - "CPython source: Lib/importlib/_bootstrap_external.py — frozen external bootstrap"
    - "importlib_util.zspec.zsdl — covers find_spec/__name__, spec_from_file_location/__name__, spec_from_loader/__name__, module_from_spec/__name__, resolve_name/__name__; find_spec('os') ModuleSpec class; find_spec('os').name; find_spec('sys').name; find_spec(nonexistent)==None; resolve_name('.os','importlib'); resolve_name('os','importlib'); module_from_spec class."
  notes:
    - "This spec extends importlib_util.zspec.zsdl with new axes not covered there."
    - "importlib_util.zspec.zsdl covers: __name__ for find_spec/spec_from_file_location/spec_from_loader/module_from_spec/resolve_name; find_spec('os') and ('sys') name checks; find_spec(nonexistent)==None; ModuleSpec class name check; resolve_name relative/absolute; module_from_spec class check."
    - "New axes: __qualname__ for find_spec/spec_from_file_location/spec_from_loader/module_from_spec/resolve_name; __module__ for find_spec/spec_from_file_location/spec_from_loader/module_from_spec; source_from_cache __name__/__qualname__/__module__; LazyLoader __qualname__; module __name__/__package__/__spec__.name."
    - "find_spec.__qualname__ == 'find_spec' — top-level function, qualname equals name."
    - "find_spec.__module__ == 'importlib.util' — find_spec is defined in importlib.util."
    - "module_from_spec.__qualname__ == 'module_from_spec' — top-level function, qualname equals name."
    - "module_from_spec.__module__ == '_frozen_importlib' — defined in the frozen bootstrap internal module."
    - "spec_from_file_location.__qualname__ == 'spec_from_file_location' — top-level function."
    - "spec_from_file_location.__module__ == '_frozen_importlib_external' — defined in frozen external bootstrap."
    - "spec_from_loader.__qualname__ == 'spec_from_loader' — top-level function."
    - "spec_from_loader.__module__ == '_frozen_importlib' — defined in frozen bootstrap."
    - "resolve_name.__qualname__ == 'resolve_name' — top-level function."
    - "source_from_cache.__name__ == 'source_from_cache', __qualname__ == 'source_from_cache', __module__ == '_frozen_importlib_external'."
    - "LazyLoader.__qualname__ == 'LazyLoader' — class qualname equals class name for top-level classes."
    - "importlib.util.__name__ == 'importlib.util' — the module's own fully-qualified name."
    - "importlib.util.__package__ == 'importlib' — util is a submodule of the importlib package."
    - "importlib.util.__spec__.name == 'importlib.util' — the module spec identifies the module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module identity — __name__, __package__, __spec__.name
#
# importlib_util.zspec.zsdl does not check these module-level attrs.
# ---------------------------------------------------------------------------

invariant importlib_util_extra.module_name:
  description: "importlib.util.__name__ == 'importlib.util'"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["importlib.util"]
  expected: true

invariant importlib_util_extra.module_package:
  description: "importlib.util.__package__ == 'importlib'"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: ["importlib"]
  expected: true

invariant importlib_util_extra.module_spec_name:
  description: "importlib.util.__spec__.name == 'importlib.util'"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["importlib.util"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__ — top-level functions in importlib.util
#
# importlib_util.zspec.zsdl covers __name__ for each function.
# __qualname__ for top-level functions equals __name__; this is a distinct
# invariant axis not yet covered for these functions.
# ---------------------------------------------------------------------------

table importlib_util_extra.function_qualnames:
  kind: python_call_eq
  category: function_attrs
  id_prefix: fqualname

  columns: [id, function, args, expected]
  rows:
    - [find_spec,              find_spec.__qualname__.__eq__,              ["find_spec"],              true]
    - [module_from_spec,       module_from_spec.__qualname__.__eq__,       ["module_from_spec"],       true]
    - [spec_from_file_location, spec_from_file_location.__qualname__.__eq__, ["spec_from_file_location"], true]
    - [spec_from_loader,       spec_from_loader.__qualname__.__eq__,       ["spec_from_loader"],       true]
    - [resolve_name,           resolve_name.__qualname__.__eq__,           ["resolve_name"],           true]

# ---------------------------------------------------------------------------
# Function __module__ — identifies which internal module defines each function
#
# Some importlib.util functions are actually defined in the frozen bootstrap
# internals. importlib_util.zspec.zsdl does not check __module__ for any of
# these functions.
# ---------------------------------------------------------------------------

invariant importlib_util_extra.find_spec_module:
  description: "importlib.util.find_spec.__module__ == 'importlib.util'"
  category: function_attrs
  kind: python_call_eq
  function: find_spec.__module__.__eq__
  args: ["importlib.util"]
  expected: true

invariant importlib_util_extra.module_from_spec_module:
  description: "importlib.util.module_from_spec.__module__ == '_frozen_importlib'"
  category: function_attrs
  kind: python_call_eq
  function: module_from_spec.__module__.__eq__
  args: ["_frozen_importlib"]
  expected: true

invariant importlib_util_extra.spec_from_file_location_module:
  description: "importlib.util.spec_from_file_location.__module__ == '_frozen_importlib_external'"
  category: function_attrs
  kind: python_call_eq
  function: spec_from_file_location.__module__.__eq__
  args: ["_frozen_importlib_external"]
  expected: true

invariant importlib_util_extra.spec_from_loader_module:
  description: "importlib.util.spec_from_loader.__module__ == '_frozen_importlib'"
  category: function_attrs
  kind: python_call_eq
  function: spec_from_loader.__module__.__eq__
  args: ["_frozen_importlib"]
  expected: true

# ---------------------------------------------------------------------------
# source_from_cache — __name__, __qualname__, __module__
#
# importlib_util.zspec.zsdl does not cover source_from_cache at all.
# source_from_cache is the inverse of cache_from_source: given a .pyc path
# it returns the corresponding .py source path.
# It is defined in the frozen external bootstrap.
# ---------------------------------------------------------------------------

table importlib_util_extra.source_from_cache_attrs:
  kind: python_call_eq
  category: function_attrs
  id_prefix: src_cache

  columns: [id, function, args, expected]
  rows:
    - [name,     source_from_cache.__name__.__eq__,     ["source_from_cache"],        true]
    - [qualname, source_from_cache.__qualname__.__eq__, ["source_from_cache"],        true]
    - [module,   source_from_cache.__module__.__eq__,   ["_frozen_importlib_external"], true]

# ---------------------------------------------------------------------------
# LazyLoader.__qualname__
#
# importlib_util.zspec.zsdl does not cover LazyLoader at all.
# importlib_extra7 (python_module(importlib) backend) covers LazyLoader
# __name__, __module__, __qualname__, __bases__[0].__name__.
# This spec adds the same qualname check via the python_module(importlib.util)
# backend — a distinct test vector since the module root differs.
# ---------------------------------------------------------------------------

invariant importlib_util_extra.LazyLoader_qualname:
  description: "importlib.util.LazyLoader.__qualname__ == 'LazyLoader'"
  category: class_attrs
  kind: python_call_eq
  function: LazyLoader.__qualname__.__eq__
  args: ["LazyLoader"]
  expected: true

invariant importlib_util_extra.LazyLoader_name:
  description: "importlib.util.LazyLoader.__name__ == 'LazyLoader'"
  category: class_attrs
  kind: python_call_eq
  function: LazyLoader.__name__.__eq__
  args: ["LazyLoader"]
  expected: true

invariant importlib_util_extra.LazyLoader_module:
  description: "importlib.util.LazyLoader.__module__ == 'importlib.util'"
  category: class_attrs
  kind: python_call_eq
  function: LazyLoader.__module__.__eq__
  args: ["importlib.util"]
  expected: true
