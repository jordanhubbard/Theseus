spec: uuid_extra216
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.__doc__.__contains__('UUID') == True — module docstring contains 'UUID'."
    - "uuid.UUID.__doc__.__contains__('UUID') == True — UUID class docstring contains 'UUID'."
    - "uuid.uuid4.__doc__.__contains__('random') == True — uuid4 docstring says 'Generate a random UUID.'."
    - "uuid.uuid5.__doc__.__contains__('SHA') == True — uuid5 docstring mentions SHA-1 hash."
    - "uuid.uuid1.__doc__.__contains__('host') == True — uuid1 docstring mentions host ID."
    - "uuid.uuid3.__doc__.__contains__('MD5') == True — uuid3 docstring mentions MD5 hash."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — NAMESPACE_DNS is a UUID instance."
    - "uuid.NAMESPACE_DNS.hex.__len__() == 32 — UUID hex is 32 hex characters (128 bits)."
    - "uuid.NAMESPACE_URL.hex.__len__() == 32 — UUID hex is 32 hex characters (128 bits)."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid __doc__ contains checks
#
# uuid.__doc__.__contains__('UUID')   == True
# uuid.UUID.__doc__.__contains__('UUID') == True
# uuid.uuid4.__doc__.__contains__('random') == True
# uuid.uuid5.__doc__.__contains__('SHA')    == True
# uuid.uuid1.__doc__.__contains__('host')   == True
# uuid.uuid3.__doc__.__contains__('MD5')    == True
# ---------------------------------------------------------------------------

table uuid_extra216.doc_contains_checks:
  description: "uuid __doc__ contains checks in uuid216 namespace — wave 216 theme: module docstring contains 'UUID'; UUID class docstring contains 'UUID'; uuid4 docstring contains 'random' (it says 'Generate a random UUID.'); uuid5 docstring contains 'SHA' (SHA-1 hash); uuid1 docstring contains 'host' (host ID); uuid3 docstring contains 'MD5' (MD5 hash); verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: doc_contains
  id_prefix: uuid216

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_UUID,   uuid.__doc__.__contains__,      ["UUID"],   true, "uuid.__doc__.__contains__('UUID') == True — module docstring mentions UUID"]
    - [UUID_doc_UUID,     uuid.UUID.__doc__.__contains__,  ["UUID"],   true, "uuid.UUID.__doc__.__contains__('UUID') == True — UUID class docstring mentions UUID"]
    - [uuid4_doc_random,  uuid.uuid4.__doc__.__contains__, ["random"], true, "uuid.uuid4.__doc__.__contains__('random') == True — uuid4 docstring says 'Generate a random UUID.'"]
    - [uuid5_doc_SHA,     uuid.uuid5.__doc__.__contains__, ["SHA"],    true, "uuid.uuid5.__doc__.__contains__('SHA') == True — uuid5 docstring mentions SHA-1 hash"]
    - [uuid1_doc_host,    uuid.uuid1.__doc__.__contains__, ["host"],   true, "uuid.uuid1.__doc__.__contains__('host') == True — uuid1 docstring mentions host ID"]
    - [uuid3_doc_MD5,     uuid.uuid3.__doc__.__contains__, ["MD5"],    true, "uuid.uuid3.__doc__.__contains__('MD5') == True — uuid3 docstring mentions MD5 hash"]

# ---------------------------------------------------------------------------
# uuid NAMESPACE_DNS and NAMESPACE_URL class and hex length checks
#
# uuid.NAMESPACE_DNS.__class__.__name__  == 'UUID'
# uuid.NAMESPACE_DNS.hex.__len__()       == 32
# uuid.NAMESPACE_URL.hex.__len__()       == 32
# ---------------------------------------------------------------------------

table uuid_extra216.namespace_constant_checks:
  description: "uuid NAMESPACE_DNS and NAMESPACE_URL constant identity checks in uuid216a namespace — wave 216 theme: both NAMESPACE_DNS and NAMESPACE_URL are UUID instances; their hex attribute is a 32-character hex string (128-bit UUID encoded as 32 hex chars); NAMESPACE_DNS value is '6ba7b810-9dad-11d1-80b4-00c04fd430c8'; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: identity
  id_prefix: uuid216a

  columns: [id, function, args, expected, description]
  rows:
    - [dns_class_name,   uuid.NAMESPACE_DNS.__class__.__name__.__eq__,  ["UUID"], true, "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — NAMESPACE_DNS is a UUID instance"]
    - [dns_hex_len,      uuid.NAMESPACE_DNS.hex.__len__,                 [],       32,   "uuid.NAMESPACE_DNS.hex.__len__() == 32 — UUID hex is 32 hex characters (128 bits)"]
    - [url_hex_len,      uuid.NAMESPACE_URL.hex.__len__,                 [],       32,   "uuid.NAMESPACE_URL.hex.__len__() == 32 — UUID hex is 32 hex characters (128 bits)"]

# ---------------------------------------------------------------------------
# Standalone invariants for uuid __doc__ contains checks
# ---------------------------------------------------------------------------

invariant uuid_extra216.module_doc_contains_UUID:
  description: "uuid.__doc__.__contains__('UUID') == True — uuid module docstring is 'UUID objects (universally unique identifiers) according to RFC 4122/9562...' which contains 'UUID'; confirms module docstring is present and identifies the module purpose; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_contains
  kind: python_call_eq
  function: uuid.__doc__.__contains__
  args: ["UUID"]
  expected: true

invariant uuid_extra216.uuid4_doc_contains_random:
  description: "uuid.uuid4.__doc__.__contains__('random') == True — uuid4 docstring is 'Generate a random UUID.' which contains 'random'; uuid4 generates version-4 UUIDs using random or pseudo-random numbers per RFC 4122 section 4.4; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_contains
  kind: python_call_eq
  function: uuid.uuid4.__doc__.__contains__
  args: ["random"]
  expected: true

invariant uuid_extra216.NAMESPACE_DNS_hex_len_32:
  description: "uuid.NAMESPACE_DNS.hex.__len__() == 32 — NAMESPACE_DNS is the well-known DNS namespace UUID (6ba7b810-9dad-11d1-80b4-00c04fd430c8); its hex attribute strips hyphens giving 32 hex characters; UUID is 128 bits = 16 bytes = 32 hex chars; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: uuid.NAMESPACE_DNS.hex.__len__
  args: []
  expected: 32
