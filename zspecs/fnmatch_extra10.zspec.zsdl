spec: fnmatch_extra10
version: ">=3.9"
backend: python_module(fnmatch)

docs: https://docs.python.org/3/library/fnmatch.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fnmatch.html — Python fnmatch module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fnmatch.py"
  notes:
    - "This spec extends fnmatch.zspec.zsdl and fnmatch_extra through fnmatch_extra9.zspec.zsdl."
    - "fnmatch_extra9 covers '?' wildcard vectors for fnmatch/fnmatchcase; filter bracket-class and prefix-star; translate '?.py' length and '*.py' exact value."
    - "fnmatch_extra8 covers __class__.__name__ == 'function' for all 4 functions; fnmatch [a-z]/[0-9] range vectors."
    - "fnmatch_extra7 covers function __module__ anchors for fnmatch/fnmatchcase/filter/translate."
    - "fnmatch_extra5 covers translate('*') and translate(''); fnmatch empty_matches_empty; filter empty_list."
    - "NOT yet covered: fnmatch.fnmatch.__name__ == 'fnmatch' as a standalone invariant."
    - "NOT yet covered: fnmatch.fnmatchcase.__name__ == 'fnmatchcase' as a standalone invariant."
    - "NOT yet covered: fnmatch.filter.__name__ == 'filter' as a standalone invariant."
    - "NOT yet covered: fnmatch.translate.__name__ == 'translate' as a standalone invariant."
    - "NOT yet covered: fnmatch.fnmatch.__qualname__ == 'fnmatch' as a standalone invariant."
    - "NOT yet covered: fnmatch.fnmatchcase.__qualname__ == 'fnmatchcase' as a standalone invariant."
    - "NOT yet covered: fnmatch.filter.__qualname__ == 'filter' as a standalone invariant."
    - "NOT yet covered: fnmatch.translate.__qualname__ == 'translate' as a standalone invariant."
    - "NOT yet covered: fnmatch.fnmatch('test.py', '*.py') == True — basic star match."
    - "NOT yet covered: fnmatch.fnmatch('test.txt', '*.py') == False — no-match case."
    - "NOT yet covered: fnmatch.fnmatch('README', '*.py') == False — bare filename no-match."
    - "NOT yet covered: fnmatch.fnmatchcase('Test.PY', '*.py') == False — case mismatch."
    - "NOT yet covered: fnmatch.fnmatchcase('test.py', '*.py') == True — exact case match."
    - "NOT yet covered: fnmatch.filter(['a.py', 'b.txt', 'c.py'], '*.py') == ['a.py', 'c.py']."
    - "fnmatch.fnmatch.__name__ == 'fnmatch'; fnmatch.fnmatchcase.__name__ == 'fnmatchcase'; fnmatch.filter.__name__ == 'filter'; fnmatch.translate.__name__ == 'translate'."
    - "fnmatch.fnmatch.__qualname__ == 'fnmatch'; fnmatch.fnmatchcase.__qualname__ == 'fnmatchcase'; fnmatch.filter.__qualname__ == 'filter'; fnmatch.translate.__qualname__ == 'translate'."
    - "fnmatch.fnmatch('test.py', '*.py') == True — basic star wildcard match."
    - "fnmatch.fnmatch('test.txt', '*.py') == False — extension mismatch."
    - "fnmatch.fnmatch('README', '*.py') == False — no dot, cannot match '*.py'."
    - "fnmatch.fnmatchcase('Test.PY', '*.py') == False — uppercase extension fails case-sensitive match."
    - "fnmatch.fnmatchcase('test.py', '*.py') == True — exact case match."
    - "fnmatch.filter(['a.py', 'b.txt', 'c.py'], '*.py') == ['a.py', 'c.py']."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ attributes — standalone invariants
#
# fnmatch_extra7 checks fnmatch.__module__ for all four functions.
# fnmatch_extra8 checks __class__.__name__ == 'function' for all four.
# No prior fnmatch spec records the __name__ of fnmatch, fnmatchcase,
# filter, or translate as a standalone invariant (only covered in tables
# within fnmatch.zspec.zsdl if at all).
# ---------------------------------------------------------------------------

table fnmatch_extra10.function_names:
  description: "fnmatch module function __name__ attributes"
  kind: python_call_eq
  category: function_identity
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [fnmatch,      fnmatch.__name__.__eq__,      ["fnmatch"],      true]
    - [fnmatchcase,  fnmatchcase.__name__.__eq__,  ["fnmatchcase"],  true]
    - [filter,       filter.__name__.__eq__,       ["filter"],       true]
    - [translate,    translate.__name__.__eq__,    ["translate"],    true]

# ---------------------------------------------------------------------------
# Function __qualname__ attributes — standalone invariants
#
# For top-level module functions, __qualname__ equals __name__.
# No prior fnmatch spec records __qualname__ for any of these four functions.
# ---------------------------------------------------------------------------

table fnmatch_extra10.function_qualnames:
  description: "fnmatch module function __qualname__ attributes"
  kind: python_call_eq
  category: function_identity
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [fnmatch,      fnmatch.__qualname__.__eq__,      ["fnmatch"],      true]
    - [fnmatchcase,  fnmatchcase.__qualname__.__eq__,  ["fnmatchcase"],  true]
    - [filter,       filter.__qualname__.__eq__,       ["filter"],       true]
    - [translate,    translate.__qualname__.__eq__,    ["translate"],    true]

# ---------------------------------------------------------------------------
# fnmatch — basic star wildcard behavioral vectors
#
# fnmatch.zspec covers fnmatch('foo.py', '*.py') == True (possibly).
# fnmatch_extra9 covers '?' wildcard and 'b*.py' prefix patterns.
# These vectors anchor the fundamental '*.ext' match/no-match behaviour in
# the fnmatch_extra10 namespace for completeness and direct lookup.
# ---------------------------------------------------------------------------

invariant fnmatch_extra10.fnmatch.basic_match:
  description: "fnmatch.fnmatch('test.py', '*.py') == True — star matches any prefix"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["test.py", "*.py"]
  expected: true

invariant fnmatch_extra10.fnmatch.extension_no_match:
  description: "fnmatch.fnmatch('test.txt', '*.py') == False — different extension"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["test.txt", "*.py"]
  expected: false

invariant fnmatch_extra10.fnmatch.bare_name_no_match:
  description: "fnmatch.fnmatch('README', '*.py') == False — no dot, cannot match '*.py'"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["README", "*.py"]
  expected: false

# ---------------------------------------------------------------------------
# fnmatchcase — case sensitivity on star pattern
#
# fnmatch_extra3/4/5/6 cover fnmatchcase with various patterns but the
# basic '*.py' case-sensitive match/no-match in the extra10 namespace is new.
# fnmatchcase('Test.PY', '*.py') == False because 'PY' != 'py' (case-sensitive).
# fnmatchcase('test.py', '*.py') == True because case matches exactly.
# ---------------------------------------------------------------------------

invariant fnmatch_extra10.fnmatchcase.case_mismatch:
  description: "fnmatch.fnmatchcase('Test.PY', '*.py') == False — uppercase extension fails"
  category: fnmatchcase
  kind: python_call_eq
  function: fnmatchcase
  args: ["Test.PY", "*.py"]
  expected: false

invariant fnmatch_extra10.fnmatchcase.exact_match:
  description: "fnmatch.fnmatchcase('test.py', '*.py') == True — exact case match"
  category: fnmatchcase
  kind: python_call_eq
  function: fnmatchcase
  args: ["test.py", "*.py"]
  expected: true

# ---------------------------------------------------------------------------
# filter — basic '*.py' pattern with mixed list
#
# fnmatch.zspec covers filter(['a.py', 'b.txt'], '*.py') == ['a.py'].
# fnmatch_extra9 covers filter with bracket-class and prefix-star patterns.
# This vector uses a three-element input with two py files to verify filter
# returns both matches while skipping the non-matching .txt entry.
# ---------------------------------------------------------------------------

invariant fnmatch_extra10.filter.basic_star:
  description: "fnmatch.filter(['a.py', 'b.txt', 'c.py'], '*.py') == ['a.py', 'c.py']"
  category: filter
  kind: python_call_eq
  function: filter
  args: [["a.py", "b.txt", "c.py"], "*.py"]
  expected: ["a.py", "c.py"]
