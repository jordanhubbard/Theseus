invariant itertools_extra4.zip_longest.class_name:
  description: "itertools.zip_longest.__name__ == 'zip_longest'"
  category: zip_longest
  kind: python_call_eq
  function: zip_longest.__name__.__eq__
  args: ["zip_longest"]
  expected: true

invariant itertools_extra4.groupby.class_name:
  description: "itertools.groupby.__name__ == 'groupby'"
  category: groupby
  kind: python_call_eq
