invariant itertools_extra4.starmap.class_name:
  description: "itertools.starmap.__name__ == 'starmap'"
  category: starmap
  kind: python_call_eq
  function: starmap.__name__.__eq__
  args: ["starmap"]
  expected: true

invariant itertools_extra4.repeat.class_name:
  description: "itertools.repeat.__name__ == 'repeat'"
  category: repeat
  kind: python_call_eq
  function: repeat.__name__.__eq__
  args: ["repeat"]
