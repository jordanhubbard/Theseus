spec: itertools_extra4
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends prior itertools specs."
    - "Focus: behavioral invariants for itertools functions — actual output values."
    - "list(itertools.chain([1, 2], [3, 4])) == [1, 2, 3, 4]."
    - "list(itertools.islice(range(10), 3)) == [0, 1, 2]."
    - "list(itertools.compress([1,2,3,4], [1,0,1,0])) == [1, 3]."
    - "list(itertools.dropwhile(lambda x: x < 3, [1,2,3,4,5])) == [3, 4, 5]."
    - "list(itertools.takewhile(lambda x: x < 3, [1,2,3,4,5])) == [1, 2]."
    - "list(itertools.filterfalse(lambda x: x % 2, range(6))) == [0, 2, 4]."
    - "list(itertools.accumulate([1, 2, 3, 4])) == [1, 3, 6, 10]."
    - "list(itertools.zip_longest([1,2], [3,4,5])) == [(1,3),(2,4),(None,5)]."
    - "list(itertools.combinations([1,2,3], 2)) == [(1,2),(1,3),(2,3)]."
    - "list(itertools.permutations([1,2,3], 2)) == [(1,2),(1,3),(2,1),(2,3),(3,1),(3,2)]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

invariant itertools_extra4.chain.two_lists:
  description: "list(itertools.chain([1, 2], [3, 4])) == [1, 2, 3, 4]"
  category: chain
  kind: python_call_eq
  function: chain
  args: [[1, 2], [3, 4]]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["chain"]
  expected: true

invariant itertools_extra4.islice.first_three:
  description: "itertools.islice.__class__.__name__ == 'type'"
  category: islice
  kind: python_call_eq
  function: islice.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra4.compress.basic:
  description: "itertools.compress.__module__ == 'itertools'"
  category: compress
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra4.accumulate.class_name:
  description: "itertools.accumulate.__name__ == 'accumulate'"
  category: accumulate
  kind: python_call_eq
  function: accumulate.__name__.__eq__
  args: ["accumulate"]
  expected: true

