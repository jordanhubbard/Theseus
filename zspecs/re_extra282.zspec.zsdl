spec: re_extra282
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re_extra281 covers re.Match class identity and method __qualname__ values."
    - "This spec focuses on re.escape() output values and re.purge/__escape function identity."
    - "re.escape('a.b*c') == 'a\\.b\\*c' — dots and asterisks are each prefixed with a backslash."
    - "len(re.escape('a.b*c')) == 7 — 5 chars become 7 after escaping 2 special characters."
    - "re.escape('abc') == 'abc' — alphanumeric strings are returned unchanged."
    - "re.escape('') == '' — the empty string escapes to itself."
    - "re.escape('1+2') == '1\\+2' — the plus sign is a special regex character and gets escaped."
    - "re.escape('a|b') == 'a\\|b' — the pipe is a special regex character and gets escaped."
    - "re.purge.__module__ == 're' — purge is defined in the re module (pure Python)."
    - "re.purge.__class__.__name__ == 'function' — purge is a regular Python function, not a builtin."
    - "re.purge.__name__ == 'purge' — the function's __name__ is the bare name."
    - "re.escape.__module__ == 're' — escape is defined in the re module (pure Python)."
    - "re.escape.__class__.__name__ == 'function' — escape is a regular Python function, not a builtin."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.escape() output values
# Special characters are prefixed with a backslash; alphanumeric chars are not.
# re.escape('a.b*c') == 'a\\.b\\*c'  (len 7)
# re.escape('abc')   == 'abc'         (unchanged)
# re.escape('')      == ''            (empty stays empty)
# ---------------------------------------------------------------------------

table re_extra282.escape_outputs:
  description: "re.escape() output: special chars get backslash-prefixed, alphanumerics are unchanged"
  kind: python_call_eq
  category: escape_behavior
  id_prefix: escape282

  columns: [id, function, args, expected, description]
  rows:
    - [dot_star,   escape.__eq__, ["a.b*c"],   "a\\.b\\*c", "re.escape('a.b*c') == 'a\\\\.b\\\\*c' — dot and asterisk are escaped"]
    - [alpha_only, escape.__eq__, ["abc"],      "abc",       "re.escape('abc') == 'abc' — plain alphanumeric is returned unchanged"]
    - [empty_str,  escape.__eq__, [""],         "",          "re.escape('') == '' — empty string escapes to itself"]
    - [plus_sign,  escape.__eq__, ["1+2"],      "1\\+2",     "re.escape('1+2') == '1\\\\+2' — plus is a special regex char"]
    - [pipe_char,  escape.__eq__, ["a|b"],      "a\\|b",     "re.escape('a|b') == 'a\\\\|b' — pipe is a special regex char"]

# ---------------------------------------------------------------------------
# re.purge and re.escape function identity
# Both are regular Python functions (class 'function') in module 're'.
# ---------------------------------------------------------------------------

table re_extra282.function_identity:
  description: "re.purge and re.escape are plain Python functions with __module__ == 're'"
  kind: python_call_eq
  category: function_identity
  id_prefix: funcid282

  columns: [id, function, args, expected, description]
  rows:
    - [purge_module,  purge.__module__.__eq__,            ["re"],       true, "re.purge.__module__ == 're'"]
    - [purge_class,   purge.__class__.__name__.__eq__,    ["function"], true, "re.purge.__class__.__name__ == 'function' — plain Python function"]
    - [purge_name,    purge.__name__.__eq__,              ["purge"],    true, "re.purge.__name__ == 'purge'"]
    - [escape_module, escape.__module__.__eq__,           ["re"],       true, "re.escape.__module__ == 're'"]
    - [escape_class,  escape.__class__.__name__.__eq__,   ["function"], true, "re.escape.__class__.__name__ == 'function' — plain Python function"]
    - [escape_name,   escape.__name__.__eq__,             ["escape"],   true, "re.escape.__name__ == 'escape'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra282.escape.dot_star_result:
  description: "re.escape('a.b*c') == 'a\\.b\\*c' — both '.' and '*' are special regex characters and each gets a backslash prefix"
  category: escape_behavior
  kind: python_call_eq
  function: escape.__eq__
  args: ["a.b*c"]
  expected: "a\\.b\\*c"

invariant re_extra282.escape.alpha_unchanged:
  description: "re.escape('abc') == 'abc' — a string of only alphabetic characters contains no special regex chars and is returned as-is"
  category: escape_behavior
  kind: python_call_eq
  function: escape.__eq__
  args: ["abc"]
  expected: "abc"

invariant re_extra282.escape.empty_unchanged:
  description: "re.escape('') == '' — the empty string has no characters to escape and is returned as the empty string"
  category: escape_behavior
  kind: python_call_eq
  function: escape.__eq__
  args: [""]
  expected: ""

invariant re_extra282.escape.escaped_len:
  description: "len(re.escape('a.b*c')) == 7 — escaping 2 special chars in a 5-char string yields 7 characters"
  category: escape_behavior
  kind: python_call_eq
  function: escape.__len__
  args: ["a.b*c"]
  expected: 7

invariant re_extra282.purge.module_is_re:
  description: "re.purge.__module__ == 're' — purge is defined in the pure-Python re module, not in the C _sre extension"
  category: function_identity
  kind: python_call_eq
  function: purge.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra282.purge.class_is_function:
  description: "re.purge.__class__.__name__ == 'function' — purge is a regular Python function object, not a builtin_function_or_method"
  category: function_identity
  kind: python_call_eq
  function: purge.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant re_extra282.escape.class_is_function:
  description: "re.escape.__class__.__name__ == 'function' — escape is a regular Python function object, not a builtin"
  category: function_identity
  kind: python_call_eq
  function: escape.__class__.__name__.__eq__
  args: ["function"]
  expected: true
