  id_prefix: it1351pi
  columns: [id, function, args, expected]
  rows:
    - [it1351pi001, itertools.product.__dict__.__contains__,      ["__slots__"],    false]
    - [it1351pi002, itertools.product.__dict__.__contains__,      ["__weakref__"],  false]
    - [it1351pi003, itertools.product.__dict__.__contains__,      ["__dict__"],     false]
    - [it1351pi004, itertools.islice.__dict__.__contains__,       ["__slots__"],    false]
    - [it1351pi005, itertools.islice.__dict__.__contains__,       ["__weakref__"],  false]
    - [it1351pi006, itertools.islice.__dict__.__contains__,       ["__dict__"],     false]
    - [it1351pi007, itertools.permutations.__dict__.__contains__, ["__slots__"],    false]
