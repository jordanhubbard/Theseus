    - [it1351ra001, itertools.repeat.__dict__.__contains__,      ["__slots__"],    false]
    - [it1351ra002, itertools.repeat.__dict__.__contains__,      ["__weakref__"],  false]
    - [it1351ra003, itertools.repeat.__dict__.__contains__,      ["__dict__"],     false]
    - [it1351ra004, itertools.accumulate.__dict__.__contains__,  ["__slots__"],    false]
    - [it1351ra005, itertools.accumulate.__dict__.__contains__,  ["__weakref__"],  false]
    - [it1351ra006, itertools.accumulate.__dict__.__contains__,  ["__dict__"],     false]
    - [it1351ra007, itertools.combinations.__dict__.__contains__, ["__slots__"],   false]
    - [it1351ra008, itertools.combinations.__dict__.__contains__, ["__weakref__"], false]

table itertools_extra1351.product_islice_permutations_slot_checks:
  description: "itertools.product, islice, and permutations __dict__ containment checks for __slots__, __weakref__, and __dict__; all are C extension types with no Python-level slot/weakref/dict descriptors"
  kind: python_call_eq
