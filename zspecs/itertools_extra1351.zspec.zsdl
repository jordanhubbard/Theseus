spec: itertools_extra1351
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave 537 (_extra1351): focuses on __slots__ and __weakref__ attribute checks for itertools C extension types."
    - "All itertools iterator types (chain, count, cycle, repeat, accumulate, combinations, product, islice, etc.) are implemented in C."
    - "C extension types do not expose __slots__ or __weakref__ descriptors in their class __dict__; tp_weaklistoffset is set at the C level."
    - "itertools.chain.__dict__.__contains__('__slots__') == False — C type; no __slots__ descriptor in class dict."
    - "itertools.chain.__dict__.__contains__('__weakref__') == False — C type; weakref support is via tp_weaklistoffset, not a Python descriptor."
    - "itertools.chain.__dict__.__contains__('__dict__') == False — C iterator types do not expose a __dict__ descriptor; instances have no per-instance __dict__."
    - "Same pattern holds for count, cycle, repeat, accumulate, combinations, product, islice, permutations, combinations_with_replacement."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table itertools_extra1351.chain_count_cycle_slot_checks:
  description: "itertools.chain, count, and cycle __dict__ containment checks for __slots__, __weakref__, and __dict__; all are C extension types with no Python-level descriptors for these attributes"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: it1351cc
  columns: [id, function, args, expected]
  rows:
    - [it1351cc001, itertools.chain.__dict__.__contains__, ["__slots__"],    false]
    - [it1351cc002, itertools.chain.__dict__.__contains__, ["__weakref__"],  false]
    - [it1351cc003, itertools.chain.__dict__.__contains__, ["__dict__"],     false]
    - [it1351cc004, itertools.count.__dict__.__contains__, ["__slots__"],    false]
    - [it1351cc005, itertools.count.__dict__.__contains__, ["__weakref__"],  false]
    - [it1351cc006, itertools.count.__dict__.__contains__, ["__dict__"],     false]
    - [it1351cc007, itertools.cycle.__dict__.__contains__, ["__slots__"],    false]
    - [it1351cc008, itertools.cycle.__dict__.__contains__, ["__weakref__"],  false]

