spec: colorama_rust
version: ">=3.9"
backend: rust_module(colorama_rust)

docs: https://github.com/tartley/colorama

provenance:
  derived_from:
    - "https://github.com/tartley/colorama — colorama ANSI color library"
  notes:
    - "colorama provides ANSI color codes for terminals."
    - "colorama.Fore.RED is a non-empty string."
    - "colorama.Style.RESET_ALL is non-empty."
    - "colorama.init() is callable."
    - "colorama.VERSION is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant colorama_rust.fore_red_nonempty:
  description: "colorama.Fore.RED is non-empty string"
  category: fore
  kind: python_call_eq
  function: colorama_fore_red_nonempty
  args: []
  expected: true

invariant colorama_rust.has_init:
  description: "colorama.init is callable"
  category: presence
  kind: python_call_eq
  function: colorama_has_init
  args: []
  expected: true

invariant colorama_rust.version_nonempty:
  description: "colorama.VERSION is non-empty"
  category: version
  kind: python_call_eq
  function: colorama_version_nonempty
  args: []
  expected: true

