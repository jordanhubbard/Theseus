spec: concurrent_futures_extra121
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers: wave 255 theme — concurrent.futures exception class identity attributes. NEW in extra121: concurrent.futures.CancelledError.__qualname__=='CancelledError' (len=14); concurrent.futures.CancelledError.__module__=='concurrent.futures._base'; concurrent.futures.CancelledError.__mro__.__len__()==5 (MRO: CancelledError->Error->Exception->BaseException->object); concurrent.futures.BrokenExecutor.__qualname__=='BrokenExecutor' (len=14); concurrent.futures.BrokenExecutor.__module__=='concurrent.futures._base'; concurrent.futures.BrokenExecutor.__bases__[0].__name__=='RuntimeError'; concurrent.futures.InvalidStateError.__qualname__=='InvalidStateError' (len=17, longest); concurrent.futures.InvalidStateError.__mro__.__len__()==5 (InvalidStateError->Error->Exception->BaseException->object); concurrent.futures.thread.BrokenThreadPool.__qualname__=='BrokenThreadPool' (len=16); concurrent.futures.thread.BrokenThreadPool.__mro__.__len__()==6 (longest MRO: adds BrokenExecutor between BrokenThreadPool and RuntimeError); concurrent.futures.process.BrokenProcessPool.__qualname__=='BrokenProcessPool' (len=17); concurrent.futures.process.BrokenProcessPool.__mro__.__len__()==6. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.CancelledError.__mro__.__len__() == 5. MRO is [CancelledError, Error, Exception, BaseException, object]. CancelledError inherits from the local Error base class (not builtins.CancelledError), which itself inherits from Exception. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'. BrokenExecutor inherits from RuntimeError (not from Error or Exception directly). MRO is [BrokenExecutor, RuntimeError, Exception, BaseException, object] (length=5). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.thread.BrokenThreadPool.__mro__.__len__() == 6. MRO is [BrokenThreadPool, BrokenExecutor, RuntimeError, Exception, BaseException, object] (6 elements, one longer than BrokenExecutor's 5). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'. InvalidStateError is defined in _base.py alongside CancelledError and BrokenExecutor. Its qualname length is 17 (longest exception qualname in this spec). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures exception class identity — extra121
#
# Wave 255 theme: concurrent.futures exception class identity attributes.
#
# CancelledError.__qualname__      == 'CancelledError'  (len=14)
# CancelledError.__module__        == 'concurrent.futures._base'
# CancelledError.__mro__.__len__() == 5
# BrokenExecutor.__qualname__      == 'BrokenExecutor'  (len=14)
# BrokenExecutor.__module__        == 'concurrent.futures._base'
# BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'
# BrokenExecutor.__mro__.__len__() == 5
# InvalidStateError.__qualname__   == 'InvalidStateError' (len=17, longest)
# InvalidStateError.__module__     == 'concurrent.futures._base'
# InvalidStateError.__mro__.__len__() == 5
# ---------------------------------------------------------------------------

table concurrent_futures_extra121.cf_exception_identity:
  description: "concurrent.futures exception class __qualname__ and __module__ identity checks in cfexcident121 namespace — wave 255 theme: exception classes defined in concurrent.futures._base module; CancelledError.__qualname__.__eq__('CancelledError')==True (len=14: 14-char top-level name); CancelledError.__qualname__.__len__()==14; CancelledError.__module__.__eq__('concurrent.futures._base')==True (defined in _base.py, not in builtins); CancelledError.__mro__.__len__()==5 (MRO: CancelledError->Error->Exception->BaseException->object, the local Error base class adds an extra step); BrokenExecutor.__qualname__.__eq__('BrokenExecutor')==True (len=14, same length as CancelledError); BrokenExecutor.__module__.__eq__('concurrent.futures._base')==True; BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError')==True (BrokenExecutor inherits from RuntimeError, not Error); BrokenExecutor.__mro__.__len__()==5 (BrokenExecutor->RuntimeError->Exception->BaseException->object); InvalidStateError.__qualname__.__eq__('InvalidStateError')==True (len=17, longest exception qualname in spec: 'Invalid'=7+'State'=5+'Error'=5=17); InvalidStateError.__module__.__eq__('concurrent.futures._base')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexcident121

  columns: [id, function, args, expected, description]
  rows:
    - [ce_qn_eq,    "concurrent.futures.CancelledError.__qualname__.__eq__",    ["CancelledError"],               true, "CancelledError.__qualname__ == 'CancelledError' (len=14); verified with Python 3.14.3"]
    - [ce_qn_len,   "concurrent.futures.CancelledError.__qualname__.__len__",   [],                               14,   "CancelledError.__qualname__.__len__() == 14; verified with Python 3.14.3"]
    - [ce_mod_eq,   "concurrent.futures.CancelledError.__module__.__eq__",      ["concurrent.futures._base"],     true, "CancelledError.__module__ == 'concurrent.futures._base' (defined in _base.py, not builtins); verified with Python 3.14.3"]
    - [ce_mro_len,  "concurrent.futures.CancelledError.__mro__.__len__",        [],                               5,    "CancelledError.__mro__.__len__() == 5 (CancelledError->Error->Exception->BaseException->object); verified with Python 3.14.3"]
    - [be_qn_eq,    "concurrent.futures.BrokenExecutor.__qualname__.__eq__",    ["BrokenExecutor"],               true, "BrokenExecutor.__qualname__ == 'BrokenExecutor' (len=14, same as CancelledError); verified with Python 3.14.3"]
    - [be_mod_eq,   "concurrent.futures.BrokenExecutor.__module__.__eq__",      ["concurrent.futures._base"],     true, "BrokenExecutor.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [be_base0,    "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__", ["RuntimeError"],           true, "BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' (inherits from RuntimeError, not Error); verified with Python 3.14.3"]
    - [be_mro_len,  "concurrent.futures.BrokenExecutor.__mro__.__len__",        [],                               5,    "BrokenExecutor.__mro__.__len__() == 5 (BrokenExecutor->RuntimeError->Exception->BaseException->object); verified with Python 3.14.3"]
    - [ise_qn_eq,   "concurrent.futures.InvalidStateError.__qualname__.__eq__", ["InvalidStateError"],            true, "InvalidStateError.__qualname__ == 'InvalidStateError' (len=17, longest exception qualname); verified with Python 3.14.3"]
    - [ise_qn_len,  "concurrent.futures.InvalidStateError.__qualname__.__len__", [],                              17,   "InvalidStateError.__qualname__.__len__() == 17 ('Invalid'=7+'State'=5+'Error'=5=17); verified with Python 3.14.3"]
    - [ise_mod_eq,  "concurrent.futures.InvalidStateError.__module__.__eq__",   ["concurrent.futures._base"],     true, "InvalidStateError.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [ise_mro_len, "concurrent.futures.InvalidStateError.__mro__.__len__",     [],                               5,    "InvalidStateError.__mro__.__len__() == 5 (InvalidStateError->Error->Exception->BaseException->object); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures BrokenThreadPool and BrokenProcessPool — extra121
#
# BrokenThreadPool.__qualname__       == 'BrokenThreadPool'  (len=16)
# BrokenThreadPool.__module__         == 'concurrent.futures.thread'
# BrokenThreadPool.__bases__[0].__name__ == 'BrokenExecutor'
# BrokenThreadPool.__mro__.__len__()  == 6
# BrokenProcessPool.__qualname__      == 'BrokenProcessPool' (len=17)
# BrokenProcessPool.__module__        == 'concurrent.futures.process'
# BrokenProcessPool.__bases__[0].__name__ == 'BrokenExecutor'
# BrokenProcessPool.__mro__.__len__() == 6
# ---------------------------------------------------------------------------

table concurrent_futures_extra121.cf_broken_pool_identity:
  description: "concurrent.futures.thread.BrokenThreadPool and process.BrokenProcessPool identity checks in cfexcident121 namespace — wave 255 theme: BrokenThreadPool is defined in concurrent.futures.thread and BrokenProcessPool in concurrent.futures.process; both inherit from BrokenExecutor (which inherits from RuntimeError); BrokenThreadPool.__qualname__.__eq__('BrokenThreadPool')==True (len=16: 'Broken'=6+'Thread'=6+'Pool'=4=16); BrokenThreadPool.__module__.__eq__('concurrent.futures.thread')==True; BrokenThreadPool.__bases__[0].__name__.__eq__('BrokenExecutor')==True; BrokenThreadPool.__mro__.__len__()==6 ([BrokenThreadPool, BrokenExecutor, RuntimeError, Exception, BaseException, object], one longer than BrokenExecutor's MRO of 5); BrokenProcessPool.__qualname__.__eq__('BrokenProcessPool')==True (len=17: 'Broken'=6+'Process'=7+'Pool'=4=17, one char longer than BrokenThreadPool due to 'Process'=7 vs 'Thread'=6); BrokenProcessPool.__module__.__eq__('concurrent.futures.process')==True; BrokenProcessPool.__bases__[0].__name__.__eq__('BrokenExecutor')==True; BrokenProcessPool.__mro__.__len__()==6 (same depth as BrokenThreadPool); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexcident121a

  columns: [id, function, args, expected, description]
  rows:
    - [btp_qn_eq,   "concurrent.futures.thread.BrokenThreadPool.__qualname__.__eq__",         ["BrokenThreadPool"],              true, "BrokenThreadPool.__qualname__ == 'BrokenThreadPool' (len=16); verified with Python 3.14.3"]
    - [btp_qn_len,  "concurrent.futures.thread.BrokenThreadPool.__qualname__.__len__",         [],                               16,   "BrokenThreadPool.__qualname__.__len__() == 16 ('Broken'=6+'Thread'=6+'Pool'=4=16); verified with Python 3.14.3"]
    - [btp_mod_eq,  "concurrent.futures.thread.BrokenThreadPool.__module__.__eq__",            ["concurrent.futures.thread"],     true, "BrokenThreadPool.__module__ == 'concurrent.futures.thread'; verified with Python 3.14.3"]
    - [btp_base0,   "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__.__eq__", ["BrokenExecutor"],                true, "BrokenThreadPool.__bases__[0].__name__ == 'BrokenExecutor'; verified with Python 3.14.3"]
    - [btp_mro_len, "concurrent.futures.thread.BrokenThreadPool.__mro__.__len__",              [],                               6,    "BrokenThreadPool.__mro__.__len__() == 6 ([BrokenThreadPool,BrokenExecutor,RuntimeError,Exception,BaseException,object]); verified with Python 3.14.3"]
    - [bpp_qn_eq,   "concurrent.futures.process.BrokenProcessPool.__qualname__.__eq__",        ["BrokenProcessPool"],             true, "BrokenProcessPool.__qualname__ == 'BrokenProcessPool' (len=17, one char longer than BrokenThreadPool); verified with Python 3.14.3"]
    - [bpp_qn_len,  "concurrent.futures.process.BrokenProcessPool.__qualname__.__len__",        [],                              17,   "BrokenProcessPool.__qualname__.__len__() == 17 ('Broken'=6+'Process'=7+'Pool'=4=17); verified with Python 3.14.3"]
    - [bpp_mod_eq,  "concurrent.futures.process.BrokenProcessPool.__module__.__eq__",           ["concurrent.futures.process"],   true, "BrokenProcessPool.__module__ == 'concurrent.futures.process'; verified with Python 3.14.3"]
    - [bpp_base0,   "concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__.__eq__", ["BrokenExecutor"],              true, "BrokenProcessPool.__bases__[0].__name__ == 'BrokenExecutor'; verified with Python 3.14.3"]
    - [bpp_mro_len, "concurrent.futures.process.BrokenProcessPool.__mro__.__len__",              [],                             6,    "BrokenProcessPool.__mro__.__len__() == 6 (same depth as BrokenThreadPool); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures TimeoutError identity — extra121
#
# TimeoutError.__qualname__      == 'TimeoutError' (len=12)
# TimeoutError.__module__        == 'builtins'
# TimeoutError.__bases__[0].__name__ == 'OSError'
# TimeoutError.__mro__.__len__() == 5
# ---------------------------------------------------------------------------

table concurrent_futures_extra121.cf_timeout_error_identity:
  description: "concurrent.futures.TimeoutError identity checks in cfexcident121 namespace — wave 255 theme: TimeoutError is the only concurrent.futures exception whose __module__ is 'builtins' (not 'concurrent.futures._base'); TimeoutError.__qualname__.__eq__('TimeoutError')==True (len=12: 'Timeout'=7+'Error'=5=12, shortest exception qualname in this spec); TimeoutError.__qualname__.__len__()==12; TimeoutError.__module__.__eq__('builtins')==True (concurrent.futures.TimeoutError is an alias for the built-in builtins.TimeoutError, unlike CancelledError which is a local subclass of the local Error class); TimeoutError.__bases__[0].__name__.__eq__('OSError')==True (TimeoutError inherits from OSError in CPython, since Python 3.3 TimeoutError is a subclass of OSError); TimeoutError.__mro__.__len__()==5 (TimeoutError->OSError->Exception->BaseException->object); compare CancelledError MRO=[CancelledError,Error,Exception,BaseException,object]=5 (same depth but different chain); TimeoutError qualname len=12 vs CancelledError=14, BrokenExecutor=14, BrokenThreadPool=16, InvalidStateError=17, BrokenProcessPool=17; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexcident121b

  columns: [id, function, args, expected, description]
  rows:
    - [te_qn_eq,   "concurrent.futures.TimeoutError.__qualname__.__eq__",       ["TimeoutError"], true, "TimeoutError.__qualname__ == 'TimeoutError' (len=12, shortest exception qualname in spec); verified with Python 3.14.3"]
    - [te_qn_len,  "concurrent.futures.TimeoutError.__qualname__.__len__",       [],              12,   "TimeoutError.__qualname__.__len__() == 12 ('Timeout'=7+'Error'=5=12); verified with Python 3.14.3"]
    - [te_mod_eq,  "concurrent.futures.TimeoutError.__module__.__eq__",          ["builtins"],    true, "TimeoutError.__module__ == 'builtins' (alias for built-in TimeoutError, unlike other cf exceptions in _base); verified with Python 3.14.3"]
    - [te_base0,   "concurrent.futures.TimeoutError.__bases__[0].__name__.__eq__", ["OSError"],   true, "TimeoutError.__bases__[0].__name__ == 'OSError' (TimeoutError inherits from OSError since Python 3.3); verified with Python 3.14.3"]
    - [te_mro_len, "concurrent.futures.TimeoutError.__mro__.__len__",            [],              5,    "TimeoutError.__mro__.__len__() == 5 (TimeoutError->OSError->Exception->BaseException->object); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra121
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra121.cf_CancelledError_module_is_base:
  description: "concurrent.futures.CancelledError.__module__.__eq__('concurrent.futures._base') returns True — concurrent.futures.CancelledError is defined in Lib/concurrent/futures/_base.py (module='concurrent.futures._base'); this contrasts with concurrent.futures.TimeoutError whose __module__ is 'builtins' (TimeoutError is an alias for the built-in OSError subclass); CancelledError.__qualname__ is 'CancelledError' (len=14); CancelledError.__mro__.__len__() is 5 (CancelledError->Error->Exception->BaseException->object); CancelledError inherits from the local Error class in _base.py (not directly from Exception or from builtins.CancelledError); NEW in extra121: first standalone CancelledError module invariant in cfexcident121 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.CancelledError.__module__.__eq__"
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra121.cf_BrokenExecutor_base_is_RuntimeError:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError') returns True — BrokenExecutor inherits from RuntimeError (not from the local Error class used by CancelledError and InvalidStateError); BrokenExecutor.__mro__ is [BrokenExecutor, RuntimeError, Exception, BaseException, object] (length=5); this inheritance design means BrokenExecutor signals internal executor state failure (a programming error condition) rather than a user-facing cancellation or timeout condition; BrokenExecutor.__qualname__ is 'BrokenExecutor' (len=14, same as CancelledError); BrokenExecutor.__module__ is 'concurrent.futures._base'; the subclasses BrokenThreadPool and BrokenProcessPool each add one more level, making their MRO length 6; NEW in extra121: first standalone BrokenExecutor base class invariant in cfexcident121 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true

invariant concurrent_futures_extra121.cf_BrokenThreadPool_mro_len_6:
  description: "concurrent.futures.thread.BrokenThreadPool.__mro__.__len__() == 6 — BrokenThreadPool.__mro__ is [BrokenThreadPool, BrokenExecutor, RuntimeError, Exception, BaseException, object] (6 elements); this is the deepest MRO among the concurrent.futures exceptions in this spec (deeper than BrokenExecutor at 5); BrokenThreadPool.__module__ is 'concurrent.futures.thread'; BrokenThreadPool.__bases__[0].__name__ is 'BrokenExecutor'; BrokenProcessPool has the same MRO depth of 6 ([BrokenProcessPool, BrokenExecutor, RuntimeError, Exception, BaseException, object]); the 6-element MRO chain contrasts with CancelledError (5), InvalidStateError (5), BrokenExecutor (5); NEW in extra121: first standalone BrokenThreadPool MRO length invariant in cfexcident121 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.thread.BrokenThreadPool.__mro__.__len__"
  args: []
  expected: 6

invariant concurrent_futures_extra121.cf_InvalidStateError_qualname_len_17:
  description: "concurrent.futures.InvalidStateError.__qualname__.__len__() == 17 — InvalidStateError.__qualname__ is 'InvalidStateError' (17 chars: 'Invalid'=7+'State'=5+'Error'=5=17); this is the longest exception qualname among the _base.py-defined exceptions: CancelledError=14, BrokenExecutor=14, InvalidStateError=17; InvalidStateError is raised when a Future method is called in an invalid state (e.g., calling set_result on an already-done Future); InvalidStateError.__module__ is 'concurrent.futures._base'; InvalidStateError.__mro__.__len__() is 5 (InvalidStateError->Error->Exception->BaseException->object); compare BrokenProcessPool.__qualname__.__len__()==17 (same length but different module: process vs _base); NEW in extra121: first standalone InvalidStateError qualname length invariant in cfexcident121 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.InvalidStateError.__qualname__.__len__"
  args: []
  expected: 17

invariant concurrent_futures_extra121.cf_TimeoutError_module_is_builtins:
  description: "concurrent.futures.TimeoutError.__module__.__eq__('builtins') returns True — concurrent.futures.TimeoutError is an alias for the built-in TimeoutError (builtins.TimeoutError), which is a subclass of OSError; unlike CancelledError, BrokenExecutor, and InvalidStateError which are defined in concurrent.futures._base, TimeoutError is not defined in the concurrent.futures package at all — it is simply the built-in exception re-exported; TimeoutError.__qualname__ is 'TimeoutError' (len=12, shortest exception qualname in this spec); TimeoutError.__bases__[0].__name__ is 'OSError' (TimeoutError inherits from OSError since Python 3.3); TimeoutError.__mro__.__len__() is 5; NEW in extra121: first standalone TimeoutError module invariant in cfexcident121 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.TimeoutError.__module__.__eq__"
  args: ["builtins"]
  expected: true
