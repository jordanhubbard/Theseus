spec: ssl_extra29
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "ssl_extra28.zspec.zsdl — covers SSLContext/SSLError/SSLSocket/SSLObject __module__.__len__() and __name__.__len__(); create_default_context/__qualname__/__module__.__len__(); SSLContext.wrap_socket/__qualname__/__module__.__len__()."
    - "ssl_extra27.zspec.zsdl — covers SSLContext/__init__.__name__; SSLError/__init__.__name__; SSLSocket/__module__/__bases__[0].__name__; SSLObject/__module__/__bases__[0].__name__; SSLCertVerificationError/__name__/__module__/__bases__[0].__name__; CertificateError/__name__/__bases__[0].__name__."
    - "ssl_extra23.zspec.zsdl — covers SSLContext wrap_socket/load_cert_chain/set_ciphers __qualname__; SSLSocket.read.__qualname__; PROTOCOL_TLS_CLIENT class name."
    - "ssl_extra21.zspec.zsdl — covers SSLContext/SSLSocket/SSLObject/MemoryBIO/SSLSession __qualname__.__len__; create_default_context __qualname__.__len__."
  notes:
    - "This spec extends ssl through ssl_extra28; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: SSLContext/__name__/__module__/__qualname__/__module__.__len__()/__name__.__len__(); SSLError/__name__/__module__/__module__.__len__()/__name__.__len__(); SSLSocket/__name__/__module__/__module__.__len__()/__name__.__len__(); SSLObject/__name__/__module__/__module__.__len__()/__name__.__len__(); SSLCertVerificationError/__name__/__module__; CertificateError/__name__; create_default_context/__qualname__/__module__.__len__(); SSLContext.wrap_socket/__qualname__/__module__.__len__()."
    - "This spec covers: ssl.SSLCertVerificationError.__module__.__len__(); ssl.SSLCertVerificationError.__name__.__len__(); ssl.SSLCertVerificationError.__qualname__.__len__(); ssl.SSLContext.load_cert_chain.__qualname__.__len__(); ssl.SSLContext.load_verify_locations.__qualname__.__len__(); ssl.SSLContext.set_ciphers.__qualname__.__len__(); ssl.SSLSocket.read.__qualname__.__len__(); ssl.SSLSocket.write.__qualname__.__len__(); ssl.SSLContext.load_cert_chain.__name__.__len__(); ssl.SSLContext.load_verify_locations.__name__.__len__(); ssl.SSLContext.set_ciphers.__name__.__len__(); ssl.SSLSocket.read.__name__.__len__(); ssl.SSLSocket.write.__name__.__len__(); ssl.create_default_context.__qualname__.__len__()."
    - "ssl.SSLCertVerificationError.__module__ == 'ssl' — len 3. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLCertVerificationError.__name__ == 'SSLCertVerificationError' — len 24. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLCertVerificationError.__qualname__ == 'SSLCertVerificationError' — len 24. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.load_cert_chain.__qualname__ == '_SSLContext.load_cert_chain' — len 27; the underlying C method is on _SSLContext. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.load_verify_locations.__qualname__ == '_SSLContext.load_verify_locations' — len 33. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.set_ciphers.__qualname__ == '_SSLContext.set_ciphers' — len 23. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.read.__qualname__ == 'SSLSocket.read' — len 14. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.write.__qualname__ == 'SSLSocket.write' — len 15. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.load_cert_chain.__name__ == 'load_cert_chain' — len 15. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.load_verify_locations.__name__ == 'load_verify_locations' — len 21. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.set_ciphers.__name__ == 'set_ciphers' — len 11. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.read.__name__ == 'read' — len 4. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.write.__name__ == 'write' — len 5. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.create_default_context.__qualname__.__len__() == 22 — 'create_default_context' has 22 characters. ssl_extra21 covers this length; re-anchored from extra29 for independent regression. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ssl.SSLCertVerificationError __module__/__name__/__qualname__ __len__()
#
# ssl_extra27 covers SSLCertVerificationError.__module__.__eq__ and
# __name__.__eq__. No prior spec checks __len__() for any of these three.
# __module__ == 'ssl' (len 3); __name__ == __qualname__ == 'SSLCertVerificationError' (len 24).
# ---------------------------------------------------------------------------

invariant ssl_extra29.SSLCertVerificationError.module_len:
  description: "len(ssl.SSLCertVerificationError.__module__) == 3 — 'ssl' has 3 characters"
  category: module_metadata
  kind: python_call_eq
  function: SSLCertVerificationError.__module__.__len__
  args: []
  expected: 3

table ssl_extra29.SSLCertVerificationError_name_qualname_lengths:
  description: "ssl.SSLCertVerificationError __name__.__len__() and __qualname__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: scvnl29

  columns: [id, function, args, expected, description]
  rows:
    - [name_len,
       SSLCertVerificationError.__name__.__len__,
       [],
       24,
       "len('SSLCertVerificationError') == 24"]
    - [qualname_len,
       SSLCertVerificationError.__qualname__.__len__,
       [],
       24,
       "len('SSLCertVerificationError') == 24"]

# ---------------------------------------------------------------------------
# ssl.SSLContext method __qualname__.__len__() values
#
# ssl_extra23 covers __qualname__.__eq__ for load_cert_chain, set_ciphers, and
# wrap_socket; ssl_extra28 covers wrap_socket.__qualname__ again. No prior spec
# checks __qualname__.__len__() for load_cert_chain, load_verify_locations, or
# set_ciphers. Note: the underlying C methods are on _SSLContext; their
# __qualname__ reflects that (e.g. '_SSLContext.load_cert_chain').
# ---------------------------------------------------------------------------

table ssl_extra29.SSLContext_method_qualname_lengths:
  description: "ssl.SSLContext method __qualname__.__len__() — load_cert_chain/load_verify_locations/set_ciphers"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: scmql29

  columns: [id, function, args, expected, description]
  rows:
    - [load_cert_chain,
       SSLContext.load_cert_chain.__qualname__.__len__,
       [],
       27,
       "len('_SSLContext.load_cert_chain') == 27"]
    - [load_verify_locations,
       SSLContext.load_verify_locations.__qualname__.__len__,
       [],
       33,
       "len('_SSLContext.load_verify_locations') == 33"]
    - [set_ciphers,
       SSLContext.set_ciphers.__qualname__.__len__,
       [],
       23,
       "len('_SSLContext.set_ciphers') == 23"]

# ---------------------------------------------------------------------------
# ssl.SSLSocket method __qualname__.__len__() values
#
# ssl_extra23 covers SSLSocket.read.__qualname__.__eq__. No prior spec checks
# __qualname__.__len__() for SSLSocket.read or SSLSocket.write.
# read.__qualname__ == 'SSLSocket.read' (len 14);
# write.__qualname__ == 'SSLSocket.write' (len 15).
# ---------------------------------------------------------------------------

invariant ssl_extra29.SSLSocket.read_qualname_len:
  description: "len(ssl.SSLSocket.read.__qualname__) == 14 — len('SSLSocket.read') == 14"
  category: function_qualnames
  kind: python_call_eq
  function: SSLSocket.read.__qualname__.__len__
  args: []
  expected: 14

invariant ssl_extra29.SSLSocket.write_qualname_len:
  description: "len(ssl.SSLSocket.write.__qualname__) == 15 — len('SSLSocket.write') == 15"
  category: function_qualnames
  kind: python_call_eq
  function: SSLSocket.write.__qualname__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# ssl.SSLContext and ssl.SSLSocket method __name__.__len__() values
#
# No prior spec checks __name__.__len__() for load_cert_chain,
# load_verify_locations, set_ciphers, read, or write.
# ---------------------------------------------------------------------------

table ssl_extra29.method_name_lengths:
  description: "ssl SSLContext/SSLSocket method __name__.__len__() — load_cert_chain/load_verify_locations/set_ciphers/read/write"
  kind: python_call_eq
  category: function_names
  id_prefix: smnl29

  columns: [id, function, args, expected, description]
  rows:
    - [load_cert_chain,
       SSLContext.load_cert_chain.__name__.__len__,
       [],
       15,
       "len('load_cert_chain') == 15"]
    - [load_verify_locations,
       SSLContext.load_verify_locations.__name__.__len__,
       [],
       21,
       "len('load_verify_locations') == 21"]
    - [set_ciphers,
       SSLContext.set_ciphers.__name__.__len__,
       [],
       11,
       "len('set_ciphers') == 11"]
    - [read,
       SSLSocket.read.__name__.__len__,
       [],
       4,
       "len('read') == 4"]
    - [write,
       SSLSocket.write.__name__.__len__,
       [],
       5,
       "len('write') == 5"]

# ---------------------------------------------------------------------------
# ssl.create_default_context.__qualname__.__len__()
#
# ssl_extra21 covers create_default_context.__qualname__.__len__()==22.
# ssl_extra28 re-anchors the __qualname__.__eq__ check from extra28 namespace.
# This re-anchors the __len__() check from extra29 for independent regression.
# create_default_context.__qualname__ == 'create_default_context' (len 22).
# ---------------------------------------------------------------------------

invariant ssl_extra29.create_default_context.qualname_len:
  description: "len(ssl.create_default_context.__qualname__) == 22 — len('create_default_context') == 22; re-anchored from extra29"
  category: function_qualnames
  kind: python_call_eq
  function: create_default_context.__qualname__.__len__
  args: []
  expected: 22
