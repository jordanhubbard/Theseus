spec: re_extra268
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.compile, re.match, re.search, re.sub, re.findall, re.split, re.fullmatch are all module-level functions."
    - "All seven functions have __module__ == 're' and __class__.__name__ == 'function'."
    - "Each function's __qualname__ equals its __name__ (all are top-level, not nested)."
    - "re.compile.__name__ == 'compile', re.match.__name__ == 'match', etc."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: function __name__ and __module__ identity
# ---------------------------------------------------------------------------

table re_extra268.function_names_modules:
  description: "re module function __name__ and __module__ identity for compile, match, search, sub, findall, split, fullmatch"
  kind: python_call_eq
  category: identity
  id_prefix: fn

  columns: [id, function, args, expected, description]
  rows:
    - [compile_name,   compile.__name__.__eq__,   ["compile"],   true, "re.compile.__name__ == 'compile'"]
    - [compile_module, compile.__module__.__eq__,  ["re"],        true, "re.compile.__module__ == 're'"]
    - [match_name,     match.__name__.__eq__,      ["match"],     true, "re.match.__name__ == 'match'"]
    - [match_module,   match.__module__.__eq__,    ["re"],        true, "re.match.__module__ == 're'"]
    - [search_name,    search.__name__.__eq__,     ["search"],    true, "re.search.__name__ == 'search'"]
    - [search_module,  search.__module__.__eq__,   ["re"],        true, "re.search.__module__ == 're'"]
    - [sub_name,       sub.__name__.__eq__,        ["sub"],       true, "re.sub.__name__ == 'sub'"]
    - [sub_module,     sub.__module__.__eq__,      ["re"],        true, "re.sub.__module__ == 're'"]
    - [findall_name,   findall.__name__.__eq__,    ["findall"],   true, "re.findall.__name__ == 'findall'"]
    - [findall_module, findall.__module__.__eq__,  ["re"],        true, "re.findall.__module__ == 're'"]
    - [split_name,     split.__name__.__eq__,      ["split"],     true, "re.split.__name__ == 'split'"]
    - [split_module,   split.__module__.__eq__,    ["re"],        true, "re.split.__module__ == 're'"]
    - [fullmatch_name, fullmatch.__name__.__eq__,  ["fullmatch"], true, "re.fullmatch.__name__ == 'fullmatch'"]
    - [fullmatch_mod,  fullmatch.__module__.__eq__, ["re"],       true, "re.fullmatch.__module__ == 're'"]

# ---------------------------------------------------------------------------
# Table: function __qualname__ and __class__.__name__
# ---------------------------------------------------------------------------

table re_extra268.function_qualnames_classes:
  description: "re module function __qualname__ and __class__.__name__ for compile, match, search, sub, findall, split, fullmatch"
  kind: python_call_eq
  category: identity
  id_prefix: qn

  columns: [id, function, args, expected, description]
  rows:
    - [compile_qualname,   compile.__qualname__.__eq__,            ["compile"],   true, "re.compile.__qualname__ == 'compile'"]
    - [compile_class,      compile.__class__.__name__.__eq__,      ["function"],  true, "re.compile.__class__.__name__ == 'function'"]
    - [match_qualname,     match.__qualname__.__eq__,              ["match"],     true, "re.match.__qualname__ == 'match'"]
    - [match_class,        match.__class__.__name__.__eq__,        ["function"],  true, "re.match.__class__.__name__ == 'function'"]
    - [search_qualname,    search.__qualname__.__eq__,             ["search"],    true, "re.search.__qualname__ == 'search'"]
    - [search_class,       search.__class__.__name__.__eq__,       ["function"],  true, "re.search.__class__.__name__ == 'function'"]
    - [sub_qualname,       sub.__qualname__.__eq__,                ["sub"],       true, "re.sub.__qualname__ == 'sub'"]
    - [sub_class,          sub.__class__.__name__.__eq__,          ["function"],  true, "re.sub.__class__.__name__ == 'function'"]
    - [findall_qualname,   findall.__qualname__.__eq__,            ["findall"],   true, "re.findall.__qualname__ == 'findall'"]
    - [findall_class,      findall.__class__.__name__.__eq__,      ["function"],  true, "re.findall.__class__.__name__ == 'function'"]
    - [split_qualname,     split.__qualname__.__eq__,              ["split"],     true, "re.split.__qualname__ == 'split'"]
    - [split_class,        split.__class__.__name__.__eq__,        ["function"],  true, "re.split.__class__.__name__ == 'function'"]
    - [fullmatch_qualname, fullmatch.__qualname__.__eq__,          ["fullmatch"], true, "re.fullmatch.__qualname__ == 'fullmatch'"]
    - [fullmatch_class,    fullmatch.__class__.__name__.__eq__,    ["function"],  true, "re.fullmatch.__class__.__name__ == 'function'"]

# ---------------------------------------------------------------------------
# Standalone invariants: cross-checks for compile and match
# ---------------------------------------------------------------------------

invariant re_extra268.compile.name_eq_qualname:
  description: "re.compile.__name__ == re.compile.__qualname__ — top-level function name equals qualname"
  category: identity
  kind: python_call_eq
  function: compile.__name__.__eq__
  args: ["compile"]
  expected: true

invariant re_extra268.match.name_eq_qualname:
  description: "re.match.__name__ == re.match.__qualname__ — top-level function name equals qualname"
  category: identity
  kind: python_call_eq
  function: match.__name__.__eq__
  args: ["match"]
  expected: true

invariant re_extra268.fullmatch.is_function:
  description: "re.fullmatch.__class__.__name__ == 'function' — fullmatch is a plain Python function"
  category: identity
  kind: python_call_eq
  function: fullmatch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant re_extra268.split.is_function:
  description: "re.split.__class__.__name__ == 'function' — split is a plain Python function"
  category: identity
  kind: python_call_eq
  function: split.__class__.__name__.__eq__
  args: ["function"]
  expected: true
