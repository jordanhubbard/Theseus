table multiprocessing_extra80.exception_qualname_lengths_cross_check:
  description: "multiprocessing exception qualname length cross-checks in mpextra80 namespace — wave 245 theme: exception __qualname__ lengths summary; ProcessError.__qualname__.__len__()==12; BufferTooShort.__qualname__.__len__()==14; TimeoutError.__qualname__.__len__()==12; ProcessError.__mro__.__len__()==4 (cross-check hierarchy depth); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpextra80c

  columns: [id, function, args, expected, description]
  rows:
    - [perr_len_cross,   ProcessError.__qualname__.__len__,              [], 12, "ProcessError.__qualname__.__len__() == 12 — cross-check; verified with Python 3.14.3"]
    - [buf_len_cross,    BufferTooShort.__qualname__.__len__,            [], 14, "BufferTooShort.__qualname__.__len__() == 14 — cross-check; verified with Python 3.14.3"]
    - [toerr_len_cross,  TimeoutError.__qualname__.__len__,              [], 12, "TimeoutError.__qualname__.__len__() == 12 — cross-check; verified with Python 3.14.3"]
    - [perr_mro_cross,   "ProcessError.__mro__.__len__",                 [], 4,  "ProcessError.__mro__.__len__() == 4 — cross-check hierarchy depth; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra80
# ---------------------------------------------------------------------------

invariant multiprocessing_extra80.ProcessError_qualname:
  description: "multiprocessing.ProcessError.__qualname__.__eq__('ProcessError') returns True — simple class qualname with no enclosing scope; NEW in extra80: first standalone __qualname__ invariant for ProcessError in mpextra80 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessError.__qualname__.__eq__
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra80.ProcessError_qualname_len:
  description: "multiprocessing.ProcessError.__qualname__.__len__() == 12 — len('ProcessError') == 12; ProcessError is the root multiprocessing exception class; NEW in extra80: first standalone __qualname__.__len__ invariant for ProcessError in mpextra80 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessError.__qualname__.__len__
  args: []
  expected: 12

invariant multiprocessing_extra80.AuthenticationError_qualname_len:
  description: "multiprocessing.AuthenticationError.__qualname__.__len__() == 19 — len('AuthenticationError') == 19; NEW in extra80: first standalone __qualname__.__len__ invariant for AuthenticationError in mpextra80 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: AuthenticationError.__qualname__.__len__
  args: []
  expected: 19

invariant multiprocessing_extra80.ProcessError_module:
  description: "multiprocessing.ProcessError.__module__.__eq__('multiprocessing.context') returns True — ProcessError and its subclasses are defined in multiprocessing.context, not in multiprocessing directly; NEW in extra80: first standalone __module__ invariant for ProcessError in mpextra80 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessError.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra80.BufferTooShort_base_name:
  description: "multiprocessing.BufferTooShort.__bases__[0].__name__.__eq__('ProcessError') returns True — BufferTooShort is a direct subclass of ProcessError; NEW in extra80: first standalone __bases__[0].__name__ invariant for BufferTooShort in mpextra80 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BufferTooShort.__bases__[0].__name__.__eq__
  args: ["ProcessError"]
  expected: true
