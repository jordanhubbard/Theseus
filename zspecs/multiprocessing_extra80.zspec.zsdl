table multiprocessing_extra80.TimeoutError_qualname_and_hierarchy:
  description: "multiprocessing TimeoutError qualname length and hierarchy checks in mpextra80 namespace — wave 245 theme: exception __qualname__ lengths; TimeoutError.__qualname__.__len__()==12 (len('TimeoutError')==12); TimeoutError.__bases__[0].__name__=='ProcessError' (TimeoutError subclasses ProcessError, not builtins.TimeoutError); AuthenticationError.__qualname__.__len__()==19 (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpextra80b

  columns: [id, function, args, expected, description]
  rows:
    - [toerr_qualname_len,  TimeoutError.__qualname__.__len__,               [],                12,  "TimeoutError.__qualname__.__len__() == 12 — len('TimeoutError') == 12; verified with Python 3.14.3"]
    - [toerr_base_name,     "TimeoutError.__bases__[0].__name__.__eq__",     ["ProcessError"],  true, "TimeoutError.__bases__[0].__name__ == 'ProcessError' — multiprocessing.TimeoutError subclasses ProcessError, not builtins.TimeoutError; verified with Python 3.14.3"]
    - [autherr_len_cross,   AuthenticationError.__qualname__.__len__,        [],                19,  "AuthenticationError.__qualname__.__len__() == 19 — cross-check; verified with Python 3.14.3"]

