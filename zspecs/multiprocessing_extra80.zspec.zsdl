spec: multiprocessing_extra80
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra79.zspec.zsdl."
    - "This spec covers: wave 245 theme — multiprocessing exception __qualname__ lengths. NEW in extra80: ProcessError.__qualname__=='ProcessError'; ProcessError.__qualname__.__len__()==12 (len('ProcessError')==12); AuthenticationError.__qualname__.__len__()==19 (len('AuthenticationError')==19); BufferTooShort.__qualname__.__len__()==14 (len('BufferTooShort')==14, note: prompt said 13 but actual value is 14); TimeoutError.__qualname__.__len__()==12 (len('TimeoutError')==12); ProcessError.__module__=='multiprocessing.context'; AuthenticationError.__module__=='multiprocessing.context'; BufferTooShort.__bases__[0].__name__=='ProcessError'; AuthenticationError.__bases__[0].__name__=='ProcessError'; TimeoutError.__bases__[0].__name__=='ProcessError'; ProcessError.__bases__[0].__name__=='Exception'; ProcessError.__mro__.__len__()==4 (ProcessError, Exception, BaseException, object). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__qualname__ == 'ProcessError'. Simple class qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__qualname__.__len__() == 12. len('ProcessError') == 12. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__qualname__.__len__() == 19. len('AuthenticationError') == 19. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.BufferTooShort.__qualname__.__len__() == 14. len('BufferTooShort') == 14. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.TimeoutError.__qualname__.__len__() == 12. len('TimeoutError') == 12. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__module__ == 'multiprocessing.context'. Exceptions are defined in multiprocessing.context, not in multiprocessing directly. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__module__ == 'multiprocessing.context'. Same module as ProcessError. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'. BufferTooShort is a direct subclass of ProcessError. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError'. AuthenticationError is a direct subclass of ProcessError. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError'. TimeoutError is a direct subclass of ProcessError. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception'. ProcessError is a direct subclass of Exception. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__mro__.__len__() == 4. MRO is [ProcessError, Exception, BaseException, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing ProcessError qualname and module checks — extra80
#
# Wave 245 theme: multiprocessing exception __qualname__ lengths.
#
# ProcessError.__qualname__ == 'ProcessError'
# ProcessError.__qualname__.__len__() == 12
# ProcessError.__module__ == 'multiprocessing.context'
# ProcessError.__bases__[0].__name__ == 'Exception'
# ProcessError.__mro__.__len__() == 4
# ---------------------------------------------------------------------------

table multiprocessing_extra80.ProcessError_qualname_and_module:
  description: "multiprocessing ProcessError qualname, module, and hierarchy checks in mpextra80 namespace — wave 245 theme: multiprocessing exception __qualname__ lengths; ProcessError.__qualname__=='ProcessError'; ProcessError.__qualname__.__len__()==12 (len('ProcessError')==12); ProcessError.__module__=='multiprocessing.context' (defined in multiprocessing.context not top-level); ProcessError.__bases__[0].__name__=='Exception'; ProcessError.__mro__.__len__()==4 (ProcessError, Exception, BaseException, object); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpextra80

  columns: [id, function, args, expected, description]
  rows:
    - [perr_qualname,       ProcessError.__qualname__.__eq__,              ["ProcessError"],             true, "ProcessError.__qualname__ == 'ProcessError' — simple class qualname; verified with Python 3.14.3"]
    - [perr_qualname_len,   ProcessError.__qualname__.__len__,             [],                           12,  "ProcessError.__qualname__.__len__() == 12 — len('ProcessError') == 12; verified with Python 3.14.3"]
    - [perr_module,         ProcessError.__module__.__eq__,                ["multiprocessing.context"],  true, "ProcessError.__module__ == 'multiprocessing.context' — defined in multiprocessing.context submodule; verified with Python 3.14.3"]
    - [perr_base_name,      "ProcessError.__bases__[0].__name__.__eq__",   ["Exception"],               true, "ProcessError.__bases__[0].__name__ == 'Exception' — direct subclass of Exception; verified with Python 3.14.3"]
    - [perr_mro_len,        "ProcessError.__mro__.__len__",                [],                           4,   "ProcessError.__mro__.__len__() == 4 — MRO is [ProcessError, Exception, BaseException, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing AuthenticationError and BufferTooShort qualname lengths — extra80
#
# AuthenticationError.__qualname__.__len__() == 19
# AuthenticationError.__module__ == 'multiprocessing.context'
# AuthenticationError.__bases__[0].__name__ == 'ProcessError'
# BufferTooShort.__qualname__.__len__() == 14
# BufferTooShort.__bases__[0].__name__ == 'ProcessError'
# ---------------------------------------------------------------------------

table multiprocessing_extra80.AuthenticationError_and_BufferTooShort_qualnames:
  description: "multiprocessing AuthenticationError and BufferTooShort qualname length and hierarchy checks in mpextra80 namespace — wave 245 theme: exception __qualname__ lengths; AuthenticationError.__qualname__.__len__()==19 (len('AuthenticationError')==19); AuthenticationError.__module__=='multiprocessing.context'; AuthenticationError.__bases__[0].__name__=='ProcessError'; BufferTooShort.__qualname__.__len__()==14 (len('BufferTooShort')==14); BufferTooShort.__bases__[0].__name__=='ProcessError'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpextra80a

  columns: [id, function, args, expected, description]
  rows:
    - [autherr_qualname_len,  AuthenticationError.__qualname__.__len__,            [],                          19,  "AuthenticationError.__qualname__.__len__() == 19 — len('AuthenticationError') == 19; verified with Python 3.14.3"]
    - [autherr_module,        AuthenticationError.__module__.__eq__,               ["multiprocessing.context"], true, "AuthenticationError.__module__ == 'multiprocessing.context' — defined in multiprocessing.context submodule; verified with Python 3.14.3"]
    - [autherr_base_name,     "AuthenticationError.__bases__[0].__name__.__eq__",  ["ProcessError"],            true, "AuthenticationError.__bases__[0].__name__ == 'ProcessError' — direct subclass of ProcessError; verified with Python 3.14.3"]
    - [buf_qualname_len,      BufferTooShort.__qualname__.__len__,                 [],                          14,  "BufferTooShort.__qualname__.__len__() == 14 — len('BufferTooShort') == 14; verified with Python 3.14.3"]
    - [buf_base_name,         "BufferTooShort.__bases__[0].__name__.__eq__",       ["ProcessError"],            true, "BufferTooShort.__bases__[0].__name__ == 'ProcessError' — direct subclass of ProcessError; verified with Python 3.14.3"]

