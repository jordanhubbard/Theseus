spec: theseus_compression_cr
version: ">=3.14"
backend: python_cleanroom(theseus_compression_cr)
blocks: compression

docs: https://docs.python.org/3/library/compression.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/compression.html"
  not_derived_from:
    - "CPython source: Lib/compression/__init__.py"
  notes:
    - "Clean-room compression namespace package (Python 3.14+). Do NOT import compression."

error_model: python_exceptions

invariant theseus_compression_cr.comp2_package:
  description: "compression is a namespace package"
  category: behavior
  kind: python_call_eq
  function: comp2_package
  args: []
  expected: true

invariant theseus_compression_cr.comp2_name:
  description: "module __name__ is set correctly"
  category: behavior
  kind: python_call_eq
  function: comp2_name
  args: []
  expected: true

invariant theseus_compression_cr.comp2_importable:
  description: "module can be imported without error"
  category: behavior
  kind: python_call_eq
  function: comp2_importable
  args: []
  expected: true
