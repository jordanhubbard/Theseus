spec: concurrent_futures_extra25
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra24.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity, exception bases (CancelledError→Error, TimeoutError→OSError, BrokenExecutor→RuntimeError, InvalidStateError→Error), as_completed/wait __name__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values, thread/process submodule __name__."
    - "This spec covers: ThreadPoolExecutor/ProcessPoolExecutor/Future __module__.__len__(); ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__.__len__(); as_completed/wait __qualname__; as_completed/wait __module__.__len__()."
    - "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' — length 25."
    - "ProcessPoolExecutor.__module__ == 'concurrent.futures.process' — length 26."
    - "Future.__module__ == 'concurrent.futures._base' — length 24."
    - "ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' — length 18."
    - "ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' — length 19."
    - "Future.__name__ == 'Future' — length 6."
    - "Executor.__name__ == 'Executor' — length 8."
    - "as_completed.__qualname__ == 'as_completed' — module-level generator function."
    - "wait.__qualname__ == 'wait' — module-level function."
    - "as_completed.__module__ == 'concurrent.futures._base' — length 24."
    - "wait.__module__ == 'concurrent.futures._base' — length 24."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __module__ length table — extra25 namespace
#
# ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (length 25).
# ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (length 26).
# Future.__module__ == 'concurrent.futures._base' (length 24).
# Prior specs verify the string values; this spec adds the __len__() axis.
# ---------------------------------------------------------------------------

table concurrent_futures_extra25.class_module_lengths:
  description: "concurrent.futures class __module__ lengths in extra25 namespace"
  kind: python_call_eq
  category: class_modules
  id_prefix: clsmodlen25

  columns: [id, function, args, expected]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__module__.__len__,  [], 25]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__module__.__len__, [], 26]
    - [Future,              Future.__module__.__len__,              [], 24]

# ---------------------------------------------------------------------------
# Class __name__ length table — extra25 namespace
#
# ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' (length 18).
# ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' (length 19).
# Future.__name__ == 'Future' (length 6).
# Executor.__name__ == 'Executor' (length 8).
# Prior specs verify the string values; this spec adds the __len__() axis.
# ---------------------------------------------------------------------------

table concurrent_futures_extra25.class_name_lengths:
  description: "concurrent.futures class __name__ lengths in extra25 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: clsnamelen25

  columns: [id, function, args, expected]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__name__.__len__,  [], 18]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__name__.__len__, [], 19]
    - [Future,              Future.__name__.__len__,              [], 6]
    - [Executor,            Executor.__name__.__len__,            [], 8]

# ---------------------------------------------------------------------------
# Module-level function __qualname__ table — extra25 namespace
#
# concurrent.futures.as_completed and wait are module-level functions defined
# in concurrent.futures._base. Their __qualname__ matches their __name__ —
# they are not nested inside any class.
# as_completed.__qualname__ == 'as_completed' (length 12).
# wait.__qualname__ == 'wait' (length 4).
# concurrent_futures_extra6 checks __qualname__ indirectly; this spec makes
# it explicit in the extra25 namespace.
# ---------------------------------------------------------------------------

table concurrent_futures_extra25.function_qualnames:
  description: "concurrent.futures module-level function __qualname__ values in extra25 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: fqualname25

  columns: [id, function, args, expected]
  rows:
    - [as_completed, as_completed.__qualname__.__eq__, ["as_completed"], true]
    - [wait,         wait.__qualname__.__eq__,         ["wait"],         true]

# ---------------------------------------------------------------------------
# Module-level function __module__ length table — extra25 namespace
#
# Both as_completed and wait are defined in concurrent.futures._base.
# Their __module__ == 'concurrent.futures._base' (length 24).
# This spec adds the __len__() axis for these two functions.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra25.as_completed_module_len:
  description: "concurrent.futures.as_completed.__module__.__len__() == 24 — defined in concurrent.futures._base"
  category: class_modules
  kind: python_call_eq
  function: as_completed.__module__.__len__
  args: []
  expected: 24

invariant concurrent_futures_extra25.wait_module_len:
  description: "concurrent.futures.wait.__module__.__len__() == 24 — defined in concurrent.futures._base"
  category: class_modules
  kind: python_call_eq
  function: wait.__module__.__len__
  args: []
  expected: 24
