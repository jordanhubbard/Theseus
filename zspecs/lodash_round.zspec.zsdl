spec: lodash_round
version: ">=4.0.0"
backend: node(lodash.round)

docs: https://lodash.com/docs/#round

provenance:
  derived_from:
    - "lodash.round README — https://www.npmjs.com/package/lodash.round"
    - "Test vectors verified with lodash.round@4.0.4 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.round exports the _.round function directly as module.exports."
    - "round(number, precision) rounds number to the given decimal precision."
    - "Precision defaults to 0 (integer rounding) if omitted."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a rounded number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_round.round:
  kind: node_module_call_eq
  function: ~
  category: round
  id_prefix: lrnd

  columns: [id, args, expected]
  rows:
    - [two_places,   [4.567, 2],  4.57]
    - [one_place,    [4.567, 1],  4.6]
    - [integer,      [4.567, 0],  5]
    - [negative,     [-4.5, 0],   -4]
    - [no_change,    [4.5, 1],    4.5]

