spec: decimal_extra1591
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — descriptor protocol checks via __dict__.__contains__ for decimal.Decimal, decimal.Context, and decimal.DecimalException"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for descriptor protocol: decimal.Decimal is a numeric value type and decimal.Context is a configuration object — neither implements the descriptor protocol (__get__, __set__, __delete__)"
    - "decimal.Decimal defines a comprehensive arithmetic protocol including both forward and reflected operators, conversion methods (__int__, __float__, __bool__), and rounding support (__round__, __floor__, __ceil__, __trunc__)"
  created_at: "2026-04-12"
error_model: python_exceptions

table decimal_extra1591.decimal_no_descriptor:
  description: "decimal.Decimal is a numeric value type, not a descriptor — it defines no __get__, __set__, or __delete__ in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1591dn

  columns: [id, function, args, expected]
  rows:
    - [dc1591dn001, decimal.Decimal.__dict__.__contains__, ["__get__"],      false]
    - [dc1591dn002, decimal.Decimal.__dict__.__contains__, ["__set__"],      false]
    - [dc1591dn003, decimal.Decimal.__dict__.__contains__, ["__delete__"],   false]
    - [dc1591dn004, decimal.Decimal.__dict__.__contains__, ["__set_name__"], false]
    - [dc1591dn005, decimal.Decimal.__dict__.__contains__, ["__call__"],     false]
    - [dc1591dn006, decimal.Decimal.__dict__.__contains__, ["__add__"],      true]
    - [dc1591dn007, decimal.Decimal.__dict__.__contains__, ["__sub__"],      true]
    - [dc1591dn008, decimal.Decimal.__dict__.__contains__, ["__mul__"],      true]
    - [dc1591dn009, decimal.Decimal.__dict__.__contains__, ["__truediv__"],  true]
    - [dc1591dn010, decimal.Decimal.__dict__.__contains__, ["__radd__"],     true]
    - [dc1591dn011, decimal.Decimal.__dict__.__contains__, ["__rsub__"],     true]
    - [dc1591dn012, decimal.Decimal.__dict__.__contains__, ["__rmul__"],     true]
    - [dc1591dn013, decimal.Decimal.__dict__.__contains__, ["__rtruediv__"], true]
    - [dc1591dn014, decimal.Decimal.__dict__.__contains__, ["__mod__"],      true]
    - [dc1591dn015, decimal.Decimal.__dict__.__contains__, ["__pow__"],      true]
    - [dc1591dn016, decimal.Decimal.__dict__.__contains__, ["__neg__"],      true]
    - [dc1591dn017, decimal.Decimal.__dict__.__contains__, ["__pos__"],      true]
    - [dc1591dn018, decimal.Decimal.__dict__.__contains__, ["__abs__"],      true]
    - [dc1591dn019, decimal.Decimal.__dict__.__contains__, ["__repr__"],     true]
    - [dc1591dn020, decimal.Decimal.__dict__.__contains__, ["__str__"],      true]
    - [dc1591dn021, decimal.Decimal.__dict__.__contains__, ["__bool__"],     true]
    - [dc1591dn022, decimal.Decimal.__dict__.__contains__, ["__int__"],      true]
    - [dc1591dn023, decimal.Decimal.__dict__.__contains__, ["__float__"],    true]
    - [dc1591dn024, decimal.Decimal.__dict__.__contains__, ["__hash__"],     true]
    - [dc1591dn025, decimal.Decimal.__dict__.__contains__, ["__eq__"],       true]
    - [dc1591dn026, decimal.Decimal.__dict__.__contains__, ["__lt__"],       true]
    - [dc1591dn027, decimal.Decimal.__dict__.__contains__, ["__le__"],       true]
    - [dc1591dn028, decimal.Decimal.__dict__.__contains__, ["__gt__"],       true]
    - [dc1591dn029, decimal.Decimal.__dict__.__contains__, ["__ge__"],       true]
    - [dc1591dn030, decimal.Decimal.__dict__.__contains__, ["__ne__"],       true]

table decimal_extra1591.context_no_descriptor:
  description: "decimal.Context is a rounding configuration object, and decimal.DecimalException is an exception base — neither implements the descriptor protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1591cn

  columns: [id, function, args, expected]
  rows:
    - [dc1591cn001, decimal.Context.__dict__.__contains__,          ["__get__"],      false]
    - [dc1591cn002, decimal.Context.__dict__.__contains__,          ["__set__"],      false]
    - [dc1591cn003, decimal.Context.__dict__.__contains__,          ["__delete__"],   false]
    - [dc1591cn004, decimal.DecimalException.__dict__.__contains__,  ["__get__"],      false]
    - [dc1591cn005, decimal.DecimalException.__dict__.__contains__,  ["__set__"],      false]
    - [dc1591cn006, decimal.DecimalException.__dict__.__contains__,  ["__delete__"],   false]
    - [dc1591cn007, decimal.Context.__dict__.__contains__,          ["__set_name__"], false]
    - [dc1591cn008, decimal.Context.__dict__.__contains__,          ["__call__"],     false]
    - [dc1591cn009, decimal.Context.__dict__.__contains__,          ["__repr__"],     true]
    - [dc1591cn010, decimal.Context.__dict__.__contains__,          ["__setattr__"],  true]
    - [dc1591cn011, decimal.Context.__dict__.__contains__,          ["__copy__"],     true]
    - [dc1591cn012, decimal.Context.__dict__.__contains__,          ["__reduce__"],   true]
    - [dc1591cn013, decimal.Context.__dict__.__contains__,          ["add"],          true]
    - [dc1591cn014, decimal.Context.__dict__.__contains__,          ["subtract"],     true]
    - [dc1591cn015, decimal.Context.__dict__.__contains__,          ["multiply"],     true]
    - [dc1591cn016, decimal.Context.__dict__.__contains__,          ["divide"],       true]
    - [dc1591cn017, decimal.Context.__dict__.__contains__,          ["sqrt"],         true]
    - [dc1591cn018, decimal.Context.__dict__.__contains__,          ["create_decimal"], true]
    - [dc1591cn019, decimal.Context.__dict__.__contains__,          ["create_decimal_from_float"], true]
    - [dc1591cn020, decimal.Context.__dict__.__contains__,          ["clear_flags"],  true]
    - [dc1591cn021, decimal.Context.__dict__.__contains__,          ["clear_traps"],  true]
    - [dc1591cn022, decimal.Context.__dict__.__contains__,          ["copy"],         true]
    - [dc1591cn023, decimal.Context.__dict__.__contains__,          ["power"],        true]
    - [dc1591cn024, decimal.Context.__dict__.__contains__,          ["divmod"],       true]
    - [dc1591cn025, decimal.Context.__dict__.__contains__,          ["quantize"],     true]

