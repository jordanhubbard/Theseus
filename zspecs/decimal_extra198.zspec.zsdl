spec: decimal_extra198
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra197.zspec.zsdl — covers decimal class attribute identity"
  notes:
    - "This spec covers decimal module-level dunder attributes: __name__, __package__, __spec__.name, __loader__.__class__.__name__, __doc__.__class__.__name__."
    - "decimal.__name__ == 'decimal'; the module name is the string 'decimal'; confirmed Python 3.14.3 macOS."
    - "decimal.__package__ == ''; decimal is a top-level module with no parent package; confirmed Python 3.14.3 macOS."
    - "decimal.__spec__.name == 'decimal'; the ModuleSpec name matches the module __name__; confirmed Python 3.14.3 macOS."
    - "decimal.__loader__.__class__.__name__ == 'SourceFileLoader'; on this CPython build the decimal module is the pure-Python wrapper loaded by SourceFileLoader; confirmed Python 3.14.3 macOS."
    - "decimal.__doc__.__class__.__name__ == 'str'; the module docstring is a str object; confirmed Python 3.14.3 macOS."
    - "Note: on CPython, 'import decimal' loads the pure-Python Lib/decimal.py (or Lib/_pydecimal.py); the C accelerator is _decimal. The __loader__ reflects the pure-Python wrapper and is SourceFileLoader; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal module __name__ identity
# __name__ == 'decimal', length == 7
# ---------------------------------------------------------------------------

table decimal_extra198.module_name:
  description: "decimal module __name__ attribute identity: value, equality, and length"
  kind: python_call_eq
  category: module_identity
  id_prefix: decimalmod198

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,            decimal.__name__.__eq__,   ["decimal"],  true,  "decimal.__name__ == 'decimal'; the module name is the string 'decimal'; confirmed Python 3.14.3 macOS"]
    - [name_len,           decimal.__name__.__len__,  [],           7,     "decimal.__name__.__len__() == 7; 'decimal' has d(1)e(2)c(3)i(4)m(5)a(6)l(7); confirmed Python 3.14.3 macOS"]
    - [name_not_cdecimal,  decimal.__name__.__eq__,   ["_decimal"], false, "decimal.__name__ != '_decimal'; the public module name differs from the C accelerator name; confirmed Python 3.14.3 macOS"]
    - [name_not_empty,     decimal.__name__.__eq__,   [""],         false, "decimal.__name__ is not empty string; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal module __package__ and __spec__.name identity
# __package__ == '', __spec__.name == 'decimal'
# ---------------------------------------------------------------------------

table decimal_extra198.module_package_and_spec:
  description: "decimal module __package__ and __spec__.name attribute identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: decimalmod198

  columns: [id, function, args, expected, description]
  rows:
    - [package_eq,      decimal.__package__.__eq__,      [""],         true,  "decimal.__package__ == ''; decimal is a top-level module with no parent package; confirmed Python 3.14.3 macOS"]
    - [package_len,     decimal.__package__.__len__,     [],           0,     "decimal.__package__.__len__() == 0; empty package string has length zero; confirmed Python 3.14.3 macOS"]
    - [spec_name_eq,    decimal.__spec__.name.__eq__,    ["decimal"],  true,  "decimal.__spec__.name == 'decimal'; the ModuleSpec name matches the module __name__; confirmed Python 3.14.3 macOS"]
    - [spec_name_len,   decimal.__spec__.name.__len__,   [],           7,     "decimal.__spec__.name.__len__() == 7; 'decimal' has d(1)e(2)c(3)i(4)m(5)a(6)l(7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal module __loader__ and __doc__ class names
# __loader__.__class__.__name__ == 'SourceFileLoader', __doc__.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table decimal_extra198.module_loader_and_doc:
  description: "decimal module __loader__.__class__.__name__ and __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: decimalmod198

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_eq,   decimal.__loader__.__class__.__name__.__eq__,    ["SourceFileLoader"], true,  "decimal.__loader__.__class__.__name__ == 'SourceFileLoader'; the decimal module is the pure-Python wrapper loaded by SourceFileLoader; confirmed Python 3.14.3 macOS"]
    - [loader_class_len,  decimal.__loader__.__class__.__name__.__len__,   [],                  16,    "decimal.__loader__.__class__.__name__.__len__() == 16; 'SourceFileLoader' has 16 characters; confirmed Python 3.14.3 macOS"]
    - [doc_class_eq,      decimal.__doc__.__class__.__name__.__eq__,       ["str"],             true,  "decimal.__doc__.__class__.__name__ == 'str'; the module docstring is a str object; confirmed Python 3.14.3 macOS"]
    - [doc_class_len,     decimal.__doc__.__class__.__name__.__len__,      [],                  3,     "decimal.__doc__.__class__.__name__.__len__() == 3; 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra198.name_eq:
  description: "decimal.__name__ == 'decimal' — the module name is the string 'decimal'; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: decimal.__name__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra198.name_len:
  description: "decimal.__name__.__len__() == 7 — 'decimal' has seven characters; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: decimal.__name__.__len__
  args: []
  expected: 7

invariant decimal_extra198.package_eq:
  description: "decimal.__package__ == '' — decimal is a top-level module with no parent package; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: decimal.__package__.__eq__
  args: [""]
  expected: true

invariant decimal_extra198.package_len:
  description: "decimal.__package__.__len__() == 0 — empty package string has length zero; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: decimal.__package__.__len__
  args: []
  expected: 0

invariant decimal_extra198.spec_name_eq:
  description: "decimal.__spec__.name == 'decimal' — the ModuleSpec name matches the module __name__; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: decimal.__spec__.name.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra198.spec_name_len:
  description: "decimal.__spec__.name.__len__() == 7 — 'decimal' has d(1)e(2)c(3)i(4)m(5)a(6)l(7); confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: decimal.__spec__.name.__len__
  args: []
  expected: 7

invariant decimal_extra198.loader_class_name_eq:
  description: "decimal.__loader__.__class__.__name__ == 'SourceFileLoader' — the decimal module is the pure-Python wrapper loaded by SourceFileLoader; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: decimal.__loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant decimal_extra198.doc_class_name_eq:
  description: "decimal.__doc__.__class__.__name__ == 'str' — the module docstring is a str object; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: decimal.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
