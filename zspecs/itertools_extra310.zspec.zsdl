spec: itertools_extra310
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "itertools.islice('abc', -1) raises ValueError — stop must be None or an integer >= 0."
    - "itertools.islice('abc', 0, 10, 0) raises ValueError — step must be a positive integer or None."
    - "itertools.repeat(1, -1) does NOT raise — it silently produces an empty iterator (immediately StopIteration)."
    - "itertools.cycle.__doc__.__len__() == 95 — verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "itertools.accumulate.__doc__.__len__() == 69 — verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "itertools.chain.from_iterable.__name__ == 'from_iterable'."
    - "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# islice error cases — invalid stop and step arguments
#
# islice enforces: stop >= 0 (or None), step >= 1 (or None).
# Negative stop or zero step raise ValueError immediately at construction.
# ---------------------------------------------------------------------------

invariant itertools_extra310.islice_negative_stop_raises:
  description: "itertools.islice('abc', -1) raises ValueError — stop must be None or an integer >= 0"
  category: errors
  kind: python_call_raises
  function: islice
  args: ["abc", -1]
  raises: ValueError

invariant itertools_extra310.islice_zero_step_raises:
  description: "itertools.islice('abc', 0, 10, 0) raises ValueError — step must be a positive integer or None"
  category: errors
  kind: python_call_raises
  function: islice
  args: ["abc", 0, 10, 0]
  raises: ValueError

# ---------------------------------------------------------------------------
# cycle and accumulate docstrings
#
# Both cycle and accumulate expose C-level __doc__ strings.
# Lengths verified on Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant itertools_extra310.cycle_doc_len:
  description: "itertools.cycle.__doc__.__len__() == 95 — cycle docstring length verified Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: cycle.__doc__.__len__
  args: []
  expected: 95

invariant itertools_extra310.accumulate_doc_len:
  description: "itertools.accumulate.__doc__.__len__() == 69 — accumulate docstring length verified Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: accumulate.__doc__.__len__
  args: []
  expected: 69

# ---------------------------------------------------------------------------
# chain.from_iterable identity
#
# chain.from_iterable is a classmethod descriptor on the chain C-type.
# Its __name__ is 'from_iterable' and __qualname__ is 'chain.from_iterable'.
# ---------------------------------------------------------------------------

invariant itertools_extra310.chain_from_iterable_name:
  description: "itertools.chain.from_iterable.__name__ == 'from_iterable'"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__name__.__eq__
  args: ["from_iterable"]
  expected: true

invariant itertools_extra310.chain_from_iterable_qualname:
  description: "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__eq__
  args: ["chain.from_iterable"]
  expected: true
