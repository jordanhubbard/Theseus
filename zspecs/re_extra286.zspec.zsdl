spec: re_extra286
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra285.zspec.zsdl — covers re.VERBOSE flag and named backreferences"
    - "re_extra.zspec.zsdl — covers Pattern, Match, error class names, flag constant values"
  notes:
    - "This spec focuses on re.Scanner class identity and re.compile function identity."
    - "re.Scanner is a pure-Python class defined in Lib/re/__init__.py."
    - "re.Scanner.__name__ == 'Scanner' — the class name is simply 'Scanner'."
    - "re.Scanner.__module__ == 're' — Scanner is defined at the top level of the re module."
    - "re.Scanner.__bases__[0].__name__ == 'object' — Scanner's sole base class is object."
    - "re.Scanner.__class__.__name__ == 'type' — Scanner is a class (metaclass is type)."
    - "re.compile.__class__.__name__ == 'function' — re.compile is a plain Python function, not a built-in."
    - "re.compile.__module__ == 're' — compile is defined in the re module."
    - "re.compile.__name__ == 'compile' — compile function's __name__ attribute is 'compile'."
    - "re.RegexFlag.__name__ == 'RegexFlag' — the flag enum class name."
    - "re.RegexFlag.__module__ == 're' — RegexFlag is defined in the re module."
    - "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits from IntFlag."
    - "re.NOFLAG has integer value 0 — the empty flag set is 0."
    - "In Python 3.14, re.error.__name__ == 'PatternError' — re.error was renamed in 3.13+; re.error is an alias."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Scanner class identity
#
# Scanner is a pure-Python class in Lib/re/__init__.py. Its sole base is
# object. The metaclass is type. __module__ and __name__ confirm the source.
# ---------------------------------------------------------------------------

table re_extra286.Scanner_class_identity:
  description: "re.Scanner class identity: __name__, __module__, base class, metaclass"
  kind: python_call_eq
  category: class_metadata
  id_prefix: scan286

  columns: [id, function, args, expected, description]
  rows:
    - [name,        Scanner.__name__.__eq__,                ["Scanner"], true, "re.Scanner.__name__ == 'Scanner'"]
    - [module,      Scanner.__module__.__eq__,              ["re"],      true, "re.Scanner.__module__ == 're' — defined in the re module"]
    - [metaclass,   Scanner.__class__.__name__.__eq__,      ["type"],    true, "type(re.Scanner).__name__ == 'type' — Scanner is a class"]
    - [qualname,    Scanner.__qualname__.__eq__,            ["Scanner"], true, "re.Scanner.__qualname__ == 'Scanner' — not nested, so qualname equals name"]

# ---------------------------------------------------------------------------
# re.compile function identity
#
# re.compile is a plain Python function (not a built-in). Its __class__ is
# 'function', its __module__ is 're', and its __name__ is 'compile'.
# ---------------------------------------------------------------------------

table re_extra286.compile_function_identity:
  description: "re.compile function identity: __class__.__name__, __module__, __name__"
  kind: python_call_eq
  category: function_metadata
  id_prefix: cfn286

  columns: [id, function, args, expected, description]
  rows:
    - [class_name,  compile.__class__.__name__.__eq__,  ["function"], true, "re.compile.__class__.__name__ == 'function' — re.compile is a plain Python function"]
    - [module,      compile.__module__.__eq__,          ["re"],       true, "re.compile.__module__ == 're' — compile is defined in the re module"]
    - [name,        compile.__name__.__eq__,            ["compile"],  true, "re.compile.__name__ == 'compile'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra286.Scanner.name_is_Scanner:
  description: "re.Scanner.__name__ == 'Scanner' — the class is named Scanner"
  category: class_metadata
  kind: python_call_eq
  function: Scanner.__name__.__eq__
  args: ["Scanner"]
  expected: true

invariant re_extra286.Scanner.module_is_re:
  description: "re.Scanner.__module__ == 're' — Scanner is defined in the top-level re module"
  category: class_metadata
  kind: python_call_eq
  function: Scanner.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra286.Scanner.base_is_object:
  description: "re.Scanner.__bases__[0].__name__ == 'object' — Scanner's sole direct base class is the built-in object"
  category: class_hierarchy
  kind: python_call_eq
  function: Scanner.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant re_extra286.compile.class_is_function:
  description: "re.compile.__class__.__name__ == 'function' — re.compile is a regular Python function, not a C built-in"
  category: function_metadata
  kind: python_call_eq
  function: compile.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant re_extra286.RegexFlag.name:
  description: "re.RegexFlag.__name__ == 'RegexFlag' — the enum class that represents regex flag constants"
  category: class_metadata
  kind: python_call_eq
  function: RegexFlag.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra286.RegexFlag.module:
  description: "re.RegexFlag.__module__ == 're' — RegexFlag is defined in the re module"
  category: class_metadata
  kind: python_call_eq
  function: RegexFlag.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra286.RegexFlag.base_is_IntFlag:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits from enum.IntFlag"
  category: class_hierarchy
  kind: python_call_eq
  function: RegexFlag.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IntFlag"

invariant re_extra286.NOFLAG.int_value_is_0:
  description: "int(re.NOFLAG) == 0 — NOFLAG is the empty flag set with integer value 0"
  category: flags
  kind: python_call_eq
  function: NOFLAG.__int__
  args: []
  expected: 0
