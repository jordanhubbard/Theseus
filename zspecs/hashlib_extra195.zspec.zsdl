spec: hashlib_extra195
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/md5module.c"
  notes:
    - "hashlib.algorithms_guaranteed and hashlib.algorithms_available are both plain Python sets (type 'set' in module 'builtins')."
    - "hashlib.algorithms_guaranteed.__contains__ is a builtin_function_or_method — it is the set membership test method."
    - "hashlib.__name__ == 'hashlib' and hashlib.__package__ == '' — hashlib is a top-level stdlib module with no package prefix."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# algorithms_guaranteed — class name and module checks
# ---------------------------------------------------------------------------

table hashlibmodule195.algorithms_guaranteed.class_checks:
  kind: python_call_eq
  category: algorithms
  id_prefix: hashlibmodule195

  columns: [id, function, args, expected, description]
  rows:
    - [alg_guar_class_name,   algorithms_guaranteed.__class__.__name__.__eq__,   ["set"],      true, "algorithms_guaranteed.__class__.__name__ == 'set'"]
    - [alg_guar_class_module, algorithms_guaranteed.__class__.__module__.__eq__,  ["builtins"], true, "algorithms_guaranteed.__class__.__module__ == 'builtins'"]
    - [alg_avail_class_name,  algorithms_available.__class__.__name__.__eq__,    ["set"],      true, "algorithms_available.__class__.__name__ == 'set'"]
    - [alg_avail_class_module,algorithms_available.__class__.__module__.__eq__,   ["builtins"], true, "algorithms_available.__class__.__module__ == 'builtins'"]

# ---------------------------------------------------------------------------
# algorithms_guaranteed.__contains__ — method identity
# ---------------------------------------------------------------------------

table hashlibmodule195.algorithms_guaranteed.contains_checks:
  kind: python_call_eq
  category: algorithms
  id_prefix: hashlibmodule195

  columns: [id, function, args, expected, description]
  rows:
    - [contains_name,  algorithms_guaranteed.__contains__.__name__.__eq__,          ["__contains__"],               true, "algorithms_guaranteed.__contains__.__name__ == '__contains__'"]
    - [contains_class, algorithms_guaranteed.__contains__.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "algorithms_guaranteed.__contains__.__class__.__name__ == 'builtin_function_or_method'"]

# ---------------------------------------------------------------------------
# hashlib module identity — __name__ and __package__
# ---------------------------------------------------------------------------

table hashlibmodule195.module_identity:
  kind: python_call_eq
  category: module_identity
  id_prefix: hashlibmodule195

  columns: [id, function, args, expected, description]
  rows:
    - [module_name,    __name__.__eq__,    ["hashlib"], true, "hashlib.__name__ == 'hashlib'"]
    - [module_package, __package__.__eq__, [""],        true, "hashlib.__package__ == ''"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlibmodule195.algorithms_guaranteed.class_name:
  description: "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

invariant hashlibmodule195.algorithms_available.class_name:
  description: "hashlib.algorithms_available.__class__.__name__ == 'set'"
  category: algorithms
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

invariant hashlibmodule195.algorithms_guaranteed.class_module:
  description: "hashlib.algorithms_guaranteed.__class__.__module__ == 'builtins'"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant hashlibmodule195.algorithms_available.class_module:
  description: "hashlib.algorithms_available.__class__.__module__ == 'builtins'"
  category: algorithms
  kind: python_call_eq
  function: algorithms_available.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant hashlibmodule195.algorithms_guaranteed.contains_name:
  description: "hashlib.algorithms_guaranteed.__contains__.__name__ == '__contains__'"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__.__name__.__eq__
  args: ["__contains__"]
  expected: true

invariant hashlibmodule195.algorithms_guaranteed.contains_class_name:
  description: "hashlib.algorithms_guaranteed.__contains__.__class__.__name__ == 'builtin_function_or_method'"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant hashlibmodule195.module.name:
  description: "hashlib.__name__ == 'hashlib'"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlibmodule195.module.package:
  description: "hashlib.__package__ == '' (top-level stdlib module, no package prefix)"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true
