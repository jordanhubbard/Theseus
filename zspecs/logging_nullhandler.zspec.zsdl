spec: logging_nullhandler
version: ">=3.2"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "Python logging documentation — https://docs.python.org/3/library/logging.html"
    - "Test vectors verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
    - "logging.zspec.zsdl — covers level constants, getLevelName, ordering, and class/function __name__ checks"
    - "logging_handlers.zspec.zsdl — covers logging.handlers submodule classes and port constants"
    - "logging_config.zspec.zsdl — covers logging.config classes and dictConfig/fileConfig functions"
  notes:
    - "logging.NullHandler is a no-op handler for library authors; it lives in logging itself, not logging.handlers."
    - "NullHandler.__module__ is 'logging' (defined in logging/__init__.py, not a submodule)."
    - "NullHandler.__bases__[0].__name__ is 'Handler'."
    - "logging.Handler.__bases__[0].__name__ is 'Filterer' — Handler inherits from Filterer."
    - "logging.Logger.__bases__[0].__name__ is 'Filterer' — Logger also inherits from Filterer."
    - "logging.StreamHandler.__bases__[0].__name__ is 'Handler'."
    - "logging.FileHandler.__bases__[0].__name__ is 'StreamHandler' — FileHandler subclasses StreamHandler."
    - "logging.Formatter.__module__ is 'logging'."
    - "logging.Filter.__module__ is 'logging'."
    - "logging.LoggerAdapter.__module__ is 'logging'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NullHandler — class name, module, and base (not covered elsewhere)
# ---------------------------------------------------------------------------

invariant logging_nullhandler.nullhandler_name:
  description: "logging.NullHandler.__name__ == 'NullHandler'"
  category: class_names
  kind: python_call_eq
  function: NullHandler.__name__.__eq__
  args: ["NullHandler"]
  expected: true

invariant logging_nullhandler.nullhandler_module:
  description: "logging.NullHandler.__module__ == 'logging'"
  category: class_modules
  kind: python_call_eq
  function: NullHandler.__module__.__eq__
  args: ["logging"]
  expected: true

invariant logging_nullhandler.nullhandler_base:
  description: "logging.NullHandler.__bases__[0].__name__ == 'Handler'"
  category: bases
  kind: python_call_eq
  function: NullHandler.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Handler"

# ---------------------------------------------------------------------------
# Inheritance chain — module checks and base class checks
# ---------------------------------------------------------------------------

table logging_nullhandler.class_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [handler,       Handler.__module__.__eq__,       ["logging"], true]
    - [stream_handler, StreamHandler.__module__.__eq__, ["logging"], true]
    - [file_handler,   FileHandler.__module__.__eq__,   ["logging"], true]
    - [formatter,      Formatter.__module__.__eq__,     ["logging"], true]
    - [filter,         Filter.__module__.__eq__,        ["logging"], true]
    - [logger,         Logger.__module__.__eq__,        ["logging"], true]
    - [loggeradapter,  LoggerAdapter.__module__.__eq__, ["logging"], true]

invariant logging_nullhandler.handler_base:
  description: "logging.Handler.__bases__[0].__name__ == 'Filterer'"
  category: bases
  kind: python_call_eq
  function: Handler.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Filterer"

invariant logging_nullhandler.stream_handler_base:
  description: "logging.StreamHandler.__bases__[0].__name__ == 'Handler'"
  category: bases
  kind: python_call_eq
  function: StreamHandler.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Handler"

invariant logging_nullhandler.file_handler_base:
  description: "logging.FileHandler.__bases__[0].__name__ == 'StreamHandler' — FileHandler subclasses StreamHandler"
  category: bases
  kind: python_call_eq
  function: FileHandler.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "StreamHandler"

invariant logging_nullhandler.logger_base:
  description: "logging.Logger.__bases__[0].__name__ == 'Filterer'"
  category: bases
  kind: python_call_eq
  function: Logger.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Filterer"

