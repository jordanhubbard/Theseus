spec: abc_extra285
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc abstract base classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "All collections.abc ABCs have __module__ == 'collections.abc'"
    - "This includes both sequence/mapping/set types and async/iterator types"
    - "Hashable, Sized, Container, Collection, Reversible all belong to collections.abc"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra285.sequence_mapping_set_modules:
  description: "__module__ identity for sequence, mapping, and set ABCs"
  kind: python_call_eq
  category: identity
  id_prefix: abc285a

  columns: [id, function, args, expected, description]
  rows:
    - [abc285a_001, collections.abc.Sequence.__module__.__eq__, ["collections.abc"], true, "Sequence.__module__ is 'collections.abc'"]
    - [abc285a_002, collections.abc.MutableSequence.__module__.__eq__, ["collections.abc"], true, "MutableSequence.__module__ is 'collections.abc'"]
    - [abc285a_003, collections.abc.Mapping.__module__.__eq__, ["collections.abc"], true, "Mapping.__module__ is 'collections.abc'"]
    - [abc285a_004, collections.abc.MutableMapping.__module__.__eq__, ["collections.abc"], true, "MutableMapping.__module__ is 'collections.abc'"]
    - [abc285a_005, collections.abc.Set.__module__.__eq__, ["collections.abc"], true, "Set.__module__ is 'collections.abc'"]
    - [abc285a_006, collections.abc.MutableSet.__module__.__eq__, ["collections.abc"], true, "MutableSet.__module__ is 'collections.abc'"]
    - [abc285a_007, collections.abc.Iterable.__module__.__eq__, ["collections.abc"], true, "Iterable.__module__ is 'collections.abc'"]
    - [abc285a_008, collections.abc.Iterator.__module__.__eq__, ["collections.abc"], true, "Iterator.__module__ is 'collections.abc'"]
    - [abc285a_009, collections.abc.Generator.__module__.__eq__, ["collections.abc"], true, "Generator.__module__ is 'collections.abc'"]
    - [abc285a_010, collections.abc.Callable.__module__.__eq__, ["collections.abc"], true, "Callable.__module__ is 'collections.abc'"]

table abc_extra285.async_and_utility_modules:
  description: "__module__ identity for async, hashable, sized, and utility ABCs"
  kind: python_call_eq
  category: identity
  id_prefix: abc285b

  columns: [id, function, args, expected, description]
  rows:
    - [abc285b_001, collections.abc.Awaitable.__module__.__eq__, ["collections.abc"], true, "Awaitable.__module__ is 'collections.abc'"]
    - [abc285b_002, collections.abc.Coroutine.__module__.__eq__, ["collections.abc"], true, "Coroutine.__module__ is 'collections.abc'"]
    - [abc285b_003, collections.abc.AsyncIterator.__module__.__eq__, ["collections.abc"], true, "AsyncIterator.__module__ is 'collections.abc'"]
    - [abc285b_004, collections.abc.AsyncGenerator.__module__.__eq__, ["collections.abc"], true, "AsyncGenerator.__module__ is 'collections.abc'"]
    - [abc285b_005, collections.abc.Hashable.__module__.__eq__, ["collections.abc"], true, "Hashable.__module__ is 'collections.abc'"]
    - [abc285b_006, collections.abc.Sized.__module__.__eq__, ["collections.abc"], true, "Sized.__module__ is 'collections.abc'"]
    - [abc285b_007, collections.abc.Container.__module__.__eq__, ["collections.abc"], true, "Container.__module__ is 'collections.abc'"]
    - [abc285b_008, collections.abc.Collection.__module__.__eq__, ["collections.abc"], true, "Collection.__module__ is 'collections.abc'"]
    - [abc285b_009, collections.abc.Reversible.__module__.__eq__, ["collections.abc"], true, "Reversible.__module__ is 'collections.abc'"]

invariant abc_extra285.sequence_module:
  description: "collections.abc.Sequence.__module__ is 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Sequence.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra285.hashable_module:
  description: "collections.abc.Hashable.__module__ is 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Hashable.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra285.async_generator_module:
  description: "collections.abc.AsyncGenerator.__module__ is 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncGenerator.__module__.__eq__
  args: ["collections.abc"]
  expected: true
