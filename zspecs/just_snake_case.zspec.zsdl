spec: just_snake_case
version: ">=3.2.0"
backend: node(just-snake-case)

docs: https://www.npmjs.com/package/just-snake-case

provenance:
  derived_from:
    - "just-snake-case README — https://www.npmjs.com/package/just-snake-case"
    - "Test vectors verified with just-snake-case via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "just-snake-case source"
  notes:
    - "just-snake-case is an npm package. Install: npm install just-snake-case"
    - "Converts a string to snake_case."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_snake_case.convert:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: jsc

  columns: [id, args, expected]
  rows:
    - [from_camel,  ["fooBar"],   "foo_bar"]
    - [from_kebab,  ["foo-bar"],  "foo_bar"]
    - [from_space,  ["Foo Bar"],  "foo_bar"]
