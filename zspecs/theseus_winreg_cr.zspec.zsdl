spec: theseus_winreg_cr
version: ">=3.0"
backend: python_cleanroom(theseus_winreg_cr)
blocks: winreg

docs: https://docs.python.org/3/library/winreg.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/winreg.html"
  not_derived_from:
    - "CPython source: PC/winreg.c"
  notes:
    - "Clean-room winreg stub. Do NOT import winreg."
    - "Windows-only module; stubs raise OSError on non-Windows."

error_model: python_exceptions

invariant theseus_winreg_cr.winreg2_constants:
  description: "winreg constants have correct values"
  category: behavior
  kind: python_call_eq
  function: winreg2_constants
  args: []
  expected: true

invariant theseus_winreg_cr.winreg2_hkeytype:
  description: "HKEYType stub works correctly"
  category: behavior
  kind: python_call_eq
  function: winreg2_hkeytype
  args: []
  expected: true

invariant theseus_winreg_cr.winreg2_functions:
  description: "winreg function stubs are callable"
  category: behavior
  kind: python_call_eq
  function: winreg2_functions
  args: []
  expected: true
