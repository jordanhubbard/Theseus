spec: abc_extra286
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc metaclass identity via __class__.__name__"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py, Lib/abc.py"
  notes:
    - "All collections.abc abstract base classes use ABCMeta as their metaclass"
    - "collections.abc.ABCMeta is the same object as abc.ABCMeta"
    - "collections.abc has __all__ on Python 3.14.4"
    - "Sequence.__mro__ has length 7; Mapping.__mro__ has length 6"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra286.metaclass_name_group_a:
  description: "collections.abc ABC metaclass __class__.__name__ == 'ABCMeta' for core abstract base classes"
  kind: python_call_eq
  category: identity
  id_prefix: abc286a

  columns: [id, function, args, expected, description]
  rows:
    - [abc286a001, collections.abc.Sequence.__class__.__name__.__eq__, ["ABCMeta"], true, "Sequence metaclass is ABCMeta"]
    - [abc286a002, collections.abc.Mapping.__class__.__name__.__eq__, ["ABCMeta"], true, "Mapping metaclass is ABCMeta"]
    - [abc286a003, collections.abc.Iterable.__class__.__name__.__eq__, ["ABCMeta"], true, "Iterable metaclass is ABCMeta"]
    - [abc286a004, collections.abc.Iterator.__class__.__name__.__eq__, ["ABCMeta"], true, "Iterator metaclass is ABCMeta"]
    - [abc286a005, collections.abc.Generator.__class__.__name__.__eq__, ["ABCMeta"], true, "Generator metaclass is ABCMeta"]
    - [abc286a006, collections.abc.Callable.__class__.__name__.__eq__, ["ABCMeta"], true, "Callable metaclass is ABCMeta"]
    - [abc286a007, collections.abc.Hashable.__class__.__name__.__eq__, ["ABCMeta"], true, "Hashable metaclass is ABCMeta"]
    - [abc286a008, collections.abc.Sized.__class__.__name__.__eq__, ["ABCMeta"], true, "Sized metaclass is ABCMeta"]
    - [abc286a009, collections.abc.Container.__class__.__name__.__eq__, ["ABCMeta"], true, "Container metaclass is ABCMeta"]

table abc_extra286.metaclass_name_group_b:
  description: "collections.abc ABC metaclass __class__.__name__ == 'ABCMeta' for async, set, and mutable abstract base classes"
  kind: python_call_eq
  category: identity
  id_prefix: abc286b

  columns: [id, function, args, expected, description]
  rows:
    - [abc286b001, collections.abc.Awaitable.__class__.__name__.__eq__, ["ABCMeta"], true, "Awaitable metaclass is ABCMeta"]
    - [abc286b002, collections.abc.Coroutine.__class__.__name__.__eq__, ["ABCMeta"], true, "Coroutine metaclass is ABCMeta"]
    - [abc286b003, collections.abc.AsyncIterable.__class__.__name__.__eq__, ["ABCMeta"], true, "AsyncIterable metaclass is ABCMeta"]
    - [abc286b004, collections.abc.AsyncIterator.__class__.__name__.__eq__, ["ABCMeta"], true, "AsyncIterator metaclass is ABCMeta"]
    - [abc286b005, collections.abc.AsyncGenerator.__class__.__name__.__eq__, ["ABCMeta"], true, "AsyncGenerator metaclass is ABCMeta"]
    - [abc286b006, collections.abc.Set.__class__.__name__.__eq__, ["ABCMeta"], true, "Set metaclass is ABCMeta"]
    - [abc286b007, collections.abc.MutableSet.__class__.__name__.__eq__, ["ABCMeta"], true, "MutableSet metaclass is ABCMeta"]
    - [abc286b008, collections.abc.MutableSequence.__class__.__name__.__eq__, ["ABCMeta"], true, "MutableSequence metaclass is ABCMeta"]
    - [abc286b009, collections.abc.MutableMapping.__class__.__name__.__eq__, ["ABCMeta"], true, "MutableMapping metaclass is ABCMeta"]

invariant abc_extra286.sequence_metaclass:
  description: "collections.abc.Sequence is an instance of ABCMeta"
  category: identity
  kind: python_call_eq
  function: collections.abc.Sequence.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra286.awaitable_metaclass:
  description: "collections.abc.Awaitable is an instance of ABCMeta"
  category: identity
  kind: python_call_eq
  function: collections.abc.Awaitable.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra286.mutable_mapping_metaclass:
  description: "collections.abc.MutableMapping is an instance of ABCMeta"
  category: identity
  kind: python_call_eq
  function: collections.abc.MutableMapping.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true
