spec: uuid_extra146
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra145.zspec.zsdl — covers uuid.UUID.hex/__bytes/__version/__variant/__node/__time/__class__.__name__.__eq__('property') / UUID.int/__class__.__name__.__eq__('member_descriptor') / uuid4.__module__.__eq__('uuid') (table + invariants)."
    - "uuid_extra144.zspec.zsdl — covers uuid.UUID.__str__/__repr__/__hash__/__eq__/__int__ qualnames and qualname lengths (table + invariants)."
    - "uuid_extra143.zspec.zsdl — covers uuid.RESERVED_NCS/RFC_4122/RESERVED_MICROSOFT/RESERVED_FUTURE string equality and lengths (table + invariants)."
    - "uuid_extra142.zspec.zsdl — covers uuid.SafeUUID.__dict__/__len__()==19 / UUID.__dict__.__contains__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra145."
    - "Wave 336 theme: uuid generator function identity — uuid1/uuid3/uuid4/uuid5 __module__, __code__.co_name, and __code__.co_argcount — uuid.uuid1.__module__.__eq__('uuid') / uuid1.__code__.co_name.__eq__('uuid1') / uuid1.__code__.co_argcount==2 / uuid4.__module__.__eq__('uuid') / uuid4.__code__.co_name.__eq__('uuid4') / uuid4.__code__.co_argcount==0 / uuid5.__code__.co_argcount==2 / uuid3.__code__.co_argcount==2."
    - "uuid.uuid1.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__code__.co_name == 'uuid1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_name == 'uuid4'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_argcount == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.uuid1.__code__.co_argcount == 2. uuid1 accepts two arguments: node (optional MAC address as 48-bit int) and clock_seq (optional clock sequence as 14-bit int). Both have defaults (None), so uuid1() can be called with no arguments. co_argcount counts the number of positional-or-keyword parameters (including those with defaults), which is 2 here."
    - "Note: uuid.uuid4.__code__.co_argcount == 0. uuid4 takes no arguments at all — it generates a fully random UUID using os.urandom(16). co_argcount == 0 because the function signature is def uuid4(): with no parameters. This makes uuid4 unique among the uuid generator functions: uuid1 has 2 params, uuid3 and uuid5 have 2 params each (namespace and name)."
    - "Note: uuid.uuid3.__code__.co_argcount == 2 and uuid.uuid5.__code__.co_argcount == 2. Both uuid3 and uuid5 require exactly two positional arguments: namespace (a UUID object) and name (a string). uuid3 uses MD5 hashing; uuid5 uses SHA-1 hashing. Neither has optional arguments. The namespace must be one of the predefined namespaces (NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500) or any other UUID."
    - "Note: uuid.uuid1.__code__.co_name == 'uuid1' (5 chars). The __code__.co_name attribute gives the name of the function as it appears in the def statement. For all four uuid generators, co_name == the function name. This confirms that the function objects are the original functions defined in uuid.py and not wrappers, lambdas, or renamed copies."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid1.__module__.__eq__('uuid')
# uuid.uuid1.__code__.co_name.__eq__('uuid1')
# uuid.uuid1.__code__.co_argcount==2
# uuid.uuid4.__module__.__eq__('uuid')
#
# Wave 336 theme: uuid1 and uuid4 module and code identity.
#
# uuid1.__module__ == 'uuid' (4 chars). uuid1.__code__.co_name == 'uuid1' (5 chars).
# uuid1.__code__.co_argcount == 2 (node and clock_seq optional params).
# uuid4.__module__ == 'uuid' (4 chars, confirmed also by extra145).
# No prior uuid spec anchors uuid1 code attributes or uuid4 module as a table under
# uuidfn146. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra146.uuid1_uuid4_module_and_code_identity:
  description: "uuid.uuid1.__module__.__eq__('uuid')==True / uuid1.__code__.co_name.__eq__('uuid1')==True / uuid1.__code__.co_argcount==2 / uuid4.__module__.__eq__('uuid')==True — uuid1.__module__ is 'uuid' (4 chars; pure Python in Lib/uuid.py); uuid1.__code__.co_name is 'uuid1' (5 chars; matches def statement name); uuid1 takes 2 args (node and clock_seq, both optional/None default); uuid4.__module__ is 'uuid' (4 chars; all uuid generators are pure Python); first uuidfn146 anchor for uuid1 code attributes"
  kind: python_call_eq
  category: identity
  id_prefix: uuidfn146

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_module_uuid,       "uuid1.__module__.__eq__",           ["uuid"],  true, "uuid.uuid1.__module__ == 'uuid' (4 chars; pure Python function in Lib/uuid.py; generates time-based UUID)"]
    - [uuid1_co_name_uuid1,     "uuid1.__code__.co_name.__eq__",     ["uuid1"], true, "uuid.uuid1.__code__.co_name == 'uuid1' (5 chars; matches def statement name; confirms original function not a wrapper)"]
    - [uuid1_co_argcount_2,     "uuid1.__code__.co_argcount.__eq__", [2],       true, "uuid.uuid1.__code__.co_argcount == 2 (node and clock_seq params, both have None defaults; uuid1() callable with no args)"]
    - [uuid4_module_uuid,       "uuid4.__module__.__eq__",           ["uuid"],  true, "uuid.uuid4.__module__ == 'uuid' (4 chars; pure Python; generates random UUID via os.urandom(16); extra145 also anchors this)"]

# ---------------------------------------------------------------------------
# uuid.uuid4.__code__.co_name.__eq__('uuid4')
# uuid.uuid4.__code__.co_argcount==0
# uuid.uuid3.__code__.co_argcount==2
# uuid.uuid5.__code__.co_argcount==2
#
# Wave 336 theme: uuid4 takes no args; uuid3 and uuid5 each take 2 args.
#
# uuid4.__code__.co_argcount == 0 (fully random; no parameters at all).
# uuid3.__code__.co_argcount == 2 and uuid5.__code__.co_argcount == 2 (namespace + name).
# This is the key contrast: uuid4 has 0 args; uuid1/uuid3/uuid5 all have 2 args.
# No prior uuid spec anchors these co_argcount values as a table under uuidfn146.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra146.uuid4_uuid3_uuid5_argcount:
  description: "uuid.uuid4.__code__.co_name.__eq__('uuid4')==True / uuid4.__code__.co_argcount==0 / uuid3.__code__.co_argcount==2 / uuid5.__code__.co_argcount==2 — uuid4 has 0 args (fully random via os.urandom(16); unique among uuid generators); uuid3 and uuid5 each have 2 args (namespace UUID and name string); uuid3 uses MD5; uuid5 uses SHA-1; all four uuid generators are pure Python (Lib/uuid.py); argcount contrast: uuid4(0) vs uuid1/uuid3/uuid5(2); first uuidfn146 anchor for uuid4/uuid3/uuid5 co_argcount values"
  kind: python_call_eq
  category: identity
  id_prefix: uuidfn146

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_co_name_uuid4,     "uuid4.__code__.co_name.__eq__",     ["uuid4"], true, "uuid.uuid4.__code__.co_name == 'uuid4' (5 chars; matches def statement name; fully random UUID generator)"]
    - [uuid4_co_argcount_0,     "uuid4.__code__.co_argcount.__eq__", [0],       true, "uuid.uuid4.__code__.co_argcount == 0 (no parameters; unique among uuid generators; fully random via os.urandom(16))"]
    - [uuid3_co_argcount_2,     "uuid3.__code__.co_argcount.__eq__", [2],       true, "uuid.uuid3.__code__.co_argcount == 2 (namespace UUID and name string; uses MD5 hash; deterministic output)"]
    - [uuid5_co_argcount_2,     "uuid5.__code__.co_argcount.__eq__", [2],       true, "uuid.uuid5.__code__.co_argcount == 2 (namespace UUID and name string; uses SHA-1 hash; deterministic output)"]

# ---------------------------------------------------------------------------
# uuid.uuid3.__code__.co_name.__eq__('uuid3')
# uuid.uuid5.__code__.co_name.__eq__('uuid5')
# uuid.uuid1.__code__.co_name.__eq__('uuid1')
# uuid.uuid4.__code__.co_argcount.__eq__(0)
#
# Wave 336 theme: co_name values for uuid3/uuid5 and combined argcount ordering.
#
# uuid3.__code__.co_name == 'uuid3' (5 chars). uuid5.__code__.co_name == 'uuid5' (5 chars).
# All four uuid functions have co_name == their function name (5 chars each).
# Argcount ordering: uuid4(0) < uuid1(2) == uuid3(2) == uuid5(2).
# No prior uuid spec anchors uuid3/uuid5 co_name values as a table under uuidfn146.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra146.uuid3_uuid5_co_name_and_argcount_ordering:
  description: "uuid.uuid3.__code__.co_name.__eq__('uuid3')==True / uuid5.__code__.co_name.__eq__('uuid5')==True / uuid1.__code__.co_argcount.__eq__(2)==True / uuid4.__code__.co_argcount.__eq__(0)==True — all four uuid generators have co_name matching function name (5 chars each: uuid1/uuid3/uuid4/uuid5); co_argcount ordering: uuid4(0) < uuid1(2)==uuid3(2)==uuid5(2); uuid3 (MD5-based) and uuid5 (SHA-1-based) share the same co_argcount==2; all are pure Python functions in Lib/uuid.py; first uuidfn146 anchor for uuid3/uuid5 co_name values"
  kind: python_call_eq
  category: identity
  id_prefix: uuidfn146

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_co_name_uuid3,     "uuid3.__code__.co_name.__eq__",     ["uuid3"], true, "uuid.uuid3.__code__.co_name == 'uuid3' (5 chars; MD5-based deterministic UUID; matches def name in Lib/uuid.py)"]
    - [uuid5_co_name_uuid5,     "uuid5.__code__.co_name.__eq__",     ["uuid5"], true, "uuid.uuid5.__code__.co_name == 'uuid5' (5 chars; SHA-1-based deterministic UUID; matches def name in Lib/uuid.py)"]
    - [uuid1_co_argcount_2b,    "uuid1.__code__.co_argcount.__eq__", [2],       true, "uuid.uuid1.__code__.co_argcount == 2 (node and clock_seq; both default to None; time-based UUID; tied with uuid3/uuid5)"]
    - [uuid4_co_argcount_0b,    "uuid4.__code__.co_argcount.__eq__", [0],       true, "uuid.uuid4.__code__.co_argcount == 0 (no args; only uuid generator with 0 params; random UUID via os.urandom)"]

# ---------------------------------------------------------------------------
# uuid.uuid1.__module__.__eq__('uuid') — standalone
#
# uuid.uuid1.__module__ is 'uuid' (4 chars). uuid1 is defined in Lib/uuid.py as a pure
# Python function. It generates a UUID based on the current time and the MAC address of
# the host. The time component is a 60-bit value encoding the current datetime as
# 100-nanosecond intervals since 15 October 1582 (the Gregorian epoch). uuid1 has two
# optional parameters: node (the 48-bit MAC address; defaults to the host's MAC address)
# and clock_seq (the 14-bit clock sequence; defaults to a random value). uuid1.__module__
# == 'uuid' (4 chars) confirms that uuid1 is a pure Python function, contrasting with C
# extension builtins that have __module__ == '_uuid' or similar. No prior uuid spec
# anchors uuid1.__module__ as a standalone under uuidfn146.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra146.uuid1_module_eq_uuid:
  description: "uuid.uuid1.__module__.__eq__('uuid') == True — 4 chars; pure Python in Lib/uuid.py; time-based UUID using current time (60-bit, 100ns intervals since 1582-10-15) and MAC address; node and clock_seq params both optional (default None); extra145 anchors uuid4.__module__=='uuid'; no prior uuid spec anchors uuid1.__module__ as a standalone; first standalone under uuidfn146"
  category: identity
  kind: python_call_eq
  function: uuid1.__module__.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid4.__code__.co_argcount.__eq__(0) — standalone
#
# uuid.uuid4.__code__.co_argcount is 0. uuid4 is the only uuid generator function that
# takes no arguments. Its function signature is simply def uuid4(): — no parameters at all.
# It generates a UUID by calling os.urandom(16) to get 16 random bytes, then setting
# bits 6 and 7 of byte 8 to '10' binary (variant=RFC 4122) and bits 4-7 of byte 6 to
# '0100' binary (version=4). The co_argcount of 0 makes uuid4 the simplest uuid generator
# to call — no arguments need to be supplied or considered. This contrasts with uuid1
# (co_argcount==2: node and clock_seq), uuid3 (co_argcount==2: namespace and name), and
# uuid5 (co_argcount==2: namespace and name). No prior uuid spec anchors
# uuid4.__code__.co_argcount as a standalone under uuidfn146.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra146.uuid4_co_argcount_eq_0:
  description: "uuid.uuid4.__code__.co_argcount.__eq__(0) == True — 0 args; only uuid generator with no parameters; def uuid4(): with no params; generates random UUID via os.urandom(16); sets version=4 bits (byte 6) and variant=RFC4122 bits (byte 8); contrasts with uuid1/uuid3/uuid5 all having co_argcount==2; no prior uuid spec anchors this as a standalone; first standalone under uuidfn146"
  category: identity
  kind: python_call_eq
  function: uuid4.__code__.co_argcount.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_argcount.__eq__(2) — standalone
#
# uuid.uuid1.__code__.co_argcount is 2. uuid1 accepts two parameters: node (int or None)
# and clock_seq (int or None). Both default to None, so uuid1() can be called with no
# arguments. When node is None, uuid1 uses the hardware MAC address of the host. When
# clock_seq is None, uuid1 generates a random 14-bit clock sequence. The co_argcount of
# 2 reflects these two keyword-or-positional parameters. co_argcount counts all
# positional-or-keyword parameters including those with default values (it does NOT
# count *args or **kwargs). uuid3 and uuid5 also have co_argcount==2 but their parameters
# are mandatory (no defaults). No prior uuid spec anchors uuid1.__code__.co_argcount
# as a standalone under uuidfn146. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra146.uuid1_co_argcount_eq_2:
  description: "uuid.uuid1.__code__.co_argcount.__eq__(2) == True — 2 params (node and clock_seq; both default to None); uuid1() callable with no args; co_argcount counts positional-or-keyword params including defaulted ones; node defaults to host MAC address; clock_seq defaults to random 14-bit int; tied with uuid3 and uuid5 at co_argcount==2; no prior uuid spec anchors this as a standalone; first standalone under uuidfn146"
  category: identity
  kind: python_call_eq
  function: uuid1.__code__.co_argcount.__eq__
  args: [2]
  expected: true
