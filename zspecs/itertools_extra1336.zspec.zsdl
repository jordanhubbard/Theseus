spec: itertools_extra1336
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave 536 (_extra1336): focuses on __hash__ and __eq__ method class checks for itertools classes."
    - "All itertools types are C extension types; __hash__ and __eq__ are wrapper_descriptors inherited from object."
    - "itertools.chain.__hash__.__class__.__name__ == 'wrapper_descriptor' — C extension type inherits __hash__ from object."
    - "itertools.chain.__eq__.__class__.__name__ == 'wrapper_descriptor' — C extension type inherits __eq__ from object."
    - "itertools.chain.__hash__.__qualname__ == 'object.__hash__' — no override defined in the C type."
    - "itertools.chain.__eq__.__qualname__ == 'object.__eq__' — no override defined in the C type."
    - "This pattern holds for all itertools types: count, cycle, repeat, accumulate, combinations, permutations, product, compress, dropwhile."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table itertools_extra1336.chain_count_cycle_hash_eq_checks:
  description: "itertools.chain, count, cycle __hash__ and __eq__ class name and qualname; all are C extension types that inherit from object"
  kind: python_call_eq
  category: hash_eq_class_checks
  id_prefix: it1336cc
  columns: [id, function, args, expected]
  rows:
    - [it1336cc001, itertools.chain.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"],  true]
    - [it1336cc002, itertools.chain.__hash__.__qualname__.__eq__,         ["object.__hash__"],     true]
    - [it1336cc003, itertools.chain.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"],  true]
    - [it1336cc004, itertools.chain.__eq__.__qualname__.__eq__,           ["object.__eq__"],       true]
    - [it1336cc005, itertools.count.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"],  true]
    - [it1336cc006, itertools.count.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"],  true]
    - [it1336cc007, itertools.cycle.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"],  true]
    - [it1336cc008, itertools.cycle.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"],  true]

