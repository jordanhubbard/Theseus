spec: ora
version: ">=8.0.0"
backend: node(ora)
esm: true

docs: https://github.com/sindresorhus/ora#readme

provenance:
  derived_from:
    - "ora README — https://github.com/sindresorhus/ora#readme"
    - "Test vectors verified with ora via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "ora source"
  notes:
    - "ora is an ESM-only npm package. Install: npm install ora"
    - "Usage: import ora from 'ora'; const spinner = ora({text:'...', color:'red'});"
    - "The default export is a factory: ora(text) or ora(options) returns an Ora instance."
    - "We test only static-state properties on the returned instance (text, color, indent, isSpinning), not animation behavior — start()/stop() write to TTY and are not deterministic in offline test runs."
    - "Default color is 'cyan'; default indent is 0; isSpinning starts false."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Construction returns an Ora instance; reading properties is side-effect free."
  stderr: "null"
  stickiness: "N/A — each ora() call creates an independent instance."
  codes: {}

# ── default state ────────────────────────────────────────────────────────────

table ora.defaults:
  kind: node_property_eq
  category: defaults
  entry: named
  function: default
  entry_args: ["Loading"]
  id_prefix: default

  columns: [id, property, expected]
  rows:
    - [text,        text,        "Loading"]
    - [color,       color,       "cyan"]
    - [indent,      indent,      0]
    - [isSpinning,  isSpinning,  false]

# ── string-shorthand constructor: ora('text') ────────────────────────────────

invariant ora.string_arg_text:
  kind: node_property_eq
  category: ctor_shapes
  entry: named
  function: default
  entry_args: ["My task"]
  property: text
  expected: "My task"

invariant ora.empty_default_text:
  kind: node_property_eq
  category: ctor_shapes
  entry: named
  function: default
  entry_args: []
  property: text
  expected: ""

# ── options-object constructor ───────────────────────────────────────────────

table ora.options:
  kind: node_property_eq
  category: options
  entry: named
  function: default
  id_prefix: opts

  columns: [id, entry_args, property, expected]
  rows:
    - [text_option,    [{text: "foo", color: "red"}],          text,   "foo"]
    - [color_red,      [{text: "x",   color: "red"}],          color,  "red"]
    - [color_green,    [{text: "x",   color: "green"}],        color,  "green"]
    - [indent_value,   [{text: "x",   indent: 4}],             indent, 4]
    - [isSpinning_off, [{text: "x"}],                           isSpinning, false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:18:16Z
  iterations: 1
  pass_count: 11
  fail_count: 0
  total_invariants: 11
  notes: Synthesis succeeded in 1 iteration(s). 11 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
