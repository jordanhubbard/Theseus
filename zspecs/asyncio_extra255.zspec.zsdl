spec: asyncio_extra255
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-protocol.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-protocol.html — asyncio protocols and transports documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/protocols.py, Lib/asyncio/transports.py"
  notes:
    - "asyncio.Protocol.__name__ == 'Protocol' (len=8); __module__ == 'asyncio.protocols' (len=17); __bases__[0].__name__ == 'BaseProtocol' — Protocol inherits from BaseProtocol."
    - "asyncio.BaseProtocol.__name__ == 'BaseProtocol' (len=12); __module__ == 'asyncio.protocols' (len=17); __bases__[0].__name__ == 'object' — BaseProtocol is the root of the protocol hierarchy."
    - "asyncio.BaseTransport.__name__ == 'BaseTransport' (len=13); __module__ == 'asyncio.transports' (len=18); __bases__[0].__name__ == 'object'."
    - "asyncio.ReadTransport and asyncio.WriteTransport both inherit from BaseTransport; asyncio.Transport inherits from both ReadTransport and WriteTransport (multiple inheritance)."
    - "asyncio.Transport.__bases__[0].__name__ == 'ReadTransport'; asyncio.Transport.__bases__[1].__name__ == 'WriteTransport' — Transport uses multiple inheritance combining read and write capability."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Protocol class hierarchy identity
#
# BaseProtocol.__name__ == 'BaseProtocol' (len=12)
# BaseProtocol.__module__ == 'asyncio.protocols' (len=17)
# BaseProtocol.__bases__[0].__name__ == 'object' (len=6)
# Protocol.__name__ == 'Protocol' (len=8)
# Protocol.__module__ == 'asyncio.protocols' (len=17)
# Protocol.__bases__[0].__name__ == 'BaseProtocol' (len=12)
# ---------------------------------------------------------------------------

table asyncio_extra255.protocol_class_identity:
  description: "asyncio Protocol class hierarchy — BaseProtocol(len=12) inherits from object; Protocol(len=8) inherits from BaseProtocol; both defined in asyncio.protocols(len=17); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: async255pr

  columns: [id, function, args, expected, description]
  rows:
    - [bp_name_eq,   BaseProtocol.__name__.__eq__,                    ["BaseProtocol"],         true, "asyncio.BaseProtocol.__name__ == 'BaseProtocol'; verified with Python 3.14.3"]
    - [bp_name_len,  BaseProtocol.__name__.__len__,                   [],                       12,   "asyncio.BaseProtocol.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [bp_mod_eq,    BaseProtocol.__module__.__eq__,                  ["asyncio.protocols"],    true, "asyncio.BaseProtocol.__module__ == 'asyncio.protocols'; verified with Python 3.14.3"]
    - [bp_mod_len,   BaseProtocol.__module__.__len__,                 [],                       17,   "asyncio.BaseProtocol.__module__.__len__() == 17; verified with Python 3.14.3"]
    - [bp_base_eq,   "BaseProtocol.__bases__[0].__name__.__eq__",     ["object"],               true, "asyncio.BaseProtocol.__bases__[0].__name__ == 'object' — BaseProtocol is the protocol hierarchy root; verified with Python 3.14.3"]
    - [bp_base_len,  "BaseProtocol.__bases__[0].__name__.__len__",    [],                       6,    "asyncio.BaseProtocol.__bases__[0].__name__.__len__() == 6; verified with Python 3.14.3"]
    - [pr_name_eq,   Protocol.__name__.__eq__,                        ["Protocol"],             true, "asyncio.Protocol.__name__ == 'Protocol'; verified with Python 3.14.3"]
    - [pr_name_len,  Protocol.__name__.__len__,                       [],                       8,    "asyncio.Protocol.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [pr_mod_eq,    Protocol.__module__.__eq__,                      ["asyncio.protocols"],    true, "asyncio.Protocol.__module__ == 'asyncio.protocols'; verified with Python 3.14.3"]
    - [pr_mod_len,   Protocol.__module__.__len__,                     [],                       17,   "asyncio.Protocol.__module__.__len__() == 17; verified with Python 3.14.3"]
    - [pr_base_eq,   "Protocol.__bases__[0].__name__.__eq__",         ["BaseProtocol"],         true, "asyncio.Protocol.__bases__[0].__name__ == 'BaseProtocol' — Protocol inherits from BaseProtocol; verified with Python 3.14.3"]
    - [pr_base_len,  "Protocol.__bases__[0].__name__.__len__",        [],                       12,   "asyncio.Protocol.__bases__[0].__name__.__len__() == 12; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Transport class hierarchy identity
#
# BaseTransport.__name__ == 'BaseTransport' (len=13)
# BaseTransport.__module__ == 'asyncio.transports' (len=18)
# BaseTransport.__bases__[0].__name__ == 'object' (len=6)
# ReadTransport.__name__ == 'ReadTransport' (len=13)
# ReadTransport.__module__ == 'asyncio.transports' (len=18)
# ReadTransport.__bases__[0].__name__ == 'BaseTransport' (len=13)
# WriteTransport.__name__ == 'WriteTransport' (len=14)
# WriteTransport.__module__ == 'asyncio.transports' (len=18)
# WriteTransport.__bases__[0].__name__ == 'BaseTransport' (len=13)
# Transport.__name__ == 'Transport' (len=9)
# Transport.__module__ == 'asyncio.transports' (len=18)
# Transport.__bases__[0].__name__ == 'ReadTransport' (len=13)
# Transport.__bases__[1].__name__ == 'WriteTransport' (len=14)
# ---------------------------------------------------------------------------

table asyncio_extra255.transport_class_identity:
  description: "asyncio Transport class hierarchy — BaseTransport(len=13) inherits from object; ReadTransport and WriteTransport both inherit from BaseTransport; Transport(len=9) uses multiple inheritance combining both; all defined in asyncio.transports(len=18); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: async255tr

  columns: [id, function, args, expected, description]
  rows:
    - [bt_name_eq,   BaseTransport.__name__.__eq__,                    ["BaseTransport"],        true, "asyncio.BaseTransport.__name__ == 'BaseTransport'; verified with Python 3.14.3"]
    - [bt_name_len,  BaseTransport.__name__.__len__,                   [],                       13,   "asyncio.BaseTransport.__name__.__len__() == 13; verified with Python 3.14.3"]
    - [bt_mod_eq,    BaseTransport.__module__.__eq__,                  ["asyncio.transports"],   true, "asyncio.BaseTransport.__module__ == 'asyncio.transports'; verified with Python 3.14.3"]
    - [bt_mod_len,   BaseTransport.__module__.__len__,                 [],                       18,   "asyncio.BaseTransport.__module__.__len__() == 18; verified with Python 3.14.3"]
    - [bt_base_eq,   "BaseTransport.__bases__[0].__name__.__eq__",     ["object"],               true, "asyncio.BaseTransport.__bases__[0].__name__ == 'object' — BaseTransport is the transport hierarchy root; verified with Python 3.14.3"]
    - [rt_name_eq,   ReadTransport.__name__.__eq__,                    ["ReadTransport"],        true, "asyncio.ReadTransport.__name__ == 'ReadTransport'; verified with Python 3.14.3"]
    - [rt_name_len,  ReadTransport.__name__.__len__,                   [],                       13,   "asyncio.ReadTransport.__name__.__len__() == 13; verified with Python 3.14.3"]
    - [rt_mod_eq,    ReadTransport.__module__.__eq__,                  ["asyncio.transports"],   true, "asyncio.ReadTransport.__module__ == 'asyncio.transports'; verified with Python 3.14.3"]
    - [rt_base_eq,   "ReadTransport.__bases__[0].__name__.__eq__",     ["BaseTransport"],        true, "asyncio.ReadTransport.__bases__[0].__name__ == 'BaseTransport' — ReadTransport inherits from BaseTransport; verified with Python 3.14.3"]
    - [wt_name_eq,   WriteTransport.__name__.__eq__,                   ["WriteTransport"],       true, "asyncio.WriteTransport.__name__ == 'WriteTransport'; verified with Python 3.14.3"]
    - [wt_name_len,  WriteTransport.__name__.__len__,                  [],                       14,   "asyncio.WriteTransport.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [wt_mod_eq,    WriteTransport.__module__.__eq__,                 ["asyncio.transports"],   true, "asyncio.WriteTransport.__module__ == 'asyncio.transports'; verified with Python 3.14.3"]
    - [wt_base_eq,   "WriteTransport.__bases__[0].__name__.__eq__",    ["BaseTransport"],        true, "asyncio.WriteTransport.__bases__[0].__name__ == 'BaseTransport' — WriteTransport inherits from BaseTransport; verified with Python 3.14.3"]
    - [tr_name_eq,   Transport.__name__.__eq__,                        ["Transport"],            true, "asyncio.Transport.__name__ == 'Transport'; verified with Python 3.14.3"]
    - [tr_name_len,  Transport.__name__.__len__,                       [],                       9,    "asyncio.Transport.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [tr_mod_eq,    Transport.__module__.__eq__,                      ["asyncio.transports"],   true, "asyncio.Transport.__module__ == 'asyncio.transports'; verified with Python 3.14.3"]
    - [tr_mod_len,   Transport.__module__.__len__,                     [],                       18,   "asyncio.Transport.__module__.__len__() == 18; verified with Python 3.14.3"]
    - [tr_base0_eq,  "Transport.__bases__[0].__name__.__eq__",         ["ReadTransport"],        true, "asyncio.Transport.__bases__[0].__name__ == 'ReadTransport' — Transport's first base in MRO; verified with Python 3.14.3"]
    - [tr_base1_eq,  "Transport.__bases__[1].__name__.__eq__",         ["WriteTransport"],       true, "asyncio.Transport.__bases__[1].__name__ == 'WriteTransport' — Transport's second base; Transport combines read and write via multiple inheritance; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra255
# ---------------------------------------------------------------------------

invariant asyncio_extra255.protocol_base_is_base_protocol:
  description: "asyncio.Protocol.__bases__[0].__name__.__eq__('BaseProtocol') returns True — Protocol inherits from BaseProtocol(len=12), not directly from object; this establishes the two-level protocol hierarchy in asyncio; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Protocol.__bases__[0].__name__.__eq__"
  args: ["BaseProtocol"]
  expected: true

invariant asyncio_extra255.transport_has_multiple_bases:
  description: "asyncio.Transport.__bases__[1].__name__.__eq__('WriteTransport') returns True — Transport is the only class in this hierarchy with multiple bases (ReadTransport and WriteTransport), unifying the read and write transport interfaces; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Transport.__bases__[1].__name__.__eq__"
  args: ["WriteTransport"]
  expected: true
