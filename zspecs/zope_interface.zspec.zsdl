spec: zope_interface
version: ">=5.0"
backend: python_module(zope.interface)

docs: https://zopeinterface.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "zope.interface documentation — https://zopeinterface.readthedocs.io/en/latest/"
    - "zope.interface README — https://github.com/zopefoundation/zope.interface"
    - "Test vectors verified with zope.interface 8.2 on Python 3.14 / macOS Darwin 25.4.0, 2026-04-05"
  not_derived_from:
    - "zope/interface/interface.py"
    - "zope/interface/declarations.py"
    - "Any other zope.interface source file"
  notes:
    - "zope.interface is a namespace package; it does not expose __version__ on the module object."
    - "Version is obtained via importlib.metadata.version('zope.interface')."
    - "Interface is an instance of InterfaceClass, not a plain class — type(Interface).__name__ == 'InterfaceClass'."
    - "implementer is a class (decorator factory); providedBy and implementedBy are C-accelerated functions."
    - "directlyProvidedBy and alsoProvides are callable functions exported at the top level."
    - "Attribute class names and function names verified with zope.interface 8.2 on Python 3.14.3."
  created_at: "2026-04-05T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version — metadata version contains a dot and starts with a digit
#
# zope.interface does not expose __version__ on the module. The harness
# retrieves the version via importlib.metadata.version('zope.interface').
# We verify the version is well-formed by checking a stable attribute.
# The spec version range >=5.0 is enforced by the harness against lib_version.
# ---------------------------------------------------------------------------

invariant zope_interface.version.interface_name_smoke:
  description: "Interface.__name__ == 'Interface' — smoke test confirming module loads correctly"
  category: version
  kind: python_call_eq
  function: Interface.__name__.__eq__
  args: ["Interface"]
  expected: true

# ---------------------------------------------------------------------------
# interface — Interface object identity checks
#
# Interface is the root of all zope.interface interfaces. It is an instance
# of InterfaceClass (a metaclass), not a plain Python class.
# ---------------------------------------------------------------------------

invariant zope_interface.interface.name:
  description: "Interface.__name__ == 'Interface'"
  category: interface
  kind: python_call_eq
  function: Interface.__name__.__eq__
  args: ["Interface"]
  expected: true

invariant zope_interface.interface.module_contains_zope:
  description: "Interface.__module__ contains 'zope'"
  category: interface
  kind: python_call_eq
  function: Interface.__module__.__contains__
  args: ["zope"]
  expected: true

invariant zope_interface.interface.module_eq:
  description: "Interface.__module__ == 'zope.interface'"
  category: interface
  kind: python_call_eq
  function: Interface.__module__.__eq__
  args: ["zope.interface"]
  expected: true

invariant zope_interface.interface.metaclass_name:
  description: "type(Interface).__name__ == 'InterfaceClass' — Interface is a metaclass instance"
  category: interface
  kind: python_call_eq
  function: Interface.__class__.__name__.__eq__
  args: ["InterfaceClass"]
  expected: true

# ---------------------------------------------------------------------------
# class_names — implementer, providedBy, implementedBy, directlyProvidedBy,
#               alsoProvides all exist and have the correct __name__
#
# implementer is a class used as a decorator factory.
# providedBy and implementedBy are C-accelerated built-in functions.
# directlyProvidedBy and alsoProvides are module-level callables.
# ---------------------------------------------------------------------------

invariant zope_interface.class_names.implementer:
  description: "implementer.__name__ == 'implementer'"
  category: class_names
  kind: python_call_eq
  function: implementer.__name__.__eq__
  args: ["implementer"]
  expected: true

invariant zope_interface.class_names.providedBy:
  description: "providedBy.__name__ == 'providedBy'"
  category: class_names
  kind: python_call_eq
  function: providedBy.__name__.__eq__
  args: ["providedBy"]
  expected: true

invariant zope_interface.class_names.implementedBy:
  description: "implementedBy.__name__ == 'implementedBy'"
  category: class_names
  kind: python_call_eq
  function: implementedBy.__name__.__eq__
  args: ["implementedBy"]
  expected: true

invariant zope_interface.class_names.directlyProvidedBy:
  description: "directlyProvidedBy.__name__ == 'directlyProvidedBy'"
  category: class_names
  kind: python_call_eq
  function: directlyProvidedBy.__name__.__eq__
  args: ["directlyProvidedBy"]
  expected: true

invariant zope_interface.class_names.alsoProvides:
  description: "alsoProvides.__name__ == 'alsoProvides'"
  category: class_names
  kind: python_call_eq
  function: alsoProvides.__name__.__eq__
  args: ["alsoProvides"]
  expected: true

# ---------------------------------------------------------------------------
# module_attrs — module-level presence checks
#
# The module's __name__ attribute is 'zope.interface' and its __package__
# attribute matches, confirming the namespace package is correctly loaded.
# ---------------------------------------------------------------------------

invariant zope_interface.module_attrs.module_name:
  description: "__name__ == 'zope.interface'"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["zope.interface"]
  expected: true

invariant zope_interface.module_attrs.package_name:
  description: "__package__ == 'zope.interface'"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: ["zope.interface"]
  expected: true

# ---------------------------------------------------------------------------
# implementer_class — implementer is a class, not a plain function
#
# implementer.__class__.__name__ == 'type' confirms it is a class object
# used as a decorator factory (via @implementer(IFoo)).
# ---------------------------------------------------------------------------

invariant zope_interface.implementer_class.is_type:
  description: "implementer.__class__.__name__ == 'type' — implementer is a class"
  category: implementer_class
  kind: python_call_eq
  function: implementer.__class__.__name__.__eq__
  args: ["type"]
  expected: true
