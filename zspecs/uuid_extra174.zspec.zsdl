spec: uuid_extra174
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "uuid.SafeUUID.__name__ == 'SafeUUID' — len=8; pure-Python Enum subclass in the uuid module."
    - "uuid.SafeUUID.__module__ == 'uuid' — defined directly in the uuid standard library module."
    - "uuid.SafeUUID.__qualname__ == 'SafeUUID' — top-level class, qualname matches name."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' — SafeUUID inherits from enum.Enum (NOT IntEnum)."
    - "uuid.SafeUUID.safe._value_ == 0 — safe UUID generation is represented as 0."
    - "uuid.SafeUUID.unsafe._value_ == -1 — unsafe UUID generation is represented as -1."
    - "uuid.SafeUUID.safe.__class__.__name__ == 'SafeUUID' — member instances are SafeUUID."
    - "uuid.SafeUUID.unsafe.__class__.__name__ == 'SafeUUID' — member instances are SafeUUID."
    - "SafeUUID.__eq__ returns NotImplemented for plain int comparisons; use ._value_ for int checks."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: SafeUUID class-level name identity
#
# uuid.SafeUUID.__name__     == 'SafeUUID'  (len=8)
# uuid.SafeUUID.__module__   == 'uuid'
# uuid.SafeUUID.__qualname__ == 'SafeUUID'
#
# SafeUUID is a pure-Python Enum subclass defined in Lib/uuid.py.
# New to extra174.
# ---------------------------------------------------------------------------

table uuid_extra174.safeuuid_name_identity:
  description: "SafeUUID __name__, __module__, __qualname__ class identity; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: uuidsafeuuid174

  columns: [id, function, args, expected, description]
  rows:
    - [safeuuid_name_eq,
       SafeUUID.__name__.__eq__,
       ["SafeUUID"],
       true,
       "uuid.SafeUUID.__name__.__eq__('SafeUUID') == True — class name is 'SafeUUID'; len=8; new to extra174"]
    - [safeuuid_name_len,
       SafeUUID.__name__.__len__,
       [],
       8,
       "uuid.SafeUUID.__name__.__len__() == 8 — 'SafeUUID' has 8 characters; new to extra174"]
    - [safeuuid_module_eq,
       SafeUUID.__module__.__eq__,
       ["uuid"],
       true,
       "uuid.SafeUUID.__module__.__eq__('uuid') == True — defined in the uuid module; new to extra174"]
    - [safeuuid_qualname_eq,
       SafeUUID.__qualname__.__eq__,
       ["SafeUUID"],
       true,
       "uuid.SafeUUID.__qualname__.__eq__('SafeUUID') == True — top-level class, qualname matches name; new to extra174"]

# ---------------------------------------------------------------------------
# Table 2: SafeUUID base class and member class identity
#
# uuid.SafeUUID.__bases__[0].__name__      == 'Enum'     (NOT IntEnum)
# uuid.SafeUUID.safe.__class__.__name__    == 'SafeUUID'
# uuid.SafeUUID.unsafe.__class__.__name__  == 'SafeUUID'
#
# SafeUUID inherits from enum.Enum (verified: MRO is SafeUUID -> Enum -> object).
# New to extra174.
# ---------------------------------------------------------------------------

table uuid_extra174.safeuuid_base_and_member_class:
  description: "SafeUUID base class and member instance class identity; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: uuidsafeuuid174

  columns: [id, function, args, expected, description]
  rows:
    - [safeuuid_base_name_eq,
       "SafeUUID.__bases__[0].__name__.__eq__",
       ["Enum"],
       true,
       "uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum') == True — SafeUUID inherits from enum.Enum; new to extra174"]
    - [safeuuid_safe_class_name_eq,
       SafeUUID.safe.__class__.__name__.__eq__,
       ["SafeUUID"],
       true,
       "uuid.SafeUUID.safe.__class__.__name__.__eq__('SafeUUID') == True — safe member is a SafeUUID instance; new to extra174"]
    - [safeuuid_unsafe_class_name_eq,
       SafeUUID.unsafe.__class__.__name__.__eq__,
       ["SafeUUID"],
       true,
       "uuid.SafeUUID.unsafe.__class__.__name__.__eq__('SafeUUID') == True — unsafe member is a SafeUUID instance; new to extra174"]
    - [safeuuid_class_name_eq,
       SafeUUID.__class__.__name__.__eq__,
       ["EnumType"],
       true,
       "uuid.SafeUUID.__class__.__name__.__eq__('EnumType') == True — SafeUUID metaclass is EnumType; new to extra174"]

# ---------------------------------------------------------------------------
# Table 3: SafeUUID member values via _value_
#
# uuid.SafeUUID.safe._value_   == 0   (safe generation)
# uuid.SafeUUID.unsafe._value_ == -1  (unsafe generation)
#
# Plain int.__eq__ returns NotImplemented for Enum members; use ._value_ to
# access the underlying integer. New to extra174.
# ---------------------------------------------------------------------------

table uuid_extra174.safeuuid_member_values:
  description: "SafeUUID.safe and SafeUUID.unsafe underlying integer values; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: uuidsafeuuid174

  columns: [id, function, args, expected, description]
  rows:
    - [safe_value_eq_0,
       SafeUUID.safe._value_.__eq__,
       [0],
       true,
       "uuid.SafeUUID.safe._value_.__eq__(0) == True — safe UUID generation has integer value 0; new to extra174"]
    - [unsafe_value_eq_neg1,
       SafeUUID.unsafe._value_.__eq__,
       [-1],
       true,
       "uuid.SafeUUID.unsafe._value_.__eq__(-1) == True — unsafe UUID generation has integer value -1; new to extra174"]
    - [safe_value_class_name_eq,
       SafeUUID.safe._value_.__class__.__name__.__eq__,
       ["int"],
       true,
       "uuid.SafeUUID.safe._value_.__class__.__name__.__eq__('int') == True — _value_ is a plain int; new to extra174"]
    - [unsafe_value_class_name_eq,
       SafeUUID.unsafe._value_.__class__.__name__.__eq__,
       ["int"],
       true,
       "uuid.SafeUUID.unsafe._value_.__class__.__name__.__eq__('int') == True — _value_ is a plain int; new to extra174"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra174
# ---------------------------------------------------------------------------

invariant uuid_extra174.safeuuid_name_is_SafeUUID:
  description: "uuid.SafeUUID.__name__ == 'SafeUUID' — len=8; pure-Python Enum in the uuid module; new to extra174"
  category: identity
  kind: python_call_eq
  function: SafeUUID.__name__.__eq__
  args: ["SafeUUID"]
  expected: true

invariant uuid_extra174.safeuuid_module_is_uuid:
  description: "uuid.SafeUUID.__module__ == 'uuid' — defined in the uuid standard library module; new to extra174"
  category: identity
  kind: python_call_eq
  function: SafeUUID.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra174.safeuuid_qualname_is_SafeUUID:
  description: "uuid.SafeUUID.__qualname__ == 'SafeUUID' — top-level class, qualname equals name; new to extra174"
  category: identity
  kind: python_call_eq
  function: SafeUUID.__qualname__.__eq__
  args: ["SafeUUID"]
  expected: true

invariant uuid_extra174.safeuuid_base_is_Enum:
  description: "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' — SafeUUID inherits from enum.Enum, not IntEnum; new to extra174"
  category: identity
  kind: python_call_eq
  function: "SafeUUID.__bases__[0].__name__.__eq__"
  args: ["Enum"]
  expected: true

invariant uuid_extra174.safeuuid_safe_class_is_SafeUUID:
  description: "uuid.SafeUUID.safe.__class__.__name__ == 'SafeUUID' — member safe is a SafeUUID instance; new to extra174"
  category: identity
  kind: python_call_eq
  function: SafeUUID.safe.__class__.__name__.__eq__
  args: ["SafeUUID"]
  expected: true

invariant uuid_extra174.safeuuid_unsafe_class_is_SafeUUID:
  description: "uuid.SafeUUID.unsafe.__class__.__name__ == 'SafeUUID' — member unsafe is a SafeUUID instance; new to extra174"
  category: identity
  kind: python_call_eq
  function: SafeUUID.unsafe.__class__.__name__.__eq__
  args: ["SafeUUID"]
  expected: true

invariant uuid_extra174.safeuuid_safe_value_is_0:
  description: "uuid.SafeUUID.safe._value_ == 0 — safe UUID generation is represented as integer 0; new to extra174"
  category: identity
  kind: python_call_eq
  function: SafeUUID.safe._value_.__eq__
  args: [0]
  expected: true

invariant uuid_extra174.safeuuid_unsafe_value_is_neg1:
  description: "uuid.SafeUUID.unsafe._value_ == -1 — unsafe UUID generation is represented as integer -1; new to extra174"
  category: identity
  kind: python_call_eq
  function: SafeUUID.unsafe._value_.__eq__
  args: [-1]
  expected: true

invariant uuid_extra174.safeuuid_name_len_is_8:
  description: "uuid.SafeUUID.__name__.__len__() == 8 — 'SafeUUID' has 8 characters; new to extra174"
  category: identity
  kind: python_call_eq
  function: SafeUUID.__name__.__len__
  args: []
  expected: 8
