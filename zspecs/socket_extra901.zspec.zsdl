spec: socket_extra901
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket callable __module__ attributes and enum constant class names"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra901.socket_callable_modules:
  description: "socket callable __module__ identity"
  kind: python_call_eq
  category: callable_modules
  id_prefix: sk901cm
  columns: [id, function, args, expected]
  rows:
    - [sk901cm001, socket.socket.__module__.__eq__,      ["socket"], true]
    - [sk901cm002, socket.getfqdn.__module__.__eq__,     ["socket"], true]
    - [sk901cm003, socket.gethostname.__module__.__eq__, ["socket"], true]
    - [sk901cm004, socket.gethostbyname.__module__.__eq__, ["socket"], true]
    - [sk901cm005, socket.error.__module__.__eq__,       ["socket"], true]

table socket_extra901.enum_constant_classes:
  description: "socket enum constant __class__.__name__ identity"
  kind: python_call_eq
  category: enum_class_names
  id_prefix: sk901ec
  columns: [id, function, args, expected]
  rows:
    - [sk901ec001, socket.AF_INET.__class__.__name__.__eq__,    ["AddressFamily"], true]
    - [sk901ec002, socket.SOCK_STREAM.__class__.__name__.__eq__, ["SocketKind"],   true]
    - [sk901ec003, socket.AF_INET6.__class__.__name__.__eq__,   ["AddressFamily"], true]
    - [sk901ec004, socket.SOCK_DGRAM.__class__.__name__.__eq__, ["SocketKind"],    true]
    - [sk901ec005, socket.AF_INET.__class__.__module__.__eq__,  ["socket"],        true]

table socket_extra901.module_level_attrs:
  description: "socket module-level attribute type identity checks"
  kind: python_call_eq
  category: module_attrs
  id_prefix: sk901ma
  columns: [id, function, args, expected]
  rows:
    - [sk901ma001, socket.socket.__module__.__class__.__name__.__eq__,      ["str"], true]
    - [sk901ma002, socket.getfqdn.__module__.__class__.__name__.__eq__,     ["str"], true]
    - [sk901ma003, socket.gethostname.__module__.__class__.__name__.__eq__, ["str"], true]
    - [sk901ma004, socket.gethostbyname.__module__.__class__.__name__.__eq__, ["str"], true]
    - [sk901ma005, socket.error.__module__.__class__.__name__.__eq__,       ["str"], true]
