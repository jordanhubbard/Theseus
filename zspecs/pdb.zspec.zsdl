spec: pdb
version: ">=3.0"
backend: python_module(pdb)

docs: https://docs.python.org/3/library/pdb.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pdb.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "pdb source: Lib/pdb.py (PSF; source inspection permitted)"
  not_derived_from:
    - "pdb source: internal debugger command dispatch implementation"
  notes:
    - "pdb is the Python interactive source code debugger."
    - "Pdb inherits from bdb.Bdb and cmd.Cmd; it extends both the debugger and command-line framework."
    - "Pdb().prompt is '(Pdb) ' — the canonical debugger prompt string (with trailing space)."
    - "Pdb().use_rawinput is 1 (truthy) — uses input() rather than sys.stdin.readline() by default."
    - "Restart is a simple exception class used to signal a restart of the debugged program."
    - "pdb.pm() is a convenience wrapper that calls post_mortem(sys.last_traceback)."
    - "Invariants cover only class/function names and safe instance attributes; debugger execution is not invoked."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name metadata — Pdb and Restart
# ---------------------------------------------------------------------------

table pdb.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [pdb_cls,  Pdb.__name__.__eq__,     ["Pdb"],     true]
    - [restart,  Restart.__name__.__eq__,  ["Restart"], true]

# ---------------------------------------------------------------------------
# Function name metadata — public API functions
# ---------------------------------------------------------------------------

table pdb.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [run,         run.__name__.__eq__,         ["run"],         true]
    - [runeval,     runeval.__name__.__eq__,      ["runeval"],     true]
    - [runcall,     runcall.__name__.__eq__,      ["runcall"],     true]
    - [set_trace,   set_trace.__name__.__eq__,    ["set_trace"],   true]
    - [post_mortem, post_mortem.__name__.__eq__,  ["post_mortem"], true]
    - [pm,          pm.__name__.__eq__,           ["pm"],          true]

# ---------------------------------------------------------------------------
# Module membership — Pdb.__module__ is 'pdb'
# ---------------------------------------------------------------------------

invariant pdb.pdb_module:
  description: "pdb.Pdb.__module__ == 'pdb'"
  category: class_names
  kind: python_call_eq
  function: Pdb.__module__.__eq__
  args: ["pdb"]
  expected: true

# ---------------------------------------------------------------------------
# Pdb instance defaults — prompt and use_rawinput
# ---------------------------------------------------------------------------

invariant pdb.pdb_prompt:
  description: "pdb.Pdb().prompt == '(Pdb) ' — the classic debugger prompt with trailing space"
  category: instance_attrs
  kind: python_call_eq
  function: Pdb
  args: []
  method: prompt.__eq__
  method_args: ["(Pdb) "]
  expected: true

invariant pdb.pdb_use_rawinput:
  description: "pdb.Pdb().use_rawinput == 1 — Pdb uses input() (raw input) by default"
  category: instance_attrs
  kind: python_call_eq
  function: Pdb
  args: []
  method: use_rawinput.__eq__
  method_args: [1]
  expected: true
