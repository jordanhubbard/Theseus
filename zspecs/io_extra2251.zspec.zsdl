spec: io_extra2251
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io.zspec.zsdl"
    - "_io_extra.zspec.zsdl"
  notes:
    - "Wave 2251, theme: callable protocol and function-attribute dict-presence."
    - "Checks __call__, __code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__ in io class __dict__s."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase are ABC-based C types; none define callable-protocol or function-attribute dunders."
    - "io.StringIO, io.BytesIO, io.FileIO are concrete C types; similarly absent."
    - "Positive anchor rows verify real method membership (read, write, getvalue, etc.) to confirm the lookup mechanism works."
  created_at: "2026-04-12"

table io_extra2251.callable_protocol_iobase:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["io2251001", io.IOBase.__dict__.__contains__,       ["__call__"],       false]
    - ["io2251002", io.IOBase.__dict__.__contains__,       ["__code__"],       false]
    - ["io2251003", io.IOBase.__dict__.__contains__,       ["__globals__"],    false]
    - ["io2251004", io.IOBase.__dict__.__contains__,       ["__defaults__"],   false]
