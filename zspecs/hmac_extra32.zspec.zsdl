spec: hmac_extra32
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hmac_extra31.zspec.zsdl — covers hmac.__name__.__len__()==4; hmac.__package__.__len__()==0; HMAC.__bases__[0].__name__.__len__()==6; trans_36/trans_5C __class__.__name__.__len__()==5 and __len__()==256; HMAC.__dict__.__class__.__name__.__len__()==12."
  notes:
    - "This spec extends hmac through hmac_extra31; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: HMAC/__name__/__module__/__qualname__/__bases__[0].__name__ (multiple specs); hmac.new/digest/compare_digest __name__/__module__/__qualname__ and their __len__() variants (extra23, extra29); HMAC.update/digest/hexdigest/copy/__init__ __name__/__qualname__/__module__.__len__() (extra29, extra30); HMAC.__mro__.__len__()==2 (extra22); trans_36/trans_5C constants (extra31); HMAC.__dict__.__class__.__name__.__len__()==12 (extra31)."
    - "This spec covers: hmac.new.__qualname__.__len__()==3 (NOVEL — 'new' has 3 characters; qualname length not checked in any prior spec); hmac.compare_digest.__qualname__.__len__()==14 (NOVEL — 'compare_digest' is 14 characters; qualname.__len__() not covered); hmac.digest.__qualname__.__len__()==6 (NOVEL — 'digest' is 6 characters; qualname.__len__() not covered); hmac.HMAC.__qualname__.__len__()==4 (NOVEL — 'HMAC' has 4 characters; length not checked in prior specs); hmac.__doc__.__class__.__name__.__len__()==3 (NOVEL — module docstring class is str, 3 chars); hmac.HMAC.__doc__.__class__.__name__.__len__()==3 (NOVEL — class docstring class is str, 3 chars); hmac.HMAC.__slots__.__len__()==5 (NOVEL — HMAC defines 5 slots); hmac.HMAC.__slots__.__class__.__name__.__len__()==5 (NOVEL — tuple has 5 chars); hmac.HMAC.digest_size.__class__.__name__.__len__()==17 (NOVEL — member_descriptor has 17 chars); hmac.HMAC.block_size.__class__.__name__.__len__()==17 (NOVEL — member_descriptor, 17 chars)."
    - "hmac.new.__qualname__ == 'new' (len 3). Prior specs (extra23, extra29) verify new.__qualname__.__eq__ but not __len__() of the string. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.compare_digest.__qualname__ == 'compare_digest' (len 14). Prior specs verify __qualname__.__eq__ but not __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.digest.__qualname__ == 'digest' (len 6). Prior specs verify __qualname__.__eq__ but not __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__qualname__ == 'HMAC' (len 4). Prior specs check __qualname__.__eq__('HMAC') but none check __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.__doc__.__class__.__name__ == 'str' (len 3). Module docstrings are str objects. Novel (no prior spec checks this). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__doc__.__class__.__name__ == 'str' (len 3). Class docstring is also str. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__slots__ == ('_hmac', '_inner', '_outer', 'block_size', 'digest_size') — 5 slots; class is tuple (5 chars). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.digest_size is a member_descriptor (17 chars). Same for block_size. These are slot descriptors for numeric attributes. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hmac.HMAC.__qualname__.__len__()
#
# hmac.HMAC.__qualname__ == 'HMAC' — 4 characters. Prior specs check
# HMAC.__qualname__.__eq__('HMAC') but no prior spec checks the __len__()
# of that string. Novel standalone invariant.
# ---------------------------------------------------------------------------

invariant hmac_extra32.HMAC.qualname_len:
  description: "hmac.HMAC.__qualname__.__len__() == 4 — 'HMAC' has 4 characters, novel length check"
  category: class_identity
  kind: python_call_eq
  function: HMAC.__qualname__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Module and class docstring class name lengths
#
# hmac.__doc__ and hmac.HMAC.__doc__ are both plain str objects.
# __class__.__name__ == 'str' (len 3). No prior hmac spec checks either of
# these docstring class names. Novel for both module and class level.
# ---------------------------------------------------------------------------

invariant hmac_extra32.module.doc_class_name_len:
  description: "hmac.__doc__.__class__.__name__.__len__() == 3 — module docstring is a str, 'str' has 3 characters"
  category: string_length
  kind: python_call_eq
  function: __doc__.__class__.__name__.__len__
  args: []
  expected: 3

invariant hmac_extra32.HMAC.doc_class_name_len:
  description: "hmac.HMAC.__doc__.__class__.__name__.__len__() == 3 — class docstring is a str, 'str' has 3 characters"
  category: string_length
  kind: python_call_eq
  function: HMAC.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# hmac.HMAC.__slots__ — length and class name length
#
# HMAC defines __slots__ = ('_hmac', '_inner', '_outer', 'block_size',
# 'digest_size'). No prior spec checks HMAC.__slots__.__len__() or
# HMAC.__slots__.__class__.__name__.__len__(). Both are novel.
# __slots__ is a tuple (len('tuple') == 5) with 5 entries.
# ---------------------------------------------------------------------------

invariant hmac_extra32.HMAC.slots_len:
  description: "hmac.HMAC.__slots__.__len__() == 5 — HMAC defines 5 slots: _hmac, _inner, _outer, block_size, digest_size"
  category: class_structure
  kind: python_call_eq
  function: HMAC.__slots__.__len__
  args: []
  expected: 5

invariant hmac_extra32.HMAC.slots_class_name_len:
  description: "hmac.HMAC.__slots__.__class__.__name__.__len__() == 5 — __slots__ is a tuple, 'tuple' has 5 characters"
  category: string_length
  kind: python_call_eq
  function: HMAC.__slots__.__class__.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# Table: module-level function __qualname__.__len__() — new, digest, compare_digest
#
# Prior specs verify __qualname__.__eq__ for these three functions but no prior
# spec verifies __qualname__.__len__(). This table fills the gap for all three.
# hmac.new.__qualname__ == 'new' (len 3)
# hmac.digest.__qualname__ == 'digest' (len 6)
# hmac.compare_digest.__qualname__ == 'compare_digest' (len 14)
# All verified at runtime.
# ---------------------------------------------------------------------------

table hmac_extra32.module_func_qualname_lengths:
  description: "hmac module-level function __qualname__.__len__() — new (3), digest (6), compare_digest (14)"
  kind: python_call_eq
  category: function_identity
  id_prefix: hmfqln32

  columns: [id, function, args, expected]
  rows:
    - [new,             new.__qualname__.__len__,             [], 3]
    - [digest,          digest.__qualname__.__len__,          [], 6]
    - [compare_digest,  compare_digest.__qualname__.__len__,  [], 14]

# ---------------------------------------------------------------------------
# Table: hmac.HMAC slot descriptor class names
#
# HMAC.digest_size and HMAC.block_size are member_descriptor objects (slot
# descriptors for the numeric instance attributes). No prior hmac spec checks
# the __class__.__name__ of these descriptors. 'member_descriptor' has 17
# characters. Novel for both attributes.
# ---------------------------------------------------------------------------

table hmac_extra32.HMAC_slot_descriptor_class_names:
  description: "hmac.HMAC.digest_size and block_size are member_descriptors; class name 'member_descriptor' has 17 characters"
  kind: python_call_eq
  category: class_structure
  id_prefix: hmsdcn32

  columns: [id, function, args, expected]
  rows:
    - [digest_size_classname_len, HMAC.digest_size.__class__.__name__.__len__, [], 17]
    - [block_size_classname_len,  HMAC.block_size.__class__.__name__.__len__,  [], 17]
    - [HMAC_qualname_len,         HMAC.__qualname__.__len__,                   [], 4]
    - [slots_len,                 HMAC.__slots__.__len__,                      [], 5]
