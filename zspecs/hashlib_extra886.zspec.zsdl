table hashlib_extra886.sha3_shake_qualnames:
  description: sha3_256, sha3_512, shake_128, shake_256 digest and hexdigest method qualnames
  kind: python_call_eq
  category: hashlib
  id_prefix: hl886xx
  columns: [id, function, args, expected]
  rows:
    - [hl886xx001, hashlib.sha3_256.digest.__qualname__.__eq__, ["sha3_256.digest"], true]
    - [hl886xx002, hashlib.sha3_256.hexdigest.__qualname__.__eq__, ["sha3_256.hexdigest"], true]
    - [hl886xx003, hashlib.sha3_512.digest.__qualname__.__eq__, ["sha3_512.digest"], true]
    - [hl886xx004, hashlib.sha3_512.hexdigest.__qualname__.__eq__, ["sha3_512.hexdigest"], true]
    - [hl886xx005, hashlib.shake_128.digest.__qualname__.__eq__, ["shake_128.digest"], true]
    - [hl886xx006, hashlib.shake_128.hexdigest.__qualname__.__eq__, ["shake_128.hexdigest"], true]
    - [hl886xx007, hashlib.shake_256.digest.__qualname__.__eq__, ["shake_256.digest"], true]
    - [hl886xx008, hashlib.shake_256.hexdigest.__qualname__.__eq__, ["shake_256.hexdigest"], true]
    - [hl886xx009, hashlib.algorithms_available.__class__.__name__.__eq__, ["set"], true]
    - [hl886xx010, hashlib.__name__.__eq__, ["hashlib"], true]
    - [hl886xx011, hashlib.__package__.__eq__, ["hashlib"], true]
    - [hl886xx012, hashlib.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true]
