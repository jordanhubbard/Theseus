spec: pathlib_extra186
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers: pathlib.PurePath join methods — joinpath.__name__=='joinpath' (len=8); with_name.__name__=='with_name' (len=9); with_stem.__name__=='with_stem' (len=9; same); with_suffix.__name__=='with_suffix' (len=11); relative_to.__name__=='relative_to' (len=11; same); is_absolute.__name__=='is_absolute' (len=11; same — 3-way tie); is_relative_to.__name__=='is_relative_to' (len=14; longest); match.__name__=='match' (len=5)."
    - "pathlib.PurePath.match.__name__ == 'match' (len=5); pathlib.PurePath.joinpath.__name__ == 'joinpath' (len=8)."
    - "pathlib.PurePath.with_name.__name__ == 'with_name' (len=9); pathlib.PurePath.with_stem.__name__ == 'with_stem' (len=9; same)."
    - "with_name (9) == with_stem (9): a 2-way tie at length 9."
    - "pathlib.PurePath.with_suffix.__name__ == 'with_suffix' (len=11); pathlib.PurePath.relative_to.__name__ == 'relative_to' (len=11; same); pathlib.PurePath.is_absolute.__name__ == 'is_absolute' (len=11; same — 3-way tie)."
    - "with_suffix (11) == relative_to (11) == is_absolute (11): a 3-way tie at length 11."
    - "pathlib.PurePath.is_relative_to.__name__ == 'is_relative_to' (len=14): the longest covered method name."
    - "Length ordering: match (5) < joinpath (8) < with_name==with_stem (9) < with_suffix==relative_to==is_absolute (11) < is_relative_to (14)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.PurePath short method names (match, joinpath)
# match (5) < joinpath (8): a strict ordering — the two shortest covered names
# ---------------------------------------------------------------------------

table pathlib_extra186.short_method_names:
  description: "pathlib.PurePath short method names: match.__name__=='match' (len=5); joinpath.__name__=='joinpath' (len=8); match (5) < joinpath (8): a strict ordering; match (5) is the shortest covered method name"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpure186

  columns: [id, function, args, expected, description]
  rows:
    - [match_name,      PurePath.match.__name__.__eq__,        ["match"],    true, "pathlib.PurePath.match.__name__ == 'match' — match() tests whether the path matches a glob-style pattern (e.g., p.match('*.py')); 'match' has 5 characters: m(1)a(2)t(3)c(4)h(5); match (5) is the minimum length in the covered set; match (5) < joinpath (8) < with_name==with_stem (9) < with_suffix==relative_to==is_absolute (11) < is_relative_to (14); confirmed Python 3.14.3 macOS"]
    - [match_name_len,  PurePath.match.__name__.__len__,       [],           5,    "pathlib.PurePath.match.__name__.__len__() == 5 — 'match' has 5 characters; match (5) is the shortest covered method name; match (5) < joinpath (8): a gap of 3 characters between the two shortest; confirmed Python 3.14.3 macOS"]
    - [join_name,       PurePath.joinpath.__name__.__eq__,     ["joinpath"], true, "pathlib.PurePath.joinpath.__name__ == 'joinpath' — joinpath() appends path components (equivalent to the / operator, e.g., p.joinpath('a', 'b')); 'joinpath' has 8 characters: j(1)o(2)i(3)n(4)p(5)a(6)t(7)h(8); match (5) < joinpath (8): joinpath is 3 characters longer than match; joinpath (8) < with_name==with_stem (9): joinpath is 1 shorter than the next group; confirmed Python 3.14.3 macOS"]
    - [join_name_len,   PurePath.joinpath.__name__.__len__,    [],           8,    "pathlib.PurePath.joinpath.__name__.__len__() == 8 — 'joinpath' has 8 characters; match (5) < joinpath (8) < with_name==with_stem (9): joinpath is strictly between the shortest and the 2-way tie at 9; confirmed Python 3.14.3 macOS"]
    - [match_ne_join,   PurePath.match.__name__.__len__,       [],           5,    "pathlib.PurePath.match.__name__.__len__() == 5 confirms match (5) != joinpath (8): a strict inequality of 3 characters; match (5) is the minimum in the full length ordering; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.PurePath medium method names (with_name, with_stem)
# with_name (9) == with_stem (9): a 2-way tie at length 9
# ---------------------------------------------------------------------------

table pathlib_extra186.medium_method_names:
  description: "pathlib.PurePath medium method names: with_name.__name__=='with_name' (len=9); with_stem.__name__=='with_stem' (len=9; same); with_name (9) == with_stem (9): a 2-way tie at length 9; joinpath (8) < with_name==with_stem (9) < with_suffix==relative_to==is_absolute (11)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpure186

  columns: [id, function, args, expected, description]
  rows:
    - [withname_name,      PurePath.with_name.__name__.__eq__,    ["with_name"], true, "pathlib.PurePath.with_name.__name__ == 'with_name' — with_name() returns a new path with a changed final component name (e.g., p.with_name('bar.py')); 'with_name' has 9 characters: w(1)i(2)t(3)h(4)_(5)n(6)a(7)m(8)e(9); with_name (9) == with_stem (9): a 2-way tie at length 9; joinpath (8) < with_name==with_stem (9): the 2-way tie exceeds joinpath by 1; confirmed Python 3.14.3 macOS"]
    - [withname_name_len,  PurePath.with_name.__name__.__len__,   [],            9,    "pathlib.PurePath.with_name.__name__.__len__() == 9 — 'with_name' has 9 characters; with_name (9) == with_stem (9): a 2-way tie; joinpath (8) < with_name==with_stem (9) < with_suffix==relative_to==is_absolute (11): the 2-way tie at 9 is flanked by 8 and 11; confirmed Python 3.14.3 macOS"]
    - [withstem_name,      PurePath.with_stem.__name__.__eq__,    ["with_stem"], true, "pathlib.PurePath.with_stem.__name__ == 'with_stem' — with_stem() returns a new path with a changed stem (the filename without its extension, e.g., p.with_stem('bar')); 'with_stem' has 9 characters: w(1)i(2)t(3)h(4)_(5)s(6)t(7)e(8)m(9); with_stem (9) == with_name (9): both 'with_*' methods share length 9; confirmed Python 3.14.3 macOS"]
    - [withstem_name_len,  PurePath.with_stem.__name__.__len__,   [],            9,    "pathlib.PurePath.with_stem.__name__.__len__() == 9 — 'with_stem' has 9 characters; with_stem (9) == with_name (9): the 2-way tie at length 9; with_stem (9) < with_suffix (11): with_suffix is 2 characters longer than with_stem; confirmed Python 3.14.3 macOS"]
    - [withsuffix_name,    PurePath.with_suffix.__name__.__eq__,  ["with_suffix"], true, "pathlib.PurePath.with_suffix.__name__ == 'with_suffix' — with_suffix() returns a new path with a changed file extension (e.g., p.with_suffix('.txt')); 'with_suffix' has 11 characters: w(1)i(2)t(3)h(4)_(5)s(6)u(7)f(8)f(9)i(10)x(11); with_suffix (11) == relative_to (11) == is_absolute (11): a 3-way tie at length 11; with_name==with_stem (9) < with_suffix==relative_to==is_absolute (11): the 3-way tie exceeds the 2-way tie by 2; confirmed Python 3.14.3 macOS"]
    - [withsuffix_name_len, PurePath.with_suffix.__name__.__len__, [],           11,   "pathlib.PurePath.with_suffix.__name__.__len__() == 11 — 'with_suffix' has 11 characters; with_suffix (11) == relative_to (11) == is_absolute (11): a 3-way tie; with_name==with_stem (9) < with_suffix==relative_to==is_absolute (11) < is_relative_to (14); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.PurePath long method names (relative_to, is_absolute, is_relative_to)
# relative_to==is_absolute (11): tie; is_relative_to (14): the longest covered
# ---------------------------------------------------------------------------

table pathlib_extra186.long_method_names:
  description: "pathlib.PurePath long method names: relative_to.__name__=='relative_to' (len=11); is_absolute.__name__=='is_absolute' (len=11; same); is_relative_to.__name__=='is_relative_to' (len=14; longest); relative_to==is_absolute (11) < is_relative_to (14) by 3"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpure186

  columns: [id, function, args, expected, description]
  rows:
    - [relativeto_name,     PurePath.relative_to.__name__.__eq__,     ["relative_to"],     true, "pathlib.PurePath.relative_to.__name__ == 'relative_to' — relative_to() computes a relative version of the path with respect to another (e.g., PurePath('/a/b').relative_to('/a') == PurePath('b')); 'relative_to' has 11 characters: r(1)e(2)l(3)a(4)t(5)i(6)v(7)e(8)_(9)t(10)o(11); relative_to (11) == with_suffix (11) == is_absolute (11): a 3-way tie at length 11; confirmed Python 3.14.3 macOS"]
    - [relativeto_name_len, PurePath.relative_to.__name__.__len__,    [],                  11,   "pathlib.PurePath.relative_to.__name__.__len__() == 11 — 'relative_to' has 11 characters; relative_to (11) == with_suffix (11) == is_absolute (11): a 3-way tie; with_name==with_stem (9) < relative_to==with_suffix==is_absolute (11) < is_relative_to (14): the 3-way tie is flanked by 9 and 14; confirmed Python 3.14.3 macOS"]
    - [isabsolute_name,     PurePath.is_absolute.__name__.__eq__,     ["is_absolute"],     true, "pathlib.PurePath.is_absolute.__name__ == 'is_absolute' — is_absolute() returns True if the path is absolute (has a root); 'is_absolute' has 11 characters: i(1)s(2)_(3)a(4)b(5)s(6)o(7)l(8)u(9)t(10)e(11); is_absolute (11) == relative_to (11) == with_suffix (11): a 3-way tie at length 11; confirmed Python 3.14.3 macOS"]
    - [isabsolute_name_len, PurePath.is_absolute.__name__.__len__,    [],                  11,   "pathlib.PurePath.is_absolute.__name__.__len__() == 11 — 'is_absolute' has 11 characters; is_absolute (11) == relative_to (11) == with_suffix (11): the 3-way tie; is_absolute (11) < is_relative_to (14): is_relative_to is 3 characters longer; confirmed Python 3.14.3 macOS"]
    - [isrelativeto_name,   PurePath.is_relative_to.__name__.__eq__,  ["is_relative_to"],  true, "pathlib.PurePath.is_relative_to.__name__ == 'is_relative_to' — is_relative_to() returns True if the path is relative to another given path (added in Python 3.9); 'is_relative_to' has 14 characters: i(1)s(2)_(3)r(4)e(5)l(6)a(7)t(8)i(9)v(10)e(11)_(12)t(13)o(14); is_relative_to (14) is the longest covered method name; relative_to==with_suffix==is_absolute (11) < is_relative_to (14) by 3; confirmed Python 3.14.3 macOS"]
    - [isrelativeto_len,    PurePath.is_relative_to.__name__.__len__, [],                  14,   "pathlib.PurePath.is_relative_to.__name__.__len__() == 14 — 'is_relative_to' has 14 characters; is_relative_to (14) is the maximum in the full ordering: match (5) < joinpath (8) < with_name==with_stem (9) < with_suffix==relative_to==is_absolute (11) < is_relative_to (14); is_relative_to (14) > is_absolute (11) by 3: the 'relative_to' suffix adds 3 characters to 'is_'; confirmed Python 3.14.3 macOS"]

