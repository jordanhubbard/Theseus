spec: itertools_extra2656
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 624 theme: __contains__, __add__, and __mul__ dict-presence checks (container membership and sequence arithmetic)."
    - "All itertools iterator classes (chain, count, repeat, cycle, islice, compress, dropwhile, takewhile, starmap, groupby, filterfalse, accumulate, zip_longest, pairwise, product, permutations, combinations, combinations_with_replacement) are lazy iterators."
    - "Lazy iterators do not support __contains__ (membership testing would require consuming the iterator)."
    - "Lazy iterators do not support __add__ or __mul__ (no concatenation or repetition semantics are defined)."
    - "itertools.repeat does have a __len__ for finite repeats, but still defines none of __contains__, __add__, __mul__."
    - "None of the itertools classes define __contains__, __add__, or __mul__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __contains__ dict-presence — absent from all itertools classes
# ---------------------------------------------------------------------------

table itertools_extra2656.contains_protocol:
  description: "__contains__ is absent from all itertools iterator class __dict__s — lazy iterators do not support membership testing"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2656

  columns: [id, function, args, expected]
  rows:
    - ["it2656001", "itertools.chain.__dict__.__contains__",                        ["__contains__"], false]
    - ["it2656002", "itertools.count.__dict__.__contains__",                        ["__contains__"], false]
    - ["it2656003", "itertools.repeat.__dict__.__contains__",                       ["__contains__"], false]
    - ["it2656004", "itertools.cycle.__dict__.__contains__",                        ["__contains__"], false]
