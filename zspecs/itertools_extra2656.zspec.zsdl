    - ["it2656007", "itertools.dropwhile.__dict__.__contains__",                    ["__contains__"], false]
    - ["it2656008", "itertools.takewhile.__dict__.__contains__",                    ["__contains__"], false]
    - ["it2656009", "itertools.starmap.__dict__.__contains__",                      ["__contains__"], false]
    - ["it2656010", "itertools.groupby.__dict__.__contains__",                      ["__contains__"], false]
    - ["it2656011", "itertools.filterfalse.__dict__.__contains__",                  ["__contains__"], false]
    - ["it2656012", "itertools.accumulate.__dict__.__contains__",                   ["__contains__"], false]
    - ["it2656013", "itertools.zip_longest.__dict__.__contains__",                  ["__contains__"], false]
    - ["it2656014", "itertools.pairwise.__dict__.__contains__",                     ["__contains__"], false]
