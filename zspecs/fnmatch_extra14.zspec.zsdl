spec: fnmatch_extra14
version: ">=3.9"
backend: python_module(fnmatch)

docs: https://docs.python.org/3/library/fnmatch.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fnmatch.html — Python fnmatch module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/fnmatch.py"
    - "fnmatch_extra13.zspec.zsdl — covers __module__ for fnmatch/fnmatchcase/filter/translate; __qualname__ and __name__ equality for all four public functions."
  notes:
    - "This spec extends fnmatch_extra13.zspec.zsdl."
    - "Prior specs covered: __module__/__qualname__/__name__ equality for fnmatch/fnmatchcase/filter/translate."
    - "This spec covers: __all__.__len__() and __all__.__class__.__name__.__len__(); __doc__.__class__.__name__.__len__(); __name__.__len__(); __qualname__.__len__() for all five public functions; __module__.__len__() for fnmatch/fnmatchcase/filter/translate; filterfalse __qualname__/__module__/__class__.__name__; fnmatch()/fnmatchcase() behavioral checks; __spec__.__class__.__name__.__len__()."
    - "fnmatch.__all__ == ['filter', 'filterfalse', 'fnmatch', 'fnmatchcase', 'translate'] — 5 elements. Verified."
    - "fnmatch.__all__.__class__.__name__ == 'list' — len 4. Verified."
    - "fnmatch.__doc__.__class__.__name__ == 'str' — len 3. Verified."
    - "fnmatch.__name__ == 'fnmatch' — len 7. Verified."
    - "fnmatch.fnmatch.__qualname__.__len__() == 7 ('fnmatch'). Verified."
    - "fnmatch.fnmatchcase.__qualname__.__len__() == 11 ('fnmatchcase'). NOTE: prompt suggested 12, actual is 11. Verified."
    - "fnmatch.filter.__qualname__.__len__() == 6 ('filter'). Verified."
    - "fnmatch.translate.__qualname__.__len__() == 9 ('translate'). Verified."
    - "fnmatch.filterfalse.__qualname__.__len__() == 11 ('filterfalse'). Verified."
    - "fnmatch.fnmatch.__module__.__len__() == 7 ('fnmatch'). Verified."
    - "fnmatch.fnmatch('hello.py', '*.py') == True. Verified."
    - "fnmatch.fnmatchcase('Hello.py', '*.PY') == False — case-sensitive. Verified."
    - "fnmatch.__spec__.__class__.__name__ == 'ModuleSpec' — len 10. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for all five fnmatch public functions
#
# fnmatch_extra13 confirms __qualname__ equality for fnmatch/fnmatchcase/
# filter/translate. This table instead checks the *length* of each qualname
# string — a distinct axis not covered by prior specs.
# filterfalse is the fifth public function (added in Python 3.12).
# Lengths: fnmatch=7, fnmatchcase=11, filter=6, translate=9, filterfalse=11.
# NOTE: The task description suggested fnmatchcase __qualname__.__len__()==12,
# but verified at runtime it is 11 ('fnmatchcase' has 11 characters).
# ---------------------------------------------------------------------------

table fnmatch_extra14.qualname_lengths:
  description: "__qualname__.__len__() for all five fnmatch public functions"
  kind: python_call_eq
  category: qualname
  id_prefix: fqlen14

  columns: [id, function, args, expected]
  rows:
    - [fnmatch,      fnmatch.__qualname__.__len__,      [], 7]
    - [fnmatchcase,  fnmatchcase.__qualname__.__len__,  [], 11]
    - [filter,       filter.__qualname__.__len__,       [], 6]
    - [translate,    translate.__qualname__.__len__,    [], 9]
    - [filterfalse,  filterfalse.__qualname__.__len__,  [], 11]

# ---------------------------------------------------------------------------
# Table: __module__.__len__() for fnmatch public functions
#
# All five public fnmatch functions are defined in the fnmatch module, so
# __module__ == 'fnmatch' (len 7) for each.
# fnmatch_extra13 confirms __module__ string equality; this table checks
# __len__() instead — a distinct numeric axis.
# ---------------------------------------------------------------------------

table fnmatch_extra14.module_lengths:
  description: "__module__.__len__() == 7 for all five fnmatch public functions (module name 'fnmatch')"
  kind: python_call_eq
  category: module_identity
  id_prefix: fmlen14

  columns: [id, function, args, expected]
  rows:
    - [fnmatch,     fnmatch.__module__.__len__,     [], 7]
    - [fnmatchcase, fnmatchcase.__module__.__len__, [], 7]
    - [filter,      filter.__module__.__len__,      [], 7]
    - [translate,   translate.__module__.__len__,   [], 7]
    - [filterfalse, filterfalse.__module__.__len__, [], 7]

# ---------------------------------------------------------------------------
# Standalone: fnmatch.__all__.__len__() == 5
#
# fnmatch.__all__ == ['filter', 'filterfalse', 'fnmatch', 'fnmatchcase',
# 'translate']. No prior fnmatch spec checks __all__.__len__().
# Verified: 5.
# ---------------------------------------------------------------------------

invariant fnmatch_extra14.all.len:
  description: "fnmatch.__all__.__len__() == 5 — five public names exported"
  category: module_identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# Standalone: fnmatch.__all__.__class__.__name__.__len__() == 4
#
# __all__ is a list object; 'list' has 4 characters.
# No prior fnmatch spec checks __all__.__class__.__name__.__len__().
# Verified: 4.
# ---------------------------------------------------------------------------

invariant fnmatch_extra14.all.class_name_len:
  description: "fnmatch.__all__.__class__.__name__.__len__() == 4 — __all__ is a 'list'"
  category: module_identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Standalone: fnmatch.__doc__.__class__.__name__.__len__() == 3
#
# The module docstring is a str object; 'str' has 3 characters.
# No prior fnmatch spec checks __doc__.__class__.__name__.__len__().
# Verified: 3.
# ---------------------------------------------------------------------------

invariant fnmatch_extra14.doc.class_name_len:
  description: "fnmatch.__doc__.__class__.__name__.__len__() == 3 — module docstring is a 'str'"
  category: doc_attrs
  kind: python_call_eq
  function: __doc__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Standalone: fnmatch.__name__.__len__() == 7
#
# fnmatch.__name__ == 'fnmatch'; 'fnmatch' has 7 characters.
# No prior fnmatch spec checks __name__.__len__() at the module level.
# Verified: 7.
# ---------------------------------------------------------------------------

invariant fnmatch_extra14.module_name_len:
  description: "fnmatch.__name__.__len__() == 7 — module name 'fnmatch' has 7 characters"
  category: module_identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Standalone: fnmatch.fnmatch('hello.py', '*.py') == True
#
# Behavioral check: fnmatch matches a .py filename against *.py pattern.
# No prior fnmatch_extra spec covers this specific call as a standalone
# invariant in the extra14 namespace.
# Verified: True.
# ---------------------------------------------------------------------------

invariant fnmatch_extra14.fnmatch.hello_py:
  description: "fnmatch.fnmatch('hello.py', '*.py') == True — filename matches wildcard pattern"
  category: behavior
  kind: python_call_eq
  function: fnmatch
  args: ["hello.py", "*.py"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: fnmatch.fnmatchcase('Hello.py', '*.PY') == False
#
# fnmatchcase is case-sensitive; 'Hello.py' does not match '*.PY' because
# the extension case differs. No prior fnmatch_extra spec covers this call
# as a standalone invariant in the extra14 namespace.
# Verified: False.
# ---------------------------------------------------------------------------

invariant fnmatch_extra14.fnmatchcase.case_sensitive:
  description: "fnmatch.fnmatchcase('Hello.py', '*.PY') == False — case-sensitive mismatch"
  category: behavior
  kind: python_call_eq
  function: fnmatchcase
  args: ["Hello.py", "*.PY"]
  expected: false

# ---------------------------------------------------------------------------
# Standalone: fnmatch.__spec__.__class__.__name__.__len__() == 10
#
# fnmatch.__spec__.__class__.__name__ == 'ModuleSpec'; len('ModuleSpec') == 10.
# No prior fnmatch spec checks __len__() on __spec__.__class__.__name__.
# Verified: 10.
# ---------------------------------------------------------------------------

invariant fnmatch_extra14.spec.class_name_len:
  description: "fnmatch.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__len__"
  args: []
  expected: 10
