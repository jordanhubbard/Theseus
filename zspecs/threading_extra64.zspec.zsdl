spec: threading_extra64
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra63.zspec.zsdl."
    - "Wave 229 theme: __defaults__ and __kwdefaults__ checks for function parameters + __code__ attribute identity + __closure__ checks."
    - "threading.Thread.__init__ is a pure-Python function (Lib/threading.py) with signature __init__(self, group=None, target=None, name=None, args=(), kwargs=None, *, daemon=None, context=None). The positional parameters with defaults are group, target, name, args, kwargs — that is 5 positional defaults. Therefore Thread.__init__.__defaults__ == (None, None, None, (), None), a 5-element tuple. Thread.__init__.__defaults__.__class__.__name__ == 'tuple'."
    - "Thread.__init__ also has keyword-only parameters daemon=None and context=None. These go into Thread.__init__.__kwdefaults__ == {'daemon': None, 'context': None}. Thread.__init__.__kwdefaults__.__class__.__name__ == 'dict'."
    - "threading.current_thread is a pure-Python function (Lib/threading.py) with no parameters. current_thread.__defaults__ is None. current_thread.__defaults__.__class__.__name__ == 'NoneType'."
    - "Thread.__init__.__code__.__class__.__name__ == 'code' — Thread.__init__ is a pure-Python function; its __code__ is a PyCodeObject."
    - "threading.current_thread.__code__.__class__.__name__ == 'code' — same reasoning."
    - "Thread.__init__.__closure__ is None — Thread.__init__ is defined inside the Thread class body which is at module scope in Lib/threading.py; it captures no free variables; __closure__ is None."
    - "threading.current_thread.__closure__ is None — current_thread is a module-level function, not a closure."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "No prior threading spec checks __defaults__, __kwdefaults__, __code__.__class__.__name__, or __closure__ for any threading function. All checks in this spec are new to extra64."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread.__init__.__defaults__ — extra64
#
# Wave 229 theme: __defaults__ checks for function parameters.
#
# threading.Thread.__init__(self, group=None, target=None, name=None,
#                           args=(), kwargs=None, *, daemon=None, context=None)
#
# Positional parameters with defaults: group, target, name, args, kwargs
# (self has no default; daemon and context are keyword-only after *)
# Therefore __defaults__ == (None, None, None, (), None)
# __defaults__.__class__.__name__ == 'tuple'
# len(__defaults__) == 5
#
# No prior threading spec checks Thread.__init__.__defaults__. New to extra64.
# ---------------------------------------------------------------------------

table threading_extra64.thread_init_defaults:
  description: "Thread.__init__.__defaults__.__class__.__name__.__eq__('tuple')==true — Thread.__init__ has 5 positional defaults; wave 229 __defaults__ checks; new to extra64"
  kind: python_call_eq
  category: defaults_type
  id_prefix: thrdcode64

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_defaults_class_name_eq_tuple,
       Thread.__init__.__defaults__.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "threading.Thread.__init__.__defaults__.__class__.__name__.__eq__('tuple') == True — Thread is a pure-Python class (Lib/threading.py); its __init__ method has signature __init__(self, group=None, target=None, name=None, args=(), kwargs=None, *, daemon=None, context=None); the 5 positional parameters with defaults (group, target, name, args, kwargs) produce __defaults__ == (None, None, None, (), None), a 5-element tuple; as a tuple object, __defaults__.__class__ is the built-in tuple type and tuple.__name__ == 'tuple'; no prior threading spec checks Thread.__init__.__defaults__; new to extra64"]

# ---------------------------------------------------------------------------
# Thread.__init__.__kwdefaults__ — extra64
#
# Wave 229 theme: __kwdefaults__ checks for keyword-only parameters.
#
# Thread.__init__ has keyword-only parameters daemon=None and context=None
# (after the * in the signature). These are stored in __kwdefaults__:
#   Thread.__init__.__kwdefaults__ == {'daemon': None, 'context': None}
#   __kwdefaults__.__class__.__name__ == 'dict'
#   __kwdefaults__.__contains__('daemon') == True
#
# No prior threading spec checks Thread.__init__.__kwdefaults__. New to extra64.
# ---------------------------------------------------------------------------

table threading_extra64.thread_init_kwdefaults:
  description: "Thread.__init__.__kwdefaults__.__class__.__name__.__eq__('dict') and __contains__('daemon') — kw-only defaults stored in dict; wave 229 __kwdefaults__ checks; new to extra64"
  kind: python_call_eq
  category: kwdefaults_type
  id_prefix: thrdcode64

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_kwdefaults_class_name_eq_dict,
       Thread.__init__.__kwdefaults__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "threading.Thread.__init__.__kwdefaults__.__class__.__name__.__eq__('dict') == True — Thread.__init__ has keyword-only parameters daemon=None and context=None (after the bare * in the signature); Python stores keyword-only parameter defaults in the __kwdefaults__ dict, one key per kw-only parameter with a default; therefore Thread.__init__.__kwdefaults__ == {'daemon': None, 'context': None}, a 2-key dict; __kwdefaults__.__class__.__name__ == 'dict'; no prior threading spec checks Thread.__init__.__kwdefaults__; new to extra64"]
    - [thread_init_kwdefaults_contains_daemon,
       Thread.__init__.__kwdefaults__.__contains__,
       ["daemon"],
       true,
       "threading.Thread.__init__.__kwdefaults__.__contains__('daemon') == True — Thread.__init__.__kwdefaults__ is {'daemon': None, 'context': None}; 'daemon' is one of the two keyword-only parameters with a default value (None); it appears as a key in __kwdefaults__; __contains__ on a dict returns True when the key is present; no prior threading spec checks __kwdefaults__.__contains__ for any threading function; new to extra64"]
    - [thread_init_kwdefaults_contains_context,
       Thread.__init__.__kwdefaults__.__contains__,
       ["context"],
       true,
       "threading.Thread.__init__.__kwdefaults__.__contains__('context') == True — Thread.__init__.__kwdefaults__ is {'daemon': None, 'context': None}; 'context' is the second keyword-only parameter with a default value (None); it appears as a key in __kwdefaults__; __contains__ returns True; no prior threading spec checks __kwdefaults__.__contains__('context'); new to extra64"]

# ---------------------------------------------------------------------------
# current_thread.__defaults__ — extra64
#
# Wave 229 theme: __defaults__ checks.
#
# threading.current_thread() — no parameters at all.
# Therefore current_thread.__defaults__ is None.
# None.__class__.__name__ == 'NoneType'.
#
# No prior threading spec checks current_thread.__defaults__. New to extra64.
# ---------------------------------------------------------------------------

table threading_extra64.current_thread_defaults:
  description: "current_thread.__defaults__.__class__.__name__.__eq__('NoneType')==true — no defaults for zero-parameter function; wave 229 __defaults__ checks; new to extra64"
  kind: python_call_eq
  category: defaults_type
  id_prefix: thrdcode64

  columns: [id, function, args, expected, description]
  rows:
    - [current_thread_defaults_class_name_eq_NoneType,
       current_thread.__defaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "threading.current_thread.__defaults__.__class__.__name__.__eq__('NoneType') == True — current_thread is a pure-Python module-level function (Lib/threading.py) that returns the Thread object corresponding to the calling thread; it takes no parameters, so there are no positional defaults; Python sets __defaults__ to None (not an empty tuple) when no positional defaults exist; None.__class__ is the NoneType type and NoneType.__name__ == 'NoneType'; no prior threading spec checks current_thread.__defaults__; new to extra64"]

# ---------------------------------------------------------------------------
# Thread.__init__.__code__ and current_thread.__code__ — extra64
#
# Wave 229 theme: __code__ attribute identity.
#
# Both Thread.__init__ and current_thread are pure-Python functions in
# Lib/threading.py. Each has a __code__ attribute pointing to a code object
# (PyCodeObject). code.__class__.__name__ == 'code'.
#
# No prior threading spec checks __code__.__class__.__name__. New to extra64.
# ---------------------------------------------------------------------------

table threading_extra64.code_class_name:
  description: "Thread.__init__/current_thread __code__.__class__.__name__.__eq__('code')==true — pure-Python functions have a code object; wave 229 __code__ identity; new to extra64"
  kind: python_call_eq
  category: code_type
  id_prefix: thrdcode64

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_code_class_name_eq_code,
       Thread.__init__.__code__.__class__.__name__.__eq__,
       ["code"],
       true,
       "threading.Thread.__init__.__code__.__class__.__name__.__eq__('code') == True — Thread.__init__ is a pure-Python function (Lib/threading.py); every Python function object (PyFunctionObject) carries a __code__ attribute pointing to its associated code object (PyCodeObject); the built-in code type has __name__ == 'code' (4 chars); this chain verifies the type identity of the code object for Thread.__init__; no prior threading spec checks __code__.__class__.__name__ for Thread.__init__; new to extra64"]
    - [current_thread_code_class_name_eq_code,
       current_thread.__code__.__class__.__name__.__eq__,
       ["code"],
       true,
       "threading.current_thread.__code__.__class__.__name__.__eq__('code') == True — current_thread is a pure-Python function (Lib/threading.py) that returns the current Thread object; its __code__ is a PyCodeObject; __code__.__class__.__name__ == 'code'; no prior threading spec checks __code__.__class__.__name__ for current_thread; new to extra64"]

# ---------------------------------------------------------------------------
# Thread.__init__.__closure__ and current_thread.__closure__ — extra64
#
# Wave 229 theme: __closure__ checks.
#
# Thread.__init__ is defined inside the Thread class body in Lib/threading.py.
# The class body is at module scope. Thread.__init__ does not capture any
# free variables from an enclosing function scope. Therefore
# Thread.__init__.__closure__ is None.
#
# current_thread is a module-level function. It is not a nested function.
# Therefore current_thread.__closure__ is None.
#
# None.__class__.__name__ == 'NoneType'.
#
# No prior threading spec checks __closure__ for any threading function. New to extra64.
# ---------------------------------------------------------------------------

table threading_extra64.closure_class_name:
  description: "Thread.__init__/current_thread __closure__.__class__.__name__.__eq__('NoneType')==true — no closures for class method or module-level function; wave 229 __closure__ checks; new to extra64"
  kind: python_call_eq
  category: closure_type
  id_prefix: thrdcode64

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_closure_class_name_eq_NoneType,
       Thread.__init__.__closure__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "threading.Thread.__init__.__closure__.__class__.__name__.__eq__('NoneType') == True — Thread.__init__ is defined inside the Thread class body in Lib/threading.py; the class body itself is at module scope (not inside another function); therefore Thread.__init__ does not capture any free variables from an enclosing function scope and __closure__ is None; None.__class__ is the NoneType type and NoneType.__name__ == 'NoneType' (8 chars); no prior threading spec checks __closure__ for Thread.__init__; new to extra64"]
    - [current_thread_closure_class_name_eq_NoneType,
       current_thread.__closure__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "threading.current_thread.__closure__.__class__.__name__.__eq__('NoneType') == True — current_thread is a module-level function defined at the top level of Lib/threading.py; it is not nested inside another function and captures no free variables; therefore current_thread.__closure__ is None; None.__class__.__name__ == 'NoneType'; no prior threading spec checks __closure__ for current_thread; new to extra64"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra64
# ---------------------------------------------------------------------------

invariant threading_extra64.thread_init_defaults_is_tuple:
  description: "threading.Thread.__init__.__defaults__.__class__.__name__.__eq__('tuple') == True — Thread.__init__ has 5 positional defaults (group, target, name, args, kwargs); __defaults__ is a 5-element tuple; wave 229 __defaults__ checks; new to extra64"
  kind: python_call_eq
  function: Thread.__init__.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant threading_extra64.thread_init_kwdefaults_is_dict:
  description: "threading.Thread.__init__.__kwdefaults__.__class__.__name__.__eq__('dict') == True — Thread.__init__ has kw-only parameters daemon=None and context=None stored in __kwdefaults__; wave 229 __kwdefaults__ checks; new to extra64"
  kind: python_call_eq
  function: Thread.__init__.__kwdefaults__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant threading_extra64.thread_init_code_is_code:
  description: "threading.Thread.__init__.__code__.__class__.__name__.__eq__('code') == True — Thread.__init__ is a pure-Python function; its __code__ is a PyCodeObject; wave 229 __code__ identity; new to extra64"
  kind: python_call_eq
  function: Thread.__init__.__code__.__class__.__name__.__eq__
  args: ["code"]
  expected: true

invariant threading_extra64.thread_init_closure_is_None:
  description: "threading.Thread.__init__.__closure__.__class__.__name__.__eq__('NoneType') == True — Thread.__init__ is not a closure; defined inside class body at module scope; __closure__ is None; wave 229 __closure__ checks; new to extra64"
  kind: python_call_eq
  function: Thread.__init__.__closure__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true
