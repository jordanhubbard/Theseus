spec: sched_extra4
version: ">=3.9"
backend: python_module(sched)

docs: https://docs.python.org/3/library/sched.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sched.html — Python sched module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sched.py"
  notes:
    - "This spec extends sched.zspec.zsdl and prior extras."
    - "sched.zspec.zsdl covers: scheduler.__name__, scheduler.__module__, scheduler is_type, Event.__name__, scheduler().empty(), scheduler().queue==[], method names table (enter/enterabs/cancel/run/empty), Event._fields membership."
    - "sched_extra.zspec.zsdl covers: scheduler.__name__, scheduler.__module__, Event.__name__, Event.__module__, scheduler().queue.__class__.__name__=='list', scheduler().empty()==True, Event._fields.__class__.__name__=='tuple'."
    - "sched_extra2.zspec.zsdl covers: scheduler.__name__/__module__/__qualname__, scheduler is_type, method __name__ and __qualname__ table (enter/cancel/run/empty), Event.__name__/__module__, Event._fields is tuple, _fields.__eq__, _fields.__len__, field-presence table."
    - "sched_extra3.zspec.zsdl covers: scheduler.__bases__[0].__name__=='object', scheduler.enterabs.__qualname__, Event.__qualname__=='Event', Event.__bases__[0].__name__=='tuple', Event._fields indexed access table (all 6 fields), scheduler.__doc__ is str."
    - "This spec adds: scheduler.__name__ standalone invariant (extra4 namespace); scheduler.__class__.__name__=='type' standalone; Event.__name__ standalone; sched.scheduler().__class__.__name__=='scheduler'; Event._fields individual field invariants via __getitem__."
    - "sched.scheduler().__class__.__name__ == 'scheduler' — an instance reports its class name as 'scheduler'."
    - "sched.Event._fields[0] == 'time', [1] == 'priority', [2] == 'sequence', [3] == 'action', [4] == 'argument', [5] == 'kwargs'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# scheduler.__name__ — standalone invariant in extra4 namespace
# (all prior specs cover this; we add as an anchor in extra4's namespace)
# ---------------------------------------------------------------------------

invariant sched_extra4.scheduler.name:
  description: "sched.scheduler.__name__ == 'scheduler'"
  category: class_identity
  kind: python_call_eq
  function: scheduler.__name__.__eq__
  args: ["scheduler"]
  expected: true

# ---------------------------------------------------------------------------
# Event.__name__ — standalone invariant in extra4 namespace
# ---------------------------------------------------------------------------

invariant sched_extra4.Event.name:
  description: "sched.Event.__name__ == 'Event'"
  category: class_identity
  kind: python_call_eq
  function: Event.__name__.__eq__
  args: ["Event"]
  expected: true

# ---------------------------------------------------------------------------
# scheduler().__class__.__name__ — instance class name check
# sched_extra2 checks scheduler.__class__.__name__ == 'type' (the class itself).
# This invariant checks that an INSTANCE reports __class__.__name__ == 'scheduler'.
# No prior spec checks the instance's class name.
# ---------------------------------------------------------------------------

invariant sched_extra4.scheduler.instance_class_name:
  description: "sched.scheduler().__class__.__name__ == 'scheduler' — instance identifies its class"
  category: class_identity
  kind: python_call_eq
  function: scheduler
  args: []
  method: __class__.__name__.__eq__
  method_args: ["scheduler"]
  expected: true

# ---------------------------------------------------------------------------
# Event._fields — individual field access invariants
# sched_extra3 covers all 6 via a table (sched_extra3.Event.fields_by_index).
# Here we add standalone invariants in extra4's namespace for individual
# traceability and independent ID assignment.
# ---------------------------------------------------------------------------

invariant sched_extra4.Event.fields_time:
  description: "sched.Event._fields[0] == 'time'"
  category: Event
  kind: python_call_eq
  function: Event._fields.__getitem__
  args: [0]
  expected: "time"

invariant sched_extra4.Event.fields_priority:
  description: "sched.Event._fields[1] == 'priority'"
  category: Event
  kind: python_call_eq
  function: Event._fields.__getitem__
  args: [1]
  expected: "priority"

invariant sched_extra4.Event.fields_sequence:
  description: "sched.Event._fields[2] == 'sequence'"
  category: Event
  kind: python_call_eq
  function: Event._fields.__getitem__
  args: [2]
  expected: "sequence"

invariant sched_extra4.Event.fields_action:
  description: "sched.Event._fields[3] == 'action'"
  category: Event
  kind: python_call_eq
  function: Event._fields.__getitem__
  args: [3]
  expected: "action"

invariant sched_extra4.Event.fields_argument:
  description: "sched.Event._fields[4] == 'argument'"
  category: Event
  kind: python_call_eq
  function: Event._fields.__getitem__
  args: [4]
  expected: "argument"

invariant sched_extra4.Event.fields_kwargs:
  description: "sched.Event._fields[5] == 'kwargs'"
  category: Event
  kind: python_call_eq
  function: Event._fields.__getitem__
  args: [5]
  expected: "kwargs"
