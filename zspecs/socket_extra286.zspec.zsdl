spec: socket_extra286
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket.socket class method identity and property descriptors"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py, Modules/socketmodule.c"
  notes:
    - "socket.socket method __qualname__ uses 'socket.' prefix (lowercase class name), not 'socket.socket.'"
    - "socket.socket.family and socket.socket.type are properties"
    - "socket.socket.proto is a member_descriptor, not a property"
    - "socket.socket.timeout is a getset_descriptor"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table socket_extra286.method_qualnames:
  description: "socket.socket method __qualname__ values"
  kind: python_call_eq
  category: identity
  id_prefix: ske286

  columns: [id, function, args, expected, description]
  rows:
    - [ske286_001, socket.socket.bind.__qualname__, [], "socket.bind", "socket.socket.bind qualname"]
    - [ske286_002, socket.socket.connect.__qualname__, [], "socket.connect", "socket.socket.connect qualname"]
    - [ske286_003, socket.socket.listen.__qualname__, [], "socket.listen", "socket.socket.listen qualname"]
    - [ske286_004, socket.socket.accept.__qualname__, [], "socket.accept", "socket.socket.accept qualname"]
    - [ske286_005, socket.socket.recv.__qualname__, [], "socket.recv", "socket.socket.recv qualname"]
    - [ske286_006, socket.socket.send.__qualname__, [], "socket.send", "socket.socket.send qualname"]
    - [ske286_007, socket.socket.close.__qualname__, [], "socket.close", "socket.socket.close qualname"]
    - [ske286_008, socket.socket.settimeout.__qualname__, [], "socket.settimeout", "socket.socket.settimeout qualname"]
    - [ske286_009, socket.socket.getsockname.__qualname__, [], "socket.getsockname", "socket.socket.getsockname qualname"]

table socket_extra286.descriptor_class_names:
  description: "socket.socket descriptor class names for family, type, proto, timeout"
  kind: python_call_eq
  category: identity
  id_prefix: ske286d

  columns: [id, function, args, expected, description]
  rows:
    - [ske286d_001, socket.socket.family.__class__.__name__, [], property, "socket.socket.family is a property"]
    - [ske286d_002, socket.socket.type.__class__.__name__, [], property, "socket.socket.type is a property"]
    - [ske286d_003, socket.socket.proto.__class__.__name__, [], member_descriptor, "socket.socket.proto is a member_descriptor"]
    - [ske286d_004, socket.socket.timeout.__class__.__name__, [], getset_descriptor, "socket.socket.timeout is a getset_descriptor"]

invariant socket_extra286.setsockopt_qualname:
  description: "socket.socket.setsockopt __qualname__ is 'socket.setsockopt'"
  category: identity
  kind: python_call_eq
  function: socket.socket.setsockopt.__qualname__
  args: []
  expected: "socket.setsockopt"

invariant socket_extra286.bind_qualname:
  description: "socket.socket.bind __qualname__ is 'socket.bind'"
  category: identity
  kind: python_call_eq
  function: socket.socket.bind.__qualname__
  args: []
  expected: "socket.bind"

invariant socket_extra286.family_is_property:
  description: "socket.socket.family is a property descriptor"
  category: identity
  kind: python_call_eq
  function: socket.socket.family.__class__.__name__
  args: []
  expected: property

invariant socket_extra286.proto_is_member_descriptor:
  description: "socket.socket.proto is a member_descriptor (not a property)"
  category: identity
  kind: python_call_eq
  function: socket.socket.proto.__class__.__name__
  args: []
  expected: member_descriptor
