spec: inspect_extra48
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra47.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/iscode/isframe/istraceback __name__/__qualname__.__len__(); iscoroutinefunction/isgeneratorfunction/isasyncgenfunction __name__/__qualname__.__len__(); getmembers/getfile/getsource/getmodule/signature/stack/currentframe/getfullargspec __qualname__.__len__(); Parameter/__mro__.__len__()==2; Signature/__mro__.__len__()==2; BoundArguments/__mro__.__len__()==2; FullArgSpec/__mro__.__len__()==3; FrameInfo/__mro__.__len__()==4; Parameter.empty/kind constants; inspect.__all__.__len__()==107; CO_OPTIMIZED==1; cleandoc/formatannotation/getattr_static/classify_class_attrs __name__ lengths; Signature/Parameter/BoundArguments method qualnames; getmembers/__module__.__len__(7); parameter kind integer values; Parameter/__name__/__module__/__qualname__; Signature/__name__/__module__/__qualname__; BoundArguments/__name__/__qualname__/__module__; FullArgSpec/__name__/__qualname__/__module__; FrameInfo/__name__/__qualname__; class __bases__[0].__name__ for Parameter/Signature/BoundArguments; FullArgSpec/__bases__[0].__name__=='tuple'; FrameInfo/__bases__[0].__name__=='_FrameInfo'; all __bases__[0].__qualname__ for Parameter/Signature/BoundArguments/FullArgSpec/FrameInfo; getouterframes/__name__/__module__; getinnerframes/__name__/__module__; formatargvalues/__name__/__module__; walktree/__name__/__module__; classify_class_attrs/__name__/__module__; getattr_static/__name__/__module__; isfunction/__class__.__name__=='function'; isbuiltin/__class__.__name__=='function'; isclass/__class__.__name__=='function'; ismodule/__class__.__name__=='function'; signature/__class__.__name__=='function'; getdoc/__class__.__name__=='function'; getsource/__class__.__name__=='function'; Parameter/__class__.__name__=='type'; Signature/__class__.__name__=='type'."
    - "This spec covers: inspect.isfunction.__class__.__qualname__ == 'function'; inspect.isbuiltin.__class__.__qualname__ == 'function'; inspect.isclass.__class__.__qualname__ == 'function'; inspect.ismodule.__class__.__qualname__ == 'function'; inspect.signature.__class__.__qualname__ == 'function'; inspect.Parameter.__class__.__qualname__ == 'type'; inspect.Signature.__class__.__qualname__ == 'type'; inspect.BoundArguments.__class__.__qualname__ == 'type'; inspect.FullArgSpec.__class__.__qualname__ == 'type'."
    - "Key findings: For all inspect module-level functions (isfunction, isbuiltin, isclass, ismodule, signature), __class__.__qualname__ == 'function' (8 chars) — the same value as __class__.__name__ because the Python 'function' type is a top-level built-in type with __qualname__ == __name__. For class objects (Parameter, Signature, BoundArguments, FullArgSpec), __class__.__qualname__ == 'type' (4 chars) — the 'type' metaclass is also a top-level built-in with __qualname__ == __name__. FullArgSpec is a namedtuple created by collections.namedtuple(), but namedtuples are constructed by calling type() at runtime, so their metaclass is still the standard 'type'. Therefore FullArgSpec.__class__.__qualname__ == 'type'. BoundArguments is a pure-Python class defined with a class statement in Lib/inspect.py (not a namedtuple), so __class__.__qualname__ == 'type' as well. No prior spec recorded __class__.__qualname__ string equality for any inspect module-level object. All nine invariants are new to extra48."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect predicate functions __class__.__qualname__ — extra48 namespace
#
# inspect.isfunction, isbuiltin, isclass, and ismodule are pure-Python boolean
# predicate functions defined in Lib/inspect.py. Their __class__ is the built-in
# 'function' type. Since 'function' is a top-level built-in type with no enclosing
# class scope, __class__.__qualname__ == __class__.__name__ == 'function' (8 chars).
# Prior spec extra47 recorded __class__.__name__ == 'function' for all four; this
# spec records __class__.__qualname__ == 'function'. No prior spec recorded
# __class__.__qualname__ for any of them. All four are new to extra48.
# ---------------------------------------------------------------------------

table inspect_extra48.predicate_functions_class_qualnames:
  description: "inspect predicate functions __class__.__qualname__ == 'function' — isfunction/isbuiltin/isclass/ismodule are pure-Python def-statement functions in Lib/inspect.py; __class__ is the built-in function type; __qualname__ == __name__ == 'function' for top-level built-in types; 8-char qualname"
  kind: python_call_eq
  category: identity
  id_prefix: inspclsqual48

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_class_qualname,
       isfunction.__class__.__qualname__.__eq__,
       ["function"],
       true,
       "inspect.isfunction.__class__.__qualname__ == 'function' — pure-Python predicate in Lib/inspect.py; returns True if object is a Python function created by a def statement; __class__ is the built-in function type; __class__.__qualname__ == __class__.__name__ == 'function' (8 chars)"]
    - [isbuiltin_class_qualname,
       isbuiltin.__class__.__qualname__.__eq__,
       ["function"],
       true,
       "inspect.isbuiltin.__class__.__qualname__ == 'function' — pure-Python predicate in Lib/inspect.py; returns True if object is a built-in function or bound method; __class__ is the built-in function type; __class__.__qualname__ == 'function' (8 chars)"]
    - [isclass_class_qualname,
       isclass.__class__.__qualname__.__eq__,
       ["function"],
       true,
       "inspect.isclass.__class__.__qualname__ == 'function' — pure-Python predicate in Lib/inspect.py; returns True if object is a class; __class__ is the built-in function type; __class__.__qualname__ == 'function' (8 chars)"]
    - [ismodule_class_qualname,
       ismodule.__class__.__qualname__.__eq__,
       ["function"],
       true,
       "inspect.ismodule.__class__.__qualname__ == 'function' — pure-Python predicate in Lib/inspect.py; returns True if object is a module; __class__ is the built-in function type; __class__.__qualname__ == 'function' (8 chars)"]

# ---------------------------------------------------------------------------
# inspect.signature __class__.__qualname__ — extra48 namespace
#
# inspect.signature is a pure-Python function defined in Lib/inspect.py.
# Its __class__.__qualname__ is 'function'. Prior spec extra47 recorded
# __class__.__name__ == 'function' for signature. This spec records
# __class__.__qualname__ == 'function'. New to extra48.
# ---------------------------------------------------------------------------

invariant inspect_extra48.signature_class_qualname:
  description: "inspect.signature.__class__.__qualname__ == 'function' — pure-Python function in Lib/inspect.py; primary public API for obtaining a Signature object; __class__ is the built-in function type; __class__.__qualname__ == __class__.__name__ == 'function' (8 chars)"
  category: identity
  kind: python_call_eq
  function: signature.__class__.__qualname__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# inspect class objects __class__.__qualname__ — extra48 namespace
#
# inspect.Parameter, Signature, BoundArguments, and FullArgSpec are class
# objects defined in Lib/inspect.py. Their __class__ is the built-in 'type'
# metaclass (FullArgSpec is a namedtuple, but namedtuples are created via
# type() so their metaclass is still 'type'). Since 'type' is a top-level
# built-in with no enclosing class scope, __class__.__qualname__ == 'type'
# (4 chars). Prior spec extra47 recorded __class__.__name__ == 'type' for
# Parameter and Signature but not BoundArguments or FullArgSpec. No prior
# spec recorded __class__.__qualname__ for any of these four. All four new
# to extra48.
# ---------------------------------------------------------------------------

table inspect_extra48.class_objects_metaclass_qualnames:
  description: "inspect Parameter/Signature/BoundArguments/FullArgSpec __class__.__qualname__ == 'type' — pure-Python class objects in Lib/inspect.py; __class__ is the built-in 'type' metaclass; __qualname__ == __name__ == 'type' for top-level built-in types; 4-char qualname"
  kind: python_call_eq
  category: identity
  id_prefix: inspclsobj48

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_class_qualname,
       Parameter.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "inspect.Parameter.__class__.__qualname__ == 'type' — pure-Python class in Lib/inspect.py; represents a parameter in a function signature with name, kind, default, and annotation; __class__ is the 'type' metaclass; __class__.__qualname__ == __class__.__name__ == 'type' (4 chars)"]
    - [Signature_class_qualname,
       Signature.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "inspect.Signature.__class__.__qualname__ == 'type' — pure-Python class in Lib/inspect.py; represents the signature of a callable with an ordered mapping of parameters and optional return annotation; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [BoundArguments_class_qualname,
       BoundArguments.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "inspect.BoundArguments.__class__.__qualname__ == 'type' — pure-Python class in Lib/inspect.py (not a namedtuple); represents the result of binding arguments to a Signature; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [FullArgSpec_class_qualname,
       FullArgSpec.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "inspect.FullArgSpec.__class__.__qualname__ == 'type' — namedtuple created via collections.namedtuple() in Lib/inspect.py; namedtuples are constructed by calling type() at runtime so their metaclass is the standard 'type'; __class__.__qualname__ == 'type' (4 chars)"]
