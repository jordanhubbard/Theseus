spec: gzip_extra
version: ">=3.8"
backend: python_module(gzip)

docs: https://docs.python.org/3/library/gzip.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gzip.html — Python gzip module documentation"
    - "RFC 1952 — GZIP file format specification version 4.3"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gzip.py"
    - "CPython source: internal implementation details"
  notes:
    - "This spec extends gzip.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "gzip.zspec.zsdl covers: compress/decompress roundtrips via pre-computed hex, compress output length checks, BadGzipFile error cases, BadGzipFile.__name__ class identity."
    - "BadGzipFile was added in Python 3.8 as a subclass of OSError."
    - "GzipFile is the primary class for reading/writing gzip-format files."
    - "gzip.open() is a function that wraps GzipFile for convenience, analogous to built-in open()."
    - "compress() and decompress() are module-level convenience functions; both return bytes."
    - "compress.__module__ == 'gzip' confirms the function is defined in the gzip module."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "gzip.decompress() raises gzip.BadGzipFile (subclass of OSError) on invalid input."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# GzipFile class identity
# ---------------------------------------------------------------------------

invariant gzip_extra.GzipFile.class_name:
  description: "GzipFile.__name__ == 'GzipFile'"
  category: class_names
  kind: python_call_eq
  function: GzipFile.__name__.__eq__
  args: ["GzipFile"]
  expected: true

invariant gzip_extra.GzipFile.module_name:
  description: "GzipFile.__module__ == 'gzip'"
  category: class_names
  kind: python_call_eq
  function: GzipFile.__module__.__eq__
  args: ["gzip"]
  expected: true

# ---------------------------------------------------------------------------
# BadGzipFile class identity (Python 3.8+)
# ---------------------------------------------------------------------------

invariant gzip_extra.BadGzipFile.module_name:
  description: "BadGzipFile.__module__ == 'gzip'"
  category: class_names
  kind: python_call_eq
  function: BadGzipFile.__module__.__eq__
  args: ["gzip"]
  expected: true

invariant gzip_extra.BadGzipFile.base_is_oserror:
  description: "BadGzipFile.__bases__[0].__name__ == 'OSError'"
  category: class_names
  kind: python_call_eq
  function: BadGzipFile.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# compress() function identity
# ---------------------------------------------------------------------------

invariant gzip_extra.compress.function_name:
  description: "compress.__name__ == 'compress'"
  category: function_names
  kind: python_call_eq
  function: compress.__name__.__eq__
  args: ["compress"]
  expected: true

invariant gzip_extra.compress.module_name:
  description: "compress.__module__ == 'gzip'"
  category: function_names
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["gzip"]
  expected: true

# ---------------------------------------------------------------------------
# decompress() function identity
# ---------------------------------------------------------------------------

invariant gzip_extra.decompress.function_name:
  description: "decompress.__name__ == 'decompress'"
  category: function_names
  kind: python_call_eq
  function: decompress.__name__.__eq__
  args: ["decompress"]
  expected: true

# ---------------------------------------------------------------------------
# open() function identity
# ---------------------------------------------------------------------------

invariant gzip_extra.open.function_name:
  description: "open.__name__ == 'open'"
  category: function_names
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# compress() return type
# ---------------------------------------------------------------------------

invariant gzip_extra.compress.returns_bytes:
  description: "compress(b'hello').__class__.__name__ == 'bytes' — compress always returns bytes"
  category: compress
  kind: python_call_eq
  function: compress
  args: [!ascii hello]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# decompress(compress(data)) == data roundtrip
# Expressed as two invariants: compress output is bytes, then decompress recovers original.
# Pre-computed hex for compress(b'hello', compresslevel=9): 1f8b08000000000002ffcb48cdc9c9070086a6103605000000
# ---------------------------------------------------------------------------

invariant gzip_extra.roundtrip.compress_output_is_bytes:
  description: "compress(b'hello') returns an object whose class is bytes"
  category: roundtrip
  kind: python_call_eq
  function: compress
  args: [!ascii hello]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant gzip_extra.roundtrip.decompress_recovers_hello:
  description: "decompress(compress(b'hello', compresslevel=9)) == b'hello' — roundtrip via pre-computed compressed bytes"
  category: roundtrip
  kind: python_call_eq
  function: decompress
  args: [{type: bytes_hex, value: "1f8b08000000000002ffcb48cdc9c9070086a6103605000000"}]
  method: __eq__
  method_args: [!ascii hello]
  expected: true
