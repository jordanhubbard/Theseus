spec: pathlib_extra292
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Path class methods and their qualified names"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "All Path methods checked via __qualname__ to confirm they are defined directly on Path (not inherited)"
    - "PurePath.__module__ is 'pathlib' confirming public module membership"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table pathlib_extra292.path_method_qualnames_a:
  description: "Path filesystem-mutation and IO method qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: pl292a

  columns: [id, function, args, expected, description]
  rows:
    - [pl292a001, pathlib.Path.stat.__qualname__, [], "Path.stat", "Path.stat qualname"]
    - [pl292a002, pathlib.Path.open.__qualname__, [], "Path.open", "Path.open qualname"]
    - [pl292a003, pathlib.Path.read_text.__qualname__, [], "Path.read_text", "Path.read_text qualname"]
    - [pl292a004, pathlib.Path.write_text.__qualname__, [], "Path.write_text", "Path.write_text qualname"]
    - [pl292a005, pathlib.Path.mkdir.__qualname__, [], "Path.mkdir", "Path.mkdir qualname"]
    - [pl292a006, pathlib.Path.unlink.__qualname__, [], "Path.unlink", "Path.unlink qualname"]
    - [pl292a007, pathlib.Path.rename.__qualname__, [], "Path.rename", "Path.rename qualname"]
    - [pl292a008, pathlib.Path.replace.__qualname__, [], "Path.replace", "Path.replace qualname"]

table pathlib_extra292.path_method_qualnames_b:
  description: "Path query and traversal method qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: pl292b

  columns: [id, function, args, expected, description]
  rows:
    - [pl292b001, pathlib.Path.is_file.__qualname__, [], "Path.is_file", "Path.is_file qualname"]
    - [pl292b002, pathlib.Path.is_dir.__qualname__, [], "Path.is_dir", "Path.is_dir qualname"]
    - [pl292b003, pathlib.Path.exists.__qualname__, [], "Path.exists", "Path.exists qualname"]
    - [pl292b004, pathlib.Path.glob.__qualname__, [], "Path.glob", "Path.glob qualname"]
    - [pl292b005, pathlib.Path.iterdir.__qualname__, [], "Path.iterdir", "Path.iterdir qualname"]
    - [pl292b006, pathlib.Path.chmod.__qualname__, [], "Path.chmod", "Path.chmod qualname"]
    - [pl292b007, pathlib.Path.symlink_to.__qualname__, [], "Path.symlink_to", "Path.symlink_to qualname"]

invariant pathlib_extra292.purepath_module:
  description: "pathlib.PurePath.__module__ is 'pathlib'"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra292.path_module:
  description: "pathlib.Path.__module__ is 'pathlib'"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra292.path_read_bytes_qualname:
  description: "Path.read_bytes qualname"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.read_bytes.__qualname__.__eq__
  args: ["Path.read_bytes"]
  expected: true

invariant pathlib_extra292.path_write_bytes_qualname:
  description: "Path.write_bytes qualname"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.write_bytes.__qualname__.__eq__
  args: ["Path.write_bytes"]
  expected: true

invariant pathlib_extra292.path_touch_qualname:
  description: "Path.touch qualname"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.touch.__qualname__.__eq__
  args: ["Path.touch"]
  expected: true
