spec: hast_util_to_html
version: ">=9.0.0"
backend: node(hast-util-to-html)

docs: https://github.com/syntax-tree/hast-util-to-html#readme

provenance:
  derived_from:
    - "hast-util-to-html README — https://github.com/syntax-tree/hast-util-to-html#readme"
    - "HAST (HTML Abstract Syntax Tree) specification — https://github.com/syntax-tree/hast"
    - "Test vectors verified with hast-util-to-html via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "hast-util-to-html source"
  notes:
    - "Convert a HAST tree to an HTML string — used by rehype-stringify."
    - "Install: npm install hast-util-to-html"
    - "v9 ESM only; named export toHtml(tree, options?)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on valid HAST trees."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant hast_util_to_html.text_node:
  description: "Text node serialises to its value"
  category: serialise
  kind: node_chain_eq
  entry: named
  function: toHtml
  entry_args: [{type: "text", value: "hello"}]
  chain: []
  expected: "hello"

invariant hast_util_to_html.text_escapes_html:
  description: "Text node containing < > & is escaped"
  category: serialise
  kind: node_chain_eq
  entry: named
  function: toHtml
  entry_args: [{type: "text", value: "<>&"}]
  chain: []
  expected: "&#x3C;>&#x26;"

invariant hast_util_to_html.simple_element:
  description: "Element with text child serialises with open/close tags"
  category: serialise
  kind: node_chain_eq
  entry: named
  function: toHtml
  entry_args: [{type: "element", tagName: "p", children: [{type: "text", value: "hello"}]}]
  chain: []
  expected: "<p>hello</p>"

invariant hast_util_to_html.element_with_property:
  description: "Element with href property serialises as attribute"
  category: serialise
  kind: node_chain_eq
  entry: named
  function: toHtml
  entry_args: [{type: "element", tagName: "a", properties: {href: "/foo"}, children: [{type: "text", value: "link"}]}]
  chain: []
  expected: "<a href=\"/foo\">link</a>"

invariant hast_util_to_html.empty_element:
  description: "Element with empty children list still has both open + close tags"
  category: serialise
  kind: node_chain_eq
  entry: named
  function: toHtml
  entry_args: [{type: "element", tagName: "div", children: []}]
  chain: []
  expected: "<div></div>"

invariant hast_util_to_html.void_element_self_closing:
  description: "Void element 'br' has no closing tag"
  category: serialise
  kind: node_chain_eq
  entry: named
  function: toHtml
  entry_args: [{type: "element", tagName: "br", children: []}]
  chain: []
  expected: "<br>"

invariant hast_util_to_html.nested_elements:
  description: "Nested elements compose correctly"
  category: serialise
  kind: node_chain_eq
  entry: named
  function: toHtml
  entry_args: [{type: "element", tagName: "div", children: [{type: "element", tagName: "p", children: [{type: "text", value: "hi"}]}]}]
  chain: []
  expected: "<div><p>hi</p></div>"

invariant hast_util_to_html.root_node_serialises_children:
  description: "Root node serialises just its children"
  category: serialise
  kind: node_chain_eq
  entry: named
  function: toHtml
  entry_args: [{type: "root", children: [{type: "text", value: "x"}]}]
  chain: []
  expected: "x"

invariant hast_util_to_html.comment_node:
  description: "Comment node becomes <!-- ... -->"
  category: serialise
  kind: node_chain_eq
  entry: named
  function: toHtml
  entry_args: [{type: "comment", value: "x"}]
  chain: []
  expected: "<!--x-->"
