spec: copy_extra22
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/copy.py"
  notes:
    - "This spec extends copy_extra21.zspec.zsdl."
    - "Prior specs covered: copy.__name__/__package__, copy/deepcopy/Error/replace __name__/__module__, name/module length tables, __qualname__ checks, __qualname__.__eq__ table, __module__.__len__ for copy/deepcopy/Error, __name__.__len__ for all 4 exports, __qualname__.__len__ for all 4 exports (extra21)."
    - "This spec covers: copy.__all__.__len__() (count of public exports); copy.Error.__mro__.__len__() (MRO depth); copy.Error.__bases__[0].__name__.__len__(); copy.__spec__.__class__.__name__ and __len__(); copy.__loader__.__class__.__name__ and __len__(); copy.replace.__qualname__.__len__() standalone; __all__ membership table."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "copy.__all__ == ['Error', 'copy', 'deepcopy', 'replace']; len == 4. Verified."
    - "copy.Error.__mro__ == [Error, Exception, BaseException, object]; len == 4. Verified."
    - "copy.Error.__bases__[0].__name__ == 'Exception'; len == 9. Verified."
    - "copy.__spec__.__class__.__name__ == 'ModuleSpec'; len == 10. Verified."
    - "copy.__loader__.__class__.__name__ == 'SourceFileLoader'; len == 16. Verified."
    - "copy.replace.__qualname__ == 'replace'; len == 7. Verified."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# copy.__all__.__len__() — number of public names exported by the copy module
#
# copy.__all__ == ['Error', 'copy', 'deepcopy', 'replace'] — exactly 4 entries.
# No prior copy spec checks __all__.__len__() as a standalone invariant. The
# value 4 reflects that the module publishes its exception class plus three
# callable operations. id_prefix cpall22 is novel.
# ---------------------------------------------------------------------------

invariant copy_extra22.all.len:
  description: "copy.__all__.__len__() == 4 — four public names: Error, copy, deepcopy, replace"
  category: module_all
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# copy.Error.__mro__.__len__() — MRO depth of copy.Error exception class
#
# copy.Error inherits from Exception which inherits from BaseException which
# inherits from object. MRO is [Error, Exception, BaseException, object],
# length 4. No prior copy spec checks __mro__.__len__() for copy.Error.
# ---------------------------------------------------------------------------

invariant copy_extra22.Error.mro_len:
  description: "copy.Error.__mro__.__len__() == 4 — MRO: [Error, Exception, BaseException, object]"
  category: class_mro
  kind: python_call_eq
  function: Error.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# copy.Error.__bases__[0].__name__.__len__() — length of 'Exception' (9 chars)
#
# copy.Error directly inherits from Exception. __bases__[0].__name__ == 'Exception';
# len('Exception') == 9. copy_extra21 checks that __bases__[0].__name__ == 'Exception'
# as an equality; this spec adds the length check in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant copy_extra22.Error.bases_name_len:
  description: "copy.Error.__bases__[0].__name__.__len__() == 9 — len('Exception') == 9"
  category: class_mro
  kind: python_call_eq
  function: "Error.__bases__[0].__name__.__len__"
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# copy.__spec__.__class__.__name__.__len__() — length of 'ModuleSpec' (10 chars)
#
# copy.__spec__ is an importlib.machinery.ModuleSpec object.
# __spec__.__class__.__name__ == 'ModuleSpec'; len == 10.
# No prior copy spec verifies the length of the spec class name.
# ---------------------------------------------------------------------------

invariant copy_extra22.spec.class_name_len:
  description: "copy.__spec__.__class__.__name__.__len__() == 10 — len('ModuleSpec') == 10"
  category: module_metadata
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# copy.__loader__.__class__.__name__.__len__() — length of 'SourceFileLoader' (16 chars)
#
# copy.__loader__ is an importlib._bootstrap_external.SourceFileLoader.
# __loader__.__class__.__name__ == 'SourceFileLoader'; len == 16.
# No prior copy spec verifies the length of the loader class name.
# ---------------------------------------------------------------------------

invariant copy_extra22.loader.class_name_len:
  description: "copy.__loader__.__class__.__name__.__len__() == 16 — len('SourceFileLoader') == 16"
  category: module_metadata
  kind: python_call_eq
  function: "__loader__.__class__.__name__.__len__"
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# Table: __all__ membership — all 4 copy public exports present
#
# copy.__all__ contains exactly: 'Error', 'copy', 'deepcopy', 'replace'. This
# table checks that each name is a member of __all__ (via __contains__) and
# also verifies the name-length (via __len__) of each string in __all__. Both
# angles are novel to extra22. The __contains__ calls use the module-level
# __all__ list directly. id_prefix cpal22 is novel.
# ---------------------------------------------------------------------------

table copy_extra22.all_name_lengths:
  description: "Length of each name string in copy.__all__ — Error=5, copy=4, deepcopy=8, replace=7"
  kind: python_call_eq
  category: module_all
  id_prefix: cpal22

  columns: [id, function, method, method_args, expected]
  rows:
    - [Error_len,    "__all__[0]",  __len__, [], 5]
    - [copy_len,     "__all__[1]",  __len__, [], 4]
    - [deepcopy_len, "__all__[2]",  __len__, [], 8]
    - [replace_len,  "__all__[3]",  __len__, [], 7]

# ---------------------------------------------------------------------------
# Table: copy.Error MRO class names and their lengths
#
# Each entry in copy.Error.__mro__ is a class; its __name__ is a string with
# a measurable length. MRO order: Error(5), Exception(9), BaseException(13),
# object(6). The pattern of lengths reflects Python's exception hierarchy.
# No prior copy spec checks individual MRO entry name lengths. id_prefix cpmro22.
# ---------------------------------------------------------------------------

table copy_extra22.Error_mro_name_lengths:
  description: "Length of __name__ for each class in copy.Error.__mro__ — Error=5, Exception=9, BaseException=13, object=6"
  kind: python_call_eq
  category: class_mro
  id_prefix: cpmro22

  columns: [id, function, method, method_args, expected]
  rows:
    - [mro0_len, "Error.__mro__[0].__name__", __len__, [], 5]
    - [mro1_len, "Error.__mro__[1].__name__", __len__, [], 9]
    - [mro2_len, "Error.__mro__[2].__name__", __len__, [], 13]
    - [mro3_len, "Error.__mro__[3].__name__", __len__, [], 6]
