spec: bisect_extra22
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
    - "bisect_extra21.zspec.zsdl — covers __spec__.name; __loader__.__class__.__name__; __spec__.__class__.__name__; standalone __module__.__eq__ for all 6 callables in extra21 namespace."
    - "bisect_extra20.zspec.zsdl — covers __name__.__len__() and __package__.__len__() at module level; __module__.__len__() for alias and all 6 callables."
    - "bisect_extra19.zspec.zsdl — covers __text_signature__.__len__() for all 6 callables."
    - "bisect_extra18.zspec.zsdl — covers __qualname__.__eq__ standalone for all 4 core functions and unified table for all 6."
  notes:
    - "This spec extends bisect.zspec.zsdl through bisect_extra21.zspec.zsdl."
    - "Prior specs cover: __qualname__/__qualname__.__len__/__module__/__module__.__len__ for all 6 callables; __spec__/__loader__ metadata; __name__/__package__; __text_signature__."
    - "NOT yet covered: __name__.__eq__ for each callable in extra22 namespace; __name__.__len__() for each callable in extra22 namespace (novel length values); bisect.__doc__.__class__.__name__."
    - "Focus: __name__.__eq__ table for all 6 bisect callables (noting aliases); __name__.__len__() table; bisect.__doc__.__class__.__name__."
    - "bisect.bisect_left.__name__ == 'bisect_left'; len = 11. Verified Python 3.14.3 macOS."
    - "bisect.bisect_right.__name__ == 'bisect_right'; len = 12. Verified."
    - "bisect.insort_left.__name__ == 'insort_left'; len = 11. Verified."
    - "bisect.insort_right.__name__ == 'insort_right'; len = 12. Verified."
    - "bisect.bisect.__name__ == 'bisect_right' (alias of bisect_right); len = 12. Verified."
    - "bisect.insort.__name__ == 'insort_right' (alias of insort_right); len = 12. Verified."
    - "bisect.__doc__.__class__.__name__ == 'str' — module docstring is a str object. Verified."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__eq__ for all 6 bisect callables — extra22 namespace
#
# Prior specs cover __name__.__eq__ in earlier namespace anchors, __qualname__,
# and __module__. This table provides __name__.__eq__ coverage in the extra22
# namespace. A key observation: bisect.bisect and bisect.insort are aliases for
# bisect_right and insort_right respectively; their __name__ reflects the
# underlying function name, not the alias name. id_prefix bsname22 is novel.
# ---------------------------------------------------------------------------

table bisect_extra22.function_names:
  description: "__name__.__eq__ for all 6 bisect callables — aliases reveal underlying function names"
  kind: python_call_eq
  category: function_name
  id_prefix: bsname22

  columns: [id, function, args, expected]
  rows:
    - [bisect_left,  bisect_left.__name__.__eq__,  ["bisect_left"],  true]
    - [bisect_right, bisect_right.__name__.__eq__, ["bisect_right"], true]
    - [insort_left,  insort_left.__name__.__eq__,  ["insort_left"],  true]
    - [insort_right, insort_right.__name__.__eq__, ["insort_right"], true]
    - [bisect_alias, bisect.__name__.__eq__,       ["bisect_right"], true]
    - [insort_alias, insort.__name__.__eq__,       ["insort_right"], true]

# ---------------------------------------------------------------------------
# __name__.__len__() for all 6 bisect callables
#
# No prior bisect spec checks __name__.__len__() for individual callables.
# bisect_extra20 checks __name__.__len__ at the module level only.
# The 4 core functions: bisect_left(11), bisect_right(12), insort_left(11),
# insort_right(12). The aliases bisect and insort resolve to bisect_right(12)
# and insort_right(12) respectively. id_prefix bsnlen22 is novel.
# ---------------------------------------------------------------------------

table bisect_extra22.function_name_lengths:
  description: "__name__.__len__() for all 6 bisect callables — aliases have len of underlying function"
  kind: python_call_eq
  category: function_name
  id_prefix: bsnlen22

  columns: [id, function, args, expected]
  rows:
    - [bisect_left,  bisect_left.__name__.__len__,  [], 11]
    - [bisect_right, bisect_right.__name__.__len__, [], 12]
    - [insort_left,  insort_left.__name__.__len__,  [], 11]
    - [insort_right, insort_right.__name__.__len__, [], 12]
    - [bisect_alias, bisect.__name__.__len__,       [], 12]
    - [insort_alias, insort.__name__.__len__,       [], 12]

# ---------------------------------------------------------------------------
# bisect.__doc__.__class__.__name__ — module docstring type identity
#
# No prior bisect spec checks the type of bisect.__doc__. The module docstring
# is a Python str object: __class__.__name__ == 'str'. This confirms the
# docstring exists (is not None) and is a string. Under python_module(bisect),
# __doc__.__class__.__name__.__eq__ accesses the docstring's class name on
# the bisect module object.
# ---------------------------------------------------------------------------

invariant bisect_extra22.doc.class_name:
  description: "bisect.__doc__.__class__.__name__ == 'str' — module docstring is a str object"
  category: module_identity
  kind: python_call_eq
  function: "__doc__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true
