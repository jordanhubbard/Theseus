spec: uuid_extra97
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__/__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length (table + invariants)."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__.__eq__ and __name__.__len__()==8 / SafeUUID.__bases__[0].__name__=='Enum' / UUID.hex/bytes/urn/fields/variant/version fget.__qualname__.__len__() (table + invariants)."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 / UUID.__setattr__.__class__.__name__=='function' / uuid3/uuid5/getnode __qualname__.__len__() / SafeUUID metaclass/module/MRO depth (table + invariants)."
    - "uuid_extra93.zspec.zsdl — covers uuid module name/spec/loader lengths / UUID/__module__/__len__()==4 / uuid1/uuid4/__module__/__len__()==4 (table + invariants)."
    - "uuid_extra92.zspec.zsdl — covers UUID property fget.__code__.co_name equality and co_argcount==1 and co_name lengths (table + invariants)."
    - "uuid_extra91.zspec.zsdl — covers UUID.__init__/__str__/__repr__/__eq__/__hash__/__lt__/__int__ __qualname__.__len__() / uuid1/uuid4 __qualname__.__len__() (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra96; it does NOT duplicate invariants present in those files."
    - "Wave 267 theme: UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant properties."
    - "uuid.UUID.hex.fget.__qualname__ == 'UUID.hex' (len 8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__qualname__ == 'UUID.bytes' (len 10). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le.fget.__qualname__ == 'UUID.bytes_le' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__qualname__ == 'UUID.fields' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.fget.__qualname__ == 'UUID.node' (len 9). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__qualname__ == 'UUID.time' (len 9). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq.fget.__qualname__ == 'UUID.clock_seq' (len 14). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__qualname__ == 'UUID.version' (len 12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__qualname__ == 'UUID.variant' (len 12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq_hi_variant.fget.__qualname__ == 'UUID.clock_seq_hi_variant' (len 25). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq_low.fget.__qualname__ == 'UUID.clock_seq_low' (len 18). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_hi_version.fget.__qualname__ == 'UUID.time_hi_version' (len 20). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid_extra95 anchors fget.__qualname__.__len__() for hex/bytes/urn/fields/variant/version; this spec anchors fget.__qualname__ string equality for a broader set of properties."
    - "Note: uuid.UUID.int and uuid.UUID.is_safe are member_descriptor (not property), so they have no fget attribute. All other UUID attributes in __slots__ that behave as properties do have fget.__qualname__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__qualname__.__eq__('UUID.hex')
# uuid.UUID.bytes.fget.__qualname__.__eq__('UUID.bytes')
# uuid.UUID.bytes_le.fget.__qualname__.__eq__('UUID.bytes_le')
# uuid.UUID.fields.fget.__qualname__.__eq__('UUID.fields')
# uuid.UUID.node.fget.__qualname__.__eq__('UUID.node')
#
# Wave 267 theme: UUID property fget qualname string equality (first group).
#
# UUID properties are defined in Lib/uuid.py using the @property decorator.
# Each property's fget function has __qualname__ == 'UUID.<property_name>'.
# uuid_extra95 anchors __qualname__.__len__() for hex(8)/bytes(10)/fields(11)/
# variant(12)/version(12); no prior uuid spec anchors fget.__qualname__ string
# *equality* as a grouped table under uuidprop97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra97.UUID_property_fget_qualname_eq_group1:
  description: "UUID.hex.fget.__qualname__.__eq__('UUID.hex')==True / UUID.bytes.fget.__qualname__.__eq__('UUID.bytes')==True / UUID.bytes_le.fget.__qualname__.__eq__('UUID.bytes_le')==True / UUID.fields.fget.__qualname__.__eq__('UUID.fields')==True / UUID.node.fget.__qualname__.__eq__('UUID.node')==True — all UUID properties have fget.__qualname__ == 'UUID.<name>'; extra95 anchors __len__() values; first uuidprop97 anchor for fget qualname string equality"
  kind: python_call_eq
  category: qualname_equality
  id_prefix: uuidprop97

  columns: [id, function, args, expected, description]
  rows:
    - [hex_fget_qname_eq,     "UUID.hex.fget.__qualname__.__eq__",     ["UUID.hex"],     true, "UUID.hex.fget.__qualname__ is 'UUID.hex' (len 8)"]
    - [bytes_fget_qname_eq,   "UUID.bytes.fget.__qualname__.__eq__",   ["UUID.bytes"],   true, "UUID.bytes.fget.__qualname__ is 'UUID.bytes' (len 10)"]
    - [bytes_le_fget_qname_eq, "UUID.bytes_le.fget.__qualname__.__eq__", ["UUID.bytes_le"], true, "UUID.bytes_le.fget.__qualname__ is 'UUID.bytes_le' (len 13)"]
    - [fields_fget_qname_eq,  "UUID.fields.fget.__qualname__.__eq__",  ["UUID.fields"],  true, "UUID.fields.fget.__qualname__ is 'UUID.fields' (len 11)"]
    - [node_fget_qname_eq,    "UUID.node.fget.__qualname__.__eq__",    ["UUID.node"],    true, "UUID.node.fget.__qualname__ is 'UUID.node' (len 9)"]

# ---------------------------------------------------------------------------
# uuid.UUID.time.fget.__qualname__.__eq__('UUID.time')
# uuid.UUID.clock_seq.fget.__qualname__.__eq__('UUID.clock_seq')
# uuid.UUID.version.fget.__qualname__.__eq__('UUID.version')
# uuid.UUID.variant.fget.__qualname__.__eq__('UUID.variant')
# uuid.UUID.clock_seq_hi_variant.fget.__qualname__.__eq__('UUID.clock_seq_hi_variant')
#
# Wave 267 theme: UUID property fget qualname string equality (second group).
#
# The time-related and variant/version UUID properties also have fget.__qualname__
# matching 'UUID.<name>'. clock_seq_hi_variant is the longest UUID property name
# at 25 chars ('UUID.clock_seq_hi_variant'). version and variant share len 12.
# uuid_extra95 anchors variant and version __len__() but not string equality;
# no prior uuid spec anchors time/clock_seq/version/variant/clock_seq_hi_variant
# fget qualname equality as a group under uuidprop97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra97.UUID_property_fget_qualname_eq_group2:
  description: "UUID.time.fget.__qualname__.__eq__('UUID.time')==True / UUID.clock_seq.fget.__qualname__.__eq__('UUID.clock_seq')==True / UUID.version.fget.__qualname__.__eq__('UUID.version')==True / UUID.variant.fget.__qualname__.__eq__('UUID.variant')==True / UUID.clock_seq_hi_variant.fget.__qualname__.__eq__('UUID.clock_seq_hi_variant')==True — version==variant==12 chars; clock_seq_hi_variant is longest UUID property qualname at 25 chars; extra95 anchors __len__() for version/variant; first uuidprop97 anchor for this group"
  kind: python_call_eq
  category: qualname_equality
  id_prefix: uuidprop97

  columns: [id, function, args, expected, description]
  rows:
    - [time_fget_qname_eq,     "UUID.time.fget.__qualname__.__eq__",     ["UUID.time"],     true, "UUID.time.fget.__qualname__ is 'UUID.time' (len 9)"]
    - [clock_seq_fget_qname_eq, "UUID.clock_seq.fget.__qualname__.__eq__", ["UUID.clock_seq"], true, "UUID.clock_seq.fget.__qualname__ is 'UUID.clock_seq' (len 14)"]
    - [version_fget_qname_eq,  "UUID.version.fget.__qualname__.__eq__",  ["UUID.version"],  true, "UUID.version.fget.__qualname__ is 'UUID.version' (len 12)"]
    - [variant_fget_qname_eq,  "UUID.variant.fget.__qualname__.__eq__",  ["UUID.variant"],  true, "UUID.variant.fget.__qualname__ is 'UUID.variant' (len 12)"]
    - [cshv_fget_qname_eq,     "UUID.clock_seq_hi_variant.fget.__qualname__.__eq__", ["UUID.clock_seq_hi_variant"], true, "UUID.clock_seq_hi_variant.fget.__qualname__ is 'UUID.clock_seq_hi_variant' (len 25; longest UUID property qualname)"]

# ---------------------------------------------------------------------------
# uuid.UUID.time_hi_version.fget.__qualname__.__len__()==20
# uuid.UUID.clock_seq_low.fget.__qualname__.__len__()==18
# uuid.UUID.clock_seq_hi_variant.fget.__qualname__.__len__()==25
# type(uuid.UUID.hex).__name__.__eq__('property')
# type(uuid.UUID.node).__name__.__eq__('property')
#
# Wave 267 theme: UUID property fget qualname lengths for RFC-field properties.
#
# The RFC 4122 field-level UUID properties (time_hi_version, clock_seq_low,
# clock_seq_hi_variant) have longer qualnames reflecting their names:
# time_hi_version=20, clock_seq_low=18, clock_seq_hi_variant=25. uuid.UUID.hex
# and uuid.UUID.node are both property objects (type().__name__=='property').
# uuid_extra95 anchors some property fget __len__() values but not
# time_hi_version/clock_seq_low/clock_seq_hi_variant lengths, and not
# type(UUID.hex).__name__ equality, as a group under uuidprop97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra97.UUID_rfc_field_property_qualname_lens:
  description: "UUID.time_hi_version.fget.__qualname__.__len__()==20 / UUID.clock_seq_low.fget.__qualname__.__len__()==18 / UUID.clock_seq_hi_variant.fget.__qualname__.__len__()==25 / type(UUID.hex).__name__.__eq__('property')==True / type(UUID.node).__name__.__eq__('property')==True — RFC 4122 field properties have longer qualname lengths; clock_seq_hi_variant is the longest UUID property qualname at 25; UUID.hex and UUID.node are property type; extra95 anchors other len() values; first uuidprop97 anchor for RFC field property lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: uuidprop97

  columns: [id, function, args, expected, description]
  rows:
    - [time_hi_ver_qlen,   "UUID.time_hi_version.fget.__qualname__.__len__",     [], 20, "'UUID.time_hi_version' is 20 chars ('UUID.' 5 + 'time_hi_version' 15)"]
    - [clock_seq_low_qlen, "UUID.clock_seq_low.fget.__qualname__.__len__",        [], 18, "'UUID.clock_seq_low' is 18 chars ('UUID.' 5 + 'clock_seq_low' 13)"]
    - [cshv_qlen,          "UUID.clock_seq_hi_variant.fget.__qualname__.__len__", [], 25, "'UUID.clock_seq_hi_variant' is 25 chars ('UUID.' 5 + 'clock_seq_hi_variant' 20); longest UUID property qualname"]
    - [hex_prop_type,      "UUID.hex.__class__.__name__.__eq__",                 ["property"], true, "UUID.hex is a property object (type.__name__=='property')"]
    - [node_prop_type,     "UUID.node.__class__.__name__.__eq__",                ["property"], true, "UUID.node is a property object (type.__name__=='property')"]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__qualname__.__eq__('UUID.hex') — standalone
#
# uuid.UUID.hex.fget.__qualname__ is 'UUID.hex'. The hex property returns
# the UUID as a 32-character lowercase hexadecimal string with no hyphens.
# It is defined in Lib/uuid.py with @property. Its fget function has
# __qualname__ == 'UUID.hex' (8 chars = 'UUID.' 5 + 'hex' 3). uuid_extra95
# anchors UUID.hex.fget.__qualname__.__len__()==8 at table level; no prior
# uuid spec anchors the string equality as a standalone under uuidprop97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra97.UUID_hex_fget_qualname_eq:
  description: "uuid.UUID.hex.fget.__qualname__.__eq__('UUID.hex') == True — hex property returns 32-char lowercase hex string without hyphens; fget qualname is 'UUID.hex' (8 chars = 'UUID.' 5 + 'hex' 3); extra95 anchors __len__()==8 at table level; first standalone for UUID.hex fget qualname equality under uuidprop97"
  category: qualname_equality
  kind: python_call_eq
  function: UUID.hex.fget.__qualname__.__eq__
  args: ["UUID.hex"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.clock_seq.fget.__qualname__.__eq__('UUID.clock_seq') — standalone
#
# uuid.UUID.clock_seq.fget.__qualname__ is 'UUID.clock_seq' (14 chars =
# 'UUID.' 5 + 'clock_seq' 9). The clock_seq property returns the 14-bit
# clock sequence used to maintain temporal uniqueness for uuid1. Unlike
# clock_seq_hi_variant and clock_seq_low (which expose raw RFC 4122 fields),
# clock_seq combines both to give the full clock sequence value. No prior
# uuid spec anchors UUID.clock_seq fget qualname equality as a standalone
# under uuidprop97. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra97.UUID_clock_seq_fget_qualname_eq:
  description: "uuid.UUID.clock_seq.fget.__qualname__.__eq__('UUID.clock_seq') == True — clock_seq property returns 14-bit clock sequence for uuid1 temporal uniqueness; combines clock_seq_hi_variant and clock_seq_low fields; fget qualname is 'UUID.clock_seq' (14 chars); no prior uuid spec anchors this as standalone; first standalone under uuidprop97"
  category: qualname_equality
  kind: python_call_eq
  function: UUID.clock_seq.fget.__qualname__.__eq__
  args: ["UUID.clock_seq"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.version.fget.__qualname__.__eq__('UUID.version') — standalone
#
# uuid.UUID.version.fget.__qualname__ is 'UUID.version' (12 chars =
# 'UUID.' 5 + 'version' 7). The version property returns the UUID version
# number (1-5) if the UUID has the RFC 4122 variant; it raises ValueError
# if the UUID has no version (e.g., for non-RFC 4122 UUIDs). version and
# variant share the same qualname length of 12 chars. uuid_extra95 anchors
# UUID.version.fget.__qualname__.__len__()==12 at table level; no prior
# uuid spec anchors the string equality as a standalone under uuidprop97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra97.UUID_version_fget_qualname_eq:
  description: "uuid.UUID.version.fget.__qualname__.__eq__('UUID.version') == True — version property returns UUID version 1-5 for RFC 4122 variant; raises ValueError for non-RFC 4122 UUIDs; qualname 'UUID.version' is 12 chars (same length as UUID.variant); extra95 anchors __len__()==12; first standalone for UUID.version fget qualname equality under uuidprop97"
  category: qualname_equality
  kind: python_call_eq
  function: UUID.version.fget.__qualname__.__eq__
  args: ["UUID.version"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.node.fget.__qualname__.__eq__('UUID.node') — standalone
#
# uuid.UUID.node.fget.__qualname__ is 'UUID.node' (9 chars = 'UUID.' 5 +
# 'node' 4). The node property returns the last 48 bits of the UUID as a
# 48-bit hardware address (used by uuid1). In uuid1 this represents the
# MAC address or a random node identifier. node and time share the same
# fget qualname length of 9 chars. No prior uuid spec anchors UUID.node
# fget qualname equality as a standalone under uuidprop97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra97.UUID_node_fget_qualname_eq:
  description: "uuid.UUID.node.fget.__qualname__.__eq__('UUID.node') == True — node property returns 48-bit hardware address from uuid1 (MAC address or random node); fget qualname 'UUID.node' is 9 chars; same length as UUID.time fget qualname; no prior uuid spec anchors UUID.node fget qualname equality as standalone; first standalone under uuidprop97"
  category: qualname_equality
  kind: python_call_eq
  function: UUID.node.fget.__qualname__.__eq__
  args: ["UUID.node"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.clock_seq_hi_variant.fget.__qualname__.__len__()==25 — standalone
#
# uuid.UUID.clock_seq_hi_variant.fget.__qualname__.__len__() is 25.
# 'UUID.clock_seq_hi_variant' = 'UUID.' (5) + 'clock_seq_hi_variant' (20).
# This is the longest fget qualname among all UUID properties. The
# clock_seq_hi_variant property exposes the raw RFC 4122 field combining the
# clock sequence high bits and the variant bits. It has 20 chars in the
# property name itself. No prior uuid spec anchors UUID.clock_seq_hi_variant
# fget qualname length as a standalone under uuidprop97.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra97.UUID_clock_seq_hi_variant_fget_qlen_25:
  description: "uuid.UUID.clock_seq_hi_variant.fget.__qualname__.__len__() == 25 — 'UUID.clock_seq_hi_variant' is 25 chars ('UUID.' 5 + 'clock_seq_hi_variant' 20); longest fget qualname among all UUID properties; clock_seq_hi_variant exposes raw RFC 4122 high clock bits and variant; no prior uuid spec anchors this length as standalone; first standalone under uuidprop97"
  category: qualname_lengths
  kind: python_call_eq
  function: UUID.clock_seq_hi_variant.fget.__qualname__.__len__
  args: []
  expected: 25
