spec: io_extra18
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl through io_extra17.zspec.zsdl."
    - "io_extra17 covers __qualname__ for StringIO/BytesIO methods and IOBase methods."
    - "No prior io spec covers io.StringIO.__mro__[1].__name__ or io.BytesIO.__mro__[1].__name__."
    - "No prior io spec covers io.IOBase.__name__, io.RawIOBase.__name__, io.BufferedIOBase.__name__, io.TextIOBase.__name__."
    - "No prior io spec covers io.SEEK_SET, io.SEEK_CUR, io.SEEK_END constants."
    - "No prior io spec covers io.DEFAULT_BUFFER_SIZE."
    - "No prior io spec covers io.StringIO.__mro__ length or io.BytesIO.__mro__ length."
    - "io.StringIO.__mro__[1].__name__ == '_TextIOBase' — the C implementation uses _TextIOBase internally."
    - "io.BytesIO.__mro__[1].__name__ == '_BufferedIOBase' — the C implementation uses _BufferedIOBase internally."
    - "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB) on macOS; the documented default is 8192 but the actual platform value may differ."
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2 — standard POSIX seek origin constants."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.StringIO and io.BytesIO — MRO position 1 __name__
#
# No prior io spec covers __mro__[1].__name__ for StringIO or BytesIO.
# The C implementation exposes internal base classes _TextIOBase and
# _BufferedIOBase at MRO position 1 (the immediate C-level parent).
# ---------------------------------------------------------------------------

invariant io_extra18.StringIO.mro1_name:
  description: "io.StringIO.__mro__[1].__name__ == '_TextIOBase' — immediate C base class of StringIO"
  category: mro_names
  kind: python_call_eq
  function: StringIO.__mro__.__getitem__
  args: [1]
  method: __name__
  method_args: []
  expected: "_TextIOBase"

invariant io_extra18.BytesIO.mro1_name:
  description: "io.BytesIO.__mro__[1].__name__ == '_BufferedIOBase' — immediate C base class of BytesIO"
  category: mro_names
  kind: python_call_eq
  function: BytesIO.__mro__.__getitem__
  args: [1]
  method: __name__
  method_args: []
  expected: "_BufferedIOBase"

# ---------------------------------------------------------------------------
# io.StringIO and io.BytesIO — MRO length
#
# No prior io spec covers __mro__ length for StringIO or BytesIO.
# StringIO MRO: [StringIO, _TextIOBase, _IOBase, object] — length 4.
# BytesIO MRO:  [BytesIO, _BufferedIOBase, _IOBase, object] — length 4.
# ---------------------------------------------------------------------------

invariant io_extra18.StringIO.mro_length:
  description: "len(io.StringIO.__mro__) == 4 — [StringIO, _TextIOBase, _IOBase, object]"
  category: mro_lengths
  kind: python_call_eq
  function: StringIO.__mro__.__len__
  args: []
  expected: 4

invariant io_extra18.BytesIO.mro_length:
  description: "len(io.BytesIO.__mro__) == 4 — [BytesIO, _BufferedIOBase, _IOBase, object]"
  category: mro_lengths
  kind: python_call_eq
  function: BytesIO.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# io abstract base class __name__ attributes
#
# No prior io spec covers __name__ for IOBase, RawIOBase, BufferedIOBase,
# or TextIOBase as top-level module attributes. These are the public names
# under which the C-level _IOBase, _RawIOBase, _BufferedIOBase, _TextIOBase
# types are exposed in the io module.
# ---------------------------------------------------------------------------

invariant io_extra18.IOBase.name:
  description: "io.IOBase.__name__ == 'IOBase' — public name of the C-level _IOBase type"
  category: class_names
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true

invariant io_extra18.RawIOBase.name:
  description: "io.RawIOBase.__name__ == 'RawIOBase' — public name of the C-level _RawIOBase type"
  category: class_names
  kind: python_call_eq
  function: RawIOBase.__name__.__eq__
  args: ["RawIOBase"]
  expected: true

invariant io_extra18.BufferedIOBase.name:
  description: "io.BufferedIOBase.__name__ == 'BufferedIOBase' — public name of the C-level _BufferedIOBase type"
  category: class_names
  kind: python_call_eq
  function: BufferedIOBase.__name__.__eq__
  args: ["BufferedIOBase"]
  expected: true

invariant io_extra18.TextIOBase.name:
  description: "io.TextIOBase.__name__ == 'TextIOBase' — public name of the C-level _TextIOBase type"
  category: class_names
  kind: python_call_eq
  function: TextIOBase.__name__.__eq__
  args: ["TextIOBase"]
  expected: true

# ---------------------------------------------------------------------------
# io.SEEK_SET, io.SEEK_CUR, io.SEEK_END — POSIX seek origin constants
#
# No prior io spec covers the SEEK_* constants. These are module-level int
# constants that mirror the POSIX lseek(2) whence values: 0=set, 1=cur, 2=end.
# ---------------------------------------------------------------------------

invariant io_extra18.SEEK_SET:
  description: "io.SEEK_SET == 0 — seek from beginning of stream (POSIX whence 0)"
  category: constants
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra18.SEEK_CUR:
  description: "io.SEEK_CUR == 1 — seek from current stream position (POSIX whence 1)"
  category: constants
  kind: python_call_eq
  function: SEEK_CUR.__eq__
  args: [1]
  expected: true

invariant io_extra18.SEEK_END:
  description: "io.SEEK_END == 2 — seek from end of stream (POSIX whence 2)"
  category: constants
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE — type check
#
# No prior io spec covers DEFAULT_BUFFER_SIZE. Its type is always int;
# the exact value is platform-dependent (131072 on macOS, 8192 on some others).
# We check the type rather than the exact value for portability.
# ---------------------------------------------------------------------------

invariant io_extra18.DEFAULT_BUFFER_SIZE.is_int:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — buffer size constant is always an int"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra18.DEFAULT_BUFFER_SIZE.positive:
  description: "io.DEFAULT_BUFFER_SIZE > 0 — buffer size is always a positive integer"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__gt__
  args: [0]
  expected: true
