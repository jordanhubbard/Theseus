spec: re_extra123
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec extends re_extra122.zspec.zsdl."
    - "This spec covers: re module __spec__ and __loader__ deep attribute chains not yet covered."
    - "re_extra62 covered: __spec__.__class__.__name__=='ModuleSpec'(10); __spec__.name=='re'(2); __spec__.name.__len__()==2; __loader__.__class__.__name__=='SourceFileLoader'; __loader__.__class__.__name__.__len__()==16; __spec__.origin.__class__.__name__=='str'; __spec__.submodule_search_locations.__class__.__name__=='list'; __spec__.has_location==True; __spec__.__class__.__name__.__len__()==10."
    - "NOT yet covered: __loader__.__class__.__module__=='_frozen_importlib_external'(26); __spec__.submodule_search_locations.__len__()==1; __loader__.__class__.__module__.__len__()==26."
    - "re.__loader__.__class__.__module__ == '_frozen_importlib_external' (len 26) — SourceFileLoader is defined in the frozen importlib external bootstrap module."
    - "re.__loader__.__class__.__module__.__len__() == 26 — '_frozen_importlib_external' has 26 characters."
    - "re.__spec__.submodule_search_locations.__len__() == 1 — re is a package with exactly one search path (the re/ directory)."
    - "re.__spec__.name.__eq__('re') already covered; re.__spec__.name.__class__.__name__=='str' is novel."
    - "re.__spec__.__class__.__module__ — ModuleSpec is defined in '_frozen_importlib'; __class__.__module__.__len__() == 17."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.__loader__.__class__.__module__ == '_frozen_importlib_external'
# The SourceFileLoader class is defined in the frozen importlib external module.
# '_frozen_importlib_external' has 26 characters.
# re_extra62 covered __loader__.__class__.__name__=='SourceFileLoader'(16).
# NO prior spec asserts __loader__.__class__.__module__ for re.
# _frozen_importlib_external is the frozen form of importlib._bootstrap_external.
# ---------------------------------------------------------------------------

table re_extra123.loader_class_module_assertions:
  description: "re.__loader__.__class__.__module__=='_frozen_importlib_external'(26); __len__()==26; SourceFileLoader defined in frozen importlib external; all assertions novel; re_extra62 covered __loader__.__class__.__name__ but not __module__"
  kind: python_call_eq
  category: module_identity
  id_prefix: reloadermod123a

  columns: [id, function, args, expected, description]
  rows:
    - [loader_mod_eq,     "__loader__.__class__.__module__.__eq__",     ["_frozen_importlib_external"],  true,  "re.__loader__.__class__.__module__ == '_frozen_importlib_external' (SourceFileLoader is defined in the frozen bootstrap external module; it handles loading of Python source files from the filesystem)"]
    - [loader_mod_len,    "__loader__.__class__.__module__.__len__",    [],                              26,    "re.__loader__.__class__.__module__.__len__() == 26 ('_frozen_importlib_external' has 26 characters: '_frozen_importlib_external' is the frozen form of importlib._bootstrap_external)"]
    - [loader_mod_ne_cls, "__loader__.__class__.__module__.__eq__",     ["_frozen_importlib"],           false, "re.__loader__.__class__.__module__ != '_frozen_importlib' (it is '_frozen_importlib_external'; the external bootstrap handles file-based loaders while the inner bootstrap handles core importlib machinery)"]
    - [loader_mod_class,  "__loader__.__class__.__module__.__class__.__name__.__eq__", ["str"],         true,  "type(re.__loader__.__class__.__module__).__name__ == 'str' (the module name attribute is always a plain Python string)"]
    - [loader_mod_startswith, "__loader__.__class__.__module__.__contains__", ["_frozen_importlib"],    true,  "re.__loader__.__class__.__module__.__contains__('_frozen_importlib') == True ('_frozen_importlib_external' contains the prefix '_frozen_importlib'; it is the external half of the frozen importlib bootstrap)"]
    - [loader_mod_has_ext, "__loader__.__class__.__module__.__contains__", ["external"],                true,  "re.__loader__.__class__.__module__.__contains__('external') == True ('_frozen_importlib_external' ends with 'external'; distinguishes it from '_frozen_importlib' which lacks the '_external' suffix)"]
    - [loader_mod_gt_cls_name, "__loader__.__class__.__module__.__len__.__gt__", [16],                 true,  "len('_frozen_importlib_external') > len('SourceFileLoader') (26 > 16; the module where SourceFileLoader is defined has a longer name than SourceFileLoader itself)"]
    - [loader_mod_ne_builtins, "__loader__.__class__.__module__.__eq__", ["builtins"],                  false, "re.__loader__.__class__.__module__ != 'builtins' (SourceFileLoader is not a built-in type; it is defined in the frozen external importlib bootstrap, not in the C builtins module)"]

# ---------------------------------------------------------------------------
# re.__spec__.submodule_search_locations.__len__() == 1
# re is a package (Lib/re/__init__.py in Python 3.11+) so submodule_search_locations
# is a non-None list containing exactly one path (the re/ directory).
# re_extra62 covered submodule_search_locations.__class__.__name__=='list'.
# NO prior spec asserts submodule_search_locations.__len__()==1.
# re.__spec__.__class__.__module__ == '_frozen_importlib' (len 17) — novel.
# ---------------------------------------------------------------------------

table re_extra123.spec_submodule_len_and_class_module:
  description: "re.__spec__.submodule_search_locations.__len__()==1; __spec__.__class__.__module__=='_frozen_importlib'(17); all assertions novel; re_extra62 covered __class__.__name__ and submodule_search_locations.__class__.__name__ but not __len__ or __class__.__module__"
  kind: python_call_eq
  category: module_identity
  id_prefix: respecmod123b

  columns: [id, function, args, expected, description]
  rows:
    - [ssl_len_1,         "__spec__.submodule_search_locations.__len__",              [],                     1,     "re.__spec__.submodule_search_locations.__len__() == 1 (re is a package with exactly one search directory — the re/ directory in the Python standard library)"]
    - [spec_cls_mod_eq,   "__spec__.__class__.__module__.__eq__",                    ["_frozen_importlib"],   true,  "re.__spec__.__class__.__module__ == '_frozen_importlib' (ModuleSpec is defined in the inner frozen importlib bootstrap module; contrasts with SourceFileLoader which lives in '_frozen_importlib_external')"]
    - [spec_cls_mod_len,  "__spec__.__class__.__module__.__len__",                   [],                     17,    "re.__spec__.__class__.__module__.__len__() == 17 ('_frozen_importlib' has 17 characters: '_frozen_'(8)+'importlib'(9)==17)"]
    - [ssl_gt_0,          "__spec__.submodule_search_locations.__len__.__gt__",      [0],                    true,  "re.__spec__.submodule_search_locations.__len__() > 0 (re is a package so submodule_search_locations is a non-empty list; contrast with simple modules where it is None)"]
    - [ssl_ne_2,          "__spec__.submodule_search_locations.__len__.__eq__",      [1],                    true,  "re.__spec__.submodule_search_locations.__len__() == 1 (exactly one search path; re is a package with a single directory, not a namespace package with multiple paths)"]
    - [spec_cls_mod_ne_ext, "__spec__.__class__.__module__.__eq__",                  ["_frozen_importlib_external"], false, "re.__spec__.__class__.__module__ != '_frozen_importlib_external' (ModuleSpec is in '_frozen_importlib', not the external module; contrast with __loader__.__class__.__module__=='_frozen_importlib_external')"]
    - [spec_cls_mod_has_frozen, "__spec__.__class__.__module__.__contains__",        ["frozen"],             true,  "re.__spec__.__class__.__module__.__contains__('frozen') == True ('_frozen_importlib' contains 'frozen'; ModuleSpec is part of the frozen importlib bootstrap)"]
    - [spec_cls_mod_lt_loader_mod, "__spec__.__class__.__module__.__len__.__lt__",   [26],                   true,  "len('_frozen_importlib') < len('_frozen_importlib_external') (17 < 26; ModuleSpec's module name is 9 chars shorter than SourceFileLoader's module name)"]

# ---------------------------------------------------------------------------
# re.__spec__.name string class identity and re.__loader__.__class__.__name__
# length/content vs __class__.__module__ length cross-comparisons
# __spec__.name.__class__.__name__ == 'str' — novel (re_extra62 only checked value equality).
# __loader__.__class__.__name__.__len__() + __spec__.__class__.__module__.__len__() == 33.
# These cross-comparisons anchor the full identity of the loader and spec types.
# ---------------------------------------------------------------------------

table re_extra123.spec_name_class_and_cross_length:
  description: "re.__spec__.name.__class__.__name__=='str'; cross-length comparisons between loader class name(16) and spec class module(17); all assertions novel; anchors the string class of spec.name"
  kind: python_call_eq
  category: module_identity
  id_prefix: respecmod123c

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_cls,        "__spec__.name.__class__.__name__.__eq__",              ["str"],                 true,  "re.__spec__.name.__class__.__name__ == 'str' (the module name 're' is a plain Python string; ModuleSpec.name is always a str in the importlib machinery)"]
    - [spec_name_cls_len,    "__spec__.name.__class__.__name__.__len__",             [],                      3,     "re.__spec__.name.__class__.__name__.__len__() == 3 ('str' has 3 characters)"]
    - [loader_mod_gt_cls_mod, "__loader__.__class__.__module__.__len__.__gt__",      [17],                   true,  "len('_frozen_importlib_external') > len('_frozen_importlib') (26 > 17; the loader class module name is 9 chars longer than the spec class module name)"]
    - [loader_cls_lt_loader_mod, "__loader__.__class__.__name__.__len__.__lt__",     [26],                   true,  "len('SourceFileLoader') < len('_frozen_importlib_external') (16 < 26; the loader class name is shorter than the module it is defined in)"]
    - [spec_cls_mod_lt_loader_cls_mod, "__spec__.__class__.__module__.__len__.__lt__", [26],                 true,  "len('_frozen_importlib') < len('_frozen_importlib_external') (17 < 26; the spec class module is shorter than the loader class module by 9 chars)"]
    - [spec_name_ne_spec_cls_name, "__spec__.name.__eq__",                           ["ModuleSpec"],          false, "re.__spec__.name != 'ModuleSpec' (re.__spec__.name == 're' (2 chars) — the module's own name, not the class name of the spec object)"]
    - [spec_name_cls_ne_int,  "__spec__.name.__class__.__name__.__eq__",             ["int"],                 false, "re.__spec__.name.__class__.__name__ != 'int' (the module name is a str, not an int; type assertion distinguishing str from other possible types)"]
    - [loader_mod_len_26,     "__loader__.__class__.__module__.__len__.__eq__",      [26],                   true,  "re.__loader__.__class__.__module__.__len__() == 26 ('_frozen_importlib_external' has exactly 26 characters; confirming the length from the first table in a cross-table invariant context)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra123.loader_class_module_is_frozen_external:
  description: "re.__loader__.__class__.__module__ == '_frozen_importlib_external' (26 chars; SourceFileLoader is the class used by CPython's import system to load Python source files from the filesystem; it is defined in importlib._bootstrap_external, which is frozen into the interpreter as '_frozen_importlib_external'; this frozen form is used during early interpreter startup before normal imports are available; re_extra62 covered __loader__.__class__.__name__=='SourceFileLoader'(16) but did not assert its defining module; this is the first re spec to assert __loader__.__class__.__module__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__module__.__eq__
  args: ["_frozen_importlib_external"]
  expected: true

invariant re_extra123.loader_class_module_len_26:
  description: "re.__loader__.__class__.__module__.__len__() == 26 ('_frozen_importlib_external' has 26 characters; this is one of the longest standard module name strings in the Python import system; it is 9 chars longer than '_frozen_importlib' (17) where ModuleSpec is defined; it is also 10 chars longer than 'SourceFileLoader' (16) — so the module name is longer than the class name it defines; no prior re spec has asserted __loader__.__class__.__module__.__len__()); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__module__.__len__
  args: []
  expected: 26

invariant re_extra123.spec_submodule_search_locations_len_1:
  description: "re.__spec__.submodule_search_locations.__len__() == 1 (re is structured as a package in Python 3.11+ with its code in Lib/re/__init__.py; as a package, submodule_search_locations is a non-None list containing exactly one entry: the path to the re/ directory; re_extra62 covered submodule_search_locations.__class__.__name__=='list' but did not assert the length of the list; this is the first re spec to assert that there is exactly one search path entry); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__len__
  args: []
  expected: 1

invariant re_extra123.spec_class_module_is_frozen_importlib:
  description: "re.__spec__.__class__.__module__ == '_frozen_importlib' (17 chars; ModuleSpec is the class that represents a module's import-related state; it is defined in importlib._bootstrap, which is frozen as '_frozen_importlib'; this contrasts with __loader__.__class__.__module__ which is '_frozen_importlib_external' (26 chars) — the external bootstrap handles file loading while the inner bootstrap handles the ModuleSpec machinery; no prior re spec has asserted __spec__.__class__.__module__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__class__.__module__.__eq__
  args: ["_frozen_importlib"]
  expected: true

invariant re_extra123.spec_name_class_is_str:
  description: "re.__spec__.name.__class__.__name__ == 'str' (3 chars; re.__spec__.name holds the string 're' — the fully-qualified name of the module; ModuleSpec.name is always a str per the importlib.machinery.ModuleSpec contract; re_extra62 covered __spec__.name.__eq__('re') and __spec__.name.__len__()==2 but did not assert the type of the name string object; this is the first re spec to assert __spec__.name.__class__.__name__=='str'); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__class__.__name__.__eq__
  args: ["str"]
  expected: true

