spec: as3001
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/asyncio-task.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-sync.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-eventloop.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "asyncio source: internal C-level accelerators (_asyncio extension)"
  notes:
    - "Wave 647 — theme: __getitem__, __setitem__, __delitem__ dict-presence (item access/mutation protocol)."
    - "Tests operator.contains(SomeClass.__dict__, '__getitem__') etc. for asyncio classes."
    - "Classes covered: Task, Future, Queue, Event, Semaphore, BoundedSemaphore, Lock, Condition, Handle, TimerHandle, Timeout, TaskGroup."
    - "None of these asyncio concurrency primitives define __getitem__, __setitem__, or __delitem__ in their own __dict__."
    - "asyncio.Queue has put/get methods but deliberately does not implement the mapping or sequence item-access protocol."
    - "Task and Future are C-accelerated (_asyncio); the __dict__ check still correctly returns False for these item-access slots."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __getitem__ dict-presence — operator.contains(Cls.__dict__, '__getitem__')
#
# None of the asyncio classes define __getitem__; all results are false.
# These are concurrency primitives, not sequences or mappings.
# ---------------------------------------------------------------------------

table as3001.getitem:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: item_getitem
  id_prefix: gi

  columns: [id, function, args, expected]
  rows:
    - ["gi_Task",             operator.contains, [Task.__dict__,             "__getitem__"], false]
    - ["gi_Future",           operator.contains, [Future.__dict__,           "__getitem__"], false]
    - ["gi_Queue",            operator.contains, [Queue.__dict__,            "__getitem__"], false]
    - ["gi_Event",            operator.contains, [Event.__dict__,            "__getitem__"], false]
    - ["gi_Semaphore",        operator.contains, [Semaphore.__dict__,        "__getitem__"], false]
    - ["gi_BoundedSemaphore", operator.contains, [BoundedSemaphore.__dict__, "__getitem__"], false]
    - ["gi_Lock",             operator.contains, [Lock.__dict__,             "__getitem__"], false]
    - ["gi_Condition",        operator.contains, [Condition.__dict__,        "__getitem__"], false]
    - ["gi_Handle",           operator.contains, [Handle.__dict__,           "__getitem__"], false]
    - ["gi_TimerHandle",      operator.contains, [TimerHandle.__dict__,      "__getitem__"], false]
    - ["gi_Timeout",          operator.contains, [Timeout.__dict__,          "__getitem__"], false]
    - ["gi_TaskGroup",        operator.contains, [TaskGroup.__dict__,        "__getitem__"], false]

