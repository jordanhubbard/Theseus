# ---------------------------------------------------------------------------
# combined — all three item-access operators across a cross-class sample
#
# Spot-checks __getitem__, __setitem__, __delitem__ absence across a
# representative selection of asyncio classes in a single table.
# 8 classes x 3 operators = 24 rows.
# ---------------------------------------------------------------------------

table as3001.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: item_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_Task_gi",             operator.contains, [Task.__dict__,      "__getitem__"], false]
