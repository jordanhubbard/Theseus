spec: concurrent_futures_extra235
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers concurrent.futures.Future class identity and method contracts."
    - "concurrent.futures.Future.__name__ == 'Future' — the class carries its unqualified name."
    - "concurrent.futures.Future.__module__ == 'concurrent.futures._base' — Future is defined in the private _base submodule; verified Python 3.14.3."
    - "concurrent.futures.Future.__bases__[0].__name__ == 'object' — Future inherits directly from object."
    - "concurrent.futures.Future.__qualname__ == 'Future' — top-level class; qualname equals __name__."
    - "result.__name__ == 'result' (len=6); result.__qualname__ == 'Future.result' (len=13)."
    - "cancel.__name__ == 'cancel' (len=6); cancel.__qualname__ == 'Future.cancel' (len=13)."
    - "done.__name__ == 'done' (len=4); done.__qualname__ == 'Future.done' (len=11)."
    - "running.__name__ == 'running' (len=7); running.__qualname__ == 'Future.running' (len=14)."
    - "add_done_callback.__name__ == 'add_done_callback' (len=17)."
    - "set_result.__name__ == 'set_result' (len=10)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.Future class identity contracts
#
# Future.__name__, __module__, __qualname__, and __bases__[0].__name__
# confirm the class lives in concurrent.futures._base and inherits from object.
# ---------------------------------------------------------------------------

table concurrent_futures_extra235.future_class_identity:
  description: "concurrent.futures.Future class identity: name, module, qualname, and base class; new to extra235"
  kind: python_call_eq
  category: class_identity
  id_prefix: cf235fut

  columns: [id, function, args, expected, description]
  rows:
    - [future_name_eq,
       Future.__name__.__eq__,
       ["Future"],
       true,
       "concurrent.futures.Future.__name__.__eq__('Future') == True — the class carries the unqualified name 'Future'; new to extra235"]
    - [future_module_eq,
       Future.__module__.__eq__,
       ["concurrent.futures._base"],
       true,
       "concurrent.futures.Future.__module__.__eq__('concurrent.futures._base') == True — Future is defined in the private _base submodule; verified Python 3.14.3; new to extra235"]
    - [future_qualname_eq,
       Future.__qualname__.__eq__,
       ["Future"],
       true,
       "concurrent.futures.Future.__qualname__.__eq__('Future') == True — top-level class; qualname equals __name__; new to extra235"]
    - [future_name_len_6,
       Future.__name__.__len__,
       [],
       6,
       "concurrent.futures.Future.__name__.__len__() == 6 — 'Future' has exactly 6 characters (F-u-t-u-r-e); new to extra235"]
    - [future_module_len_24,
       Future.__module__.__len__,
       [],
       24,
       "concurrent.futures.Future.__module__.__len__() == 24 — 'concurrent.futures._base' has exactly 24 characters; new to extra235"]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures.Future method __name__ contracts
#
# Verifies __name__ for result, cancel, done, running, add_done_callback,
# and set_result methods on the Future class.
# ---------------------------------------------------------------------------

table concurrent_futures_extra235.future_method_names:
  description: "concurrent.futures.Future method __name__ contracts; new to extra235"
  kind: python_call_eq
  category: method_names
  id_prefix: cf235futm

  columns: [id, function, args, expected, description]
  rows:
    - [result_name_eq,
       Future.result.__name__.__eq__,
       ["result"],
       true,
       "concurrent.futures.Future.result.__name__.__eq__('result') == True — method name is 'result' (len=6); new to extra235"]
    - [cancel_name_eq,
       Future.cancel.__name__.__eq__,
       ["cancel"],
       true,
       "concurrent.futures.Future.cancel.__name__.__eq__('cancel') == True — method name is 'cancel' (len=6); new to extra235"]
    - [done_name_eq,
       Future.done.__name__.__eq__,
       ["done"],
       true,
       "concurrent.futures.Future.done.__name__.__eq__('done') == True — method name is 'done' (len=4); new to extra235"]
    - [running_name_eq,
       Future.running.__name__.__eq__,
       ["running"],
       true,
       "concurrent.futures.Future.running.__name__.__eq__('running') == True — method name is 'running' (len=7); new to extra235"]
    - [add_done_callback_name_eq,
       Future.add_done_callback.__name__.__eq__,
       ["add_done_callback"],
       true,
       "concurrent.futures.Future.add_done_callback.__name__.__eq__('add_done_callback') == True — method name is 'add_done_callback' (len=17); new to extra235"]

# ---------------------------------------------------------------------------
# Table 3: concurrent.futures.Future method __qualname__ contracts
#
# For methods defined directly on Future, __qualname__ is 'Future.<method>'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra235.future_method_qualnames:
  description: "concurrent.futures.Future method __qualname__ contracts; new to extra235"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: cf235futmq

  columns: [id, function, args, expected, description]
  rows:
    - [result_qualname_eq,
       Future.result.__qualname__.__eq__,
       ["Future.result"],
       true,
       "concurrent.futures.Future.result.__qualname__.__eq__('Future.result') == True — qualname is 'Future.result' (len=13); new to extra235"]
    - [cancel_qualname_eq,
       Future.cancel.__qualname__.__eq__,
       ["Future.cancel"],
       true,
       "concurrent.futures.Future.cancel.__qualname__.__eq__('Future.cancel') == True — qualname is 'Future.cancel' (len=13); new to extra235"]
    - [done_qualname_eq,
       Future.done.__qualname__.__eq__,
       ["Future.done"],
       true,
       "concurrent.futures.Future.done.__qualname__.__eq__('Future.done') == True — qualname is 'Future.done' (len=11); new to extra235"]
    - [running_qualname_eq,
       Future.running.__qualname__.__eq__,
       ["Future.running"],
       true,
       "concurrent.futures.Future.running.__qualname__.__eq__('Future.running') == True — qualname is 'Future.running' (len=14); new to extra235"]
    - [set_result_qualname_eq,
       Future.set_result.__qualname__.__eq__,
       ["Future.set_result"],
       true,
       "concurrent.futures.Future.set_result.__qualname__.__eq__('Future.set_result') == True — qualname is 'Future.set_result' (len=17); new to extra235"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra235
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra235.Future.name:
  description: "concurrent.futures.Future.__name__ == 'Future'; new to extra235"
  category: class_identity
  kind: python_call_eq
  function: Future.__name__.__eq__
  args: ["Future"]
  expected: true

invariant concurrent_futures_extra235.Future.module:
  description: "concurrent.futures.Future.__module__ == 'concurrent.futures._base'; new to extra235"
  category: class_identity
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra235.Future.qualname:
  description: "concurrent.futures.Future.__qualname__ == 'Future' — top-level class; new to extra235"
  category: class_identity
  kind: python_call_eq
  function: Future.__qualname__.__eq__
  args: ["Future"]
  expected: true

invariant concurrent_futures_extra235.Future.base_name:
  description: "concurrent.futures.Future.__bases__[0].__name__ == 'object' — Future inherits directly from object; new to extra235"
  category: class_identity
  kind: python_call_eq
  function: "Future.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant concurrent_futures_extra235.Future.result_name:
  description: "concurrent.futures.Future.result.__name__ == 'result'; new to extra235"
  category: method_names
  kind: python_call_eq
  function: Future.result.__name__.__eq__
  args: ["result"]
  expected: true

invariant concurrent_futures_extra235.Future.result_qualname:
  description: "concurrent.futures.Future.result.__qualname__ == 'Future.result'; new to extra235"
  category: method_qualnames
  kind: python_call_eq
  function: Future.result.__qualname__.__eq__
  args: ["Future.result"]
  expected: true

invariant concurrent_futures_extra235.Future.cancel_name:
  description: "concurrent.futures.Future.cancel.__name__ == 'cancel'; new to extra235"
  category: method_names
  kind: python_call_eq
  function: Future.cancel.__name__.__eq__
  args: ["cancel"]
  expected: true

invariant concurrent_futures_extra235.Future.cancel_qualname:
  description: "concurrent.futures.Future.cancel.__qualname__ == 'Future.cancel'; new to extra235"
  category: method_qualnames
  kind: python_call_eq
  function: Future.cancel.__qualname__.__eq__
  args: ["Future.cancel"]
  expected: true

invariant concurrent_futures_extra235.Future.done_name:
  description: "concurrent.futures.Future.done.__name__ == 'done'; new to extra235"
  category: method_names
  kind: python_call_eq
  function: Future.done.__name__.__eq__
  args: ["done"]
  expected: true

invariant concurrent_futures_extra235.Future.done_qualname:
  description: "concurrent.futures.Future.done.__qualname__ == 'Future.done'; new to extra235"
  category: method_qualnames
  kind: python_call_eq
  function: Future.done.__qualname__.__eq__
  args: ["Future.done"]
  expected: true
