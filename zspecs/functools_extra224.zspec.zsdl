spec: functools_extra224
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools.lru_cache, functools.reduce, and functools.WRAPPER_UPDATES (wave 385)."
    - "lru_cache.__name__ == 'lru_cache'; __module__ == 'functools'; __qualname__ == 'lru_cache'. Verified with Python 3.14.3."
    - "reduce.__name__ == 'reduce'; __module__ == '_functools' (C-level module). Verified with Python 3.14.3."
    - "reduce([1,2,3], operator.add) == 6; reduce([1,2,3,4], operator.mul) == 24. Verified with Python 3.14.3."
    - "WRAPPER_UPDATES.__class__.__name__ == 'tuple'; len == 1; WRAPPER_UPDATES[0] == '__dict__'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.lru_cache identity checks
#
# lru_cache is a decorator factory defined in Lib/functools.py.
# Its __name__, __module__, and __qualname__ are stable string invariants.
#
# Verified with Python 3.14.3:
#   functools.lru_cache.__name__ == 'lru_cache'
#   functools.lru_cache.__module__ == 'functools'
#   functools.lru_cache.__qualname__ == 'lru_cache'
# ---------------------------------------------------------------------------

table functools_extra224.lru_cache_identity:
  description: "functools.lru_cache __name__, __module__, __qualname__ identity checks; wave 385; new to extra224"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra224lrucache

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_name_eq,
       lru_cache.__name__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__name__.__eq__('lru_cache') == True — lru_cache is defined in Lib/functools.py; its __name__ is 'lru_cache'; str.__eq__('lru_cache') returns True; new to extra224"]
    - [lru_cache_module_eq,
       lru_cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is defined in the functools module (Lib/functools.py); its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra224"]
    - [lru_cache_qualname_eq,
       lru_cache.__qualname__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — lru_cache is a top-level function so its __qualname__ equals its __name__; str.__eq__('lru_cache') returns True; new to extra224"]
    - [lru_cache_name_len,
       lru_cache.__name__.__len__,
       [],
       9,
       "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters; str.__len__() returns 9; new to extra224"]
    - [lru_cache_module_len,
       lru_cache.__module__.__len__,
       [],
       9,
       "functools.lru_cache.__module__.__len__() == 9 — 'functools' has 9 characters; str.__len__() returns 9; new to extra224"]

# ---------------------------------------------------------------------------
# Table 2: functools.reduce identity checks
#
# functools.reduce is a C-level function from _functoolsmodule.c.
# It is re-exported via functools. Its __module__ is '_functools'.
#
# Verified with Python 3.14.3:
#   functools.reduce.__name__ == 'reduce'
#   functools.reduce.__module__ == '_functools'
# ---------------------------------------------------------------------------

table functools_extra224.reduce_identity:
  description: "functools.reduce __name__ and __module__ identity checks; wave 385; new to extra224"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra224reduce

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_name_eq,
       reduce.__name__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__name__.__eq__('reduce') == True — reduce is a C-level function in _functoolsmodule.c; its __name__ is 'reduce'; str.__eq__('reduce') returns True; new to extra224"]
    - [reduce_module_eq,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is implemented in the C extension _functoolsmodule.c and re-exported via functools; its __module__ is '_functools'; str.__eq__('_functools') returns True; new to extra224"]
    - [reduce_name_len,
       reduce.__name__.__len__,
       [],
       6,
       "functools.reduce.__name__.__len__() == 6 — 'reduce' has 6 characters; str.__len__() returns 6; new to extra224"]
    - [reduce_module_contains_functools,
       reduce.__module__.__contains__,
       ["functools"],
       true,
       "functools.reduce.__module__.__contains__('functools') == True — '_functools' contains the substring 'functools'; str.__contains__('functools') returns True; new to extra224"]

# ---------------------------------------------------------------------------
# Table 3: functools.WRAPPER_UPDATES checks
#
# WRAPPER_UPDATES is a module-level tuple constant in functools.
# It holds ('__dict__',) — one element that names the attribute to update
# when wrapping a function with functools.wraps.
#
# Verified with Python 3.14.3:
#   functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'
#   len(functools.WRAPPER_UPDATES) == 1
#   functools.WRAPPER_UPDATES[0] == '__dict__'
# ---------------------------------------------------------------------------

table functools_extra224.wrapper_updates_checks:
  description: "functools.WRAPPER_UPDATES type, length, and content checks; wave 385; new to extra224"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra224wrapperupdates

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_updates_class_name_eq,
       WRAPPER_UPDATES.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a tuple constant holding attribute names to copy during wrapping; its __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra224"]
    - [wrapper_updates_len_eq,
       WRAPPER_UPDATES.__len__,
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES is ('__dict__',), a 1-element tuple; tuple.__len__() returns 1; new to extra224"]
    - [wrapper_updates_first_elem_eq,
       WRAPPER_UPDATES.__getitem__,
       [0],
       "__dict__",
       "functools.WRAPPER_UPDATES.__getitem__(0) == '__dict__' — the first (and only) element of WRAPPER_UPDATES is '__dict__'; this is the attribute merged from the wrapped function into the wrapper; tuple.__getitem__(0) returns '__dict__'; new to extra224"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra224
# ---------------------------------------------------------------------------

invariant functools_extra224.lru_cache_name:
  description: "functools.lru_cache.__name__.__eq__('lru_cache') == True; wave 385; new to extra224"
  kind: python_call_eq
  function: lru_cache.__name__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra224.lru_cache_module:
  description: "functools.lru_cache.__module__.__eq__('functools') == True; wave 385; new to extra224"
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra224.lru_cache_qualname:
  description: "functools.lru_cache.__qualname__.__eq__('lru_cache') == True; wave 385; new to extra224"
  kind: python_call_eq
  function: lru_cache.__qualname__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra224.reduce_name:
  description: "functools.reduce.__name__.__eq__('reduce') == True; wave 385; new to extra224"
  kind: python_call_eq
  function: reduce.__name__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra224.reduce_module:
  description: "functools.reduce.__module__.__eq__('_functools') == True — reduce is a C-level function; wave 385; new to extra224"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra224.wrapper_updates_class_name:
  description: "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True; wave 385; new to extra224"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra224.wrapper_updates_len:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES is a 1-element tuple; wave 385; new to extra224"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra224.wrapper_updates_item0:
  description: "functools.WRAPPER_UPDATES.__getitem__(0) == '__dict__' — first element is '__dict__'; wave 385; new to extra224"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__getitem__
  args: [0]
  expected: "__dict__"
