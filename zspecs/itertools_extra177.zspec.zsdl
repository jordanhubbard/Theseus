spec: itertools_extra177
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.count and repeat identity — itertools.count.__name__=='count' (len=5); itertools.count.__module__=='itertools'; itertools.count.__mro__.__len__()==2; itertools.repeat.__name__=='repeat' (len=6); itertools.repeat.__mro__.__len__()==2; itertools.cycle.__name__=='cycle' (len=5; same as count); itertools.cycle.__mro__.__len__()==2; itertools.islice.__name__=='islice' (len=6; same as repeat); itertools.tee.__name__=='tee' (len=3; shortest itertools name)."
    - "itertools.count.__name__ == 'count' — count is a C extension type in itertoolsmodule.c that generates an infinite arithmetic sequence starting from a start value; its __name__ is 'count', 5 characters. Verified with Python 3.14.3."
    - "itertools.count.__module__ == 'itertools' — count is defined in the itertools C extension module. Verified with Python 3.14.3."
    - "itertools.count.__mro__.__len__() == 2 — count is a C extension type inheriting directly from object; its MRO is (count, object). Verified with Python 3.14.3."
    - "itertools.repeat.__name__ == 'repeat' — repeat is a C extension type in itertoolsmodule.c that returns an object that repeatedly yields the same value; its __name__ is 'repeat', 6 characters. Verified with Python 3.14.3."
    - "itertools.repeat.__mro__.__len__() == 2 — repeat is a C extension type inheriting directly from object; its MRO is (repeat, object). Verified with Python 3.14.3."
    - "itertools.cycle.__name__ == 'cycle' — cycle is a C extension type in itertoolsmodule.c that cycles through an iterable indefinitely; its __name__ is 'cycle', 5 characters, same length as 'count'. Verified with Python 3.14.3."
    - "itertools.cycle.__mro__.__len__() == 2 — cycle is a C extension type inheriting directly from object; its MRO is (cycle, object). Verified with Python 3.14.3."
    - "itertools.islice.__name__ == 'islice' — islice is a C extension type in itertoolsmodule.c that slices an iterator; its __name__ is 'islice', 6 characters, same length as 'repeat'. Verified with Python 3.14.3."
    - "itertools.tee.__name__ == 'tee' — tee is a function in itertoolsmodule.c that returns n independent iterators from a single iterable; its __name__ is 'tee', 3 characters, the shortest name among itertools public names. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.count class __name__ and __module__
#
# itertools.count.__name__ == 'count'
# itertools.count.__name__.__len__() == 5
# itertools.count.__module__ == 'itertools'
# itertools.count.__module__.__len__() == 9
#
# itertools.count is a C extension type defined in itertoolsmodule.c that
# generates an infinite arithmetic sequence starting from a start value with a
# given step. Its __name__ is 'count' (5 chars) and its __module__ is
# 'itertools' (9 chars). New to extra177.
# ---------------------------------------------------------------------------

table itertools_extra177.count_name_and_module:
  description: "itertools.count.__name__ 'count' len 5; __module__ 'itertools' len 9; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: itercount177

  columns: [id, function, args, expected, description]
  rows:
    - [count_name_eq,
       "count.__name__.__eq__",
       ["count"],
       true,
       "itertools.count.__name__.__eq__('count') == True — itertools.count is a C extension type in itertoolsmodule.c that generates an infinite arithmetic sequence starting at a given value; its __name__ is 'count'; str.__eq__('count') returns True; new to extra177"]
    - [count_name_len_5,
       "count.__name__.__len__",
       [],
       5,
       "itertools.count.__name__.__len__() == 5 — the name 'count' has exactly 5 characters: c-o-u-n-t; str.__len__() returns 5; new to extra177"]
    - [count_module_itertools,
       "count.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.count.__module__.__eq__('itertools') == True — itertools.count is a C extension type defined in the itertools module (itertoolsmodule.c); its __module__ is the string 'itertools'; str.__eq__('itertools') returns True; new to extra177"]
    - [count_module_len_9,
       "count.__module__.__len__",
       [],
       9,
       "itertools.count.__module__.__len__() == 9 — the module name 'itertools' has exactly 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; new to extra177"]

# ---------------------------------------------------------------------------
# Table 2: itertools.count __mro__ and itertools.repeat __name__
#
# itertools.count.__mro__.__len__() == 2
# itertools.count.__mro__[0].__name__ == 'count'
# itertools.repeat.__name__ == 'repeat'
# itertools.repeat.__name__.__len__() == 6
#
# count's MRO is (count, object) — it inherits directly from object like all
# itertools C types. repeat is another C extension type whose __name__ is
# 'repeat' (6 chars). New to extra177.
# ---------------------------------------------------------------------------

table itertools_extra177.count_mro_and_repeat_name:
  description: "itertools.count.__mro__ len 2, mro[0] 'count'; repeat.__name__ 'repeat' len 6; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: itercount177

  columns: [id, function, args, expected, description]
  rows:
    - [count_mro_len_2,
       "count.__mro__.__len__",
       [],
       2,
       "itertools.count.__mro__.__len__() == 2 — itertools.count is a C extension type defined in itertoolsmodule.c that inherits directly from object with no intermediate base classes; its __mro__ is (count, object), a tuple of length 2; tuple.__len__() returns 2; new to extra177"]
    - ["count_mro_0_count",
       "count.__mro__[0].__name__.__eq__",
       ["count"],
       true,
       "itertools.count.__mro__[0].__name__.__eq__('count') == True — the first entry in count.__mro__ is the count class itself; its __name__ is 'count'; str.__eq__('count') returns True; new to extra177"]
    - [repeat_name_eq,
       "repeat.__name__.__eq__",
       ["repeat"],
       true,
       "itertools.repeat.__name__.__eq__('repeat') == True — itertools.repeat is a C extension type in itertoolsmodule.c that returns an iterator yielding a single value over and over (optionally a fixed number of times); its __name__ is 'repeat'; str.__eq__('repeat') returns True; new to extra177"]
    - [repeat_name_len_6,
       "repeat.__name__.__len__",
       [],
       6,
       "itertools.repeat.__name__.__len__() == 6 — the name 'repeat' has exactly 6 characters: r-e-p-e-a-t; str.__len__() returns 6; new to extra177"]

# ---------------------------------------------------------------------------
# Table 3: itertools.repeat __mro__ and itertools.cycle __name__
#
# itertools.repeat.__mro__.__len__() == 2
# itertools.cycle.__name__ == 'cycle'
# itertools.cycle.__name__.__len__() == 5
# itertools.cycle.__mro__.__len__() == 2
#
# repeat's MRO is (repeat, object), length 2. cycle is another C extension type
# whose __name__ is 'cycle' (5 chars, same as 'count'). cycle's MRO is also
# (cycle, object), length 2. New to extra177.
# ---------------------------------------------------------------------------

table itertools_extra177.repeat_mro_and_cycle_name:
  description: "itertools.repeat.__mro__ len 2; cycle.__name__ 'cycle' len 5 (same as count); cycle.__mro__ len 2; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: itercount177

  columns: [id, function, args, expected, description]
  rows:
    - [repeat_mro_len_2,
       "repeat.__mro__.__len__",
       [],
       2,
       "itertools.repeat.__mro__.__len__() == 2 — itertools.repeat is a C extension type defined in itertoolsmodule.c that inherits directly from object with no intermediate base classes; its __mro__ is (repeat, object), a tuple of length 2; tuple.__len__() returns 2; new to extra177"]
    - [cycle_name_eq,
       "cycle.__name__.__eq__",
       ["cycle"],
       true,
       "itertools.cycle.__name__.__eq__('cycle') == True — itertools.cycle is a C extension type in itertoolsmodule.c that makes an iterator returning elements from the iterable and saving a copy of each; it repeats the saved copies indefinitely; its __name__ is 'cycle'; str.__eq__('cycle') returns True; new to extra177"]
    - [cycle_name_len_5,
       "cycle.__name__.__len__",
       [],
       5,
       "itertools.cycle.__name__.__len__() == 5 — the name 'cycle' has exactly 5 characters: c-y-c-l-e; same length as 'count' (5); str.__len__() returns 5; new to extra177"]
    - [cycle_mro_len_2,
       "cycle.__mro__.__len__",
       [],
       2,
       "itertools.cycle.__mro__.__len__() == 2 — itertools.cycle is a C extension type defined in itertoolsmodule.c that inherits directly from object; its __mro__ is (cycle, object), a tuple of length 2; tuple.__len__() returns 2; new to extra177"]

# ---------------------------------------------------------------------------
# Table 4: itertools.islice and itertools.tee __name__
#
# itertools.islice.__name__ == 'islice'
# itertools.islice.__name__.__len__() == 6
# itertools.tee.__name__ == 'tee'
# itertools.tee.__name__.__len__() == 3
#
# islice is a C extension type whose __name__ is 'islice' (6 chars, same as
# 'repeat'). tee returns independent iterators from a single iterable; its
# __name__ is 'tee' (3 chars, the shortest public name in itertools). New to
# extra177.
# ---------------------------------------------------------------------------

table itertools_extra177.islice_and_tee_name:
  description: "itertools.islice.__name__ 'islice' len 6 (same as repeat); tee.__name__ 'tee' len 3 (shortest); new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: itercount177

  columns: [id, function, args, expected, description]
  rows:
    - [islice_name_eq,
       "islice.__name__.__eq__",
       ["islice"],
       true,
       "itertools.islice.__name__.__eq__('islice') == True — itertools.islice is a C extension type in itertoolsmodule.c that makes an iterator that returns selected elements from an iterable (like slicing but for iterators); its __name__ is 'islice'; str.__eq__('islice') returns True; new to extra177"]
    - [islice_name_len_6,
       "islice.__name__.__len__",
       [],
       6,
       "itertools.islice.__name__.__len__() == 6 — the name 'islice' has exactly 6 characters: i-s-l-i-c-e; same length as 'repeat' (6); str.__len__() returns 6; new to extra177"]
    - [tee_name_eq,
       "tee.__name__.__eq__",
       ["tee"],
       true,
       "itertools.tee.__name__.__eq__('tee') == True — itertools.tee is a function in itertoolsmodule.c that returns n independent iterators from a single iterable by saving copies of each element; its __name__ is 'tee'; str.__eq__('tee') returns True; new to extra177"]
    - [tee_name_len_3,
       "tee.__name__.__len__",
       [],
       3,
       "itertools.tee.__name__.__len__() == 3 — the name 'tee' has exactly 3 characters: t-e-e; this is the shortest public name in the itertools module; str.__len__() returns 3; new to extra177"]

