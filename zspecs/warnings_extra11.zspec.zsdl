spec: warnings_extra11
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Modules/_warnings.c"
  notes:
    - "This spec extends warnings.zspec.zsdl through warnings_extra10.zspec.zsdl."
    - "This spec covers: warnings.filters __class__.__name__; warnings.defaultaction __class__.__name__ and value; warnings.onceregistry __class__.__name__; catch_warnings __name__/__module__/__qualname__; WarningMessage __name__/__module__; WarningMessage base class; warn_explicit/__module__; warn/__qualname__."
    - "warnings.filters is a list maintained by the warnings machinery."
    - "warnings.defaultaction is 'default' in a fresh Python process."
    - "warnings.onceregistry is a dict tracking 'once' filter firings."
    - "warnings.warn_explicit is implemented in _warnings (C extension), so its __module__ is '_warnings'."
    - "warnings.warn.__qualname__ == 'warn' — module-level function."
    - "warnings.catch_warnings is a context manager class defined in warnings.py."
    - "warnings.WarningMessage is a simple record class whose only base is object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level data attributes — filters, defaultaction, onceregistry
#
# These three module-level attributes are part of the public warnings API.
# No prior warnings spec records their __class__.__name__ or the value of
# defaultaction as standalone invariants.
# ---------------------------------------------------------------------------

invariant warnings_extra11.filters.class_name:
  description: "warnings.filters.__class__.__name__ == 'list' — filter list type"
  category: module_attrs
  kind: python_call_eq
  function: filters.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant warnings_extra11.defaultaction.class_name:
  description: "warnings.defaultaction.__class__.__name__ == 'str'"
  category: module_attrs
  kind: python_call_eq
  function: defaultaction.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant warnings_extra11.defaultaction.value:
  description: "warnings.defaultaction == 'default'"
  category: module_attrs
  kind: python_call_eq
  function: defaultaction.__eq__
  args: ["default"]
  expected: true

invariant warnings_extra11.onceregistry.class_name:
  description: "warnings.onceregistry.__class__.__name__ == 'dict' — once-registry type"
  category: module_attrs
  kind: python_call_eq
  function: onceregistry.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# catch_warnings — __name__, __module__, __qualname__
#
# warnings.catch_warnings is a context manager class that saves and restores
# the warning filter list. No prior warnings spec records these three
# identity attributes for catch_warnings.
# ---------------------------------------------------------------------------

table warnings_extra11.catch_warnings_identity:
  description: "Identity attributes for warnings.catch_warnings class"
  kind: python_call_eq
  category: class_identity

  columns: [id, function, args, expected]
  rows:
    - [name,     catch_warnings.__name__.__eq__,     ["catch_warnings"], true]
    - [module,   catch_warnings.__module__.__eq__,   ["warnings"],       true]
    - [qualname, catch_warnings.__qualname__.__eq__, ["catch_warnings"], true]

# ---------------------------------------------------------------------------
# WarningMessage — __name__, __module__, base class
#
# warnings.WarningMessage is the object passed to showwarning-like callbacks.
# No prior warnings spec records its identity attributes or base class.
# ---------------------------------------------------------------------------

invariant warnings_extra11.WarningMessage.name:
  description: "warnings.WarningMessage.__name__ == 'WarningMessage'"
  category: class_identity
  kind: python_call_eq
  function: WarningMessage.__name__.__eq__
  args: ["WarningMessage"]
  expected: true

invariant warnings_extra11.WarningMessage.module:
  description: "warnings.WarningMessage.__module__ == 'warnings'"
  category: class_identity
  kind: python_call_eq
  function: WarningMessage.__module__.__eq__
  args: ["warnings"]
  expected: true

invariant warnings_extra11.WarningMessage.base0_name:
  description: "warnings.WarningMessage.__bases__[0].__name__ == 'object'"
  category: base_classes
  kind: python_call_eq
  function: WarningMessage.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# warn_explicit — __module__; warn — __qualname__
#
# warn_explicit is implemented in the C extension _warnings, so its __module__
# is '_warnings' rather than 'warnings'. warn is the pure-Python wrapper and
# has __qualname__ == 'warn'.
# ---------------------------------------------------------------------------

invariant warnings_extra11.warn_explicit.module:
  description: "warnings.warn_explicit.__module__ == '_warnings' — C extension implementation"
  category: function_modules
  kind: python_call_eq
  function: warn_explicit.__module__.__eq__
  args: ["_warnings"]
  expected: true

invariant warnings_extra11.warn.qualname:
  description: "warnings.warn.__qualname__ == 'warn'"
  category: function_qualnames
  kind: python_call_eq
  function: warn.__qualname__.__eq__
  args: ["warn"]
  expected: true
