spec: struct_extra254
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "struct.Struct instance methods (pack, unpack, pack_into, unpack_from, iter_unpack) are builtin_function_or_method."
    - "Qualnames follow the pattern 'Struct.<method>' (e.g. 'Struct.pack', 'Struct.unpack')."
    - "struct.Struct('!I').size is an int; struct.Struct('!I').format is a str."
    - "type(struct.Struct('!I')).__name__ == 'Struct' and __module__ == '_struct'."
    - "All method name/qualname/class values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Struct.pack method identity
# ---------------------------------------------------------------------------

invariant struct_extra254.Struct.pack.name:
  description: "struct.Struct('!I').pack.__name__ == 'pack'"
  category: identity
  kind: python_call_eq
  function: Struct.__init__
  args: ["!I"]
  method: pack.__name__.__eq__
  method_args: ["pack"]
  expected: true

invariant struct_extra254.Struct.pack.qualname:
  description: "struct.Struct('!I').pack.__qualname__ == 'Struct.pack'"
  category: identity
  kind: python_call_eq
  function: Struct.__init__
  args: ["!I"]
  method: pack.__qualname__.__eq__
  method_args: ["Struct.pack"]
  expected: true

invariant struct_extra254.Struct.pack.class_name:
  description: "struct.Struct('!I').pack.__class__.__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: Struct.__init__
  args: ["!I"]
  method: pack.__class__.__name__.__eq__
  method_args: ["builtin_function_or_method"]
  expected: true

