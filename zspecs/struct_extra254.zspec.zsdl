# ---------------------------------------------------------------------------
# Struct class-level type identity
# ---------------------------------------------------------------------------

invariant struct_extra254.Struct.type.name:
  description: "type(struct.Struct('!I')).__name__ == 'Struct'"
  category: identity
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

invariant struct_extra254.Struct.type.module:
  description: "type(struct.Struct('!I')).__module__ == '_struct'"
  category: identity
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true
