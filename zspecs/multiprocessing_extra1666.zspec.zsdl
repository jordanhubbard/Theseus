spec: multiprocessing_extra1666
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/exceptions.py"
  notes:
    - "Theme: __new__ — object construction protocol; which multiprocessing classes define custom __new__."
    - "multiprocessing.Process is a thin proxy class; on CPython it inherits from multiprocessing.process.BaseProcess."
    - "multiprocessing.Process.__dict__.__contains__('__new__') is False — Process defines no custom __new__."
    - "multiprocessing.Process.__dict__.__contains__('__init__') is False — Process does NOT define its own __init__; __init__ lives on BaseProcess."
    - "multiprocessing.process.BaseProcess.__dict__.__contains__('__new__') is False — BaseProcess inherits __new__ from object."
    - "multiprocessing.process.BaseProcess.__dict__.__contains__('__init__') is True — BaseProcess.__init__ sets _name, _target, _args, _kwargs, _popen, _daemonic, _authkey, _tempdir, _parent_pid, _parent_name, and _identity."
    - "multiprocessing.ProcessError is the base exception class in the multiprocessing exception hierarchy."
    - "multiprocessing.ProcessError.__dict__.__contains__('__new__') is False — no custom __new__; inherits from Exception."
    - "multiprocessing.ProcessError.__dict__.__contains__('__init__') is False — no custom __init__; uses Exception.__init__."
    - "multiprocessing.BufferTooShort is a subclass of ProcessError with no custom __new__ or __init__."
    - "multiprocessing.AuthenticationError is a subclass of ProcessError with no custom __new__ or __init__."
    - "multiprocessing.TimeoutError is a subclass of ProcessError with no custom __new__ or __init__."
    - "Exception subclasses that do not need extra state need not define __new__ or __init__; they delegate entirely to Exception."
    - "BaseProcess.__name__ == 'BaseProcess' (len=11); Process.__name__ == 'Process' (len=7)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing_extra1666.new_init_checks
#
# Process (public API class) and BaseProcess (internal base): both lack __new__;
# Process also lacks __init__ (defined on BaseProcess); BaseProcess has __init__.
# ---------------------------------------------------------------------------

table multiprocessing_extra1666.new_init_checks:
  description: "multiprocessing.Process and multiprocessing.process.BaseProcess __new__ and __init__ presence: Process defines neither __new__ nor __init__ in its own __dict__; BaseProcess defines __init__ (True) but not __new__ (False); the full construction protocol is object.__new__(Process) followed by BaseProcess.__init__ via MRO; verified with Python 3.14.4"
  kind: python_call_eq
  category: new_init_presence
  id_prefix: mp1666ni

  columns: [id, function, args, expected]
  rows:
    - ["mp1666ni001", "multiprocessing.Process.__dict__.__contains__",                ["__new__"],  false]
    - ["mp1666ni002", "multiprocessing.Process.__dict__.__contains__",                ["__init__"], false]
    - ["mp1666ni003", "multiprocessing.process.BaseProcess.__dict__.__contains__",    ["__new__"],  false]
    - ["mp1666ni004", "multiprocessing.process.BaseProcess.__dict__.__contains__",    ["__init__"], true]
    - ["mp1666ni005", "multiprocessing.Process.__name__.__eq__",                      ["Process"],  true]
    - ["mp1666ni006", "multiprocessing.Process.__name__.__len__",                     [],           7]
    - ["mp1666ni007", "multiprocessing.process.BaseProcess.__name__.__eq__",          ["BaseProcess"], true]
    - ["mp1666ni008", "multiprocessing.process.BaseProcess.__name__.__len__",         [],           11]
    - ["mp1666ni009", "multiprocessing.process.BaseProcess.__dict__.__contains__",    ["start"],    true]
    - ["mp1666ni010", "multiprocessing.process.BaseProcess.__dict__.__contains__",    ["run"],      true]
    - ["mp1666ni011", "multiprocessing.process.BaseProcess.__dict__.__contains__",    ["terminate"],true]
    - ["mp1666ni012", "multiprocessing.process.BaseProcess.__dict__.__contains__",    ["join"],     true]
    - ["mp1666ni013", "multiprocessing.process.BaseProcess.__dict__.__contains__",    ["is_alive"], true]
    - ["mp1666ni014", "multiprocessing.Process.__dict__.__contains__",                ["start"],    false]
    - ["mp1666ni015", "multiprocessing.Process.__dict__.__contains__",                ["run"],      false]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing_extra1666.exception_new_init
#
# ProcessError and its subclasses: all are simple Exception subclasses with
# no custom __new__ or __init__ in their own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra1666.exception_new_init:
  description: "multiprocessing exception classes — __new__ and __init__ presence: ProcessError, BufferTooShort, AuthenticationError, TimeoutError are all simple Exception subclasses; none define custom __new__ or __init__ in their own __dict__; they inherit Exception.__new__ and Exception.__init__ for all construction; verified with Python 3.14.4"
  kind: python_call_eq
  category: exception_new_init
  id_prefix: mp1666ex

  columns: [id, function, args, expected]
  rows:
    - ["mp1666ex001", "multiprocessing.ProcessError.__dict__.__contains__",        ["__new__"],  false]
    - ["mp1666ex002", "multiprocessing.ProcessError.__dict__.__contains__",        ["__init__"], false]
    - ["mp1666ex003", "multiprocessing.BufferTooShort.__dict__.__contains__",      ["__new__"],  false]
    - ["mp1666ex004", "multiprocessing.BufferTooShort.__dict__.__contains__",      ["__init__"], false]
    - ["mp1666ex005", "multiprocessing.AuthenticationError.__dict__.__contains__", ["__new__"],  false]
    - ["mp1666ex006", "multiprocessing.AuthenticationError.__dict__.__contains__", ["__init__"], false]
    - ["mp1666ex007", "multiprocessing.TimeoutError.__dict__.__contains__",        ["__new__"],  false]
    - ["mp1666ex008", "multiprocessing.TimeoutError.__dict__.__contains__",        ["__init__"], false]
    - ["mp1666ex009", "multiprocessing.ProcessError.__name__.__eq__",              ["ProcessError"],        true]
    - ["mp1666ex010", "multiprocessing.ProcessError.__name__.__len__",             [],                      12]
    - ["mp1666ex011", "multiprocessing.BufferTooShort.__name__.__eq__",            ["BufferTooShort"],      true]
    - ["mp1666ex012", "multiprocessing.BufferTooShort.__name__.__len__",           [],                      14]
    - ["mp1666ex013", "multiprocessing.AuthenticationError.__name__.__eq__",       ["AuthenticationError"], true]
    - ["mp1666ex014", "multiprocessing.AuthenticationError.__name__.__len__",      [],                      19]
    - ["mp1666ex015", "multiprocessing.TimeoutError.__name__.__eq__",              ["TimeoutError"],        true]
    - ["mp1666ex016", "multiprocessing.TimeoutError.__name__.__len__",             [],                      12]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra1666
# ---------------------------------------------------------------------------

invariant multiprocessing_extra1666.process_no_own_init:
  description: "multiprocessing.Process.__dict__.__contains__('__init__') returns False — Process is the publicly-visible class created per-context (fork, spawn, forkserver); it is a thin subclass of multiprocessing.process.BaseProcess generated by the context mechanism; Process itself has no __init__ in its class __dict__; the MRO resolves __init__ to BaseProcess.__init__, which receives _target, _name, _args, _kwargs, _daemon and sets up all instance state; verified with Python 3.14.4"
  category: init_absent
  kind: python_call_eq
  function: "multiprocessing.Process.__dict__.__contains__"
  args: ["__init__"]
  expected: false

invariant multiprocessing_extra1666.baseprocess_has_init:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('__init__') returns True — BaseProcess.__init__(self, group, target, name, args, kwargs, *, daemon=None) performs all Process instance setup: it assigns _target, _name, _args, _kwargs, _popen=None, _daemonic, _authkey, _tempdir, _parent_pid, _parent_name, and _identity; this is the sole __init__ in the Process MRO that does any work; verified with Python 3.14.4"
  category: init_present
  kind: python_call_eq
  function: "multiprocessing.process.BaseProcess.__dict__.__contains__"
  args: ["__init__"]
  expected: true

invariant multiprocessing_extra1666.process_no_custom_new:
  description: "multiprocessing.Process.__dict__.__contains__('__new__') returns False — neither Process nor BaseProcess defines a custom __new__; the construction protocol is: object.__new__(ProcessSubclass) allocates the object, then BaseProcess.__init__ initialises it; this is the plain two-phase construction protocol without any customisation of the allocation step; verified with Python 3.14.4"
  category: new_absent
  kind: python_call_eq
  function: "multiprocessing.Process.__dict__.__contains__"
  args: ["__new__"]
  expected: false

invariant multiprocessing_extra1666.process_error_no_custom_new:
  description: "multiprocessing.ProcessError.__dict__.__contains__('__new__') returns False — ProcessError is a direct subclass of Exception; it carries no additional instance state and therefore needs no custom __new__; Exception.__new__ (ultimately object.__new__) is used for allocation; verified with Python 3.14.4"
  category: exception_new_absent
  kind: python_call_eq
  function: "multiprocessing.ProcessError.__dict__.__contains__"
  args: ["__new__"]
  expected: false

invariant multiprocessing_extra1666.process_error_no_custom_init:
  description: "multiprocessing.ProcessError.__dict__.__contains__('__init__') returns False — ProcessError defines no custom __init__; it inherits Exception.__init__ via the normal MRO; when ProcessError(msg) is called the message is stored via Exception.__init__; subclasses BufferTooShort, AuthenticationError, and TimeoutError follow the same pattern: no custom __init__, no custom __new__; verified with Python 3.14.4"
  category: exception_init_absent
  kind: python_call_eq
  function: "multiprocessing.ProcessError.__dict__.__contains__"
  args: ["__init__"]
  expected: false

invariant multiprocessing_extra1666.baseprocess_name_len:
  description: "multiprocessing.process.BaseProcess.__name__.__len__() == 11 — 'BaseProcess' has 11 characters (B-a-s-e-P-r-o-c-e-s-s); this confirms we are inspecting the correct internal class; BaseProcess.__name__.__len__() == 11 vs Process.__name__.__len__() == 7; the difference of 4 is exactly len('Base'); verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.process.BaseProcess.__name__.__len__"
  args: []
  expected: 11
