spec: hashlib_extra285
version: ">=3.6"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "This spec extends hashlib.zspec.zsdl through hashlib_extra284.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "hashlib_extra284.zspec.zsdl covers: sha256.update() incremental hashing; copy() behaviour; HASH object attributes (name/digest_size/block_size); sha256(b'hello world').hexdigest() known vector."
    - "This spec focuses on: sha256 file-hash pattern — sha256(b'abc').hexdigest() known vector; sha256(b'abc').digest() length == 32; sha256 name attribute == 'sha256'; sha256(b'').digest() known bytes value (first 4 bytes)."
    - "hashlib.sha256(b'abc').hexdigest() == 'ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha256(b'abc').digest() hex == 'ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad' — same 32 bytes as hexdigest. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "len(hashlib.sha256(b'abc').digest()) == 32 — SHA-256 always produces exactly 32 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha256(b'abc').name == 'sha256' — name attribute identifies the algorithm. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha256(b'').hexdigest() == 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855' — SHA-256 of empty input. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha256(b'').digest()[:4] == bytes([0xe3, 0xb0, 0xc4, 0x42]) — first 4 bytes of the empty-input digest. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "hashlib.sha256() returns a HASH object; .hexdigest() returns a lowercase hex string; .digest() returns a bytes object of length digest_size."
  stderr: "null"
  stickiness: "HASH objects carry mutable state; each test creates a fresh instance."
  codes: {}

# ---------------------------------------------------------------------------
# hashlib.sha256 — known hexdigest vectors for b'abc' and b''
# These are canonical SHA-256 test vectors (NIST FIPS 180-4 sample).
# sha256(b'abc').hexdigest() is the most widely cited single-block test vector.
# sha256(b'').hexdigest() is the SHA-256 hash of the empty message.
# ---------------------------------------------------------------------------

table hashlib_extra285.sha256_hexdigest_vectors:
  description: "hashlib.sha256() hexdigest known vectors for b'abc' and b''; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: known_vector
  id_prefix: shv285

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_abc_hex,   "sha256", [{type: bytes_ascii, value: "abc"}], "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad", "sha256(b'abc').hexdigest() — NIST FIPS 180-4 sample vector"]
    - [sha256_empty_hex, "sha256", [],                                   "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855", "sha256(b'').hexdigest() — SHA-256 of the empty message"]

# ---------------------------------------------------------------------------
# hashlib.sha256 — digest() returns bytes of the correct length
# digest() always returns exactly digest_size == 32 bytes for SHA-256.
# The length is independent of the input; it is the fixed output size of the
# hash function.
# ---------------------------------------------------------------------------

table hashlib_extra285.sha256_digest_length:
  description: "hashlib.sha256().digest() length == 32 for any input; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: output_length
  id_prefix: sdl285

  columns: [id, function, args, expected, description]
  rows:
    - [abc_digest_len,   "sha256.__call__.digest.__len__", [{type: bytes_ascii, value: "abc"}], 32, "len(sha256(b'abc').digest()) == 32 — fixed 32-byte output"]
    - [empty_digest_len, "sha256.__call__.digest.__len__", [],                                  32, "len(sha256(b'').digest()) == 32 — fixed 32-byte output for empty input"]

# ---------------------------------------------------------------------------
# hashlib.sha256 — name attribute
# The .name attribute of a HASH object returns the canonical algorithm name
# as a lowercase string.  For sha256 this is always 'sha256'.
# ---------------------------------------------------------------------------

invariant hashlib_extra285.sha256_attrs.name_abc:
  description: "hashlib.sha256(b'abc').name == 'sha256' — name attribute identifies the algorithm regardless of input; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: hash_attributes
  kind: python_call_eq
  function: sha256
  args: [{type: bytes_ascii, value: "abc"}]
  method: name.__eq__
  method_args: ["sha256"]
  expected: true

invariant hashlib_extra285.sha256_attrs.name_empty:
  description: "hashlib.sha256().name == 'sha256' — name attribute is 'sha256' even for a zero-data hash object; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: hash_attributes
  kind: python_call_eq
  function: sha256
  args: []
  method: name.__eq__
  method_args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256 — digest() bytes value for b'abc'
# The full 32-byte digest of b'abc' is a NIST test vector.
# Expressed here as the !hex literal form for the complete digest.
# ---------------------------------------------------------------------------

invariant hashlib_extra285.sha256_digest.abc_full:
  description: "hashlib.sha256(b'abc').digest() == bytes.fromhex('ba7816bf...15ad') — full 32-byte NIST test vector; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: known_vector
  kind: python_call_eq
  function: sha256
  args: [{type: bytes_ascii, value: "abc"}]
  method: digest
  method_args: []
  expected: !hex ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad

# ---------------------------------------------------------------------------
# hashlib.sha256 — digest() bytes value for b'' (empty input)
# The first 4 bytes of the empty-input digest are 0xe3 0xb0 0xc4 0x42.
# ---------------------------------------------------------------------------

invariant hashlib_extra285.sha256_digest.empty_first4:
  description: "hashlib.sha256(b'').digest()[:4] == b'\\xe3\\xb0\\xc4\\x42' — first 4 bytes of the empty-message SHA-256 digest; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: known_vector
  kind: python_call_eq
  function: sha256.__call__.digest.__getitem__
  args: [{type: bytes_ascii, value: ""}, {slice: {stop: 4}}]
  expected: !hex e3b0c442

# ---------------------------------------------------------------------------
# hashlib.sha256 — hexdigest() and digest() are consistent
# hexdigest() must equal digest().hex() — they describe the same bytes.
# Verified for b'abc'.
# ---------------------------------------------------------------------------

invariant hashlib_extra285.sha256_consistency.hexdigest_eq_digest_hex:
  description: "hashlib.sha256(b'abc').hexdigest() == hashlib.sha256(b'abc').digest().hex() — hexdigest is digest in hex form; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: consistency
  kind: python_call_eq
  function: sha256
  args: [{type: bytes_ascii, value: "abc"}]
  method: hexdigest
  method_args: []
  expected: "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"

# ---------------------------------------------------------------------------
# hashlib.sha256 — digest_size and block_size attributes
# digest_size == 32 bytes (256 bits); block_size == 64 bytes (512 bits).
# These are intrinsic properties of the SHA-256 algorithm.
# ---------------------------------------------------------------------------

invariant hashlib_extra285.sha256_attrs.digest_size:
  description: "hashlib.sha256(b'abc').digest_size == 32 — SHA-256 produces a 32-byte (256-bit) digest; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: hash_attributes
  kind: python_call_eq
  function: sha256
  args: [{type: bytes_ascii, value: "abc"}]
  method: digest_size.__eq__
  method_args: [32]
  expected: true

invariant hashlib_extra285.sha256_attrs.block_size:
  description: "hashlib.sha256(b'abc').block_size == 64 — SHA-256 uses a 64-byte (512-bit) block size; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: hash_attributes
  kind: python_call_eq
  function: sha256
  args: [{type: bytes_ascii, value: "abc"}]
  method: block_size.__eq__
  method_args: [64]
  expected: true
