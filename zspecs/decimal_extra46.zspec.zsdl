spec: decimal_extra46
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra45.zspec.zsdl — covers ROUND_HALF_DOWN/ROUND_05UP __class__.__name__=='str'; ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN __class__.__qualname__=='str'; __class__.__module__=='builtins' for ROUND_HALF_DOWN/ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN/ROUND_05UP."
    - "decimal_extra44.zspec.zsdl — covers DecimalException/InvalidOperation/DivisionByZero/Overflow __class__.__qualname__.__eq__('type'); getcontext/setcontext/localcontext __class__.__qualname__.__eq__('builtin_function_or_method')."
    - "decimal_extra42.zspec.zsdl — covers ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP/ROUND_HALF_DOWN/ROUND_05UP __class__.__qualname__.__eq__('str'); MIN_ETINY.__class__.__name__/__qualname__.__eq__('int')."
    - "decimal_extra25.zspec.zsdl — covers ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN/ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP __class__.__name__.__eq__('str'); ROUND_HALF_EVEN.__class__.__name__.__len__()==3."
    - "decimal_extra24.zspec.zsdl — covers ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP __class__.__module__.__eq__('builtins')."
    - "decimal_extra20.zspec.zsdl — covers all ROUND_* constant __len__() values."
  notes:
    - "This spec extends decimal_extra45.zspec.zsdl."
    - "Prior specs collectively covered: all ROUND_* string equality and lengths (decimal_extra/decimal_extra4/decimal_extra6/decimal_extra13/decimal_extra20); ROUND_* __class__.__name__/__qualname__/__module__ (decimal_extra23/24/25/42/45); Decimal/Context/DecimalException/InvalidOperation/DivisionByZero/Overflow __class__.__qualname__=='type' (decimal_extra44); getcontext/setcontext/localcontext __class__.__qualname__ (decimal_extra44). NO prior decimal spec checks the __doc__ attribute of any decimal class or the decimal module itself, nor the type (__class__.__name__/__qualname__) of those __doc__ strings."
    - "This spec covers: decimal.Decimal.__doc__.__class__.__name__.__eq__('str') (NOVEL — no prior decimal spec checks Decimal.__doc__ or its type; novel); decimal.Context.__doc__.__class__.__name__.__eq__('str') (NOVEL); decimal.DecimalException.__doc__.__class__.__name__.__eq__('str') (NOVEL); decimal.InvalidOperation.__doc__.__class__.__name__.__eq__('str') (NOVEL); decimal.DivisionByZero.__doc__.__class__.__name__.__eq__('str') (NOVEL); decimal.Overflow.__doc__.__class__.__name__.__eq__('str') (NOVEL); decimal.Underflow.__doc__.__class__.__name__.__eq__('str') (NOVEL); decimal.Inexact.__doc__.__class__.__name__.__eq__('str') (NOVEL); decimal.__doc__.__class__.__name__.__eq__('str') (NOVEL — module docstring type; novel); decimal.Decimal.__doc__.__class__.__qualname__.__eq__('str') (NOVEL — no prior decimal spec checks __doc__.__class__.__qualname__; novel); decimal.Context.__doc__.__class__.__qualname__.__eq__('str') (NOVEL); decimal.__doc__.__class__.__qualname__.__eq__('str') (NOVEL)."
    - "decimal.Decimal.__doc__ is a str instance. Decimal is a Python class in the decimal module; its class docstring is a plain Python str. Therefore __doc__.__class__.__name__=='str'. No prior decimal spec checks Decimal.__doc__ or its type. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Context.__doc__.__class__.__name__ == 'str'. Context is a Python class providing decimal arithmetic context; its docstring is a str. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.DecimalException.__doc__.__class__.__name__ == 'str'. DecimalException is the base exception class for the decimal module; its docstring is a str. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.InvalidOperation.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.DivisionByZero.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Overflow.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Underflow.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Inexact.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.__doc__.__class__.__name__ == 'str'. The decimal module itself has a docstring; its type is str. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Decimal.__doc__.__class__.__qualname__ == 'str'. For the builtin str type, __qualname__==__name__=='str'. Novel __qualname__ path anchor for Decimal.__doc__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Context.__doc__.__class__.__qualname__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.__doc__.__class__.__qualname__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal class __doc__.__class__.__name__ equality
#
# Every decimal class has a docstring attribute (__doc__) that is a plain
# Python str instance. Therefore for any decimal class C:
#
#   C.__doc__.__class__.__name__ == 'str'
#
# This covers the major decimal classes plus the module docstring:
#
#   decimal.Decimal.__doc__.__class__.__name__          == 'str'
#   decimal.Context.__doc__.__class__.__name__          == 'str'
#   decimal.DecimalException.__doc__.__class__.__name__ == 'str'
#   decimal.InvalidOperation.__doc__.__class__.__name__ == 'str'
#   decimal.DivisionByZero.__doc__.__class__.__name__   == 'str'
#   decimal.Overflow.__doc__.__class__.__name__         == 'str'
#   decimal.Underflow.__doc__.__class__.__name__        == 'str'
#   decimal.Inexact.__doc__.__class__.__name__          == 'str'
#   decimal.__doc__.__class__.__name__                  == 'str'
#
# No prior decimal spec checks __doc__ or its type for any decimal class.
# All nine equality anchors are novel in the decimal_extra46 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra46.class_doc_names:
  description: "decimal class __doc__.__class__.__name__.__eq__('str') for Decimal/Context/DecimalException/InvalidOperation/DivisionByZero/Overflow/Underflow/Inexact/decimal-module — every decimal class docstring is a plain str instance; no prior decimal spec checks __doc__ or its type for any decimal class; all nine novel equality anchors in decimal_extra46 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decdoc46cn

  columns: [id, function, args, expected]
  rows:
    - [Decimal_doc_class_name,          "Decimal.__doc__.__class__.__name__.__eq__",          ["str"], true]
    - [Context_doc_class_name,          "Context.__doc__.__class__.__name__.__eq__",          ["str"], true]
    - [DecimalException_doc_class_name, "DecimalException.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [InvalidOperation_doc_class_name, "InvalidOperation.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [DivisionByZero_doc_class_name,   "DivisionByZero.__doc__.__class__.__name__.__eq__",   ["str"], true]
    - [Overflow_doc_class_name,         "Overflow.__doc__.__class__.__name__.__eq__",         ["str"], true]
    - [Underflow_doc_class_name,        "Underflow.__doc__.__class__.__name__.__eq__",        ["str"], true]
    - [Inexact_doc_class_name,          "Inexact.__doc__.__class__.__name__.__eq__",          ["str"], true]
    - [module_doc_class_name,           "__doc__.__class__.__name__.__eq__",                  ["str"], true]

# ---------------------------------------------------------------------------
# decimal class __doc__.__class__.__qualname__ equality (selected)
#
# For the builtin str type, __qualname__==__name__=='str'. Therefore:
#
#   decimal.Decimal.__doc__.__class__.__qualname__ == 'str'
#   decimal.Context.__doc__.__class__.__qualname__ == 'str'
#   decimal.__doc__.__class__.__qualname__         == 'str'
#
# No prior decimal spec checks __doc__.__class__.__qualname__ for any class.
# All three equality anchors are novel in the decimal_extra46 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra46.class_doc_qualnames:
  description: "decimal class __doc__.__class__.__qualname__.__eq__('str') for Decimal/Context/decimal-module — for the builtin str type __qualname__==__name__=='str'; no prior decimal spec checks __doc__.__class__.__qualname__ for any decimal class; all three novel __qualname__ path anchors in decimal_extra46 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decdoc46cq

  columns: [id, function, args, expected]
  rows:
    - [Decimal_doc_class_qualname, "Decimal.__doc__.__class__.__qualname__.__eq__", ["str"], true]
    - [Context_doc_class_qualname, "Context.__doc__.__class__.__qualname__.__eq__", ["str"], true]
    - [module_doc_class_qualname,  "__doc__.__class__.__qualname__.__eq__",         ["str"], true]
