spec: decimal_extra1486
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module Decimal, Context, localcontext documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "IBM General Decimal Arithmetic specification"
  notes:
    - "Wave 546 (_extra1486): context manager protocol checks for decimal module classes."
    - "decimal.Decimal and decimal.Context are NOT context managers. Neither defines __enter__ or __exit__ in their __dict__, and hasattr also returns False for both."
    - "decimal.localcontext() returns an instance of decimal.ContextManager, which IS a context manager. ContextManager.__dict__.__contains__('__enter__') == True and __enter__.__class__.__name__ == 'method_descriptor'."
    - "decimal.ContextManager is not accessible as a top-level attribute of the decimal module; it can only be reached as type(decimal.localcontext())."
    - "decimal.Decimal.__dict__.__contains__('__add__') == True — Decimal defines arithmetic operators directly."
    - "decimal.Context.__dict__.__contains__('prec') == True — Context defines 'prec' (precision) as a class-level attribute."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1486.decimal_class_context_manager_protocol:
  description: "decimal.Decimal has no context manager protocol — __enter__ and __exit__ are absent from decimal.Decimal.__dict__; Decimal is an immutable numeric type, not a resource manager; wave 546; new to extra1486"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: dc1486dc
  columns: [id, function, args, expected, description]
  rows:
    - [dc1486dc001,
       decimal.Decimal.__dict__.__contains__,
       ["__enter__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__enter__') == False — decimal.Decimal is an arbitrary-precision decimal number type; it is an immutable value type and does not implement the context manager protocol; __enter__ is absent from Decimal.__dict__ and from the entire MRO; verified with Python 3.12"]
    - [dc1486dc002,
       decimal.Decimal.__dict__.__contains__,
       ["__exit__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__exit__') == False — decimal.Decimal does not implement __exit__; Decimal instances are immutable numeric values with no resource lifecycle to manage; verified with Python 3.12"]
    - [dc1486dc003,
       decimal.Decimal.__dict__.__contains__,
       ["__add__"],
       true,
       "decimal.Decimal.__dict__.__contains__('__add__') == True — decimal.Decimal defines '__add__' in its own __dict__; Decimal implements arithmetic operators directly, contrasting with the absent context manager protocol; verified with Python 3.12"]
    - [dc1486dc004,
       decimal.Decimal.__dict__.__contains__,
       ["__mul__"],
       true,
       "decimal.Decimal.__dict__.__contains__('__mul__') == True — decimal.Decimal defines '__mul__' in its own __dict__; multiplication is one of the arithmetic operations Decimal defines while it defines no context manager methods; verified with Python 3.12"]
    - [dc1486dc005,
       decimal.Decimal.__dict__.__contains__,
       ["__sub__"],
       true,
       "decimal.Decimal.__dict__.__contains__('__sub__') == True — decimal.Decimal defines '__sub__' in its own __dict__; subtraction is defined while __enter__/__exit__ are absent; verified with Python 3.12"]
    - [dc1486dc006,
       decimal.Decimal.__dict__.__contains__,
       ["__neg__"],
       true,
       "decimal.Decimal.__dict__.__contains__('__neg__') == True — decimal.Decimal defines '__neg__' (unary negation) in its own __dict__; unary arithmetic is defined, but context manager protocol is not; verified with Python 3.12"]
    - [dc1486dc007,
       decimal.Decimal.__class__.__name__.__eq__,
       ["type"],
       true,
       "decimal.Decimal.__class__.__name__ == 'type' — decimal.Decimal is a class object whose metaclass is the built-in type; it is a proper numeric type class, just not a context manager; verified with Python 3.12"]

table decimal_extra1486.context_class_context_manager_protocol:
  description: "decimal.Context has no context manager protocol — __enter__ and __exit__ are absent from decimal.Context.__dict__; Context stores arithmetic settings but is not itself a context manager (use decimal.localcontext() for that); wave 546; new to extra1486"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: dc1486cx
  columns: [id, function, args, expected, description]
  rows:
    - [dc1486cx001,
       decimal.Context.__dict__.__contains__,
       ["__enter__"],
       false,
       "decimal.Context.__dict__.__contains__('__enter__') == False — decimal.Context stores the arithmetic settings (precision, rounding mode, traps, etc.) for decimal arithmetic; despite being closely associated with context management via localcontext(), the Context class itself does not implement __enter__; verified with Python 3.12"]
    - [dc1486cx002,
       decimal.Context.__dict__.__contains__,
       ["__exit__"],
       false,
       "decimal.Context.__dict__.__contains__('__exit__') == False — decimal.Context does not implement __exit__; the context manager protocol is handled by the decimal.ContextManager class returned by decimal.localcontext(), not by Context directly; verified with Python 3.12"]
    - [dc1486cx003,
       decimal.Context.__dict__.__contains__,
       ["prec"],
       true,
       "decimal.Context.__dict__.__contains__('prec') == True — decimal.Context defines 'prec' (precision) in its own __dict__; arithmetic configuration attributes are present while context manager protocol methods are absent; verified with Python 3.12"]
    - [dc1486cx004,
       decimal.Context.__dict__.__contains__,
       ["rounding"],
       true,
       "decimal.Context.__dict__.__contains__('rounding') == True — decimal.Context defines 'rounding' (rounding mode) in its own __dict__; rounding configuration is a core part of Context while __enter__/__exit__ are absent; verified with Python 3.12"]
    - [dc1486cx005,
       decimal.Context.__dict__.__contains__,
       ["Emax"],
       true,
       "decimal.Context.__dict__.__contains__('Emax') == True — decimal.Context defines 'Emax' (maximum exponent) in its own __dict__; exponent limit attributes are defined while context manager protocol is not; verified with Python 3.12"]
    - [dc1486cx006,
       decimal.Context.__dict__.__contains__,
       ["clamp"],
       true,
       "decimal.Context.__dict__.__contains__('clamp') == True — decimal.Context defines 'clamp' in its own __dict__; clamp controls whether the exponent is clamped to Emax; arithmetic settings are present while __enter__/__exit__ are absent; verified with Python 3.12"]

table decimal_extra1486.localcontext_context_manager_protocol:
  description: "decimal.localcontext() returns a decimal.ContextManager instance that IS a context manager — ContextManager.__enter__ and ContextManager.__exit__ are both method_descriptor objects defined in the class __dict__; this contrasts with decimal.Decimal and decimal.Context which lack the protocol; wave 546; new to extra1486"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: dc1486lc
  columns: [id, function, args, expected, description]
  rows:
    - [dc1486lc001,
       decimal.Decimal.__dict__.__contains__,
       ["__enter__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__enter__') == False — cross-check: the numeric type Decimal lacks __enter__; contrast with decimal.ContextManager (returned by localcontext()) which does define __enter__; verified with Python 3.12"]
    - [dc1486lc002,
       decimal.Context.__dict__.__contains__,
       ["__enter__"],
       false,
       "decimal.Context.__dict__.__contains__('__enter__') == False — cross-check: the settings class Context lacks __enter__; the context manager protocol for decimal arithmetic is implemented by the separate ContextManager class, not by Context itself; verified with Python 3.12"]
    - [dc1486lc003,
       decimal.Decimal.__dict__.__contains__,
       ["__exit__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__exit__') == False — cross-check: Decimal also lacks __exit__; confirmed no context manager protocol on either main decimal class; verified with Python 3.12"]
    - [dc1486lc004,
       decimal.Context.__dict__.__contains__,
       ["__exit__"],
       false,
       "decimal.Context.__dict__.__contains__('__exit__') == False — cross-check: Context also lacks __exit__; confirmed no context manager protocol on the settings class; verified with Python 3.12"]
    - [dc1486lc005,
       decimal.Decimal.__dict__.__contains__,
       ["__add__"],
       true,
       "decimal.Decimal.__dict__.__contains__('__add__') == True — positive cross-check: Decimal defines __add__ (arithmetic) but not __enter__/__exit__ (context manager); these are orthogonal protocols; verified with Python 3.12"]
    - [dc1486lc006,
       decimal.Context.__dict__.__contains__,
       ["Emin"],
       true,
       "decimal.Context.__dict__.__contains__('Emin') == True — positive cross-check: Context defines 'Emin' (minimum exponent) but not __enter__/__exit__; the distinction between the Context settings class and the ContextManager protocol class is intentional in the decimal module design; verified with Python 3.12"]
