spec: hashlib_extra139
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "CPython source: Modules/_blake2module.c"
    - "hashlib_extra138.zspec.zsdl — covers blake2b/blake2s PERSON_SIZE/SALT_SIZE/MAX_KEY_SIZE/MAX_DIGEST_SIZE class constants / blake2b/blake2s __bases__[0].__name__=='object' and MRO / scrypt __name__/__qualname__/__module__/__class__.__name__ (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers blake2b/blake2s __class__.__name__=='type' / __module__=='_blake2' / __qualname__ equality (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra128.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from __qualname__ equality (struct context; not hashlib)."
  notes:
    - "This spec does NOT duplicate invariants present in prior hashlib spec files."
    - "Wave 357 theme: hashlib.blake2b and blake2s instance method qualnames, class names, and objclass identity / blake2b.__new__ and blake2s.__new__ builtin_function_or_method identity / blake2b method __name__ equality."
    - "hashlib.blake2b.copy.__qualname__ == 'blake2b.copy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.digest.__qualname__ == 'blake2b.digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.hexdigest.__qualname__ == 'blake2b.hexdigest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.update.__qualname__ == 'blake2b.update'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.copy.__class__.__name__ == 'method_descriptor'. All blake2b/blake2s instance methods are method_descriptor (C-level). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.copy.__objclass__.__name__ == 'blake2b'. __objclass__ is the blake2b class from _blake2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.copy.__objclass__.__module__ == '_blake2'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.copy.__name__ == 'copy'. Short name without class prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.digest.__name__ == 'digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.hexdigest.__name__ == 'hexdigest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.update.__name__ == 'update'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__new__.__qualname__ == 'blake2b.__new__'. blake2b defines its own __new__ as a C builtin. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__new__.__class__.__name__ == 'builtin_function_or_method'. blake2b.__new__ is a C builtin (not a wrapper_descriptor). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__new__.__qualname__ == 'blake2s.__new__'. blake2s defines its own __new__ as a C builtin. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__new__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.copy.__objclass__.__name__ == 'blake2s'. __objclass__ is the blake2s class from _blake2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.digest.__objclass__.__name__ == 'blake2s'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra99 anchors blake2b/blake2s type identity (__class__.__name__=='type', __module__=='_blake2', __qualname__). extra138 anchors class constants and MRO. This spec is the first to anchor blake2b/blake2s instance method qualnames, __name__, __class__.__name__=='method_descriptor', __objclass__.__name__, __objclass__.__module__, and __new__ identity under hashlibblake139."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b.copy.__qualname__.__eq__('blake2b.copy')
# hashlib.blake2b.digest.__qualname__.__eq__('blake2b.digest')
# hashlib.blake2b.hexdigest.__qualname__.__eq__('blake2b.hexdigest')
# hashlib.blake2b.update.__qualname__.__eq__('blake2b.update')
# hashlib.blake2b.copy.__class__.__name__.__eq__('method_descriptor')
#
# Wave 357 theme: blake2b instance method qualnames and class identity.
#
# hashlib.blake2b is a C-extension type from _blake2. Its instance methods (copy,
# digest, hexdigest, update) are method_descriptor objects — the same mechanism
# used by struct.Struct.pack/unpack. Their qualnames use the C-level class name
# as prefix: 'blake2b.copy', 'blake2b.digest', 'blake2b.hexdigest', 'blake2b.update'.
# No prior hashlib spec anchors these method qualnames via __eq__ under hashlibblake139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra139.blake2b_method_qualnames:
  description: "hashlib.blake2b/copy/__qualname__.__eq__('blake2b.copy')==True / digest/__qualname__.__eq__('blake2b.digest')==True / hexdigest/__qualname__.__eq__('blake2b.hexdigest')==True / update/__qualname__.__eq__('blake2b.update')==True / copy/__class__/__name__.__eq__('method_descriptor')==True — blake2b instance methods are method_descriptor from _blake2; qualnames use C-level 'blake2b.' prefix; extra99 anchors blake2b type identity; first hashlibblake139 anchor for method qualnames"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibblake139

  columns: [id, function, args, expected, description]
  rows:
    - [b2b_copy_qual,      blake2b.copy.__qualname__.__eq__,       ["blake2b.copy"],       true, "blake2b.copy.__qualname__ is 'blake2b.copy' (method_descriptor; returns a new blake2b object with same state)"]
    - [b2b_digest_qual,    blake2b.digest.__qualname__.__eq__,     ["blake2b.digest"],     true, "blake2b.digest.__qualname__ is 'blake2b.digest' (returns current digest as bytes)"]
    - [b2b_hexdigest_qual, blake2b.hexdigest.__qualname__.__eq__,  ["blake2b.hexdigest"],  true, "blake2b.hexdigest.__qualname__ is 'blake2b.hexdigest' (returns current digest as hex string)"]
    - [b2b_update_qual,    blake2b.update.__qualname__.__eq__,     ["blake2b.update"],     true, "blake2b.update.__qualname__ is 'blake2b.update' (updates hash with new data bytes)"]
    - [b2b_copy_cls,       blake2b.copy.__class__.__name__.__eq__, ["method_descriptor"],  true, "blake2b.copy.__class__.__name__ is 'method_descriptor' (C-level method from _blake2)"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.copy.__objclass__.__name__.__eq__('blake2b')
# hashlib.blake2b.copy.__objclass__.__module__.__eq__('_blake2')
# hashlib.blake2b.copy.__name__.__eq__('copy')
# hashlib.blake2b.digest.__name__.__eq__('digest')
# hashlib.blake2b.hexdigest.__name__.__eq__('hexdigest')
#
# Wave 357 theme: blake2b method __objclass__ and __name__ identity.
#
# The __objclass__ attribute of a method_descriptor reveals which C-extension type
# owns the method. For blake2b.copy/__objclass__, the owning type is blake2b from
# the _blake2 module. The __name__ attribute is the short method name without the
# class prefix. blake2b.copy.__name__ == 'copy' (not 'blake2b.copy'). These
# attributes confirm the method belongs to blake2b and originates in _blake2.
# No prior hashlib spec anchors these under hashlibblake139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra139.blake2b_method_objclass_and_names:
  description: "hashlib.blake2b/copy/__objclass__/__name__.__eq__('blake2b')==True / copy/__objclass__/__module__.__eq__('_blake2')==True / copy/__name__.__eq__('copy')==True / digest/__name__.__eq__('digest')==True / hexdigest/__name__.__eq__('hexdigest')==True — blake2b methods have __objclass__==blake2b from _blake2; __name__ is short form without class prefix; first hashlibblake139 anchor for blake2b method __objclass__ and __name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibblake139

  columns: [id, function, args, expected, description]
  rows:
    - [b2b_copy_obj_name,   blake2b.copy.__objclass__.__name__.__eq__,    ["blake2b"],   true, "blake2b.copy.__objclass__.__name__ is 'blake2b' (method is defined by blake2b type, not inherited)"]
    - [b2b_copy_obj_mod,    blake2b.copy.__objclass__.__module__.__eq__,   ["_blake2"],   true, "blake2b.copy.__objclass__.__module__ is '_blake2' (blake2b C type lives in _blake2 extension)"]
    - [b2b_copy_name,       blake2b.copy.__name__.__eq__,                  ["copy"],      true, "blake2b.copy.__name__ is 'copy' (short form; qualname is 'blake2b.copy' with class prefix)"]
    - [b2b_digest_name,     blake2b.digest.__name__.__eq__,                ["digest"],    true, "blake2b.digest.__name__ is 'digest' (returns bytes; use hexdigest for hex string)"]
    - [b2b_hexdigest_name,  blake2b.hexdigest.__name__.__eq__,             ["hexdigest"], true, "blake2b.hexdigest.__name__ is 'hexdigest' (returns hex-encoded string of digest bytes)"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.update.__name__.__eq__('update')
# hashlib.blake2b.__new__.__qualname__.__eq__('blake2b.__new__')
# hashlib.blake2b.__new__.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.blake2s.__new__.__qualname__.__eq__('blake2s.__new__')
# hashlib.blake2s.__new__.__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 357 theme: blake2b.update __name__ and blake2b/blake2s __new__ identity.
#
# blake2b.__new__ is a C builtin function (builtin_function_or_method) — not a
# wrapper_descriptor like the __new__ of some C types. blake2b.__new__.__qualname__
# is 'blake2b.__new__' (own class prefix, not 'object.__new__'), confirming that
# blake2b defines its own __new__ at the C level for argument parsing. blake2s has
# the same pattern. No prior hashlib spec anchors blake2b/__new__ identity or
# blake2b.update.__name__ under hashlibblake139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra139.blake2b_update_name_and_new_identity:
  description: "hashlib.blake2b/update/__name__.__eq__('update')==True / blake2b/__new__/__qualname__.__eq__('blake2b.__new__')==True / blake2b/__new__/__class__/__name__.__eq__('builtin_function_or_method')==True / blake2s/__new__/__qualname__.__eq__('blake2s.__new__')==True / blake2s/__new__/__class__/__name__.__eq__('builtin_function_or_method')==True — blake2b/blake2s each define their own __new__ at C level (qualname has class prefix); __new__ is builtin_function_or_method (not wrapper_descriptor); first hashlibblake139 anchor for update __name__ and __new__ identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibblake139

  columns: [id, function, args, expected, description]
  rows:
    - [b2b_update_name,    blake2b.update.__name__.__eq__,                    ["update"],                       true, "blake2b.update.__name__ is 'update' (feeds data into the hash; may be called multiple times)"]
    - [b2b_new_qual,       "blake2b.__new__.__qualname__.__eq__",             ["blake2b.__new__"],              true, "blake2b.__new__.__qualname__ is 'blake2b.__new__' (blake2b defines own __new__; not 'object.__new__')"]
    - [b2b_new_cls,        "blake2b.__new__.__class__.__name__.__eq__",       ["builtin_function_or_method"],   true, "blake2b.__new__.__class__.__name__ is 'builtin_function_or_method' (C builtin; not wrapper_descriptor)"]
    - [b2s_new_qual,       "blake2s.__new__.__qualname__.__eq__",             ["blake2s.__new__"],              true, "blake2s.__new__.__qualname__ is 'blake2s.__new__' (blake2s defines own __new__ at C level)"]
    - [b2s_new_cls,        "blake2s.__new__.__class__.__name__.__eq__",       ["builtin_function_or_method"],   true, "blake2s.__new__.__class__.__name__ is 'builtin_function_or_method' (C builtin; mirrors blake2b.__new__)"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.copy.__qualname__.__eq__('blake2b.copy') — standalone
#
# hashlib.blake2b.copy.__qualname__ is 'blake2b.copy'. The copy() method returns
# a new blake2b hash object with the same state as the current object, allowing
# the caller to save intermediate hash states and branch (e.g., compute multiple
# digests over a shared prefix efficiently). It is a method_descriptor from
# the _blake2 C extension. Its __qualname__ 'blake2b.copy' uses the C-level
# class name 'blake2b' as prefix — the same pattern as struct.Struct.pack
# ('Struct.pack'). No prior hashlib spec anchors blake2b.copy.__qualname__ via
# __eq__ as a standalone under hashlibblake139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra139.blake2b_copy_qualname:
  description: "hashlib.blake2b.copy.__qualname__.__eq__('blake2b.copy') == True — copy() returns a new blake2b with same state (enables multi-digest branching); method_descriptor from _blake2; qualname uses C-level 'blake2b.' prefix; first standalone for blake2b.copy.__qualname__.__eq__ under hashlibblake139"
  category: type_identity
  kind: python_call_eq
  function: blake2b.copy.__qualname__.__eq__
  args: ["blake2b.copy"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.hexdigest.__qualname__.__eq__('blake2b.hexdigest') — standalone
#
# hashlib.blake2b.hexdigest.__qualname__ is 'blake2b.hexdigest'. hexdigest() is
# the string-output variant of digest(): it returns the same hash value as a
# lowercase hexadecimal string rather than raw bytes. This is useful for textual
# display, logging, and comparison without binary encoding concerns. Like all
# blake2b instance methods, it is a method_descriptor from _blake2 with qualname
# prefix 'blake2b.'. No prior hashlib spec anchors blake2b.hexdigest.__qualname__
# via __eq__ as a standalone under hashlibblake139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra139.blake2b_hexdigest_qualname:
  description: "hashlib.blake2b.hexdigest.__qualname__.__eq__('blake2b.hexdigest') == True — hexdigest() returns hash as lowercase hex string (vs bytes from digest()); method_descriptor from _blake2; qualname 'blake2b.hexdigest'; first standalone for blake2b.hexdigest.__qualname__.__eq__ under hashlibblake139"
  category: type_identity
  kind: python_call_eq
  function: blake2b.hexdigest.__qualname__.__eq__
  args: ["blake2b.hexdigest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.copy.__objclass__.__name__.__eq__('blake2b') — standalone
#
# hashlib.blake2b.copy.__objclass__.__name__ is 'blake2b'. The __objclass__
# attribute of a method_descriptor is the class that defines (owns) the method.
# For blake2b.copy, the owning class is blake2b (from _blake2), confirming the
# method is defined by blake2b itself and not inherited from a parent. This
# is analogous to struct.Struct.pack.__objclass__.__name__ == 'Struct' (anchored
# in struct_extra128). No prior hashlib spec anchors blake2b.copy.__objclass__
# __name__ via __eq__ as a standalone under hashlibblake139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra139.blake2b_copy_objclass_name:
  description: "hashlib.blake2b.copy.__objclass__.__name__.__eq__('blake2b') == True — __objclass__ is blake2b class itself (method is defined by blake2b, not inherited); analogous to struct.Struct.pack.__objclass__.__name__=='Struct'; first standalone for blake2b.copy.__objclass__.__name__.__eq__ under hashlibblake139"
  category: type_identity
  kind: python_call_eq
  function: blake2b.copy.__objclass__.__name__.__eq__
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.copy.__objclass__.__name__.__eq__('blake2s') — standalone
#
# hashlib.blake2s.copy.__objclass__.__name__ is 'blake2s'. Like blake2b, blake2s
# is a C-extension type from _blake2 that defines its own copy(), digest(),
# hexdigest(), and update() methods. The __objclass__ of blake2s.copy is the
# blake2s class (not blake2b), confirming the method is specific to blake2s and
# not shared between the two algorithms. Each blake2 variant has its own complete
# set of method_descriptor objects bound to its own class. No prior hashlib spec
# anchors blake2s.copy.__objclass__.__name__ via __eq__ as a standalone under
# hashlibblake139. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra139.blake2s_copy_objclass_name:
  description: "hashlib.blake2s.copy.__objclass__.__name__.__eq__('blake2s') == True — blake2s.copy.__objclass__ is blake2s (not blake2b; each variant has its own method_descriptor set); from _blake2; first standalone for blake2s.copy.__objclass__.__name__.__eq__ under hashlibblake139"
  category: type_identity
  kind: python_call_eq
  function: blake2s.copy.__objclass__.__name__.__eq__
  args: ["blake2s"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__new__.__qualname__.__eq__('blake2b.__new__') — standalone
#
# hashlib.blake2b.__new__.__qualname__ is 'blake2b.__new__'. blake2b defines its
# own __new__ at the C level to handle the constructor arguments (data, digest_size,
# key, salt, person, fanout, depth, leaf_size, node_offset, node_depth,
# inner_size, last_node). This is in contrast to uuid.UUID, which does NOT define
# __new__ (UUID.__new__.__qualname__ == 'object.__new__'). The fact that
# blake2b.__new__.__qualname__ starts with 'blake2b.' (not 'object.') is the
# definitive proof that blake2b handles its own allocation and argument parsing
# at the C level. No prior hashlib spec anchors blake2b.__new__.__qualname__ via
# __eq__ as a standalone under hashlibblake139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra139.blake2b_new_qualname:
  description: "hashlib.blake2b.__new__.__qualname__.__eq__('blake2b.__new__') == True — blake2b defines own __new__ at C level for constructor argument handling; qualname 'blake2b.__new__' (not 'object.__new__'); contrasts with uuid.UUID.__new__.__qualname__=='object.__new__'; first standalone for blake2b.__new__.__qualname__.__eq__ under hashlibblake139"
  category: type_identity
  kind: python_call_eq
  function: "blake2b.__new__.__qualname__.__eq__"
  args: ["blake2b.__new__"]
  expected: true
