spec: inspect_extra166
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Parameter.__name__ 'Parameter' (cross-check, also in extra164); inspect.Parameter.__module__ 'inspect' (cross-check); inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ '_ParameterKind'; inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ '_ParameterKind'; inspect.Parameter.VAR_POSITIONAL.__class__.__name__ '_ParameterKind'; inspect.Parameter.KEYWORD_ONLY.__class__.__name__ '_ParameterKind'; inspect.Parameter.VAR_KEYWORD.__class__.__name__ '_ParameterKind' (Wave 295)."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — inspect.Parameter.POSITIONAL_ONLY is an enum member of the _ParameterKind enum defined in Lib/inspect.py; its __class__ is _ParameterKind; __class__.__name__ is '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind' — POSITIONAL_OR_KEYWORD is an enum member of _ParameterKind (value 1); its __class__.__name__ is '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind' — VAR_POSITIONAL is an enum member of _ParameterKind (value 2); it represents *args parameters; its __class__.__name__ is '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind' — KEYWORD_ONLY is an enum member of _ParameterKind (value 3); it represents keyword-only parameters following *; its __class__.__name__ is '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind' — VAR_KEYWORD is an enum member of _ParameterKind (value 4); it represents **kwargs parameters; its __class__.__name__ is '_ParameterKind'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter class identity (cross-check) and POSITIONAL_ONLY
#
# Wave 295 theme: inspect.Parameter class identity and the POSITIONAL_ONLY
# kind constant — its class name and value.
#
# inspect.Parameter.__name__ == 'Parameter'
# inspect.Parameter.__module__ == 'inspect'
# inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.POSITIONAL_ONLY.value == 0
#
# inspect.Parameter is the Python class in Lib/inspect.py that represents a
# single parameter in a function's signature. It has five class-level kind
# constants (POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL,
# KEYWORD_ONLY, VAR_KEYWORD) that are enum members of the _ParameterKind enum.
# POSITIONAL_ONLY (value 0) represents parameters that can only be supplied
# positionally (before a / separator in the signature). New to extra166.
# ---------------------------------------------------------------------------

table inspect_extra166.parameter_identity_and_positional_only:
  description: "inspect.Parameter: __name__ 'Parameter', __module__ 'inspect', POSITIONAL_ONLY.__class__.__name__ '_ParameterKind'; wave 295; new to extra166"
  kind: python_call_eq
  category: identity
  id_prefix: inspectpipo166

  columns: [id, function, args, expected, description]
  rows:
    - [param_name_parameter,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — inspect.Parameter is the Python class in Lib/inspect.py representing a single function parameter with attributes name/default/annotation/kind; its class __name__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra166"]
    - [param_module_inspect,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — inspect.Parameter is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra166"]
    - [pos_only_cls_name,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is an enum member of the _ParameterKind enum defined in Lib/inspect.py; it represents parameters that can only be supplied positionally (before / in the signature); its __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra166"]
    - [pos_only_cls_not_int,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__",
       ["int"],
       false,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('int') == False — POSITIONAL_ONLY is a _ParameterKind enum member, NOT an int; its __class__.__name__ is '_ParameterKind', not 'int'; str.__eq__('int') returns False; new to extra166"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter.POSITIONAL_OR_KEYWORD and VAR_POSITIONAL kinds
#
# Wave 295 theme: inspect.Parameter kind constants — POSITIONAL_OR_KEYWORD
# and VAR_POSITIONAL are both _ParameterKind enum members.
#
# inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.POSITIONAL_OR_KEYWORD.value == 1
# inspect.Parameter.VAR_POSITIONAL.value == 2
#
# POSITIONAL_OR_KEYWORD (value 1) represents parameters that can be supplied
# either positionally or as a keyword argument — the default for most Python
# function parameters. VAR_POSITIONAL (value 2) represents the *args variadic
# positional parameter. Both are _ParameterKind enum members defined in
# Lib/inspect.py. New to extra166.
# ---------------------------------------------------------------------------

table inspect_extra166.positional_or_keyword_and_var_positional_kinds:
  description: "inspect.Parameter: POSITIONAL_OR_KEYWORD and VAR_POSITIONAL __class__.__name__ '_ParameterKind'; wave 295; new to extra166"
  kind: python_call_eq
  category: identity
  id_prefix: inspectpkpv166

  columns: [id, function, args, expected, description]
  rows:
    - [pos_or_kw_cls_name,
       "Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_OR_KEYWORD (value 1) is an enum member of _ParameterKind representing parameters that may be supplied positionally or by keyword; its __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra166"]
    - [var_pos_cls_name,
       "Parameter.VAR_POSITIONAL.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__('_ParameterKind') == True — VAR_POSITIONAL (value 2) is an enum member of _ParameterKind representing a *args variadic positional parameter; its __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra166"]
    - [pos_or_kw_cls_not_str,
       "Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__",
       ["str"],
       false,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('str') == False — POSITIONAL_OR_KEYWORD is a _ParameterKind enum member, not a str; __class__.__name__ is '_ParameterKind', not 'str'; str.__eq__('str') returns False; new to extra166"]
    - [var_pos_cls_not_type,
       "Parameter.VAR_POSITIONAL.__class__.__name__.__eq__",
       ["type"],
       false,
       "inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__('type') == False — VAR_POSITIONAL is an enum member instance, not a class; __class__.__name__ is '_ParameterKind', not 'type'; str.__eq__('type') returns False; new to extra166"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter.KEYWORD_ONLY and VAR_KEYWORD kinds
#
# Wave 295 theme: inspect.Parameter kind constants — KEYWORD_ONLY and
# VAR_KEYWORD are both _ParameterKind enum members.
#
# inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.KEYWORD_ONLY.value == 3
# inspect.Parameter.VAR_KEYWORD.value == 4
#
# KEYWORD_ONLY (value 3) represents parameters that must be supplied as
# keyword arguments (following a * or *args in the signature). VAR_KEYWORD
# (value 4) represents the **kwargs variadic keyword parameter. Both are
# _ParameterKind enum members defined in Lib/inspect.py. New to extra166.
# ---------------------------------------------------------------------------

table inspect_extra166.keyword_only_and_var_keyword_kinds:
  description: "inspect.Parameter: KEYWORD_ONLY and VAR_KEYWORD __class__.__name__ '_ParameterKind'; wave 295; new to extra166"
  kind: python_call_eq
  category: identity
  id_prefix: inspectpkkv166

  columns: [id, function, args, expected, description]
  rows:
    - [kw_only_cls_name,
       "Parameter.KEYWORD_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — KEYWORD_ONLY (value 3) is an enum member of _ParameterKind representing parameters that must be supplied as keyword arguments (those following a * or *args separator in the signature); its __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra166"]
    - [var_kw_cls_name,
       "Parameter.VAR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — VAR_KEYWORD (value 4) is an enum member of _ParameterKind representing a **kwargs variadic keyword parameter; its __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra166"]
    - [kw_only_cls_not_function,
       "Parameter.KEYWORD_ONLY.__class__.__name__.__eq__",
       ["function"],
       false,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('function') == False — KEYWORD_ONLY is a _ParameterKind enum member, not a function; __class__.__name__ is '_ParameterKind', not 'function'; str.__eq__('function') returns False; new to extra166"]
    - [var_kw_cls_not_function,
       "Parameter.VAR_KEYWORD.__class__.__name__.__eq__",
       ["function"],
       false,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('function') == False — VAR_KEYWORD is a _ParameterKind enum member, not a function; __class__.__name__ is '_ParameterKind', not 'function'; str.__eq__('function') returns False; new to extra166"]

# ---------------------------------------------------------------------------
# Table 4: All five _ParameterKind kinds share the same __class__.__name__
#
# Wave 295 theme: cross-check that all five kind constants on inspect.Parameter
# have the same __class__.__name__ value ('_ParameterKind') — demonstrating
# they all belong to the same enum.
#
# POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY,
# VAR_KEYWORD all have __class__.__name__ == '_ParameterKind'
# POSITIONAL_ONLY.__class__.__name__ != 'type'
# POSITIONAL_ONLY.__class__ is same as KEYWORD_ONLY.__class__
#   (cross-check via __name__ equality)
#
# All five constants on inspect.Parameter are members of the same
# _ParameterKind IntEnum defined in Lib/inspect.py. They form a complete
# and exclusive set of possible parameter kinds. New to extra166.
# ---------------------------------------------------------------------------

table inspect_extra166.all_parameter_kinds_same_class:
  description: "inspect.Parameter: all five kind constants have __class__.__name__ '_ParameterKind'; cross-checks; wave 295; new to extra166"
  kind: python_call_eq
  category: identity
  id_prefix: inspectapkc166

  columns: [id, function, args, expected, description]
  rows:
    - [pos_only_cls_param_kind,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is a _ParameterKind enum member (value 0); all five kind constants share __class__.__name__ '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra166"]
    - [pos_or_kw_cls_param_kind,
       "Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_OR_KEYWORD is a _ParameterKind enum member (value 1); all five kind constants share __class__.__name__ '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra166"]
    - [var_pos_cls_param_kind,
       "Parameter.VAR_POSITIONAL.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__('_ParameterKind') == True — VAR_POSITIONAL is a _ParameterKind enum member (value 2); all five kind constants share __class__.__name__ '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra166"]
    - [kw_only_cls_param_kind,
       "Parameter.KEYWORD_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — KEYWORD_ONLY is a _ParameterKind enum member (value 3); all five kind constants share __class__.__name__ '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra166"]
    - [var_kw_cls_param_kind,
       "Parameter.VAR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — VAR_KEYWORD is a _ParameterKind enum member (value 4); all five kind constants share __class__.__name__ '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra166"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra166
# ---------------------------------------------------------------------------

invariant inspect_extra166.positional_only_class_parameter_kind:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — enum member for positional-only parameters (value 0, before / in signature); wave 295; new to extra166"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra166.positional_or_keyword_class_parameter_kind:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind' — enum member for parameters that may be positional or keyword (value 1, default kind); wave 295; new to extra166"
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra166.var_positional_class_parameter_kind:
  description: "inspect.Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind' — enum member for *args parameters (value 2); wave 295; new to extra166"
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra166.keyword_only_class_parameter_kind:
  description: "inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind' — enum member for keyword-only parameters following * (value 3); wave 295; new to extra166"
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra166.var_keyword_class_parameter_kind:
  description: "inspect.Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind' — enum member for **kwargs parameters (value 4); wave 295; new to extra166"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra166.positional_only_class_not_int:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ != 'int' — POSITIONAL_ONLY is a _ParameterKind enum member, not a plain int; wave 295; new to extra166"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__
  args: ["int"]
  expected: false

invariant inspect_extra166.var_keyword_class_not_type:
  description: "inspect.Parameter.VAR_KEYWORD.__class__.__name__ != 'type' — VAR_KEYWORD is an enum member instance, not a class; wave 295; new to extra166"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.__class__.__name__.__eq__
  args: ["type"]
  expected: false

invariant inspect_extra166.parameter_name_parameter_cross_check:
  description: "inspect.Parameter.__name__ == 'Parameter' — cross-check confirming Parameter class identity alongside kind constants; wave 295; new to extra166"
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

