spec: threading_extra2581
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2581 (_extra2581): __call__ dict-presence checks — callable functor classification."
    - "No threading class defines __call__ in its own __dict__. Threading primitives are context managers and lifecycle objects, not callable functors."
    - "threading.Thread is callable as a constructor (type.__call__ inherited) but Thread instances are started via .start(), not called."
    - "threading.Lock is a factory function (not a type) returning a _thread.lock object; the lock type itself does not define __call__."
    - "threading.Semaphore, threading.BoundedSemaphore, threading.Condition, threading.Barrier are all pure-Python classes with no __call__ override."
    - "threading.Event is a pure-Python class; events are set/cleared via .set()/.clear(), not by calling the object."
    - "threading.Timer subclasses Thread; it also does not define __call__."
    - "threading.local is a C extension type for thread-local storage; no __call__ in its __dict__."
    - "threading._RLock is the pure-Python reentrant lock fallback (alongside the C-accelerated _CRLock); neither defines __call__."
    - "threading.ExceptHookArgs and threading.BrokenBarrierError are data/exception types with no __call__ override."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __call__ dict-presence — threading synchronization primitives
#
# The core threading synchronization primitives (Lock, RLock, Semaphore,
# BoundedSemaphore, Condition, Event, Barrier) are context managers and
# state machines.  None define __call__ in their own __dict__; they are
# used via acquire()/release(), with-blocks, or wait()/set() methods.
# ---------------------------------------------------------------------------

table threading_extra2581.call_absent_primitives:
  description: "threading synchronization primitives __call__ dict-presence — wave 2581"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2581

  columns: [id, function, args, expected]
  rows:
    - ["th2581001", "threading.Lock.__dict__.__contains__", ["__call__"], false]
    - ["th2581002", "threading.Semaphore.__dict__.__contains__", ["__call__"], false]
    - ["th2581003", "threading.BoundedSemaphore.__dict__.__contains__", ["__call__"], false]
    - ["th2581004", "threading.Condition.__dict__.__contains__", ["__call__"], false]
    - ["th2581005", "threading.Event.__dict__.__contains__", ["__call__"], false]
    - ["th2581006", "threading.Barrier.__dict__.__contains__", ["__call__"], false]
    - ["th2581007", "threading._RLock.__dict__.__contains__", ["__call__"], false]

# ---------------------------------------------------------------------------
# Table 2: __call__ dict-presence — threading thread and timer classes
#
# threading.Thread and threading.Timer are the primary threading execution
# classes.  Thread instances are started with .start() and joined with
# .join(); they are lifecycle objects, not callable functors.  Timer
# subclasses Thread to add a delay before execution.  Neither defines
# __call__ in its own __dict__.
# ---------------------------------------------------------------------------

table threading_extra2581.call_absent_thread_classes:
  description: "threading Thread and Timer __call__ dict-presence — wave 2581"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2581

  columns: [id, function, args, expected]
  rows:
    - ["th2581008", "threading.Thread.__dict__.__contains__", ["__call__"], false]
    - ["th2581009", "threading.Timer.__dict__.__contains__", ["__call__"], false]
    - ["th2581010", "threading._MainThread.__dict__.__contains__", ["__call__"], false]
    - ["th2581011", "threading._DummyThread.__dict__.__contains__", ["__call__"], false]

# ---------------------------------------------------------------------------
# Table 3: __call__ dict-presence — threading storage and exception types
#
# threading.local is a C extension type providing thread-local storage.
# threading.ExceptHookArgs is a namedtuple for unhandled thread exceptions.
# threading.BrokenBarrierError is the exception raised by a broken Barrier.
# threading._LockType is the C-level lock type alias.
# None define __call__ in their own __dict__.
# ---------------------------------------------------------------------------

table threading_extra2581.call_absent_misc:
  description: "threading storage, exception, and utility types __call__ dict-presence — wave 2581"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2581

  columns: [id, function, args, expected]
  rows:
    - ["th2581012", "threading.local.__dict__.__contains__", ["__call__"], false]
    - ["th2581013", "threading.ExceptHookArgs.__dict__.__contains__", ["__call__"], false]
    - ["th2581014", "threading.BrokenBarrierError.__dict__.__contains__", ["__call__"], false]
    - ["th2581015", "threading._LockType.__dict__.__contains__", ["__call__"], false]
    - ["th2581016", "threading._CRLock.__dict__.__contains__", ["__call__"], false]
    - ["th2581017", "threading.ThreadError.__dict__.__contains__", ["__call__"], false]
