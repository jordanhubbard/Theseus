spec: itertools_extra1786
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module reference"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools.zspec.zsdl — covers class __name__ checks and first_element tests"
    - "itertools_extra.zspec.zsdl — covers filterfalse classname, chain/repeat/islice length_hint and first_element"
  notes:
    - "Wave 566 theme: __class_getitem__ and __init_subclass__ class creation hooks (PEP 487/585)."
    - "PEP 585 (Python 3.9+) added __class_getitem__ to itertools C types to support generic alias syntax, e.g. itertools.chain[int]."
    - "itertools.chain.__dict__.__contains__('__class_getitem__') == True — C extension type with PEP 585 generic support."
    - "itertools.count.__dict__.__contains__('__class_getitem__') == True — C extension type with PEP 585 generic support."
    - "itertools.cycle.__dict__.__contains__('__class_getitem__') == True — C extension type with PEP 585 generic support."
    - "itertools.repeat.__dict__.__contains__('__class_getitem__') == True — C extension type with PEP 585 generic support."
    - "itertools.islice.__dict__.__contains__('__class_getitem__') == True — C extension type with PEP 585 generic support."
    - "itertools.accumulate.__dict__.__contains__('__class_getitem__') == True — C extension type with PEP 585 generic support."
    - "itertools.compress.__dict__.__contains__('__class_getitem__') == True — C extension type with PEP 585 generic support."
    - "itertools.product.__dict__.__contains__('__class_getitem__') == True — C extension type with PEP 585 generic support."
    - "itertools.combinations.__dict__.__contains__('__class_getitem__') == True — C extension type with PEP 585 generic support."
    - "itertools.permutations.__dict__.__contains__('__class_getitem__') == True — C extension type with PEP 585 generic support."
    - "None of the itertools C types define __init_subclass__ in their own __dict__; that dunder is inherited from object."
    - "None of the itertools C types define __subclasshook__ in their own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __class_getitem__ presence in itertools C types
#
# PEP 585 (Python 3.9+) added __class_getitem__ to itertools C extension
# types, enabling generic alias syntax such as itertools.chain[int].
# All itertools types updated in 3.9 define __class_getitem__ in their
# own __dict__ as a classmethod_descriptor.
# ---------------------------------------------------------------------------

table itertools_extra1786.class_getitem_presence:
  description: "Which itertools C types define __class_getitem__ in their own __dict__ (PEP 585, Python 3.9+)"
  kind: python_call_eq
  category: class_creation_hooks
  id_prefix: it1786

  columns: [id, function, args, expected]
  rows:
    - ["it1786001", itertools.chain.__dict__.__contains__,        ["__class_getitem__"], true]
    - ["it1786002", itertools.count.__dict__.__contains__,        ["__class_getitem__"], true]
    - ["it1786003", itertools.cycle.__dict__.__contains__,        ["__class_getitem__"], true]
    - ["it1786004", itertools.repeat.__dict__.__contains__,       ["__class_getitem__"], true]
    - ["it1786005", itertools.islice.__dict__.__contains__,       ["__class_getitem__"], true]
    - ["it1786006", itertools.accumulate.__dict__.__contains__,   ["__class_getitem__"], true]
    - ["it1786007", itertools.compress.__dict__.__contains__,     ["__class_getitem__"], true]
    - ["it1786008", itertools.product.__dict__.__contains__,      ["__class_getitem__"], true]
    - ["it1786009", itertools.combinations.__dict__.__contains__,  ["__class_getitem__"], true]
    - ["it1786010", itertools.permutations.__dict__.__contains__,  ["__class_getitem__"], true]
    - ["it1786011", itertools.chain.__dict__.__contains__,        ["__init_subclass__"], false]
    - ["it1786012", itertools.count.__dict__.__contains__,        ["__init_subclass__"], false]
    - ["it1786013", itertools.cycle.__dict__.__contains__,        ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Table 2: complementary __dict__ membership checks for itertools C types
#
# Verifies __init_subclass__ and __subclasshook__ absence, and confirms
# standard dunder names that itertools C types do own in their __dict__.
# C extension types in itertools typically own __new__, __next__, __iter__,
# __reduce__, __doc__, and __class_getitem__ (from PEP 585).
# None own __init_subclass__ or __subclasshook__.
# ---------------------------------------------------------------------------

table itertools_extra1786.dict_membership_complement:
  description: "Complementary __dict__ membership checks: __init_subclass__ absent; __iter__ and __next__ present in itertools C types"
  kind: python_call_eq
  category: dict_membership
  id_prefix: it1786

  columns: [id, function, args, expected]
  rows:
    - ["it1786014", itertools.repeat.__dict__.__contains__,       ["__init_subclass__"], false]
    - ["it1786015", itertools.islice.__dict__.__contains__,       ["__init_subclass__"], false]
    - ["it1786016", itertools.accumulate.__dict__.__contains__,   ["__init_subclass__"], false]
    - ["it1786017", itertools.compress.__dict__.__contains__,     ["__init_subclass__"], false]
    - ["it1786018", itertools.chain.__dict__.__contains__,        ["__subclasshook__"],  false]
    - ["it1786019", itertools.count.__dict__.__contains__,        ["__subclasshook__"],  false]
    - ["it1786020", itertools.chain.__dict__.__contains__,        ["__iter__"],          true]
    - ["it1786021", itertools.chain.__dict__.__contains__,        ["__next__"],          true]
    - ["it1786022", itertools.count.__dict__.__contains__,        ["__iter__"],          true]
    - ["it1786023", itertools.count.__dict__.__contains__,        ["__next__"],          true]
    - ["it1786024", itertools.repeat.__dict__.__contains__,       ["__iter__"],          true]
    - ["it1786025", itertools.islice.__dict__.__contains__,       ["__iter__"],          true]
