spec: asyncio_extra9
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-exceptions.html — asyncio Exceptions"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/exceptions.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "Extends asyncio.zspec.zsdl, asyncio_events.zspec.zsdl, asyncio_extra.zspec.zsdl through asyncio_extra8.zspec.zsdl."
    - "asyncio_extra2 covers __module__ for AbstractEventLoop/BaseEventLoop (asyncio.events / asyncio.base_events)."
    - "asyncio_extra4 covers __module__ for CancelledError/TimeoutError (asyncio), Task (asyncio.tasks), Future (asyncio.futures), Queue (asyncio.queues), Lock (asyncio.locks)."
    - "asyncio_extra5 covers __module__ for Semaphore/Lock/Queue."
    - "asyncio_extra7 covers __name__ and __qualname__ for InvalidStateError/IncompleteReadError — but NOT __module__."
    - "asyncio_extra8 covers __bases__[0].__name__ for Task/Future/QueueEmpty/QueueFull; __module__ for Task/_asyncio and Future/_asyncio as standalone invariants."
    - "This spec adds NEW axes:"
    - "  (1) Exception base class hierarchy: CancelledError.__bases__[0].__name__=='BaseException'; TimeoutError.__bases__[0].__name__=='OSError'; InvalidStateError.__bases__[0].__name__=='Exception'; IncompleteReadError.__bases__[0].__name__=='EOFError' — none previously covered."
    - "  (2) Event loop class hierarchy: AbstractEventLoop.__bases__[0].__name__=='object'; BaseEventLoop.__bases__[0].__name__=='AbstractEventLoop' — not covered."
    - "  (3) Queue subclass hierarchy: PriorityQueue.__bases__[0].__name__=='Queue'; LifoQueue.__bases__[0].__name__=='Queue' — not covered."
    - "  (4) __module__ for InvalidStateError/IncompleteReadError (asyncio.exceptions) — not covered."
    - "  (5) __module__ for Condition/BoundedSemaphore (asyncio.locks) — extra5 covered Semaphore/Lock/Queue but not Condition/BoundedSemaphore."
    - "  (6) __module__ for PriorityQueue/LifoQueue (asyncio.queues) — not covered."
    - "  (7) __class__.__name__ for gather/sleep/create_task ('function') — type checks not covered."
    - "asyncio.CancelledError.__bases__[0].__name__ == 'BaseException' — CancelledError directly subclasses BaseException in Python 3.8+."
    - "asyncio.TimeoutError.__bases__[0].__name__ == 'OSError' — asyncio.TimeoutError is the builtin TimeoutError which inherits from OSError."
    - "asyncio.InvalidStateError.__bases__[0].__name__ == 'Exception' — direct Exception subclass."
    - "asyncio.IncompleteReadError.__bases__[0].__name__ == 'EOFError' — subclasses EOFError for stream errors."
    - "asyncio.AbstractEventLoop.__bases__[0].__name__ == 'object' — abstract base with no intermediate parents."
    - "asyncio.BaseEventLoop.__bases__[0].__name__ == 'AbstractEventLoop' — concrete base inherits from abstract base."
    - "asyncio.PriorityQueue.__bases__[0].__name__ == 'Queue' — priority variant of asyncio.Queue."
    - "asyncio.LifoQueue.__bases__[0].__name__ == 'Queue' — LIFO variant of asyncio.Queue."
    - "asyncio.InvalidStateError.__module__ == 'asyncio.exceptions' — defined in Lib/asyncio/exceptions.py."
    - "asyncio.IncompleteReadError.__module__ == 'asyncio.exceptions' — defined in Lib/asyncio/exceptions.py."
    - "asyncio.Condition.__module__ == 'asyncio.locks' — defined in Lib/asyncio/locks.py."
    - "asyncio.BoundedSemaphore.__module__ == 'asyncio.locks' — defined in Lib/asyncio/locks.py."
    - "asyncio.PriorityQueue.__module__ == 'asyncio.queues' — defined in Lib/asyncio/queues.py."
    - "asyncio.LifoQueue.__module__ == 'asyncio.queues' — defined in Lib/asyncio/queues.py."
    - "asyncio.gather.__class__.__name__ == 'function' — coroutine function, plain Python function object."
    - "asyncio.sleep.__class__.__name__ == 'function' — coroutine function, plain Python function object."
    - "asyncio.create_task.__class__.__name__ == 'function' — plain Python function."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception base class hierarchy — __bases__[0].__name__
#
# asyncio_extra8 covers Task/Future/QueueEmpty/QueueFull __bases__[0].
# This spec covers the remaining exception classes:
#   CancelledError inherits directly from BaseException (Python 3.8+).
#   TimeoutError is the builtin TimeoutError, inheriting from OSError.
#   InvalidStateError is a direct Exception subclass.
#   IncompleteReadError inherits from EOFError (for stream read errors).
# ---------------------------------------------------------------------------

invariant asyncio_extra9.CancelledError.base_name:
  description: "asyncio.CancelledError.__bases__[0].__name__ == 'BaseException' — direct BaseException subclass in Python 3.8+"
  category: exception_hierarchy
  kind: python_call_eq
  function: CancelledError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseException"

invariant asyncio_extra9.TimeoutError.base_name:
  description: "asyncio.TimeoutError.__bases__[0].__name__ == 'OSError' — builtin TimeoutError inherits from OSError"
  category: exception_hierarchy
  kind: python_call_eq
  function: TimeoutError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

invariant asyncio_extra9.InvalidStateError.base_name:
  description: "asyncio.InvalidStateError.__bases__[0].__name__ == 'Exception' — direct Exception subclass"
  category: exception_hierarchy
  kind: python_call_eq
  function: InvalidStateError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant asyncio_extra9.IncompleteReadError.base_name:
  description: "asyncio.IncompleteReadError.__bases__[0].__name__ == 'EOFError' — subclasses EOFError for stream errors"
  category: exception_hierarchy
  kind: python_call_eq
  function: IncompleteReadError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "EOFError"

# ---------------------------------------------------------------------------
# Event loop class hierarchy — __bases__[0].__name__
#
# No prior asyncio spec has checked __bases__[0].__name__ for event loop
# classes. AbstractEventLoop is a root ABC inheriting from object; BaseEventLoop
# is the concrete base class that implements AbstractEventLoop.
# ---------------------------------------------------------------------------

invariant asyncio_extra9.AbstractEventLoop.base_name:
  description: "asyncio.AbstractEventLoop.__bases__[0].__name__ == 'object' — root abstract base class"
  category: event_loop_hierarchy
  kind: python_call_eq
  function: AbstractEventLoop.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant asyncio_extra9.BaseEventLoop.base_name:
  description: "asyncio.BaseEventLoop.__bases__[0].__name__ == 'AbstractEventLoop' — implements the ABC"
  category: event_loop_hierarchy
  kind: python_call_eq
  function: BaseEventLoop.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "AbstractEventLoop"

# ---------------------------------------------------------------------------
# Queue subclass hierarchy — PriorityQueue and LifoQueue inherit from Queue
#
# asyncio_extra8 checks __name__ for PriorityQueue and LifoQueue. No prior
# spec checks __bases__[0].__name__ for either — both inherit from Queue.
# ---------------------------------------------------------------------------

invariant asyncio_extra9.PriorityQueue.base_name:
  description: "asyncio.PriorityQueue.__bases__[0].__name__ == 'Queue' — priority variant of asyncio.Queue"
  category: queue_hierarchy
  kind: python_call_eq
  function: PriorityQueue.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Queue"

invariant asyncio_extra9.LifoQueue.base_name:
  description: "asyncio.LifoQueue.__bases__[0].__name__ == 'Queue' — LIFO variant of asyncio.Queue"
  category: queue_hierarchy
  kind: python_call_eq
  function: LifoQueue.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Queue"

# ---------------------------------------------------------------------------
# __module__ for exception classes not yet checked
#
# asyncio_extra7 covers __name__ and __qualname__ for InvalidStateError
# and IncompleteReadError, but does NOT check __module__. Both are defined
# in asyncio/exceptions.py.
# ---------------------------------------------------------------------------

invariant asyncio_extra9.InvalidStateError.module:
  description: "asyncio.InvalidStateError.__module__ == 'asyncio.exceptions' — defined in asyncio/exceptions.py"
  category: class_modules
  kind: python_call_eq
  function: InvalidStateError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra9.IncompleteReadError.module:
  description: "asyncio.IncompleteReadError.__module__ == 'asyncio.exceptions' — defined in asyncio/exceptions.py"
  category: class_modules
  kind: python_call_eq
  function: IncompleteReadError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for synchronization primitives not yet checked
#
# asyncio_extra5 covers Semaphore/Lock/Queue __module__;
# asyncio_extra8 covers Event/__module__; asyncio_extra4 covers Lock/__module__.
# Condition and BoundedSemaphore __module__ have not been checked in any spec.
# PriorityQueue and LifoQueue __module__ have also not been checked.
# ---------------------------------------------------------------------------

table asyncio_extra9.sync_and_queue_modules:
  description: "asyncio sync primitives (Condition, BoundedSemaphore) and queue variants have correct __module__"
  kind: python_call_eq
  category: class_modules
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [Condition,        Condition.__module__.__eq__,        ["asyncio.locks"],  true]
    - [BoundedSemaphore, BoundedSemaphore.__module__.__eq__, ["asyncio.locks"],  true]
    - [PriorityQueue,    PriorityQueue.__module__.__eq__,    ["asyncio.queues"], true]
    - [LifoQueue,        LifoQueue.__module__.__eq__,        ["asyncio.queues"], true]

# ---------------------------------------------------------------------------
# Function type checks — gather, sleep, create_task
#
# Prior specs check __name__, __qualname__, and __module__ for these
# coroutine functions. No prior spec has checked __class__.__name__ ('function').
# ---------------------------------------------------------------------------

table asyncio_extra9.coroutine_function_types:
  description: "asyncio coroutine functions have __class__.__name__ == 'function'"
  kind: python_call_eq
  category: function_types
  id_prefix: ftype

  columns: [id, function, args, expected]
  rows:
    - [gather,       gather.__class__.__name__.__eq__,       ["function"], true]
    - [sleep,        sleep.__class__.__name__.__eq__,        ["function"], true]
    - [create_task,  create_task.__class__.__name__.__eq__,  ["function"], true]
