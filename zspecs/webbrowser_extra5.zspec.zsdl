spec: webbrowser_extra5
version: ">=3.9"
backend: python_module(webbrowser)

docs: https://docs.python.org/3/library/webbrowser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/webbrowser.html — Python webbrowser module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/webbrowser.py"
  notes:
    - "This spec extends webbrowser.zspec.zsdl through webbrowser_extra4.zspec.zsdl."
    - "webbrowser covers: function name table (open/open_new/open_new_tab/get/register); class name table (BaseBrowser/GenericBrowser/BackgroundBrowser/Mozilla); open.__module__; GenericBrowser/BackgroundBrowser class hierarchy."
    - "webbrowser_extra covers: function __name__/__qualname__/__class__; Error.__name__/__module__/__class__/__bases__."
    - "webbrowser_extra2 covers: BaseBrowser/GenericBrowser/BackgroundBrowser __name__/__module__/__qualname__/__class__; _tryorder is list; _browsers is dict."
    - "webbrowser_extra3 covers: open/open_new/open_new_tab/get/register __module__; function __name__ batch table."
    - "webbrowser_extra4 covers: Mozilla/Chrome/Edge __name__/__module__; UnixBrowser __name__/__module__/__bases__[0]; __all__ is list and contains 'open'/'get'."
    - "This spec adds: Opera/__name__/__module__; MacOSXOSAScript/__name__/__module__; Error.__qualname__; Mozilla.__qualname__; BaseBrowser base is object; __all__ contains 'register'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Opera — __name__ and __module__
# Opera is a UnixBrowser subclass for Opera-family browsers.
# Not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant webbrowser_extra5.Opera.name:
  description: "webbrowser.Opera.__name__ == 'Opera'"
  category: classes
  kind: python_call_eq
  function: Opera.__name__.__eq__
  args: ["Opera"]
  expected: true

invariant webbrowser_extra5.Opera.module:
  description: "webbrowser.Opera.__module__ == 'webbrowser'"
  category: classes
  kind: python_call_eq
  function: Opera.__module__.__eq__
  args: ["webbrowser"]
  expected: true

# ---------------------------------------------------------------------------
# MacOSXOSAScript — __name__ and __module__
# MacOSXOSAScript drives AppleScript-controlled browsers on macOS.
# Not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant webbrowser_extra5.MacOSXOSAScript.name:
  description: "webbrowser.MacOSXOSAScript.__name__ == 'MacOSXOSAScript'"
  category: classes
  kind: python_call_eq
  function: MacOSXOSAScript.__name__.__eq__
  args: ["MacOSXOSAScript"]
  expected: true

invariant webbrowser_extra5.MacOSXOSAScript.module:
  description: "webbrowser.MacOSXOSAScript.__module__ == 'webbrowser'"
  category: classes
  kind: python_call_eq
  function: MacOSXOSAScript.__module__.__eq__
  args: ["webbrowser"]
  expected: true

# ---------------------------------------------------------------------------
# Error.__qualname__ — not covered in any prior spec
# (extra checks __name__ and __module__; __qualname__ is new here)
# ---------------------------------------------------------------------------

invariant webbrowser_extra5.Error.qualname:
  description: "webbrowser.Error.__qualname__ == 'Error'"
  category: classes
  kind: python_call_eq
  function: Error.__qualname__.__eq__
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# Mozilla.__qualname__ — not covered in any prior spec
# (extra4 covers Mozilla.__name__ and Mozilla.__module__)
# ---------------------------------------------------------------------------

invariant webbrowser_extra5.Mozilla.qualname:
  description: "webbrowser.Mozilla.__qualname__ == 'Mozilla'"
  category: classes
  kind: python_call_eq
  function: Mozilla.__qualname__.__eq__
  args: ["Mozilla"]
  expected: true

# ---------------------------------------------------------------------------
# BaseBrowser base class — BaseBrowser inherits directly from object
# Not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant webbrowser_extra5.BaseBrowser.base_is_object:
  description: "webbrowser.BaseBrowser.__bases__[0].__name__ == 'object' — BaseBrowser inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: BaseBrowser.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# __all__ contains 'register' — not covered in extra4 (which checks 'open'/'get')
# ---------------------------------------------------------------------------

invariant webbrowser_extra5.all.contains_register:
  description: "webbrowser.__all__ contains 'register'"
  category: module
  kind: python_call_eq
  function: __all__.__contains__
  args: ["register"]
  expected: true
