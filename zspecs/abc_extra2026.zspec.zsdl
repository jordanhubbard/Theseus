spec: abc_extra2026
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 582 (_extra2026): __truediv__, __floordiv__, __mod__, __pow__, __divmod__ dict-presence checks."
    - "abc.ABCMeta is a metaclass; abc.ABC is a helper base class; abc.abstractmethod is a decorator."
    - "None of these abc constructs define division, floor division, modulo, power, or divmod protocols in their own __dict__."
    - "ABCMeta does define some special methods but none related to numeric arithmetic."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra2026.truediv_protocol:
  description: "abc.ABCMeta, abc.ABC, abc.abstractmethod __truediv__/__rtruediv__/__itruediv__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2026

  columns: [id, function, args, expected]
  rows:
    - ["ab2026001", "abc.ABCMeta.__dict__.__contains__", ["__truediv__"], false]
    - ["ab2026002", "abc.ABCMeta.__dict__.__contains__", ["__rtruediv__"], false]
    - ["ab2026003", "abc.ABCMeta.__dict__.__contains__", ["__itruediv__"], false]
    - ["ab2026004", "abc.ABC.__dict__.__contains__", ["__truediv__"], false]
    - ["ab2026005", "abc.ABC.__dict__.__contains__", ["__rtruediv__"], false]
    - ["ab2026006", "abc.ABC.__dict__.__contains__", ["__itruediv__"], false]
    - ["ab2026007", "abc.abstractmethod.__dict__.__contains__", ["__truediv__"], false]
    - ["ab2026008", "abc.abstractmethod.__dict__.__contains__", ["__rtruediv__"], false]
    - ["ab2026009", "abc.abstractmethod.__dict__.__contains__", ["__itruediv__"], false]

