spec: re_extra272
version: ">=3.11"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.RegexFlag is an enum.IntFlag subclass; type(re.RegexFlag).__name__ == 'EnumType'."
    - "re.RegexFlag.__name__ == 'RegexFlag' and re.RegexFlag.__module__ == 're'."
    - "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (direct base class)."
    - "re.NOFLAG was added in Python 3.11; it is a RegexFlag member with integer value 0."
    - "re.I is re.IGNORECASE (same object), re.M is re.MULTILINE, re.S is re.DOTALL, re.X is re.VERBOSE, re.A is re.ASCII, re.U is re.UNICODE."
    - "re.UNICODE has integer value 32, re.LOCALE has integer value 4."
    - "All re flag constants have __class__.__name__ == 'RegexFlag'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: RegexFlag class identity
# ---------------------------------------------------------------------------

table re_extra272.regexflag_class_identity:
  description: "re.RegexFlag class identity: __name__, __module__, metaclass name, and base class name"
  kind: python_call_eq
  category: identity
  id_prefix: rfi

  columns: [id, function, args, expected, description]
  rows:
    - [regexflag_name,    RegexFlag.__name__.__eq__,                          ["RegexFlag"], true, "re.RegexFlag.__name__ == 'RegexFlag'"]
    - [regexflag_module,  RegexFlag.__module__.__eq__,                        ["re"],        true, "re.RegexFlag.__module__ == 're'"]
    - [regexflag_meta,    RegexFlag.__class__.__name__.__eq__,                ["EnumType"],  true, "type(re.RegexFlag).__name__ == 'EnumType' (RegexFlag is an enum metaclass instance)"]
    - [regexflag_base,    "RegexFlag.__bases__[0].__name__.__eq__",           ["IntFlag"],   true, "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (RegexFlag inherits from IntFlag)"]

# ---------------------------------------------------------------------------
# Table: re flag alias identity and integer values
# ---------------------------------------------------------------------------

table re_extra272.flag_aliases_and_values:
  description: "re flag short aliases equal their long-form counterparts; UNICODE==32, LOCALE==4, NOFLAG==0"
  kind: python_call_eq
  category: identity
  id_prefix: fav

  columns: [id, function, args, expected, description]
  rows:
    - [i_is_ignorecase,  I.__eq__,         [2],  true, "re.I.__eq__(2) == True (re.I is re.IGNORECASE, value 2)"]
    - [m_is_multiline,   M.__eq__,         [8],  true, "re.M.__eq__(8) == True (re.M is re.MULTILINE, value 8)"]
    - [s_is_dotall,      S.__eq__,         [16], true, "re.S.__eq__(16) == True (re.S is re.DOTALL, value 16)"]
    - [x_is_verbose,     X.__eq__,         [64], true, "re.X.__eq__(64) == True (re.X is re.VERBOSE, value 64)"]
    - [a_is_ascii,       A.__eq__,         [256], true, "re.A.__eq__(256) == True (re.A is re.ASCII, value 256)"]
    - [u_is_unicode,     U.__eq__,         [32], true, "re.U.__eq__(32) == True (re.U is re.UNICODE, value 32)"]
    - [locale_val,       LOCALE.__eq__,    [4],  true, "re.LOCALE.__eq__(4) == True (re.LOCALE has integer value 4)"]
    - [noflag_val,       NOFLAG.__eq__,    [0],  true, "re.NOFLAG.__eq__(0) == True (re.NOFLAG has integer value 0; Python 3.11+)"]

# ---------------------------------------------------------------------------
# Standalone invariants: flag class names and NOFLAG type
# ---------------------------------------------------------------------------

invariant re_extra272.RegexFlag.name:
  description: "re.RegexFlag.__name__ == 'RegexFlag'"
  category: identity
  kind: python_call_eq
  function: RegexFlag.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra272.RegexFlag.module:
  description: "re.RegexFlag.__module__ == 're'"
  category: identity
  kind: python_call_eq
  function: RegexFlag.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra272.NOFLAG.class_name:
  description: "re.NOFLAG.__class__.__name__ == 'RegexFlag' (NOFLAG is a RegexFlag member)"
  category: identity
  kind: python_call_eq
  function: NOFLAG.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra272.UNICODE.class_name:
  description: "re.UNICODE.__class__.__name__ == 'RegexFlag'"
  category: identity
  kind: python_call_eq
  function: UNICODE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra272.LOCALE.class_name:
  description: "re.LOCALE.__class__.__name__ == 'RegexFlag'"
  category: identity
  kind: python_call_eq
  function: LOCALE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra272.IGNORECASE.class_name:
  description: "re.IGNORECASE.__class__.__name__ == 'RegexFlag'"
  category: identity
  kind: python_call_eq
  function: IGNORECASE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true
