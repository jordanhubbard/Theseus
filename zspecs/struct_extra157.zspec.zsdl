spec: struct_extra157
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra156.zspec.zsdl — covers struct.Struct.__doc__ and struct module __doc__ type/length / struct.__doc__.__len__()==1278 / Struct.__doc__.__len__()==40 / pack_into.__name__.__eq__('pack_into') / unpack_from.__name__.__eq__('unpack_from') (table + invariants)."
    - "struct_extra155.zspec.zsdl — covers struct.Struct getset_descriptor qualnames and names / Struct.size/__qualname__.__eq__('Struct.size') / Struct.format/__qualname__.__eq__('Struct.format') / calcsize/__name__ string (table + invariants)."
    - "struct_extra154.zspec.zsdl — covers struct.Struct method qualnames: Struct.pack/__qualname__ / Struct.unpack/__qualname__ / Struct.pack_into/__qualname__ / Struct.pack.__class__.__name__.__eq__('method_descriptor') (table + invariants)."
    - "struct_extra153.zspec.zsdl — covers struct.Struct.__init__.__qualname__.__eq__('Struct.__init__') / Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') / Struct.__doc__.__len__()==40 / error.__doc__ NoneType (table + invariants)."
    - "struct_extra152.zspec.zsdl — covers struct.iter_unpack/__class__/__module__/__name__ / Struct.__name__.__len__()==6 / pack/__unpack/__calcsize/__pack_into __name__ and lengths (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra156."
    - "Wave 343 theme: struct.Struct.__repr__ and __sizeof__ qualname and type identity; struct module __name__ and __package__ identity; struct.Struct.__name__ and __module__ identity — Struct.__repr__.__qualname__.__eq__('Struct.__repr__') / Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__') / Struct.__repr__.__class__.__name__.__eq__('wrapper_descriptor') / Struct.__sizeof__.__class__.__name__.__eq__('method_descriptor') / struct.__name__.__eq__('struct') / struct.__package__.__eq__('') / Struct.__name__.__eq__('Struct') / Struct.__module__.__eq__('_struct')."
    - "struct.Struct.__repr__.__qualname__ == 'Struct.__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__qualname__ == 'Struct.__sizeof__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__repr__.__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__repr__.__qualname__.__len__() == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__qualname__.__len__() == 17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__name__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__package__ == '' (empty string). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.__repr__.__qualname__ == 'Struct.__repr__' (15 chars = 'Struct.'=7 + '__repr__'=8). Struct.__repr__ is a wrapper_descriptor (not a method_descriptor). wrapper_descriptor is the type used for __repr__ and similar special methods in C extension types. This contrasts with Struct.pack which is a method_descriptor (extra154 anchors Struct.pack.__class__.__name__=='method_descriptor'). 'Struct.__repr__' (15 chars) ties 'Struct.__init__' (15 chars; extra153 anchors Struct.__init__ qualname)."
    - "Note: struct.Struct.__sizeof__.__qualname__ == 'Struct.__sizeof__' (17 chars = 'Struct.'=7 + '__sizeof__'=10). Struct.__sizeof__ is a method_descriptor. '__sizeof__' (10 chars) = '__'=2 + 'sizeof'=6 + '__'=2 = 10. 'Struct.__sizeof__' (17 chars) is the longest method qualname in this spec. method_descriptor is used for __sizeof__ while wrapper_descriptor is used for __repr__ (different descriptor types for different special method categories in C extensions)."
    - "Note: struct.__name__ == 'struct' (6 chars). struct.__package__ == '' (empty string, 0 chars). The struct module is a built-in module (C extension). struct.__package__ is the empty string because struct is a top-level module (not in a package). An empty __package__ (not None) is the convention for top-level modules in Python 3. struct.__name__ == 'struct' == struct.Struct.__name__[:6] (the module name equals the first 6 chars of the class name). Verified Python 3.14.3."
    - "Note: struct.Struct.__name__ == 'Struct' (6 chars). struct.Struct.__module__ == '_struct' (7 chars). Struct.__name__ is the bare class name ('Struct'); Struct.__module__ is '_struct' (the C extension where it is implemented). '_struct' (7 chars = '_'=1 + 'struct'=6) has a leading underscore denoting a private implementation module. Struct.__name__ (6 chars) < Struct.__module__ (7 chars) in length. struct_extra148 anchors Struct.__name__=='Struct' and Struct.__module__=='_struct' as rows; this spec anchors them as standalone invariants."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__repr__.__qualname__.__eq__('Struct.__repr__')
# struct.Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__')
# struct.Struct.__repr__.__class__.__name__.__eq__('wrapper_descriptor')
# struct.Struct.__sizeof__.__class__.__name__.__eq__('method_descriptor')
#
# Wave 343 theme: Struct.__repr__ and __sizeof__ qualname strings and types.
#
# Struct.__repr__.__qualname__ == 'Struct.__repr__' (15 chars = 'Struct.'=7 + '__repr__'=8).
# Struct.__sizeof__.__qualname__ == 'Struct.__sizeof__' (17 chars = 'Struct.'=7 + '__sizeof__'=10).
# Struct.__repr__.__class__.__name__ == 'wrapper_descriptor' (18 chars; same type as __init__).
# Struct.__sizeof__.__class__.__name__ == 'method_descriptor' (17 chars; same type as pack).
# No prior struct spec anchors Struct.__repr__ or __sizeof__ qualnames as a table under
# structrep157. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra157.Struct_repr_sizeof_qualnames_and_types:
  description: "struct.Struct.__repr__.__qualname__.__eq__('Struct.__repr__')==True / Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__')==True / Struct.__repr__.__class__.__name__.__eq__('wrapper_descriptor')==True / Struct.__sizeof__.__class__.__name__.__eq__('method_descriptor')==True — Struct.__repr__.__qualname__ is 'Struct.__repr__' (15 chars = 'Struct.'=7 + '__repr__'=8; wrapper_descriptor; same length as 'Struct.__init__' from extra153; Struct.__repr__ is the special dunder repr method for Struct instances); Struct.__sizeof__.__qualname__ is 'Struct.__sizeof__' (17 chars = 'Struct.'=7 + '__sizeof__'=10; method_descriptor; '__sizeof__'=10 chars is longer than '__repr__'=8; __sizeof__ returns size of Struct in memory); Struct.__repr__.__class__.__name__ is 'wrapper_descriptor' (18 chars; type for special dunder methods in C types; same type as Struct.__init__); Struct.__sizeof__.__class__.__name__ is 'method_descriptor' (17 chars; type for regular methods; same type as Struct.pack from extra154); first structrep157 anchor for Struct.__repr__/__sizeof__ qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: structrep157

  columns: [id, function, args, expected, description]
  rows:
    - [repr_qualname_str,     "Struct.__repr__.__qualname__.__eq__",              ["Struct.__repr__"],   true, "struct.Struct.__repr__.__qualname__ == 'Struct.__repr__' (15 chars = 'Struct.'=7 + '__repr__'=8; wrapper_descriptor; ties Struct.__init__ at 15 chars)"]
    - [sizeof_qualname_str,   "Struct.__sizeof__.__qualname__.__eq__",            ["Struct.__sizeof__"], true, "struct.Struct.__sizeof__.__qualname__ == 'Struct.__sizeof__' (17 chars = 'Struct.'=7 + '__sizeof__'=10; method_descriptor; longest Struct qualname here)"]
    - [repr_class_wrapper_d,  "Struct.__repr__.__class__.__name__.__eq__",        ["wrapper_descriptor"], true, "struct.Struct.__repr__.__class__.__name__ == 'wrapper_descriptor' (18 chars; special dunder descriptor type; same type as Struct.__init__)"]
    - [sizeof_class_method_d, "Struct.__sizeof__.__class__.__name__.__eq__",      ["method_descriptor"], true, "struct.Struct.__sizeof__.__class__.__name__ == 'method_descriptor' (17 chars; regular C method descriptor; same type as Struct.pack)"]

# ---------------------------------------------------------------------------
# Struct.__repr__ and __sizeof__ qualname lengths
#
# Wave 343 theme: qualname length comparison for Struct.__repr__ and __sizeof__.
#
# Struct.__repr__.__qualname__.__len__() == 15 ('Struct.'=7 + '__repr__'=8 = 15).
# Struct.__sizeof__.__qualname__.__len__() == 17 ('Struct.'=7 + '__sizeof__'=10 = 17).
# Length ordering: Struct.pack(11) < Struct.size(11) < Struct.unpack(13) < Struct.__repr__(15) < Struct.__sizeof__(17).
# No prior struct spec anchors Struct.__repr__ or __sizeof__ qualname lengths as a table
# under structrep157. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra157.Struct_repr_sizeof_qualname_lengths:
  description: "struct.Struct.__repr__.__qualname__.__len__()==15 / Struct.__sizeof__.__qualname__.__len__()==17 / Struct.__repr__.__class__.__name__.__eq__('wrapper_descriptor')==True / Struct.__sizeof__.__class__.__name__.__eq__('method_descriptor')==True — Struct.__repr__.__qualname__ is 15 chars ('Struct.__repr__' = 'Struct.'=7 + '__repr__'=8; ties 'Struct.__init__' at 15 chars from extra153; longer than 'Struct.pack'=11 from extra154); Struct.__sizeof__.__qualname__ is 17 chars ('Struct.__sizeof__' = 'Struct.'=7 + '__sizeof__'=10; '__sizeof__'=10 chars is longest dunder suffix here; longest Struct method qualname anchored in this spec); Struct.__repr__ is wrapper_descriptor (18 chars; confirmed); Struct.__sizeof__ is method_descriptor (17 chars; confirmed); length ordering: Struct.pack(11) < Struct.format(13) < Struct.__repr__(15) < Struct.__sizeof__(17); first structrep157 anchor for Struct.__repr__ and __sizeof__ qualname lengths"
  kind: python_call_eq
  category: identity
  id_prefix: structrep157

  columns: [id, function, args, expected, description]
  rows:
    - [repr_qualname_len_15,   "Struct.__repr__.__qualname__.__len__",   [], 15, "struct.Struct.__repr__.__qualname__.__len__() is 15 ('Struct.'=7 + '__repr__'=8 = 15; ties 'Struct.__init__' from extra153 at 15 chars)"]
    - [sizeof_qualname_len_17, "Struct.__sizeof__.__qualname__.__len__", [], 17, "struct.Struct.__sizeof__.__qualname__.__len__() is 17 ('Struct.'=7 + '__sizeof__'=10 = 17; longest Struct method qualname in this spec)"]
    - [repr_class_wrapper_db,  "Struct.__repr__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true, "struct.Struct.__repr__.__class__.__name__ == 'wrapper_descriptor' (18 chars; confirmed again; type for dunder special methods in C types)"]
    - [sizeof_class_method_db, "Struct.__sizeof__.__class__.__name__.__eq__", ["method_descriptor"],  true, "struct.Struct.__sizeof__.__class__.__name__ == 'method_descriptor' (17 chars; confirmed again; same type as Struct.pack/unpack)"]

# ---------------------------------------------------------------------------
# struct.__name__ and struct.__package__ identity
#
# Wave 343 theme: struct module __name__ and __package__ attribute identity.
#
# struct.__name__ == 'struct' (6 chars).
# struct.__package__ == '' (empty string, 0 chars; top-level module, not in a package).
# struct.Struct.__name__ == 'Struct' (6 chars; class name).
# struct.Struct.__module__ == '_struct' (7 chars; C extension module with leading underscore).
# No prior struct spec anchors struct.__name__ or struct.__package__ as a table under
# structrep157. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra157.struct_module_and_Struct_class_identity:
  description: "struct.__name__.__eq__('struct')==True / struct.__package__.__eq__('')==True / struct.Struct.__name__.__eq__('Struct')==True / struct.Struct.__module__.__eq__('_struct')==True — struct.__name__ is 'struct' (6 chars; module name; struct is a C extension module built into Python; same string as module attribute path prefix); struct.__package__ is '' (empty string, 0 chars; top-level module not in a package; __package__=='' for top-level modules vs None for __main__); struct.Struct.__name__ is 'Struct' (6 chars; C extension class name; defined in Modules/_struct.c; struct_extra148 anchors this as a table row); struct.Struct.__module__ is '_struct' (7 chars = '_'=1 + 'struct'=6; leading underscore = private C extension; struct_extra148 anchors this as a table row; '_struct' is 1 char longer than 'struct'); first structrep157 anchor for struct.__name__ and struct.__package__ as a table"
  kind: python_call_eq
  category: identity
  id_prefix: structrep157

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_struct,      "__name__.__eq__",               ["struct"],  true, "struct.__name__ == 'struct' (6 chars; C extension module name; top-level module; same string as attribute access prefix)"]
    - [module_package_empty,    "__package__.__eq__",            [""],        true, "struct.__package__ == '' (empty string; 0 chars; top-level module not in a package; __package__=='' for built-in/top-level modules)"]
    - [Struct_name_Struct,      "Struct.__name__.__eq__",        ["Struct"],  true, "struct.Struct.__name__ == 'Struct' (6 chars; C extension class name; struct_extra148 anchors as row; 'Struct' with capital S)"]
    - [Struct_module_underscore,"Struct.__module__.__eq__",      ["_struct"], true, "struct.Struct.__module__ == '_struct' (7 chars = '_'=1 + 'struct'=6; C extension; struct_extra148 anchors as row; 1 char longer than 'struct')"]

# ---------------------------------------------------------------------------
# struct.Struct.__repr__.__qualname__.__eq__('Struct.__repr__') — standalone
#
# struct.Struct.__repr__.__qualname__ is 'Struct.__repr__' (15 chars = 'Struct.'=7 +
# '__repr__'=8). Struct.__repr__ is a wrapper_descriptor (the type used for special
# dunder methods in C extension types). wrapper_descriptor is used for methods like
# __repr__, __str__, __init__, __new__ in C types, as opposed to method_descriptor
# which is used for regular methods like pack, unpack. 'Struct.__repr__' (15 chars)
# ties 'Struct.__init__' (15 chars; extra153 anchors __init__ qualname). '__repr__' (8 chars)
# is shorter than '__sizeof__' (10 chars), placing __repr__ below __sizeof__ in qualname
# length. No prior struct spec anchors Struct.__repr__.__qualname__ as a standalone under
# structrep157. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra157.Struct_repr_qualname_eq:
  description: "struct.Struct.__repr__.__qualname__.__eq__('Struct.__repr__') == True — 15 chars = 'Struct.'=7 + '__repr__'=8; wrapper_descriptor (same type as Struct.__init__ from extra153; different from method_descriptor used by Struct.pack); ties 'Struct.__init__' at 15 chars; returns string representation of Struct instance; '__repr__'=8 chars; Struct.__sizeof__ qualname is 17 chars (longer); qualname length ordering in this spec: Struct.pack(11) < Struct.format(13) < Struct.__repr__(15) < Struct.__sizeof__(17); no prior struct spec anchors this as a standalone; first standalone under structrep157"
  category: identity
  kind: python_call_eq
  function: Struct.__repr__.__qualname__.__eq__
  args: ["Struct.__repr__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__') — standalone
#
# struct.Struct.__sizeof__.__qualname__ is 'Struct.__sizeof__' (17 chars = 'Struct.'=7 +
# '__sizeof__'=10). Struct.__sizeof__ is a method_descriptor. '__sizeof__' (10 chars) =
# '__'=2 + 'sizeof'=6 + '__'=2. The __sizeof__ method returns the size of a Struct instance
# in memory (in bytes), used by sys.getsizeof(). Struct.__sizeof__ is a method_descriptor
# (unlike Struct.__repr__ which is a wrapper_descriptor). 'Struct.__sizeof__' (17 chars)
# is longer than 'Struct.__repr__' (15 chars) because '__sizeof__' (10 chars) >
# '__repr__' (8 chars). 'Struct.__sizeof__' is the longest Struct method qualname anchored
# in this spec. No prior struct spec anchors Struct.__sizeof__.__qualname__ as a standalone
# under structrep157. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra157.Struct_sizeof_qualname_eq:
  description: "struct.Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__') == True — 17 chars = 'Struct.'=7 + '__sizeof__'=10; method_descriptor (not wrapper_descriptor; __sizeof__ is a regular C method unlike __repr__/__init__); '__sizeof__'=10 chars = '__'=2 + 'sizeof'=6 + '__'=2; 'sizeof'=6 chars; __sizeof__() returns size of Struct instance in memory; used by sys.getsizeof(); longest Struct method qualname in this spec at 17 chars; Struct.__repr__(15) < Struct.__sizeof__(17); no prior struct spec anchors this as a standalone; first standalone under structrep157"
  category: identity
  kind: python_call_eq
  function: Struct.__sizeof__.__qualname__.__eq__
  args: ["Struct.__sizeof__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__name__.__eq__('struct') — standalone
#
# struct.__name__ is 'struct' (6 chars). The struct module is a C extension module
# (built into CPython). struct.__name__ == 'struct' is the module name. This is
# distinct from struct.Struct.__name__ == 'Struct' (capital S; 6 chars; the class name).
# struct.__name__ and struct.Struct.__name__ have the same length (6 chars each) but
# differ in casing: 'struct' vs 'Struct'. struct.__package__ == '' (empty string, 0 chars)
# because struct is a top-level module. struct.__name__.__len__() == 6; same length as
# struct.Struct.__name__ (both 6 chars). No prior struct spec anchors struct.__name__ as
# a standalone under structrep157 (struct_extra148 anchors it as a row but it is novel as
# a standalone here). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra157.struct_module_name_eq:
  description: "struct.__name__.__eq__('struct') == True — 'struct' (6 chars; module name; same length as 'Struct'=6 chars but lowercase; C extension module built into CPython); struct.__name__.__len__()==6; struct.Struct.__name__=='Struct' (same length 6, different case); struct.__package__=='' (empty; top-level module); struct.__name__!='Struct' (different case); struct_extra148 anchors Struct.__name__=='Struct' as a row but NOT struct.__name__ as a standalone; no prior struct spec anchors struct.__name__ as a standalone; first standalone under structrep157"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__package__.__eq__('') — standalone
#
# struct.__package__ is '' (empty string, 0 chars). The __package__ attribute of a
# module indicates which package the module belongs to. For top-level modules (not
# inside any package), __package__ is the empty string ''. This contrasts with None
# (used for __main__) and a package name (used for submodules, e.g., 'os' for 'os.path').
# struct is a top-level built-in module: it is accessed as 'import struct' with no
# package qualification. struct.__package__ == '' (empty string). struct.__name__ == 'struct'
# (6 chars). struct.__package__.__len__() == 0 (empty string has length 0).
# No prior struct spec anchors struct.__package__ as a standalone under structrep157.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra157.struct_package_empty:
  description: "struct.__package__.__eq__('') == True — empty string (0 chars); struct is a top-level module not in any package; __package__=='' for top-level modules (vs None for __main__, vs package name for submodules); struct.__package__.__len__()==0; struct.__name__=='struct' (6 chars); empty __package__ is the convention for built-in C extension modules accessible at top level; no prior struct spec anchors struct.__package__ as a standalone; first standalone under structrep157"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true
