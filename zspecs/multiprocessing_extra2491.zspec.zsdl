# ---------------------------------------------------------------------------
# __getitem__ on class __dict__ raises KeyError for absent mutable-item keys
# ---------------------------------------------------------------------------

table multiprocessing_extra2491.dict_getitem_raises:
  description: "multiprocessing class __dict__.__getitem__ raises KeyError for absent __setitem__, __delitem__, __missing__ — none of these multiprocessing classes define mutable item access methods; verified Python 3.14.4"
  kind: python_call_raises
  category: dict_presence
  id_prefix: mp2491

