spec: multiprocessing_extra2491
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#process-and-exceptions — Process"
    - "https://docs.python.org/3/library/multiprocessing.html#exchanging-objects-between-processes — Queue, SimpleQueue, JoinableQueue"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Theme: __setitem__, __delitem__, and __missing__ dict-presence — checking whether multiprocessing classes define mutable item access and missing-key protocol in their class __dict__."
    - "multiprocessing.Process.__dict__.__contains__('__setitem__') == False — Process does not define __setitem__; verified Python 3.14.4."
    - "multiprocessing.Process.__dict__.__contains__('__delitem__') == False — Process does not define __delitem__; verified Python 3.14.4."
    - "multiprocessing.Process.__dict__.__contains__('__missing__') == False — Process does not define __missing__; verified Python 3.14.4."
    - "multiprocessing.queues.Queue.__dict__.__contains__('__setitem__') == False — Queue does not define __setitem__; verified Python 3.14.4."
    - "multiprocessing.queues.SimpleQueue.__dict__.__contains__('__setitem__') == False — SimpleQueue does not define __setitem__; verified Python 3.14.4."
    - "multiprocessing.queues.JoinableQueue.__dict__.__contains__('__setitem__') == False — JoinableQueue does not define __setitem__; verified Python 3.14.4."
    - "Accessing a missing key via __dict__.__getitem__ raises KeyError for all multiprocessing classes; verified Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing class __dict__ __contains__ checks — __setitem__,
# __delitem__, __missing__ dict-presence theme
#
# None of the core multiprocessing classes define __setitem__, __delitem__, or
# __missing__ in their own class __dict__. Process and the queue variants are
# IPC primitives and do not support mutable item access or missing-key fallback.
# ---------------------------------------------------------------------------

table multiprocessing_extra2491.process_dict_mutable_item:
  description: "multiprocessing.Process.__dict__.__contains__ checks for __setitem__, __delitem__, __missing__ — Process defines _start_method, _Popen, __doc__ but NOT mutable item access methods; verified Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: mp2491

  columns: [id, function, args, expected]
  rows:
    - ["mp2491001", multiprocessing.Process.__dict__.__contains__, ["__doc__"],        true]
    - ["mp2491002", multiprocessing.Process.__dict__.__contains__, ["_start_method"],  true]
    - ["mp2491003", multiprocessing.Process.__dict__.__contains__, ["_Popen"],         true]
    - ["mp2491004", multiprocessing.Process.__dict__.__contains__, ["__setitem__"],    false]
    - ["mp2491005", multiprocessing.Process.__dict__.__contains__, ["__delitem__"],    false]
    - ["mp2491006", multiprocessing.Process.__dict__.__contains__, ["__missing__"],    false]

