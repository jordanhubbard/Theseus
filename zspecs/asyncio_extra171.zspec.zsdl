spec: asyncio_extra171
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-eventloop.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-eventloop.html — Python asyncio event loop documentation"
    - "https://docs.python.org/3/library/asyncio-runner.html — Python asyncio runner documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py"
    - "CPython source: Lib/asyncio/runners.py"
    - "CPython source: Modules/_asyncio.c"
  notes:
    - "This spec covers: asyncio.get_event_loop.__name__=='get_event_loop' and __module__=='_asyncio'; asyncio.get_running_loop.__name__=='get_running_loop' and __module__=='_asyncio'; asyncio.new_event_loop.__name__=='new_event_loop' and __module__=='asyncio.events'; asyncio.run.__name__=='run' and __module__=='asyncio.runners'. KEY FINDINGS: asyncio.get_event_loop and asyncio.get_running_loop are C-accelerated builtins — their __module__=='_asyncio' (the C extension module), NOT 'asyncio.events'; asyncio.new_event_loop is a Python-level function in asyncio.events (__module__=='asyncio.events'); asyncio.run is defined in asyncio.runners (__module__=='asyncio.runners'). The _asyncio module is CPython's C-extension implementation of the core asyncio internals. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.get_event_loop.__name__=='get_event_loop' (len=14: 'get'=3+'_'=1+'event'=5+'_'=1+'loop'=4=14); __module__=='_asyncio' (len=8: '_'=1+'asyncio'=7=8); get_event_loop is implemented in C (_asyncio module) for performance — it retrieves the running event loop or creates one for the current OS thread. Verified with Python 3.14.3."
    - "asyncio.get_running_loop.__name__=='get_running_loop' (len=16: 'get'=3+'_'=1+'running'=7+'_'=1+'loop'=4=16); __module__=='_asyncio' (len=8; same as get_event_loop — both are C builtins); get_running_loop() raises RuntimeError if there is no running loop, making it safer than get_event_loop() for coroutine contexts. Verified with Python 3.14.3."
    - "asyncio.new_event_loop.__name__=='new_event_loop' (len=14: 'new'=3+'_'=1+'event'=5+'_'=1+'loop'=4=14; same length as 'get_event_loop'=14); __module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14); new_event_loop is a Python-level function defined in asyncio/events.py (NOT a C builtin). Verified with Python 3.14.3."
    - "asyncio.run.__name__=='run' (len=3: 'r'+'u'+'n'=3; shortest function name in this spec); __module__=='asyncio.runners' (len=15: 'asyncio'=7+'.'=1+'runners'=7=15); asyncio.run() was added in Python 3.7 as the canonical entry point for asyncio programs. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.get_event_loop function name and module identity — extra171
#
# asyncio.get_event_loop.__name__.__eq__('get_event_loop') == True
# asyncio.get_event_loop.__name__.__len__()               == 14
# asyncio.get_event_loop.__module__.__eq__('_asyncio')    == True  (C builtin)
# asyncio.get_event_loop.__module__.__len__()             == 8
# ---------------------------------------------------------------------------

table asyncio_extra171.asyncio_get_event_loop_identity:
  description: "asyncio.get_event_loop function name and module identity checks in asynciogelident171 namespace — asyncio.get_event_loop.__name__.__eq__('get_event_loop')==True (get_event_loop.__name__=='get_event_loop' (len=14: 'get'=3+'_'=1+'event'=5+'_'=1+'loop'=4=14); asyncio.get_event_loop() returns the running event loop in the current OS thread; if there is no running loop, in Python 3.10+ it emits a DeprecationWarning and creates a new one; in Python 3.12+ it raises DeprecationWarning if called from outside a running loop and no current event loop is set for the thread; prefer asyncio.get_running_loop() inside coroutines); asyncio.get_event_loop.__name__.__len__()==14 ('get_event_loop'=14: 'get'=3+'_'=1+'event'=5+'_'=1+'loop'=4=14; equal in length to 'new_event_loop'=14: same prefix 'get' vs 'new'=3, same suffix '_event_loop'=11); asyncio.get_event_loop.__module__.__eq__('_asyncio')==True (KEY FINDING: __module__=='_asyncio' (NOT 'asyncio.events'); get_event_loop is implemented in C as part of the _asyncio CPython C extension; the _asyncio module provides the high-performance C implementations of asyncio internals; '__module__'=='_asyncio' (len=8: '_'=1+'asyncio'=7=8)); asyncio.get_event_loop.__module__.__len__()==8 ('_asyncio'=8; compare: 'asyncio.events'=14 is 6 longer; 'asyncio.runners'=15 is 7 longer; '_asyncio'=8 is the shortest module path in this spec); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciogelident171

  columns: [id, function, args, expected, description]
  rows:
    - [gel_name_eq,  asyncio.get_event_loop.__name__.__eq__,    ["get_event_loop"],  true,  "get_event_loop.__name__ == 'get_event_loop' (len=14: 'get'=3+'_event_loop'=11); verified with Python 3.14.3"]
    - [gel_name_len, asyncio.get_event_loop.__name__.__len__,   [],                  14,    "get_event_loop.__name__.__len__() == 14 ('get_event_loop'=14; equal to 'new_event_loop'=14); verified with Python 3.14.3"]
    - [gel_mod_eq,   asyncio.get_event_loop.__module__.__eq__,  ["_asyncio"],        true,  "get_event_loop.__module__ == '_asyncio' (C builtin; NOT 'asyncio.events'; len=8); verified with Python 3.14.3"]
    - [gel_mod_len,  asyncio.get_event_loop.__module__.__len__, [],                  8,     "get_event_loop.__module__.__len__() == 8 ('_asyncio'=8; shortest in this spec; '_'=1+'asyncio'=7); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.get_running_loop function name and module identity — extra171
#
# asyncio.get_running_loop.__name__.__eq__('get_running_loop') == True
# asyncio.get_running_loop.__name__.__len__()                  == 16
# asyncio.get_running_loop.__module__.__eq__('_asyncio')       == True  (C builtin)
# asyncio.get_running_loop.__module__.__len__()                == 8
# ---------------------------------------------------------------------------

table asyncio_extra171.asyncio_get_running_loop_identity:
  description: "asyncio.get_running_loop function name and module identity checks in asynciogrlident171 namespace — asyncio.get_running_loop.__name__.__eq__('get_running_loop')==True (get_running_loop.__name__=='get_running_loop' (len=16: 'get'=3+'_'=1+'running'=7+'_'=1+'loop'=4=16); asyncio.get_running_loop() returns the running event loop in the current OS thread and raises RuntimeError if there is no running loop; it is the PREFERRED function over get_event_loop() in coroutines and async callbacks because it never creates a new loop — it only returns the already-running loop; added in Python 3.7); asyncio.get_running_loop.__name__.__len__()==16 ('get_running_loop'=16: 2 longer than 'get_event_loop'=14 because 'running'=7 > 'event'=5 by 2; 'running_loop'=12 vs 'event_loop'=10); asyncio.get_running_loop.__module__.__eq__('_asyncio')==True (KEY FINDING: __module__=='_asyncio' (same as get_event_loop — both are C builtins); get_running_loop is implemented in C for performance — reading the running loop is a hot path in asyncio; CONTRAST: asyncio.new_event_loop.__module__=='asyncio.events' (Python-level function)); asyncio.get_running_loop.__module__.__len__()==8 (same as get_event_loop.__module__.__len__()==8; '_asyncio'=8); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciogrlident171

  columns: [id, function, args, expected, description]
  rows:
    - [grl_name_eq,  asyncio.get_running_loop.__name__.__eq__,    ["get_running_loop"],  true,  "get_running_loop.__name__ == 'get_running_loop' (len=16: 'get_running_loop'=16; 2 longer than get_event_loop=14); verified with Python 3.14.3"]
    - [grl_name_len, asyncio.get_running_loop.__name__.__len__,   [],                    16,    "get_running_loop.__name__.__len__() == 16 ('get_running_loop'=16: 'running'=7 > 'event'=5 by 2); verified with Python 3.14.3"]
    - [grl_mod_eq,   asyncio.get_running_loop.__module__.__eq__,  ["_asyncio"],          true,  "get_running_loop.__module__ == '_asyncio' (C builtin; same module as get_event_loop; NOT 'asyncio.events'); verified with Python 3.14.3"]
    - [grl_mod_len,  asyncio.get_running_loop.__module__.__len__, [],                    8,     "get_running_loop.__module__.__len__() == 8 ('_asyncio'=8; same as get_event_loop module len); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.new_event_loop function name and module identity — extra171
#
# asyncio.new_event_loop.__name__.__eq__('new_event_loop')         == True
# asyncio.new_event_loop.__name__.__len__()                        == 14
# asyncio.new_event_loop.__module__.__eq__('asyncio.events')       == True
# asyncio.new_event_loop.__module__.__len__()                      == 14
# ---------------------------------------------------------------------------

table asyncio_extra171.asyncio_new_event_loop_identity:
  description: "asyncio.new_event_loop function name and module identity checks in asyncionelident171 namespace — asyncio.new_event_loop.__name__.__eq__('new_event_loop')==True (new_event_loop.__name__=='new_event_loop' (len=14: 'new'=3+'_'=1+'event'=5+'_'=1+'loop'=4=14); asyncio.new_event_loop() creates and returns a new event loop object; the default event loop type is determined by the current event loop policy; the returned loop is NOT set as the running loop — the caller must call loop.run_until_complete() or similar to run it; new_event_loop() is typically used to create background loops in non-main threads); asyncio.new_event_loop.__name__.__len__()==14 ('new_event_loop'=14; same length as 'get_event_loop'=14 — the prefix 'new'=3 vs 'get'=3 are equal length, and '_event_loop'=11 suffix is the same); asyncio.new_event_loop.__module__.__eq__('asyncio.events')==True (KEY CONTRAST: new_event_loop.__module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14); NEW FINDING: unlike get_event_loop and get_running_loop which are C builtins (__module__=='_asyncio'), new_event_loop is a Python-level function defined in Lib/asyncio/events.py; this is because new_event_loop() calls the current event loop policy and involves Python-level policy objects); asyncio.new_event_loop.__module__.__len__()==14 ('asyncio.events'=14; equal to new_event_loop name len=14 — coincidentally both are 14 chars); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncionelident171

  columns: [id, function, args, expected, description]
  rows:
    - [nel_name_eq,  asyncio.new_event_loop.__name__.__eq__,    ["new_event_loop"],   true,  "new_event_loop.__name__ == 'new_event_loop' (len=14: 'new'=3+'_event_loop'=11; same len as get_event_loop); verified with Python 3.14.3"]
    - [nel_name_len, asyncio.new_event_loop.__name__.__len__,   [],                   14,    "new_event_loop.__name__.__len__() == 14 ('new_event_loop'=14; equal to get_event_loop=14); verified with Python 3.14.3"]
    - [nel_mod_eq,   asyncio.new_event_loop.__module__.__eq__,  ["asyncio.events"],   true,  "new_event_loop.__module__ == 'asyncio.events' (Python function; NOT C builtin like get_event_loop; len=14); verified with Python 3.14.3"]
    - [nel_mod_len,  asyncio.new_event_loop.__module__.__len__, [],                   14,    "new_event_loop.__module__.__len__() == 14 ('asyncio.events'=14; coincidentally equal to name len=14); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.run function name and module identity — extra171
#
# asyncio.run.__name__.__eq__('run')                   == True
# asyncio.run.__name__.__len__()                       == 3
# asyncio.run.__module__.__eq__('asyncio.runners')     == True
# asyncio.run.__module__.__len__()                     == 15
# ---------------------------------------------------------------------------

table asyncio_extra171.asyncio_run_identity:
  description: "asyncio.run function name and module identity checks in asynciorunident171 namespace — asyncio.run.__name__.__eq__('run')==True (run.__name__=='run' (len=3: 'r'+'u'+'n'=3); asyncio.run(coro, *, debug=None, loop_factory=None) is the canonical entry point for asyncio programs; it runs the given coroutine, creates a new event loop for the current thread, sets it as the running loop, runs the coroutine to completion, then closes the loop; added in Python 3.7; asyncio.run() is ALWAYS the recommended way to start an asyncio program in the main thread — it handles loop creation, running, and cleanup automatically); asyncio.run.__name__.__len__()==3 ('run'=3: the shortest function name in this spec; compare: 'run'=3 < 'get_event_loop'=14 < 'get_running_loop'=16); asyncio.run.__module__.__eq__('asyncio.runners')==True (run.__module__=='asyncio.runners' (len=15: 'asyncio'=7+'.'=1+'runners'=7=15); asyncio.run is defined in Lib/asyncio/runners.py — a separate submodule from asyncio.events where new_event_loop lives; 'runners' is a Python-level module housing the high-level runner API); asyncio.run.__module__.__len__()==15 ('asyncio.runners'=15: 1 longer than 'asyncio.events'=14; 7 longer than '_asyncio'=8); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciorunident171

  columns: [id, function, args, expected, description]
  rows:
    - [run_name_eq,  asyncio.run.__name__.__eq__,    ["run"],              true,  "run.__name__ == 'run' (len=3: shortest name in this spec; asyncio.run is the canonical program entry point); verified with Python 3.14.3"]
    - [run_name_len, asyncio.run.__name__.__len__,   [],                   3,     "run.__name__.__len__() == 3 ('run'=3; shortest: run=3 < get_event_loop=14 < get_running_loop=16); verified with Python 3.14.3"]
    - [run_mod_eq,   asyncio.run.__module__.__eq__,  ["asyncio.runners"],  true,  "run.__module__ == 'asyncio.runners' (len=15: 'asyncio'=7+'.'=1+'runners'=7=15); verified with Python 3.14.3"]
    - [run_mod_len,  asyncio.run.__module__.__len__, [],                   15,    "run.__module__.__len__() == 15 ('asyncio.runners'=15; 1 longer than asyncio.events=14); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Cross-comparison of asyncio function modules — extra171
#
# get_event_loop and get_running_loop: __module__=='_asyncio' (C builtins)
# new_event_loop: __module__=='asyncio.events' (Python function)
# run: __module__=='asyncio.runners' (Python function)
# ---------------------------------------------------------------------------

table asyncio_extra171.asyncio_function_module_cross_comparison:
  description: "Cross-comparison of asyncio event loop function modules in asynciofuncmod171 namespace — asyncio.get_event_loop.__module__.__eq__('_asyncio')==True AND asyncio.get_running_loop.__module__.__eq__('_asyncio')==True: KEY FINDING: both get_event_loop and get_running_loop are C-accelerated builtins with __module__=='_asyncio' (the CPython C extension for asyncio internals), NOT 'asyncio.events'; asyncio.new_event_loop.__module__.__eq__('asyncio.events')==True: new_event_loop is a Python-level function in asyncio/events.py; asyncio.run.__module__.__eq__('asyncio.runners')==True: run is a Python-level function in asyncio/runners.py; KEY PATTERN: the two 'get_*' functions are C builtins (hot path — reading the current loop must be fast) while 'new_event_loop' (creates a new loop, involves policy objects) and 'run' (full lifecycle management) are Python-level; ORDERING of module path lengths: '_asyncio'=8 < 'asyncio.events'=14 < 'asyncio.runners'=15; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciofuncmod171

  columns: [id, function, args, expected, description]
  rows:
    - [gel_mod_xcheck,  asyncio.get_event_loop.__module__.__eq__,   ["_asyncio"],         true,  "get_event_loop.__module__ == '_asyncio' (C builtin; cross-check); verified with Python 3.14.3"]
    - [grl_mod_xcheck,  asyncio.get_running_loop.__module__.__eq__,  ["_asyncio"],         true,  "get_running_loop.__module__ == '_asyncio' (C builtin; same as get_event_loop; cross-check); verified with Python 3.14.3"]
    - [nel_mod_xcheck,  asyncio.new_event_loop.__module__.__eq__,    ["asyncio.events"],   true,  "new_event_loop.__module__ == 'asyncio.events' (Python function; contrast with C builtins); verified with Python 3.14.3"]
    - [run_mod_xcheck,  asyncio.run.__module__.__eq__,               ["asyncio.runners"],  true,  "run.__module__ == 'asyncio.runners' (Python function; separate submodule from asyncio.events); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra171
# ---------------------------------------------------------------------------

invariant asyncio_extra171.asyncio_get_event_loop_name_eq:
  description: "asyncio.get_event_loop.__name__.__eq__('get_event_loop') returns True — asyncio.get_event_loop.__name__=='get_event_loop' (len=14: 'get'=3+'_'=1+'event'=5+'_'=1+'loop'=4=14); asyncio.get_event_loop() retrieves the running event loop for the current OS thread; in Python 3.10+, calling get_event_loop() when there is no running loop emits DeprecationWarning; in coroutines and callbacks, prefer get_running_loop() which raises RuntimeError instead of silently creating a loop; the function is a C builtin from _asyncio module (NOT defined in asyncio/events.py despite what the public API suggests); LENGTH ORDERING for asyncio function names in this spec: 'run'=3 < 'get_event_loop'=14 == 'new_event_loop'=14 < 'get_running_loop'=16; NEW in extra171: first standalone get_event_loop.__name__ identity invariant in asynciogelident171 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.get_event_loop.__name__.__eq__
  args: ["get_event_loop"]
  expected: true

invariant asyncio_extra171.asyncio_get_event_loop_module_is_asyncio_c:
  description: "asyncio.get_event_loop.__module__.__eq__('_asyncio') returns True — KEY FINDING: asyncio.get_event_loop.__module__=='_asyncio' (len=8: '_'=1+'asyncio'=7=8); get_event_loop is implemented in C as part of the _asyncio CPython C extension module (Modules/_asynciomodule.c in CPython source); the _asyncio module provides C-accelerated implementations of: get_event_loop, get_running_loop, Task, Future, and other performance-critical asyncio internals; the public asyncio package re-exports these from _asyncio (asyncio/__init__.py imports from _asyncio); CRITICAL DISTINCTION: get_event_loop.__module__=='_asyncio' (C builtin, len=8) while new_event_loop.__module__=='asyncio.events' (Python function, len=14) — functions that are on the hot path (reading the current loop) are in C, while functions that do more work (creating loops, running programs) stay in Python; new_event_loop involves calling the event loop policy object which is Python-level code; NEW in extra171: first standalone get_event_loop.__module__ invariant confirming '_asyncio' C module in asynciogelident171 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.get_event_loop.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra171.asyncio_get_running_loop_name_eq:
  description: "asyncio.get_running_loop.__name__.__eq__('get_running_loop') returns True — asyncio.get_running_loop.__name__=='get_running_loop' (len=16: 'get'=3+'_'=1+'running'=7+'_'=1+'loop'=4=16); asyncio.get_running_loop() was added in Python 3.7 as the safe alternative to get_event_loop(): it returns the running loop or raises RuntimeError if called outside a running loop; this explicit failure mode (RuntimeError) is preferred over get_event_loop()'s implicit loop-creation behavior; calling get_running_loop() at the module level (outside async code) always raises RuntimeError; 'get_running_loop'=16 is 2 chars longer than 'get_event_loop'=14 because 'running'=7 > 'event'=5 by 2; both are C builtins from _asyncio module; NEW in extra171: first standalone get_running_loop.__name__ identity invariant in asynciogrlident171 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.get_running_loop.__name__.__eq__
  args: ["get_running_loop"]
  expected: true

invariant asyncio_extra171.asyncio_get_running_loop_module_is_asyncio_c:
  description: "asyncio.get_running_loop.__module__.__eq__('_asyncio') returns True — KEY FINDING: asyncio.get_running_loop.__module__=='_asyncio' (len=8; same as get_event_loop.__module__); get_running_loop is a C builtin — the most performance-sensitive of the loop-access functions because it is commonly called from within coroutines where avoiding the overhead of Python-level attribute lookup matters; the C implementation accesses a thread-local variable directly; PATTERN: both get_event_loop and get_running_loop share __module__=='_asyncio' while new_event_loop.__module__=='asyncio.events' and run.__module__=='asyncio.runners' — the two functions that merely READ the current loop are C builtins; the two functions that CREATE or MANAGE loops are Python; NEW in extra171: first standalone get_running_loop.__module__ invariant confirming '_asyncio' C module in asynciogrlident171 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.get_running_loop.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra171.asyncio_new_event_loop_module_eq:
  description: "asyncio.new_event_loop.__module__.__eq__('asyncio.events') returns True — asyncio.new_event_loop.__module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14); new_event_loop is a Python-level function in Lib/asyncio/events.py (NOT a C builtin); new_event_loop() calls get_event_loop_policy().new_event_loop() — it delegates to the current event loop policy object which is Python-level; this Python-level delegation is why new_event_loop lives in asyncio.events (with the policy classes) rather than in _asyncio (the C module for hot-path builtins); 'asyncio.events'=14 is 6 chars longer than '_asyncio'=8; COINCIDENCE: new_event_loop.__name__.__len__()==14 == new_event_loop.__module__.__len__()==14 — both the function name ('new_event_loop'=14) and its module path ('asyncio.events'=14) have the same length; NEW in extra171: first standalone new_event_loop.__module__ invariant confirming 'asyncio.events' in asyncionelident171 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.new_event_loop.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra171.asyncio_run_module_eq:
  description: "asyncio.run.__module__.__eq__('asyncio.runners') returns True — asyncio.run.__module__=='asyncio.runners' (len=15: 'asyncio'=7+'.'=1+'runners'=7=15); asyncio.run is defined in Lib/asyncio/runners.py; asyncio.run() is the high-level entry point that: (1) creates a new event loop, (2) sets it as the current loop, (3) runs the provided coroutine until completion, (4) closes the loop and finalizes it; as of Python 3.11, asyncio.run() accepts a loop_factory parameter; 'asyncio.runners'=15 is the longest module path among the four functions in this spec: '_asyncio'=8 < 'asyncio.events'=14 < 'asyncio.runners'=15; compare: asyncio.run.__name__='run'=3 is the SHORTEST function name while its module path 'asyncio.runners'=15 is the LONGEST — an inverse relationship; NEW in extra171: first standalone run.__module__ invariant confirming 'asyncio.runners' in asynciorunident171 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.run.__module__.__eq__
  args: ["asyncio.runners"]
  expected: true

invariant asyncio_extra171.asyncio_run_name_eq:
  description: "asyncio.run.__name__.__eq__('run') returns True — asyncio.run.__name__=='run' (len=3: 'r'+'u'+'n'=3; the shortest asyncio function name in this spec series); asyncio.run() was added in Python 3.7 as the recommended high-level API for running asyncio programs; before asyncio.run(), users had to manually create a loop, call loop.run_until_complete(), and close the loop; asyncio.run() handles this lifecycle automatically; asyncio.run() also installs signal handlers on POSIX for KeyboardInterrupt and wraps the coroutine in a Task; 'run'=3 is dramatically shorter than all other function names in this spec: 'run'=3 vs 'get_event_loop'=14 (11 shorter) vs 'get_running_loop'=16 (13 shorter); this brevity reflects asyncio.run's role as the idiomatic top-level call — it appears in nearly every asyncio program as 'asyncio.run(main())'; COMPARISON: asyncio.run.__module__=='asyncio.runners' (len=15) but asyncio.run.__name__=='run' (len=3) — the module path is 5x longer than the function name; NEW in extra171: first standalone run.__name__ identity invariant in asynciorunident171 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.run.__name__.__eq__
  args: ["run"]
  expected: true

