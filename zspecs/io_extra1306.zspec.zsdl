spec: io_extra1306
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "Wave 534 (_extra1306): focuses on exception-raising behavior for bad argument types to io constructors and io.open."
    - "io.BytesIO('str') raises TypeError: a bytes-like object is required, not 'str'."
    - "io.BytesIO(42) raises TypeError: a bytes-like object is required, not 'int'."
    - "io.StringIO(b'bytes') raises TypeError: initial_value must be str or None, not bytes."
    - "io.open('/dev/null', 'bad_mode') raises ValueError: invalid mode."
    - "io.open('/dev/null', 'rt', encoding=42) raises TypeError: encoding must be str or None."
    - "All exceptions verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table io_extra1306.bytes_io_errors:
  description: "io.BytesIO raises TypeError when given non-bytes-like initial value"
  kind: python_call_raises
  category: constructor_errors
  id_prefix: io1306be
  columns: [id, function, args, exception]
  rows:
    - [io1306be001, io.BytesIO, ["not bytes"],       "TypeError"]
    - [io1306be002, io.BytesIO, [42],                "TypeError"]
    - [io1306be003, io.BytesIO, [3.14],              "TypeError"]
    - [io1306be004, io.BytesIO, [true],              "TypeError"]
    - [io1306be005, io.BytesIO, [[]],                "TypeError"]
    - [io1306be006, io.BytesIO, [{}],                "TypeError"]

table io_extra1306.string_io_errors:
  description: "io.StringIO raises TypeError when given bytes as initial value"
  kind: python_call_raises
  category: constructor_errors
  id_prefix: io1306se
  columns: [id, function, args, exception]
  rows:
    - [io1306se001, io.StringIO, [null, 42],         "TypeError"]
    - [io1306se002, io.StringIO, [42],               "TypeError"]
    - [io1306se003, io.StringIO, [3.14],             "TypeError"]
    - [io1306se004, io.StringIO, [[]],               "TypeError"]
    - [io1306se005, io.StringIO, [{}],               "TypeError"]
    - [io1306se006, io.StringIO, [true],             "TypeError"]

table io_extra1306.open_mode_errors:
  description: "io.open raises ValueError on invalid mode strings and TypeError on wrong encoding type"
  kind: python_call_raises
  category: open_errors
  id_prefix: io1306oe
  columns: [id, function, args, exception]
  rows:
    - [io1306oe001, io.open, ["/dev/null", "bad_mode"],         "ValueError"]
    - [io1306oe002, io.open, ["/dev/null", "rbt"],              "ValueError"]
    - [io1306oe003, io.open, ["/dev/null", "rwb"],              "ValueError"]
    - [io1306oe004, io.open, ["/dev/null", "rr"],               "ValueError"]
    - [io1306oe005, io.open, [null, "r"],                       "TypeError"]
    - [io1306oe006, io.open, [null],                            "TypeError"]
