invariant multiprocessing_extra69.Process_init_co_name:
  description: "multiprocessing.Process.__init__.__code__.co_name.__eq__('__init__') returns True — Process is a pure Python class; its __init__ code object's co_name is '__init__'; NEW in extra69: first standalone co_name invariant for Process.__init__ in the mpcode69 namespace; wave 237 first code object name invariant for Process.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

invariant multiprocessing_extra69.Process_init_co_argcount_6:
  description: "multiprocessing.Process.__init__.__code__.co_argcount.__eq__(6) returns True — Process.__init__ positional parameters are self + group + target + name + args + kwargs = 6; daemon is keyword-only; co_argcount is 6; NEW in extra69: first standalone co_argcount invariant for Process.__init__ in the mpcode69 namespace; wave 237 first code object argcount invariant for Process.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.__init__.__code__.co_argcount.__eq__
  args: [6]
  expected: true

invariant multiprocessing_extra69.Process_mro1_BaseProcess:
  description: "multiprocessing.Process.__mro__[1].__name__.__eq__('BaseProcess') returns True — second MRO entry is the immediate base class BaseProcess; __mro__[1].__name__ is 'BaseProcess'; NEW in extra69: first standalone __mro__[1].__name__ invariant for Process in the mpcode69 namespace; wave 237 first MRO entry name invariant for Process; verified with Python 3.14.3"
  category: mro
  kind: python_call_eq
  function: "Process.__mro__[1].__name__.__eq__"
  args: ["BaseProcess"]
  expected: true

invariant multiprocessing_extra69.Process_bases0_BaseProcess:
  description: "multiprocessing.Process.__bases__[0].__name__.__eq__('BaseProcess') returns True — Process inherits directly from BaseProcess; __bases__[0].__name__ is 'BaseProcess'; NEW in extra69: first standalone __bases__[0].__name__ invariant for Process in the mpcode69 namespace; wave 237 first bases name invariant for Process; verified with Python 3.14.3"
  category: mro
  kind: python_call_eq
  function: "Process.__bases__[0].__name__.__eq__"
  args: ["BaseProcess"]
  expected: true

invariant multiprocessing_extra69.Process_init_varnames_tuple:
  description: "multiprocessing.Process.__init__.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — co_varnames is always a tuple in CPython; Process.__init__.__code__.co_varnames.__class__.__name__ is 'tuple'; NEW in extra69: first standalone co_varnames class name invariant for Process.__init__ in the mpcode69 namespace; wave 237 first co_varnames type invariant for Process.__init__; verified with Python 3.14.3"
  category: code
