spec: multiprocessing_extra69
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Process — Python multiprocessing Process documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec extends multiprocessing_extra68.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__/__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/active_children/current_process __qualname__, Pool/Queue __doc__.__class__.__name__=='str', exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process/Pool method tables, __mro__.__len__() tables, __all__ metadata, class __dict__ tables, class __class__ identity, __repr__/__weakref__/__eq__ class names, mp.__all__ membership and length, __loader__/__spec__/__file__/__cached__ class names, __spec__ attributes, code object attribute chains, __defaults__/__kwdefaults__ class names, exception hierarchy, Pool.__init__ code object attributes."
    - "This spec covers (mpcode69 namespace): wave 237 theme — multiprocessing class __init__ code object attributes. NEW in extra69: Process.__init__.__code__.co_name=='__init__'; Process.__init__.__code__.co_argcount==6 (self + group + target + name + args + kwargs; daemon is keyword-only); Process.__init__.__code__.co_varnames.__class__.__name__=='tuple'; Process.__mro__[0].__name__=='Process'; Process.__mro__[1].__name__=='BaseProcess'; Process.__mro__[2].__name__=='object'; Process.__bases__[0].__name__=='BaseProcess'; Pool.__mro__[0].__name__=='Pool'; Pool.__mro__[1].__name__=='object'. Pool is accessed via multiprocessing.pool.Pool."
    - "multiprocessing.Process.__init__.__code__.co_name == '__init__'. Process is a pure Python class in multiprocessing/process.py; its __init__ is a Python function; co_name is '__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__init__.__code__.co_argcount == 6. Process.__init__ positional parameters are self + group + target + name + args + kwargs = 6; daemon is keyword-only (not counted by co_argcount). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__init__.__code__.co_varnames.__class__.__name__ == 'tuple'. co_varnames is always a tuple in CPython; Process.__init__.__code__.co_varnames.__class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__mro__[0].__name__ == 'Process'. First MRO entry is always the class itself. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__mro__[1].__name__ == 'BaseProcess'. Second MRO entry is the immediate base class BaseProcess (internal implementation class). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__mro__[2].__name__ == 'object'. Third MRO entry is object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess'. Process inherits directly from BaseProcess; __bases__[0].__name__ is 'BaseProcess'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.__mro__[0].__name__ == 'Pool'. First MRO entry is Pool itself; Pool inherits directly from object with MRO depth 2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.pool.Pool.__mro__[1].__name__ == 'object'. Pool inherits directly from object; __mro__[1].__name__ is 'object'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Process.__init__ code object checks — extra69
#
# Wave 237 theme: multiprocessing class __init__ code object attributes.
#
# Process.__init__.__code__.co_name == '__init__'
# Process.__init__.__code__.co_argcount == 6
# ---------------------------------------------------------------------------

table multiprocessing_extra69.Process_init_code:
  description: "multiprocessing Process.__init__ code object attribute checks in mpcode69 namespace — wave 237 theme: multiprocessing class __init__ code object attributes; Process.__init__.__code__.co_name=='__init__' (pure Python class; code object stores the function name); Process.__init__.__code__.co_argcount==6 (self + group + target + name + args + kwargs; daemon is keyword-only not counted by co_argcount); NEW in extra69: first co_name and co_argcount checks for Process.__init__ in the mpcode69 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpcode69

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_co_name,     Process.__init__.__code__.co_name.__eq__,     ["__init__"], true, "Process.__init__.__code__.co_name == '__init__' — multiprocessing.Process is a pure Python class in multiprocessing/process.py; its __init__ code object's co_name is '__init__'; NEW in extra69: first co_name.__eq__('__init__') check for Process.__init__ in the mpcode69 namespace; verified with Python 3.14.3"]
    - [process_init_co_argcount, Process.__init__.__code__.co_argcount.__eq__, [6],          true, "Process.__init__.__code__.co_argcount == 6 — Process.__init__ positional parameters are self + group + target + name + args + kwargs = 6; daemon is keyword-only (not counted by co_argcount); NEW in extra69: first co_argcount.__eq__(6) check for Process.__init__ in the mpcode69 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process.__init__ co_varnames class check — extra69
#
# Wave 237 theme: code object co_varnames type identity.
#
# Process.__init__.__code__.co_varnames.__class__.__name__ == 'tuple'
# ---------------------------------------------------------------------------

table multiprocessing_extra69.Process_init_varnames:
  description: "multiprocessing Process.__init__.__code__.co_varnames.__class__.__name__ check in mpcode69 namespace — wave 237 theme: code object co_varnames type identity; co_varnames is always a tuple in CPython; Process.__init__.__code__.co_varnames.__class__.__name__=='tuple'; NEW in extra69: first co_varnames.__class__.__name__=='tuple' check for Process.__init__ in the mpcode69 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpcode69a

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_varnames_cls, Process.__init__.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true, "Process.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple in CPython; Process.__init__.__code__.co_varnames.__class__.__name__ is 'tuple'; NEW in extra69: first co_varnames.__class__.__name__.__eq__('tuple') check for Process.__init__ in the mpcode69 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process MRO name checks — extra69
#
# Wave 237 theme: Process MRO entry names.
#
# Process.__mro__[0].__name__ == 'Process'
# Process.__mro__[1].__name__ == 'BaseProcess'
# Process.__mro__[2].__name__ == 'object'
# Process.__bases__[0].__name__ == 'BaseProcess'
# ---------------------------------------------------------------------------

table multiprocessing_extra69.Process_mro:
  description: "multiprocessing Process MRO and bases name checks in mpcode69 namespace — wave 237 theme: Process MRO entry names; Process.__mro__[0].__name__=='Process' (first MRO entry is the class itself); Process.__mro__[1].__name__=='BaseProcess' (immediate base class; internal implementation class); Process.__mro__[2].__name__=='object' (root class); Process.__bases__[0].__name__=='BaseProcess' (direct parent); NEW in extra69: first MRO and bases name checks for Process in the mpcode69 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: mro
  id_prefix: mpcode69b

  columns: [id, function, args, expected, description]
  rows:
    - [process_mro0_name,   "Process.__mro__[0].__name__.__eq__",   ["Process"],     true, "Process.__mro__[0].__name__ == 'Process' — first MRO entry is always the class itself; __mro__[0].__name__ is 'Process'; NEW in extra69: first __mro__[0].__name__ check for Process in the mpcode69 namespace; verified with Python 3.14.3"]
    - [process_mro1_name,   "Process.__mro__[1].__name__.__eq__",   ["BaseProcess"], true, "Process.__mro__[1].__name__ == 'BaseProcess' — second MRO entry is the immediate base class BaseProcess (internal implementation class in multiprocessing/process.py); __mro__[1].__name__ is 'BaseProcess'; NEW in extra69: first __mro__[1].__name__ check for Process in the mpcode69 namespace; verified with Python 3.14.3"]
    - [process_mro2_name,   "Process.__mro__[2].__name__.__eq__",   ["object"],      true, "Process.__mro__[2].__name__ == 'object' — third MRO entry is object, the root of all Python classes; __mro__[2].__name__ is 'object'; NEW in extra69: first __mro__[2].__name__ check for Process in the mpcode69 namespace; verified with Python 3.14.3"]
    - [process_bases0_name, "Process.__bases__[0].__name__.__eq__", ["BaseProcess"], true, "Process.__bases__[0].__name__ == 'BaseProcess' — Process inherits directly from BaseProcess; __bases__[0].__name__ is 'BaseProcess'; NEW in extra69: first __bases__[0].__name__ check for Process in the mpcode69 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
