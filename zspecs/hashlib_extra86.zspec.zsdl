spec: hashlib_extra86
version: ">=3.9"
extends: hashlib_extra85
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra85.zspec.zsdl — covers sha256/sha512/md5/sha1/__module__.__eq__('_hashlib') / sha3_256/sha3_512/shake_128/shake_256/__module__.__eq__('_hashlib') / file_digest/__class__.__name__/__module__/__code__/co_name/co_argcount (table + invariants)."
    - "hashlib_extra84.zspec.zsdl — covers sha256/__qualname__/__eq__('openssl_sha256')/True / sha512/md5/sha1/__qualname__/__len__() / sha224/sha384/sha3_256/sha3_512/__qualname__/__len__() / blake2b/blake2s/new/__qualname__/__len__() / algorithms_guaranteed/__len__()==14 (table + invariants)."
    - "hashlib_extra83.zspec.zsdl — covers sha256/sha512/md5/sha1/blake2b/blake2s __doc__.__class__.__name__ and algorithms_guaranteed/algorithms_available membership (table + invariants)."
    - "hashlib_extra80.zspec.zsdl — covers blake2b/blake2s class-level size constants and hexdigest/__class__/__name__ (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra85; it does NOT duplicate invariants present in those files."
    - "Wave 250 theme: hashlib blake2b/blake2s class identity — __class__.__name__/'type', __name__, __module__/'_blake2', __qualname__, __bases__[0].__name__/'object', __mro__.__len__()==2, SALT_SIZE.__class__.__name__/'int'."
    - "hashlib.blake2b.__class__.__name__ == 'type' — blake2b is an actual Python class (type), not a C builtin function like sha256. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__class__.__name__ == 'type' — blake2s is also a Python class. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__name__ == 'blake2b' — the class name attribute. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__name__ == 'blake2s' — the class name attribute. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__ == '_blake2' — blake2b lives in the _blake2 C extension, NOT _hashlib. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__module__ == '_blake2' — blake2s also lives in _blake2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__qualname__ == 'blake2b' — the qualified name matches the class name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__qualname__ == 'blake2s' — the qualified name matches the class name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__bases__[0].__name__ == 'object' — blake2b directly inherits from object. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__bases__[0].__name__ == 'object' — blake2s directly inherits from object. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__mro__.__len__() == 2 — MRO is [blake2b, object]. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__mro__.__len__() == 2 — MRO is [blake2s, object]. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.SALT_SIZE.__class__.__name__ == 'int' — SALT_SIZE is an int class attribute (value 16). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.SALT_SIZE.__class__.__name__ == 'int' — SALT_SIZE is an int class attribute (value 8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b/__class__/__name__ / blake2s/__class__/__name__
# hashlib.blake2b/__name__ / blake2s/__name__
#
# Wave 250 theme: blake2b/blake2s class identity — type and name.
#
# blake2b and blake2s are actual Python classes (type), unlike sha256/md5
# which are C builtin functions. Their __class__.__name__ is 'type'.
# Their __name__ attribute is the class name itself.
# No prior hashlib spec checks __class__.__name__ or __name__ for blake2b/blake2s.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra86.blake2_class_and_name:
  description: "hashlib.blake2b/__class__/__name__.__eq__('type')==True / blake2s/__class__/__name__.__eq__('type')==True / blake2b/__name__.__eq__('blake2b')==True / blake2s/__name__.__eq__('blake2s')==True — blake2b and blake2s are genuine Python classes (their __class__ is 'type'), unlike sha256/md5 which are C builtin functions; their __name__ equals their class name; no prior hashlib spec checks __class__.__name__ or __name__ for blake2b/blake2s; first class identity anchor for hashlib.blake2b and blake2s"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra86

  columns: [id, function, args, expected]
  rows:
    - [blake2b_class_name_type,   blake2b.__class__.__name__.__eq__, ["type"],   true]
    - [blake2s_class_name_type,   blake2s.__class__.__name__.__eq__, ["type"],   true]
    - [blake2b_name_eq_blake2b,   blake2b.__name__.__eq__,           ["blake2b"], true]
    - [blake2s_name_eq_blake2s,   blake2s.__name__.__eq__,           ["blake2s"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b/__module__ / blake2s/__module__
# hashlib.blake2b/__qualname__ / blake2s/__qualname__
#
# Wave 250 theme: blake2b/blake2s __module__ and __qualname__ identity.
#
# blake2b and blake2s live in the _blake2 C extension (NOT _hashlib).
# Their __qualname__ equals their __name__ (no nesting).
# No prior hashlib spec checks __module__ or __qualname__ for blake2b/blake2s.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra86.blake2_module_and_qualname:
  description: "hashlib.blake2b/__module__.__eq__('_blake2')==True / blake2s/__module__.__eq__('_blake2')==True / blake2b/__qualname__.__eq__('blake2b')==True / blake2s/__qualname__.__eq__('blake2s')==True — blake2b and blake2s are implemented in the _blake2 C extension (not _hashlib); their __qualname__ matches their __name__; no prior hashlib spec checks __module__ or __qualname__ for blake2b/blake2s; first __module__ and __qualname__ identity anchor for hashlib.blake2b and blake2s"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra86

  columns: [id, function, args, expected]
  rows:
    - [blake2b_module_eq_blake2,    blake2b.__module__.__eq__,   ["_blake2"], true]
    - [blake2s_module_eq_blake2,    blake2s.__module__.__eq__,   ["_blake2"], true]
    - [blake2b_qualname_eq_blake2b, blake2b.__qualname__.__eq__, ["blake2b"], true]
    - [blake2s_qualname_eq_blake2s, blake2s.__qualname__.__eq__, ["blake2s"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b/__bases__[0]/__name__ / blake2s/__bases__[0]/__name__
# hashlib.blake2b/__mro__/__len__() / blake2s/__mro__/__len__()
#
# Wave 250 theme: blake2b/blake2s inheritance and MRO.
#
# blake2b and blake2s both inherit directly from object.
# Their MRO is [blake2b, object] or [blake2s, object] (length 2).
# No prior hashlib spec checks __bases__[0].__name__ or __mro__.__len__ for blake2b/blake2s.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra86.blake2_bases_and_mro:
  description: "hashlib.blake2b/__bases__[0]/__name__.__eq__('object')==True / blake2s/__bases__[0]/__name__.__eq__('object')==True / blake2b/__mro__/__len__()==2 / blake2s/__mro__/__len__()==2 — blake2b and blake2s both inherit directly from object (no intermediate base); their MRO has exactly 2 entries [blake2x, object]; no prior hashlib spec checks __bases__[0].__name__ or __mro__.__len__ for blake2b/blake2s; first inheritance and MRO anchor for hashlib.blake2b and blake2s"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra86

  columns: [id, function, args, expected]
  rows:
    - [blake2b_bases0_name_object,  "blake2b.__bases__[0].__name__.__eq__", ["object"], true]
    - [blake2s_bases0_name_object,  "blake2s.__bases__[0].__name__.__eq__", ["object"], true]
    - [blake2b_mro_len_2,           blake2b.__mro__.__len__,                [],         2]
    - [blake2s_mro_len_2,           blake2s.__mro__.__len__,                [],         2]

# ---------------------------------------------------------------------------
# hashlib.blake2b/SALT_SIZE/__class__/__name__ / blake2s/SALT_SIZE/__class__/__name__
# hashlib.blake2b/__name__/__len__() / blake2s/__name__/__len__()
# hashlib.blake2b/__module__/__len__() / blake2s/__module__/__len__()
#
# Wave 250 theme: SALT_SIZE class attribute type and name/module string lengths.
#
# SALT_SIZE is an int class attribute on both blake2b and blake2s.
# blake2b.__name__ is 'blake2b' (7 chars), blake2b.__module__ is '_blake2' (7 chars).
# blake2s.__name__ is 'blake2s' (7 chars), blake2s.__module__ is '_blake2' (7 chars).
# No prior hashlib spec checks SALT_SIZE.__class__.__name__ or these string lengths.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra86.blake2_salt_size_and_lengths:
  description: "hashlib.blake2b/SALT_SIZE/__class__/__name__.__eq__('int')==True / blake2s/SALT_SIZE/__class__/__name__.__eq__('int')==True / blake2b/__name__/__len__()==7 / blake2s/__name__/__len__()==7 — SALT_SIZE is an integer class attribute on both blake2b (value 16) and blake2s (value 8); 'blake2b' and 'blake2s' are both 7-character strings; no prior hashlib spec checks SALT_SIZE.__class__.__name__ or __name__/__len__ for blake2b/blake2s; first SALT_SIZE type and name-length anchor for hashlib.blake2b and blake2s"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra86

  columns: [id, function, args, expected]
  rows:
    - [blake2b_salt_size_class_int,  blake2b.SALT_SIZE.__class__.__name__.__eq__, ["int"], true]
    - [blake2s_salt_size_class_int,  blake2s.SALT_SIZE.__class__.__name__.__eq__, ["int"], true]
    - [blake2b_name_len_7,           blake2b.__name__.__len__,                    [],      7]
    - [blake2s_name_len_7,           blake2s.__name__.__len__,                    [],      7]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__class__.__name__.__eq__('type') — standalone
#
# blake2b.__class__.__name__ is 'type'. No prior hashlib spec checks
# blake2b.__class__.__name__. First __class__.__name__ standalone for
# hashlib.blake2b. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra86.blake2b_class_name_type:
  description: "hashlib.blake2b.__class__.__name__.__eq__('type') == True — blake2b is a genuine Python class (its metaclass is 'type'), unlike sha256/md5 which are C builtin functions; no prior hashlib spec checks blake2b.__class__.__name__; first __class__.__name__ standalone for hashlib.blake2b"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__module__.__eq__('_blake2') — standalone
#
# blake2b.__module__ is '_blake2'. No prior hashlib spec checks
# blake2b.__module__. First __module__ standalone for hashlib.blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra86.blake2b_module_eq_blake2:
  description: "hashlib.blake2b.__module__.__eq__('_blake2') == True — blake2b is implemented in the _blake2 C extension (not _hashlib); no prior hashlib spec checks blake2b.__module__; first __module__ standalone for hashlib.blake2b"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.__module__.__eq__
  args: ["_blake2"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.__module__.__eq__('_blake2') — standalone
#
# blake2s.__module__ is '_blake2'. No prior hashlib spec checks
# blake2s.__module__. First __module__ standalone for hashlib.blake2s.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra86.blake2s_module_eq_blake2:
  description: "hashlib.blake2s.__module__.__eq__('_blake2') == True — blake2s is implemented in the _blake2 C extension (not _hashlib); no prior hashlib spec checks blake2s.__module__; first __module__ standalone for hashlib.blake2s"
  category: class_attrs
  kind: python_call_eq
  function: blake2s.__module__.__eq__
  args: ["_blake2"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__mro__.__len__() — standalone
#
# blake2b.__mro__.__len__() is 2: [blake2b, object].
# No prior hashlib spec checks blake2b.__mro__.__len__.
# First __mro__.__len__ standalone for hashlib.blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra86.blake2b_mro_len_2:
  description: "hashlib.blake2b.__mro__.__len__() == 2 — blake2b's MRO contains exactly [blake2b, object]; direct inheritance from object with no intermediate classes; no prior hashlib spec checks blake2b.__mro__.__len__; first __mro__.__len__ standalone for hashlib.blake2b"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# hashlib.blake2b.SALT_SIZE.__class__.__name__.__eq__('int') — standalone
#
# blake2b.SALT_SIZE.__class__.__name__ is 'int'. No prior hashlib spec checks
# blake2b.SALT_SIZE.__class__.__name__. First SALT_SIZE.__class__.__name__
# standalone for hashlib.blake2b. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra86.blake2b_salt_size_class_int:
  description: "hashlib.blake2b.SALT_SIZE.__class__.__name__.__eq__('int') == True — SALT_SIZE is an integer class attribute (value 16) on blake2b; no prior hashlib spec checks SALT_SIZE.__class__.__name__; first SALT_SIZE type standalone for hashlib.blake2b"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.SALT_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true
