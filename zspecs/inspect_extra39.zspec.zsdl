spec: inspect_extra39
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra38.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/iscode/isframe/istraceback __name__/__qualname__.__len__(); iscoroutinefunction/isgeneratorfunction/isasyncgenfunction __name__/__qualname__.__len__(); getmembers/getfile/getsource/getsourcelines/getmodule/signature/stack/currentframe/getfullargspec __qualname__.__len__(); Parameter/__mro__.__len__()==2; Signature/__mro__.__len__()==2; BoundArguments/__mro__.__len__()==2; Parameter.empty.__class__.__name__.__len__()==4; Parameter.POSITIONAL_ONLY/__class__.__name__.__len__()==14; _ParameterKind.__qualname__.__len__()==14; inspect.__all__.__len__()==107; CO_OPTIMIZED==1; cleandoc/__name__(8)/formatannotation/__name__(16)/getattr_static/__name__(14)/classify_class_attrs/__name__(20); Signature method qualnames: __init__(18)/bind(14)/bind_partial(22)/replace(17); Parameter method qualnames: __init__(18)/replace(17); BoundArguments.apply_defaults qualname(29); BoundArguments.args.__class__.__name__(8); getmembers/__module__.__len__(7); signature/__module__.__len__(7); isfunction/__module__.__len__(7); Parameter/__module__.__len__(7); Signature/__module__.__len__(7); BoundArguments/__module__.__len__(7); Parameter.empty.__name__.__len__()==6; BoundArguments.__name__.__len__()==14; FullArgSpec._fields.__len__()==7."
    - "This spec covers: inspect.Parameter.POSITIONAL_ONLY integer value (0); inspect.Parameter.POSITIONAL_OR_KEYWORD integer value (1); inspect.Parameter.VAR_POSITIONAL integer value (2); inspect.Parameter.KEYWORD_ONLY integer value (3); inspect.Parameter.VAR_KEYWORD integer value (4); inspect.Parameter.__name__ == 'Parameter'; inspect.Parameter.__module__ == 'inspect'; inspect.Signature.__name__ == 'Signature'; inspect.Signature.__module__ == 'inspect'."
    - "Key findings: The five inspect.Parameter kind constants form a contiguous zero-based integer sequence: POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1, VAR_POSITIONAL=2, KEYWORD_ONLY=3, VAR_KEYWORD=4. These are _ParameterKind enum values and their integer representations are determined by the order they are defined in Lib/inspect.py. inspect.Parameter.__name__ is 'Parameter' (9 chars) and inspect.Parameter.__module__ is 'inspect' (7 chars) — matching the class_module_name_lengths table in the prior spec which recorded Parameter.__module__.__len__()==7. inspect.Signature.__name__ is 'Signature' (9 chars) and inspect.Signature.__module__ is 'inspect' (7 chars) — both Parameter and Signature have the same 9-char __name__ length. No prior inspect spec records these enum integer values or these string equality invariants in the extra39 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.Parameter kind constants — extra39 namespace
#
# inspect.Parameter.POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL,
# KEYWORD_ONLY, and VAR_KEYWORD are _ParameterKind enum values whose integer
# representations form the contiguous sequence 0–4. They are defined in this
# order in Lib/inspect.py. The integer values matter because code that
# inspects parameter kinds may compare against these constants numerically.
# Prior specs recorded Parameter.POSITIONAL_ONLY.__class__.__name__.__len__()==14
# and _ParameterKind.__qualname__.__len__()==14, but not the integer values
# themselves. These five integer equality invariants are recorded for the
# first time in the extra39 namespace.
# ---------------------------------------------------------------------------

table inspect_extra39.parameter_kind_values:
  description: "inspect.Parameter kind constant integer values: POSITIONAL_ONLY(0), POSITIONAL_OR_KEYWORD(1), VAR_POSITIONAL(2), KEYWORD_ONLY(3), VAR_KEYWORD(4)"
  kind: python_call_eq
  category: constants
  id_prefix: paramkind39

  columns: [id, function, args, expected, description]
  rows:
    - [POSITIONAL_ONLY,
       "Parameter.POSITIONAL_ONLY.__eq__",
       [0],
       true,
       "inspect.Parameter.POSITIONAL_ONLY == 0 — first _ParameterKind enum value; positional-only parameters appear before a / in the signature"]
    - [POSITIONAL_OR_KEYWORD,
       "Parameter.POSITIONAL_OR_KEYWORD.__eq__",
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD == 1 — default parameter kind; can be passed positionally or by keyword"]
    - [VAR_POSITIONAL,
       "Parameter.VAR_POSITIONAL.__eq__",
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL == 2 — *args parameter; captures extra positional arguments as a tuple"]
    - [KEYWORD_ONLY,
       "Parameter.KEYWORD_ONLY.__eq__",
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY == 3 — parameters after * or *args; must be passed by keyword"]
    - [VAR_KEYWORD,
       "Parameter.VAR_KEYWORD.__eq__",
       [4],
       true,
       "inspect.Parameter.VAR_KEYWORD == 4 — **kwargs parameter; captures extra keyword arguments as a dict"]

# ---------------------------------------------------------------------------
# inspect.Parameter and inspect.Signature identity metadata — extra39 namespace
#
# inspect.Parameter.__name__ is 'Parameter' (9 chars) and inspect.Parameter.
# __module__ is 'inspect' (7 chars). inspect.Signature.__name__ is 'Signature'
# (9 chars) and inspect.Signature.__module__ is 'inspect' (7 chars). Both
# classes have the same __name__ length (9) and the same __module__ (7 chars).
# Prior specs recorded __module__.__len__()==7 for both classes, but not the
# string equality invariants for __name__ or the direct __module__ equality.
# These four equality invariants are recorded for the first time in the
# extra39 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra39.Parameter_name:
  description: "inspect.Parameter.__name__ == 'Parameter' — pure-Python class representing a single callable parameter; 9-char name"
  category: identity
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra39.Parameter_module:
  description: "inspect.Parameter.__module__ == 'inspect' — pure-Python class defined in Lib/inspect.py; 7-char module name"
  category: module_metadata
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra39.Signature_name:
  description: "inspect.Signature.__name__ == 'Signature' — pure-Python class representing a callable's full signature; 9-char name; same length as Parameter.__name__"
  category: identity
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra39.Signature_module:
  description: "inspect.Signature.__module__ == 'inspect' — pure-Python class defined in Lib/inspect.py; 7-char module name; same as Parameter.__module__"
  category: module_metadata
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true
