spec: uuid_extra1036
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module UUID class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid.UUID property descriptor class names and module-level identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1036.uuid_numeric_property_class_names:
  description: "uuid.UUID numeric field property descriptor __class__.__name__ identity"
  kind: python_call_eq
  category: property_class_names
  id_prefix: uu1036n
  columns: [id, function, args, expected]
  rows:
    - [uu1036n001, uuid.UUID.int.__class__.__name__.__eq__,              ["property"], true]
    - [uu1036n002, uuid.UUID.time_low.__class__.__name__.__eq__,         ["property"], true]
    - [uu1036n003, uuid.UUID.time_mid.__class__.__name__.__eq__,         ["property"], true]
    - [uu1036n004, uuid.UUID.time_hi_version.__class__.__name__.__eq__,  ["property"], true]
    - [uu1036n005, uuid.UUID.clock_seq_hi_variant.__class__.__name__.__eq__, ["property"], true]
    - [uu1036n006, uuid.UUID.clock_seq_low.__class__.__name__.__eq__,    ["property"], true]
    - [uu1036n007, uuid.UUID.node.__class__.__name__.__eq__,             ["property"], true]

table uuid_extra1036.uuid_bytes_property_class_names:
  description: "uuid.UUID bytes and fields property descriptor __class__.__name__ identity"
  kind: python_call_eq
  category: property_class_names
  id_prefix: uu1036b
  columns: [id, function, args, expected]
  rows:
    - [uu1036b001, uuid.UUID.bytes.__class__.__name__.__eq__,            ["property"], true]
    - [uu1036b002, uuid.UUID.bytes_le.__class__.__name__.__eq__,         ["property"], true]
    - [uu1036b003, uuid.UUID.fields.__class__.__name__.__eq__,           ["property"], true]
    - [uu1036b004, uuid.UUID.hex.__class__.__name__.__eq__,              ["property"], true]
    - [uu1036b005, uuid.UUID.urn.__class__.__name__.__eq__,              ["property"], true]
    - [uu1036b006, uuid.UUID.variant.__class__.__name__.__eq__,          ["property"], true]
    - [uu1036b007, uuid.UUID.version.__class__.__name__.__eq__,          ["property"], true]

table uuid_extra1036.uuid_module_and_class_identity:
  description: "uuid module and UUID class identity checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: uu1036m
  columns: [id, function, args, expected]
  rows:
    - [uu1036m001, uuid.__doc__.__class__.__name__.__eq__,               ["str"],   true]
    - [uu1036m002, uuid.__name__.__eq__,                                 ["uuid"],  true]
    - [uu1036m003, uuid.UUID.__class__.__name__.__eq__,                  ["type"],  true]
    - [uu1036m004, uuid.UUID.__module__.__eq__,                          ["uuid"],  true]
    - [uu1036m005, uuid.UUID.__doc__.__class__.__name__.__eq__,          ["str"],   true]
