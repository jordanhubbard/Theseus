spec: threading_extra1981
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 579 (_extra1981): __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence checks."
    - "threading.Thread, threading.Event, threading.Lock, threading.Condition, threading.Semaphore, threading.Barrier do NOT define __sizeof__ in their own dict."
    - "None of the threading classes define __length_hint__ — they are synchronization primitives, not iterators."
    - "None of the threading classes define __floor__, __ceil__, or __trunc__ — they are not numeric types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table threading_extra1981.sizeof_protocol:
  description: "threading types __sizeof__ dict-presence checks — none define __sizeof__ in own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1981
  columns: [id, function, args, expected]
  rows:
    - ["th1981001", "threading.Thread.__dict__.__contains__",    ["__sizeof__"], false]
    - ["th1981002", "threading.Event.__dict__.__contains__",     ["__sizeof__"], false]
    - ["th1981003", "threading.Lock.__dict__.__contains__",      ["__sizeof__"], false]
    - ["th1981004", "threading.Condition.__dict__.__contains__", ["__sizeof__"], false]
    - ["th1981005", "threading.Semaphore.__dict__.__contains__", ["__sizeof__"], false]
    - ["th1981006", "threading.Barrier.__dict__.__contains__",   ["__sizeof__"], false]

