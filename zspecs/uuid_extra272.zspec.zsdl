spec: uuid_extra272
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "This spec extends uuid.zspec.zsdl through uuid_extra271.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "uuid_extra271.zspec.zsdl covers: uuid4().__class__.__name__; uuid4().version == 4; uuid4().variant string; uuid.UUID.__doc__ docstring; uuid4().int class name; uuid4().hex length."
    - "This spec focuses on: uuid.UUID property types — time/clock_seq/node/hex/version/bytes/fields are all 'property' objects; uuid.UUID.__slots__ count equals 3; slots tuple contents."
    - "uuid.UUID.time.__class__.__name__ == 'property' — the time attribute is a Python property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.clock_seq.__class__.__name__ == 'property' — clock_seq is a property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.node.__class__.__name__ == 'property' — node is a property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.hex.__class__.__name__ == 'property' — hex is a property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.version.__class__.__name__ == 'property' — version is a property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "len(uuid.UUID.__slots__) == 3 — UUID defines exactly 3 slots: ('int', 'is_safe', '__weakref__'). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__slots__[0] == 'int' — first slot is 'int', the 128-bit integer backing store. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__slots__[1] == 'is_safe' — second slot tracks SafeUUID safety flag. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__slots__[2] == '__weakref__' — third slot enables weak references. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID property descriptors — class-level attribute type
# All computed UUID fields (time, clock_seq, node, hex, bytes, fields, version,
# variant, urn, bytes_le) are implemented as Python property objects on the class.
# uuid.UUID.time.__class__.__name__ == 'property' for each of them.
# Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table uuid_extra272.UUID_property_types:
  description: "uuid.UUID.<attr>.__class__.__name__ == 'property' for all computed attributes — time/clock_seq/node/hex/version/bytes/fields; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: property_type
  id_prefix: upt272

  columns: [id, function, args, expected, description]
  rows:
    - [time_is_property,      "UUID.time.__class__.__name__.__eq__",      ["property"], true, "uuid.UUID.time is a property descriptor"]
    - [clock_seq_is_property, "UUID.clock_seq.__class__.__name__.__eq__", ["property"], true, "uuid.UUID.clock_seq is a property descriptor"]
    - [node_is_property,      "UUID.node.__class__.__name__.__eq__",      ["property"], true, "uuid.UUID.node is a property descriptor"]
    - [hex_is_property,       "UUID.hex.__class__.__name__.__eq__",       ["property"], true, "uuid.UUID.hex is a property descriptor"]
    - [version_is_property,   "UUID.version.__class__.__name__.__eq__",   ["property"], true, "uuid.UUID.version is a property descriptor"]
    - [bytes_is_property,     "UUID.bytes.__class__.__name__.__eq__",     ["property"], true, "uuid.UUID.bytes is a property descriptor"]
    - [fields_is_property,    "UUID.fields.__class__.__name__.__eq__",    ["property"], true, "uuid.UUID.fields is a property descriptor"]

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__ — slots count and contents
# UUID uses __slots__ to restrict instance attributes and reduce memory use.
# Python 3.x: __slots__ == ('int', 'is_safe', '__weakref__'), length == 3.
# The tuple is stable across Python 3.9–3.14.
# ---------------------------------------------------------------------------

invariant uuid_extra272.UUID_slots.count:
  description: "len(uuid.UUID.__slots__) == 3 — UUID defines exactly 3 slots: 'int', 'is_safe', '__weakref__'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: slots
  kind: python_call_eq
  function: UUID.__slots__.__len__
  args: []
  expected: 3

invariant uuid_extra272.UUID_slots.first_is_int:
  description: "uuid.UUID.__slots__[0] == 'int' — first slot is 'int', the 128-bit integer backing store for the UUID value; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: slots
  kind: python_call_eq
  function: UUID.__slots__.__getitem__
  args: [0]
  expected: "int"

invariant uuid_extra272.UUID_slots.second_is_safe:
  description: "uuid.UUID.__slots__[1] == 'is_safe' — second slot holds a SafeUUID enum value indicating whether the UUID was generated safely; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: slots
  kind: python_call_eq
  function: UUID.__slots__.__getitem__
  args: [1]
  expected: "is_safe"

invariant uuid_extra272.UUID_slots.third_is_weakref:
  description: "uuid.UUID.__slots__[2] == '__weakref__' — third slot enables weak references to UUID instances; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: slots
  kind: python_call_eq
  function: UUID.__slots__.__getitem__
  args: [2]
  expected: "__weakref__"

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__ — class of the slots object
# __slots__ is a tuple (not a list or frozenset).
# ---------------------------------------------------------------------------

invariant uuid_extra272.UUID_slots.class_name:
  description: "uuid.UUID.__slots__.__class__.__name__ == 'tuple' — __slots__ is a tuple; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: slots
  kind: python_call_eq
  function: UUID.__slots__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID — class-level metadata
# UUID is a regular Python class (not a C extension type).
# __name__ == 'UUID'; __module__ == 'uuid'.
# ---------------------------------------------------------------------------

invariant uuid_extra272.UUID_class.name:
  description: "uuid.UUID.__name__ == 'UUID' — the class name is 'UUID'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: class_metadata
  kind: python_call_eq
  function: UUID.__name__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra272.UUID_class.module:
  description: "uuid.UUID.__module__ == 'uuid' — UUID is defined in the uuid module; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: class_metadata
  kind: python_call_eq
  function: UUID.__module__.__eq__
  args: ["uuid"]
  expected: true
