spec: uuid_extra2341
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 603 (_extra2341): __slots__ content and absence checks."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID is a pure-Python class that defines __slots__ = ('int', 'is_safe', '__weakref__')."
    - "uuid.UUID.__slots__ is a tuple of length 3."
    - "uuid.UUID attributes like 'version', 'bytes', 'hex', 'node' are properties, not slots — NOT in __slots__."
    - "uuid.SafeUUID is an Enum subclass (not IntEnum); __dict__.__contains__('__slots__') == False."
    - "uuid.UUID.__dict__.__contains__('__slots__') == True because the class defines __slots__."
  created_at: "2026-04-12"

table uuid_extra2341.uuid_has_slots:
  description: "uuid.UUID defines __slots__ — confirmed via __dict__ and direct slot presence"
  kind: python_call_eq
  category: slots_content
  id_prefix: uu2341
  columns: [id, function, args, expected]
  rows:
    - ["uu2341001", "uuid.UUID.__dict__.__contains__", ["__slots__"], true]
    - ["uu2341002", "uuid.UUID.__slots__.__len__", [], 3]
    - ["uu2341003", "uuid.UUID.__slots__.__contains__", ["int"], true]
    - ["uu2341004", "uuid.UUID.__slots__.__contains__", ["is_safe"], true]
    - ["uu2341005", "uuid.UUID.__slots__.__contains__", ["__weakref__"], true]

table uuid_extra2341.uuid_slots_absent:
  description: "uuid.UUID.__slots__ does NOT contain property names — those are descriptors, not slots"
  kind: python_call_eq
  category: slots_absence
  id_prefix: uu2341
  columns: [id, function, args, expected]
  rows:
    - ["uu2341006", "uuid.UUID.__slots__.__contains__", ["version"], false]
    - ["uu2341007", "uuid.UUID.__slots__.__contains__", ["bytes"], false]
    - ["uu2341008", "uuid.UUID.__slots__.__contains__", ["hex"], false]
    - ["uu2341009", "uuid.UUID.__slots__.__contains__", ["node"], false]
    - ["uu2341010", "uuid.UUID.__slots__.__contains__", ["time"], false]
    - ["uu2341011", "uuid.UUID.__slots__.__contains__", ["clock_seq"], false]
    - ["uu2341012", "uuid.UUID.__slots__.__contains__", ["variant"], false]
    - ["uu2341013", "uuid.UUID.__slots__.__contains__", ["urn"], false]

table uuid_extra2341.safeuuid_no_slots:
  description: "uuid.SafeUUID is an Enum subclass — no __slots__ defined in its own __dict__"
  kind: python_call_eq
  category: slots_absence
  id_prefix: uu2341
  columns: [id, function, args, expected]
  rows:
    - ["uu2341014", "uuid.SafeUUID.__dict__.__contains__", ["__slots__"], false]

table uuid_extra2341.uuid_slot_count_crosscheck:
  description: "Cross-check: uuid.UUID.__slots__ length equals the number of named slots confirmed present"
  kind: python_call_eq
  category: slots_content
  id_prefix: uu2341
  columns: [id, function, args, expected]
  rows:
    - ["uu2341015", "uuid.UUID.__slots__.__len__", [], 3]
    - ["uu2341016", "uuid.UUID.__slots__.__contains__", ["int"], true]
    - ["uu2341017", "uuid.UUID.__slots__.__contains__", ["is_safe"], true]
    - ["uu2341018", "uuid.UUID.__slots__.__contains__", ["__weakref__"], true]
    - ["uu2341019", "uuid.UUID.__slots__.__contains__", ["__dict__"], false]
    - ["uu2341020", "uuid.UUID.__slots__.__contains__", ["bytes_le"], false]
    - ["uu2341021", "uuid.UUID.__dict__.__contains__", ["__slots__"], true]
