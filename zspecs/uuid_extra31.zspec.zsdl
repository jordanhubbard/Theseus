spec: uuid_extra31
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra30.zspec.zsdl — covers UUID.__name__/__module__ string eq; UUID.__bases__[0].__name__.__eq__('object'); uuid1/3/4/5 __name__ string eq; uuid4.__module__.__eq__('uuid'); NAMESPACE_DNS.__class__.__name__.__eq__('UUID')."
    - "uuid_extra24.zspec.zsdl — covers getnode/__name__/__qualname__/__module__.__len__(); SafeUUID __name__/__qualname__/__mro__/__bases__[0].__name__.__len__()."
    - "uuid_extra23.zspec.zsdl — covers NAMESPACE_DNS/URL __class__.__name__.__len__()==4; RFC_4122.__class__.__name__.__len__()==3; RFC_4122.__len__()==21."
    - "uuid_extra6.zspec.zsdl — covers RESERVED_NCS/__class__/__name__.__eq__('str'); RESERVED_NCS/__eq__ (value check)."
    - "uuid_extra2.zspec.zsdl — covers RESERVED_NCS/__eq__('reserved for NCS compatibility') value check."
  notes:
    - "This spec extends uuid through uuid_extra30; it does NOT duplicate invariants present in those files."
    - "Coverage gap: uuid_extra23 covers RFC_4122.__len__()==21 but no prior uuid spec checks RESERVED_NCS/__MICROSOFT/__FUTURE __len__(). These are str constants; their lengths characterize the verbosity of the variant descriptions. All three are novel string-length invariants."
    - "uuid_extra24 covers getnode.__name__.__len__()==7 and getnode.__qualname__.__len__()==7 (length only). No prior uuid spec checks getnode.__name__.__eq__('getnode') or getnode.__qualname__.__eq__('getnode') as string equality values."
    - "uuid.RESERVED_NCS.__len__() == 30. 'reserved for NCS compatibility' has 30 characters. uuid_extra2 and uuid_extra6 check the string VALUE via __eq__ and __class__.__name__.__eq__('str') respectively, but no prior spec checks __len__() on RESERVED_NCS. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_MICROSOFT.__len__() == 36. 'reserved for Microsoft compatibility' has 36 characters. No prior uuid spec checks RESERVED_MICROSOFT.__len__(). The RFC 4122 variant description is longer than RESERVED_NCS. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_FUTURE.__len__() == 30. 'reserved for future definition' has 30 characters. No prior uuid spec checks RESERVED_FUTURE.__len__(). Shares length 30 with RESERVED_NCS. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.getnode.__name__.__eq__('getnode'). extra24 covers __name__.__len__()==7 but NOT the string eq value. The __eq__ check is a distinct invariant from the __len__ check. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.getnode.__qualname__.__eq__('getnode'). extra24 covers __qualname__.__len__()==7 but NOT the string eq value. getnode is a top-level function so its qualname equals its name. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.RESERVED_NCS, RESERVED_MICROSOFT, RESERVED_FUTURE string lengths
#
# uuid_extra2 checks RESERVED_NCS value via __eq__; uuid_extra6 checks its
# __class__.__name__ == 'str'. uuid_extra23 checks RFC_4122.__len__()==21.
# No prior uuid spec checks __len__() for RESERVED_NCS, RESERVED_MICROSOFT,
# or RESERVED_FUTURE.
#
#   RESERVED_NCS       == 'reserved for NCS compatibility'      (30 chars)
#   RESERVED_MICROSOFT == 'reserved for Microsoft compatibility' (36 chars)
#   RESERVED_FUTURE    == 'reserved for future definition'       (30 chars)
#
# Verified on Python 3.14 macOS/Darwin 25.4.0, 2026-04-10.
# ---------------------------------------------------------------------------

table uuid_extra31.reserved_string_lengths:
  description: "uuid.RESERVED_NCS/__len__()==30, RESERVED_MICROSOFT/__len__()==36, RESERVED_FUTURE/__len__()==30 — novel string-length checks; no prior spec checks __len__() on any RESERVED_* constant (extra23 covers RFC_4122.__len__()==21 only)"
  kind: python_call_eq
  category: string_length
  id_prefix: ursl31

  columns: [id, function, args, expected]
  rows:
    - [reserved_ncs_len,       RESERVED_NCS.__len__,       [], 30]
    - [reserved_microsoft_len, RESERVED_MICROSOFT.__len__,  [], 36]
    - [reserved_future_len,    RESERVED_FUTURE.__len__,     [], 30]

# ---------------------------------------------------------------------------
# uuid.getnode __name__ and __qualname__ string eq checks
#
# uuid_extra24 covers getnode.__name__.__len__()==7 and
# getnode.__qualname__.__len__()==7 (length only).
# No prior uuid spec checks getnode.__name__.__eq__('getnode') or
# getnode.__qualname__.__eq__('getnode') as string equality values.
# getnode is a top-level function so its __qualname__ equals its __name__.
# ---------------------------------------------------------------------------

table uuid_extra31.getnode_name_qualname_eq:
  description: "uuid.getnode.__name__=='getnode' and __qualname__=='getnode' — novel string eq checks; extra24 covers __name__/__qualname__.__len__()==7 only; qualname==name because getnode is a top-level function"
  kind: python_call_eq
  category: function_names
  id_prefix: ugnq31

  columns: [id, function, args, expected]
  rows:
    - [getnode_name_eq,     getnode.__name__.__eq__,     ["getnode"], true]
    - [getnode_qualname_eq, getnode.__qualname__.__eq__,  ["getnode"], true]
