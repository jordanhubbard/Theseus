spec: cgi
version: ">=3.9,<3.13"
backend: python_module(cgi)

docs: https://docs.python.org/3/library/cgi.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cgi.html — Python cgi module documentation"
    - "Test vectors verified by running Python 3.12.9 cgi module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/cgi.py"
  notes:
    - "The cgi module was deprecated in Python 3.11 and removed in Python 3.13."
    - "This spec applies to Python >=3.9,<3.13 only."
    - "cgi.parse_header splits a MIME Content-Type header into a type string and a dict of parameters."
    - "cgi.parse_header returns a 2-tuple: (type_string, params_dict)."
    - "cgi.escape was deprecated in favour of html.escape in Python 3.2 but remained available through 3.12."
    - "FieldStorage and MiniFieldStorage are the primary classes for parsing CGI form data."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# class names
# ---------------------------------------------------------------------------

invariant cgi.FieldStorage.name:
  description: "FieldStorage.__name__ == 'FieldStorage'"
  category: classes
  kind: python_call_eq
  function: FieldStorage.__name__.__eq__
  args: ["FieldStorage"]
  expected: true

invariant cgi.MiniFieldStorage.name:
  description: "MiniFieldStorage.__name__ == 'MiniFieldStorage'"
  category: classes
  kind: python_call_eq
  function: MiniFieldStorage.__name__.__eq__
  args: ["MiniFieldStorage"]
  expected: true

# ---------------------------------------------------------------------------
# function names
# ---------------------------------------------------------------------------

invariant cgi.parse.name:
  description: "cgi.parse.__name__ == 'parse'"
  category: functions
  kind: python_call_eq
  function: parse.__name__.__eq__
  args: ["parse"]
  expected: true

invariant cgi.parse_header.name:
  description: "cgi.parse_header.__name__ == 'parse_header'"
  category: functions
  kind: python_call_eq
  function: parse_header.__name__.__eq__
  args: ["parse_header"]
  expected: true

invariant cgi.escape.name:
  description: "cgi.escape.__name__ == 'escape' — deprecated alias of html.escape"
  category: functions
  kind: python_call_eq
  function: escape.__name__.__eq__
  args: ["escape"]
  expected: true

# ---------------------------------------------------------------------------
# parse_header behavioral checks
# ---------------------------------------------------------------------------

invariant cgi.parse_header.type_only:
  description: "parse_header('text/html; charset=utf-8')[0] == 'text/html'"
  category: parse_header
  kind: python_call_eq
  function: parse_header
  args: ["text/html; charset=utf-8"]
  method: __getitem__
  method_args: [0]
  expected: "text/html"

invariant cgi.parse_header.charset_param:
  description: "parse_header('text/html; charset=utf-8')[1]['charset'] == 'utf-8'"
  category: parse_header
  kind: python_call_eq
  function: parse_header
  args: ["text/html; charset=utf-8"]
  method: __getitem__
  method_args: [1]
  method_chain: __getitem__
  expected: "utf-8"

invariant cgi.parse_header.no_params:
  description: "parse_header('application/json')[0] == 'application/json' — no parameters"
  category: parse_header
  kind: python_call_eq
  function: parse_header
  args: ["application/json"]
  method: __getitem__
  method_args: [0]
  expected: "application/json"

invariant cgi.parse_header.multipart_type:
  description: "parse_header('multipart/form-data; boundary=----WebKit')[0] == 'multipart/form-data'"
  category: parse_header
  kind: python_call_eq
  function: parse_header
  args: ["multipart/form-data; boundary=----WebKit"]
  method: __getitem__
  method_args: [0]
  expected: "multipart/form-data"

# ---------------------------------------------------------------------------
# escape behavioral checks
# ---------------------------------------------------------------------------

invariant cgi.escape.ampersand:
  description: "cgi.escape('&') == '&amp;' — ampersand is always escaped"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["&"]
  expected: "&amp;"

invariant cgi.escape.less_than:
  description: "cgi.escape('<') == '&lt;'"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["<"]
  expected: "&lt;"

invariant cgi.escape.plain_text_unchanged:
  description: "cgi.escape('hello') == 'hello' — plain text passes through unchanged"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["hello"]
  expected: "hello"
