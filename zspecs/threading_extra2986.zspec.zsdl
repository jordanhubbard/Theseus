spec: th2986
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 646 (th2986): __len__, __length_hint__, __contains__ dict-presence checks for threading types."
    - "threading types are synchronization primitives and thread management classes — none define len, length_hint, or contains (container/sequence protocol) operators."
    - "Verified types: threading.Thread, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Event, threading.Timer, threading.Barrier, threading.local."
    - "threading.Semaphore does not define __contains__ despite having an internal counter; membership testing is not part of its interface."
    - "threading.Condition does not expose a __len__ even though it wraps a lock and a waiters list."
    - "threading.Timer is a Thread subclass used for delayed execution."
    - "threading.local is the thread-local storage class."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th2986.len:
  description: "threading types __len__ dict-presence checks; wave 646"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2986
  columns: [id, function, args, expected]
  rows:
    - ["th2986001", operator.contains, [threading.Thread.__dict__,           "__len__"], false]
    - ["th2986002", operator.contains, [threading.Condition.__dict__,        "__len__"], false]
    - ["th2986003", operator.contains, [threading.Semaphore.__dict__,        "__len__"], false]
    - ["th2986004", operator.contains, [threading.BoundedSemaphore.__dict__, "__len__"], false]
    - ["th2986005", operator.contains, [threading.Event.__dict__,            "__len__"], false]
    - ["th2986006", operator.contains, [threading.Barrier.__dict__,          "__len__"], false]

