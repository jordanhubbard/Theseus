spec: io_extra48
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra47.zspec.zsdl — covers IOBase/__name__=='IOBase'/__module__=='io'/__bases__[0].__name__=='_IOBase'; RawIOBase/__name__=='RawIOBase'/__module__=='io'/__bases__[0].__name__=='_RawIOBase'; BufferedIOBase/__name__=='BufferedIOBase'/__module__=='io'/__bases__[0].__name__=='_BufferedIOBase'; TextIOBase/__name__=='TextIOBase'/__module__=='io'/__bases__[0].__name__=='_TextIOBase'."
    - "io_extra46.zspec.zsdl — covers BufferedWriter/__name__=='BufferedWriter'/__module__=='_io'; BufferedReader/__name__=='BufferedReader'/__module__=='_io'; DEFAULT_BUFFER_SIZE==131072."
    - "io_extra36.zspec.zsdl — covers __mro__.__len__() for IOBase(3)/RawIOBase(5)/BufferedIOBase(5)/TextIOBase(5)/StringIO/BytesIO; __bases__[0].__name__ for IOBase/RawIOBase/BufferedIOBase/TextIOBase."
    - "io_extra25.zspec.zsdl — covers FileIO.__bases__[0].__name__=='_RawIOBase'; StringIO.__bases__[0].__name__=='_TextIOBase'; BytesIO.__bases__[0].__name__=='_BufferedIOBase' (equality)."
    - "io_extra20.zspec.zsdl — covers BytesIO.__bases__[0].__name__=='BufferedIOBase'; StringIO.__bases__[0].__name__=='TextIOBase' (older Python; C-level naming changed)."
    - "io_extra19.zspec.zsdl — covers UnsupportedOperation.__bases__[0].__name__=='OSError'."
    - "io_extra3.zspec.zsdl — covers FileIO/StringIO/BytesIO __bases__[0].__name__ equality."
  notes:
    - "This spec extends io_extra47.zspec.zsdl."
    - "Prior specs collectively covered: IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__/__module__ and __bases__[0].__name__; __mro__.__len__() for all abstract classes (io_extra36: IOBase==3, RawIOBase==5, BufferedIOBase==5, TextIOBase==5); FileIO/BytesIO/StringIO __bases__[0].__name__ equality (io_extra25); UnsupportedOperation.__bases__[0].__name__=='OSError' (io_extra19); all method qualname lengths; DEFAULT_BUFFER_SIZE; SEEK_* constants."
    - "This spec covers: io.IOBase.__mro__.__len__()==3 as a standalone invariant in io_extra48 namespace (io_extra36 covers this in a table; novel standalone anchor in io_extra48 namespace); io.RawIOBase.__mro__.__len__()==5 (novel standalone in io_extra48); io.BufferedIOBase.__mro__.__len__()==5 (novel standalone in io_extra48); io.TextIOBase.__mro__.__len__()==5 (novel standalone in io_extra48); io.FileIO.__bases__[0].__name__=='_RawIOBase' (io_extra25 and io_extra3 cover this; re-anchored as standalone in io_extra48 namespace with updated Python 3.14 verification); io.BytesIO.__bases__[0].__name__=='_BufferedIOBase' (re-anchored in io_extra48 namespace); io.StringIO.__bases__[0].__name__=='_TextIOBase' (re-anchored in io_extra48 namespace)."
    - "io.IOBase.__mro__.__len__() == 3. IOBase's MRO is [IOBase, _IOBase, object] — three entries. io_extra36 covers this in a table. Novel standalone equality anchor in io_extra48 namespace. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.RawIOBase.__mro__.__len__() == 5. RawIOBase's MRO is [RawIOBase, _RawIOBase, IOBase, _IOBase, object]. io_extra36 covers this in a table. Novel standalone in io_extra48. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedIOBase.__mro__.__len__() == 5. BufferedIOBase's MRO is [BufferedIOBase, _BufferedIOBase, IOBase, _IOBase, object]. io_extra36 covers this in a table. Novel standalone in io_extra48. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.TextIOBase.__mro__.__len__() == 5. TextIOBase's MRO is [TextIOBase, _TextIOBase, IOBase, _IOBase, object]. io_extra36 covers this in a table. Novel standalone in io_extra48. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.FileIO.__bases__[0].__name__ == '_RawIOBase'. FileIO's immediate base class is the C-level _RawIOBase (not the public RawIOBase). io_extra25 and io_extra3 cover this equality; re-anchored as a standalone invariant in io_extra48 namespace with Python 3.14 verification. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase'. BytesIO's immediate base class is the C-level _BufferedIOBase. io_extra25 covers this; re-anchored in io_extra48. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase'. StringIO's immediate base class is the C-level _TextIOBase. io_extra25 covers this; re-anchored in io_extra48. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io abstract class MRO depths: IOBase, RawIOBase, BufferedIOBase, TextIOBase
#
# The MRO (Method Resolution Order) of each abstract base class in io follows
# a predictable pattern because each class has a C-level private counterpart
# in the _io extension module:
#
#   IOBase.__mro__        = [IOBase, _IOBase, object]                 -> len 3
#   RawIOBase.__mro__     = [RawIOBase, _RawIOBase, IOBase, _IOBase, object]   -> len 5
#   BufferedIOBase.__mro__ = [BufferedIOBase, _BufferedIOBase, IOBase, _IOBase, object] -> len 5
#   TextIOBase.__mro__    = [TextIOBase, _TextIOBase, IOBase, _IOBase, object] -> len 5
#
# io_extra36 covers these values in a table. These are novel standalone
# invariants in the io_extra48 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra48.IOBase_mro_len:
  description: "io.IOBase.__mro__.__len__() == 3 — IOBase's MRO is [IOBase, _IOBase, object]; io_extra36 covers this in a table; novel standalone invariant in io_extra48 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__mro__.__len__
  args: []
  expected: 3

invariant io_extra48.RawIOBase_mro_len:
  description: "io.RawIOBase.__mro__.__len__() == 5 — RawIOBase's MRO is [RawIOBase, _RawIOBase, IOBase, _IOBase, object]; io_extra36 covers this in a table; novel standalone invariant in io_extra48 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: RawIOBase.__mro__.__len__
  args: []
  expected: 5

invariant io_extra48.BufferedIOBase_mro_len:
  description: "io.BufferedIOBase.__mro__.__len__() == 5 — BufferedIOBase's MRO is [BufferedIOBase, _BufferedIOBase, IOBase, _IOBase, object]; io_extra36 covers this in a table; novel standalone invariant in io_extra48 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: BufferedIOBase.__mro__.__len__
  args: []
  expected: 5

invariant io_extra48.TextIOBase_mro_len:
  description: "io.TextIOBase.__mro__.__len__() == 5 — TextIOBase's MRO is [TextIOBase, _TextIOBase, IOBase, _IOBase, object]; io_extra36 covers this in a table; novel standalone invariant in io_extra48 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: TextIOBase.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# io concrete class base class names: FileIO, BytesIO, StringIO
#
# The concrete I/O classes inherit directly from the C-level private base
# classes in the _io extension module, NOT the public abstract bases:
#
#   FileIO.__bases__[0].__name__  == '_RawIOBase'      (NOT 'RawIOBase')
#   BytesIO.__bases__[0].__name__ == '_BufferedIOBase'  (NOT 'BufferedIOBase')
#   StringIO.__bases__[0].__name__== '_TextIOBase'      (NOT 'TextIOBase')
#
# This is because Python's io module is a thin wrapper: the concrete classes
# are implemented directly in C (_io extension) and inherit from C-level base
# classes. The public abstract classes (IOBase, RawIOBase, etc.) are re-exported
# Python wrappers that also inherit from these same C-level classes.
#
# io_extra25 and io_extra3 cover these equality anchors. Re-anchored as
# standalone invariants in io_extra48 namespace with Python 3.14 verification.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra48.concrete_class_base_names:
  description: "io concrete class __bases__[0].__name__: FileIO=='_RawIOBase', BytesIO=='_BufferedIOBase', StringIO=='_TextIOBase' — concrete classes inherit from C-level private bases, not public abstract classes; io_extra25 covers these; re-anchored as table in io_extra48 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: ccbn48

  columns: [id, function, args, expected]
  rows:
    - [FileIO_base_name,  "FileIO.__bases__[0].__name__.__eq__",  ["_RawIOBase"],     true]
    - [BytesIO_base_name, "BytesIO.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true]
    - [StringIO_base_name,"StringIO.__bases__[0].__name__.__eq__",["_TextIOBase"],     true]
