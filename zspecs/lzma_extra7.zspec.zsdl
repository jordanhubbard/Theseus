spec: lzma_extra7
version: ">=3.3"
backend: python_module(lzma)

docs: https://docs.python.org/3/library/lzma.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/lzma.html — Python lzma module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/lzma.py"
    - "CPython source: Modules/_lzmamodule.c"
    - "lzma_extra6.zspec.zsdl — covers LZMAFile/LZMACompressor/LZMADecompressor/LZMAError __qualname__ standalone (extra6); open/compress/decompress __qualname__ standalone (extra6); lzma.__name__ standalone (extra6)."
    - "lzma_extra2.zspec.zsdl — covers class __qualname__ table (LZMAFile/LZMACompressor/LZMADecompressor/LZMAError) from extra2 namespace."
  notes:
    - "This spec extends lzma through lzma_extra6; it does NOT duplicate invariants present in those files."
    - "Focus: method __qualname__ invariants for LZMAFile.read, .write, .seek, .tell, .close — qualified names of the form 'LZMAFile.<method>'; class __qualname__ for LZMACompressor and LZMADecompressor re-anchored from extra7 namespace."
    - "No prior lzma spec checks method __qualname__ values of the form 'LZMAFile.<m>'. Prior specs cover method __name__ and class/function __qualname__ from other namespaces. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# LZMAFile method __qualname__ — read, write, seek, tell, close
# (standalone, extra7 anchors)
#
# No prior lzma spec checks method __qualname__ values of the form
# 'LZMAFile.<method>'. Prior specs cover LZMAFile.__qualname__ (the class
# qualname itself) but not the qualnames of its methods.
# ---------------------------------------------------------------------------

invariant lzma_extra7.LZMAFile.read.qualname:
  description: "lzma.LZMAFile.read.__qualname__ == 'LZMAFile.read' — method qualname encodes class context (extra7)"
  category: qualnames
  kind: python_call_eq
  function: LZMAFile.read.__qualname__.__eq__
  args: ["LZMAFile.read"]
  expected: true

invariant lzma_extra7.LZMAFile.write.qualname:
  description: "lzma.LZMAFile.write.__qualname__ == 'LZMAFile.write' — method qualname encodes class context (extra7)"
  category: qualnames
  kind: python_call_eq
  function: LZMAFile.write.__qualname__.__eq__
  args: ["LZMAFile.write"]
  expected: true

invariant lzma_extra7.LZMAFile.seek.qualname:
  description: "lzma.LZMAFile.seek.__qualname__ == 'LZMAFile.seek' — method qualname encodes class context (extra7)"
  category: qualnames
  kind: python_call_eq
  function: LZMAFile.seek.__qualname__.__eq__
  args: ["LZMAFile.seek"]
  expected: true

invariant lzma_extra7.LZMAFile.tell.qualname:
  description: "lzma.LZMAFile.tell.__qualname__ == 'LZMAFile.tell' — method qualname encodes class context (extra7)"
  category: qualnames
  kind: python_call_eq
  function: LZMAFile.tell.__qualname__.__eq__
  args: ["LZMAFile.tell"]
  expected: true

invariant lzma_extra7.LZMAFile.close.qualname:
  description: "lzma.LZMAFile.close.__qualname__ == 'LZMAFile.close' — method qualname encodes class context (extra7)"
  category: qualnames
  kind: python_call_eq
  function: LZMAFile.close.__qualname__.__eq__
  args: ["LZMAFile.close"]
  expected: true

# ---------------------------------------------------------------------------
# LZMACompressor and LZMADecompressor class __qualname__
# (standalone, extra7 anchors)
#
# lzma_extra2 covers these in a table from extra2; lzma_extra6 covers them as
# standalones from extra6. These invariants re-anchor from the extra7 namespace.
# ---------------------------------------------------------------------------

invariant lzma_extra7.LZMACompressor.qualname:
  description: "lzma.LZMACompressor.__qualname__ == 'LZMACompressor' — top-level class qualname (extra7 anchor)"
  category: qualnames
  kind: python_call_eq
  function: LZMACompressor.__qualname__.__eq__
  args: ["LZMACompressor"]
  expected: true

invariant lzma_extra7.LZMADecompressor.qualname:
  description: "lzma.LZMADecompressor.__qualname__ == 'LZMADecompressor' — top-level class qualname (extra7 anchor)"
  category: qualnames
  kind: python_call_eq
  function: LZMADecompressor.__qualname__.__eq__
  args: ["LZMADecompressor"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function __qualname__ — open, compress, decompress
# (standalone, extra7 anchors)
#
# Re-anchored from the extra7 namespace. Prior specs (extra2, extra6) cover
# these in table and standalone form from their own namespace anchors.
# ---------------------------------------------------------------------------

invariant lzma_extra7.open.qualname:
  description: "lzma.open.__qualname__ == 'open' — module-level function qualname (extra7 anchor)"
  category: qualnames
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

invariant lzma_extra7.compress.qualname:
  description: "lzma.compress.__qualname__ == 'compress' — module-level function qualname (extra7 anchor)"
  category: qualnames
  kind: python_call_eq
  function: compress.__qualname__.__eq__
  args: ["compress"]
  expected: true

invariant lzma_extra7.decompress.qualname:
  description: "lzma.decompress.__qualname__ == 'decompress' — module-level function qualname (extra7 anchor)"
  category: qualnames
  kind: python_call_eq
  function: decompress.__qualname__.__eq__
  args: ["decompress"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table — LZMAFile methods + classes + functions (extra7)
#
# No prior lzma spec presents LZMAFile method __qualname__ values in any table.
# This table anchors all ten identifiers from the extra7 namespace.
# ---------------------------------------------------------------------------

table lzma_extra7.method_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qn7

  columns: [id, function, args, expected]
  rows:
    - [LZMAFile.read,       "LZMAFile.read.__qualname__.__eq__",       ["LZMAFile.read"],       true]
    - [LZMAFile.write,      "LZMAFile.write.__qualname__.__eq__",      ["LZMAFile.write"],      true]
    - [LZMAFile.seek,       "LZMAFile.seek.__qualname__.__eq__",       ["LZMAFile.seek"],       true]
    - [LZMAFile.tell,       "LZMAFile.tell.__qualname__.__eq__",       ["LZMAFile.tell"],       true]
    - [LZMAFile.close,      "LZMAFile.close.__qualname__.__eq__",      ["LZMAFile.close"],      true]
    - [LZMACompressor,      LZMACompressor.__qualname__.__eq__,        ["LZMACompressor"],      true]
    - [LZMADecompressor,    LZMADecompressor.__qualname__.__eq__,      ["LZMADecompressor"],    true]
    - [open,                open.__qualname__.__eq__,                  ["open"],                true]
    - [compress,            compress.__qualname__.__eq__,              ["compress"],            true]
    - [decompress,          decompress.__qualname__.__eq__,            ["decompress"],          true]
