spec: re_extra273
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "re.__spec__.__class__.__name__ == 'ModuleSpec' (importlib.machinery.ModuleSpec)."
    - "re.__loader__.__class__.__name__ == 'SourceFileLoader' (importlib.machinery.SourceFileLoader)."
    - "re.__spec__.origin is a str (path to the re/__init__.py file)."
    - "re._compiler is a submodule of the re package; re._compiler.__package__ == 're'."
    - "re._compiler.__loader__.__class__.__name__ == 'SourceFileLoader'."
    - "re.__version__ == '2.2.1' (a historic version string carried in the module)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: re module __spec__ and __loader__ identity
# ---------------------------------------------------------------------------

table re_extra273.re_module_spec_identity:
  description: "re module __name__, __package__, __spec__.name, __spec__.__class__.__name__, __loader__.__class__.__name__, __spec__.origin type"
  kind: python_call_eq
  category: identity
  id_prefix: msi

  columns: [id, function, args, expected, description]
  rows:
    - [re_name,          __name__.__eq__,                             ["re"],              true, "re.__name__ == 're'"]
    - [re_package,       __package__.__eq__,                          ["re"],              true, "re.__package__ == 're'"]
    - [spec_name,        __spec__.name.__eq__,                        ["re"],              true, "re.__spec__.name == 're'"]
    - [spec_class,       __spec__.__class__.__name__.__eq__,          ["ModuleSpec"],      true, "re.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [loader_class,     __loader__.__class__.__name__.__eq__,        ["SourceFileLoader"], true, "re.__loader__.__class__.__name__ == 'SourceFileLoader'"]
    - [origin_class,     __spec__.origin.__class__.__name__.__eq__,   ["str"],             true, "re.__spec__.origin.__class__.__name__ == 'str'"]

# ---------------------------------------------------------------------------
# Table: re._compiler submodule identity
# ---------------------------------------------------------------------------

table re_extra273.re_compiler_submodule_identity:
  description: "re._compiler submodule __name__, __package__, and __loader__ class name"
  kind: python_call_eq
  category: identity
  id_prefix: csi

  columns: [id, function, args, expected, description]
  rows:
    - [compiler_name,    _compiler.__name__.__eq__,                        ["re._compiler"],    true, "re._compiler.__name__ == 're._compiler'"]
    - [compiler_package, _compiler.__package__.__eq__,                     ["re"],              true, "re._compiler.__package__ == 're'"]
    - [compiler_loader,  _compiler.__loader__.__class__.__name__.__eq__,   ["SourceFileLoader"], true, "re._compiler.__loader__.__class__.__name__ == 'SourceFileLoader'"]

# ---------------------------------------------------------------------------
# Standalone invariants: re module version and spec origin
# ---------------------------------------------------------------------------

invariant re_extra273.re.__version__:
  description: "re.__version__ == '2.2.1'"
  category: identity
  kind: python_call_eq
  function: __version__.__eq__
  args: ["2.2.1"]
  expected: true

invariant re_extra273.re.__version__.class_name:
  description: "re.__version__.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __version__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant re_extra273.re.__spec__.name:
  description: "re.__spec__.name == 're'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["re"]
  expected: true

invariant re_extra273.re.__loader__.class_name:
  description: "re.__loader__.__class__.__name__ == 'SourceFileLoader'"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant re_extra273.re._compiler.__name__:
  description: "re._compiler.__name__ == 're._compiler'"
  category: identity
  kind: python_call_eq
  function: _compiler.__name__.__eq__
  args: ["re._compiler"]
  expected: true

invariant re_extra273.re._compiler.__package__:
  description: "re._compiler.__package__ == 're'"
  category: identity
  kind: python_call_eq
  function: _compiler.__package__.__eq__
  args: ["re"]
  expected: true
