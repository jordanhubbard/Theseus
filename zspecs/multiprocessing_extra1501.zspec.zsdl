spec: multiprocessing_extra1501
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "Wave 547 theme: async protocol method __dict__ presence checks. multiprocessing is a sync-only module — none of its classes define __await__, __aenter__, __aexit__, __aiter__, or __anext__ in their own __dict__."
    - "multiprocessing.Process does NOT define __aenter__ or __aexit__ in its own __dict__. Process is a sync-only class for spawning child processes."
    - "multiprocessing.pool.Pool does NOT define __await__, __aenter__, or __aexit__ in its own __dict__. Pool manages a pool of worker processes but is entirely synchronous."
    - "multiprocessing.queues.Queue does NOT define any async protocol methods in its own __dict__. Queues in multiprocessing are sync inter-process communication primitives."
    - "The multiprocessing module predates Python's async/await syntax and has no async protocol support in any of its classes."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Process has no async protocol in __dict__
#
# multiprocessing.Process.__dict__.__contains__('__await__')  == False
# multiprocessing.Process.__dict__.__contains__('__aenter__') == False
# multiprocessing.Process.__dict__.__contains__('__aexit__')  == False
# multiprocessing.Process.__dict__.__contains__('__aiter__')  == False
# multiprocessing.Process.__dict__.__contains__('__anext__')  == False
# multiprocessing.Process.__dict__.__contains__('_start_method') == True  (sync)
# ---------------------------------------------------------------------------

table multiprocessing_extra1501.process_no_async_protocol:
  description: "multiprocessing.Process has no async protocol methods in its own __dict__ — mp1501pr namespace. multiprocessing.Process.__dict__.__contains__('__await__')==False (Process is a sync-only class for spawning child processes; it is not awaitable — there is no event-loop integration; Process.start() spawns the child synchronously and Process.join() blocks the parent thread); multiprocessing.Process.__dict__.__contains__('__aenter__')==False (Process is not an async context manager; you cannot use 'async with process:'; the module predates async/await syntax); multiprocessing.Process.__dict__.__contains__('__aexit__')==False (no async exit protocol on Process); multiprocessing.Process.__dict__.__contains__('__aiter__')==False (Process is not an async iterator); multiprocessing.Process.__dict__.__contains__('__anext__')==False (no async iteration on Process); multiprocessing.Process.__dict__.__contains__('_start_method')==True (Process defines _start_method in its own __dict__ as established in prior specs; the context.Process subclass that multiprocessing.Process points to defines _start_method directly — it is the platform start method such as 'fork' or 'spawn'); verified with Python 3.14.4"
  kind: python_call_eq
  category: async_protocol
  id_prefix: mp1501pr

  columns: [id, function, args, expected, description]
  rows:
    - [mp1501pr001, multiprocessing.Process.__dict__.__contains__, ["__await__"],      false, "Process.__dict__.__contains__('__await__')==False — sync-only process class, not awaitable; verified with Python 3.14.4"]
    - [mp1501pr002, multiprocessing.Process.__dict__.__contains__, ["__aenter__"],     false, "Process.__dict__.__contains__('__aenter__')==False — Process is not an async context manager; verified with Python 3.14.4"]
    - [mp1501pr003, multiprocessing.Process.__dict__.__contains__, ["__aexit__"],      false, "Process.__dict__.__contains__('__aexit__')==False — no async exit protocol on Process; verified with Python 3.14.4"]
    - [mp1501pr004, multiprocessing.Process.__dict__.__contains__, ["__aiter__"],      false, "Process.__dict__.__contains__('__aiter__')==False — Process is not an async iterator; verified with Python 3.14.4"]
    - [mp1501pr005, multiprocessing.Process.__dict__.__contains__, ["__anext__"],      false, "Process.__dict__.__contains__('__anext__')==False — no async iteration on Process; verified with Python 3.14.4"]
    - [mp1501pr006, multiprocessing.Process.__dict__.__contains__, ["_start_method"],  true,  "Process.__dict__.__contains__('_start_method')==True — the context.Process subclass defines _start_method directly (e.g. 'fork' or 'spawn'); established in prior specs; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.pool.Pool has no async protocol in __dict__
#
# multiprocessing.pool.Pool.__dict__.__contains__('__await__')  == False
# multiprocessing.pool.Pool.__dict__.__contains__('__aenter__') == False
# multiprocessing.pool.Pool.__dict__.__contains__('__aexit__')  == False
# multiprocessing.pool.Pool.__dict__.__contains__('__aiter__')  == False
# multiprocessing.pool.Pool.__dict__.__contains__('__anext__')  == False
# multiprocessing.pool.Pool.__dict__.__contains__('apply')      == True  (sync)
# ---------------------------------------------------------------------------

table multiprocessing_extra1501.pool_no_async_protocol:
  description: "multiprocessing.pool.Pool has no async protocol methods in its own __dict__ — mp1501pl namespace. multiprocessing.pool.Pool.__dict__.__contains__('__await__')==False (Pool manages a pool of worker processes for parallel execution; it is entirely synchronous — Pool.map() blocks until all results are available, Pool.apply() blocks for a single result; no event-loop integration); multiprocessing.pool.Pool.__dict__.__contains__('__aenter__')==False (Pool is not an async context manager; while 'with Pool() as p:' works via __enter__/__exit__, 'async with Pool() as p:' does not work; __aenter__ is not in Pool.__dict__); multiprocessing.pool.Pool.__dict__.__contains__('__aexit__')==False (no async exit protocol on Pool); multiprocessing.pool.Pool.__dict__.__contains__('__aiter__')==False (Pool is not an async iterator); multiprocessing.pool.Pool.__dict__.__contains__('__anext__')==False (no async iteration on Pool); multiprocessing.pool.Pool.__dict__.__contains__('apply')==True (Pool.apply() IS defined directly in Pool.__dict__ as a synchronous method that applies a function in a worker process and blocks until the result is ready); verified with Python 3.14.4"
  kind: python_call_eq
  category: async_protocol
  id_prefix: mp1501pl

  columns: [id, function, args, expected, description]
  rows:
    - [mp1501pl001, multiprocessing.pool.Pool.__dict__.__contains__, ["__await__"],  false, "Pool.__dict__.__contains__('__await__')==False — sync-only pool, not awaitable; verified with Python 3.14.4"]
    - [mp1501pl002, multiprocessing.pool.Pool.__dict__.__contains__, ["__aenter__"], false, "Pool.__dict__.__contains__('__aenter__')==False — Pool is not an async context manager; verified with Python 3.14.4"]
    - [mp1501pl003, multiprocessing.pool.Pool.__dict__.__contains__, ["__aexit__"],  false, "Pool.__dict__.__contains__('__aexit__')==False — no async exit protocol on Pool; verified with Python 3.14.4"]
    - [mp1501pl004, multiprocessing.pool.Pool.__dict__.__contains__, ["__aiter__"],  false, "Pool.__dict__.__contains__('__aiter__')==False — Pool is not an async iterator; verified with Python 3.14.4"]
    - [mp1501pl005, multiprocessing.pool.Pool.__dict__.__contains__, ["__anext__"],  false, "Pool.__dict__.__contains__('__anext__')==False — no async iteration on Pool; verified with Python 3.14.4"]
    - [mp1501pl006, multiprocessing.pool.Pool.__dict__.__contains__, ["apply"],      true,  "Pool.__dict__.__contains__('apply')==True — Pool.apply() is a sync method in Pool.__dict__; blocks until result is ready; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 3: Cross-module contrast — multiprocessing vs asyncio async protocol
#
# multiprocessing.Process.__dict__.__contains__('__await__')  == False
# asyncio.Future.__dict__.__contains__('__await__')           == True
# multiprocessing.pool.Pool.__dict__.__contains__('__aenter__') == False
# asyncio.TaskGroup.__dict__.__contains__('__aenter__')       == True
# multiprocessing.Process.__dict__.__contains__('__aiter__')  == False
# asyncio.StreamReader.__dict__.__contains__('__aiter__')     == True
# ---------------------------------------------------------------------------

table multiprocessing_extra1501.mp_vs_asyncio_contrast:
  description: "Cross-module contrast: multiprocessing classes vs asyncio classes for async protocol __dict__ presence — mp1501xc namespace. multiprocessing.Process.__dict__.__contains__('__await__')==False (Process is sync-only; contrast with asyncio.Future which defines __await__ in its C-level __dict__); asyncio.Future.__dict__.__contains__('__await__')==True (asyncio.Future IS awaitable; defines __await__ directly); the fundamental distinction: multiprocessing uses OS processes and blocking calls while asyncio uses coroutines and event-loop integration; multiprocessing.pool.Pool.__dict__.__contains__('__aenter__')==False (Pool is not an async context manager; contrast asyncio.TaskGroup which defines __aenter__ directly); asyncio.TaskGroup.__dict__.__contains__('__aenter__')==True (TaskGroup IS an async context manager with __aenter__ in its own __dict__); multiprocessing.Process.__dict__.__contains__('__aiter__')==False (Process is not an async iterator); asyncio.StreamReader.__dict__.__contains__('__aiter__')==True (StreamReader IS an async iterator with __aiter__ in its own __dict__); verified with Python 3.14.4"
  kind: python_call_eq
  category: async_protocol
  id_prefix: mp1501xc

  columns: [id, function, args, expected, description]
  rows:
    - [mp1501xc001, multiprocessing.Process.__dict__.__contains__, ["__await__"],  false, "Process.__dict__.__contains__('__await__')==False — sync process; contrast asyncio.Future which is True; verified with Python 3.14.4"]
    - [mp1501xc002, asyncio.Future.__dict__.__contains__,          ["__await__"],  true,  "asyncio.Future.__dict__.__contains__('__await__')==True — async future; contrast multiprocessing.Process which is False; verified with Python 3.14.4"]
    - [mp1501xc003, multiprocessing.pool.Pool.__dict__.__contains__, ["__aenter__"], false, "Pool.__dict__.__contains__('__aenter__')==False — sync pool; contrast asyncio.TaskGroup which is True; verified with Python 3.14.4"]
    - [mp1501xc004, asyncio.TaskGroup.__dict__.__contains__,       ["__aenter__"], true,  "asyncio.TaskGroup.__dict__.__contains__('__aenter__')==True — async context manager; contrast Pool which is False; verified with Python 3.14.4"]
    - [mp1501xc005, multiprocessing.Process.__dict__.__contains__, ["__aiter__"],  false, "Process.__dict__.__contains__('__aiter__')==False — no async iteration on Process; contrast asyncio.StreamReader which is True; verified with Python 3.14.4"]
    - [mp1501xc006, asyncio.StreamReader.__dict__.__contains__,    ["__aiter__"],  true,  "asyncio.StreamReader.__dict__.__contains__('__aiter__')==True — async iterator; contrast Process which is False; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1501
# ---------------------------------------------------------------------------

invariant multiprocessing_extra1501.process_no_await:
  description: "multiprocessing.Process.__dict__.__contains__('__await__') returns False — multiprocessing.Process is a synchronous class for spawning OS-level child processes; it does not define __await__ in its own __dict__; multiprocessing predates Python's async/await syntax (PEP 492, Python 3.5) and has no event-loop integration; Process.join() blocks the calling thread synchronously; wave 547 theme: async protocol __dict__ presence; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: async_protocol
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant multiprocessing_extra1501.process_no_aenter:
  description: "multiprocessing.Process.__dict__.__contains__('__aenter__') returns False — multiprocessing.Process does not define __aenter__ in its own __dict__; Process is not an async context manager and does not support 'async with process:'; the multiprocessing module is entirely synchronous and has no async protocol support in any of its classes (Process, Pool, Queue, Pipe, Manager, etc.); wave 547 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: async_protocol
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["__aenter__"]
  expected: false

invariant multiprocessing_extra1501.pool_no_await:
  description: "multiprocessing.pool.Pool.__dict__.__contains__('__await__') returns False — multiprocessing.pool.Pool is a synchronous pool of worker processes; it does not define __await__ in its own __dict__; Pool.map() distributes work across processes and blocks until all results are collected; Pool.apply_async() returns an AsyncResult object (which is NOT awaitable — the 'Async' in the name refers to non-blocking submission, not Python coroutines); wave 547 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: async_protocol
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant multiprocessing_extra1501.pool_no_aenter:
  description: "multiprocessing.pool.Pool.__dict__.__contains__('__aenter__') returns False — multiprocessing.pool.Pool does not define __aenter__ in its own __dict__; Pool is not an async context manager; while Pool supports the synchronous context manager protocol ('with Pool() as p:' via __enter__/__exit__), it does not support 'async with Pool() as p:' because __aenter__ is absent from Pool.__dict__; wave 547 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: async_protocol
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__dict__.__contains__
  args: ["__aenter__"]
  expected: false
