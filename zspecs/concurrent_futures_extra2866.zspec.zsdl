spec: cf2866
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [concurrent.futures source, Python docs, https://docs.python.org/3/library/concurrent.futures.html]
  not_derived_from: [any external dataset, concurrent_futures_extra2851.zspec.zsdl — covers __rlshift__/__rrshift__/__rpow__ dict-presence, concurrent_futures_extra2836.zspec.zsdl — covers __rtruediv__/__rfloordiv__/__rmod__ dict-presence]
  notes: [Wave 638 theme — __rand__/__ror__/__rxor__ dict-presence checks for concurrent.futures types. Reflected bitwise AND, OR, and XOR operators. Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor/CancelledError/TimeoutError/BrokenExecutor/InvalidStateError are concurrency primitives not bitwise/set-like types — none define these dunders. All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

table cf2866.rand:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["cf2866001", operator.contains, [concurrent.futures.Future.__dict__, "__rand__"], false]
    - ["cf2866002", operator.contains, [concurrent.futures.Executor.__dict__, "__rand__"], false]
    - ["cf2866003", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__, "__rand__"], false]
    - ["cf2866004", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__rand__"], false]
    - ["cf2866005", operator.contains, [concurrent.futures.CancelledError.__dict__, "__rand__"], false]
    - ["cf2866006", operator.contains, [concurrent.futures.TimeoutError.__dict__, "__rand__"], false]

