spec: tarfile_extra4
version: ">=3.9"
backend: python_module(tarfile)

docs: https://docs.python.org/3/library/tarfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tarfile.html — Python tarfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tarfile.py"
    - "tarfile.zspec.zsdl — covers USTAR/GNU/PAX/DEFAULT_FORMAT values, BLOCKSIZE, RECORDSIZE, ENCODING value, type flag bytes, TarInfo construction, class __name__ for TarFile/TarInfo/TarError/ReadError, exception hierarchy, is_tarfile"
    - "tarfile_extra.zspec.zsdl — covers class __name__ table for TarFile/TarInfo/TarError/ReadError/CompressionError, open/__name__, is_tarfile/__name__, TarError base, ENCODING class name"
    - "tarfile_extra2.zspec.zsdl — covers TarFile/__name__/__module__, TarInfo/__name__/__module__, CompressionError/__name__/base, ENCODING class, REGULAR_TYPES/SUPPORTED_TYPES class, open/__name__, TarFile/TarInfo is_type, REGULAR_TYPES/SUPPORTED_TYPES membership"
    - "tarfile_extra3.zspec.zsdl — covers class __name__ table for TarFile/TarInfo/TarError/ReadError/CompressionError/ExtractError/HeaderError, open/__name__, is_tarfile/__name__, TarFile __module__, TarError base, ReadError base, REGTYPE/DIRTYPE/SYMTYPE values, TarInfo instance class"
  notes:
    - "This spec adds __qualname__ vectors for tarfile classes, exceptions, and functions."
    - "tarfile.TarFile.__qualname__ == 'TarFile' — top-level class."
    - "tarfile.TarInfo.__qualname__ == 'TarInfo' — top-level class."
    - "tarfile.TarError.__qualname__ == 'TarError' — top-level exception."
    - "tarfile.ReadError.__qualname__ == 'ReadError' — top-level exception."
    - "tarfile.CompressionError.__qualname__ == 'CompressionError' — top-level exception."
    - "tarfile.ExtractError.__qualname__ == 'ExtractError' — top-level exception."
    - "tarfile.open.__qualname__ == 'TarFile.open' — open is a classmethod on TarFile, so qualname is nested."
    - "tarfile.is_tarfile.__qualname__ == 'is_tarfile' — module-level function."
    - "tarfile.GNU_FORMAT.__class__.__name__ == 'int' — format constant is an int."
    - "tarfile.PAX_FORMAT.__class__.__name__ == 'int' — format constant is an int."
    - "tarfile.USTAR_FORMAT.__class__.__name__ == 'int' — format constant is an int."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — TarFile, TarInfo
# Top-level classes have __qualname__ == __name__.
# ---------------------------------------------------------------------------

table tarfile_extra4.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [TarFile, TarFile.__qualname__.__eq__, ["TarFile"], true]
    - [TarInfo, TarInfo.__qualname__.__eq__, ["TarInfo"], true]

# ---------------------------------------------------------------------------
# __qualname__ checks — exception classes
# ---------------------------------------------------------------------------

table tarfile_extra4.exception_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: excqname

  columns: [id, function, args, expected]
  rows:
    - [TarError,         TarError.__qualname__.__eq__,         ["TarError"],         true]
    - [ReadError,        ReadError.__qualname__.__eq__,        ["ReadError"],        true]
    - [CompressionError, CompressionError.__qualname__.__eq__, ["CompressionError"], true]
    - [ExtractError,     ExtractError.__qualname__.__eq__,     ["ExtractError"],     true]

# ---------------------------------------------------------------------------
# __qualname__ checks — module-level functions
# is_tarfile is a plain function; open is a classmethod exposed at module level
# as tarfile.open, which has __qualname__ == 'TarFile.open'.
# ---------------------------------------------------------------------------

invariant tarfile_extra4.is_tarfile.qualname:
  description: "tarfile.is_tarfile.__qualname__ == 'is_tarfile' — module-level function"
  category: qualnames
  kind: python_call_eq
  function: is_tarfile.__qualname__.__eq__
  args: ["is_tarfile"]
  expected: true

invariant tarfile_extra4.open.qualname:
  description: "tarfile.open.__qualname__ == 'TarFile.open' — open is a classmethod on TarFile"
  category: qualnames
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["TarFile.open"]
  expected: true

# ---------------------------------------------------------------------------
# HeaderError __qualname__ — also covered by extra3 for __name__; qualname is new
# ---------------------------------------------------------------------------

invariant tarfile_extra4.HeaderError.qualname:
  description: "tarfile.HeaderError.__qualname__ == 'HeaderError'"
  category: qualnames
  kind: python_call_eq
  function: HeaderError.__qualname__.__eq__
  args: ["HeaderError"]
  expected: true

# ---------------------------------------------------------------------------
# Format constant type checks — GNU_FORMAT, PAX_FORMAT, USTAR_FORMAT are ints
# The values are covered by tarfile.zspec.zsdl; the class-name type check is new.
# ---------------------------------------------------------------------------

invariant tarfile_extra4.GNU_FORMAT.class_name:
  description: "tarfile.GNU_FORMAT.__class__.__name__ == 'int' — GNU format constant is an int"
  category: constants
  kind: python_call_eq
  function: GNU_FORMAT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant tarfile_extra4.PAX_FORMAT.class_name:
  description: "tarfile.PAX_FORMAT.__class__.__name__ == 'int' — PAX format constant is an int"
  category: constants
  kind: python_call_eq
  function: PAX_FORMAT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant tarfile_extra4.USTAR_FORMAT.class_name:
  description: "tarfile.USTAR_FORMAT.__class__.__name__ == 'int' — USTAR format constant is an int"
  category: constants
  kind: python_call_eq
  function: USTAR_FORMAT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# TarFile.__module__ == 'tarfile' — cross-check using __qualname__ context
# (tarfile_extra2 and tarfile_extra3 both cover this; added here as a pairing
#  with the new __qualname__ table for completeness cross-referencing)
# StreamError __qualname__ — another exception not yet in any qualname table
# ---------------------------------------------------------------------------

invariant tarfile_extra4.StreamError.qualname:
  description: "tarfile.StreamError.__qualname__ == 'StreamError'"
  category: qualnames
  kind: python_call_eq
  function: StreamError.__qualname__.__eq__
  args: ["StreamError"]
  expected: true
