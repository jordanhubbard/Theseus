spec: re3481
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 679 (re3481): __enter__, __exit__, __call__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __enter__/__exit__/__call__ dict-presence (context manager / callable protocol)."
    - "re.Pattern, re.Match, and re.RegexFlag do not define __enter__ or __exit__ in their own __dict__s: re types are not context managers."
    - "re.Pattern, re.Match, and re.RegexFlag do not define __call__ in their own __dict__s: re types are not callable objects."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __enter__ dict-presence — operator.contains(Cls.__dict__, '__enter__')
#
# No re class defines __enter__ in its own __dict__; all false.
# re.Pattern, re.Match, and re.RegexFlag are not context managers;
# __enter__ is absent from all re class __dict__s.
# ---------------------------------------------------------------------------

table re3481.enter:
  description: "re types __enter__ dict-presence checks; wave 679"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3481

  columns: [id, function, args, expected]
  rows:
    - ["re3481001", operator.contains, [re.Pattern.__dict__,   "__enter__"], false]
    - ["re3481002", operator.contains, [re.Match.__dict__,     "__enter__"], false]
    - ["re3481003", operator.contains, [re.RegexFlag.__dict__, "__enter__"], false]

