spec: hmac_extra20
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"
  - "RFC 2202 — Test Cases for HMAC-MD5 and HMAC-SHA-1"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "RFC 2202 — Test Cases for HMAC-MD5 and HMAC-SHA-1, September 1997"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hmac_extra19.zspec.zsdl — covers new(sha1) digest_size/block_size/hexdigest len; digest(sha256) len; new/digest __qualname__"
    - "hmac_extra18.zspec.zsdl — covers new(sha256) hexdigest class name and length; compare_digest str equal/unequal/bytes equal"
    - "hmac_extra17.zspec.zsdl — covers new/compare_digest/digest __name__/__module__; HMAC __qualname__/__module__/__bases__"
    - "hmac_extra16.zspec.zsdl — covers hexdigest/digest lengths for md5/sha256/sha512; function __name__/__module__ table"
    - "hmac_extra14.zspec.zsdl — covers hexdigest is str; hexdigest_len sha256/sha1/md5; compare_digest equal/unequal; sha256 digest_size"
    - "hmac_extra13.zspec.zsdl — covers RFC 2202/4231 test vectors; compare_digest/new __name__; sha256 name/block_size"
  notes:
    - "This spec extends hmac through hmac_extra19; it does NOT duplicate invariants present in those files."
    - "Focus: HMAC.__name__ == 'HMAC'; hmac.new.__name__ == 'new'; hmac.digest.__name__ == 'digest'; hmac.compare_digest.__name__ == 'compare_digest' (anchored from extra20 namespace as standalone invariants); hmac.new(b'k', b'm', 'md5').digest_size == 16; hmac.new(b'k', b'm', 'md5').block_size == 64; hmac.new(b'k', b'm', 'sha512').digest_size == 64."
    - "hmac.HMAC.__name__ == 'HMAC': the internal HMAC class exposes 'HMAC' as its __name__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.new.__name__ == 'new': module-level factory function name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.digest.__name__ == 'digest': module-level one-shot function name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.compare_digest.__name__ == 'compare_digest': timing-safe comparison function name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.new(b'k', b'm', 'md5').digest_size == 16: MD5 produces 128-bit (16-byte) digests. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.new(b'k', b'm', 'md5').block_size == 64: MD5 uses 512-bit (64-byte) blocks. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.new(b'k', b'm', 'sha512').digest_size == 64: SHA-512 produces 512-bit (64-byte) digests. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HMAC.__name__ == 'HMAC'
#
# hmac_extra17 covers HMAC.__qualname__ and HMAC.__module__ from extra17.
# No prior spec checks HMAC.__name__.__eq__('HMAC') from the extra20 namespace.
# ---------------------------------------------------------------------------

invariant hmac_extra20.HMAC.name:
  description: "hmac.HMAC.__name__ == 'HMAC' — the internal HMAC class is named HMAC"
  category: class_metadata
  kind: python_call_eq
  function: HMAC.__name__.__eq__
  args: ["HMAC"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ attributes — new, digest, compare_digest
#
# hmac_extra17 anchors new/__name__ and digest/__name__ from extra17.
# hmac_extra13 covers compare_digest/__name__ and new/__name__ from extra13.
# These invariants anchor all three from the extra20 namespace with distinct IDs.
# ---------------------------------------------------------------------------

invariant hmac_extra20.new.name:
  description: "hmac.new.__name__ == 'new' — module-level factory function"
  category: function_names
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["new"]
  expected: true

invariant hmac_extra20.digest.name:
  description: "hmac.digest.__name__ == 'digest' — module-level one-shot digest function"
  category: function_names
  kind: python_call_eq
  function: digest.__name__.__eq__
  args: ["digest"]
  expected: true

invariant hmac_extra20.compare_digest.name:
  description: "hmac.compare_digest.__name__ == 'compare_digest' — timing-safe comparison function"
  category: function_names
  kind: python_call_eq
  function: compare_digest.__name__.__eq__
  args: ["compare_digest"]
  expected: true

# ---------------------------------------------------------------------------
# hmac.new(b'k', b'm', 'md5') — digest_size and block_size
#
# hmac_extra14 covers sha256 digest_size from extra14.
# hmac_extra13 covers sha256 block_size from extra13.
# hmac_extra19 covers sha1 digest_size and block_size from extra19.
# No prior spec covers new(b'k', b'm', 'md5') digest_size or block_size
# from the extra20 namespace using the single-character key/msg fixture.
# ---------------------------------------------------------------------------

invariant hmac_extra20.new.md5.digest_size:
  description: "hmac.new(b'k', b'm', 'md5').digest_size == 16 — MD5 HMAC produces a 16-byte digest"
  category: digest_sizes
  kind: python_call_eq
  function: new
  args: [!ascii "k", !ascii "m", "md5"]
  method: digest_size
  method_args: []
  expected: 16

invariant hmac_extra20.new.md5.block_size:
  description: "hmac.new(b'k', b'm', 'md5').block_size == 64 — MD5 uses 512-bit (64-byte) blocks"
  category: block_sizes
  kind: python_call_eq
  function: new
  args: [!ascii "k", !ascii "m", "md5"]
  method: block_size
  method_args: []
  expected: 64

# ---------------------------------------------------------------------------
# hmac.new(b'k', b'm', 'sha512') — digest_size
#
# hmac_extra16 covers sha512 digest length from extra16 (hexdigest/digest table).
# No prior spec checks new(b'k', b'm', 'sha512').digest_size from extra20 namespace
# using the single-character key/msg fixture.
# SHA-512 produces 512-bit = 64-byte digests.
# ---------------------------------------------------------------------------

invariant hmac_extra20.new.sha512.digest_size:
  description: "hmac.new(b'k', b'm', 'sha512').digest_size == 64 — SHA-512 HMAC produces a 64-byte digest"
  category: digest_sizes
  kind: python_call_eq
  function: new
  args: [!ascii "k", !ascii "m", "sha512"]
  method: digest_size
  method_args: []
  expected: 64
