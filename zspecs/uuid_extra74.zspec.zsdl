invariant uuid_extra74.uuid_int_class_qualname_member_descriptor:
  description: "uuid.UUID.int.__class__.__qualname__.__eq__('member_descriptor') == True — UUID.int is stored as a C-level member_descriptor (slot) for performance, not as a Python property; no prior uuid spec checks UUID.int.__class__.__qualname__; first __class__.__qualname__ standalone for uuid.UUID.int"
