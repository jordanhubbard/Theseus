invariant uuid_extra74.uuid_node_class_qualname_property:
  description: "uuid.UUID.node.__class__.__qualname__.__eq__('property') == True — UUID.node is a property descriptor for the hardware-address portion of the UUID; no prior uuid spec checks UUID.node.__class__.__qualname__; first __class__.__qualname__ standalone for uuid.UUID.node"
  category: class_attrs
  kind: python_call_eq
  function: UUID.node.__class__.__qualname__.__eq__
