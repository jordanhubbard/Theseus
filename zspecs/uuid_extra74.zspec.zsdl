invariant uuid_extra74.uuid_time_low_class_qualname_property:
  description: "uuid.UUID.time_low.__class__.__qualname__.__eq__('property') == True — UUID.time_low is a property descriptor for the low 32 bits of the UUID timestamp; no prior uuid spec checks UUID.time_low.__class__.__qualname__; first __class__.__qualname__ standalone for uuid.UUID.time_low"
  category: class_attrs
  kind: python_call_eq
  function: UUID.time_low.__class__.__qualname__.__eq__
  args: ["property"]
