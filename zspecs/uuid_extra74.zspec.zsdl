spec: uuid_extra74
version: ">=3.9"
extends: uuid_extra73
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra73.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 qualname lengths / UUID.__dict__ special method membership (__repr__/__hash__/__eq__/__lt__) / UUID.__dict__ property membership (bytes_le/node/time) and mappingproxy class name (table + invariants)."
    - "uuid_extra72.zspec.zsdl — covers NAMESPACE_DNS/URL/OID/X500 __class__.__name__/__module__/__qualname__ / UUID/__name__/__module__/__qualname__/__bases__[0].__name__ / SafeUUID identity (table + invariants)."
    - "uuid_extra71.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name/co_argcount and __module__/__qualname__ (table + invariants)."
    - "uuid_extra70.zspec.zsdl — covers UUID/__dict__.__contains__ for __init__/__str__/__eq__/__hash__/__lt__/int/hex/urn/version/bytes/fields / UUID/__init__/__code__/co_name/co_argcount (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra73; it does NOT duplicate invariants present in those files."
    - "Wave 249 theme: uuid UUID property descriptor __qualname__ identity and UUID.int member_descriptor __qualname__ identity."
    - "uuid.UUID.hex.__class__.__qualname__ == 'property' — UUID.hex is a property descriptor; __class__.__qualname__ is 'property'. No prior uuid spec checks UUID.hex.__class__.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.urn.__class__.__qualname__ == 'property' — UUID.urn is a property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.__class__.__qualname__ == 'property' — UUID.version is a property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.__class__.__qualname__ == 'property' — UUID.bytes is a property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le.__class__.__qualname__ == 'property' — UUID.bytes_le is a property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.__class__.__qualname__ == 'property' — UUID.fields is a property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.__class__.__qualname__ == 'property' — UUID.node is a property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.__class__.__qualname__ == 'property' — UUID.time is a property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_hi_version.__class__.__qualname__ == 'property' — UUID.time_hi_version is a property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_low.__class__.__qualname__ == 'property' — UUID.time_low is a property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_mid.__class__.__qualname__ == 'property' — UUID.time_mid is a property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq_hi_variant.__class__.__qualname__ == 'property' — UUID.clock_seq_hi_variant is a property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq_low.__class__.__qualname__ == 'property' — UUID.clock_seq_low is a property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.int.__class__.__qualname__ == 'member_descriptor' — UUID.int is a member_descriptor (a C-level slot), not a property. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.hex/__class__/__qualname__ / UUID.urn/__class__/__qualname__
# uuid.UUID.version/__class__/__qualname__ / UUID.bytes/__class__/__qualname__
#
# Wave 249 theme: UUID property descriptor __qualname__ identity (hex/urn/version/bytes).
#
# hex, urn, version, bytes are all property descriptors on UUID.
# Their __class__.__qualname__ == 'property'.
# No prior uuid spec checks __class__.__qualname__ for any UUID descriptor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra74.uuid_property_qualnames_group1:
  description: "uuid.UUID.hex/__class__/__qualname__.__eq__('property')==True / UUID.urn/__class__/__qualname__.__eq__('property')==True / UUID.version/__class__/__qualname__.__eq__('property')==True / UUID.bytes/__class__/__qualname__.__eq__('property')==True — hex/urn/version/bytes are property descriptors; __class__.__qualname__ confirms the property type; no prior uuid spec checks __class__.__qualname__ for any UUID descriptor; first __qualname__ identity anchor for UUID property descriptors"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra74

  columns: [id, function, args, expected]
  rows:
    - [uuid_hex_class_qualname_property,     UUID.hex.__class__.__qualname__.__eq__,     ["property"], true]
    - [uuid_urn_class_qualname_property,     UUID.urn.__class__.__qualname__.__eq__,     ["property"], true]
    - [uuid_version_class_qualname_property, UUID.version.__class__.__qualname__.__eq__, ["property"], true]
    - [uuid_bytes_class_qualname_property,   UUID.bytes.__class__.__qualname__.__eq__,   ["property"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.bytes_le/__class__/__qualname__ / UUID.fields/__class__/__qualname__
# uuid.UUID.node/__class__/__qualname__ / UUID.time/__class__/__qualname__
#
# Wave 249 theme: UUID property descriptor __qualname__ identity (bytes_le/fields/node/time).
#
# bytes_le, fields, node, time are all property descriptors on UUID.
# Their __class__.__qualname__ == 'property'.
# No prior uuid spec checks __class__.__qualname__ for any of these.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra74.uuid_property_qualnames_group2:
  description: "uuid.UUID.bytes_le/__class__/__qualname__.__eq__('property')==True / UUID.fields/__class__/__qualname__.__eq__('property')==True / UUID.node/__class__/__qualname__.__eq__('property')==True / UUID.time/__class__.__qualname__.__eq__('property')==True — bytes_le/fields/node/time are property descriptors; no prior uuid spec checks __class__.__qualname__ for these descriptors; first __qualname__ identity anchor for bytes_le/fields/node/time"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra74

  columns: [id, function, args, expected]
  rows:
    - [uuid_bytes_le_class_qualname_property, UUID.bytes_le.__class__.__qualname__.__eq__, ["property"], true]
    - [uuid_fields_class_qualname_property,   UUID.fields.__class__.__qualname__.__eq__,   ["property"], true]
    - [uuid_node_class_qualname_property,     UUID.node.__class__.__qualname__.__eq__,     ["property"], true]
    - [uuid_time_class_qualname_property,     UUID.time.__class__.__qualname__.__eq__,     ["property"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.time_hi_version/__class__/__qualname__ / UUID.time_low/__class__/__qualname__
# uuid.UUID.time_mid/__class__/__qualname__ / UUID.clock_seq_hi_variant/__class__/__qualname__
#
# Wave 249 theme: UUID property descriptor __qualname__ identity (time sub-fields group 1).
#
# time_hi_version, time_low, time_mid, clock_seq_hi_variant are all property descriptors.
# Their __class__.__qualname__ == 'property'.
# No prior uuid spec checks __class__.__qualname__ for any of these.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra74.uuid_property_qualnames_group3:
  description: "uuid.UUID.time_hi_version/__class__/__qualname__.__eq__('property')==True / UUID.time_low/__class__/__qualname__.__eq__('property')==True / UUID.time_mid/__class__/__qualname__.__eq__('property')==True / UUID.clock_seq_hi_variant/__class__/__qualname__.__eq__('property')==True — all four are property descriptors for UUID time and clock_seq sub-fields; no prior uuid spec checks __class__.__qualname__ for these; first __qualname__ identity anchor for UUID time/clock_seq sub-field properties"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra74

  columns: [id, function, args, expected]
  rows:
    - [uuid_time_hi_version_class_qualname,   UUID.time_hi_version.__class__.__qualname__.__eq__,   ["property"], true]
    - [uuid_time_low_class_qualname,          UUID.time_low.__class__.__qualname__.__eq__,          ["property"], true]
    - [uuid_time_mid_class_qualname,          UUID.time_mid.__class__.__qualname__.__eq__,          ["property"], true]
    - [uuid_clock_seq_hi_variant_class_qual,  UUID.clock_seq_hi_variant.__class__.__qualname__.__eq__, ["property"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.clock_seq_low/__class__/__qualname__ / UUID.int/__class__/__qualname__
#
# Wave 249 theme: clock_seq_low property and UUID.int member_descriptor contrast.
#
# clock_seq_low is a property descriptor (__class__.__qualname__ == 'property').
# UUID.int is a member_descriptor (__class__.__qualname__ == 'member_descriptor'),
# not a property — it is stored as a C-level slot for performance.
# No prior uuid spec checks __class__.__qualname__ for clock_seq_low or UUID.int.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra74.uuid_clock_seq_low_and_int_qualnames:
  description: "uuid.UUID.clock_seq_low/__class__/__qualname__.__eq__('property')==True / UUID.int/__class__/__qualname__.__eq__('member_descriptor')==True — clock_seq_low is a property descriptor; UUID.int is a member_descriptor (C-level slot, not a Python property); no prior uuid spec checks __class__.__qualname__ for clock_seq_low or UUID.int; first anchor distinguishing the member_descriptor type of UUID.int from the property descriptors"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra74

  columns: [id, function, args, expected]
  rows:
    - [uuid_clock_seq_low_class_qualname,    UUID.clock_seq_low.__class__.__qualname__.__eq__, ["property"],         true]
    - [uuid_int_class_qualname_member_desc,  UUID.int.__class__.__qualname__.__eq__,           ["member_descriptor"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.__class__.__qualname__.__eq__('property') — standalone
#
# UUID.hex is a property descriptor. No prior uuid spec checks
# UUID.hex.__class__.__qualname__. First __class__.__qualname__ standalone
# for uuid.UUID.hex. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra74.uuid_hex_class_qualname_property:
  description: "uuid.UUID.hex.__class__.__qualname__.__eq__('property') == True — UUID.hex is a property descriptor; its __class__.__qualname__ is 'property'; no prior uuid spec checks UUID.hex.__class__.__qualname__; first __class__.__qualname__ standalone for uuid.UUID.hex"
  category: class_attrs
  kind: python_call_eq
  function: UUID.hex.__class__.__qualname__.__eq__
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.version.__class__.__qualname__.__eq__('property') — standalone
