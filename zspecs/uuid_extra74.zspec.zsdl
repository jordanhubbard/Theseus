invariant uuid_extra74.uuid_version_class_qualname_property:
  description: "uuid.UUID.version.__class__.__qualname__.__eq__('property') == True — UUID.version is a property descriptor; no prior uuid spec checks UUID.version.__class__.__qualname__; first __class__.__qualname__ standalone for uuid.UUID.version"
  category: class_attrs
  kind: python_call_eq
  function: UUID.version.__class__.__qualname__.__eq__
