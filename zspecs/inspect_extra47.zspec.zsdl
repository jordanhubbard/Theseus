spec: inspect_extra47
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra46.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/iscode/isframe/istraceback __name__/__qualname__.__len__(); iscoroutinefunction/isgeneratorfunction/isasyncgenfunction __name__/__qualname__.__len__(); getmembers/getfile/getsource/getmodule/signature/stack/currentframe/getfullargspec __qualname__.__len__(); Parameter/__mro__.__len__()==2; Signature/__mro__.__len__()==2; BoundArguments/__mro__.__len__()==2; FullArgSpec/__mro__.__len__()==3; FrameInfo/__mro__.__len__()==4; Parameter.empty/kind constants; inspect.__all__.__len__()==107; CO_OPTIMIZED==1; cleandoc/formatannotation/getattr_static/classify_class_attrs __name__ lengths; Signature/Parameter/BoundArguments method qualnames; getmembers/__module__.__len__(7); parameter kind integer values; Parameter/__name__/__module__/__qualname__; Signature/__name__/__module__/__qualname__; BoundArguments/__name__/__qualname__/__module__; FullArgSpec/__name__/__qualname__/__module__; FrameInfo/__name__/__qualname__; class __bases__[0].__name__ for Parameter/Signature/BoundArguments; FullArgSpec/__bases__[0].__name__=='tuple'; FrameInfo/__bases__[0].__name__=='_FrameInfo'; all __bases__[0].__qualname__ for Parameter/Signature/BoundArguments/FullArgSpec/FrameInfo; getouterframes/__name__/__module__; getinnerframes/__name__/__module__; formatargvalues/__name__/__module__; walktree/__name__/__module__; classify_class_attrs/__name__/__module__; getattr_static/__name__/__module__."
    - "This spec covers: inspect.isfunction.__class__.__name__ == 'function'; inspect.isbuiltin.__class__.__name__ == 'function'; inspect.isclass.__class__.__name__ == 'function'; inspect.ismodule.__class__.__name__ == 'function'; inspect.signature.__class__.__name__ == 'function'; inspect.getdoc.__class__.__name__ == 'function'; inspect.getsource.__class__.__name__ == 'function'; inspect.Parameter.__class__.__name__ == 'type'; inspect.Signature.__class__.__name__ == 'type'."
    - "Key findings: All inspect module-level functions are pure-Python (def-statements in Lib/inspect.py), so their __class__.__name__ is 'function' (8 chars) — the standard CPython type for Python-level function objects. The is* predicates (isfunction, isbuiltin, isclass, ismodule) are simple boolean-returning functions that check the type of their argument; each has __class__.__name__ == 'function'. inspect.signature is the primary public API for obtaining a Signature object; inspect.getdoc and getsource are documentation/source retrieval utilities — all three are also pure-Python functions with __class__.__name__ == 'function'. By contrast, inspect.Parameter and inspect.Signature are class objects defined as pure-Python classes (class statements) in Lib/inspect.py; their __class__ is the 'type' metaclass, so __class__.__name__ == 'type' (4 chars). No prior spec recorded __class__.__name__ string equality for any inspect module-level object; prior specs recorded the objects' own __name__/__qualname__ (the functions' names) but not the metaclass/type-class names. All nine invariants are new to extra47."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect predicate functions __class__.__name__ — extra47 namespace
#
# inspect.isfunction, isbuiltin, isclass, and ismodule are pure-Python boolean
# predicate functions defined in Lib/inspect.py. Their __class__.__name__ is
# 'function' (8 chars) — the standard CPython type for Python-level function
# objects created by def statements. Prior specs recorded __name__.__len__() and
# __qualname__.__len__() for all four via length survey tables, but no prior spec
# recorded __class__.__name__ string equality for any of them. All four new to extra47.
# ---------------------------------------------------------------------------

table inspect_extra47.predicate_functions_class_names:
  description: "inspect predicate functions __class__.__name__ == 'function' — isfunction/isbuiltin/isclass/ismodule are pure-Python def-statement functions in Lib/inspect.py; __class__ is the standard Python function type; 8-char type name"
  kind: python_call_eq
  category: identity
  id_prefix: pred47

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_class_name,
       isfunction.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.isfunction.__class__.__name__ == 'function' — pure-Python predicate in Lib/inspect.py; returns True if object is a Python function (created by a def statement); __class__ is the built-in function type; __class__.__name__ is 'function' (8 chars)"]
    - [isbuiltin_class_name,
       isbuiltin.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.isbuiltin.__class__.__name__ == 'function' — pure-Python predicate in Lib/inspect.py; returns True if object is a built-in function or bound method; __class__ is the built-in function type; __class__.__name__ is 'function' (8 chars)"]
    - [isclass_class_name,
       isclass.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.isclass.__class__.__name__ == 'function' — pure-Python predicate in Lib/inspect.py; returns True if object is a class; __class__ is the built-in function type; __class__.__name__ is 'function' (8 chars)"]
    - [ismodule_class_name,
       ismodule.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.ismodule.__class__.__name__ == 'function' — pure-Python predicate in Lib/inspect.py; returns True if object is a module; __class__ is the built-in function type; __class__.__name__ is 'function' (8 chars)"]

# ---------------------------------------------------------------------------
# inspect utility functions __class__.__name__ — extra47 namespace
#
# inspect.signature, getdoc, and getsource are pure-Python utility functions
# defined in Lib/inspect.py. Their __class__.__name__ is 'function' (8 chars).
# inspect.signature is the primary public API for obtaining a callable's
# parameter signature (added in Python 3.3). inspect.getdoc returns a cleaned
# docstring; inspect.getsource returns the source code text for an object.
# Prior specs recorded __qualname__.__len__() for signature via length survey
# tables and __name__/__module__ for getdoc and getsource indirectly, but no
# prior spec recorded __class__.__name__ string equality for any of the three.
# All three are new to extra47.
# ---------------------------------------------------------------------------

table inspect_extra47.utility_functions_class_names:
  description: "inspect utility functions __class__.__name__ == 'function' — signature/getdoc/getsource are pure-Python functions in Lib/inspect.py; __class__ is the standard Python function type; 8-char type name"
  kind: python_call_eq
  category: identity
  id_prefix: util47

  columns: [id, function, args, expected, description]
  rows:
    - [signature_class_name,
       signature.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.signature.__class__.__name__ == 'function' — pure-Python function in Lib/inspect.py; primary public API for obtaining a Signature object describing a callable's parameters; added in Python 3.3; __class__.__name__ is 'function' (8 chars)"]
    - [getdoc_class_name,
       getdoc.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getdoc.__class__.__name__ == 'function' — pure-Python function in Lib/inspect.py; returns a cleaned-up docstring for an object, stripping leading whitespace; __class__.__name__ is 'function' (8 chars)"]
    - [getsource_class_name,
       getsource.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getsource.__class__.__name__ == 'function' — pure-Python function in Lib/inspect.py; returns the text of the source code for an object (module, class, method, function, traceback, frame, or code object); __class__.__name__ is 'function' (8 chars)"]

# ---------------------------------------------------------------------------
# inspect class objects __class__.__name__ — extra47 namespace
#
# inspect.Parameter and inspect.Signature are class objects — pure-Python classes
# defined with class statements in Lib/inspect.py. Their __class__ is the built-in
# 'type' metaclass, so __class__.__name__ == 'type' (4 chars). This is consistent
# with the general Python invariant that all class objects (whether C-extension
# types or pure-Python classes) are instances of the 'type' metaclass. Prior specs
# recorded __name__/__qualname__/__module__/__bases__[0].__qualname__ and __mro__.__len__()
# for both Parameter and Signature, but no prior spec recorded __class__.__name__
# string equality for either. Both are new to extra47.
# ---------------------------------------------------------------------------

table inspect_extra47.class_objects_metaclass_names:
  description: "inspect.Parameter and Signature __class__.__name__ == 'type' — pure-Python class objects in Lib/inspect.py; __class__ is the built-in 'type' metaclass; 4-char metaclass name"
  kind: python_call_eq
  category: identity
  id_prefix: cls47

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_class_name,
       Parameter.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Parameter.__class__.__name__ == 'type' — pure-Python class in Lib/inspect.py; represents a parameter in a function signature with name, kind, default, and annotation attributes; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
    - [Signature_class_name,
       Signature.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Signature.__class__.__name__ == 'type' — pure-Python class in Lib/inspect.py; represents the signature of a callable with an ordered mapping of parameters and optional return annotation; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
