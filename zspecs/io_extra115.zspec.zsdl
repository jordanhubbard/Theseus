spec: io_extra115
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec extends io_extra114.zspec.zsdl."
    - "This spec covers: io.BytesIO and io.StringIO __dict__ type (mappingproxy), __qualname__ values and lengths, and __class__.__name__ for FileIO/BufferedReader/BufferedWriter/TextIOWrapper."
    - "type(io.BytesIO.__dict__).__name__ == 'mappingproxy' (length 12); same for StringIO, FileIO, TextIOWrapper."
    - "io.BytesIO.__qualname__ == 'BytesIO' (length 7); io.StringIO.__qualname__ == 'StringIO' (length 8)."
    - "io.FileIO.__qualname__ == 'FileIO' (length 6); io.BufferedReader.__qualname__ == 'BufferedReader' (length 14)."
    - "io.BufferedWriter.__qualname__ == 'BufferedWriter' (length 14); io.TextIOWrapper.__qualname__ == 'TextIOWrapper' (length 13)."
    - "All class __dict__ values are of type 'mappingproxy' (the read-only proxy wrapping the underlying C type's tp_dict)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO and io.StringIO __dict__ type name
# Both class __dict__ attributes are 'mappingproxy' — the read-only proxy type
# used to expose C extension type dictionaries.
# 'mappingproxy' has 12 characters.
# ---------------------------------------------------------------------------

table io_extra115.BytesIO_StringIO_dict_type:
  description: "io.BytesIO and io.StringIO __dict__ type name: both are 'mappingproxy' (12 chars); FileIO and TextIOWrapper share the same __dict__ type"
  kind: python_call_eq
  category: class_names
  id_prefix: iodict115a

  columns: [id, function, args, expected, description]
  rows:
    - [bytesio_dict_type,    "BytesIO.__dict__.__class__.__name__.__eq__",      ["mappingproxy"], true,  "type(io.BytesIO.__dict__).__name__ == 'mappingproxy' (C extension class dicts are read-only mappingproxy instances)"]
    - [stringio_dict_type,   "StringIO.__dict__.__class__.__name__.__eq__",     ["mappingproxy"], true,  "type(io.StringIO.__dict__).__name__ == 'mappingproxy'"]
    - [fileio_dict_type,     "FileIO.__dict__.__class__.__name__.__eq__",        ["mappingproxy"], true,  "type(io.FileIO.__dict__).__name__ == 'mappingproxy'"]
    - [textiowrapper_dict_type, "TextIOWrapper.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true, "type(io.TextIOWrapper.__dict__).__name__ == 'mappingproxy'"]
    - [bytesio_dict_type_len,   "BytesIO.__dict__.__class__.__name__.__len__",  [],              12,    "type(io.BytesIO.__dict__).__name__.__len__() == 12 ('mappingproxy' has 12 chars)"]
    - [stringio_dict_type_len,  "StringIO.__dict__.__class__.__name__.__len__", [],              12,    "type(io.StringIO.__dict__).__name__.__len__() == 12 (same 'mappingproxy' type name length)"]
    - [dict_not_dict_type,      "BytesIO.__dict__.__class__.__name__.__eq__",   ["dict"],        false, "type(io.BytesIO.__dict__).__name__ != 'dict' (class __dict__ is a mappingproxy, not a plain dict)"]

# ---------------------------------------------------------------------------
# io.BytesIO and io.StringIO __qualname__ values and lengths
# BytesIO.__qualname__ == 'BytesIO' (7 chars); StringIO.__qualname__ == 'StringIO' (8 chars).
# These are simple top-level class qualnames (no nesting dot notation).
# ---------------------------------------------------------------------------

table io_extra115.BytesIO_StringIO_qualnames:
  description: "io.BytesIO and io.StringIO __qualname__: BytesIO='BytesIO'(7), StringIO='StringIO'(8); top-level class qualnames with no nesting"
  kind: python_call_eq
  category: qualnames
  id_prefix: ioqn115b

  columns: [id, function, args, expected, description]
  rows:
    - [bytesio_qn_eq,    "BytesIO.__qualname__.__eq__",    ["BytesIO"],    true,  "io.BytesIO.__qualname__ == 'BytesIO' (top-level class; qualname equals simple class name)"]
    - [bytesio_qn_len,   "BytesIO.__qualname__.__len__",   [],             7,     "io.BytesIO.__qualname__.__len__() == 7 ('BytesIO' has 7 chars)"]
    - [stringio_qn_eq,   "StringIO.__qualname__.__eq__",   ["StringIO"],   true,  "io.StringIO.__qualname__ == 'StringIO' (top-level class; qualname equals simple class name)"]
    - [stringio_qn_len,  "StringIO.__qualname__.__len__",  [],             8,     "io.StringIO.__qualname__.__len__() == 8 ('StringIO' has 8 chars; one char longer than BytesIO)"]
    - [fileio_qn_eq,     "FileIO.__qualname__.__eq__",     ["FileIO"],     true,  "io.FileIO.__qualname__ == 'FileIO' (6 chars)"]
    - [fileio_qn_len,    "FileIO.__qualname__.__len__",    [],             6,     "io.FileIO.__qualname__.__len__() == 6 ('FileIO' has 6 chars; shortest among the io stream classes)"]
    - [bytesio_ne_stringio_qn, "BytesIO.__qualname__.__eq__", ["StringIO"], false, "io.BytesIO.__qualname__ != 'StringIO' (distinct classes with different qualnames and lengths: 7 vs 8)"]

# ---------------------------------------------------------------------------
# io.BufferedReader, BufferedWriter, TextIOWrapper __qualname__ lengths
# BufferedReader.__qualname__ == 'BufferedReader' (14 chars).
# BufferedWriter.__qualname__ == 'BufferedWriter' (14 chars).
# TextIOWrapper.__qualname__ == 'TextIOWrapper' (13 chars).
# All are simple top-level class qualnames with no nesting.
# ---------------------------------------------------------------------------

table io_extra115.Buffered_TextIO_qualnames:
  description: "io.BufferedReader/BufferedWriter/TextIOWrapper __qualname__: BufferedReader='BufferedReader'(14), BufferedWriter='BufferedWriter'(14), TextIOWrapper='TextIOWrapper'(13)"
  kind: python_call_eq
  category: qualnames
  id_prefix: ioqn115c

  columns: [id, function, args, expected, description]
  rows:
    - [breader_qn_eq,    "BufferedReader.__qualname__.__eq__",    ["BufferedReader"],   true,  "io.BufferedReader.__qualname__ == 'BufferedReader' (14 chars)"]
    - [breader_qn_len,   "BufferedReader.__qualname__.__len__",   [],                  14,    "io.BufferedReader.__qualname__.__len__() == 14 ('BufferedReader' has 14 chars)"]
    - [bwriter_qn_eq,    "BufferedWriter.__qualname__.__eq__",    ["BufferedWriter"],   true,  "io.BufferedWriter.__qualname__ == 'BufferedWriter' (14 chars; same length as BufferedReader)"]
    - [bwriter_qn_len,   "BufferedWriter.__qualname__.__len__",   [],                  14,    "io.BufferedWriter.__qualname__.__len__() == 14 ('BufferedWriter' has 14 chars; equal to BufferedReader)"]
    - [textiowrapper_qn_eq,  "TextIOWrapper.__qualname__.__eq__", ["TextIOWrapper"],   true,  "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' (13 chars)"]
    - [textiowrapper_qn_len, "TextIOWrapper.__qualname__.__len__", [],                 13,    "io.TextIOWrapper.__qualname__.__len__() == 13 ('TextIOWrapper' has 13 chars; one shorter than the Buffered classes)"]
    - [breader_eq_bwriter_len, "BufferedReader.__qualname__.__len__.__eq__", [14],     true,  "len('BufferedReader') == len('BufferedWriter') == 14 (both buffered classes share identical qualname length)"]
    - [textiowrapper_lt_buffered, "TextIOWrapper.__qualname__.__len__.__lt__", [14],   true,  "len('TextIOWrapper') < len('BufferedReader') (13 < 14; TextIOWrapper qualname is one char shorter)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra115.BytesIO.dict_type_mappingproxy:
  description: "type(io.BytesIO.__dict__).__name__ == 'mappingproxy' (length 12; the __dict__ of every C extension type is exposed as a read-only mappingproxy; attempting to assign to it raises TypeError; this contrasts with plain Python class __dict__ which is also a mappingproxy but wrapping a regular dict)"
  category: class_names
  kind: python_call_eq
  function: "BytesIO.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

invariant io_extra115.BytesIO.qualname_len_7:
  description: "io.BytesIO.__qualname__.__len__() == 7 ('BytesIO' has 7 characters; it is a top-level class so __qualname__ equals __name__; compare with StringIO.__qualname__ which is 8 chars and FileIO.__qualname__ which is 6 chars)"
  category: qualnames
  kind: python_call_eq
  function: "BytesIO.__qualname__.__len__"
  args: []
  expected: 7

invariant io_extra115.StringIO.qualname_len_8:
  description: "io.StringIO.__qualname__.__len__() == 8 ('StringIO' has 8 characters; one longer than 'BytesIO' at 7 chars; both are simple top-level class qualnames equal to their __name__)"
  category: qualnames
  kind: python_call_eq
  function: "StringIO.__qualname__.__len__"
  args: []
  expected: 8

invariant io_extra115.FileIO.qualname_len_6:
  description: "io.FileIO.__qualname__.__len__() == 6 ('FileIO' has 6 characters; the shortest qualname among the io stream classes BytesIO(7)/StringIO(8)/FileIO(6)/TextIOWrapper(13)/BufferedReader(14)/BufferedWriter(14))"
  category: qualnames
  kind: python_call_eq
  function: "FileIO.__qualname__.__len__"
  args: []
  expected: 6

invariant io_extra115.BufferedReader.qualname_len_14:
  description: "io.BufferedReader.__qualname__.__len__() == 14 ('BufferedReader' has 14 characters; same length as 'BufferedWriter' at 14 chars; both are the longest io stream class qualnames)"
  category: qualnames
  kind: python_call_eq
  function: "BufferedReader.__qualname__.__len__"
  args: []
  expected: 14
