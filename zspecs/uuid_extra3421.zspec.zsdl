  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 675 (uu3421): __hash__, __eq__, __lt__ dict-presence checks for uuid.UUID."
    - "uuid.UUID defines __hash__ (true): UUID objects are hashable and can be used as dictionary keys."
    - "uuid.UUID defines __eq__ (true): UUID objects support == comparison for UUID equality."
    - "uuid.UUID defines __lt__ (true): UUID objects support < comparison for UUID ordering."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

