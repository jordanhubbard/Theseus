spec: struct_extra26
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra25.zspec.zsdl — covers __module__.__len__() for all six functions and both classes; __name__.__len__() for pack/unpack/calcsize/pack_into (lengths 4/6/8/9)."
    - "struct_extra24.zspec.zsdl — covers __module__.__len__() for pack/unpack/calcsize (all 7)."
    - "struct_extra23.zspec.zsdl — covers __module__.__len__() for pack_into/unpack_from/iter_unpack (all 7)."
    - "struct_extra22.zspec.zsdl — covers __module__.__len__() for Struct (7) and error (6)."
    - "struct_extra20.zspec.zsdl — covers __qualname__.__len__() for pack/unpack/pack_into/unpack_from/calcsize/iter_unpack."
  notes:
    - "This spec extends struct_extra25.zspec.zsdl."
    - "Prior specs covered: all function __qualname__/__name__/__module__ strings and lengths; Struct and error __module__ and __name__ lengths; struct.__all__ not yet covered."
    - "This spec covers: struct.__all__.__len__() (8) and __class__.__name__ ('list'); struct.__spec__.__class__.__name__ ('ModuleSpec'); struct.Struct.__reduce__.__qualname__.__len__() (17); struct.error.__reduce__.__qualname__.__len__() (24); __name__.__len__() for unpack_from/iter_unpack (both 11); Struct.__name__.__len__() (6) and error.__name__.__len__() (5)."
    - "struct.__all__ == ['calcsize','pack','pack_into','unpack','unpack_from','iter_unpack','Struct','error'], len=8. Verified."
    - "struct.__all__.__class__.__name__ == 'list'. Verified."
    - "struct.__spec__.__class__.__name__ == 'ModuleSpec'. Verified."
    - "struct.Struct.__reduce__.__qualname__ == 'object.__reduce__', __qualname__.__len__() == 17. Verified."
    - "struct.error.__reduce__.__qualname__ == 'BaseException.__reduce__', __qualname__.__len__() == 24. Verified."
    - "struct.unpack_from.__name__.__len__() == 11 — len('unpack_from') == 11. Verified."
    - "struct.iter_unpack.__name__.__len__() == 11 — len('iter_unpack') == 11. Verified."
    - "struct.Struct.__name__.__len__() == 6 — len('Struct') == 6. Verified."
    - "struct.error.__name__.__len__() == 5 — len('error') == 5. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: struct.__all__ membership — length and class name
#
# No prior struct spec covers struct.__all__ at all. The module exports
# 8 public names via __all__, stored as a list.
# Verified: __len__() == 8, __class__.__name__ == 'list' (len 4).
# ---------------------------------------------------------------------------

table struct_extra26.all_membership:
  description: "struct.__all__ has 8 entries and is a list — __len__()==8, __class__.__name__ len==4"
  kind: python_call_eq
  category: module_constants
  id_prefix: allm26

  columns: [id, function, args, expected]
  rows:
    - [all_len,        "__all__.__len__",                  [], 8]
    - [all_class_len,  "__all__.__class__.__name__.__len__", [], 4]

# ---------------------------------------------------------------------------
# Table: __reduce__ qualname lengths for Struct and error
#
# No prior struct spec covers __reduce__.__qualname__.__len__() for any type.
# struct.Struct inherits __reduce__ from object ('object.__reduce__', len 17).
# struct.error inherits __reduce__ from BaseException ('BaseException.__reduce__', len 24).
# The difference (17 vs 24) reflects the different inheritance chains.
# Verified: Struct=17, error=24.
# ---------------------------------------------------------------------------

table struct_extra26.reduce_qualname_lengths:
  description: "struct.Struct and error __reduce__.__qualname__.__len__() — 17 and 24"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: rqlen26

  columns: [id, function, args, expected]
  rows:
    - [Struct_reduce_qlen, "Struct.__reduce__.__qualname__.__len__", [], 17]
    - [error_reduce_qlen,  "error.__reduce__.__qualname__.__len__",  [], 24]

# ---------------------------------------------------------------------------
# Standalone: struct.__spec__.__class__.__name__ length == 10
#
# struct.__spec__ is a ModuleSpec instance. 'ModuleSpec' has 10 characters.
# No prior struct spec covers __spec__.__class__.__name__ or its length.
# Verified: struct.__spec__.__class__.__name__ == 'ModuleSpec', len=10.
# ---------------------------------------------------------------------------

invariant struct_extra26.spec_class_name_len:
  description: "struct.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Standalone: struct.Struct.__name__.__len__() == 6
#
# 'Struct' has 6 characters. struct_extra25 covers Struct.__module__.__len__()
# but no prior spec covers Struct.__name__.__len__().
# Verified: struct.Struct.__name__ == 'Struct', len=6.
# ---------------------------------------------------------------------------

invariant struct_extra26.Struct.name_len:
  description: "struct.Struct.__name__.__len__() == 6 — 'Struct' has 6 characters"
  category: class_identity
  kind: python_call_eq
  function: "Struct.__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Standalone: struct.unpack_from.__name__.__len__() == 11
#
# 'unpack_from' has 11 characters. struct_extra25 covers __name__.__len__() for
# pack/unpack/calcsize/pack_into but not unpack_from or iter_unpack.
# Both unpack_from and iter_unpack share length 11.
# Verified: len('unpack_from') == 11; len('iter_unpack') == 11.
# ---------------------------------------------------------------------------

invariant struct_extra26.unpack_from.name_len:
  description: "struct.unpack_from.__name__.__len__() == 11 — 'unpack_from' has 11 characters"
  category: function_identity
  kind: python_call_eq
  function: "unpack_from.__name__.__len__"
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# Standalone: struct.error.__reduce__.__qualname__.__len__() == 24
#
# struct.error inherits __reduce__ from BaseException, making the qualname
# 'BaseException.__reduce__' (24 chars). This is longer than Struct's 17
# because BaseException has a longer name than object.
# No prior struct spec covers __reduce__ qualname length for error.
# Verified: len('BaseException.__reduce__') == 24.
# ---------------------------------------------------------------------------

invariant struct_extra26.error_reduce_qualname_len:
  description: "struct.error.__reduce__.__qualname__.__len__() == 24 — inherits 'BaseException.__reduce__' (24 chars)"
  category: method_qualnames
  kind: python_call_eq
  function: "error.__reduce__.__qualname__.__len__"
  args: []
  expected: 24
