spec: hashlib_extra111
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra110.zspec.zsdl — covers HASH class-level method descriptor qualnames for digest/copy / method_descriptor type names for update/digest/copy at class level / sha256 instance-bound method qualnames (digest/copy/hexdigest) / hexdigest descriptor type name and length confirmations (table + invariants)."
    - "hashlib_extra109.zspec.zsdl — covers algorithms_guaranteed and algorithms_available class names and sizes / subset relationship / hashlib.new code attributes (co_name, co_argcount, type, module) / blake2s membership (table + invariants)."
    - "hashlib_extra108.zspec.zsdl — covers sha224/sha384/sha3_256/sha3_512 digest_size and block_size / blake2b/blake2s digest_size and block_size and type names / sha3_256/sha3_512 HASH type identity / HASH.update and HASH.hexdigest qualname string equality via sha256().__class__ (table + invariants)."
    - "hashlib_extra107.zspec.zsdl — covers HASH type identity (__name__=='HASH', __module__=='_hashlib', __mro__.__len__()==2, __bases__[0].__name__=='object') / HASH method qualname lengths (update=11, digest=11, hexdigest=14, copy=9) via md5().__class__ / md5/sha1/sha256/sha512 digest_size and block_size (table + invariants)."
    - "hashlib_extra106.zspec.zsdl — covers pbkdf2_hmac/scrypt __class__.__name__/__qualname__/__len__() and __name__.__eq__ / file_digest __qualname__/__name__/__module__.__len__() / sha3_224/256/384/512 and shake_128/256 __name__.__len__() (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s class/module/qualname / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* __qualname__/__module__ equality and __class__.__name__ / file_digest class/qualname/module equality / hashlib.__all__ class name and length (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra110; it does NOT duplicate invariants present in those files."
    - "Wave 270 theme: pbkdf2_hmac and scrypt function class names and qualnames / md5/sha256/sha3_256/blake2b class name heterogeneity (builtin_function_or_method vs type) / sha3_256 module is _hashlib / blake2b module is _blake2."
    - "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.pbkdf2_hmac.__qualname__) == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__qualname__ == 'scrypt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.scrypt.__qualname__) == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.sha3_256).__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.blake2b).__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__ == '_blake2'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: sha3_256 is a builtin_function_or_method from _hashlib (OpenSSL-backed). blake2b is a type object from _blake2 (pure C extension type). This is a key structural difference: calling sha3_256() calls a C function; calling blake2b() calls the type's __call__."
    - "Note: pbkdf2_hmac.__qualname__=='pbkdf2_hmac' (11 chars; same length as 'HASH.update'/'HASH.digest'). scrypt.__qualname__=='scrypt' (6 chars). These qualnames are unqualified (no class prefix) because they are module-level functions from _hashlib."
    - "Note: hashlib_extra106 anchors pbkdf2_hmac/scrypt __qualname__.__len__() and __name__.__eq__; this spec anchors the same quantities via __class__.__name__ and __module__ as grouped tables not covered by extra106."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib')
# hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac')
# hashlib.pbkdf2_hmac.__qualname__.__len__()==11
# hashlib.scrypt.__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 270 theme: pbkdf2_hmac and scrypt class names, modules, and qualnames.
#
# pbkdf2_hmac and scrypt are module-level functions from _hashlib (OpenSSL).
# Both are builtin_function_or_method objects. pbkdf2_hmac.__qualname__ is
# 'pbkdf2_hmac' (11 chars — same length as 'HASH.update' and 'HASH.digest').
# scrypt.__qualname__ is 'scrypt' (6 chars). hashlib_extra106 anchors qualname
# lengths and __name__ equality; this spec anchors __class__.__name__ and
# __module__ as a grouped table under hashhkdf111.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra111.pbkdf2_hmac_scrypt_class_and_module:
  description: "pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method')==True / pbkdf2_hmac.__module__.__eq__('_hashlib')==True / pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac')==True / pbkdf2_hmac.__qualname__.__len__()==11 / scrypt.__class__.__name__.__eq__('builtin_function_or_method')==True — both are module-level C functions from _hashlib (OpenSSL); pbkdf2_hmac qualname is 11 chars (same as HASH.update/digest); extra106 anchors qualname lengths and __name__ equality; this spec anchors __class__.__name__ and __module__ as group; first hashhkdf111 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashhkdf111

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_class_name,    "pbkdf2_hmac.__class__.__name__.__eq__",   ["builtin_function_or_method"], true, "pbkdf2_hmac.__class__.__name__ is 'builtin_function_or_method' (C-level function from _hashlib/OpenSSL)"]
    - [pbkdf2_module_eq,     "pbkdf2_hmac.__module__.__eq__",           ["_hashlib"],                   true, "pbkdf2_hmac.__module__ is '_hashlib' (OpenSSL-backed C extension)"]
    - [pbkdf2_qualname_eq,   "pbkdf2_hmac.__qualname__.__eq__",         ["pbkdf2_hmac"],                true, "pbkdf2_hmac.__qualname__ is 'pbkdf2_hmac' (11 chars; unqualified module-level function name)"]
    - [pbkdf2_qualname_len,  "pbkdf2_hmac.__qualname__.__len__",        [],                             11,   "pbkdf2_hmac.__qualname__.__len__() is 11 (same length as 'HASH.update' and 'HASH.digest')"]
    - [scrypt_class_name,    "scrypt.__class__.__name__.__eq__",        ["builtin_function_or_method"], true, "scrypt.__class__.__name__ is 'builtin_function_or_method' (C-level function from _hashlib/OpenSSL)"]

# ---------------------------------------------------------------------------
# hashlib.scrypt.__qualname__.__eq__('scrypt')
# hashlib.scrypt.__qualname__.__len__()==6
# hashlib.md5.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha3_256.__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 270 theme: scrypt qualname and md5/sha256/sha3_256 class name homogeneity.
#
# scrypt.__qualname__ is 'scrypt' (6 chars). md5, sha256, and sha3_256 are all
# builtin_function_or_method — they are C-level factory functions, not types.
# This is in contrast to blake2b which is a type object. hashlib_extra99 anchors
# md5/sha256 __class__.__name__ equality; no prior hashlib spec anchors sha3_256
# __class__.__name__ as part of a grouped comparison table with md5/sha256.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra111.scrypt_qualname_and_algo_class_names:
  description: "scrypt.__qualname__.__eq__('scrypt')==True / scrypt.__qualname__.__len__()==6 / md5.__class__.__name__.__eq__('builtin_function_or_method')==True / sha256.__class__.__name__.__eq__('builtin_function_or_method')==True / sha3_256.__class__.__name__.__eq__('builtin_function_or_method')==True — scrypt qualname is 'scrypt' (6 chars); md5/sha256/sha3_256 are all builtin_function_or_method (C factory functions); extra99 anchors md5/sha256 class names; no prior spec groups sha3_256 class name with md5/sha256; first hashhkdf111 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashhkdf111

  columns: [id, function, args, expected, description]
  rows:
    - [scrypt_qualname_eq,    "scrypt.__qualname__.__eq__",              ["scrypt"],                     true, "scrypt.__qualname__ is 'scrypt' (6 chars; shortest qualname among hashlib KDF functions)"]
    - [scrypt_qualname_len,   "scrypt.__qualname__.__len__",             [],                             6,    "scrypt.__qualname__.__len__() is 6 (6 chars: 's','c','r','y','p','t')"]
    - [md5_class_name,        "md5.__class__.__name__.__eq__",           ["builtin_function_or_method"], true, "md5.__class__.__name__ is 'builtin_function_or_method' (C factory function from _hashlib)"]
    - [sha256_class_name,     "sha256.__class__.__name__.__eq__",        ["builtin_function_or_method"], true, "sha256.__class__.__name__ is 'builtin_function_or_method' (C factory function from _hashlib)"]
    - [sha3_256_class_name,   "sha3_256.__class__.__name__.__eq__",      ["builtin_function_or_method"], true, "sha3_256.__class__.__name__ is 'builtin_function_or_method' (OpenSSL-backed; same pattern as md5/sha256)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__module__.__eq__('_hashlib')
# hashlib.blake2b.__class__.__name__.__eq__('type')
# hashlib.blake2b.__module__.__eq__('_blake2')
# hashlib.sha3_256.__qualname__.__eq__('openssl_sha3_256')
# hashlib.blake2b.__qualname__.__eq__('blake2b')
#
# Wave 270 theme: sha3_256 module vs blake2b module / blake2b is a type not a function.
#
# sha3_256 is a builtin_function_or_method from _hashlib with qualname
# 'openssl_sha3_256' (16 chars). blake2b is a type object from _blake2 with
# qualname 'blake2b' (7 chars). This heterogeneity — sha3_256 from _hashlib
# vs blake2b from _blake2 — is a key structural distinction in the hashlib
# implementation. No prior hashlib spec anchors sha3_256.__module__ or
# blake2b.__class__.__name__ as a grouped table under hashhkdf111.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra111.sha3_256_module_and_blake2b_type_identity:
  description: "sha3_256.__module__.__eq__('_hashlib')==True / blake2b.__class__.__name__.__eq__('type')==True / blake2b.__module__.__eq__('_blake2')==True / sha3_256.__qualname__.__eq__('openssl_sha3_256')==True / blake2b.__qualname__.__eq__('blake2b')==True — sha3_256 is builtin_function_or_method from _hashlib (OpenSSL); blake2b is a type from _blake2; this heterogeneity is a key structural distinction; no prior spec anchors sha3_256.__module__ or blake2b type identity as group; first hashhkdf111 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashhkdf111

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_module_eq,    "sha3_256.__module__.__eq__",              ["_hashlib"],   true, "sha3_256.__module__ is '_hashlib' (OpenSSL-backed; sha3_256 comes from _hashlib C extension)"]
    - [blake2b_class_name,    "blake2b.__class__.__name__.__eq__",       ["type"],       true, "blake2b.__class__.__name__ is 'type' (blake2b is a type object, not a function; calling blake2b() invokes type.__call__)"]
    - [blake2b_module_eq,     "blake2b.__module__.__eq__",               ["_blake2"],    true, "blake2b.__module__ is '_blake2' (separate BLAKE2 C extension; not _hashlib/OpenSSL)"]
    - [sha3_256_qualname_eq,  "sha3_256.__qualname__.__eq__",            ["openssl_sha3_256"], true, "sha3_256.__qualname__ is 'openssl_sha3_256' (16 chars; 'openssl_' prefix reflects OpenSSL implementation)"]
    - [blake2b_qualname_eq,   "blake2b.__qualname__.__eq__",             ["blake2b"],    true, "blake2b.__qualname__ is 'blake2b' (7 chars; simple unqualified name for the type from _blake2)"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac') — standalone
#
# hashlib.pbkdf2_hmac.__qualname__ is 'pbkdf2_hmac' (11 chars). The qualname
# is unqualified (no class prefix) because pbkdf2_hmac is a module-level
# function exported from the _hashlib C extension. pbkdf2_hmac implements
# PBKDF2 (Password-Based Key Derivation Function 2) from RFC 2898, used for
# deriving cryptographic keys from passwords. Its qualname length (11) equals
# that of 'HASH.update' and 'HASH.digest' (both 11 chars), but for a
# structurally different reason — no 'ClassName.' prefix here.
# No prior hashlib spec anchors pbkdf2_hmac.__qualname__ equality as a
# standalone under hashhkdf111. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra111.pbkdf2_hmac_qualname_eq:
  description: "hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac') == True — qualname is 'pbkdf2_hmac' (11 chars; unqualified module-level function from _hashlib); implements PBKDF2 (RFC 2898) for password-based key derivation; length 11 equals HASH.update/HASH.digest but without 'ClassName.' prefix; extra106 anchors __qualname__.__len__()==11 but not equality; first standalone under hashhkdf111"
  category: function_identity
  kind: python_call_eq
  function: "pbkdf2_hmac.__qualname__.__eq__"
  args: ["pbkdf2_hmac"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.scrypt.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.scrypt.__class__.__name__ is 'builtin_function_or_method'. scrypt
# implements the scrypt memory-hard key derivation function (RFC 7914). Like
# pbkdf2_hmac, scrypt is a module-level C function from _hashlib (OpenSSL).
# Both KDF functions share the same __class__.__name__ as the standard hash
# constructor functions (md5, sha256, etc.) — all are builtin_function_or_method.
# No prior hashlib spec anchors scrypt.__class__.__name__ as a standalone
# under hashhkdf111. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra111.scrypt_class_name_eq:
  description: "hashlib.scrypt.__class__.__name__.__eq__('builtin_function_or_method') == True — scrypt is a C-level function from _hashlib/OpenSSL implementing RFC 7914 memory-hard KDF; shares __class__.__name__ with md5/sha256 and pbkdf2_hmac (all builtin_function_or_method); extra106 anchors scrypt __class__.__name__.__len__() but not __eq__; first standalone under hashhkdf111"
  category: function_identity
  kind: python_call_eq
  function: "scrypt.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__class__.__name__.__eq__('type') — standalone
#
# hashlib.blake2b.__class__.__name__ is 'type'. Unlike md5, sha256, sha3_256,
# pbkdf2_hmac, and scrypt (all builtin_function_or_method), blake2b is a
# Python type object. Calling blake2b() invokes type.__call__ which calls
# blake2b.__new__ and blake2b.__init__. This structural difference reflects
# that blake2b is implemented as a full Python extension type in the _blake2
# C module, rather than as a simple factory function in _hashlib. The blake2s
# function has the same class identity pattern.
# No prior hashlib spec anchors blake2b.__class__.__name__ equality as a
# standalone under hashhkdf111. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra111.blake2b_class_name_type:
  description: "hashlib.blake2b.__class__.__name__.__eq__('type') == True — blake2b is a type object (not a builtin_function_or_method like md5/sha256/sha3_256); calling blake2b() invokes type.__call__; implemented as full extension type in _blake2 C module; contrasts with sha3_256 (builtin_function_or_method from _hashlib); no prior spec anchors blake2b.__class__.__name__ as standalone; first standalone under hashhkdf111"
  category: function_identity
  kind: python_call_eq
  function: "blake2b.__class__.__name__.__eq__"
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__module__.__eq__('_hashlib') — standalone
#
# hashlib.sha3_256.__module__ is '_hashlib'. Despite SHA-3 being a distinct
# algorithm family from OpenSSL-backed SHA-2 (md5/sha256 also come from
# _hashlib), sha3_256 is implemented via the same _hashlib C extension —
# indicating that CPython uses OpenSSL's SHA-3 implementation rather than
# a separate pure-C SHA-3 extension. This is in contrast to blake2b which
# comes from the separate _blake2 module.
# No prior hashlib spec anchors sha3_256.__module__ as a standalone under
# hashhkdf111. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra111.sha3_256_module_hashlib:
  description: "hashlib.sha3_256.__module__.__eq__('_hashlib') == True — sha3_256 is from _hashlib (OpenSSL-backed), not a separate sha3 extension; contrasts with blake2b which uses _blake2 module; CPython uses OpenSSL for both SHA-2 and SHA-3 families; qualname is 'openssl_sha3_256' (confirming OpenSSL backing); no prior spec anchors sha3_256.__module__ as standalone; first standalone under hashhkdf111"
  category: function_identity
  kind: python_call_eq
  function: "sha3_256.__module__.__eq__"
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__module__.__eq__('_blake2') — standalone
#
# hashlib.blake2b.__module__ is '_blake2'. The BLAKE2 hash functions (blake2b
# and blake2s) use a dedicated _blake2 C extension module, separate from
# the _hashlib OpenSSL-backed extension. BLAKE2 was designed by Jean-Philippe
# Aumasson et al. as a faster alternative to SHA-3 and MD5/SHA-1. The separate
# _blake2 module has been part of CPython since Python 3.6. blake2b is a type
# (not a function), and its __module__ is '_blake2' (not '_hashlib'), marking
# it as structurally distinct from all other hashlib hash constructors.
# No prior hashlib spec anchors blake2b.__module__ as a standalone under
# hashhkdf111. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra111.blake2b_module_blake2:
  description: "hashlib.blake2b.__module__.__eq__('_blake2') == True — blake2b uses dedicated _blake2 C extension (not _hashlib/OpenSSL); BLAKE2 designed as faster alternative to SHA-3; _blake2 in CPython since Python 3.6; blake2b is a type and its module is '_blake2' — both attributes distinguish it from all other hashlib hash constructors; no prior spec anchors blake2b.__module__ as standalone; first standalone under hashhkdf111"
  category: function_identity
  kind: python_call_eq
  function: "blake2b.__module__.__eq__"
  args: ["_blake2"]
  expected: true
