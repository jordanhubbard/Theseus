spec: concurrent_futures_extra150
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers: concurrent.futures.Executor class identity and executor subclass identity. Executor.__name__=='Executor' (len=8); Executor.__module__=='concurrent.futures._base' (len=24; defined in Lib/concurrent/futures/_base.py); Executor.__bases__[0].__name__=='object' (Executor is an abstract base class inheriting from object — it is NOT an abc.ABC subclass; its abstract status is enforced by documentation convention and NotImplementedError raises, not by ABCMeta); ThreadPoolExecutor.__name__=='ThreadPoolExecutor' (len=18); ThreadPoolExecutor.__module__=='concurrent.futures.thread' (len=25); ThreadPoolExecutor.__bases__[0].__name__=='Executor' (inherits from Executor); ProcessPoolExecutor.__name__=='ProcessPoolExecutor' (len=19); ProcessPoolExecutor.__module__=='concurrent.futures.process' (len=26); ProcessPoolExecutor.__bases__[0].__name__=='Executor' (also inherits from Executor); concurrent.futures._base.Executor.__module__=='concurrent.futures._base'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Executor.__module__=='concurrent.futures._base' — Executor is defined in Lib/concurrent/futures/_base.py and re-exported through concurrent/futures/__init__.py; its __module__ is 'concurrent.futures._base' (len=24), NOT 'concurrent.futures' (len=18); this is the private submodule _base.py that contains the core Executor API and Future class; compare: Executor.__bases__[0].__name__=='object' (Executor is not an ABCMeta-based ABC; it is a conventional abstract class using NotImplementedError). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__=='Executor' and concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__=='Executor' — both executor implementations inherit directly from Executor (single inheritance in both cases); ThreadPoolExecutor is in 'concurrent.futures.thread' (len=25) and ProcessPoolExecutor is in 'concurrent.futures.process' (len=26). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Executor class identity — extra150
