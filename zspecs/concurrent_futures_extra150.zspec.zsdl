table concurrent_futures_extra150.cf_threadpool_executor_identity:
  description: "concurrent.futures.ThreadPoolExecutor class identity checks in cfthread150 namespace — concurrent.futures.ThreadPoolExecutor.__name__=='ThreadPoolExecutor' (len=18; the thread-based executor implementation managing a pool of Python threads for concurrent execution); concurrent.futures.ThreadPoolExecutor.__module__=='concurrent.futures.thread' (len=25; defined in Lib/concurrent/futures/thread.py — the submodule name 'concurrent.futures.thread' has len=25); concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__=='Executor' (len=8; directly inherits from Executor using single inheritance; does NOT inherit from ProcessPoolExecutor); ThreadPoolExecutor is simpler than ProcessPoolExecutor (thread.__dict__.__len__()==25 vs process.__dict__.__len__()==47) because thread management is handled by Python's threading module; name length: ThreadPoolExecutor(18) < ProcessPoolExecutor(19); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfthread150

  columns: [id, function, args, expected, description]
  rows:
    - [thread_name_eq,   "concurrent.futures.ThreadPoolExecutor.__name__.__eq__",              ["ThreadPoolExecutor"],            true,  "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' (len=18); verified with Python 3.14.3"]
    - [thread_mod_eq,    "concurrent.futures.ThreadPoolExecutor.__module__.__eq__",             ["concurrent.futures.thread"],     true,  "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (len=25); verified with Python 3.14.3"]
    - [thread_base_eq,   "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],                      true,  "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' (directly inherits from Executor); verified with Python 3.14.3"]
    - [thread_name_len,  "concurrent.futures.ThreadPoolExecutor.__name__.__len__",              [],                                18,    "concurrent.futures.ThreadPoolExecutor.__name__.__len__() == 18 ('ThreadPoolExecutor'); verified with Python 3.14.3"]

