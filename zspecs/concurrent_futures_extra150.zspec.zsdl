invariant concurrent_futures_extra150.cf_Executor_module_is_base:
  description: "concurrent.futures.Executor.__module__.__eq__('concurrent.futures._base') returns True — concurrent.futures.Executor is defined in Lib/concurrent/futures/_base.py; its __module__ is 'concurrent.futures._base' (len=24), NOT 'concurrent.futures' (len=18); the _base submodule contains the core Executor abstract class, the Future class, the wait() and as_completed() utilities, and the exception classes; Executor.__bases__[0].__name__=='object' (Executor inherits from object — it is a conventional abstract class, not an ABCMeta-based ABC); concurrent.futures._base.Executor.__module__=='concurrent.futures._base' (same object when accessed via either path); NEW in extra150: first standalone concurrent.futures.Executor.__module__ identity invariant in cfexec150 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Executor.__module__.__eq__"
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra150.cf_Executor_bases0_is_object:
  description: "concurrent.futures.Executor.__bases__[0].__name__.__eq__('object') returns True — Executor inherits directly from object (single inheritance); Executor is NOT an ABCMeta-based abstract base class — it is a conventional abstract class that enforces its interface by raising NotImplementedError in the submit() method; compare: abc.ABCMeta.__bases__[0].__name__=='type' (ABCMeta IS a metaclass); Executor.__bases__[0].__name__=='object' (len=6); Executor.__name__.__len__()==8 ('Executor'); Executor.__module__=='concurrent.futures._base' (len=24); both subclasses (ThreadPoolExecutor and ProcessPoolExecutor) also use single inheritance from Executor; NEW in extra150: first standalone concurrent.futures.Executor.__bases__[0] name identity invariant in cfexec150 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Executor.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant concurrent_futures_extra150.cf_ThreadPoolExecutor_bases0_is_Executor:
  description: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor') returns True — ThreadPoolExecutor inherits directly from Executor using single inheritance; ThreadPoolExecutor.__bases__[0].__name__=='Executor' (len=8); ThreadPoolExecutor.__module__=='concurrent.futures.thread' (len=25); ThreadPoolExecutor.__name__=='ThreadPoolExecutor' (len=18); ThreadPoolExecutor implements Executor's abstract interface by maintaining a pool of Python threads (using threading.Thread); it overrides submit() to schedule callables on available threads and returns Future objects; ThreadPoolExecutor is the simpler of the two executors (thread dict size=25 vs process dict size=47); NEW in extra150: first standalone concurrent.futures.ThreadPoolExecutor.__bases__[0] name identity invariant in cfthread150 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra150.cf_ProcessPoolExecutor_bases0_is_Executor:
  description: "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor') returns True — ProcessPoolExecutor inherits directly from Executor using single inheritance (same pattern as ThreadPoolExecutor); ProcessPoolExecutor.__bases__[0].__name__=='Executor' (len=8); ProcessPoolExecutor.__module__=='concurrent.futures.process' (len=26; 1 char longer than 'concurrent.futures.thread'=25); ProcessPoolExecutor.__name__=='ProcessPoolExecutor' (len=19; 1 char longer than 'ThreadPoolExecutor'=18); ProcessPoolExecutor implements parallelism beyond the GIL by spawning worker processes; it is more complex than ThreadPoolExecutor (process dict=47 vs thread dict=25) due to inter-process communication infrastructure; NEW in extra150: first standalone concurrent.futures.ProcessPoolExecutor.__bases__[0] name identity invariant in cfprocess150 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra150.cf_base_Executor_module_eq:
  description: "concurrent.futures._base.Executor.__module__.__eq__('concurrent.futures._base') returns True — concurrent.futures._base.Executor is the same object as concurrent.futures.Executor (re-exported through __init__.py); both paths reach the same class defined in Lib/concurrent/futures/_base.py; _base.Executor.__module__=='concurrent.futures._base' (len=24); accessing via concurrent.futures._base.Executor directly (without going through the top-level re-export) gives the same __module__ value; Executor.__name__=='Executor' (len=8); Executor.__bases__[0].__name__=='object'; NEW in extra150: first standalone concurrent.futures._base.Executor.__module__ identity invariant in cfexec150 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures._base.Executor.__module__.__eq__"
  args: ["concurrent.futures._base"]
  expected: true

