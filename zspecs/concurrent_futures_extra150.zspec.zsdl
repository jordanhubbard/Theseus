table concurrent_futures_extra150.cf_processpool_executor_identity:
  description: "concurrent.futures.ProcessPoolExecutor class identity checks in cfprocess150 namespace — concurrent.futures.ProcessPoolExecutor.__name__=='ProcessPoolExecutor' (len=19; the process-based executor implementation managing a pool of worker processes for parallelism beyond the GIL); concurrent.futures.ProcessPoolExecutor.__module__=='concurrent.futures.process' (len=26; defined in Lib/concurrent/futures/process.py — 'concurrent.futures.process' is 1 char longer than 'concurrent.futures.thread'=25); concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__=='Executor' (len=8; directly inherits from Executor — same single-inheritance pattern as ThreadPoolExecutor; both ThreadPoolExecutor and ProcessPoolExecutor have Executor as their sole base class); ProcessPoolExecutor(19) is 1 char longer than ThreadPoolExecutor(18); both inherit directly from Executor(8) which inherits from object(6); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfprocess150

  columns: [id, function, args, expected, description]
  rows:
    - [proc_name_eq,   "concurrent.futures.ProcessPoolExecutor.__name__.__eq__",              ["ProcessPoolExecutor"],           true,  "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' (len=19); verified with Python 3.14.3"]
    - [proc_mod_eq,    "concurrent.futures.ProcessPoolExecutor.__module__.__eq__",             ["concurrent.futures.process"],    true,  "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (len=26); verified with Python 3.14.3"]
    - [proc_base_eq,   "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],                      true,  "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' (inherits from Executor — same base as ThreadPoolExecutor); verified with Python 3.14.3"]
    - [proc_name_len,  "concurrent.futures.ProcessPoolExecutor.__name__.__len__",              [],                                19,    "concurrent.futures.ProcessPoolExecutor.__name__.__len__() == 19 ('ProcessPoolExecutor'; 1 longer than ThreadPoolExecutor=18); verified with Python 3.14.3"]

