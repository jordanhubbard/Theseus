# concurrent.futures.Executor.__name__.__eq__('Executor')                       == True
# concurrent.futures.Executor.__module__.__eq__('concurrent.futures._base')     == True
# concurrent.futures.Executor.__bases__[0].__name__.__eq__('object')            == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra150.cf_executor_class_identity:
  description: "concurrent.futures.Executor class identity checks in cfexec150 namespace — concurrent.futures.Executor.__name__=='Executor' (len=8; the abstract base class for all executor implementations — defines submit(), map(), and shutdown()); concurrent.futures.Executor.__module__=='concurrent.futures._base' (len=24; defined in Lib/concurrent/futures/_base.py, the private submodule — NOT 'concurrent.futures' which is len=18); concurrent.futures.Executor.__bases__[0].__name__=='object' (len=6; Executor inherits from object — it is NOT an ABCMeta-based ABC; its abstract interface is enforced by raising NotImplementedError in submit()); concurrent.futures.Executor.__name__.__len__()==8 ('Executor': 'Exec'=4+'utor'=4=8); concurrent.futures._base.Executor.__module__=='concurrent.futures._base' (same as concurrent.futures.Executor — they are the same object); Executor.__module__.__len__()==24; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexec150

  columns: [id, function, args, expected, description]
  rows:
    - [exec_name_eq,   "concurrent.futures.Executor.__name__.__eq__",                       ["Executor"],                    true,  "concurrent.futures.Executor.__name__ == 'Executor' (len=8); verified with Python 3.14.3"]
    - [exec_mod_eq,    "concurrent.futures.Executor.__module__.__eq__",                      ["concurrent.futures._base"],    true,  "concurrent.futures.Executor.__module__ == 'concurrent.futures._base' (len=24; private submodule, not top-level); verified with Python 3.14.3"]
    - [exec_base_eq,   "concurrent.futures.Executor.__bases__[0].__name__.__eq__",           ["object"],                      true,  "concurrent.futures.Executor.__bases__[0].__name__ == 'object' (inherits from object — conventional abstract class, not ABCMeta); verified with Python 3.14.3"]
    - [exec_name_len,  "concurrent.futures.Executor.__name__.__len__",                       [],                              8,     "concurrent.futures.Executor.__name__.__len__() == 8 ('Executor'); verified with Python 3.14.3"]
    - [exec_mod_len,   "concurrent.futures.Executor.__module__.__len__",                     [],                              24,    "concurrent.futures.Executor.__module__.__len__() == 24 ('concurrent.futures._base'); verified with Python 3.14.3"]

