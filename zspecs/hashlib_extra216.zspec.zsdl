table hashlib_extra216.file_digest_and_constructors_doc_contains:
  description: "hashlib.file_digest, hashlib.md5, hashlib.sha256 __doc__ contains checks in hashlibdoc216b namespace — wave 216 theme: hashlib.file_digest.__doc__.__contains__('fileobj')==True; hashlib.file_digest.__doc__.__contains__('binary')==True; hashlib.file_digest.__doc__.__contains__('contents')==True; hashlib.file_digest.__doc__.__contains__('constructor')==True; hashlib.md5.__doc__.__contains__('string')==True; hashlib.sha256.__doc__.__contains__('string')==True; hashlib.md5.__doc__.__contains__('Returns')==True; hashlib.md5.__doc__.__contains__('optionally')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibdoc216b

  columns: [id, function, args, expected, description]
  rows:
    - [fd_doc_has_fileobj,      hashlib.file_digest.__doc__.__contains__, ["fileobj"],      true, "hashlib.file_digest.__doc__ contains 'fileobj'; parameter name for file-like object; verified with Python 3.14.3"]
    - [fd_doc_has_binary,       hashlib.file_digest.__doc__.__contains__, ["binary"],       true, "hashlib.file_digest.__doc__ contains 'binary'; file must be opened in binary mode; verified with Python 3.14.3"]
    - [fd_doc_has_contents,     hashlib.file_digest.__doc__.__contains__, ["contents"],     true, "hashlib.file_digest.__doc__ contains 'contents'; hashes the contents of a file-like object; verified with Python 3.14.3"]
    - [fd_doc_has_constructor,  hashlib.file_digest.__doc__.__contains__, ["constructor"],  true, "hashlib.file_digest.__doc__ contains 'constructor'; digest arg may be a hash constructor; verified with Python 3.14.3"]
    - [md5_doc_has_string,      hashlib.md5.__doc__.__contains__,         ["string"],       true, "hashlib.md5.__doc__ contains 'string'; doc reads 'optionally initialized with a string'; verified with Python 3.14.3"]
    - [md5_doc_has_Returns,     hashlib.md5.__doc__.__contains__,         ["Returns"],      true, "hashlib.md5.__doc__ contains 'Returns'; doc reads 'Returns a md5 hash object'; verified with Python 3.14.3"]
    - [md5_doc_has_optionally,  hashlib.md5.__doc__.__contains__,         ["optionally"],   true, "hashlib.md5.__doc__ contains 'optionally'; optional initialization with a string; verified with Python 3.14.3"]
    - [sha256_doc_has_string,   hashlib.sha256.__doc__.__contains__,      ["string"],       true, "hashlib.sha256.__doc__ contains 'string'; doc reads 'optionally initialized with a string'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — hashlib_extra216
# ---------------------------------------------------------------------------

invariant hashlib_extra216.new_doc_contains_hashing:
  description: "hashlib.new.__doc__.__contains__('hashing') returns True — hashlib.new's docstring reads 'new(name, data=b'') - Return a new hashing object using the named algorithm; optionally initialized with data (which must be a bytes-like object)'; the word 'hashing' appears in 'hashing object', describing the type of object returned; this distinguishes hashlib.new from, say, hashlib.Hashing or a general factory; the '-ing' form emphasizes the ongoing computation nature of the object; compare: hashlib.md5.__doc__ uses 'hash' (noun) in 'hash object' rather than 'hashing'; NEW in hashlib_extra216: first standalone new.__doc__.__contains__('hashing') invariant in hashlibdoc216 namespace; wave 216; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.new.__doc__.__contains__
  args: ["hashing"]
  expected: true

invariant hashlib_extra216.new_doc_contains_bytes_like:
  description: "hashlib.new.__doc__.__contains__('bytes-like') returns True — hashlib.new's docstring reads 'optionally initialized with data (which must be a bytes-like object)'; the hyphenated term 'bytes-like' refers to Python's bytes-like object protocol (objects supporting the buffer protocol: bytes, bytearray, memoryview); this is the precise technical term used in CPython docs to describe acceptable data inputs; __contains__ matches the hyphenated string exactly; NEW in hashlib_extra216: first standalone new.__doc__.__contains__('bytes-like') invariant; wave 216; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.new.__doc__.__contains__
  args: ["bytes-like"]
  expected: true

invariant hashlib_extra216.pbkdf2_doc_contains_derivation:
  description: "hashlib.pbkdf2_hmac.__doc__.__contains__('derivation') returns True — hashlib.pbkdf2_hmac's docstring reads 'Password based key derivation function 2 (PKCS #5 v2.0) with HMAC as pseudorandom function'; the word 'derivation' appears as part of 'key derivation function', the technical classification of PBKDF2; a key derivation function (KDF) transforms a password and salt into a cryptographic key; PBKDF2 specifically uses iterated HMAC to slow down brute-force attacks; the presence of 'derivation' in the doc accurately classifies the algorithm category; NEW in hashlib_extra216: first standalone pbkdf2_hmac.__doc__.__contains__('derivation') invariant; wave 216; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.pbkdf2_hmac.__doc__.__contains__
  args: ["derivation"]
  expected: true

invariant hashlib_extra216.file_digest_doc_contains_fileobj:
  description: "hashlib.file_digest.__doc__.__contains__('fileobj') returns True — hashlib.file_digest's docstring reads '*fileobj* must be a file-like object opened for reading in binary mode'; 'fileobj' is the parameter name for the first argument to file_digest; the reST markup *fileobj* appears in the docstring indicating the parameter name in bold; this parameter accepts objects from open(), io.BytesIO(), and SocketIO; file_digest reads from the fileobj and computes the hash; __contains__ matches 'fileobj' as a substring of '*fileobj*' because __contains__ searches for any occurrence regardless of surrounding characters; NEW in hashlib_extra216: first standalone file_digest.__doc__.__contains__('fileobj') invariant; wave 216; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.file_digest.__doc__.__contains__
  args: ["fileobj"]
  expected: true
