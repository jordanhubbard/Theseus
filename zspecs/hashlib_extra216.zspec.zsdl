spec: hashlib_extra216
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "All __doc__ contains checks verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.new.__doc__ contains 'hashing', 'object', 'named', 'initialized', 'bytes-like'."
    - "hashlib.pbkdf2_hmac.__doc__ contains 'derivation', 'pseudorandom', 'function', 'based', 'PKCS'."
    - "hashlib.file_digest.__doc__ contains 'fileobj', 'binary', 'contents', 'reading', 'descriptor', 'constructor'."
    - "hashlib.md5.__doc__ and hashlib.sha256.__doc__ contain 'string', 'Returns', 'optionally', 'object', 'initialized'."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new — __doc__ contains checks (different words from wave 379)
#
# hashlib.new.__doc__ contains 'hashing', 'object', 'named', 'initialized'
# ---------------------------------------------------------------------------

table hashlib_extra216.new_doc_contains_extra:
  description: "hashlib.new __doc__ contains checks in hashlibdoc216 namespace — wave 216 theme: hashlib.new.__doc__.__contains__('hashing')==True; hashlib.new.__doc__.__contains__('object')==True; hashlib.new.__doc__.__contains__('named')==True; hashlib.new.__doc__.__contains__('initialized')==True; doc reads 'Return a new hashing object using the named algorithm; optionally initialized with data'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibdoc216

  columns: [id, function, args, expected, description]
  rows:
    - [new_doc_has_hashing,     hashlib.new.__doc__.__contains__, ["hashing"],     true, "hashlib.new.__doc__ contains 'hashing'; doc reads 'Return a new hashing object'; verified with Python 3.14.3"]
    - [new_doc_has_object,      hashlib.new.__doc__.__contains__, ["object"],      true, "hashlib.new.__doc__ contains 'object'; factory returns a hashing object; verified with Python 3.14.3"]
    - [new_doc_has_named,       hashlib.new.__doc__.__contains__, ["named"],       true, "hashlib.new.__doc__ contains 'named'; references 'using the named algorithm'; verified with Python 3.14.3"]
    - [new_doc_has_initialized, hashlib.new.__doc__.__contains__, ["initialized"], true, "hashlib.new.__doc__ contains 'initialized'; doc reads 'optionally initialized with data'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
