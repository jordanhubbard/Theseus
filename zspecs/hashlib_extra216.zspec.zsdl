table hashlib_extra216.pbkdf2_doc_contains_extra:
  description: "hashlib.pbkdf2_hmac __doc__ contains checks in hashlibdoc216a namespace — wave 216 theme: hashlib.pbkdf2_hmac.__doc__.__contains__('derivation')==True; hashlib.pbkdf2_hmac.__doc__.__contains__('pseudorandom')==True; hashlib.pbkdf2_hmac.__doc__.__contains__('function')==True; hashlib.pbkdf2_hmac.__doc__.__contains__('PKCS')==True; doc reads 'Password based key derivation function 2 (PKCS #5 v2.0) with HMAC as pseudorandom function'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibdoc216a

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_doc_has_derivation,   hashlib.pbkdf2_hmac.__doc__.__contains__, ["derivation"],   true, "hashlib.pbkdf2_hmac.__doc__ contains 'derivation'; PBKDF2 is a key derivation function; verified with Python 3.14.3"]
    - [pbkdf2_doc_has_pseudorandom, hashlib.pbkdf2_hmac.__doc__.__contains__, ["pseudorandom"], true, "hashlib.pbkdf2_hmac.__doc__ contains 'pseudorandom'; HMAC used as pseudorandom function; verified with Python 3.14.3"]
    - [pbkdf2_doc_has_function,     hashlib.pbkdf2_hmac.__doc__.__contains__, ["function"],     true, "hashlib.pbkdf2_hmac.__doc__ contains 'function'; references function in PKCS #5 context; verified with Python 3.14.3"]
    - [pbkdf2_doc_has_PKCS,         hashlib.pbkdf2_hmac.__doc__.__contains__, ["PKCS"],         true, "hashlib.pbkdf2_hmac.__doc__ contains 'PKCS'; references PKCS #5 v2.0 standard; verified with Python 3.14.3"]

