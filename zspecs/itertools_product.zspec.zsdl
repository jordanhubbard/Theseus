spec: itertools_product
version: ">=3.0"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html#itertools.product

provenance:
  derived_from:
    - "Python itertools documentation — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "product([1,2],[3,4]) yields (1,3),(1,4),(2,3),(2,4) — Cartesian product in lexicographic order."
    - "product('AB', repeat=2) yields ('A','A'),('A','B'),('B','A'),('B','B')."
    - "combinations([1,2,3], 2) yields (1,2),(1,3),(2,3) — r-length subsequences, no repeated elements."
    - "combinations_with_replacement([1,2], 2) yields (1,1),(1,2),(2,2) — allows repeated elements."
    - "permutations([1,2,3], 2) yields (1,2),(1,3),(2,1),(2,3),(3,1),(3,2) — ordered arrangements."
    - "permutations([1,2,3]) with no r arg yields all 3! = 6 full-length permutations."
    - "All these classes are C-level types in CPython; __name__ is verified via NAME.__name__.__eq__(NAME)."
    - "First-element tests call iterator.__next__() to retrieve the first tuple yielded."
    - "The harness normalises tuples to lists when expected is a list."
    - "All expected values verified by running Python 3.14 on macOS Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name verification
# ---------------------------------------------------------------------------

invariant itertools_product.classnames.product:
  description: "itertools.product.__name__ == 'product'"
  category: classnames
  kind: python_call_eq
  function: product.__name__.__eq__
  args: ["product"]
  expected: true

invariant itertools_product.classnames.combinations:
  description: "itertools.combinations.__name__ == 'combinations'"
  category: classnames
  kind: python_call_eq
  function: combinations.__name__.__eq__
  args: ["combinations"]
  expected: true

invariant itertools_product.classnames.combinations_with_replacement:
  description: "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement'"
  category: classnames
  kind: python_call_eq
  function: combinations_with_replacement.__name__.__eq__
  args: ["combinations_with_replacement"]
  expected: true

invariant itertools_product.classnames.permutations:
  description: "itertools.permutations.__name__ == 'permutations'"
  category: classnames
  kind: python_call_eq
  function: permutations.__name__.__eq__
  args: ["permutations"]
  expected: true

# ---------------------------------------------------------------------------
# product — first element of Cartesian products
# ---------------------------------------------------------------------------

invariant itertools_product.product.first_pair:
  description: "product([1,2],[3,4]).__next__() == (1,3) — first pair; tuple normalised to list"
  category: product
  kind: python_call_eq
  function: product
  args: [[1, 2], [3, 4]]
  method: __next__
  expected: [1, 3]

invariant itertools_product.product.single_list_first:
  description: "product([10,20,30]).__next__() == (10,) — single-iterable product; normalised to [10]"
  category: product
  kind: python_call_eq
  function: product
  args: [[10, 20, 30]]
  method: __next__
  expected: [10]

# ---------------------------------------------------------------------------
# combinations — first r-length combination
# ---------------------------------------------------------------------------

invariant itertools_product.combinations.r2_first:
  description: "combinations([1,2,3], 2).__next__() == (1,2) — first pair; normalised to list"
  category: combinations
  kind: python_call_eq
  function: combinations
  args: [[1, 2, 3], 2]
  method: __next__
  expected: [1, 2]

invariant itertools_product.combinations.r1_first:
  description: "combinations([5,6,7], 1).__next__() == (5,) — first singleton; normalised to [5]"
  category: combinations
  kind: python_call_eq
  function: combinations
  args: [[5, 6, 7], 1]
  method: __next__
  expected: [5]

# ---------------------------------------------------------------------------
# combinations_with_replacement — allows repeated elements
# ---------------------------------------------------------------------------

invariant itertools_product.combinations_with_replacement.r2_first:
  description: "combinations_with_replacement([1,2], 2).__next__() == (1,1) — repeated element; normalised to [1,1]"
  category: combinations_with_replacement
  kind: python_call_eq
  function: combinations_with_replacement
  args: [[1, 2], 2]
  method: __next__
  expected: [1, 1]

# ---------------------------------------------------------------------------
# permutations — ordered arrangements
# ---------------------------------------------------------------------------

invariant itertools_product.permutations.r2_first:
  description: "permutations([1,2,3], 2).__next__() == (1,2) — first 2-permutation; normalised to list"
  category: permutations
  kind: python_call_eq
  function: permutations
  args: [[1, 2, 3], 2]
  method: __next__
  expected: [1, 2]

invariant itertools_product.permutations.full_first:
  description: "permutations([1,2,3]).__next__() == (1,2,3) — first full-length permutation; normalised to list"
  category: permutations
  kind: python_call_eq
  function: permutations
  args: [[1, 2, 3]]
  method: __next__
  expected: [1, 2, 3]

invariant itertools_product.permutations.r1_first:
  description: "permutations([7,8,9], 1).__next__() == (7,) — first 1-permutation; normalised to [7]"
  category: permutations
  kind: python_call_eq
  function: permutations
  args: [[7, 8, 9], 1]
  method: __next__
  expected: [7]

