spec: select_extra
version: ">=3.2"
backend: python_module(select)

docs: https://docs.python.org/3/library/select.html

provenance:
  derived_from:
    - "Python select documentation — https://docs.python.org/3/library/select.html"
    - "Test vectors verified by running Python 3.14.3 select module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/selectmodule.c"
  notes:
    - "This spec covers aspects of the select module not in select.zspec.zsdl."
    - "select.error is an alias for OSError; its __name__ is 'error' (not 'OSError')."
    - "select.error.__bases__[0].__name__ == 'OSError' — the first base class of error is OSError."
    - "select.select is a built-in function implemented in C; its __module__ is 'select'."
    - "The select module is not available on Windows; all tests target POSIX (macOS/Linux)."
    - "All expected values verified by running Python 3.14.3 select module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# select.error — name and base class
#
# select.error is an alias for OSError; __name__ is 'error' (the alias name),
# and its first base class is OSError.
# ---------------------------------------------------------------------------

invariant select_extra.error.name:
  description: "select.error.__name__ == 'error' — select.error is an alias; its __name__ is 'error'"
  category: exceptions
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant select_extra.error.base_class:
  description: "select.error.__bases__[0].__name__ == 'OSError' — select.error inherits from OSError"
  category: exceptions
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# select.select — function name and module
#
# select.select is the core cross-platform I/O multiplexing function.
# Its __name__ is 'select' and its __module__ is 'select'.
# ---------------------------------------------------------------------------

invariant select_extra.select.name:
  description: "select.select.__name__ == 'select'"
  category: functions
  kind: python_call_eq
  function: select.__name__.__eq__
  args: ["select"]
  expected: true

invariant select_extra.select.module:
  description: "select.select.__module__ == 'select'"
  category: functions
  kind: python_call_eq
  function: select.__module__.__eq__
  args: ["select"]
  expected: true
