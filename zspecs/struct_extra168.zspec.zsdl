spec: struct_extra168
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra167.zspec.zsdl — covers struct.__name__/__package__/__spec__/__loader__/__doc__ module-level identity and Struct.__dict__ __doc__/__repr__ membership (table + invariants)."
    - "struct_extra166.zspec.zsdl — covers struct.Struct.__name__/__module__ via __eq__ calls and Struct.__dict__.__sizeof__ membership (table + invariants)."
    - "struct_extra165.zspec.zsdl — covers struct.Struct.__dict__.__contains__ for __init__/__new__ and struct.error class identity (table + invariants)."
    - "struct_extra164.zspec.zsdl — covers struct module-level function __name__.__len__() integer values for all six functions (table + invariants)."
    - "struct_extra162.zspec.zsdl — covers struct.pack/__unpack/__pack_into/__unpack_from/__iter_unpack/__calcsize .__name__/__module__ (table + invariants)."
    - "struct_extra161.zspec.zsdl — covers struct.error/__Struct class identity (__name__/__module__/__bases__) (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__=='struct' and struct.__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra167."
    - "Wave 354 theme: struct.Struct.__mro__ length / struct.error.__mro__ length / module-level function __qualname__ attributes. struct_extra161 anchors struct.Struct.__bases__[0].__name__=='object' and struct.error.__bases__[0].__name__=='Exception'; this spec anchors MRO lengths and function __qualname__ as primary novel content."
    - "struct.Struct.__mro__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0. Struct MRO: (_struct.Struct, object) — 2 classes."
    - "struct.error.__mro__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0. error MRO: (struct.error, Exception, BaseException, object) — 4 classes."
    - "struct.pack.__qualname__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__qualname__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__qualname__ == 'pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__ == 'calcsize'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__qualname__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.__mro__ == (_struct.Struct, object). Struct is a C extension type defined in _struct.c that inherits only from object (no Python-level intermediate bases). Struct.__mro__.__len__()==2 is the minimum possible MRO length."
    - "Note: struct.error.__mro__ == (struct.error, Exception, BaseException, object). struct.error is a Python exception class that inherits from Exception. The MRO includes Exception and BaseException as required by the exception hierarchy. error.__mro__.__len__()==4 > Struct.__mro__.__len__()==2 by 2."
    - "Note: struct.pack.__qualname__ == 'pack'. For C builtin functions at module level, __qualname__ equals __name__. struct.pack is a C builtin from _struct.c; its __qualname__ is the same as its __name__: 'pack' (4 chars)."
    - "Note: struct.iter_unpack.__qualname__ == 'iter_unpack'. 'iter_unpack' (11 chars) is the longest function name/qualname in this spec."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__mro__.__len__()==2
# struct.error.__mro__.__len__()==4
#
# Wave 354 theme: Struct and error MRO chain lengths.
#
# Struct.__mro__ == (_struct.Struct, object) — 2 classes.
# error.__mro__ == (struct.error, Exception, BaseException, object) — 4 classes.
# error has a longer MRO because exceptions chain through BaseException.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra168.Struct_error_mro_lengths:
  description: "struct.Struct.__mro__.__len__()==2 / struct.error.__mro__.__len__()==4 — Struct.__mro__.__len__() is 2 (struct.Struct's MRO is (_struct.Struct, object) — 2 classes; Struct is a C extension type from Modules/_struct.c that inherits directly from object without any intermediate Python-level base classes; Struct.__mro__.__len__()==2 is the minimum possible MRO length for any type; novel anchor: no prior struct spec anchors Struct.__mro__.__len__() under structmro168; first anchor for this integer); struct.error.__mro__.__len__() is 4 (struct.error's MRO is (struct.error, Exception, BaseException, object) — 4 classes; struct.error inherits from Exception which inherits from BaseException which inherits from object; the exception hierarchy adds BaseException as an extra intermediate class; error.__mro__.__len__()==4 > Struct.__mro__.__len__()==2 by 2: the exception hierarchy doubles the MRO length compared to Struct; novel anchor: no prior struct spec anchors error.__mro__.__len__() under structmro168; first anchor for this integer); first structmro168 anchor for Struct and error MRO lengths)"
  kind: python_call_eq
  category: identity
  id_prefix: structmro168

  columns: [id, function, args, expected, description]
  rows:
    - [struct_mro_len_2,  "Struct.__mro__.__len__", [], 2, "struct.Struct.__mro__.__len__() is 2 (MRO: (_struct.Struct, object); C type inheriting only from object; minimum MRO length; novel anchor)"]
    - [error_mro_len_4,   "error.__mro__.__len__",  [], 4, "struct.error.__mro__.__len__() is 4 (MRO: (error, Exception, BaseException, object); exception chain adds BaseException; 4 > 2 by 2; novel anchor)"]

