  description: "struct.pack.__qualname__.__eq__('pack')==True / struct.unpack.__qualname__.__eq__('unpack')==True / struct.pack.__qualname__.__len__()==4 / struct.unpack.__qualname__.__len__()==6 — pack.__qualname__ is 'pack' (4 chars; for C builtin functions at module level, __qualname__ equals __name__; struct.pack is a C builtin from _struct.c that packs values into bytes according to a format string; 'pack'(4 chars) = 4 letters; struct_extra162 anchors pack.__name__=='pack' and pack.__module__=='_struct'; this spec anchors pack.__qualname__ as novel content under structmro168); unpack.__qualname__ is 'unpack' (6 chars; struct.unpack is a C builtin from _struct.c that unpacks bytes into a tuple of values; 'unpack'(6 chars) = 'un'=2 + 'pack'=4; unpack.__qualname__.__len__()==6 == struct.Struct.__name__.__len__()==6 — coincidental: unpack name length equals Struct class name length; struct_extra162 anchors unpack.__name__=='unpack'; this spec anchors unpack.__qualname__ as novel content); pack.__qualname__.__len__() is 4 ('pack' = 4 chars; __qualname__==__name__ so same 4-char length; struct_extra164 anchors pack.__name__.__len__()==4); unpack.__qualname__.__len__() is 6 ('unpack' = 6 chars; struct_extra164 anchors unpack.__name__.__len__()==6; 'unpack'(6) > 'pack'(4) by 2 chars — the 'un' prefix adds 2 chars; first structmro168 anchor for pack/unpack qualname)"
  kind: python_call_eq
  category: identity
  id_prefix: structmro168

  columns: [id, function, args, expected, description]
  rows:
    - [pack_qn_eq,        "pack.__qualname__.__eq__",    ["pack"],   true, "struct.pack.__qualname__ == 'pack' (4 chars; C builtin: __qualname__==__name__; struct_extra162 anchors __name__; first __qualname__ anchor)"]
    - [unpack_qn_eq,      "unpack.__qualname__.__eq__",  ["unpack"], true, "struct.unpack.__qualname__ == 'unpack' (6 chars; C builtin: __qualname__==__name__; struct_extra162 anchors __name__; first __qualname__ anchor)"]
    - [pack_qn_len_4,     "pack.__qualname__.__len__",   [],         4,    "struct.pack.__qualname__.__len__() is 4 ('pack'=4; __qualname__==__name__; struct_extra164 anchors __name__.__len__()==4)"]
    - [unpack_qn_len_6,   "unpack.__qualname__.__len__", [],         6,    "struct.unpack.__qualname__.__len__() is 6 ('unpack'=6; 'unpack'(6)>'pack'(4) by 2 — 'un' prefix; struct_extra164 anchors __name__.__len__()==6)"]

