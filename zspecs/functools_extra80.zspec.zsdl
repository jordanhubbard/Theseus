spec: functools_extra80
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec extends functools_extra79.zspec.zsdl."
    - "This spec covers: functools cached_property class identity (Wave 241)."
    - "cached_property.__name__ == 'cached_property' — cached_property is a pure-Python class defined in Lib/functools.py. Verified with Python 3.14.3."
    - "cached_property.__module__ == 'functools' — cached_property is defined in the functools module. Verified with Python 3.14.3."
    - "cached_property.__qualname__ == 'cached_property' — cached_property is a top-level class; its __qualname__ equals its simple name. Verified with Python 3.14.3."
    - "cached_property.__bases__[0].__name__ == 'object' — cached_property inherits directly from object. Verified with Python 3.14.3."
    - "cached_property.__mro__.__len__() == 2 — MRO is [cached_property, object]. Verified with Python 3.14.3."
    - "cached_property.__class__.__name__ == 'type' — cached_property is a class; its metaclass is type. Verified with Python 3.14.3."
    - "cached_property.__doc__.__class__.__name__ == 'NoneType' — cached_property.__doc__ is None in Python 3.14.3; the class has no docstring. Verified with Python 3.14.3."
    - "cached_property.__dict__.__class__.__name__ == 'mappingproxy' — the class namespace is a mappingproxy. Verified with Python 3.14.3."
    - "cached_property.__dict__.__contains__('__get__') == True — cached_property implements the descriptor protocol. Verified with Python 3.14.3."
    - "cached_property.__dict__.__contains__('__init__') == True — cached_property defines __init__. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# cached_property name/module/qualname identity — extra80
#
# Wave 241 theme: functools cached_property class identity.
#
# functools.cached_property.__name__    == 'cached_property'
# functools.cached_property.__module__  == 'functools'
# functools.cached_property.__qualname__ == 'cached_property'
#
# No prior functools spec checks cached_property name/module/qualname via functoolsmore80. New to extra80.
# ---------------------------------------------------------------------------

table functools_extra80.cached_property_name_module_qualname:
  description: "cached_property.__name__=='cached_property', __module__=='functools', __qualname__=='cached_property'; wave 241 cached_property identity; new to extra80"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore80

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_name_eq_cached_property,
       cached_property.__name__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__name__.__eq__('cached_property') == True — cached_property is a pure-Python class defined in Lib/functools.py that transforms a method into a cached property; its __name__ attribute stores the class name as a str 'cached_property' (15 chars); str.__eq__('cached_property') returns True; no prior functools spec checks cached_property.__name__ via functoolsmore80; new to extra80"]
    - [cached_property_module_eq_functools,
       cached_property.__module__.__eq__,
       ["functools"],
       true,
       "functools.cached_property.__module__.__eq__('functools') == True — cached_property is defined in Lib/functools.py and its __module__ attribute records the module name as the str 'functools' (9 chars); str.__eq__('functools') returns True; no prior functools spec checks cached_property.__module__ via functoolsmore80; new to extra80"]
    - [cached_property_qualname_eq_cached_property,
       cached_property.__qualname__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__qualname__.__eq__('cached_property') == True — cached_property is a top-level class (not nested inside another class or function); __qualname__ for a top-level class equals its simple name 'cached_property' (15 chars); str.__eq__('cached_property') returns True; no prior functools spec checks cached_property.__qualname__ via functoolsmore80; new to extra80"]

# ---------------------------------------------------------------------------
# cached_property base class and MRO — extra80
#
# Wave 241 theme: cached_property inheritance.
#
# functools.cached_property.__bases__[0].__name__ == 'object'
# functools.cached_property.__mro__.__len__()     == 2
#
# No prior functools spec checks cached_property __bases__/__mro__ via functoolsmore80. New to extra80.
# ---------------------------------------------------------------------------

table functools_extra80.cached_property_bases_mro:
  description: "cached_property.__bases__[0].__name__=='object', __mro__.__len__()==2; wave 241 cached_property inheritance; new to extra80"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore80

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_bases0_name_eq_object,
       "cached_property.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — cached_property inherits directly from object with no intermediate base classes; __bases__[0] is object and object.__name__ == 'object' (6 chars); str.__eq__('object') returns True; no prior functools spec checks cached_property.__bases__[0].__name__ via functoolsmore80; new to extra80"]
    - [cached_property_mro_len_eq_2,
       cached_property.__mro__.__len__,
       [],
       2,
       "functools.cached_property.__mro__.__len__() == 2 — cached_property inherits directly from object; its MRO is [cached_property, object] with exactly 2 entries; tuple.__len__() returns 2; no prior functools spec checks cached_property.__mro__.__len__ via functoolsmore80; new to extra80"]

# ---------------------------------------------------------------------------
# cached_property metaclass and doc class — extra80
#
# Wave 241 theme: cached_property metaclass is type; doc is None.
#
# functools.cached_property.__class__.__name__         == 'type'
# functools.cached_property.__doc__.__class__.__name__ == 'NoneType'
#
# No prior functools spec checks cached_property __class__/__doc__ via functoolsmore80. New to extra80.
# ---------------------------------------------------------------------------

table functools_extra80.cached_property_class_and_doc:
  description: "cached_property.__class__.__name__=='type', __doc__.__class__.__name__=='NoneType'; wave 241 cached_property metaclass and doc; new to extra80"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore80

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_class_name_eq_type,
       cached_property.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.cached_property.__class__.__name__.__eq__('type') == True — cached_property is a class; its metaclass is the built-in type; __class__.__name__ == 'type' (4 chars); str.__eq__('type') returns True; no prior functools spec checks cached_property.__class__.__name__ via functoolsmore80; new to extra80"]
    - [cached_property_doc_class_name_eq_NoneType,
       cached_property.__doc__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "functools.cached_property.__doc__.__class__.__name__.__eq__('NoneType') == True — cached_property.__doc__ is None in Python 3.14.3 (the class carries no docstring); None.__class__.__name__ == 'NoneType' (8 chars); str.__eq__('NoneType') returns True; no prior functools spec checks cached_property.__doc__.__class__.__name__ via functoolsmore80; new to extra80"]

# ---------------------------------------------------------------------------
# cached_property __dict__ class and descriptor protocol — extra80
#
# Wave 241 theme: cached_property __dict__ is a mappingproxy; descriptor protocol.
#
# functools.cached_property.__dict__.__class__.__name__  == 'mappingproxy'
# functools.cached_property.__dict__.__contains__('__get__')  == True
# functools.cached_property.__dict__.__contains__('__init__') == True
#
# No prior functools spec checks cached_property __dict__ attrs via functoolsmore80. New to extra80.
# ---------------------------------------------------------------------------

table functools_extra80.cached_property_dict_attrs:
  description: "cached_property.__dict__.__class__.__name__=='mappingproxy', __contains__('__get__')==True, __contains__('__init__')==True; wave 241 cached_property descriptor; new to extra80"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore80

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_dict_class_name_eq_mappingproxy,
       cached_property.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "functools.cached_property.__dict__.__class__.__name__.__eq__('mappingproxy') == True — the class namespace of cached_property is exposed as a mappingproxy (read-only dict view); __dict__.__class__.__name__ == 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior functools spec checks cached_property.__dict__.__class__.__name__ via functoolsmore80; new to extra80"]
    - [cached_property_dict_contains_get,
       cached_property.__dict__.__contains__,
       ["__get__"],
       true,
       "functools.cached_property.__dict__.__contains__('__get__') == True — cached_property implements the descriptor protocol by defining __get__ in its class body; mappingproxy.__contains__('__get__') returns True; no prior functools spec checks cached_property.__dict__.__contains__('__get__') via functoolsmore80; new to extra80"]
    - [cached_property_dict_contains_init,
       cached_property.__dict__.__contains__,
       ["__init__"],
       true,
       "functools.cached_property.__dict__.__contains__('__init__') == True — cached_property defines __init__(self, func) in its class body to store the wrapped function; mappingproxy.__contains__('__init__') returns True; no prior functools spec checks cached_property.__dict__.__contains__('__init__') via functoolsmore80; new to extra80"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra80
# ---------------------------------------------------------------------------

invariant functools_extra80.cached_property_name:
  description: "functools.cached_property.__name__.__eq__('cached_property') == True — cached_property class name is 'cached_property'; wave 241 cached_property identity; new to extra80"
  kind: python_call_eq
  function: cached_property.__name__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra80.cached_property_module:
  description: "functools.cached_property.__module__.__eq__('functools') == True — cached_property.__module__ is 'functools'; wave 241 cached_property identity; new to extra80"
  kind: python_call_eq
  function: cached_property.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra80.cached_property_mro_len:
  description: "functools.cached_property.__mro__.__len__() == 2 — cached_property MRO has 2 entries [cached_property, object]; wave 241 cached_property inheritance; new to extra80"
  kind: python_call_eq
  function: cached_property.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra80.cached_property_dict_contains_get:
  description: "functools.cached_property.__dict__.__contains__('__get__') == True — cached_property implements __get__ (descriptor protocol); wave 241 cached_property descriptor; new to extra80"
  kind: python_call_eq
  function: cached_property.__dict__.__contains__
  args: ["__get__"]
  expected: true

invariant functools_extra80.cached_property_dict_contains_init:
  description: "functools.cached_property.__dict__.__contains__('__init__') == True — cached_property defines __init__; wave 241 cached_property descriptor; new to extra80"
  kind: python_call_eq
  function: cached_property.__dict__.__contains__
  args: ["__init__"]
  expected: true
