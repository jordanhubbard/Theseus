spec: io_extra2026
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 582 (_extra2026): __truediv__, __rtruediv__, __itruediv__, __floordiv__, __rfloordiv__, __ifloordiv__, __mod__, __rmod__, __imod__, __pow__, __rpow__, __divmod__, __rdivmod__ dict-presence checks."
    - "io.IOBase, io.BytesIO, io.StringIO, io.FileIO, io.RawIOBase are I/O classes; none defines division, modulo, exponentiation, or divmod operators."
    - "All five io classes are C types (from the _io extension); arithmetic operators are absent from their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __truediv__ / __rtruediv__ / __itruediv__ — true division dict-presence
# ---------------------------------------------------------------------------

table io_extra2026.truediv_protocol:
  description: "io types __truediv__/__rtruediv__/__itruediv__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2026

  columns: [id, function, args, expected]
  rows:
    - ["io2026001", "io.IOBase.__dict__.__contains__",    ["__truediv__"],  false]
    - ["io2026002", "io.IOBase.__dict__.__contains__",    ["__rtruediv__"], false]
