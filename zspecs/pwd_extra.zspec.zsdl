spec: pwd_extra
version: ">=3.9"
backend: python_module(pwd)

docs: https://docs.python.org/3/library/pwd.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pwd.html — Python pwd module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/pwdmodule.c"
  notes:
    - "Extends pwd.zspec.zsdl with __match_args__, __module__, and additional struct_passwd invariants."
    - "pwd is a POSIX-only module; not available on Windows."
    - "pwd.getpwuid, pwd.getpwnam, pwd.getpwall are C-level builtin_function_or_method objects."
    - "pwd.struct_passwd.__name__ == 'struct_passwd' and __module__ == 'pwd'."
    - "pwd.struct_passwd.__match_args__ is a tuple of 7 field name strings."
    - "The seven __match_args__ fields in order: pw_name, pw_passwd, pw_uid, pw_gid, pw_gecos, pw_dir, pw_shell."
    - "pwd.struct_passwd.__match_args__.__len__() == 7."
    - "All expected values verified by running Python 3.12 pwd module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ attributes
# ---------------------------------------------------------------------------

table pwd_extra.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [getpwuid, getpwuid.__name__.__eq__, ["getpwuid"], true]
    - [getpwnam, getpwnam.__name__.__eq__, ["getpwnam"], true]
    - [getpwall, getpwall.__name__.__eq__, ["getpwall"], true]

# ---------------------------------------------------------------------------
# struct_passwd — class name and module affiliation
# ---------------------------------------------------------------------------

invariant pwd_extra.struct_passwd.class_name:
  description: "pwd.struct_passwd.__name__ == 'struct_passwd'"
  category: class_names
  kind: python_call_eq
  function: struct_passwd.__name__.__eq__
  args: ["struct_passwd"]
  expected: true

invariant pwd_extra.struct_passwd.module:
  description: "pwd.struct_passwd.__module__ == 'pwd'"
  category: class_modules
  kind: python_call_eq
  function: struct_passwd.__module__.__eq__
  args: ["pwd"]
  expected: true

# ---------------------------------------------------------------------------
# struct_passwd.__match_args__ — presence, type, and length
#
# Python 3.10+ struct-sequence types expose __match_args__ for structural
# pattern matching. For struct_passwd this is a tuple of 7 field names.
# ---------------------------------------------------------------------------

invariant pwd_extra.struct_passwd.match_args_is_tuple:
  description: "pwd.struct_passwd.__match_args__.__class__.__name__ == 'tuple'"
  category: match_args
  kind: python_call_eq
  function: struct_passwd.__match_args__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant pwd_extra.struct_passwd.match_args_len:
  description: "len(pwd.struct_passwd.__match_args__) == 7 — seven pattern-match fields"
  category: match_args
  kind: python_call_eq
  function: struct_passwd.__match_args__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# struct_passwd.__match_args__ — individual field names by index
# ---------------------------------------------------------------------------

invariant pwd_extra.struct_passwd.match_args_0:
  description: "pwd.struct_passwd.__match_args__[0] == 'pw_name'"
  category: match_args
  kind: python_call_eq
  function: struct_passwd.__match_args__.__getitem__
  args: [0]
  expected: "pw_name"

invariant pwd_extra.struct_passwd.match_args_1:
  description: "pwd.struct_passwd.__match_args__[1] == 'pw_passwd'"
  category: match_args
  kind: python_call_eq
  function: struct_passwd.__match_args__.__getitem__
  args: [1]
  expected: "pw_passwd"

invariant pwd_extra.struct_passwd.match_args_2:
  description: "pwd.struct_passwd.__match_args__[2] == 'pw_uid'"
  category: match_args
  kind: python_call_eq
  function: struct_passwd.__match_args__.__getitem__
  args: [2]
  expected: "pw_uid"

invariant pwd_extra.struct_passwd.match_args_3:
  description: "pwd.struct_passwd.__match_args__[3] == 'pw_gid'"
  category: match_args
  kind: python_call_eq
  function: struct_passwd.__match_args__.__getitem__
  args: [3]
  expected: "pw_gid"

invariant pwd_extra.struct_passwd.match_args_4:
  description: "pwd.struct_passwd.__match_args__[4] == 'pw_gecos'"
  category: match_args
  kind: python_call_eq
  function: struct_passwd.__match_args__.__getitem__
  args: [4]
  expected: "pw_gecos"

invariant pwd_extra.struct_passwd.match_args_5:
  description: "pwd.struct_passwd.__match_args__[5] == 'pw_dir'"
  category: match_args
  kind: python_call_eq
  function: struct_passwd.__match_args__.__getitem__
  args: [5]
  expected: "pw_dir"

invariant pwd_extra.struct_passwd.match_args_6:
  description: "pwd.struct_passwd.__match_args__[6] == 'pw_shell'"
  category: match_args
  kind: python_call_eq
  function: struct_passwd.__match_args__.__getitem__
  args: [6]
  expected: "pw_shell"
