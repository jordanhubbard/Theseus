spec: functools_extra435
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module identity and metadata"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.reduce may report __module__ as '_functools' (C extension) or 'functools' depending on implementation"
    - "functools.partial is a C-implemented type; its __bases__ chain leads to object"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra435.function_names:
  description: "functools public functions and classes report correct __name__"
  kind: python_call_eq
  category: identity
  id_prefix: fn

  columns: [id, function, args, expected]
  rows:
    - [fn001, functools.reduce.__name__.__eq__, ["reduce"], true]
    - [fn002, functools.lru_cache.__name__.__eq__, ["lru_cache"], true]
    - [fn003, functools.cache.__name__.__eq__, ["cache"], true]
    - [fn004, functools.partial.__name__.__eq__, ["partial"], true]

table functools_extra435.function_modules:
  description: "functools public functions and classes report correct __module__"
  kind: python_call_eq
  category: identity
  id_prefix: fm

  columns: [id, function, args, expected]
  rows:
    - [fm001, functools.lru_cache.__module__.__eq__, ["functools"], true]
    - [fm002, functools.cache.__module__.__eq__, ["functools"], true]
    - [fm003, functools.partial.__module__.__eq__, ["functools"], true]

table functools_extra435.doc_checks:
  description: "functools.reduce __doc__ is a string (not None)"
  kind: python_call_eq
  category: identity
  id_prefix: dc

  columns: [id, function, args, expected]
  rows:
    - [dc001, functools.reduce.__doc__.__class__.__name__.__eq__, ["str"], true]

invariant functools_extra435.reduce_name:
  description: "functools.reduce.__name__ is 'reduce'"
  category: identity
  kind: python_call_eq
  function: functools.reduce.__name__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra435.reduce_module_functools:
  description: "functools.reduce.__module__ is 'functools' or '_functools' (C extension)"
  category: identity
  kind: python_call_eq
  function: functools.reduce.__module__.__contains__
  args: ["functools"]
  expected: true

invariant functools_extra435.partial_bases_object:
  description: "functools.partial.__bases__[0].__name__ is 'object'"
  category: identity
  kind: python_call_eq
  function: "functools.partial.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
