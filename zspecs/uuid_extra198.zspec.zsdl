spec: uuid_extra198
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "This spec covers __code__ attributes of uuid module Python-level functions: uuid1, uuid3, uuid4, uuid5, UUID.__init__."
    - "uuid.uuid1.__code__.co_flags.__class__.__name__ == 'int' — co_flags is a plain Python int; verified with Python 3.14.3."
    - "uuid.uuid3.__code__.co_flags.__class__.__name__ == 'int' — co_flags is a plain Python int; verified with Python 3.14.3."
    - "uuid.uuid4.__code__.co_flags.__class__.__name__ == 'int' — co_flags is a plain Python int; verified with Python 3.14.3."
    - "uuid.uuid1.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is a plain Python int; verified with Python 3.14.3."
    - "uuid.UUID.__init__.__code__.co_flags.__class__.__name__ == 'int' — co_flags on UUID.__init__'s code is a plain Python int; verified with Python 3.14.3."
    - "uuid.uuid1.__code__.co_argcount == 2 — uuid1 takes 2 positional parameters (node, clock_seq); verified with Python 3.14.3."
    - "uuid.uuid4.__code__.co_argcount == 0 — uuid4 takes no positional parameters; verified with Python 3.14.3."
    - "uuid.UUID.__init__.__code__.co_argcount == 7 — UUID.__init__ takes 7 positional parameters; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

