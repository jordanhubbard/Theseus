spec: select_extra8
version: ">=3.9"
backend: python_module(select)

docs: https://docs.python.org/3/library/select.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/select.html — Python select module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/selectmodule.c"
  notes:
    - "Extends select.zspec.zsdl through select_extra7.zspec.zsdl."
    - "select.zspec covers: select.__name__; poll.__name__; kqueue.__name__; kevent.__name__; POLLIN/POLLOUT/POLLERR is_int; KQ_FILTER_READ/WRITE is_int; kqueue()/poll() instance class."
    - "select_extra covers: error.__name__=='error'/'OSError'; error base; select.__name__/__module__."
    - "select_extra2 covers: POLLIN==1; POLLOUT==4; KQ_FILTER_READ==-1; KQ_FILTER_WRITE==-2; KQ_EV_ADD/DELETE/ENABLE/DISABLE."
    - "select_extra3 covers: module __name__; poll/__module__; error.__module__; POLLERR==8; POLLHUP==16; POLLNVAL==32."
    - "select_extra4 covers: kqueue/kevent/__module__/__qualname__; select.__qualname__; KQ_FILTER_PROC==-5; KQ_FILTER_SIGNAL==-6; KQ_EV_ONESHOT/CLEAR/ERROR/EOF."
    - "select_extra5 covers: PIPE_BUF==512; POLLPRI/POLLRDNORM/POLLWRNORM/POLLRDBAND/POLLWRBAND; KQ_FILTER_AIO==-3/VNODE==-4/TIMER==-7; KQ_NOTE_DELETE/WRITE/EXTEND/ATTRIB/LINK/RENAME/REVOKE; KQ_NOTE_EXIT/FORK/EXEC."
    - "select_extra6 covers: error.__qualname__=='OSError'; poll.__qualname__=='poll'; POLLIN bitmask combinations; select.epoll AttributeError."
    - "select_extra7 covers: kqueue/kevent __bases__/__mro__ length; KQ_EV_* bitmask ORs; POLLHUP|POLLNVAL; POLLOUT|POLLERR; PIPE_BUF<<1; KQ_NOTE_DELETE|WRITE."
    - "This spec adds: KQ_NOTE_TRACK/TRACKERR/CHILD/LOWAT values and types (proc-filter notes not in any prior spec); KQ_NOTE_PCTRLMASK/PDATAMASK values and types (proc-filter mask constants not covered); KQ_EV_FLAG1/SYSFLAGS values and types (internal/system flags not in any prior spec)."
    - "KQ_NOTE_TRACK == 1: follow forked child (KQ_FILTER_PROC note bit)."
    - "KQ_NOTE_TRACKERR == 2: unable to track child (KQ_FILTER_PROC error note)."
    - "KQ_NOTE_CHILD == 4: child process of tracked parent (KQ_FILTER_PROC note)."
    - "KQ_NOTE_LOWAT == 1: low-water mark note (used with KQ_FILTER_READ/socket filters)."
    - "KQ_NOTE_PCTRLMASK == -1048576: negative bitmask isolating the process control bits in proc filter notes."
    - "KQ_NOTE_PDATAMASK == 1048575: positive bitmask for the data portion of proc filter notes."
    - "KQ_EV_FLAG1 == 8192: internal kqueue flag (not commonly used in application code)."
    - "KQ_EV_SYSFLAGS == 61440: composite mask of internal/system kevent flags."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# KQ_NOTE process-filter notes — TRACK, TRACKERR, CHILD, LOWAT
#
# select_extra5 covers: KQ_NOTE_DELETE/WRITE/EXTEND/ATTRIB/LINK/RENAME/REVOKE
# (vnode filter notes) and KQ_NOTE_EXIT/FORK/EXEC (proc filter notes).
# KQ_NOTE_TRACK/TRACKERR/CHILD/LOWAT are NOT covered by any prior spec.
# ---------------------------------------------------------------------------

table select_extra8.kq_note_proc_values:
  description: "KQ_NOTE_TRACK/TRACKERR/CHILD/LOWAT process-filter note constant values on macOS"
  kind: python_call_eq
  category: constants
  id_prefix: kqnote

  columns: [id, function, args, expected]
  rows:
    - [TRACK,    KQ_NOTE_TRACK.__eq__,    [1], true]
    - [TRACKERR, KQ_NOTE_TRACKERR.__eq__, [2], true]
    - [CHILD,    KQ_NOTE_CHILD.__eq__,    [4], true]
    - [LOWAT,    KQ_NOTE_LOWAT.__eq__,    [1], true]

table select_extra8.kq_note_proc_types:
  description: "KQ_NOTE_TRACK/TRACKERR/CHILD/LOWAT are plain integer constants"
  kind: python_call_eq
  category: constants
  id_prefix: kqnote_type

  columns: [id, function, args, expected]
  rows:
    - [TRACK,    KQ_NOTE_TRACK.__class__.__name__.__eq__,    ["int"], true]
    - [TRACKERR, KQ_NOTE_TRACKERR.__class__.__name__.__eq__, ["int"], true]
    - [CHILD,    KQ_NOTE_CHILD.__class__.__name__.__eq__,    ["int"], true]
    - [LOWAT,    KQ_NOTE_LOWAT.__class__.__name__.__eq__,    ["int"], true]

# ---------------------------------------------------------------------------
# KQ_NOTE_PCTRLMASK and KQ_NOTE_PDATAMASK — proc filter mask constants
#
# These two constants define the bitmask split in process-filter note fflags.
# No prior select spec covers either of these constants.
# KQ_NOTE_PCTRLMASK == -1048576 (high bits, negative interpreted as two's complement).
# KQ_NOTE_PDATAMASK == 1048575 (low 20 bits; 2^20 - 1).
# ---------------------------------------------------------------------------

invariant select_extra8.KQ_NOTE_PCTRLMASK.value:
  description: "select.KQ_NOTE_PCTRLMASK == -1048576 on macOS/Darwin — proc control bitmask"
  category: constants
  kind: python_call_eq
  function: KQ_NOTE_PCTRLMASK.__eq__
  args: [-1048576]
  expected: true

invariant select_extra8.KQ_NOTE_PCTRLMASK.type:
  description: "select.KQ_NOTE_PCTRLMASK.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: KQ_NOTE_PCTRLMASK.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant select_extra8.KQ_NOTE_PDATAMASK.value:
  description: "select.KQ_NOTE_PDATAMASK == 1048575 on macOS/Darwin — proc data bitmask (2^20 - 1)"
  category: constants
  kind: python_call_eq
  function: KQ_NOTE_PDATAMASK.__eq__
  args: [1048575]
  expected: true

invariant select_extra8.KQ_NOTE_PDATAMASK.type:
  description: "select.KQ_NOTE_PDATAMASK.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: KQ_NOTE_PDATAMASK.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# KQ_EV_FLAG1 and KQ_EV_SYSFLAGS — internal kevent flag constants
#
# select_extra4 covers KQ_EV_ONESHOT/CLEAR/ERROR/EOF (application-facing flags).
# KQ_EV_FLAG1 and KQ_EV_SYSFLAGS are internal/system flags not used in normal
# application code, and not covered by any prior spec.
# KQ_EV_FLAG1 == 8192 (0x2000); KQ_EV_SYSFLAGS == 61440 (0xF000).
# ---------------------------------------------------------------------------

invariant select_extra8.KQ_EV_FLAG1.value:
  description: "select.KQ_EV_FLAG1 == 8192 on macOS/Darwin — internal kevent flag (0x2000)"
  category: constants
  kind: python_call_eq
  function: KQ_EV_FLAG1.__eq__
  args: [8192]
  expected: true

invariant select_extra8.KQ_EV_FLAG1.type:
  description: "select.KQ_EV_FLAG1.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: KQ_EV_FLAG1.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant select_extra8.KQ_EV_SYSFLAGS.value:
  description: "select.KQ_EV_SYSFLAGS == 61440 on macOS/Darwin — composite system flags mask (0xF000)"
  category: constants
  kind: python_call_eq
  function: KQ_EV_SYSFLAGS.__eq__
  args: [61440]
  expected: true

invariant select_extra8.KQ_EV_SYSFLAGS.type:
  description: "select.KQ_EV_SYSFLAGS.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: KQ_EV_SYSFLAGS.__class__.__name__.__eq__
  args: ["int"]
  expected: true
