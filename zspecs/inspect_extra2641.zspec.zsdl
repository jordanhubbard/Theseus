spec: inspect_extra2641
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 623 (_extra2641): __copy__, __deepcopy__, and __sizeof__ dict-presence checks for inspect module types."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
    - "__copy__ supports copy.copy() shallow copying. None of the inspect types (Parameter, BoundArguments, Signature, FullArgSpec, ArgInfo) define __copy__ in their class __dict__ — all False."
    - "__deepcopy__ supports copy.deepcopy() deep copying. None of the inspect types define __deepcopy__ in their class __dict__ — all False."
    - "__sizeof__ is used by sys.getsizeof() for memory introspection. None of the inspect types define __sizeof__ in their class __dict__ — all False."
    - "inspect.FullArgSpec and inspect.ArgInfo are namedtuple subclasses; namedtuples inherit from tuple and do not define __copy__, __deepcopy__, or __sizeof__ in their own class __dict__."
    - "inspect.Parameter, BoundArguments, and Signature are pure-Python introspection helper classes; they also define none of these three dunders in their own __dict__."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __copy__ dict-presence for inspect introspection types
#
# __copy__ is the hook for copy.copy() shallow copying. inspect.Parameter,
# BoundArguments, Signature, FullArgSpec, and ArgInfo are introspection
# helpers; none define __copy__ in their own class __dict__ — all False.
# ---------------------------------------------------------------------------

table inspect_extra2641.copy_absent:
  description: "inspect types do not define __copy__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2641

  columns: [id, function, args, expected]
  rows:
    - ["in2641001", "inspect.Parameter.__dict__.__contains__",      ["__copy__"], false]
    - ["in2641002", "inspect.BoundArguments.__dict__.__contains__", ["__copy__"], false]
    - ["in2641003", "inspect.Signature.__dict__.__contains__",      ["__copy__"], false]
    - ["in2641004", "inspect.FullArgSpec.__dict__.__contains__",    ["__copy__"], false]
    - ["in2641005", "inspect.ArgInfo.__dict__.__contains__",        ["__copy__"], false]

# ---------------------------------------------------------------------------
# Table 2: __deepcopy__ dict-presence for inspect introspection types
#
# __deepcopy__ is the hook for copy.deepcopy() deep copying. None of the
# inspect types define it in their own class __dict__. Deep copying falls
# back to the default mechanism for all of these types — all False.
# ---------------------------------------------------------------------------

table inspect_extra2641.deepcopy_absent:
  description: "inspect types do not define __deepcopy__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2641

  columns: [id, function, args, expected]
  rows:
    - ["in2641006", "inspect.Parameter.__dict__.__contains__",      ["__deepcopy__"], false]
    - ["in2641007", "inspect.BoundArguments.__dict__.__contains__", ["__deepcopy__"], false]
    - ["in2641008", "inspect.Signature.__dict__.__contains__",      ["__deepcopy__"], false]
    - ["in2641009", "inspect.FullArgSpec.__dict__.__contains__",    ["__deepcopy__"], false]
    - ["in2641010", "inspect.ArgInfo.__dict__.__contains__",        ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# Table 3: __sizeof__ dict-presence for inspect introspection types
#
# __sizeof__ is called by sys.getsizeof() to obtain the memory footprint of
# an object in bytes. None of the inspect types define a custom __sizeof__
# in their own class __dict__ — all False. sys.getsizeof() falls back to the
# default object sizing for all of these types.
# ---------------------------------------------------------------------------

table inspect_extra2641.sizeof_absent:
  description: "inspect types do not define __sizeof__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2641

  columns: [id, function, args, expected]
  rows:
    - ["in2641011", "inspect.Parameter.__dict__.__contains__",      ["__sizeof__"], false]
    - ["in2641012", "inspect.BoundArguments.__dict__.__contains__", ["__sizeof__"], false]
    - ["in2641013", "inspect.Signature.__dict__.__contains__",      ["__sizeof__"], false]
    - ["in2641014", "inspect.FullArgSpec.__dict__.__contains__",    ["__sizeof__"], false]
    - ["in2641015", "inspect.ArgInfo.__dict__.__contains__",        ["__sizeof__"], false]

# ---------------------------------------------------------------------------
# Table 4: Combined absence summary — all three dunders absent from all types
#
# Cross-check confirming that none of the five inspect types define any of
# __copy__, __deepcopy__, or __sizeof__ in their own class __dict__. Assigns
# a unique dunder per type in a first pass, then cross-checks additional
# combinations to confirm the full absence pattern.
# ---------------------------------------------------------------------------

table inspect_extra2641.copy_sizeof_absent_summary:
  description: "inspect types define none of __copy__, __deepcopy__, __sizeof__ — cross-type summary"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2641

  columns: [id, function, args, expected]
  rows:
    - ["in2641016", "inspect.Parameter.__dict__.__contains__",      ["__copy__"],     false]
    - ["in2641017", "inspect.BoundArguments.__dict__.__contains__", ["__deepcopy__"], false]
    - ["in2641018", "inspect.Signature.__dict__.__contains__",      ["__sizeof__"],   false]
    - ["in2641019", "inspect.FullArgSpec.__dict__.__contains__",    ["__copy__"],     false]
    - ["in2641020", "inspect.ArgInfo.__dict__.__contains__",        ["__deepcopy__"], false]
    - ["in2641021", "inspect.Parameter.__dict__.__contains__",      ["__deepcopy__"], false]
    - ["in2641022", "inspect.BoundArguments.__dict__.__contains__", ["__sizeof__"],   false]
    - ["in2641023", "inspect.Signature.__dict__.__contains__",      ["__copy__"],     false]
    - ["in2641024", "inspect.FullArgSpec.__dict__.__contains__",    ["__sizeof__"],   false]
    - ["in2641025", "inspect.ArgInfo.__dict__.__contains__",        ["__copy__"],     false]
