spec: threading_extra841
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - threading module standard library documentation
    - Python 3.9+ threading API
  not_derived_from:
    - concurrent.futures or multiprocessing modules
    - gevent or eventlet cooperative threading libraries
  notes:
    - Covers __qualname__ and __module__ identity for threading module-level functions
    - All covered functions are defined in threading.py (pure Python)
    - enumerate here refers to threading.enumerate, not the builtin
  created_at: "2026-04-12"

table threading_extra841.qualname_and_module:
  description: Verify __qualname__ and __module__ identity for threading module-level functions
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: thr841xx
  columns: [id, function, args, expected]
  rows:
    - [thr841xx001, threading.current_thread.__qualname__.__eq__, ["current_thread"], true]
    - [thr841xx002, threading.current_thread.__module__.__eq__, ["threading"], true]
    - [thr841xx003, threading.main_thread.__qualname__.__eq__, ["main_thread"], true]
    - [thr841xx004, threading.main_thread.__module__.__eq__, ["threading"], true]
    - [thr841xx005, threading.active_count.__qualname__.__eq__, ["active_count"], true]
    - [thr841xx006, threading.active_count.__module__.__eq__, ["threading"], true]
    - [thr841xx007, threading.enumerate.__qualname__.__eq__, ["enumerate"], true]
    - [thr841xx008, threading.enumerate.__module__.__eq__, ["threading"], true]
    - [thr841xx009, threading.settrace.__qualname__.__eq__, ["settrace"], true]
    - [thr841xx010, threading.settrace.__module__.__eq__, ["threading"], true]
    - [thr841xx011, threading.setprofile.__qualname__.__eq__, ["setprofile"], true]
    - [thr841xx012, threading.setprofile.__module__.__eq__, ["threading"], true]
