spec: re_extra2821
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "Wave 635 theme: __radd__, __rsub__, and __rmul__ dict-presence checks (reflected arithmetic operators)."
    - "re.Pattern and re.Match are regex engine objects, not numeric types — none define reflected arithmetic operators."
    - "re.Pattern (type(re.compile(''))) does NOT define __radd__, __rsub__, or __rmul__ in its __dict__."
    - "re.Match (type(re.match('', ''))) does NOT define __radd__, __rsub__, or __rmul__ in its __dict__."
    - "Absence is uniform across both re result types."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __radd__ dict-presence — absent from re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2821.radd_protocol:
  description: "__radd__ is absent from re.Pattern.__dict__ and re.Match.__dict__ — regex objects have no addition semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2821

  columns: [id, function, args, expected]
  rows:
    - ["re2821001", "re.Pattern.__dict__.__contains__", ["__radd__"], false]
    - ["re2821002", "re.Match.__dict__.__contains__",   ["__radd__"], false]

# ---------------------------------------------------------------------------
# Table: __rsub__ dict-presence — absent from re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2821.rsub_protocol:
  description: "__rsub__ is absent from re.Pattern.__dict__ and re.Match.__dict__ — regex objects have no subtraction semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2821

  columns: [id, function, args, expected]
  rows:
    - ["re2821003", "re.Pattern.__dict__.__contains__", ["__rsub__"], false]
    - ["re2821004", "re.Match.__dict__.__contains__",   ["__rsub__"], false]

# ---------------------------------------------------------------------------
# Table: __rmul__ dict-presence — absent from re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2821.rmul_protocol:
  description: "__rmul__ is absent from re.Pattern.__dict__ and re.Match.__dict__ — regex objects have no multiplication semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2821

  columns: [id, function, args, expected]
  rows:
    - ["re2821005", "re.Pattern.__dict__.__contains__", ["__rmul__"], false]
    - ["re2821006", "re.Match.__dict__.__contains__",   ["__rmul__"], false]

# ---------------------------------------------------------------------------
# Table: all three reflected ops — combined view for both re types
# Confirms that neither Pattern nor Match defines any reflected arithmetic protocol
# ---------------------------------------------------------------------------

table re_extra2821.reflected_ops_summary:
  description: "All three reflected arithmetic operators absent from both re.Pattern and re.Match __dict__s"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2821

  columns: [id, function, args, expected]
  rows:
    - ["re2821007", "re.Pattern.__dict__.__contains__", ["__radd__"], false]
    - ["re2821008", "re.Pattern.__dict__.__contains__", ["__rsub__"], false]
    - ["re2821009", "re.Pattern.__dict__.__contains__", ["__rmul__"], false]
    - ["re2821010", "re.Match.__dict__.__contains__",   ["__radd__"], false]
    - ["re2821011", "re.Match.__dict__.__contains__",   ["__rsub__"], false]
    - ["re2821012", "re.Match.__dict__.__contains__",   ["__rmul__"], false]
