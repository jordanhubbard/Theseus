spec: queue_extra5
version: ">=3.9"
backend: python_module(queue)

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/queue.html — Python queue module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/queue.py"
  notes:
    - "This spec extends queue.zspec.zsdl and prior extras through queue_extra4.zspec.zsdl."
    - "queue_extra3 covers: __name__ and __module__ for all 6 classes; Empty/Full __bases__[0].__name__; Queue instance behavior (qsize, maxsize, class name); LifoQueue/PriorityQueue instance class names."
    - "queue_extra4 covers: __qualname__ for all 6 classes."
    - "This spec adds: class hierarchy (__bases__[0].__name__) for Queue, LifoQueue, PriorityQueue, SimpleQueue — new coverage."
    - "This spec adds: Queue method names (get, put, empty, full, qsize) — not previously verified in any queue spec."
    - "This spec adds: SimpleQueue method names (get, put, empty, qsize) — not previously verified."
    - "This spec adds: SimpleQueue instance behavior (empty() == True, __class__.__name__ == 'SimpleQueue') — not in extra3 which covered only Queue/LifoQueue/PriorityQueue instances."
    - "queue.Queue.__bases__[0].__name__ == 'object' — Queue inherits directly from object."
    - "queue.LifoQueue.__bases__[0].__name__ == 'Queue' — LifoQueue inherits from Queue."
    - "queue.PriorityQueue.__bases__[0].__name__ == 'Queue' — PriorityQueue inherits from Queue."
    - "queue.SimpleQueue.__bases__[0].__name__ == 'object' — SimpleQueue inherits directly from object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class hierarchy — __bases__[0].__name__
#
# queue_extra3 covered only Empty and Full base classes.
# Queue, LifoQueue, PriorityQueue, and SimpleQueue hierarchy is new coverage.
# Queue and SimpleQueue inherit from object; LifoQueue and PriorityQueue
# both inherit from Queue.
# ---------------------------------------------------------------------------

invariant queue_extra5.Queue.base_is_object:
  description: "queue.Queue.__bases__[0].__name__ == 'object' — Queue inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Queue.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant queue_extra5.LifoQueue.base_is_Queue:
  description: "queue.LifoQueue.__bases__[0].__name__ == 'Queue' — LifoQueue inherits from Queue"
  category: class_hierarchy
  kind: python_call_eq
  function: LifoQueue.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Queue"

invariant queue_extra5.PriorityQueue.base_is_Queue:
  description: "queue.PriorityQueue.__bases__[0].__name__ == 'Queue' — PriorityQueue inherits from Queue"
  category: class_hierarchy
  kind: python_call_eq
  function: PriorityQueue.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Queue"

invariant queue_extra5.SimpleQueue.base_is_object:
  description: "queue.SimpleQueue.__bases__[0].__name__ == 'object' — SimpleQueue inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: SimpleQueue.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Queue method names
#
# The core Queue methods get, put, empty, full, and qsize are regular
# Python methods defined in Lib/queue.py. Their __name__ attributes equal
# their literal method names. Not covered in any prior queue spec.
# ---------------------------------------------------------------------------

table queue_extra5.Queue.method_names:
  description: "queue.Queue methods have correct __name__"
  kind: python_call_eq
  category: method_names
  id_prefix: qmname

  columns: [id, function, args, expected]
  rows:
    - [get,   Queue.get.__name__.__eq__,   ["get"],   true]
    - [put,   Queue.put.__name__.__eq__,   ["put"],   true]
    - [empty, Queue.empty.__name__.__eq__, ["empty"], true]
    - [full,  Queue.full.__name__.__eq__,  ["full"],  true]
    - [qsize, Queue.qsize.__name__.__eq__, ["qsize"], true]

# ---------------------------------------------------------------------------
# SimpleQueue method names
#
# SimpleQueue is backed by a C extension (_queue.SimpleQueue) but exposes
# Python-accessible methods: get, put, empty, qsize. Their __name__ attributes
# match the method names. Not covered in any prior queue spec.
# ---------------------------------------------------------------------------

table queue_extra5.SimpleQueue.method_names:
  description: "queue.SimpleQueue methods have correct __name__"
  kind: python_call_eq
  category: method_names
  id_prefix: sqmname

  columns: [id, function, args, expected]
  rows:
    - [get,   SimpleQueue.get.__name__.__eq__,   ["get"],   true]
    - [put,   SimpleQueue.put.__name__.__eq__,   ["put"],   true]
    - [empty, SimpleQueue.empty.__name__.__eq__, ["empty"], true]
    - [qsize, SimpleQueue.qsize.__name__.__eq__, ["qsize"], true]

# ---------------------------------------------------------------------------
# SimpleQueue instance behavior
#
# queue_extra3 covered Queue/LifoQueue/PriorityQueue instance behavior.
# SimpleQueue instance behavior is new coverage.
# A freshly created SimpleQueue is empty; empty() returns True.
# ---------------------------------------------------------------------------

invariant queue_extra5.SimpleQueue.instance_class:
  description: "queue.SimpleQueue().__class__.__name__ == 'SimpleQueue'"
  category: SimpleQueue_behavior
  kind: python_call_eq
  function: SimpleQueue
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["SimpleQueue"]
  expected: true
