spec: itertools_extra486
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools chain.from_iterable and iterator type identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "itertools types are C-extension types; __bases__[0] is always object for these iterator classes"
    - "chain.from_iterable is a classmethod descriptor accessible at class level"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra486.chain_from_iterable_identity:
  description: "itertools.chain.from_iterable name and qualname identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: cfi

  columns: [id, function, args, expected]
  rows:
    - [cfi001, itertools.chain.from_iterable.__name__.__eq__, ["from_iterable"], true]
    - [cfi002, itertools.chain.from_iterable.__qualname__.__eq__, ["chain.from_iterable"], true]

table itertools_extra486.tee_repeat_identity:
  description: "itertools.tee and itertools.repeat name and module identity"
  kind: python_call_eq
  category: identity
  id_prefix: tri

  columns: [id, function, args, expected]
  rows:
    - [tri001, itertools.tee.__name__.__eq__, ["tee"], true]
    - [tri002, itertools.tee.__module__.__eq__, ["itertools"], true]
    - [tri003, itertools.repeat.__name__.__eq__, ["repeat"], true]
    - [tri004, itertools.repeat.__module__.__eq__, ["itertools"], true]

table itertools_extra486.base_class_identity:
  description: "itertools iterator type __bases__[0].__name__ checks — all C-extension types inherit from object"
  kind: python_call_eq
  category: identity
  id_prefix: base

  columns: [id, function, args, expected]
  rows:
    - [base001, "itertools.repeat.__bases__[0].__name__.__eq__", ["object"], true]
    - [base002, "itertools.count.__bases__[0].__name__.__eq__", ["object"], true]
    - [base003, "itertools.islice.__bases__[0].__name__.__eq__", ["object"], true]
    - [base004, "itertools.compress.__bases__[0].__name__.__eq__", ["object"], true]
    - [base005, "itertools.dropwhile.__bases__[0].__name__.__eq__", ["object"], true]
    - [base006, "itertools.takewhile.__bases__[0].__name__.__eq__", ["object"], true]
