spec: operator_extra5
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl and prior extras."
    - "operator_extra4 covers __qualname__ for add/sub/mul/truediv/floordiv/mod/pow/neg/pos/abs and eq/ne/lt/le/gt/ge."
    - "operator_extra3 covers __module__ == '_operator' for add/sub/mul/truediv/floordiv/mod/pow/neg/abs/eq/ne/lt/le/gt/ge/not_/and_/or_/xor/lshift/rshift/getitem/setitem/delitem/contains."
    - "operator_extra2 covers attrgetter/__name__, itemgetter/__name__, methodcaller/__name__; length_hint, index, concat, abs, pos, iadd, truth, is_."
    - "operator_extra covers itemgetter/attrgetter/methodcaller class names and call results; iadd/isub/imul/itruediv call results."
    - "Focus: __qualname__ checks for the remaining operator functions not covered in extra4 — logical, bitwise, item-access, in-place, and miscellaneous operators; plus attrgetter/itemgetter/methodcaller __qualname__."
    - "All C builtin functions in _operator have flat __qualname__ equal to __name__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ — logical and bitwise operators
#
# operator_extra3 recorded __module__ for not_/and_/or_/xor/lshift/rshift.
# operator_extra4 recorded __qualname__ for arithmetic and comparison operators
# only. This table fills in the remaining logical and bitwise operators.
# ---------------------------------------------------------------------------

table operator_extra5.qualnames.logical_bitwise:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [not_,   not_.__qualname__.__eq__,   ["not_"],   true]
    - [and_,   and_.__qualname__.__eq__,   ["and_"],   true]
    - [or_,    or_.__qualname__.__eq__,    ["or_"],    true]
    - [xor,    xor.__qualname__.__eq__,    ["xor"],    true]
    - [lshift, lshift.__qualname__.__eq__, ["lshift"], true]
    - [rshift, rshift.__qualname__.__eq__, ["rshift"], true]

# ---------------------------------------------------------------------------
# __qualname__ — item-access operators
#
# getitem/setitem/delitem/contains: __module__ covered in extra3, __qualname__
# not yet recorded.
# ---------------------------------------------------------------------------

table operator_extra5.qualnames.item_access:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [getitem,  getitem.__qualname__.__eq__,  ["getitem"],  true]
    - [setitem,  setitem.__qualname__.__eq__,  ["setitem"],  true]
    - [delitem,  delitem.__qualname__.__eq__,  ["delitem"],  true]
    - [contains, contains.__qualname__.__eq__, ["contains"], true]

# ---------------------------------------------------------------------------
# __qualname__ — in-place operators
#
# iadd/isub/imul: __name__ in operator.zspec.zsdl; __qualname__ not yet recorded.
# itruediv: call result in operator_extra; __qualname__ not yet recorded.
# ---------------------------------------------------------------------------

table operator_extra5.qualnames.inplace:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [iadd,    iadd.__qualname__.__eq__,    ["iadd"],    true]
    - [isub,    isub.__qualname__.__eq__,    ["isub"],    true]
    - [imul,    imul.__qualname__.__eq__,    ["imul"],    true]
    - [itruediv, itruediv.__qualname__.__eq__, ["itruediv"], true]

# ---------------------------------------------------------------------------
# __qualname__ — miscellaneous operators
#
# truth/is_/concat/length_hint/index: call results covered in extra2; __qualname__
# not yet recorded.
# pos: call result covered in extra2 (class name check); __qualname__ not yet
# recorded (extra4 covers pos.__qualname__).
# ---------------------------------------------------------------------------

table operator_extra5.qualnames.misc:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [truth,       truth.__qualname__.__eq__,       ["truth"],       true]
    - [is_,         is_.__qualname__.__eq__,          ["is_"],         true]
    - [concat,      concat.__qualname__.__eq__,       ["concat"],      true]
    - [length_hint, length_hint.__qualname__.__eq__,  ["length_hint"], true]
    - [index,       index.__qualname__.__eq__,         ["index"],       true]

# ---------------------------------------------------------------------------
# __qualname__ — attrgetter, itemgetter, methodcaller
#
# These are C-extension type objects. operator_extra2 records __name__ for each.
# __qualname__ is a distinct attribute (also equal to __name__ for top-level
# classes) not yet recorded in any prior spec.
# ---------------------------------------------------------------------------

table operator_extra5.qualnames.factory_classes:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [attrgetter,   attrgetter.__qualname__.__eq__,   ["attrgetter"],   true]
    - [itemgetter,   itemgetter.__qualname__.__eq__,   ["itemgetter"],   true]
    - [methodcaller, methodcaller.__qualname__.__eq__, ["methodcaller"], true]
