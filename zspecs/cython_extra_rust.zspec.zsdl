spec: cython_extra_rust
version: ">=3.9"
backend: rust_module(cython_extra_rust)

docs: https://cython.org/

provenance:
  derived_from:
    - "https://cython.org/ — Cython"
  notes:
    - "Cython compiles Python to C for performance."
    - "Cython.__version__ is non-empty."
    - "Cython.Build.cythonize is callable."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant cython_extra_rust.has_cythonize:
  description: "Cython.Build.cythonize is callable"
  category: presence
  kind: python_call_eq
  function: cython_extra_has_cythonize
  args: []
  expected: true

invariant cython_extra_rust.has_inline:
  description: "Cython.inline is callable"
  category: presence
  kind: python_call_eq
  function: cython_extra_has_inline
  args: []
  expected: true

invariant cython_extra_rust.version_nonempty:
  description: "Cython.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: cython_extra_version_nonempty
  args: []
  expected: true

