spec: concurrent_futures_extra1786
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "Wave 566, suffix _extra1786. Theme: __class_getitem__ and __init_subclass__ class creation hooks — which stdlib types define these in their own __dict__."
    - "concurrent.futures.Future defines __class_getitem__ in its own __dict__ (PEP 585 generic syntax, Future[T] supported in Python 3.9+)."
    - "concurrent.futures.ThreadPoolExecutor does NOT define __class_getitem__ in its own __dict__ — executor types are not generic."
    - "concurrent.futures.ProcessPoolExecutor does NOT define __class_getitem__ in its own __dict__ — executor types are not generic."
    - "concurrent.futures.Executor does NOT define __class_getitem__ in its own __dict__ — the base Executor class is not generic."
    - "None of the concurrent.futures types define __init_subclass__ in their own __dict__; all rely on the default inherited from object."
    - "concurrent.futures.Executor defines __enter__ and __exit__ in its own __dict__ (sync context manager)."
    - "concurrent.futures.Future defines cancel, result, done, running, and exception in its own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __class_getitem__ and __init_subclass__ in concurrent.futures dicts
#
# concurrent.futures.Future defines __class_getitem__ for PEP 585 generic
# syntax (Future[T]).  Executor subclasses do NOT define __class_getitem__.
# None of the types define __init_subclass__ in their own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1786.class_getitem_in_dict:
  kind: python_call_eq
  category: class_getitem
  id_prefix: cf1786

  columns: [id, function, args, expected]
  rows:
    - ["cf1786001", concurrent.futures.Future.__dict__.__contains__,             ["__class_getitem__"], true]
    - ["cf1786002", concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["__class_getitem__"], false]
    - ["cf1786003", concurrent.futures.ProcessPoolExecutor.__dict__.__contains__,  ["__class_getitem__"], false]
    - ["cf1786004", concurrent.futures.Executor.__dict__.__contains__,           ["__class_getitem__"], false]
    - ["cf1786005", concurrent.futures.Future.__dict__.__contains__,             ["__init_subclass__"], false]
    - ["cf1786006", concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["__init_subclass__"], false]
    - ["cf1786007", concurrent.futures.ProcessPoolExecutor.__dict__.__contains__,  ["__init_subclass__"], false]
    - ["cf1786008", concurrent.futures.Executor.__dict__.__contains__,           ["__init_subclass__"], false]
    - ["cf1786009", concurrent.futures.Future.__dict__.__contains__,             ["cancel"],             true]
    - ["cf1786010", concurrent.futures.Future.__dict__.__contains__,             ["result"],             true]
    - ["cf1786011", concurrent.futures.Future.__dict__.__contains__,             ["done"],               true]
    - ["cf1786012", concurrent.futures.Executor.__dict__.__contains__,           ["__enter__"],          true]
    - ["cf1786013", concurrent.futures.Executor.__dict__.__contains__,           ["__exit__"],           true]

# ---------------------------------------------------------------------------
# Table 2: complementary identity and sync-protocol checks
#
# Confirm class names, module membership, and presence of key methods that
# serve as positive anchors alongside the negative __class_getitem__ checks
# for executor types.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1786.identity_and_complementary:
  kind: python_call_eq
  category: identity
  id_prefix: cf1786

  columns: [id, function, args, expected]
  rows:
    - ["cf1786014", concurrent.futures.Future.__name__.__eq__,                   ["Future"],                    true]
    - ["cf1786015", concurrent.futures.ThreadPoolExecutor.__name__.__eq__,        ["ThreadPoolExecutor"],         true]
    - ["cf1786016", concurrent.futures.ProcessPoolExecutor.__name__.__eq__,        ["ProcessPoolExecutor"],        true]
    - ["cf1786017", concurrent.futures.Executor.__name__.__eq__,                 ["Executor"],                  true]
    - ["cf1786018", concurrent.futures.Future.__module__.__eq__,                 ["concurrent.futures._base"],  true]
    - ["cf1786019", concurrent.futures.Future.__dict__.__contains__,             ["running"],                   true]
    - ["cf1786020", concurrent.futures.Future.__dict__.__contains__,             ["exception"],                 true]
    - ["cf1786021", concurrent.futures.wait.__class__.__name__.__eq__,           ["function"],                  true]
    - ["cf1786022", concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["submit"],                    true]
    - ["cf1786023", concurrent.futures.Executor.__dict__.__contains__,           ["map"],                       true]
    - ["cf1786024", concurrent.futures.Executor.__dict__.__contains__,           ["shutdown"],                  true]
    - ["cf1786025", concurrent.futures.Future.__dict__.__contains__,             ["add_done_callback"],          true]
