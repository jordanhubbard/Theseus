# ---------------------------------------------------------------------------
# Signature class identity
#
# inspect.Signature is a class defined in inspect.
# __name__ == 'Signature', __module__ == 'inspect', __bases__[0] == object.
# ---------------------------------------------------------------------------

invariant inspect_extra298.Signature.name:
  description: "inspect.Signature.__name__ == 'Signature'"
  category: Signature
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra298.Signature.module:
  description: "inspect.Signature.__module__ == 'inspect'"
  category: Signature
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra298.Signature.base_is_object:
  description: "inspect.Signature.__bases__[0].__name__ == 'object' — inherits directly from object"
  category: Signature
  kind: python_call_eq
  function: Signature.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
