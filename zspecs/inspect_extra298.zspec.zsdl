spec: inspect_extra298
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# function identity — __name__ and __module__
#
# All public inspect functions are Python-level functions defined in the
# inspect module itself. __module__ == 'inspect' for each.
# ---------------------------------------------------------------------------

invariant inspect_extra298.signature.name:
  description: "inspect.signature.__name__ == 'signature'"
  category: signature
  kind: python_call_eq
  function: signature.__name__.__eq__
  args: ["signature"]
  expected: true

invariant inspect_extra298.signature.module:
  description: "inspect.signature.__module__ == 'inspect'"
  category: signature
  kind: python_call_eq
  function: signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra298.getsource.name:
  description: "inspect.getsource.__name__ == 'getsource'"
  category: getsource
  kind: python_call_eq
  function: getsource.__name__.__eq__
  args: ["getsource"]
  expected: true

invariant inspect_extra298.getsource.module:
  description: "inspect.getsource.__module__ == 'inspect'"
  category: getsource
  kind: python_call_eq
  function: getsource.__module__.__eq__
  args: ["inspect"]
  expected: true

