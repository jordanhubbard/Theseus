spec: theseus_zoneinfo_cr
version: ">=3.9"
backend: python_cleanroom(theseus_zoneinfo_cr)
blocks: zoneinfo

docs: https://docs.python.org/3/library/zoneinfo.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/zoneinfo.html"
  not_derived_from:
    - "CPython source: Lib/zoneinfo/__init__.py"
  notes:
    - "Clean-room zoneinfo module. Do NOT import zoneinfo."

error_model: python_exceptions

invariant theseus_zoneinfo_cr.zoneinfo2_utc:
  description: "ZoneInfo('UTC') can be created"
  category: behavior
  kind: python_call_eq
  function: zoneinfo2_utc
  args: []
  expected: true

invariant theseus_zoneinfo_cr.zoneinfo2_available_timezones:
  description: "available_timezones() returns a non-empty set"
  category: behavior
  kind: python_call_eq
  function: zoneinfo2_available_timezones
  args: []
  expected: true

invariant theseus_zoneinfo_cr.zoneinfo2_key:
  description: "ZoneInfo objects have a key attribute"
  category: behavior
  kind: python_call_eq
  function: zoneinfo2_key
  args: []
  expected: true
