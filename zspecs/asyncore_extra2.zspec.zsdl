spec: asyncore_extra2
version: ">=3.9,<3.12"
backend: python_module(asyncore)

docs: https://docs.python.org/3/library/asyncore.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncore.html — Python asyncore documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncore.py"
  notes:
    - "This spec extends asyncore.zspec.zsdl and prior extras."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "asyncore raises no module-specific exception class; socket and OS errors propagate normally."
  stderr: "null"
  stickiness: "N/A — class-level structural checks only."
  codes: {}

# ---------------------------------------------------------------------------
# dispatcher class — qualname
# ---------------------------------------------------------------------------

invariant asyncore_extra2.dispatcher_qualname:
  description: "dispatcher.__qualname__ == 'dispatcher'"
  category: classnames
  kind: python_call_eq
  function: dispatcher.__qualname__.__eq__
  args: ["dispatcher"]
  expected: true

# ---------------------------------------------------------------------------
# file_dispatcher class — module
# ---------------------------------------------------------------------------

invariant asyncore_extra2.file_dispatcher_module:
  description: "file_dispatcher.__module__ == 'asyncore'"
  category: classnames
  kind: python_call_eq
  function: file_dispatcher.__module__.__eq__
  args: ["asyncore"]
  expected: true

# ---------------------------------------------------------------------------
# file_dispatcher class — qualname
# ---------------------------------------------------------------------------

invariant asyncore_extra2.file_dispatcher_qualname:
  description: "file_dispatcher.__qualname__ == 'file_dispatcher'"
  category: classnames
  kind: python_call_eq
  function: file_dispatcher.__qualname__.__eq__
  args: ["file_dispatcher"]
  expected: true

# ---------------------------------------------------------------------------
# loop function — module
# ---------------------------------------------------------------------------

invariant asyncore_extra2.loop_module:
  description: "loop.__module__ == 'asyncore'"
  category: functions
  kind: python_call_eq
  function: loop.__module__.__eq__
  args: ["asyncore"]
  expected: true

# ---------------------------------------------------------------------------
# dispatcher class — base qualname
# ---------------------------------------------------------------------------

invariant asyncore_extra2.dispatcher_base_qualname:
  description: "dispatcher.__bases__[0].__qualname__ == 'object'"
  category: classnames
  kind: python_call_eq
  function: dispatcher.__bases__.__getitem__
  args: [0]
  method: __qualname__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# file_wrapper class — module
# ---------------------------------------------------------------------------

invariant asyncore_extra2.file_wrapper_module:
  description: "file_wrapper.__module__ == 'asyncore'"
  category: classnames
  kind: python_call_eq
  function: file_wrapper.__module__.__eq__
  args: ["asyncore"]
  expected: true
