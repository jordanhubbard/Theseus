spec: asyncio_extra224
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "asyncio.Queue.__init__.__code__.co_argcount == 2 — parameters are (self, maxsize=0); verified with Python 3.14.3."
    - "asyncio.Queue.__init__.__code__.co_name == '__init__' — method name as stored in code object; verified with Python 3.14.3."
    - "asyncio.Queue.__init__.__qualname__ == 'Queue.__init__' — qualified name includes class; verified with Python 3.14.3."
    - "asyncio.Queue.__init__.__module__ == 'asyncio.queues' — defined in the asyncio.queues submodule; verified with Python 3.14.3."
    - "asyncio.Lock.__init__.__code__.co_argcount == 1 — only parameter is self; verified with Python 3.14.3."
    - "asyncio.Lock.__init__.__code__.co_name == '__init__' — method name as stored in code object; verified with Python 3.14.3."
    - "asyncio.Event.__init__.__code__.co_argcount == 1 — only parameter is self; verified with Python 3.14.3."
    - "asyncio.Semaphore.__init__.__code__.co_argcount == 2 — parameters are (self, value); verified with Python 3.14.3."
    - "asyncio.BoundedSemaphore.__init__.__code__.co_argcount == 2 — parameters are (self, value); verified with Python 3.14.3."
    - "asyncio.Condition.__init__.__code__.co_argcount == 2 — parameters are (self, lock=None); verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue.__init__ code object contracts — extra224 namespace
#
# Queue.__init__ takes (self, maxsize=0): co_argcount == 2.
# co_name and __qualname__ confirm method identity.
# __module__ confirms the submodule where Queue is defined.
# ---------------------------------------------------------------------------

table asyncio_extra224.queue_init_code:
  description: "asyncio.Queue.__init__ code object and identity checks in extra224 namespace"
  kind: python_call_eq
  category: code_contracts
  id_prefix: aio224queueinit

  columns: [id, function, args, expected, description]
  rows:
    - [queue_init_argcount,   Queue.__init__.__code__.co_argcount.__eq__,  [2],          true, "asyncio.Queue.__init__.__code__.co_argcount == 2 — parameters are (self, maxsize=0); verified with Python 3.14.3"]
    - [queue_init_co_name,    Queue.__init__.__code__.co_name.__eq__,      ["__init__"], true, "asyncio.Queue.__init__.__code__.co_name == '__init__' — method name in code object; verified with Python 3.14.3"]
    - [queue_init_qualname,   Queue.__init__.__qualname__.__eq__,          ["Queue.__init__"], true, "asyncio.Queue.__init__.__qualname__ == 'Queue.__init__' — qualified name includes owning class; verified with Python 3.14.3"]
    - [queue_init_module,     Queue.__init__.__module__.__eq__,            ["asyncio.queues"], true, "asyncio.Queue.__init__.__module__ == 'asyncio.queues' — Queue is defined in the asyncio.queues submodule; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Lock / Event __init__ code object contracts — extra224 namespace
#
# Lock.__init__ and Event.__init__ each take only self: co_argcount == 1.
# co_name confirms method identity for both.
# ---------------------------------------------------------------------------

table asyncio_extra224.lock_event_init_code:
  description: "asyncio.Lock and Event __init__ code object checks in extra224 namespace"
  kind: python_call_eq
  category: code_contracts
  id_prefix: aio224lockevinit

  columns: [id, function, args, expected, description]
  rows:
    - [lock_init_argcount,  Lock.__init__.__code__.co_argcount.__eq__,  [1],          true, "asyncio.Lock.__init__.__code__.co_argcount == 1 — only parameter is self; verified with Python 3.14.3"]
    - [lock_init_co_name,   Lock.__init__.__code__.co_name.__eq__,      ["__init__"], true, "asyncio.Lock.__init__.__code__.co_name == '__init__' — method name in code object; verified with Python 3.14.3"]
    - [event_init_argcount, Event.__init__.__code__.co_argcount.__eq__, [1],          true, "asyncio.Event.__init__.__code__.co_argcount == 1 — only parameter is self; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Semaphore, BoundedSemaphore, Condition __init__ contracts — extra224
#
