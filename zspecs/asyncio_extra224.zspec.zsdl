  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_init_argcount,        Semaphore.__init__.__code__.co_argcount.__eq__,        [2], true, "asyncio.Semaphore.__init__.__code__.co_argcount == 2 — parameters are (self, value); verified with Python 3.14.3"]
    - [boundedsemaphore_init_argcount, BoundedSemaphore.__init__.__code__.co_argcount.__eq__, [2], true, "asyncio.BoundedSemaphore.__init__.__code__.co_argcount == 2 — parameters are (self, value); verified with Python 3.14.3"]
    - [condition_init_argcount,        Condition.__init__.__code__.co_argcount.__eq__,        [2], true, "asyncio.Condition.__init__.__code__.co_argcount == 2 — parameters are (self, lock=None); verified with Python 3.14.3"]
