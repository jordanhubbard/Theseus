spec: socket_extra503
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module classes, error hierarchy, and enum types"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "socket.error is an alias for OSError, so its __qualname__ is 'OSError'"
    - "socket.timeout, socket.herror, and socket.gaierror all inherit directly from OSError"
    - "AddressFamily and SocketKind are IntEnum subclasses"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra503.qualname_checks:
  description: "socket module class and enum __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: SKE503

  columns: [id, function, args, expected]
  rows:
    - [id001, socket.socket.__qualname__.__eq__, ["socket"], true]
    - [id002, socket.error.__qualname__.__eq__, ["OSError"], true]
    - [id003, socket.timeout.__qualname__.__eq__, ["timeout"], true]
    - [id004, socket.herror.__qualname__.__eq__, ["herror"], true]
    - [id005, socket.gaierror.__qualname__.__eq__, ["gaierror"], true]
    - [id006, socket.AddressFamily.__qualname__.__eq__, ["AddressFamily"], true]
    - [id007, socket.SocketKind.__qualname__.__eq__, ["SocketKind"], true]

table socket_extra503.base_class_checks:
  description: "socket exception class base class identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: SKE503B

  columns: [id, function, args, expected]
  rows:
    - [id001, "socket.timeout.__bases__[0].__name__.__eq__", ["OSError"], true]
    - [id002, "socket.herror.__bases__[0].__name__.__eq__", ["OSError"], true]
    - [id003, "socket.gaierror.__bases__[0].__name__.__eq__", ["OSError"], true]
