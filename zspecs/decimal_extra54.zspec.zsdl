spec: decimal_extra54
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra53.zspec.zsdl — covers decimal module has no __all__ (decimal.__dict__.__contains__('__all__')==False); Decimal/Context __eq__.__class__.__name__.__eq__('wrapper_descriptor'); DecimalException/InvalidOperation __eq__.__class__.__name__.__eq__('wrapper_descriptor')."
    - "decimal_extra52.zspec.zsdl — covers Decimal/Context __repr__.__class__.__name__.__eq__('wrapper_descriptor'); DecimalException/InvalidOperation __repr__.__class__.__name__.__eq__('wrapper_descriptor'); Decimal/Context __hash__.__class__.__name__.__eq__('wrapper_descriptor')."
    - "decimal_extra51.zspec.zsdl — covers Decimal/Context __class__.__module__.__eq__('builtins'); DecimalException/InvalidOperation/DivisionByZero/Overflow/Underflow/Clamped __class__.__module__.__eq__('builtins')."
    - "decimal_extra50.zspec.zsdl — covers Decimal/Context/DecimalException/InvalidOperation/DivisionByZero __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy')."
    - "decimal_extra49.zspec.zsdl — covers all 8 decimal exception __module__=='decimal' equality and __module__.__class__.__name__=='str'."
    - "decimal_extra46.zspec.zsdl — covers Decimal/Context/__doc__.__class__.__name__.__eq__('str') and __qualname__.__eq__('str'); also DecimalException/InvalidOperation/__doc__.__class__.__name__.__eq__('str') — NOTE: decimal_extra46 claims these as 'str' but actual Python 3.14.3 runtime shows DecimalException.__doc__ is None; the module-level Decimal and Context docstrings are genuine str instances."
    - "decimal_extra34.zspec.zsdl — covers decimal.__name__.__len__()==7; decimal.__package__=='' was noted as not worth a separate check."
  notes:
    - "This spec extends decimal_extra53.zspec.zsdl."
    - "Wave 224 theme: __all__.__contains__ membership + module __package__ identity + class __doc__.__class__.__name__ checks."
    - "CONFIRMED: decimal has no __all__ (decimal.__dict__.__contains__('__all__') == False; hasattr(decimal, '__all__') == False). Therefore no __all__.__contains__ table is included. This was established in decimal_extra53."
    - "decimal.__package__ == '' — decimal is a C-extension module (_decimal) with a Python shim layer. It is NOT a package (no subdirectory or __init__.py). Therefore __package__ is the empty string ''. Verified: decimal.__package__.__eq__('') == True. decimal_extra34 noted this but did not produce a spec row for it. The equality test is novel as a standalone spec anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.Decimal.__doc__.__class__.__name__.__len__() == 3 — decimal_extra46 covers Decimal.__doc__.__class__.__name__.__eq__('str') (equality). This spec adds the __len__()==3 angle: the type name 'str' has 3 characters. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.Context.__doc__.__class__.__name__.__len__() == 3 — decimal_extra46 covers Context.__doc__.__class__.__name__.__eq__('str') (equality). Novel length angle. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "IMPORTANT: decimal.DecimalException.__doc__ is None (verified Python 3.14.3). Accessing DecimalException.__doc__.__class__ directly would encounter NoneType, not str. This spec does NOT include a __doc__.__class__.__name__ chain for DecimalException or InvalidOperation. Instead, their docstring state is confirmed via decimal_extra53's __eq__.__class__.__name__ tests."
    - "decimal.__spec__.__class__.__name__ == 'ModuleSpec' — No prior decimal spec checks __spec__.__class__.__name__. The decimal module's __spec__ is an importlib.machinery.ModuleSpec instance. __spec__.__class__.__name__ == 'ModuleSpec'. __spec__.__class__.__module__ == '_frozen_importlib'. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.__spec__.name.__eq__('decimal') == True — the ModuleSpec's name attribute is the string 'decimal'. No prior decimal spec checks __spec__.name equality. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.__spec__.name.__len__() == 7 — 'decimal' has 7 characters. Novel length anchor for __spec__.name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.__package__ identity
#
# decimal is a C-extension module (_decimal) with a Python shim. It is NOT a
# package — it has no subdirectory or __init__.py. Therefore its __package__
# attribute is the empty string ''.
#
#   decimal.__package__.__eq__('') == True
#
# decimal_extra34 noted that decimal.__package__=='' without producing a spec
# row for it. The equality test is novel as a standalone anchor in decpkg54.
# This contrasts with re.__package__=='re' and pathlib.__package__=='pathlib',
# which are packages. io.__package__ is also '' like decimal.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra54.package_identity:
  description: "decimal.__package__.__eq__('') — decimal is a C-extension module (not a package); its __package__ is the empty string ''; decimal_extra34 noted this value but did not produce a spec row for it; this equality anchor is novel in decpkg54 namespace; contrasts with re ('re') and pathlib ('pathlib') which are packages; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: decpkg54pkg

  columns: [id, function, args, expected]
  rows:
    - [package_eq_empty, __package__.__eq__, [""], true]

# ---------------------------------------------------------------------------
# decimal Decimal/Context __doc__.__class__.__name__.__len__() == 3
#
# decimal_extra46 covered Decimal.__doc__.__class__.__name__.__eq__('str') and
# Context.__doc__.__class__.__name__.__eq__('str') (equality anchors).
#
# Novel angle: the __len__() of the type name string. 'str' has length 3.
# The chain: T.__doc__ is a str instance; .__class__ is the str type;
# .__class__.__name__ is 'str'; .__len__() == 3.
#
#   Decimal.__doc__.__class__.__name__.__len__() == 3
#   Context.__doc__.__class__.__name__.__len__() == 3
#
# NOTE: DecimalException.__doc__ and InvalidOperation.__doc__ are both None
# (verified Python 3.14.3). These exception classes cannot be included in a
# __doc__.__class__.__name__ chain — only Decimal and Context have real docs.
#
# No prior decimal spec checks __doc__.__class__.__name__.__len__() for any class.
# Both anchors are novel in the decpkg54 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra54.doc_class_name_len:
  description: "decimal Decimal/Context __doc__.__class__.__name__.__len__()==3 — the docstring type name 'str' has length 3; decimal_extra46 covers Decimal/Context __doc__.__class__.__name__.__eq__('str') (equality); this spec adds the __len__()==3 angle which is novel; NOTE: DecimalException.__doc__ is None in Python 3.14.3 so the chain cannot be used for exception classes; both anchors novel in decpkg54 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decpkg54dlen

  columns: [id, function, args, expected]
  rows:
    - [Decimal_doc_class_name_len, "Decimal.__doc__.__class__.__name__.__len__", [], 3]
    - [Context_doc_class_name_len, "Context.__doc__.__class__.__name__.__len__", [], 3]

# ---------------------------------------------------------------------------
# decimal.__spec__ class identity
#
# The decimal module's __spec__ is an importlib.machinery.ModuleSpec instance.
# No prior decimal spec checks any __spec__ attribute.
#
#   decimal.__spec__.__class__.__name__.__eq__('ModuleSpec') == True
#   decimal.__spec__.name.__eq__('decimal')                  == True
#   decimal.__spec__.name.__len__()                          == 7
#
# The ModuleSpec type lives in _frozen_importlib (the frozen bootstrap
# importlib). __spec__.__class__.__module__ == '_frozen_importlib'.
# The spec's name attribute is the module's fully qualified name, 'decimal'.
# 'decimal' has 7 characters.
#
# All three anchors are novel in the decpkg54 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra54.spec_class_identity:
  description: "decimal.__spec__.__class__.__name__.__eq__('ModuleSpec') and __spec__.name identity — decimal.__spec__ is an importlib.machinery.ModuleSpec; __class__.__name__=='ModuleSpec'; __spec__.name=='decimal' (len 7); no prior decimal spec checks any __spec__ attribute; all three novel anchors in decpkg54 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: decpkg54spec

  columns: [id, function, args, expected]
  rows:
    - [spec_class_name,  "__spec__.__class__.__name__.__eq__", ["ModuleSpec"], true]
    - [spec_name_eq,     "__spec__.name.__eq__",               ["decimal"],    true]
    - [spec_name_len,    "__spec__.name.__len__",              [],             7   ]

invariant decimal_extra54.package_eq_empty_string:
  description: "decimal.__package__.__eq__('') == True — decimal is a C-extension module, not a package; __package__ is the empty string; decimal_extra34 noted this value without a spec row; this equality anchor is novel in decpkg54 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant decimal_extra54.Decimal_doc_class_name_len_3:
  description: "decimal.Decimal.__doc__.__class__.__name__.__len__() == 3 — the str type name 'str' has length 3; decimal_extra46 covers Decimal.__doc__.__class__.__name__.__eq__('str') (equality); this __len__()==3 angle is novel in decpkg54 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

invariant decimal_extra54.spec_class_name_ModuleSpec:
  description: "decimal.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — the decimal module's __spec__ is an importlib.machinery.ModuleSpec instance; __class__.__name__=='ModuleSpec'; __class__.__module__=='_frozen_importlib'; no prior decimal spec checks any __spec__ attribute; novel anchor in decpkg54 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant decimal_extra54.spec_name_eq_decimal:
  description: "decimal.__spec__.name.__eq__('decimal') == True — the ModuleSpec name is the module's fully qualified name 'decimal'; no prior decimal spec checks __spec__.name; novel anchor in decpkg54 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["decimal"]
  expected: true
