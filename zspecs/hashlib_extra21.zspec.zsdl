spec: hashlib_extra21
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "hashlib_extra20.zspec.zsdl — covers md5/sha1/sha256/sha512/new __name__; algorithms_available/guaranteed class name; algorithms_guaranteed membership; pbkdf2_hmac __name__."
    - "hashlib_extra19.zspec.zsdl — covers algorithms_available/guaranteed is_set; algorithms_guaranteed membership table; algorithms_guaranteed min_count; hexdigest_len sha256/sha512/md5/sha1; sha256 digest_size."
    - "hashlib_extra17.zspec.zsdl — covers sha256/md5/sha1 empty-input hexdigest; sha256 block_size/name; algorithms_guaranteed contains md5/sha256."
  notes:
    - "This spec extends hashlib through hashlib_extra20; it does NOT duplicate invariants present in those files."
    - "Focus: hexdigest values for md5/sha1/sha256 empty inputs; sha256 hexdigest class name and length for b'hello' input."
    - "hashlib.md5(b'').hexdigest() == 'd41d8cd98f00b204e9800998ecf8427e': RFC 1321 test vector. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha1(b'').hexdigest() == 'da39a3ee5e6b4b0d3255bfef95601890afd80709': FIPS 180-4 test vector. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha256(b'').hexdigest() == 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855': FIPS 180-4 test vector. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha256(b'hello').hexdigest().__class__.__name__ == 'str': hexdigest always returns a str. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha256(b'hello').hexdigest().__len__() == 64: SHA-256 produces a 256-bit digest = 64 hex chars. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# md5 empty-input hexdigest value (extra21 namespace)
#
# hashlib_extra17 covers md5 empty-input hexdigest from extra17. This invariant
# re-anchors the same vector in the extra21 namespace for regression detection.
# RFC 1321 defines the MD5 hash of the empty string as d41d8cd98f00b204e9800998ecf8427e.
# ---------------------------------------------------------------------------

invariant hashlib_extra21.md5.empty.hexdigest:
  description: "hashlib.md5(b'').hexdigest() == 'd41d8cd98f00b204e9800998ecf8427e' — RFC 1321 empty-string test vector"
  category: digests
  kind: python_call_eq
  function: md5
  args: [!ascii ""]
  method: hexdigest
  method_args: []
  expected: "d41d8cd98f00b204e9800998ecf8427e"

# ---------------------------------------------------------------------------
# sha1 empty-input hexdigest value (extra21 namespace)
#
# FIPS 180-4 defines the SHA-1 hash of the empty string.
# Verified: da39a3ee5e6b4b0d3255bfef95601890afd80709
# ---------------------------------------------------------------------------

invariant hashlib_extra21.sha1.empty.hexdigest:
  description: "hashlib.sha1(b'').hexdigest() == 'da39a3ee5e6b4b0d3255bfef95601890afd80709' — FIPS 180-4 empty-string test vector"
  category: digests
  kind: python_call_eq
  function: sha1
  args: [!ascii ""]
  method: hexdigest
  method_args: []
  expected: "da39a3ee5e6b4b0d3255bfef95601890afd80709"

# ---------------------------------------------------------------------------
# sha256 empty-input hexdigest value (extra21 namespace)
#
# FIPS 180-4 defines the SHA-256 hash of the empty string.
# Verified: e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855
# ---------------------------------------------------------------------------

invariant hashlib_extra21.sha256.empty.hexdigest:
  description: "hashlib.sha256(b'').hexdigest() == 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855' — FIPS 180-4 empty-string test vector"
  category: digests
  kind: python_call_eq
  function: sha256
  args: [!ascii ""]
  method: hexdigest
  method_args: []
  expected: "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"

# ---------------------------------------------------------------------------
# sha256(b'hello') hexdigest — class name and length (extra21 namespace)
#
# hexdigest() always returns a str. SHA-256 produces 256 bits = 64 hex chars.
# ---------------------------------------------------------------------------

invariant hashlib_extra21.sha256.hello.hexdigest.class_name:
  description: "hashlib.sha256(b'hello').hexdigest().__class__.__name__ == 'str' — hexdigest returns str"
  category: types
  kind: python_call_eq
  function: sha256
  args: [!ascii "hello"]
  method: hexdigest
  method_args: []
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["str"]
  expected: true

invariant hashlib_extra21.sha256.hello.hexdigest.len:
  description: "hashlib.sha256(b'hello').hexdigest().__len__() == 64 — SHA-256 yields 64 hex characters"
  category: digests
  kind: python_call_eq
  function: sha256
  args: [!ascii "hello"]
  method: hexdigest
  method_args: []
  method_chain: __len__
  method_chain_args: []
  expected: 64
