spec: theseus_decimal_cr
version: ">=3.0"
backend: python_cleanroom(theseus_decimal_cr)
blocks: decimal

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "CPython source: Lib/decimal.py"
  notes:
    - "Clean-room decimal module. Do NOT import decimal."

error_model: python_exceptions

invariant theseus_decimal_cr.decimal2_basic_ops:
  description: "Basic Decimal arithmetic works"
  category: behavior
  kind: python_call_eq
  function: decimal2_basic_ops
  args: []
  expected: true

invariant theseus_decimal_cr.decimal2_precision:
  description: "Decimal precision is controllable via Context"
  category: behavior
  kind: python_call_eq
  function: decimal2_precision
  args: []
  expected: true

invariant theseus_decimal_cr.decimal2_rounding:
  description: "Decimal rounding modes work"
  category: behavior
  kind: python_call_eq
  function: decimal2_rounding
  args: []
  expected: true
