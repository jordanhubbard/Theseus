spec: theseus_annotationlib_cr
version: ">=3.14"
backend: python_cleanroom(theseus_annotationlib_cr)
blocks: annotationlib

docs: https://docs.python.org/3/library/annotationlib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/annotationlib.html"
  not_derived_from:
    - "CPython source: Lib/annotationlib.py"
  notes:
    - "Clean-room annotationlib module. Do NOT import annotationlib."

error_model: python_exceptions

invariant theseus_annotationlib_cr.annotlib2_get_annotations:
  description: "get_annotations() retrieves annotations from a function"
  category: behavior
  kind: python_call_eq
  function: annotlib2_get_annotations
  args: []
  expected: true

invariant theseus_annotationlib_cr.annotlib2_forward_ref:
  description: "ForwardRef class can be instantiated"
  category: behavior
  kind: python_call_eq
  function: annotlib2_forward_ref
  args: []
  expected: true

invariant theseus_annotationlib_cr.annotlib2_format:
  description: "Format enum has VALUE and STRING members"
  category: behavior
  kind: python_call_eq
  function: annotlib2_format
  args: []
  expected: true
