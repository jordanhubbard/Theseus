spec: os_extra19
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "CPython source: Lib/os.py"
    - "os_extra.zspec.zsdl — covers sep/linesep/pathsep/name __class__.__name__ and curdir/pardir/extsep values"
    - "os_extra9.zspec.zsdl — covers sep/__len__==1, linesep/__len__==1, extsep/__len__==1, devnull/__len__==9"
    - "os_extra10.zspec.zsdl — covers sep/curdir/pardir isascii()"
    - "os_extra13.zspec.zsdl — covers pathsep/extsep isascii() and pathsep/__len__==1"
    - "os_extra17.zspec.zsdl — covers sep/extsep/pathsep/linesep/curdir/pardir/devnull values and F_OK/R_OK/W_OK/X_OK"
    - "os_extra18.zspec.zsdl — covers stat/getpid/getcwd/__class__.__name__, getuid/getgid __name__/__qualname__, getenv/__qualname__"
  notes:
    - "This spec extends os.zspec.zsdl and prior extras through os_extra18.zspec.zsdl."
    - "No prior os spec covers os.curdir.__class__.__name__ == 'str'."
    - "No prior os spec covers os.pardir.__class__.__name__ == 'str'."
    - "No prior os spec covers os.extsep.__class__.__name__ == 'str'."
    - "No prior os spec covers os.curdir.__len__() == 1 — curdir '.' is one character."
    - "No prior os spec covers os.pardir.__len__() == 2 — pardir '..' is two characters."
    - "No prior os spec covers os.devnull.__class__.__name__ == 'str' as a named invariant in this series."
    - "No prior os spec covers os.sep.__contains__('/') == True — sep is the '/' character."
    - "No prior os spec covers os.name.__len__() == 5 on POSIX — 'posix' has 5 characters."
    - "No prior os spec covers os.devnull.__contains__('null') == True."
    - "No prior os spec covers os.extsep.__contains__('.') == True."
    - "os.curdir == '.', so curdir.__len__() == 1 and curdir.__class__.__name__ == 'str'."
    - "os.pardir == '..', so pardir.__len__() == 2 and pardir.__class__.__name__ == 'str'."
    - "os.extsep == '.', so extsep.__class__.__name__ == 'str' and extsep.__contains__('.') == True."
    - "os.name == 'posix' on POSIX platforms; 'posix' has len 5."
    - "os.sep == '/', so sep.__contains__('/') == True."
    - "os.devnull == '/dev/null' on POSIX; contains the substring 'null'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# os path constant string type checks — curdir, pardir, extsep
#
# os_extra covers sep/linesep/pathsep/name __class__.__name__ == 'str'.
# os_extra2 covers devnull.__class__.__name__ == 'str'.
# No prior spec covers curdir.__class__.__name__, pardir.__class__.__name__,
# or extsep.__class__.__name__. All three are always str on every platform.
# ---------------------------------------------------------------------------

table os_extra19.constant_class_names:
  description: "__class__.__name__ == 'str' for os path constants curdir, pardir, extsep"
  kind: python_call_eq
  category: constant_types

  columns: [id, function, args, expected]
  rows:
    - [curdir, curdir.__class__.__name__.__eq__, ["str"], true]
    - [pardir, pardir.__class__.__name__.__eq__, ["str"], true]
    - [extsep, extsep.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# os path constant length checks — curdir and pardir
#
# os_extra9 covers sep/__len__==1, linesep/__len__==1, extsep/__len__==1,
# devnull/__len__==9. os_extra13 covers pathsep/__len__==1.
# No prior spec covers curdir.__len__() or pardir.__len__().
# os.curdir == '.' (1 character); os.pardir == '..' (2 characters).
# ---------------------------------------------------------------------------

invariant os_extra19.curdir.len:
  description: "os.curdir.__len__() == 1 — curdir '.' is a single character"
  category: constant_lengths
  kind: python_call_eq
  function: curdir.__len__
  args: []
  expected: 1

invariant os_extra19.pardir.len:
  description: "os.pardir.__len__() == 2 — pardir '..' is two characters"
  category: constant_lengths
  kind: python_call_eq
  function: pardir.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# os.name length check
#
# os_extra covers name.__class__.__name__ == 'str'.
# os.zspec.zsdl and os_extra10 cover name.__eq__('posix').
# No prior spec covers name.__len__() == 5 — 'posix' is five characters.
# ---------------------------------------------------------------------------

invariant os_extra19.name.len:
  description: "os.name.__len__() == 5 on POSIX — 'posix' is five characters"
  category: constant_lengths
  kind: python_call_eq
  function: name.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# os constant __contains__ checks
#
# No prior os spec covers sep.__contains__('/'), extsep.__contains__('.'),
# or devnull.__contains__('null'). These complement the value-equality checks
# already in os_extra17 with a new membership-testing axis.
# ---------------------------------------------------------------------------

invariant os_extra19.sep.contains_slash:
  description: "os.sep.__contains__('/') == True — sep is the slash character on POSIX"
  category: constant_contains
  kind: python_call_eq
  function: sep.__contains__
  args: ["/"]
  expected: true

invariant os_extra19.extsep.contains_dot:
  description: "os.extsep.__contains__('.') == True — extsep is the dot character"
  category: constant_contains
  kind: python_call_eq
  function: extsep.__contains__
  args: ["."]
  expected: true

invariant os_extra19.devnull.contains_null:
  description: "os.devnull.__contains__('null') == True — devnull path includes the word 'null'"
  category: constant_contains
  kind: python_call_eq
  function: devnull.__contains__
  args: ["null"]
  expected: true

# ---------------------------------------------------------------------------
# os constant startswith checks — curdir and pardir
#
# No prior spec checks curdir.startswith('.') or pardir.startswith('.').
# Both curdir '.' and pardir '..' start with the dot character.
# ---------------------------------------------------------------------------

invariant os_extra19.curdir.startswith_dot:
  description: "os.curdir.startswith('.') == True — curdir begins with a dot"
  category: constant_startswith
  kind: python_call_eq
  function: curdir.startswith
  args: ["."]
  expected: true

invariant os_extra19.pardir.startswith_dot:
  description: "os.pardir.startswith('.') == True — pardir begins with a dot"
  category: constant_startswith
  kind: python_call_eq
  function: pardir.startswith
  args: ["."]
  expected: true

# ---------------------------------------------------------------------------
# os.linesep and os.pathsep — upper/lower case identity checks
#
# No prior spec covers linesep.__lower__()==linesep or pathsep-based
# string method checks. On POSIX, linesep=='\n' and pathsep==':'.
# Both are non-alphabetic, so swapcase() and lower() return them unchanged.
# This provides a new string-method axis for these constants.
# ---------------------------------------------------------------------------

invariant os_extra19.linesep.strip_eq:
  description: "os.linesep.strip() == '' — stripping linesep '\\n' leaves empty string"
  category: constant_string_methods
  kind: python_call_eq
  function: linesep.strip
  args: []
  expected: ""

invariant os_extra19.pathsep.strip_noop:
  description: "os.pathsep.strip() == ':' — strip on a non-whitespace char is a no-op"
  category: constant_string_methods
  kind: python_call_eq
  function: pathsep.strip
  args: []
  expected: ":"
