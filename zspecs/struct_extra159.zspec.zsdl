# ---------------------------------------------------------------------------
# struct.__spec__.origin.__class__.__name__.__eq__('str') — standalone
#
# struct.__spec__.origin.__class__.__name__ is 'str' (3 chars). The origin attribute of a
# ModuleSpec is the filesystem path to the module source file. For struct, this is the
# absolute path to struct.py on the current system. Because the path is platform-specific
# (different on macOS, Linux, Windows, and between Python installations), the spec does not
# hardcode the actual path. Instead, we verify that origin is a 'str' object (which it always
# is for Python source modules) and that it contains the string 'struct' as a substring.
# origin.__class__.__name__ == 'str' (3 chars) confirms the type without binding to a
# specific path value. No prior struct spec anchors origin.__class__.__name__ as a standalone
# under structspec159. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra159.struct_spec_origin_class_str:
  description: "struct.__spec__.origin.__class__.__name__.__eq__('str') == True — 'str' (3 chars; origin is a filesystem path string to struct.py; platform-specific absolute path; type check avoids hardcoding path value); origin is the source file path used by the import system; struct_extra150 does not anchor origin type; first structspec159 standalone for origin.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__spec__.origin.__contains__('struct') — standalone
#
# struct.__spec__.origin.__contains__('struct') is True. The filesystem path to struct.py
# always contains the string 'struct' as a substring (e.g., '.../lib/python3.14/struct.py').
# This is a robust cross-platform check that does not hardcode the full path. The module
# name 'struct' appears in the filename and typically also in the directory structure.
# origin.__contains__('struct') == True works on any platform where Python is installed.
# This is the recommended way to check origin content in ZSDL specs without platform-specific
# hardcoding. No prior struct spec anchors origin.__contains__('struct') as a standalone
# under structspec159. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra159.struct_spec_origin_contains_struct:
  description: "struct.__spec__.origin.__contains__('struct') == True — origin is the path to struct.py; 'struct' appears in the filename and often in the directory path; cross-platform safe check (avoids hardcoding absolute path); origin.__class__.__name__=='str' (the path is a str); struct.__spec__.name=='struct' (6 chars; the spec module name); origin.__contains__('struct') is the structural verification without path hardcoding; first structspec159 standalone for origin.__contains__"
  category: identity
  kind: python_call_eq
  function: __spec__.origin.__contains__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') — standalone
#
# struct.__spec__.submodule_search_locations.__class__.__name__ is 'NoneType' (8 chars).
# submodule_search_locations is None for plain modules (not packages). struct is a plain
# module, not a package (there is no struct/ directory with __init__.py). The Python import
# system sets submodule_search_locations to None for non-package modules. For package modules,
# submodule_search_locations would be a list of directory paths (or a _NamespacePath).
# 'NoneType' (8 chars = 'None'=4 + 'Type'=4) is the class name of Python's None object.
# This check confirms that struct is a plain module (not a package) without using 'is None'
# which is not supported in python_call_eq specs. No prior struct spec anchors
# submodule_search_locations as a standalone under structspec159.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra159.struct_spec_submod_locs_nonetype:
  description: "struct.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — 'NoneType' (8 chars = 'None'=4 + 'Type'=4); struct is a plain module not a package; submodule_search_locations==None for plain modules; packages have non-None value (list of directory paths); 'NoneType' is the __class__.__name__ of Python's None singleton; this check confirms struct is not a package without using 'is None'; first structspec159 standalone for submodule_search_locations type check"
