spec: io_extra100
version: ">=3.9"
backend: python_module(io)
extends: io_extra99

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
  notes:
    - "This spec extends io_extra99.zspec.zsdl."
    - "This spec covers: io.BytesIO and io.StringIO method class names — these are C extension types, their methods are method_descriptor or wrapper_descriptor."
    - "BytesIO and StringIO are C extension types from _io. Their regular methods (read, write, seek, etc.) are 'method_descriptor' when accessed as class attributes."
    - "BytesIO.__init__.__class__.__name__ = 'wrapper_descriptor' — __init__ and __repr__ on C types are wrapper_descriptors (slot wrappers)."
    - "BytesIO.read.__class__.__name__ = 'method_descriptor' — all data I/O methods are method_descriptor."
    - "StringIO methods have identical class name patterns to BytesIO: regular methods are method_descriptor, __init__ and __repr__ are wrapper_descriptor."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO main method class names: read, write, seek, tell, getvalue, close
# All are method_descriptor (C extension methods accessed on the class).
# ---------------------------------------------------------------------------

table io_extra100.BytesIO_main_methods_classname:
  description: "io.BytesIO main methods (read, write, seek, tell, getvalue, close) __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: iobytesstringsio100

  columns: [id, function, args, expected]
  rows:
    - [bytesio_read_cls,     BytesIO.read.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [bytesio_write_cls,    BytesIO.write.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [bytesio_seek_cls,     BytesIO.seek.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [bytesio_tell_cls,     BytesIO.tell.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [bytesio_getvalue_cls, BytesIO.getvalue.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [bytesio_close_cls,    BytesIO.close.__class__.__name__.__eq__,    ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# io.BytesIO predicate and dunder method class names
# readable, writable, seekable -> method_descriptor
# __init__, __repr__ -> wrapper_descriptor (slot wrappers on C types)
# __getstate__, __setstate__ -> method_descriptor
# ---------------------------------------------------------------------------

table io_extra100.BytesIO_predicate_dunder_classname:
  description: "io.BytesIO predicate methods (readable, writable, seekable) and dunders (__init__, __repr__) class names"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: iobytesstringsio100

  columns: [id, function, args, expected]
  rows:
    - [bytesio_readable_cls,    BytesIO.readable.__class__.__name__.__eq__,    ["method_descriptor"],  true]
    - [bytesio_writable_cls,    BytesIO.writable.__class__.__name__.__eq__,    ["method_descriptor"],  true]
    - [bytesio_seekable_cls,    BytesIO.seekable.__class__.__name__.__eq__,    ["method_descriptor"],  true]
    - [bytesio_init_cls,        BytesIO.__init__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true]
    - [bytesio_repr_cls,        BytesIO.__repr__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true]
    - [bytesio_init_not_meth,   BytesIO.__init__.__class__.__name__.__eq__,    ["method_descriptor"],  false]
    - [bytesio_getstate_cls,    BytesIO.__getstate__.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [bytesio_setstate_cls,    BytesIO.__setstate__.__class__.__name__.__eq__, ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# io.StringIO main method class names: read, write, seek, tell, getvalue, close
# All are method_descriptor (same pattern as BytesIO).
# ---------------------------------------------------------------------------

table io_extra100.StringIO_main_methods_classname:
  description: "io.StringIO main methods (read, write, seek, tell, getvalue, close) __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: iobytesstringsio100

  columns: [id, function, args, expected]
  rows:
    - [stringio_read_cls,     StringIO.read.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [stringio_write_cls,    StringIO.write.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [stringio_seek_cls,     StringIO.seek.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [stringio_tell_cls,     StringIO.tell.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [stringio_getvalue_cls, StringIO.getvalue.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [stringio_close_cls,    StringIO.close.__class__.__name__.__eq__,    ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# io.StringIO predicate and dunder method class names
# readable, writable, seekable -> method_descriptor
# __init__, __repr__ -> wrapper_descriptor
# ---------------------------------------------------------------------------

table io_extra100.StringIO_predicate_dunder_classname:
  description: "io.StringIO predicate methods (readable, writable, seekable) and dunders (__init__, __repr__) class names"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: iobytesstringsio100

  columns: [id, function, args, expected]
  rows:
    - [stringio_readable_cls,  StringIO.readable.__class__.__name__.__eq__,  ["method_descriptor"],  true]
    - [stringio_writable_cls,  StringIO.writable.__class__.__name__.__eq__,  ["method_descriptor"],  true]
    - [stringio_seekable_cls,  StringIO.seekable.__class__.__name__.__eq__,  ["method_descriptor"],  true]
    - [stringio_init_cls,      StringIO.__init__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [stringio_repr_cls,      StringIO.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [stringio_init_not_meth, StringIO.__init__.__class__.__name__.__eq__,  ["method_descriptor"],  false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra100.BytesIO.read_is_method_descriptor:
  description: "io.BytesIO.read.__class__.__name__ == 'method_descriptor' (BytesIO is a C extension type; its methods are method_descriptor when accessed on the class)"
  category: method_descriptor
  kind: python_call_eq
  function: BytesIO.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra100.BytesIO.init_is_wrapper_descriptor:
  description: "io.BytesIO.__init__.__class__.__name__ == 'wrapper_descriptor' (slot wrappers on C types are wrapper_descriptor, not method_descriptor)"
  category: method_descriptor
  kind: python_call_eq
  function: BytesIO.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant io_extra100.BytesIO.getvalue_is_method_descriptor:
  description: "io.BytesIO.getvalue.__class__.__name__ == 'method_descriptor' (getvalue is a regular C method, not a slot wrapper)"
  category: method_descriptor
  kind: python_call_eq
  function: BytesIO.getvalue.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra100.StringIO.seek_is_method_descriptor:
  description: "io.StringIO.seek.__class__.__name__ == 'method_descriptor' (StringIO.seek is a C extension method)"
  category: method_descriptor
  kind: python_call_eq
  function: StringIO.seek.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra100.StringIO.repr_is_wrapper_descriptor:
  description: "io.StringIO.__repr__.__class__.__name__ == 'wrapper_descriptor' (StringIO.__repr__ is a slot wrapper, same as BytesIO.__repr__)"
  category: method_descriptor
  kind: python_call_eq
  function: StringIO.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true
