spec: concurrent_futures_extra1501
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "Wave 547 theme: async protocol method __dict__ presence checks. concurrent.futures is a sync-only module — none of its classes define __await__, __aenter__, __aexit__, __aiter__, or __anext__ in their own __dict__."
    - "concurrent.futures.Future is a SYNC future — it is NOT awaitable and has no __await__ in its __dict__. This contrasts sharply with asyncio.Future which defines __await__ directly."
    - "concurrent.futures.Executor defines __aenter__ and __aexit__ — but NOT in its own __dict__; these are NOT present in Executor.__dict__ (verified). The Executor ABC does not implement the async context manager protocol."
    - "concurrent.futures.ThreadPoolExecutor and ProcessPoolExecutor do NOT define any async protocol methods in their own __dict__."
    - "The key invariant for wave 547 in this module: all async protocol checks return False — none of __await__, __aenter__, __aexit__, __aiter__, __anext__ appear in the __dict__ of any concurrent.futures class."
    - "concurrent.futures.Future.__dict__ contains sync methods: result, exception, cancel, done, running, add_done_callback, set_result, set_exception — all synchronous."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.Future has no async protocol in __dict__
#
# concurrent.futures.Future.__dict__.__contains__('__await__')  == False
# concurrent.futures.Future.__dict__.__contains__('__aenter__') == False
# concurrent.futures.Future.__dict__.__contains__('__aexit__')  == False
# concurrent.futures.Future.__dict__.__contains__('__aiter__')  == False
# concurrent.futures.Future.__dict__.__contains__('__anext__')  == False
# concurrent.futures.Future.__dict__.__contains__('result')     == True  (sync)
# ---------------------------------------------------------------------------

table concurrent_futures_extra1501.cf_future_no_async_protocol:
  description: "concurrent.futures.Future has no async protocol methods in its own __dict__ — cf1501ft namespace. concurrent.futures.Future.__dict__.__contains__('__await__')==False (cf.Future is a SYNCHRONOUS future — it is not awaitable; unlike asyncio.Future which defines __await__ in its own __dict__, cf.Future has no __await__; cf.Future.result() blocks the calling thread until the result is available); concurrent.futures.Future.__dict__.__contains__('__aenter__')==False (cf.Future is not an async context manager; there is no 'async with future:' idiom for cf.Future); concurrent.futures.Future.__dict__.__contains__('__aexit__')==False (no async exit protocol on cf.Future); concurrent.futures.Future.__dict__.__contains__('__aiter__')==False (cf.Future is not an async iterator); concurrent.futures.Future.__dict__.__contains__('__anext__')==False (no async iteration on cf.Future); concurrent.futures.Future.__dict__.__contains__('result')==True (cf.Future.result() IS defined directly in cf.Future.__dict__ — it is the synchronous method that blocks until the future completes); verified with Python 3.14.4"
  kind: python_call_eq
  category: async_protocol
  id_prefix: cf1501ft

  columns: [id, function, args, expected, description]
  rows:
    - [cf1501ft001, concurrent.futures.Future.__dict__.__contains__, ["__await__"],  false, "cf.Future.__dict__.__contains__('__await__')==False — cf.Future is sync-only, not awaitable; contrast asyncio.Future which defines __await__; verified with Python 3.14.4"]
    - [cf1501ft002, concurrent.futures.Future.__dict__.__contains__, ["__aenter__"], false, "cf.Future.__dict__.__contains__('__aenter__')==False — cf.Future is not an async context manager; verified with Python 3.14.4"]
    - [cf1501ft003, concurrent.futures.Future.__dict__.__contains__, ["__aexit__"],  false, "cf.Future.__dict__.__contains__('__aexit__')==False — no async exit protocol on cf.Future; verified with Python 3.14.4"]
    - [cf1501ft004, concurrent.futures.Future.__dict__.__contains__, ["__aiter__"],  false, "cf.Future.__dict__.__contains__('__aiter__')==False — cf.Future is not an async iterator; verified with Python 3.14.4"]
    - [cf1501ft005, concurrent.futures.Future.__dict__.__contains__, ["__anext__"],  false, "cf.Future.__dict__.__contains__('__anext__')==False — no async iteration on cf.Future; verified with Python 3.14.4"]
    - [cf1501ft006, concurrent.futures.Future.__dict__.__contains__, ["result"],     true,  "cf.Future.__dict__.__contains__('result')==True — Future.result() is a sync method defined directly in cf.Future.__dict__; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures.Executor and subclasses have no async protocol
#
# concurrent.futures.Executor.__dict__.__contains__('__await__')         == False
# concurrent.futures.Executor.__dict__.__contains__('__aenter__')        == False
# concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__aenter__') == False
# concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__aenter__') == False
# concurrent.futures.Executor.__dict__.__contains__('submit')            == True  (sync)
# concurrent.futures.Executor.__dict__.__contains__('map')               == True  (sync)
# ---------------------------------------------------------------------------

table concurrent_futures_extra1501.cf_executor_no_async_protocol:
  description: "concurrent.futures.Executor and its subclasses have no async protocol in __dict__ — cf1501ex namespace. concurrent.futures.Executor.__dict__.__contains__('__await__')==False (Executor is a sync-only abstract base class for thread/process pool executors; not awaitable); concurrent.futures.Executor.__dict__.__contains__('__aenter__')==False (Executor does NOT define __aenter__ in its own __dict__; the executor can be used as a sync context manager via __enter__/__exit__ but not async context manager); concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__aenter__')==False (ThreadPoolExecutor does not define __aenter__ in its own __dict__); concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__aenter__')==False (ProcessPoolExecutor does not define __aenter__ in its own __dict__); concurrent.futures.Executor.__dict__.__contains__('submit')==True (Executor.submit() is defined directly in Executor — no, actually submit is abstract; this confirms sync-only interface); concurrent.futures.Executor.__dict__.__contains__('map')==True (Executor.map() is defined directly in Executor.__dict__ as a synchronous method); verified with Python 3.14.4"
  kind: python_call_eq
  category: async_protocol
  id_prefix: cf1501ex

  columns: [id, function, args, expected, description]
  rows:
    - [cf1501ex001, concurrent.futures.Executor.__dict__.__contains__,             ["__await__"],  false, "Executor.__dict__.__contains__('__await__')==False — sync-only executor base class; verified with Python 3.14.4"]
    - [cf1501ex002, concurrent.futures.Executor.__dict__.__contains__,             ["__aenter__"], false, "Executor.__dict__.__contains__('__aenter__')==False — Executor is not an async context manager; verified with Python 3.14.4"]
    - [cf1501ex003, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,   ["__aenter__"], false, "ThreadPoolExecutor.__dict__.__contains__('__aenter__')==False — no async protocol in ThreadPoolExecutor; verified with Python 3.14.4"]
    - [cf1501ex004, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__,  ["__aenter__"], false, "ProcessPoolExecutor.__dict__.__contains__('__aenter__')==False — no async protocol in ProcessPoolExecutor; verified with Python 3.14.4"]
    - [cf1501ex005, concurrent.futures.Executor.__dict__.__contains__,             ["__aexit__"],  false, "Executor.__dict__.__contains__('__aexit__')==False — no async exit protocol on Executor; verified with Python 3.14.4"]
    - [cf1501ex006, concurrent.futures.Executor.__dict__.__contains__,             ["map"],        true,  "Executor.__dict__.__contains__('map')==True — Executor.map() is a sync method defined in Executor.__dict__; confirmed sync-only interface; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 3: Cross-module contrast — cf.Future vs asyncio.Future async protocol
#
# concurrent.futures.Future.__dict__.__contains__('__await__')  == False
# asyncio.Future.__dict__.__contains__('__await__')             == True
# concurrent.futures.Future.__dict__.__contains__('__aenter__') == False
# asyncio.TaskGroup.__dict__.__contains__('__aenter__')         == True
# concurrent.futures.Future.__dict__.__contains__('__aiter__')  == False
# asyncio.StreamReader.__dict__.__contains__('__aiter__')       == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra1501.cf_vs_asyncio_async_contrast:
  description: "Cross-module contrast: concurrent.futures classes vs asyncio classes for async protocol __dict__ presence — cf1501xc namespace. concurrent.futures.Future.__dict__.__contains__('__await__')==False (cf.Future is sync-only; no __await__ in __dict__); asyncio.Future.__dict__.__contains__('__await__')==True (asyncio.Future is awaitable; defines __await__ in C-level __dict__); this is the sharpest contrast between the two Future classes — cf.Future blocks calling threads while asyncio.Future integrates with the event loop via __await__; concurrent.futures.Future.__dict__.__contains__('__aenter__')==False (cf.Future has no async context manager protocol); asyncio.TaskGroup.__dict__.__contains__('__aenter__')==True (asyncio.TaskGroup IS an async context manager with __aenter__ in its own __dict__); concurrent.futures.Future.__dict__.__contains__('__aiter__')==False (no async iteration on cf.Future); asyncio.StreamReader.__dict__.__contains__('__aiter__')==True (asyncio.StreamReader IS an async iterator with __aiter__ in its own __dict__); these contrasts illustrate the fundamental sync/async divide between the two modules; verified with Python 3.14.4"
  kind: python_call_eq
  category: async_protocol
  id_prefix: cf1501xc

  columns: [id, function, args, expected, description]
  rows:
    - [cf1501xc001, concurrent.futures.Future.__dict__.__contains__, ["__await__"],  false, "cf.Future.__dict__.__contains__('__await__')==False — sync future; contrast asyncio.Future which IS True; verified with Python 3.14.4"]
    - [cf1501xc002, asyncio.Future.__dict__.__contains__,            ["__await__"],  true,  "asyncio.Future.__dict__.__contains__('__await__')==True — async future; contrast cf.Future which is False; verified with Python 3.14.4"]
    - [cf1501xc003, concurrent.futures.Future.__dict__.__contains__, ["__aenter__"], false, "cf.Future.__dict__.__contains__('__aenter__')==False — no async ctx manager; contrast asyncio.TaskGroup which is True; verified with Python 3.14.4"]
    - [cf1501xc004, asyncio.TaskGroup.__dict__.__contains__,         ["__aenter__"], true,  "asyncio.TaskGroup.__dict__.__contains__('__aenter__')==True — async ctx manager; contrast cf.Future which is False; verified with Python 3.14.4"]
    - [cf1501xc005, concurrent.futures.Future.__dict__.__contains__, ["__aiter__"],  false, "cf.Future.__dict__.__contains__('__aiter__')==False — no async iteration; contrast asyncio.StreamReader which is True; verified with Python 3.14.4"]
    - [cf1501xc006, asyncio.StreamReader.__dict__.__contains__,      ["__aiter__"],  true,  "asyncio.StreamReader.__dict__.__contains__('__aiter__')==True — async iterator; contrast cf.Future which is False; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1501
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra1501.cf_future_no_await:
  description: "concurrent.futures.Future.__dict__.__contains__('__await__') returns False — concurrent.futures.Future is a synchronous future class; it does NOT define __await__ in its own __dict__; cf.Future.result() blocks the calling thread (synchronously) until the computation completes — it has no event-loop integration; this is the fundamental distinction from asyncio.Future which defines __await__ and integrates with the asyncio event loop; wave 547 theme: async protocol __dict__ presence; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: async_protocol
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant concurrent_futures_extra1501.cf_future_no_aenter:
  description: "concurrent.futures.Future.__dict__.__contains__('__aenter__') returns False — concurrent.futures.Future does not define __aenter__ in its own __dict__; cf.Future is not an async context manager; the concurrent.futures module is entirely synchronous — none of its public classes (Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor) define any async protocol methods; wave 547 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: async_protocol
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["__aenter__"]
  expected: false

invariant concurrent_futures_extra1501.cf_executor_no_await:
  description: "concurrent.futures.Executor.__dict__.__contains__('__await__') returns False — concurrent.futures.Executor is the abstract base class for thread and process pool executors; it does not define __await__ in its own __dict__; Executor is entirely synchronous — its submit() method returns a cf.Future (sync), and its map() method is a synchronous generator; wave 547 theme: async protocol __dict__ presence; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: async_protocol
  kind: python_call_eq
  function: concurrent.futures.Executor.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant concurrent_futures_extra1501.cf_threadpool_no_aenter:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__aenter__') returns False — ThreadPoolExecutor does not define __aenter__ in its own __dict__; while ThreadPoolExecutor supports the sync context manager protocol ('with ThreadPoolExecutor() as ex:'), it does not support the async context manager protocol ('async with'); __aenter__ is not in ThreadPoolExecutor.__dict__; wave 547 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: async_protocol
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__dict__.__contains__
  args: ["__aenter__"]
  expected: false
