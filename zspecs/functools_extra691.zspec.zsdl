spec: functools_extra691
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers partialmethod attribute descriptors and cached_property identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra691.partialmethod_descriptors:
  description: "functools.partialmethod attribute descriptor class names and qualnames"
  kind: python_call_eq
  category: partialmethod_attrs
  id_prefix: ft691pm
  columns: [id, function, args, expected]
  rows:
    - [ft691pm001, functools.partialmethod.func.__class__.__name__.__eq__, ["property"], true]
    - [ft691pm002, functools.partialmethod.args.__class__.__name__.__eq__, ["property"], true]
    - [ft691pm003, functools.partialmethod.keywords.__class__.__name__.__eq__, ["property"], true]
    - [ft691pm004, functools.partialmethod.func.__qualname__.__eq__, ["partialmethod.func"], true]
    - [ft691pm005, functools.partialmethod.args.__qualname__.__eq__, ["partialmethod.args"], true]
    - [ft691pm006, functools.partialmethod.keywords.__qualname__.__eq__, ["partialmethod.keywords"], true]

table functools_extra691.partialmethod_identity:
  description: "functools.partialmethod class-level identity attributes"
  kind: python_call_eq
  category: partialmethod_identity
  id_prefix: ft691pi
  columns: [id, function, args, expected]
  rows:
    - [ft691pi001, functools.partialmethod.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ft691pi002, functools.partialmethod.__qualname__.__eq__, ["partialmethod"], true]
    - [ft691pi003, functools.partialmethod.__module__.__eq__, ["functools"], true]

table functools_extra691.cached_property_identity:
  description: "functools.cached_property class-level identity attributes"
  kind: python_call_eq
  category: cached_property_identity
  id_prefix: ft691cp
  columns: [id, function, args, expected]
  rows:
    - [ft691cp001, functools.cached_property.attrname.__class__.__name__.__eq__, ["NoneType"], true]
    - [ft691cp002, functools.cached_property.__qualname__.__eq__, ["cached_property"], true]
    - [ft691cp003, functools.cached_property.__module__.__eq__, ["functools"], true]
