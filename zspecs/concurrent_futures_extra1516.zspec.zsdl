spec: concurrent_futures_extra1516
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "Wave 548 theme: arithmetic/numeric operator protocol dict-presence checks — __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__ in class __dict__."
    - "concurrent.futures is a thread/process pool executor module — not a numeric library. None of Future, Executor, ThreadPoolExecutor, or ProcessPoolExecutor define arithmetic operator protocol methods in their own __dict__."
    - "concurrent.futures.Future is a SYNCHRONOUS result container — its interface is result(), exception(), cancel(), done(), running(), cancelled(), add_done_callback(). No arithmetic operators apply to a sync future."
    - "concurrent.futures.Executor is an abstract base class for thread and process pools — submit(), map(), shutdown() are its interface, not arithmetic operations."
    - "concurrent.futures.ThreadPoolExecutor manages a pool of threads to execute callables — no arithmetic operators in its __dict__."
    - "concurrent.futures.ProcessPoolExecutor manages a pool of processes — no arithmetic operators in its __dict__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.Future arithmetic operator __dict__ absence
#
# concurrent.futures.Future.__dict__.__contains__('__add__')      == False
# concurrent.futures.Future.__dict__.__contains__('__mul__')      == False
# concurrent.futures.Future.__dict__.__contains__('__sub__')      == False
# concurrent.futures.Future.__dict__.__contains__('__truediv__')  == False
# concurrent.futures.Future.__dict__.__contains__('__floordiv__') == False
# concurrent.futures.Future.__dict__.__contains__('__mod__')      == False
# concurrent.futures.Future.__dict__.__contains__('cancel')       == True  (sync method)
# ---------------------------------------------------------------------------

table concurrent_futures_extra1516.cf_future_no_arithmetic_ops:
  description: "concurrent.futures.Future has no arithmetic operator methods in its own __dict__ — cf1516ft namespace. concurrent.futures.Future.__dict__.__contains__('__add__')==False (cf.Future is a sync result container — it represents the result of a callable submitted to an Executor; its interface is result(), exception(), cancel(), done(), running(); no arithmetic operators apply to a future result container); concurrent.futures.Future.__dict__.__contains__('__mul__')==False (no multiplication on cf.Future — multiplying a future object is semantically undefined); concurrent.futures.Future.__dict__.__contains__('__sub__')==False (no subtraction on cf.Future); concurrent.futures.Future.__dict__.__contains__('__truediv__')==False (no true division on cf.Future); concurrent.futures.Future.__dict__.__contains__('__floordiv__')==False (no floor division on cf.Future); concurrent.futures.Future.__dict__.__contains__('__mod__')==False (no modulo on cf.Future); concurrent.futures.Future.__dict__.__contains__('cancel')==True (cf.Future.cancel() IS defined directly in cf.Future.__dict__ — it attempts to cancel the future if it has not yet started executing; returns True if successfully cancelled); verified with Python 3.14.4"
  kind: python_call_eq
  category: arithmetic_protocol
  id_prefix: cf1516ft

  columns: [id, function, args, expected, description]
  rows:
    - [cf1516ft001, concurrent.futures.Future.__dict__.__contains__, ["__add__"],      false, "cf.Future.__dict__.__contains__('__add__')==False — sync result container, not numeric; no __add__ in __dict__; verified with Python 3.14.4"]
    - [cf1516ft002, concurrent.futures.Future.__dict__.__contains__, ["__mul__"],      false, "cf.Future.__dict__.__contains__('__mul__')==False — no multiplication on cf.Future; verified with Python 3.14.4"]
    - [cf1516ft003, concurrent.futures.Future.__dict__.__contains__, ["__sub__"],      false, "cf.Future.__dict__.__contains__('__sub__')==False — no subtraction on cf.Future; verified with Python 3.14.4"]
    - [cf1516ft004, concurrent.futures.Future.__dict__.__contains__, ["__truediv__"],  false, "cf.Future.__dict__.__contains__('__truediv__')==False — no true division on cf.Future; verified with Python 3.14.4"]
    - [cf1516ft005, concurrent.futures.Future.__dict__.__contains__, ["__floordiv__"], false, "cf.Future.__dict__.__contains__('__floordiv__')==False — no floor division on cf.Future; verified with Python 3.14.4"]
    - [cf1516ft006, concurrent.futures.Future.__dict__.__contains__, ["__mod__"],      false, "cf.Future.__dict__.__contains__('__mod__')==False — no modulo on cf.Future; verified with Python 3.14.4"]
    - [cf1516ft007, concurrent.futures.Future.__dict__.__contains__, ["cancel"],       true,  "cf.Future.__dict__.__contains__('cancel')==True — Future.cancel() is defined directly in cf.Future.__dict__; attempts to cancel a pending future; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures.Executor arithmetic operator __dict__ absence
#
# concurrent.futures.Executor.__dict__.__contains__('__add__')             == False
# concurrent.futures.Executor.__dict__.__contains__('__mul__')             == False
# concurrent.futures.Executor.__dict__.__contains__('__pow__')             == False
# concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__add__')   == False
# concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__mul__')  == False
# concurrent.futures.Executor.__dict__.__contains__('map')                 == True  (sync method)
# concurrent.futures.Executor.__dict__.__contains__('shutdown')            == True  (sync method)
# ---------------------------------------------------------------------------

table concurrent_futures_extra1516.cf_executor_no_arithmetic_ops:
  description: "concurrent.futures.Executor and its subclasses have no arithmetic operators in their own __dict__ — cf1516ex namespace. concurrent.futures.Executor.__dict__.__contains__('__add__')==False (Executor is the abstract base class for thread/process pool executors; its __dict__ contains submit(), map(), shutdown() — all executor management methods; no arithmetic operators; combining executors via addition is undefined); concurrent.futures.Executor.__dict__.__contains__('__mul__')==False (no multiplication on Executor — Executor manages a pool of workers, not a numeric value); concurrent.futures.Executor.__dict__.__contains__('__pow__')==False (no exponentiation on Executor); concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__add__')==False (ThreadPoolExecutor extends Executor with thread pool management; no arithmetic operators in its __dict__); concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__mul__')==False (ProcessPoolExecutor manages a pool of processes; no multiplication operator defined); concurrent.futures.Executor.__dict__.__contains__('map')==True (Executor.map() IS defined directly in Executor.__dict__ — it maps a callable over an iterable in parallel using the pool and returns an iterator of results; synchronous interface); concurrent.futures.Executor.__dict__.__contains__('shutdown')==True (Executor.shutdown() IS defined directly in Executor.__dict__ — it signals the executor to free resources when all futures are done); verified with Python 3.14.4"
  kind: python_call_eq
  category: arithmetic_protocol
  id_prefix: cf1516ex

  columns: [id, function, args, expected, description]
  rows:
    - [cf1516ex001, concurrent.futures.Executor.__dict__.__contains__,            ["__add__"],  false, "Executor.__dict__.__contains__('__add__')==False — abstract executor base class, not numeric; no __add__; verified with Python 3.14.4"]
    - [cf1516ex002, concurrent.futures.Executor.__dict__.__contains__,            ["__mul__"],  false, "Executor.__dict__.__contains__('__mul__')==False — no multiplication on Executor; verified with Python 3.14.4"]
    - [cf1516ex003, concurrent.futures.Executor.__dict__.__contains__,            ["__pow__"],  false, "Executor.__dict__.__contains__('__pow__')==False — no exponentiation on Executor; verified with Python 3.14.4"]
    - [cf1516ex004, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["__add__"],  false, "ThreadPoolExecutor.__dict__.__contains__('__add__')==False — thread pool executor, not numeric; no __add__; verified with Python 3.14.4"]
    - [cf1516ex005, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__mul__"],  false, "ProcessPoolExecutor.__dict__.__contains__('__mul__')==False — process pool executor, not numeric; no __mul__; verified with Python 3.14.4"]
    - [cf1516ex006, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__sub__"],  false, "ProcessPoolExecutor.__dict__.__contains__('__sub__')==False — no subtraction on ProcessPoolExecutor; verified with Python 3.14.4"]
    - [cf1516ex007, concurrent.futures.Executor.__dict__.__contains__,            ["map"],      true,  "Executor.__dict__.__contains__('map')==True — Executor.map() defined directly in Executor.__dict__; parallel mapping over an iterable; verified with Python 3.14.4"]
    - [cf1516ex008, concurrent.futures.Executor.__dict__.__contains__,            ["shutdown"], true,  "Executor.__dict__.__contains__('shutdown')==True — Executor.shutdown() defined in Executor.__dict__; frees pool resources after pending futures complete; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 3: Cross-module arithmetic contrast — cf.Future vs numeric types
#
# concurrent.futures.Future.__dict__.__contains__('__add__')     == False
# concurrent.futures.Future.__dict__.__contains__('__mul__')     == False
# concurrent.futures.Future.__dict__.__contains__('__sub__')     == False
# concurrent.futures.Future.__dict__.__contains__('__truediv__') == False
# concurrent.futures.Future.__dict__.__contains__('__pow__')     == False
# concurrent.futures.Future.__dict__.__contains__('result')      == True
# concurrent.futures.Future.__dict__.__contains__('running')     == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra1516.cf_future_full_arith_sweep:
  description: "concurrent.futures.Future full arithmetic operator sweep across all 7 operators — cf1516fs namespace. Confirms that concurrent.futures.Future defines none of the standard arithmetic operator protocol methods (__add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__) in its own __dict__. cf.Future is a synchronous result container wrapping a callable submitted to an executor; its semantic domain is 'pending computation with result access', not numeric arithmetic; the only numeric-adjacent concept is the internal state machine (PENDING, RUNNING, CANCELLED, FINISHED) but those are string constants, not arithmetic operators; cf.Future.__dict__.__contains__('result')==True (result() IS in Future.__dict__ — the primary sync retrieval method that blocks until done); cf.Future.__dict__.__contains__('running')==True (running() IS in Future.__dict__ — returns True if the future is currently executing); verified with Python 3.14.4"
  kind: python_call_eq
  category: arithmetic_protocol
  id_prefix: cf1516fs

  columns: [id, function, args, expected, description]
  rows:
    - [cf1516fs001, concurrent.futures.Future.__dict__.__contains__, ["__add__"],      false, "cf.Future.__dict__.__contains__('__add__')==False — no addition operator; Future is a result container, not numeric; verified with Python 3.14.4"]
    - [cf1516fs002, concurrent.futures.Future.__dict__.__contains__, ["__mul__"],      false, "cf.Future.__dict__.__contains__('__mul__')==False — no multiplication on cf.Future; verified with Python 3.14.4"]
    - [cf1516fs003, concurrent.futures.Future.__dict__.__contains__, ["__sub__"],      false, "cf.Future.__dict__.__contains__('__sub__')==False — no subtraction on cf.Future; verified with Python 3.14.4"]
    - [cf1516fs004, concurrent.futures.Future.__dict__.__contains__, ["__truediv__"],  false, "cf.Future.__dict__.__contains__('__truediv__')==False — no true division on cf.Future; verified with Python 3.14.4"]
    - [cf1516fs005, concurrent.futures.Future.__dict__.__contains__, ["__floordiv__"], false, "cf.Future.__dict__.__contains__('__floordiv__')==False — no floor division on cf.Future; verified with Python 3.14.4"]
    - [cf1516fs006, concurrent.futures.Future.__dict__.__contains__, ["__mod__"],      false, "cf.Future.__dict__.__contains__('__mod__')==False — no modulo on cf.Future; verified with Python 3.14.4"]
    - [cf1516fs007, concurrent.futures.Future.__dict__.__contains__, ["__pow__"],      false, "cf.Future.__dict__.__contains__('__pow__')==False — no exponentiation on cf.Future; verified with Python 3.14.4"]
    - [cf1516fs008, concurrent.futures.Future.__dict__.__contains__, ["result"],       true,  "cf.Future.__dict__.__contains__('result')==True — Future.result() defined in cf.Future.__dict__; primary sync retrieval method; verified with Python 3.14.4"]
    - [cf1516fs009, concurrent.futures.Future.__dict__.__contains__, ["running"],      true,  "cf.Future.__dict__.__contains__('running')==True — Future.running() defined in cf.Future.__dict__; returns True if future is currently executing; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1516
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra1516.cf_future_no_add:
  description: "concurrent.futures.Future.__dict__.__contains__('__add__') returns False — concurrent.futures.Future does not define __add__ in its own __dict__; cf.Future is a synchronous result container for a callable submitted to a thread or process pool; its semantic domain is 'pending computation' not 'numeric value'; cf.Future.__dict__ contains result(), exception(), cancel(), cancelled(), done(), running(), add_done_callback(), set_result(), set_exception() — all synchronous result-management methods; no arithmetic operator (__add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__) is defined; wave 548 theme: arithmetic operator __dict__ presence checks; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: arithmetic_protocol
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["__add__"]
  expected: false

invariant concurrent_futures_extra1516.cf_future_no_mul:
  description: "concurrent.futures.Future.__dict__.__contains__('__mul__') returns False — concurrent.futures.Future does not define __mul__ in its own __dict__; multiplication of a sync future object is semantically meaningless and unsupported; cf.Future represents a pending async computation (from a thread or process pool) and is retrieved synchronously via result(); the interface is about computation state and result retrieval, not numeric operations; wave 548 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: arithmetic_protocol
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["__mul__"]
  expected: false

invariant concurrent_futures_extra1516.cf_executor_no_add:
  description: "concurrent.futures.Executor.__dict__.__contains__('__add__') returns False — concurrent.futures.Executor does not define __add__ in its own __dict__; Executor is the abstract base class for ThreadPoolExecutor and ProcessPoolExecutor; its __dict__ contains submit(), map(), and shutdown() — the core executor interface for submitting callables and managing pool lifecycle; combining executors via addition is undefined; wave 548 theme: arithmetic operator __dict__ presence; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: arithmetic_protocol
  kind: python_call_eq
  function: concurrent.futures.Executor.__dict__.__contains__
  args: ["__add__"]
  expected: false

invariant concurrent_futures_extra1516.cf_threadpool_no_pow:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__pow__') returns False — ThreadPoolExecutor does not define __pow__ in its own __dict__; ThreadPoolExecutor manages a pool of threads to execute submitted callables; its __dict__ contains thread management methods and overrides of submit() from the abstract Executor; exponentiation is entirely undefined for an executor pool; wave 548 theme: arithmetic operator __dict__ presence; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: arithmetic_protocol
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__dict__.__contains__
  args: ["__pow__"]
  expected: false
