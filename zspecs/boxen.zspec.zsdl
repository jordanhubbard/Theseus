spec: boxen
version: ">=8.0.0"
backend: node(boxen)

docs: https://github.com/sindresorhus/boxen#readme

provenance:
  derived_from:
    - "boxen README — https://github.com/sindresorhus/boxen#readme"
    - "Test vectors verified with boxen via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "boxen source"
  notes:
    - "Create boxes in the terminal — used by update-notifier and many CLI greeters."
    - "Install: npm install boxen"
    - "v8 ESM only; default export takes (text, options)."
    - "Tests use {borderStyle: 'classic'} for simple ASCII output (no Unicode glyph variability)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; throws on invalid borderStyle or unsupported options."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant boxen.classic_no_padding:
  description: "Classic ASCII box around 'hello' with no padding has +/-/| corners"
  category: render
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["hello", {padding: 0, borderStyle: "classic"}]
  chain: []
  expected: "+-----+\n|hello|\n+-----+"

invariant boxen.classic_with_title:
  description: "Title centred on top border replaces the dashes"
  category: render
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["hi", {title: "T", titleAlignment: "center", padding: 0, borderStyle: "classic"}]
  chain: []
  expected: "+ T +\n|hi |\n+---+"

invariant boxen.line_count_no_padding:
  description: "Output for one line of text + 0 padding has 3 lines (top border + content + bottom border)"
  category: render
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["x", {padding: 0, borderStyle: "classic"}]
  chain:
    - {method: split, args: ["\n"]}
    - {get: length}
  expected: 3

invariant boxen.empty_string_box:
  description: "Empty input still produces a box (1-char-wide content)"
  category: edge
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["", {padding: 0, borderStyle: "classic"}]
  chain: []
  expected: "++\n||\n++"

invariant boxen.padding_one_adds_two_columns:
  description: "{padding: 1} adds 1 space on each side and 1 line above/below"
  category: padding
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["x", {padding: 1, borderStyle: "classic"}]
  chain:
    - {method: split, args: ["\n"]}
    - {get: length}
  expected: 5

invariant boxen.borderStyle_double_corners:
  description: "borderStyle 'double' uses ╔/╗/╚/╝ corners"
  category: borderStyle
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["x", {padding: 0, borderStyle: "double"}]
  chain: []
  expected: "╔═╗\n║x║\n╚═╝"

invariant boxen.returns_string:
  description: "Output is a String"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["hi", {padding: 0, borderStyle: "classic"}]
  chain:
    - {get: "constructor.name"}
  expected: "String"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:59:05Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
