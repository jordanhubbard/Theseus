spec: pathlib_extra1351
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 537 (_extra1351): focuses on __slots__ and __weakref__ attribute checks at the class __dict__ level."
    - "pathlib.PurePath defines __slots__ in its own __dict__ (True) — it uses __slots__ to avoid per-instance __dict__ overhead for immutable path objects."
    - "pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, and pathlib.PosixPath all define __slots__ in their own __dict__ (True) — each subclass extends the slot tuple."
    - "None of the pathlib classes define __weakref__ in their own __dict__ — the __weakref__ slot is inherited via the __slots__ mechanism from PurePath (it is included in PurePath's __slots__ tuple, not added as a separate descriptor)."
    - "None of the pathlib classes define __dict__ in their own __dict__ — the __slots__ declaration suppresses the per-instance __dict__."
    - "PurePath.__slots__ contains the actual slot names used by the immutable path internals; the presence of '__slots__' key in PurePath.__dict__ confirms the class uses the __slots__ mechanism."
    - "The absence of '__weakref__' in PurePath.__dict__ as a standalone key does NOT mean pathlib objects are not weakly referenceable; the weakref slot is defined within the __slots__ tuple value itself."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table pathlib_extra1351.PurePath_slots_weakref_dict:
  description: "pathlib.PurePath __slots__, __weakref__, and __dict__ membership in class __dict__: PurePath defines __slots__ (True) but not __weakref__ or __dict__ as standalone keys; verified with Python 3.12"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: pl1351pp
  columns: [id, function, args, expected]
  rows:
    - [pl1351pp001, pathlib.PurePath.__dict__.__contains__, ["__slots__"],   true]
    - [pl1351pp002, pathlib.PurePath.__dict__.__contains__, ["__weakref__"], false]
    - [pl1351pp003, pathlib.PurePath.__dict__.__contains__, ["__dict__"],    false]
    - [pl1351pp004, pathlib.PurePosixPath.__dict__.__contains__, ["__slots__"],   true]
    - [pl1351pp005, pathlib.PurePosixPath.__dict__.__contains__, ["__weakref__"], false]
    - [pl1351pp006, pathlib.PurePosixPath.__dict__.__contains__, ["__dict__"],    false]

table pathlib_extra1351.PureWindowsPath_Path_slots_weakref_dict:
  description: "pathlib.PureWindowsPath and pathlib.Path __slots__, __weakref__, and __dict__ checks: both define __slots__ (True) but neither defines __weakref__ or __dict__ as standalone keys in their own class __dict__; verified with Python 3.12"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: pl1351wp
  columns: [id, function, args, expected]
  rows:
    - [pl1351wp001, pathlib.PureWindowsPath.__dict__.__contains__, ["__slots__"],   true]
    - [pl1351wp002, pathlib.PureWindowsPath.__dict__.__contains__, ["__weakref__"], false]
    - [pl1351wp003, pathlib.PureWindowsPath.__dict__.__contains__, ["__dict__"],    false]
    - [pl1351wp004, pathlib.Path.__dict__.__contains__, ["__slots__"],   true]
    - [pl1351wp005, pathlib.Path.__dict__.__contains__, ["__weakref__"], false]
    - [pl1351wp006, pathlib.Path.__dict__.__contains__, ["__dict__"],    false]

table pathlib_extra1351.PosixPath_slots_weakref_dict:
  description: "pathlib.PosixPath __slots__, __weakref__, and __dict__ checks; PosixPath defines __slots__ (True) but not __weakref__ or __dict__ as standalone keys; cross-class comparison of __slots__ presence across all five pathlib path types confirms consistent use of __slots__ throughout the hierarchy; verified with Python 3.12"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: pl1351px
  columns: [id, function, args, expected]
  rows:
    - [pl1351px001, pathlib.PosixPath.__dict__.__contains__, ["__slots__"],   true]
    - [pl1351px002, pathlib.PosixPath.__dict__.__contains__, ["__weakref__"], false]
    - [pl1351px003, pathlib.PosixPath.__dict__.__contains__, ["__dict__"],    false]
    - [pl1351px004, pathlib.PurePath.__dict__.__contains__,      ["__slots__"], true]
    - [pl1351px005, pathlib.PurePosixPath.__dict__.__contains__, ["__slots__"], true]
    - [pl1351px006, pathlib.Path.__dict__.__contains__,          ["__slots__"], true]
