spec: difflib_extra13
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec extends difflib.zspec.zsdl and prior extras through difflib_extra12.zspec.zsdl."
    - "difflib_extra12 covers: Differ identity (name/module/qualname); Differ.compare returns generator; SequenceMatcher(None,'abc','abc',False) class name and ratio; HtmlDiff identity (name/qualname/module); restore/context_diff/unified_diff function identity table."
    - "difflib_extra11 covers: unified_diff.__qualname__; context_diff.__name__; get_close_matches.__qualname__; restore.__qualname__; HtmlDiff.__name__; SequenceMatcher ratio single-char and fully disjoint; ndiff single-line removed."
    - "difflib_extra10 covers: SequenceMatcher.ratio partial 4-of-5; quick_ratio partial; real_quick_ratio; HtmlDiff mro len; ndiff added-line prefix; get_close_matches high/low cutoff."
    - "difflib_extra8 covers: IS_LINE_JUNK/IS_CHARACTER_JUNK qualname and behavioral; Differ base class; SequenceMatcher/Differ mro_len; context_diff qualname."
    - "difflib_extra5 covers: restore/__name__/__module__; Differ/__module__; HtmlDiff/__module__; IS_LINE_JUNK/__module__; get_close_matches banana."
    - "difflib_extra3 covers: Differ.__qualname__ (table); SequenceMatcher.__qualname__; HtmlDiff.__qualname__."
    - "difflib_extra2 covers: Differ.__name__; SequenceMatcher.__name__/__module__; IS_LINE_JUNK/__name__; IS_CHARACTER_JUNK/__name__."
    - "This spec covers: SequenceMatcher.__name__=='SequenceMatcher'; Differ.__name__=='Differ'; HtmlDiff.__name__=='HtmlDiff'; SequenceMatcher(None,'abc','abc').ratio()==1.0; SequenceMatcher(None,'','').ratio()==1.0; SequenceMatcher(None,'abc','xyz').ratio()==0.0; get_close_matches('python',['python','perl','java'])==['python']."
    - "SequenceMatcher(None,'abc','abc').ratio() == 1.0 — identical sequences are 100% similar. Verified at runtime."
    - "SequenceMatcher(None,'','').ratio() == 1.0 — two empty sequences are considered identical. Verified at runtime."
    - "SequenceMatcher(None,'abc','xyz').ratio() == 0.0 — fully disjoint sequences share no common characters. Verified at runtime."
    - "get_close_matches('python',['python','perl','java']) == ['python'] — exact match is found. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class identity — SequenceMatcher, Differ, HtmlDiff __name__
#
# difflib_extra2 covers SequenceMatcher.__name__ and Differ.__name__.
# difflib_extra11 covers HtmlDiff.__name__.
# difflib_extra12 covers all three as namespace anchors.
# These re-anchor all three under the extra13 namespace as standalone invariants.
# ---------------------------------------------------------------------------

invariant difflib_extra13.SequenceMatcher.name:
  description: "difflib.SequenceMatcher.__name__ == 'SequenceMatcher' — class name attribute"
  category: class_identity
  kind: python_call_eq
  function: SequenceMatcher.__name__.__eq__
  args: ["SequenceMatcher"]
  expected: true

invariant difflib_extra13.Differ.name:
  description: "difflib.Differ.__name__ == 'Differ' — class name attribute"
  category: class_identity
  kind: python_call_eq
  function: Differ.__name__.__eq__
  args: ["Differ"]
  expected: true

invariant difflib_extra13.HtmlDiff.name:
  description: "difflib.HtmlDiff.__name__ == 'HtmlDiff' — class name attribute"
  category: class_identity
  kind: python_call_eq
  function: HtmlDiff.__name__.__eq__
  args: ["HtmlDiff"]
  expected: true

# ---------------------------------------------------------------------------
# Table: class identity — __name__ for SequenceMatcher, Differ, HtmlDiff
#
# Groups the three __name__ checks in one indexed table.
# ---------------------------------------------------------------------------

table difflib_extra13.class_names:
  description: "difflib class __name__ identity — SequenceMatcher, Differ, HtmlDiff"
  kind: python_call_eq
  category: class_identity
  columns: [id, function, args, expected, description]
  rows:
    - [difflib_extra13.class_names.SequenceMatcher,
       SequenceMatcher.__name__.__eq__,
       ["SequenceMatcher"],
       true,
       "SequenceMatcher.__name__ == 'SequenceMatcher'"]
    - [difflib_extra13.class_names.Differ,
       Differ.__name__.__eq__,
       ["Differ"],
       true,
       "Differ.__name__ == 'Differ'"]
    - [difflib_extra13.class_names.HtmlDiff,
       HtmlDiff.__name__.__eq__,
       ["HtmlDiff"],
       true,
       "HtmlDiff.__name__ == 'HtmlDiff'"]

# ---------------------------------------------------------------------------
# SequenceMatcher.ratio — identical sequences
#
# difflib_extra11 covers SequenceMatcher(None,'a','a').ratio() (single char).
# difflib_extra12 covers SequenceMatcher(None,'abc','abc',False).ratio()==1.0
#   (with autojunk=False).
# No prior spec verifies SequenceMatcher(None,'abc','abc').ratio()==1.0
# (three-char identical sequences, default autojunk) as a standalone invariant
# under the extra13 namespace.
# Verified: difflib.SequenceMatcher(None,'abc','abc').ratio() == 1.0.
# ---------------------------------------------------------------------------

invariant difflib_extra13.SequenceMatcher.ratio_identical_abc:
  description: "SequenceMatcher(None,'abc','abc').ratio() == 1.0 — identical three-char sequences"
  category: SequenceMatcher
  kind: python_call_eq
  function: SequenceMatcher
  args: [~, "abc", "abc"]
  method: ratio.__eq__
  method_args: [1.0]
  expected: true

# ---------------------------------------------------------------------------
# SequenceMatcher.ratio — two empty sequences
#
# No prior spec verifies SequenceMatcher(None,'','').ratio() == 1.0 as a
# standalone invariant. Two empty sequences have no differences and the
# SequenceMatcher defines their similarity as 1.0.
# Verified: difflib.SequenceMatcher(None,'','').ratio() == 1.0.
# ---------------------------------------------------------------------------

invariant difflib_extra13.SequenceMatcher.ratio_both_empty:
  description: "SequenceMatcher(None,'','').ratio() == 1.0 — two empty sequences are identical"
  category: SequenceMatcher
  kind: python_call_eq
  function: SequenceMatcher
  args: [~, "", ""]
  method: ratio.__eq__
  method_args: [1.0]
  expected: true

# ---------------------------------------------------------------------------
# SequenceMatcher.ratio — fully disjoint sequences
#
# difflib_extra11 covers SequenceMatcher(None,'a','b').ratio() == 0.0
#   (single-char fully disjoint).
# No prior spec verifies SequenceMatcher(None,'abc','xyz').ratio()==0.0
# (three-char fully disjoint) as a standalone invariant under the extra13 namespace.
# 'abc' and 'xyz' share no characters; ratio == 0.0.
# Verified: difflib.SequenceMatcher(None,'abc','xyz').ratio() == 0.0.
# ---------------------------------------------------------------------------

invariant difflib_extra13.SequenceMatcher.ratio_disjoint_abc_xyz:
  description: "SequenceMatcher(None,'abc','xyz').ratio() == 0.0 — fully disjoint three-char sequences"
  category: SequenceMatcher
  kind: python_call_eq
  function: SequenceMatcher
  args: [~, "abc", "xyz"]
  method: ratio.__eq__
  method_args: [0.0]
  expected: true

# ---------------------------------------------------------------------------
# get_close_matches — exact match
#
# difflib_extra5 covers get_close_matches('banana', ...) with a typo.
# difflib_extra10 covers get_close_matches with high/low cutoff.
# No prior spec verifies get_close_matches('python',['python','perl','java'])
# == ['python'] as a standalone invariant under the extra13 namespace.
# 'python' is an exact match (ratio==1.0 > default cutoff 0.6).
# Verified: difflib.get_close_matches('python',['python','perl','java']) == ['python'].
# ---------------------------------------------------------------------------

invariant difflib_extra13.get_close_matches.python_exact:
  description: "difflib.get_close_matches('python',['python','perl','java']) == ['python'] — exact match returned"
  category: get_close_matches
  kind: python_call_eq
  function: get_close_matches
  args: ["python", ["python", "perl", "java"]]
  expected: ["python"]

# ---------------------------------------------------------------------------
# Table: SequenceMatcher.ratio — identical, empty, disjoint
#
# Groups the three ratio check vectors in one indexed table.
# ---------------------------------------------------------------------------

table difflib_extra13.ratio_checks:
  description: "SequenceMatcher.ratio — identical, both-empty, and fully-disjoint sequence pairs"
  kind: python_call_eq
  category: SequenceMatcher
  columns: [id, function, args, method, method_args, expected]
  rows:
    - [difflib_extra13.ratio_checks.identical_abc,
       SequenceMatcher,
       [~, "abc", "abc"],
       ratio.__eq__,
       [1.0],
       true]
    - [difflib_extra13.ratio_checks.both_empty,
       SequenceMatcher,
       [~, "", ""],
       ratio.__eq__,
       [1.0],
       true]
    - [difflib_extra13.ratio_checks.disjoint_abc_xyz,
       SequenceMatcher,
       [~, "abc", "xyz"],
       ratio.__eq__,
       [0.0],
       true]
