spec: ssl_extra22
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "ssl_extra21.zspec.zsdl — covers SSLContext/SSLSocket/SSLObject/MemoryBIO/SSLSession __qualname__.__len__(); create_default_context __qualname__ and __len__(); SSLContext/SSLSocket qualname as standalone __eq__ invariants."
    - "ssl_extra17.zspec.zsdl — covers SSLError.__qualname__.__len__()==8; CertificateError.__qualname__.__len__()==24; MRO lengths for SSLError/SSLCertVerificationError/SSLContext/SSLSocket."
    - "ssl_extra8.zspec.zsdl — covers SSLContext/SSLSocket/SSLError/SSLCertVerificationError __qualname__ via table."
    - "ssl_extra6.zspec.zsdl — covers VerifyMode.__qualname__ == 'VerifyMode' (class-level qualname)."
    - "ssl_extra3.zspec.zsdl — covers PROTOCOL_TLS_CLIENT.__class__.__name__ == '_SSLMethod'."
    - "ssl_extra2.zspec.zsdl — covers CERT_NONE/CERT_REQUIRED.__class__.__name__ == 'VerifyMode'."
  notes:
    - "This spec extends ssl through ssl_extra21; it does NOT duplicate invariants present in those files."
    - "Focus: __class__.__qualname__ for VerifyMode enum members (CERT_NONE/CERT_OPTIONAL/CERT_REQUIRED) and PROTOCOL_TLS_CLIENT; VerifyMode.__qualname__.__len__(); SSLCertVerificationError.__qualname__ as standalone __eq__ from extra22 namespace."
    - "ssl_extra2 covers CERT_REQUIRED.__class__.__name__ == 'VerifyMode' (using __name__). No prior spec checks __class__.__qualname__ for enum members — a distinct attribute access chain."
    - "ssl.CERT_REQUIRED.__class__.__qualname__ == 'VerifyMode': on Python 3.12, __qualname__ == __name__ for top-level enum classes. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.CERT_NONE.__class__.__qualname__ == 'VerifyMode': all VerifyMode members share the same __class__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.CERT_OPTIONAL.__class__.__qualname__ == 'VerifyMode': same class qualname. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.PROTOCOL_TLS_CLIENT.__class__.__qualname__ == '_SSLMethod': matches __name__ for internal _ssl enum. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.VerifyMode.__qualname__.__len__() == 10: len('VerifyMode') == 10. ssl_extra6 covers __qualname__.__eq__ but not its length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLCertVerificationError.__qualname__ anchored from extra22 namespace as a standalone invariant (ssl_extra8 covers it via table). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# VerifyMode enum member __class__.__qualname__ table
#
# ssl_extra2 covers CERT_NONE/__class__/__name__ and CERT_REQUIRED/__class__/__name__.
# ssl_extra4 covers CERT_OPTIONAL/__class__/__name__.
# No prior spec checks __class__.__qualname__ for any VerifyMode member.
# On CPython 3.12, VerifyMode.__qualname__ == 'VerifyMode' == VerifyMode.__name__.
# ---------------------------------------------------------------------------

table ssl_extra22.VerifyMode_member_class_qualnames:
  description: "ssl VerifyMode enum members __class__.__qualname__ == 'VerifyMode'"
  kind: python_call_eq
  category: type_metadata
  id_prefix: sslvmcq22

  columns: [id, function, args, expected]
  rows:
    - [CERT_NONE,     CERT_NONE.__class__.__qualname__.__eq__,     ["VerifyMode"], true]
    - [CERT_OPTIONAL, CERT_OPTIONAL.__class__.__qualname__.__eq__, ["VerifyMode"], true]
    - [CERT_REQUIRED, CERT_REQUIRED.__class__.__qualname__.__eq__, ["VerifyMode"], true]

# ---------------------------------------------------------------------------
# PROTOCOL_TLS_CLIENT.__class__.__qualname__
#
# ssl_extra3 covers PROTOCOL_TLS_CLIENT.__class__.__name__ == '_SSLMethod'.
# ssl_extra13 covers PROTOCOL_TLS_SERVER.__class__.__name__ == '_SSLMethod'.
# No prior spec checks __class__.__qualname__ for PROTOCOL_TLS_CLIENT.
# On CPython 3.12, _SSLMethod.__qualname__ == '_SSLMethod' (top-level internal enum).
# ---------------------------------------------------------------------------

invariant ssl_extra22.PROTOCOL_TLS_CLIENT.class_qualname:
  description: "ssl.PROTOCOL_TLS_CLIENT.__class__.__qualname__ == '_SSLMethod' — internal CPython enum qualname"
  category: type_metadata
  kind: python_call_eq
  function: PROTOCOL_TLS_CLIENT.__class__.__qualname__.__eq__
  args: ["_SSLMethod"]
  expected: true

# ---------------------------------------------------------------------------
# VerifyMode.__qualname__.__len__()
#
# ssl_extra6 covers VerifyMode.__qualname__.__eq__('VerifyMode') == True.
# No prior spec checks the length of VerifyMode.__qualname__.
# len('VerifyMode') == 10.
# ---------------------------------------------------------------------------

invariant ssl_extra22.VerifyMode.qualname_len:
  description: "ssl.VerifyMode.__qualname__.__len__() == 10 — len('VerifyMode') == 10"
  category: class_qualnames
  kind: python_call_eq
  function: VerifyMode.__qualname__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# SSLCertVerificationError.__qualname__ — standalone from extra22 namespace
#
# ssl_extra8 covers SSLCertVerificationError.__qualname__ via a shared table row.
# This invariant anchors the same property from the extra22 namespace via a
# standalone __eq__ call, providing an independent execution path.
# SSLCertVerificationError.__qualname__ == 'SSLCertVerificationError' (len 24).
# ---------------------------------------------------------------------------

invariant ssl_extra22.SSLCertVerificationError.qualname:
  description: "ssl.SSLCertVerificationError.__qualname__ == 'SSLCertVerificationError'"
  category: class_qualnames
  kind: python_call_eq
  function: SSLCertVerificationError.__qualname__.__eq__
  args: ["SSLCertVerificationError"]
  expected: true
