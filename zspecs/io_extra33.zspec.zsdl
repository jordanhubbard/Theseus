spec: io_extra33
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra9.zspec.zsdl — covers BytesIO/StringIO __qualname__ in table rows; IOBase.__module__ in table"
    - "io_extra14.zspec.zsdl — covers UnsupportedOperation.__module__ as a standalone invariant"
    - "io_extra15.zspec.zsdl — covers BytesIO/StringIO/FileIO __qualname__ as standalone invariants"
    - "io_extra16.zspec.zsdl — covers TextIOWrapper.__qualname__ as a standalone invariant"
    - "io_extra19.zspec.zsdl — covers BytesIO/StringIO/FileIO/TextIOWrapper __qualname__ as standalone invariants"
    - "io_extra22.zspec.zsdl — covers UnsupportedOperation.__qualname__/__module__; BytesIO/StringIO __qualname__ as standalone invariants"
    - "io_extra26.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedRandom __qualname__ in table"
    - "io_extra30.zspec.zsdl — covers BufferedReader/BufferedWriter/TextIOWrapper __qualname__ in table"
    - "io_extra31.zspec.zsdl — covers IOBase/__qualname__/__module__; RawIOBase/__qualname__/__module__; BufferedIOBase/__qualname__/__module__; TextIOBase/__qualname__/__module__; UnsupportedOperation/__qualname__/__bases__[0..1].__name__"
    - "io_extra32.zspec.zsdl — covers FileIO/BytesIO/StringIO/BufferedReader/BufferedWriter/TextIOWrapper __qualname__/__module__/__bases__[0].__name__"
  notes:
    - "This spec extends io_extra32.zspec.zsdl."
    - "NEW in extra33 — Axis 1: IOBase/RawIOBase/BufferedIOBase/TextIOBase __qualname__ as extra33-namespace standalone invariants (values verified: all flat). Note: abstract base classes have __module__ == 'io' (the public module), unlike the concrete C-extension classes which have __module__ == '_io'."
    - "NEW in extra33 — Axis 2: BytesIO/StringIO/FileIO/TextIOWrapper __qualname__ as extra33-namespace standalone invariants (values verified: all flat, all == class __name__)."
    - "NEW in extra33 — Axis 3: UnsupportedOperation.__qualname__/__module__/__bases__[0].__name__ as extra33-namespace standalone invariants. UnsupportedOperation is pure-Python (module == 'io'); its first base is OSError."
    - "NEW in extra33 — Axis 4: io.open.__qualname__ as an extra33-namespace invariant. io.open is the built-in open() function; its __qualname__ is 'open' and its __module__ is '_io'."
    - "io.IOBase.__qualname__ == 'IOBase' — flat qualname; abstract base class."
    - "io.RawIOBase.__qualname__ == 'RawIOBase' — flat qualname; abstract base for raw I/O."
    - "io.BufferedIOBase.__qualname__ == 'BufferedIOBase' — flat qualname; abstract base for buffered I/O."
    - "io.TextIOBase.__qualname__ == 'TextIOBase' — flat qualname; abstract base for text I/O."
    - "io.BytesIO.__qualname__ == 'BytesIO' — flat qualname; C-extension concrete class."
    - "io.StringIO.__qualname__ == 'StringIO' — flat qualname; C-extension concrete class."
    - "io.FileIO.__qualname__ == 'FileIO' — flat qualname; C-extension concrete class."
    - "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — flat qualname; C-extension concrete class."
    - "io.UnsupportedOperation.__qualname__ == 'UnsupportedOperation' — flat qualname."
    - "io.UnsupportedOperation.__module__ == 'io' — defined in the pure-Python io wrapper, not in _io."
    - "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — first parent class is OSError."
    - "io.open.__qualname__ == 'open' — flat qualname for the built-in open() function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Abstract base class __qualname__ — extra33-namespace standalone invariants
#
# IOBase, RawIOBase, BufferedIOBase, and TextIOBase are the four abstract
# base classes defining the io type hierarchy. All have flat __qualname__
# values (equal to __name__). Prior specs establish these facts in various
# namespaces (notably io_extra31). These invariants establish them in the
# extra33 namespace for completeness with the concrete-class coverage below.
#
# Important: although these classes are C-extension types (implemented in
# _io.c), they are registered under the public 'io' module namespace, so
# their __module__ is 'io' — unlike the concrete classes (BytesIO, StringIO,
# FileIO, TextIOWrapper, etc.) which have __module__ == '_io'.
# ---------------------------------------------------------------------------

table io_extra33.abstract_base_qualnames:
  description: "__qualname__ for IOBase, RawIOBase, BufferedIOBase, TextIOBase — all flat"
  kind: python_call_eq
  category: class_identity
  id_prefix: abq33

  columns: [id, function, args, expected]
  rows:
    - [IOBase,        IOBase.__qualname__.__eq__,        ["IOBase"],        true]
    - [RawIOBase,     RawIOBase.__qualname__.__eq__,     ["RawIOBase"],     true]
    - [BufferedIOBase, BufferedIOBase.__qualname__.__eq__, ["BufferedIOBase"], true]
    - [TextIOBase,    TextIOBase.__qualname__.__eq__,    ["TextIOBase"],    true]

# ---------------------------------------------------------------------------
# Concrete class __qualname__ — extra33-namespace standalone invariants
#
# BytesIO, StringIO, FileIO, and TextIOWrapper are the four primary concrete
# I/O classes. All are C-extensions registered under '_io'. Their __qualname__
# values are flat (equal to __name__). Prior specs establish these in multiple
# namespaces. These invariants establish them in the extra33 namespace.
# ---------------------------------------------------------------------------

table io_extra33.concrete_class_qualnames:
  description: "__qualname__ for BytesIO, StringIO, FileIO, TextIOWrapper — all flat"
  kind: python_call_eq
  category: class_identity
  id_prefix: ccq33

  columns: [id, function, args, expected]
  rows:
    - [BytesIO,       BytesIO.__qualname__.__eq__,       ["BytesIO"],       true]
    - [StringIO,      StringIO.__qualname__.__eq__,      ["StringIO"],      true]
    - [FileIO,        FileIO.__qualname__.__eq__,        ["FileIO"],        true]
    - [TextIOWrapper, TextIOWrapper.__qualname__.__eq__, ["TextIOWrapper"], true]

# ---------------------------------------------------------------------------
# UnsupportedOperation — qualname, module, and first base class
#
# io.UnsupportedOperation is the exception raised when an I/O operation is
# not supported by a stream. Unlike the C-extension classes, it is defined
# in the pure-Python io module (not _io), so its __module__ is 'io'. It
# inherits from both OSError and ValueError; __bases__[0] is OSError.
# Prior specs (io_extra14, io_extra22, io_extra31) cover these attributes in
# various namespaces. These invariants establish them in the extra33 namespace.
# ---------------------------------------------------------------------------

invariant io_extra33.UnsupportedOperation.qualname:
  description: "io.UnsupportedOperation.__qualname__ == 'UnsupportedOperation' — flat qualname for the I/O exception class"
  category: class_identity
  kind: python_call_eq
  function: UnsupportedOperation.__qualname__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

invariant io_extra33.UnsupportedOperation.module:
  description: "io.UnsupportedOperation.__module__ == 'io' — defined in the pure-Python io module, not in the C-extension _io"
  category: class_identity
  kind: python_call_eq
  function: UnsupportedOperation.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra33.UnsupportedOperation.base0:
  description: "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — first parent class is OSError (also inherits ValueError as second base)"
  category: class_identity
  kind: python_call_eq
  function: "UnsupportedOperation.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# io.open.__qualname__ — built-in open() function identity
#
# io.open is the built-in file-open function (the same object as the built-in
# open()). It is implemented in C and registered under the '_io' extension
# module. Its __qualname__ is the flat string 'open'. No prior io spec anchors
# io.open.__qualname__ as a standalone extra33-namespace invariant.
# ---------------------------------------------------------------------------

invariant io_extra33.open.qualname:
  description: "io.open.__qualname__ == 'open' — flat qualname for the built-in file-open function"
  category: function_identity
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true
