spec: enum_extra26
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum_extra25.zspec.zsdl."
    - "Focus: __qualname__ values for enum.Enum instance methods (__str__, __repr__, __new__) and enum.EnumMeta (EnumType) methods (__new__, __contains__, __getitem__, __iter__) in the extra26 namespace."
    - "enum_extra25 covers __qualname__.__len__() for Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique/EnumMeta."
    - "enum_extra21 covers class-level __qualname__ for Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique and EnumMeta.__qualname__ == 'EnumType'."
    - "No prior enum spec records method-level qualnames such as Enum.__str__.__qualname__, Enum.__repr__.__qualname__, Enum.__new__.__qualname__, or any EnumMeta method __qualname__."
    - "On Python 3.11+, enum.EnumMeta was renamed to EnumType internally; EnumMeta.__new__.__qualname__ is 'EnumType.__new__', not 'EnumMeta.__new__'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# enum.Enum method __qualname__ values — combined table
#
# Enum defines __str__, __repr__, and __new__ as instance/class methods.
# Their __qualname__ values use the 'Enum.' prefix.
# No prior enum spec records any of these method qualnames.
# ---------------------------------------------------------------------------

table enum_extra26.Enum_method_qualnames:
  description: "__qualname__.__eq__ for enum.Enum methods"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [str,  "Enum.__str__.__qualname__.__eq__",  ["Enum.__str__"],  true]
    - [repr, "Enum.__repr__.__qualname__.__eq__", ["Enum.__repr__"], true]
    - [new,  "Enum.__new__.__qualname__.__eq__",  ["Enum.__new__"],  true]

# ---------------------------------------------------------------------------
# enum.EnumMeta method __qualname__ values — combined table
#
# On Python 3.11+ EnumMeta was renamed EnumType internally; all method
# __qualname__ values use 'EnumType.' prefix, not 'EnumMeta.'.
# No prior enum spec records any EnumMeta method qualnames.
# ---------------------------------------------------------------------------

table enum_extra26.EnumMeta_method_qualnames:
  description: "__qualname__.__eq__ for enum.EnumMeta (EnumType) methods — Python 3.11+"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [new,      "EnumMeta.__new__.__qualname__.__eq__",      ["EnumType.__new__"],      true]
    - [contains, "EnumMeta.__contains__.__qualname__.__eq__", ["EnumType.__contains__"], true]
    - [getitem,  "EnumMeta.__getitem__.__qualname__.__eq__",  ["EnumType.__getitem__"],  true]
    - [iter,     "EnumMeta.__iter__.__qualname__.__eq__",     ["EnumType.__iter__"],     true]

# ---------------------------------------------------------------------------
# enum.Enum method __qualname__.__len__() values — combined table
#
# Verifies the string length of each Enum method __qualname__:
#   Enum.__str__ -> 12, Enum.__repr__ -> 13, Enum.__new__ -> 12
# No prior enum spec collects these method qualname lengths together.
# ---------------------------------------------------------------------------

table enum_extra26.Enum_method_qualname_lens:
  description: "__qualname__.__len__() for enum.Enum methods"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [str,  "Enum.__str__.__qualname__.__len__",  [], 12]
    - [repr, "Enum.__repr__.__qualname__.__len__", [], 13]
    - [new,  "Enum.__new__.__qualname__.__len__",  [], 12]

# ---------------------------------------------------------------------------
# enum.EnumMeta method __qualname__.__len__() values — combined table
#
# Verifies the string length of each EnumMeta method __qualname__:
#   EnumType.__new__ -> 16, EnumType.__contains__ -> 21,
#   EnumType.__getitem__ -> 20, EnumType.__iter__ -> 17
# No prior enum spec collects these method qualname lengths together.
# ---------------------------------------------------------------------------

table enum_extra26.EnumMeta_method_qualname_lens:
  description: "__qualname__.__len__() for enum.EnumMeta (EnumType) methods — Python 3.11+"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [new,      "EnumMeta.__new__.__qualname__.__len__",      [], 16]
    - [contains, "EnumMeta.__contains__.__qualname__.__len__", [], 21]
    - [getitem,  "EnumMeta.__getitem__.__qualname__.__len__",  [], 20]
    - [iter,     "EnumMeta.__iter__.__qualname__.__len__",     [], 17]
