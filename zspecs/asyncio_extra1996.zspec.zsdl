spec: asyncio_extra1996
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-queue.html"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Wave 580 (_extra1996): __index__, __complex__, __float__, __round__, __abs__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio concurrency primitives are not numeric types and define none of these dunders in their own __dict__."
    - "Covers asyncio.Task, asyncio.Future, asyncio.Event, asyncio.Lock, asyncio.Queue, asyncio.Semaphore."
  created_at: "2026-04-12"
error_model: python_exceptions

table asyncio_extra1996.task_index_protocol:
  description: "asyncio.Task __index__ dict-presence check"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1996

  columns: [id, function, args, expected]
  rows:
    - ["as1996001", "asyncio.Task.__dict__.__contains__",      ["__index__"],   false]
    - ["as1996002", "asyncio.Future.__dict__.__contains__",    ["__index__"],   false]
    - ["as1996003", "asyncio.Event.__dict__.__contains__",     ["__index__"],   false]
    - ["as1996004", "asyncio.Lock.__dict__.__contains__",      ["__index__"],   false]
    - ["as1996005", "asyncio.Queue.__dict__.__contains__",     ["__index__"],   false]
    - ["as1996006", "asyncio.Semaphore.__dict__.__contains__", ["__index__"],   false]

