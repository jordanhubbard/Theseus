spec: functools_extra111
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra110.zspec.zsdl."
    - "This spec covers: functools.WRAPPER_ASSIGNMENTS and functools.WRAPPER_UPDATES tuple identity (class name, length); functools.partial and functools.partialmethod class identity (__name__, __module__, __bases__[0].__name__, __mro__.__len__); functools.reduce and functools.cmp_to_key C-extension identity (class name, module); wave 259."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'. Verified with Python 3.14.3."
    - "len(functools.WRAPPER_ASSIGNMENTS) == 6. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'. Verified with Python 3.14.3."
    - "len(functools.WRAPPER_UPDATES) == 1. Verified with Python 3.14.3."
    - "functools.partial.__name__ == 'partial'. Verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.partial.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "functools.partial.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "functools.partial.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "functools.partialmethod.__name__ == 'partialmethod'. Verified with Python 3.14.3."
    - "functools.partialmethod.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.partialmethod.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "functools.partialmethod.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools'. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__module__ == '_functools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES tuple identity
#
# Wave 259 theme: functools.WRAPPER_ASSIGNMENTS and functools.WRAPPER_UPDATES
# are module-level tuple constants. WRAPPER_ASSIGNMENTS has 6 entries
# (the attributes copied by update_wrapper/wraps). WRAPPER_UPDATES has 1
# entry ('__dict__'). Both are plain tuple objects.
#
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
# len(functools.WRAPPER_ASSIGNMENTS) == 6
# functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'
# len(functools.WRAPPER_UPDATES) == 1
#
# New to extra111.
# ---------------------------------------------------------------------------

table functools_extra111.wrapper_constants_identity:
  description: "functools.WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES tuple class name and length; WRAPPER_ASSIGNMENTS has 6 entries, WRAPPER_UPDATES has 1; wave 259; new to extra111"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolswrapconst111

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_class_name_tuple,
       "WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level tuple constant in Lib/functools.py listing the attributes copied by update_wrapper (and wraps); it is a plain Python tuple; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra111"]
    - [wrapper_assignments_len_6,
       "WRAPPER_ASSIGNMENTS.__len__",
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS contains 6 attribute names: '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'; tuple.__len__() returns 6; new to extra111"]
    - [wrapper_updates_class_name_tuple,
       "WRAPPER_UPDATES.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a module-level tuple constant listing attributes that are updated (merged) by update_wrapper; it is a plain Python tuple; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra111"]
    - [wrapper_updates_len_1,
       "WRAPPER_UPDATES.__len__",
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES contains exactly 1 attribute name: '__dict__'; the wrapper's __dict__ is updated from the wrapped function's __dict__; tuple.__len__() returns 1; new to extra111"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial and functools.partialmethod class identity
#
# Wave 259 theme: functools.partial is a C extension type (from
# Modules/_functoolsmodule.c) but its __module__ is 'functools' (set
# explicitly). functools.partialmethod is a pure-Python class in
# Lib/functools.py. Both have __bases__ == (object,) and MRO length 2.
#
# functools.partial.__name__ == 'partial'
# functools.partial.__module__ == 'functools'
# functools.partial.__bases__[0].__name__ == 'object'
# functools.partial.__mro__.__len__() == 2
# functools.partialmethod.__name__ == 'partialmethod'
# functools.partialmethod.__module__ == 'functools'
# functools.partialmethod.__bases__[0].__name__ == 'object'
# functools.partialmethod.__mro__.__len__() == 2
#
# New to extra111.
# ---------------------------------------------------------------------------

table functools_extra111.partial_class_identity:
  description: "functools.partial and functools.partialmethod class identity (__name__, __module__, __bases__[0].__name__, __mro__.__len__); both inherit from object with MRO depth 2; wave 259; new to extra111"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolspartial111

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_eq,
       "partial.__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — functools.partial is a C extension type whose __name__ is 'partial'; str.__eq__('partial') returns True; new to extra111"]
    - [partial_module_eq,
       "partial.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — functools.partial.__module__ is 'functools' (set explicitly even though the C implementation is in Modules/_functoolsmodule.c); str.__eq__('functools') returns True; new to extra111"]
    - ["partial_bases_0_name_object",
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial inherits directly from object; __bases__[0] is object; object.__name__ is 'object'; str.__eq__('object') returns True; new to extra111"]
    - [partial_mro_len_2,
       "partial.__mro__.__len__",
       [],
       2,
       "functools.partial.__mro__.__len__() == 2 — partial inherits directly from object; its MRO is [partial, object] with length 2; new to extra111"]
    - [partialmethod_name_eq,
       "partialmethod.__name__.__eq__",
       ["partialmethod"],
       true,
       "functools.partialmethod.__name__.__eq__('partialmethod') == True — functools.partialmethod is a pure-Python class in Lib/functools.py; its __name__ is 'partialmethod'; str.__eq__('partialmethod') returns True; new to extra111"]
    - [partialmethod_module_eq,
       "partialmethod.__module__.__eq__",
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod is defined in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra111"]
    - ["partialmethod_bases_0_name_object",
       "partialmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__bases__[0].__name__.__eq__('object') == True — partialmethod inherits directly from object; __bases__[0] is object; object.__name__ is 'object'; str.__eq__('object') returns True; new to extra111"]
    - [partialmethod_mro_len_2,
       "partialmethod.__mro__.__len__",
       [],
       2,
       "functools.partialmethod.__mro__.__len__() == 2 — partialmethod inherits directly from object; its MRO is [partialmethod, object] with length 2; new to extra111"]

# ---------------------------------------------------------------------------
# Table 3: functools.reduce and functools.cmp_to_key C-extension identity
#
# Wave 259 theme: functools.reduce and functools.cmp_to_key are C extension
# functions from Modules/_functoolsmodule.c. Their __class__.__name__ is
# 'builtin_function_or_method' and their __module__ is '_functools'
# (the underlying C extension module), not 'functools'.
#
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
# functools.reduce.__module__ == '_functools'
# functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'
# functools.cmp_to_key.__module__ == '_functools'
#
# New to extra111.
# ---------------------------------------------------------------------------

table functools_extra111.c_extension_function_identity:
  description: "functools.reduce and functools.cmp_to_key are C extension functions; class name is 'builtin_function_or_method'; __module__ is '_functools' (not 'functools'); wave 259; new to extra111"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolscext111

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_name_builtin,
       "reduce.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — functools.reduce is a C extension function defined in Modules/_functoolsmodule.c; accessed at module level it is a builtin_function_or_method; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra111"]
    - [reduce_module_functools_c,
       "reduce.__module__.__eq__",
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — functools.reduce is implemented in the C extension _functools (Modules/_functoolsmodule.c); its __module__ is '_functools' (not 'functools'); this contrasts with pure-Python functools functions whose __module__ is 'functools'; str.__eq__('_functools') returns True; new to extra111"]
    - [cmp_to_key_class_name_builtin,
       "cmp_to_key.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — functools.cmp_to_key is a C extension function from Modules/_functoolsmodule.c; it is a builtin_function_or_method; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra111"]
    - [cmp_to_key_module_functools_c,
       "cmp_to_key.__module__.__eq__",
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is implemented in the C extension _functools; its __module__ is '_functools'; this distinguishes it from pure-Python functools functions; str.__eq__('_functools') returns True; new to extra111"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra111
# ---------------------------------------------------------------------------

invariant functools_extra111.wrapper_assignments_len:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — tuple of 6 attribute names copied by update_wrapper; wave 259; new to extra111"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra111.wrapper_updates_len:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — tuple of 1 attribute name ('__dict__') updated by update_wrapper; wave 259; new to extra111"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra111.partial_mro_len:
  description: "functools.partial.__mro__.__len__() == 2 — partial inherits directly from object; MRO is [partial, object]; wave 259; new to extra111"
  kind: python_call_eq
  function: partial.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra111.reduce_module_c_functools:
  description: "functools.reduce.__module__ == '_functools' — C extension function module is '_functools', not 'functools'; contrast with pure-Python functools functions; wave 259; new to extra111"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra111.partialmethod_mro_len:
  description: "functools.partialmethod.__mro__.__len__() == 2 — pure-Python class inheriting directly from object; MRO is [partialmethod, object]; wave 259; new to extra111"
  kind: python_call_eq
  function: partialmethod.__mro__.__len__
  args: []
  expected: 2

