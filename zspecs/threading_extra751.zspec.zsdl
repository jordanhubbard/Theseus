spec: threading_extra751
version: ">=3.9"
backend: python_module(threading)
docs: "Behavioral specs for threading module-level function and attribute identity checks"
provenance:
  derived_from:
    - "Python 3.9+ standard library threading module"
  not_derived_from:
    - "any third-party threading extension"
  notes:
    - "Covers __class__.__name__ and __qualname__ identity for threading module attributes"
    - "Mixes function-class checks with qualname checks depending on attribute kind"
  created_at: "2026-04-12"
error_model: python_exceptions

table threading_extra751.identity:
  description: "Verify class names and qualnames for threading module-level attributes"
  kind: python_call_eq
  category: identity
  id_prefix: th751xx
  columns: [id, function, args, expected]
  rows:
    - [th751xx001, threading.current_thread.__class__.__name__.__eq__, ["function"], true]
    - [th751xx002, threading.main_thread.__class__.__name__.__eq__, ["function"], true]
    - [th751xx003, threading.active_count.__class__.__name__.__eq__, ["function"], true]
    - [th751xx004, threading.enumerate.__class__.__name__.__eq__, ["function"], true]
    - [th751xx005, threading.settrace.__qualname__.__eq__, ["settrace"], true]
    - [th751xx006, threading.setprofile.__qualname__.__eq__, ["setprofile"], true]
    - [th751xx007, threading.stack_size.__qualname__.__eq__, ["stack_size"], true]
    - [th751xx008, threading.excepthook.__qualname__.__eq__, ["excepthook"], true]
    - [th751xx009, threading.get_ident.__qualname__.__eq__, ["get_ident"], true]
    - [th751xx010, threading.get_native_id.__qualname__.__eq__, ["get_native_id"], true]
    - [th751xx011, threading.TIMEOUT_MAX.__class__.__name__.__eq__, ["float"], true]
    - [th751xx012, threading.local.__class__.__name__.__eq__, ["type"], true]
