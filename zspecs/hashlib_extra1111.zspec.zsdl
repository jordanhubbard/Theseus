spec: hashlib_extra1111
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib.__name__ and class identity, hashlib.__doc__.__class__.__name__, HASH instance __doc__ class attrs, hashlib.algorithms_guaranteed/available class attrs, pbkdf2_hmac qualname/module/class, hashlib.new qualname/module/class"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1111.module_name_attrs:
  description: "hashlib.__name__ identity and class attributes"
  kind: python_call_eq
  category: module_name_attrs
  id_prefix: hl1111mn
  columns: [id, function, args, expected]
  rows:
    - [hl1111mn001, hashlib.__name__.__eq__,                            ["hashlib"],  true]
    - [hl1111mn002, hashlib.__name__.__class__.__name__.__eq__,         ["str"],      true]
    - [hl1111mn003, hashlib.__name__.__class__.__qualname__.__eq__,     ["str"],      true]
    - [hl1111mn004, hashlib.__name__.__class__.__module__.__eq__,       ["builtins"], true]
    - [hl1111mn005, hashlib.__doc__.__class__.__name__.__eq__,          ["str"],      true]
    - [hl1111mn006, hashlib.__doc__.__class__.__qualname__.__eq__,      ["str"],      true]
    - [hl1111mn007, hashlib.__doc__.__class__.__module__.__eq__,        ["builtins"], true]
    - [hl1111mn008, hashlib.algorithms_guaranteed.__class__.__name__.__eq__,    ["set"], true]
    - [hl1111mn009, hashlib.algorithms_available.__class__.__name__.__eq__,     ["set"], true]
    - [hl1111mn010, hashlib.algorithms_guaranteed.__class__.__qualname__.__eq__, ["set"], true]

table hashlib_extra1111.algorithms_len_qualnames:
  description: "hashlib.algorithms_guaranteed and algorithms_available __len__.__qualname__ identity"
  kind: python_call_eq
  category: algorithms_len_qualnames
  id_prefix: hl1111al
  columns: [id, function, args, expected]
  rows:
    - [hl1111al001, hashlib.algorithms_guaranteed.__len__.__qualname__.__eq__,              ["set.__len__"], true]
    - [hl1111al002, hashlib.algorithms_available.__len__.__qualname__.__eq__,               ["set.__len__"], true]
    - [hl1111al003, hashlib.algorithms_guaranteed.__len__.__qualname__.__class__.__name__.__eq__, ["str"],   true]
    - [hl1111al004, hashlib.algorithms_available.__len__.__qualname__.__class__.__name__.__eq__,  ["str"],   true]
    - [hl1111al005, hashlib.algorithms_guaranteed.__len__.__class__.__name__.__eq__,        ["method-wrapper"], true]
    - [hl1111al006, hashlib.algorithms_available.__len__.__class__.__name__.__eq__,         ["method-wrapper"], true]
    - [hl1111al007, hashlib.algorithms_guaranteed.__class__.__name__.__eq__,                ["set"],            true]
    - [hl1111al008, hashlib.algorithms_available.__class__.__name__.__eq__,                 ["set"],            true]

table hashlib_extra1111.pbkdf2_and_new_attrs:
  description: "hashlib.pbkdf2_hmac and hashlib.new qualname, module, class identity"
  kind: python_call_eq
  category: pbkdf2_new_attrs
  id_prefix: hl1111pn
  columns: [id, function, args, expected]
  rows:
    - [hl1111pn001, hashlib.pbkdf2_hmac.__qualname__.__eq__,              ["pbkdf2_hmac"],               true]
    - [hl1111pn002, hashlib.pbkdf2_hmac.__module__.__eq__,                ["_hashlib"],                  true]
    - [hl1111pn003, hashlib.pbkdf2_hmac.__class__.__name__.__eq__,        ["builtin_function_or_method"], true]
    - [hl1111pn004, hashlib.pbkdf2_hmac.__qualname__.__class__.__name__.__eq__, ["str"],                 true]
    - [hl1111pn005, hashlib.pbkdf2_hmac.__module__.__class__.__name__.__eq__,   ["str"],                 true]
    - [hl1111pn006, hashlib.new.__qualname__.__eq__,                       ["__hash_new"],               true]
    - [hl1111pn007, hashlib.new.__module__.__eq__,                         ["hashlib"],                  true]
    - [hl1111pn008, hashlib.new.__class__.__name__.__eq__,                 ["function"],                 true]
    - [hl1111pn009, hashlib.new.__qualname__.__class__.__name__.__eq__,    ["str"],                      true]
    - [hl1111pn010, hashlib.new.__module__.__class__.__name__.__eq__,      ["str"],                      true]
