# Function names — verify the module exports the expected callables
# ---------------------------------------------------------------------------

invariant locale.names.setlocale:
  description: "locale.setlocale.__name__ == 'setlocale'"
  category: names
  kind: python_call_eq
  function: "setlocale.__name__.__eq__"
  args: ["setlocale"]
  expected: true

invariant locale.names.getlocale:
  description: "locale.getlocale.__name__ == 'getlocale'"
  category: names
  kind: python_call_eq
  function: "getlocale.__name__.__eq__"
  args: ["getlocale"]
  expected: true

invariant locale.names.getpreferredencoding:
  description: "locale.getpreferredencoding.__name__ == 'getpreferredencoding'"
  category: names
  kind: python_call_eq
