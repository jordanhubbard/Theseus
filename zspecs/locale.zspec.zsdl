spec: locale
version: ">=3.x"
backend: python_module(locale)

docs: https://docs.python.org/3/library/locale.html

provenance:
  derived_from:
    - "Python locale documentation — https://docs.python.org/3/library/locale.html"
    - "Test vectors verified by running Python 3.14.3 locale module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/locale.py"
  notes:
    - "locale.LC_ALL, LC_CTYPE, LC_NUMERIC, LC_TIME, LC_COLLATE, LC_MONETARY are integer constants whose exact values are platform-specific."
    - "All LC_* constants are plain Python int objects regardless of platform."
    - "locale.setlocale(locale.LC_ALL, '') resets to the environment locale; setlocale(locale.LC_ALL, 'C') uses the POSIX C locale."
    - "locale.getpreferredencoding(False) returns the default encoding string without side-effecting the locale state."
    - "locale.getlocale() returns a (language code, encoding) tuple for the current locale."
    - "locale.format_string, locale.currency, locale.atoi, locale.atof are callable functions in the module."
    - "locale.resetlocale() is deprecated in Python 3.11 and removed in Python 3.13; its presence is tested only for >=3.9,<3.13."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "locale functions raise locale.Error (a subclass of ValueError) when an unsupported locale is requested."
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# LC_* constants — all must be plain ints (portable across macOS and Linux)
# ---------------------------------------------------------------------------

invariant locale.LC_ALL.is_int:
  description: "locale.LC_ALL.__class__.__name__ == 'int' — LC_ALL is a plain int"
  category: constants
  kind: python_call_eq
  function: "LC_ALL.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

invariant locale.LC_CTYPE.is_int:
  description: "locale.LC_CTYPE.__class__.__name__ == 'int' — LC_CTYPE is a plain int"
  category: constants
  kind: python_call_eq
  function: "LC_CTYPE.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

invariant locale.LC_NUMERIC.is_int:
  description: "locale.LC_NUMERIC.__class__.__name__ == 'int' — LC_NUMERIC is a plain int"
  category: constants
  kind: python_call_eq
  function: "LC_NUMERIC.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

invariant locale.LC_TIME.is_int:
  description: "locale.LC_TIME.__class__.__name__ == 'int' — LC_TIME is a plain int"
  category: constants
  kind: python_call_eq
  function: "LC_TIME.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

invariant locale.LC_COLLATE.is_int:
  description: "locale.LC_COLLATE.__class__.__name__ == 'int' — LC_COLLATE is a plain int"
  category: constants
  kind: python_call_eq
  function: "LC_COLLATE.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

invariant locale.LC_MONETARY.is_int:
  description: "locale.LC_MONETARY.__class__.__name__ == 'int' — LC_MONETARY is a plain int"
  category: constants
  kind: python_call_eq
  function: "LC_MONETARY.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

