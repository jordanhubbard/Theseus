# ---------------------------------------------------------------------------
# getpreferredencoding(False) — returns a str (side-effect-free probe)
# ---------------------------------------------------------------------------

invariant locale.getpreferredencoding.returns_str:
  description: "locale.getpreferredencoding(False).__class__.__name__ == 'str' — result is a string"
  category: getpreferredencoding
  kind: python_call_eq
  function: getpreferredencoding
  args: [false]
  method: __class__
  method_chain: __name__
  expected: "str"

invariant locale.getpreferredencoding.nonempty:
  description: "len(locale.getpreferredencoding(False)) > 0 — encoding name is non-empty"
  category: getpreferredencoding
  kind: python_call_eq
  function: getpreferredencoding
  args: [false]
  method: __len__
  method_chain: __gt__
  method_chain_args: [0]
  expected: true

