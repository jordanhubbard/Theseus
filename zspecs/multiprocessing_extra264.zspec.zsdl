spec: multiprocessing_extra264
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/synchronize.py"
  notes:
    - "multiprocessing.Semaphore is a bound method (factory) on the context object; __module__ == 'multiprocessing.context'."
    - "multiprocessing.Lock is a bound method (factory) on the context object; __module__ == 'multiprocessing.context'."
    - "multiprocessing.Event is a bound method (factory) on the context object; __module__ == 'multiprocessing.context'."
    - "multiprocessing.RLock is a bound method (factory) on the context object; __module__ == 'multiprocessing.context'."
    - "multiprocessing.Barrier is a bound method (factory) on the context object; __module__ == 'multiprocessing.context'."
    - "multiprocessing.Condition is a bound method (factory) on the context object; __module__ == 'multiprocessing.context'."
    - "All of these factories have __qualname__ prefixed with 'BaseContext.' (e.g., 'BaseContext.Semaphore')."
    - "The __name__ of each factory is the unqualified synchronization primitive name."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing synchronization factories — __module__ table
#
# Semaphore, Lock, Event, RLock, Barrier, and Condition are all bound-method
# factories on the default context object. Their __module__ is
# 'multiprocessing.context' and their __name__ is the primitive name.
# ---------------------------------------------------------------------------

table multiprocessing_extra264.sync_factory_modules:
  description: "multiprocessing synchronization factory __name__ and __module__ values"
  kind: python_call_eq
  category: identity
  id_prefix: sfmod

  columns: [id, function, args, expected, description]
  rows:
    - [sem_name,   Semaphore.__name__.__eq__,   ["Semaphore"],              true, "multiprocessing.Semaphore.__name__ == 'Semaphore'"]
    - [sem_mod,    Semaphore.__module__.__eq__,  ["multiprocessing.context"], true, "multiprocessing.Semaphore.__module__ == 'multiprocessing.context'"]
    - [lck_name,   Lock.__name__.__eq__,         ["Lock"],                   true, "multiprocessing.Lock.__name__ == 'Lock'"]
    - [lck_mod,    Lock.__module__.__eq__,        ["multiprocessing.context"], true, "multiprocessing.Lock.__module__ == 'multiprocessing.context'"]
    - [evt_name,   Event.__name__.__eq__,         ["Event"],                  true, "multiprocessing.Event.__name__ == 'Event'"]
    - [evt_mod,    Event.__module__.__eq__,        ["multiprocessing.context"], true, "multiprocessing.Event.__module__ == 'multiprocessing.context'"]

# ---------------------------------------------------------------------------
# multiprocessing synchronization factories — __qualname__ table
#
# Each factory's __qualname__ is prefixed with 'BaseContext.' because these
# are bound methods defined on the BaseContext class.
# ---------------------------------------------------------------------------

table multiprocessing_extra264.sync_factory_qualnames:
  description: "multiprocessing synchronization factory __qualname__ values"
  kind: python_call_eq
  category: identity
  id_prefix: sfqn

  columns: [id, function, args, expected, description]
  rows:
    - [sem_qn,   Semaphore.__qualname__.__eq__,  ["BaseContext.Semaphore"],  true, "multiprocessing.Semaphore.__qualname__ == 'BaseContext.Semaphore'"]
    - [lck_qn,   Lock.__qualname__.__eq__,        ["BaseContext.Lock"],       true, "multiprocessing.Lock.__qualname__ == 'BaseContext.Lock'"]
    - [evt_qn,   Event.__qualname__.__eq__,        ["BaseContext.Event"],      true, "multiprocessing.Event.__qualname__ == 'BaseContext.Event'"]
    - [rlk_qn,   RLock.__qualname__.__eq__,        ["BaseContext.RLock"],      true, "multiprocessing.RLock.__qualname__ == 'BaseContext.RLock'"]
    - [brr_qn,   Barrier.__qualname__.__eq__,      ["BaseContext.Barrier"],    true, "multiprocessing.Barrier.__qualname__ == 'BaseContext.Barrier'"]
    - [cnd_qn,   Condition.__qualname__.__eq__,    ["BaseContext.Condition"],  true, "multiprocessing.Condition.__qualname__ == 'BaseContext.Condition'"]

# ---------------------------------------------------------------------------
# multiprocessing.RLock, Barrier, Condition — module standalone invariants
# ---------------------------------------------------------------------------

invariant multiprocessing_extra264.RLock.module:
  description: "multiprocessing.RLock.__module__ == 'multiprocessing.context'"
  category: identity
  kind: python_call_eq
  function: RLock.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra264.RLock.name:
  description: "multiprocessing.RLock.__name__ == 'RLock'"
  category: identity
  kind: python_call_eq
  function: RLock.__name__.__eq__
  args: ["RLock"]
  expected: true

invariant multiprocessing_extra264.Barrier.module:
  description: "multiprocessing.Barrier.__module__ == 'multiprocessing.context'"
  category: identity
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra264.Barrier.name:
  description: "multiprocessing.Barrier.__name__ == 'Barrier'"
  category: identity
  kind: python_call_eq
  function: Barrier.__name__.__eq__
  args: ["Barrier"]
  expected: true

invariant multiprocessing_extra264.Condition.module:
  description: "multiprocessing.Condition.__module__ == 'multiprocessing.context'"
  category: identity
  kind: python_call_eq
  function: Condition.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra264.Condition.name:
  description: "multiprocessing.Condition.__name__ == 'Condition'"
  category: identity
  kind: python_call_eq
  function: Condition.__name__.__eq__
  args: ["Condition"]
  expected: true
