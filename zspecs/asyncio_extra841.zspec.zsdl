    - [as841xx003, asyncio.sleep.__qualname__.__eq__, ["sleep"], true]
    - [as841xx004, asyncio.sleep.__module__.__eq__, ["asyncio"], true]
    - [as841xx005, asyncio.gather.__qualname__.__eq__, ["gather"], true]
    - [as841xx006, asyncio.gather.__module__.__eq__, ["asyncio"], true]
    - [as841xx007, asyncio.wait.__qualname__.__eq__, ["wait"], true]
    - [as841xx008, asyncio.wait.__module__.__eq__, ["asyncio"], true]
    - [as841xx009, asyncio.create_task.__qualname__.__eq__, ["create_task"], true]
    - [as841xx010, asyncio.create_task.__module__.__eq__, ["asyncio"], true]
    - [as841xx011, asyncio.ensure_future.__qualname__.__eq__, ["ensure_future"], true]
