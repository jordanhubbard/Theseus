spec: inspect_extra2821
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "any proprietary source"
  notes:
    - "Wave 635 (_extra2821): __radd__, __rsub__, and __rmul__ dict-presence checks (reflected/right-hand addition, subtraction, multiplication)."
    - "inspect.Parameter is a pure-Python class modeling a callable parameter — no reflected arithmetic operators."
    - "inspect.BoundArguments is a pure-Python class holding bound argument mappings — no reflected arithmetic operators."
    - "inspect.Signature is a pure-Python class representing a callable's signature — no reflected arithmetic operators."
    - "inspect.FullArgSpec is a named-tuple subclass holding argument specification data — no reflected arithmetic operators."
    - "Introspection data containers have no numeric arithmetic semantics; reflected operators (__radd__, __rsub__, __rmul__) are entirely absent."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __radd__ dict-presence (reflected addition)
#
# inspect.Parameter, BoundArguments, Signature, FullArgSpec are introspection
# data containers — none define __radd__ in their own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra2821.radd_protocol:
  description: "inspect types __radd__ dict-presence checks — all False (no reflected addition protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2821
  columns: [id, function, args, expected]
  rows:
    - ["in2821001", "inspect.Parameter.__dict__.__contains__",      ["__radd__"], false]
    - ["in2821002", "inspect.BoundArguments.__dict__.__contains__", ["__radd__"], false]
    - ["in2821003", "inspect.Signature.__dict__.__contains__",      ["__radd__"], false]
    - ["in2821004", "inspect.FullArgSpec.__dict__.__contains__",    ["__radd__"], false]

# ---------------------------------------------------------------------------
# Table 2: __rsub__ dict-presence (reflected subtraction)
#
# None of the inspect introspection types define __rsub__ — they model
# callable metadata and have no numeric subtraction semantics.
# ---------------------------------------------------------------------------

table inspect_extra2821.rsub_protocol:
  description: "inspect types __rsub__ dict-presence checks — all False (no reflected subtraction protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2821
  columns: [id, function, args, expected]
  rows:
    - ["in2821005", "inspect.Parameter.__dict__.__contains__",      ["__rsub__"], false]
    - ["in2821006", "inspect.BoundArguments.__dict__.__contains__", ["__rsub__"], false]
    - ["in2821007", "inspect.Signature.__dict__.__contains__",      ["__rsub__"], false]
    - ["in2821008", "inspect.FullArgSpec.__dict__.__contains__",    ["__rsub__"], false]

# ---------------------------------------------------------------------------
# Table 3: __rmul__ dict-presence (reflected multiplication)
#
# None of the inspect types define __rmul__ — signature and argument
# introspection objects have no multiplication or sequence repetition semantics.
# ---------------------------------------------------------------------------

table inspect_extra2821.rmul_protocol:
  description: "inspect types __rmul__ dict-presence checks — all False (no reflected multiplication protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2821
  columns: [id, function, args, expected]
  rows:
    - ["in2821009", "inspect.Parameter.__dict__.__contains__",      ["__rmul__"], false]
    - ["in2821010", "inspect.BoundArguments.__dict__.__contains__", ["__rmul__"], false]
    - ["in2821011", "inspect.Signature.__dict__.__contains__",      ["__rmul__"], false]
    - ["in2821012", "inspect.FullArgSpec.__dict__.__contains__",    ["__rmul__"], false]

# ---------------------------------------------------------------------------
# Table 4: combined reflected arithmetic operator absence — all types, all ops
#
# Cross-check: each inspect type lacks all three reflected arithmetic operators.
# Confirms that the inspect API is strictly an introspection surface with
# no numeric addition, subtraction, or multiplication semantics.
# ---------------------------------------------------------------------------

table inspect_extra2821.reflected_arith_absent:
  description: "inspect types full __radd__/__rsub__/__rmul__ absence cross-check — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2821
  columns: [id, function, args, expected]
  rows:
    - ["in2821013", "inspect.Parameter.__dict__.__contains__",      ["__radd__"], false]
    - ["in2821014", "inspect.Parameter.__dict__.__contains__",      ["__rsub__"], false]
    - ["in2821015", "inspect.Parameter.__dict__.__contains__",      ["__rmul__"], false]
    - ["in2821016", "inspect.BoundArguments.__dict__.__contains__", ["__radd__"], false]
    - ["in2821017", "inspect.BoundArguments.__dict__.__contains__", ["__rsub__"], false]
    - ["in2821018", "inspect.BoundArguments.__dict__.__contains__", ["__rmul__"], false]
    - ["in2821019", "inspect.Signature.__dict__.__contains__",      ["__radd__"], false]
    - ["in2821020", "inspect.Signature.__dict__.__contains__",      ["__rsub__"], false]
    - ["in2821021", "inspect.Signature.__dict__.__contains__",      ["__rmul__"], false]
    - ["in2821022", "inspect.FullArgSpec.__dict__.__contains__",    ["__radd__"], false]
    - ["in2821023", "inspect.FullArgSpec.__dict__.__contains__",    ["__rsub__"], false]
    - ["in2821024", "inspect.FullArgSpec.__dict__.__contains__",    ["__rmul__"], false]
