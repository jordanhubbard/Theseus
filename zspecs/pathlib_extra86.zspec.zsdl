spec: pathlib_extra86
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra85."
    - "Prior specs covered: PurePath/Path class identity; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes for open/read_text/write_text/iterdir/mkdir/exists/unlink/stat/rename/read_bytes/write_bytes/touch/rmdir/resolve/glob/rglob/is_dir/is_file/absolute/symlink_to/hardlink_to/lstat/expanduser/chmod/with_name/with_suffix/with_stem; PurePath/__dict__ membership; Path/__dict__ membership; Path.parent/name/suffix/stem/parts/drive as property descriptors; Path.read_text/write_text/read_bytes/write_bytes/open/unlink/rename/replace __code__.co_name and co_argcount."
    - "This spec covers: Path.mkdir/__code__.co_name and co_argcount; Path.rmdir/__code__.co_name and co_argcount; Path.iterdir/__code__.co_name and co_argcount; Path.stat/__code__.co_name and co_argcount; Path.lstat/__code__.co_name and co_argcount; Path.resolve/__code__.co_name and co_argcount; Path.absolute/__code__.co_name and co_argcount; Path.expanduser/__code__.co_name and co_argcount."
    - "pathlib.Path.mkdir.__code__.co_name == 'mkdir' — verified by code object attribute."
    - "pathlib.Path.mkdir.__code__.co_argcount == 4 — mkdir(self, mode=0o777, parents=False, exist_ok=False): 4 positional-or-keyword args."
    - "pathlib.Path.rmdir.__code__.co_name == 'rmdir' — verified by code object attribute."
    - "pathlib.Path.rmdir.__code__.co_argcount == 1 — rmdir(self): self only."
    - "pathlib.Path.iterdir.__code__.co_name == 'iterdir' — verified by code object attribute."
    - "pathlib.Path.iterdir.__code__.co_argcount == 1 — iterdir(self): self only."
    - "pathlib.Path.stat.__code__.co_name == 'stat' — verified by code object attribute."
    - "pathlib.Path.stat.__code__.co_argcount == 1 — stat(self, *, follow_symlinks=True): 1 positional arg (follow_symlinks is keyword-only)."
    - "pathlib.Path.lstat.__code__.co_name == 'lstat' — verified by code object attribute."
    - "pathlib.Path.lstat.__code__.co_argcount == 1 — lstat(self): self only."
    - "pathlib.Path.resolve.__code__.co_name == 'resolve' — verified by code object attribute."
    - "pathlib.Path.resolve.__code__.co_argcount == 2 — resolve(self, strict=False): self + strict."
    - "pathlib.Path.absolute.__code__.co_name == 'absolute' — verified by code object attribute."
    - "pathlib.Path.absolute.__code__.co_argcount == 1 — absolute(self): self only."
    - "pathlib.Path.expanduser.__code__.co_name == 'expanduser' — verified by code object attribute."
    - "pathlib.Path.expanduser.__code__.co_argcount == 1 — expanduser(self): self only."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.mkdir and Path.rmdir __code__ attributes
# mkdir(self, mode=0o777, parents=False, exist_ok=False): co_argcount == 4.
# rmdir(self): co_argcount == 1 (self only).
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra86.mkdir_rmdir_code:
  description: "Path.mkdir and Path.rmdir __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibextra86

  columns: [id, function, args, expected]
  rows:
    - [mkdir_co_name, Path.mkdir.__code__.co_name.__eq__,      ["mkdir"], true]
    - [mkdir_co_argc, Path.mkdir.__code__.co_argcount.__eq__,  [4],       true]
    - [rmdir_co_name, Path.rmdir.__code__.co_name.__eq__,      ["rmdir"], true]
    - [rmdir_co_argc, Path.rmdir.__code__.co_argcount.__eq__,  [1],       true]

# ---------------------------------------------------------------------------
# Path.iterdir and Path.stat __code__ attributes
# iterdir(self): co_argcount == 1 (self only).
# stat(self, *, follow_symlinks=True): co_argcount == 1 (follow_symlinks is keyword-only).
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra86.iterdir_stat_code:
  description: "Path.iterdir and Path.stat __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibextra86

  columns: [id, function, args, expected]
  rows:
    - [iterdir_co_name, Path.iterdir.__code__.co_name.__eq__,      ["iterdir"], true]
    - [iterdir_co_argc, Path.iterdir.__code__.co_argcount.__eq__,  [1],         true]
    - [stat_co_name,    Path.stat.__code__.co_name.__eq__,         ["stat"],    true]
    - [stat_co_argc,    Path.stat.__code__.co_argcount.__eq__,     [1],         true]

# ---------------------------------------------------------------------------
# Path.lstat and Path.resolve __code__ attributes
# lstat(self): co_argcount == 1 (self only).
# resolve(self, strict=False): co_argcount == 2 (self + strict).
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra86.lstat_resolve_code:
  description: "Path.lstat and Path.resolve __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibextra86

  columns: [id, function, args, expected]
  rows:
    - [lstat_co_name,   Path.lstat.__code__.co_name.__eq__,      ["lstat"],   true]
    - [lstat_co_argc,   Path.lstat.__code__.co_argcount.__eq__,  [1],         true]
    - [resolve_co_name, Path.resolve.__code__.co_name.__eq__,    ["resolve"], true]
    - [resolve_co_argc, Path.resolve.__code__.co_argcount.__eq__, [2],        true]

# ---------------------------------------------------------------------------
# Path.absolute and Path.expanduser __code__ attributes
# absolute(self): co_argcount == 1 (self only).
# expanduser(self): co_argcount == 1 (self only).
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra86.absolute_expanduser_code:
  description: "Path.absolute and Path.expanduser __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibextra86

  columns: [id, function, args, expected]
  rows:
    - [abs_co_name,  Path.absolute.__code__.co_name.__eq__,       ["absolute"],   true]
    - [abs_co_argc,  Path.absolute.__code__.co_argcount.__eq__,   [1],            true]
    - [exp_co_name,  Path.expanduser.__code__.co_name.__eq__,     ["expanduser"], true]
    - [exp_co_argc,  Path.expanduser.__code__.co_argcount.__eq__, [1],            true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra86.mkdir_code.co_name:
  description: "pathlib.Path.mkdir.__code__.co_name == 'mkdir'"
  category: code_attrs
  kind: python_call_eq
  function: Path.mkdir.__code__.co_name.__eq__
  args: ["mkdir"]
  expected: true

invariant pathlib_extra86.mkdir_code.co_argcount:
  description: "pathlib.Path.mkdir.__code__.co_argcount == 4 (self + mode + parents + exist_ok)"
  category: code_attrs
  kind: python_call_eq
  function: Path.mkdir.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant pathlib_extra86.resolve_code.co_argcount:
  description: "pathlib.Path.resolve.__code__.co_argcount == 2 (self + strict)"
  category: code_attrs
  kind: python_call_eq
  function: Path.resolve.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant pathlib_extra86.iterdir_code.co_name:
  description: "pathlib.Path.iterdir.__code__.co_name == 'iterdir'"
  category: code_attrs
  kind: python_call_eq
  function: Path.iterdir.__code__.co_name.__eq__
  args: ["iterdir"]
  expected: true

invariant pathlib_extra86.expanduser_code.co_name:
  description: "pathlib.Path.expanduser.__code__.co_name == 'expanduser'"
  category: code_attrs
  kind: python_call_eq
  function: Path.expanduser.__code__.co_name.__eq__
  args: ["expanduser"]
  expected: true
