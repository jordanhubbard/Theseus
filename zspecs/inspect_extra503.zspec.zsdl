spec: inspect_extra503
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module stack and frame introspection functions"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "__name__ is the unqualified function name; __module__ identifies the defining module"
    - "inspect functions are pure Python; all carry __module__ == 'inspect'"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra503.name_identity:
  description: "Each inspect stack/frame function has the expected __name__ string"
  kind: python_call_eq
  category: attributes
  id_prefix: ISN

  columns: [id, function, args, expected]
  rows:
    - [ISN001, inspect.stack.__name__.__eq__, ["stack"], true]
    - [ISN002, inspect.currentframe.__name__.__eq__, ["currentframe"], true]
    - [ISN003, inspect.getframeinfo.__name__.__eq__, ["getframeinfo"], true]
    - [ISN004, inspect.getouterframes.__name__.__eq__, ["getouterframes"], true]
    - [ISN005, inspect.getinnerframes.__name__.__eq__, ["getinnerframes"], true]
    - [ISN006, inspect.trace.__name__.__eq__, ["trace"], true]
    - [ISN007, inspect.getattr_static.__name__.__eq__, ["getattr_static"], true]
    - [ISN008, inspect.classify_class_attrs.__name__.__eq__, ["classify_class_attrs"], true]
    - [ISN009, inspect.getmro.__name__.__eq__, ["getmro"], true]

table inspect_extra503.module_identity:
  description: "Selected inspect functions carry __module__ == 'inspect'"
  kind: python_call_eq
  category: attributes
  id_prefix: ISM

  columns: [id, function, args, expected]
  rows:
    - [ISM001, inspect.stack.__module__.__eq__, ["inspect"], true]
    - [ISM002, inspect.getframeinfo.__module__.__eq__, ["inspect"], true]
    - [ISM003, inspect.getattr_static.__module__.__eq__, ["inspect"], true]
    - [ISM004, inspect.getmro.__module__.__eq__, ["inspect"], true]
