spec: abc_extra1216
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc.ABCMeta.__dict__.__contains__ for register/__new__/__instancecheck__/__subclasscheck__, abc.ABC.__dict__.__contains__ for __abstractmethods__/__doc__/_abc_impl/__slots__, abc.abstractproperty/__isabstractmethod__ in __dict__, abc.abstractclassmethod/__isabstractmethod__ in __dict__, abc.abstractstaticmethod/__isabstractmethod__ in __dict__"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc.ABCMeta.__dict__.__contains__ for key members (register, __new__, __instancecheck__, __subclasscheck__), abc.ABC.__dict__.__contains__ for key members (__abstractmethods__, __doc__, _abc_impl, __slots__), and deprecated decorator __dict__.__contains__ for __isabstractmethod__ — behaviors not covered by extra1186 (dict/mro class names) or extra1201 (__bases__/__mro__ lengths)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra1216.abcmeta_dict_contains:
  description: "abc.ABCMeta.__dict__ contains expected protocol members: register, __new__, __instancecheck__, __subclasscheck__"
  kind: python_call_eq
  category: class_interface
  id_prefix: ab1216md
  columns: [id, function, args, expected]
  rows:
    - [ab1216md001, abc.ABCMeta.__dict__.__contains__,  ["register"],           true]
    - [ab1216md002, abc.ABCMeta.__dict__.__contains__,  ["__new__"],            true]
    - [ab1216md003, abc.ABCMeta.__dict__.__contains__,  ["__instancecheck__"],  true]
    - [ab1216md004, abc.ABCMeta.__dict__.__contains__,  ["__subclasscheck__"],  true]
    - [ab1216md005, abc.ABCMeta.__dict__.__contains__,  ["__init__"],           false]
    - [ab1216md006, abc.ABCMeta.__dict__.__contains__,  ["__call__"],           false]
    - [ab1216md007, abc.ABCMeta.__name__.__eq__,        ["ABCMeta"],            true]
    - [ab1216md008, abc.ABCMeta.__name__.__len__.__eq__, [7],                   true]

table abc_extra1216.abc_dict_contains:
  description: "abc.ABC.__dict__ contains __abstractmethods__, __doc__, _abc_impl, __slots__ but not __init__"
  kind: python_call_eq
  category: class_interface
  id_prefix: ab1216ac
  columns: [id, function, args, expected]
  rows:
    - [ab1216ac001, abc.ABC.__dict__.__contains__,  ["__abstractmethods__"], true]
    - [ab1216ac002, abc.ABC.__dict__.__contains__,  ["__doc__"],             true]
    - [ab1216ac003, abc.ABC.__dict__.__contains__,  ["_abc_impl"],           true]
    - [ab1216ac004, abc.ABC.__dict__.__contains__,  ["__slots__"],           true]
    - [ab1216ac005, abc.ABC.__dict__.__contains__,  ["__init__"],            false]
    - [ab1216ac006, abc.ABC.__dict__.__contains__,  ["register"],            false]
    - [ab1216ac007, abc.ABC.__name__.__eq__,        ["ABC"],                 true]
    - [ab1216ac008, abc.ABC.__name__.__len__.__eq__, [3],                    true]
    - [ab1216ac009, abc.ABC.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

table abc_extra1216.abstract_decorators_isabstractmethod:
  description: "abc.abstractproperty, abstractclassmethod, and abstractstaticmethod each define __isabstractmethod__ in their own __dict__"
  kind: python_call_eq
  category: class_interface
  id_prefix: ab1216di
  columns: [id, function, args, expected]
  rows:
    - [ab1216di001, abc.abstractproperty.__dict__.__contains__,     ["__isabstractmethod__"], true]
    - [ab1216di002, abc.abstractclassmethod.__dict__.__contains__,  ["__isabstractmethod__"], true]
    - [ab1216di003, abc.abstractstaticmethod.__dict__.__contains__,  ["__isabstractmethod__"], true]
    - [ab1216di004, abc.abstractproperty.__dict__.__class__.__name__.__eq__,     ["mappingproxy"], true]
    - [ab1216di005, abc.abstractclassmethod.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true]
    - [ab1216di006, abc.abstractstaticmethod.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [ab1216di007, abc.abstractproperty.__name__.__eq__,     ["abstractproperty"],     true]
    - [ab1216di008, abc.abstractclassmethod.__name__.__eq__,  ["abstractclassmethod"],  true]
    - [ab1216di009, abc.abstractstaticmethod.__name__.__eq__, ["abstractstaticmethod"], true]
    - [ab1216di010, abc.abstractproperty.__name__.__len__.__eq__,     [16], true]
    - [ab1216di011, abc.abstractclassmethod.__name__.__len__.__eq__,  [19], true]
    - [ab1216di012, abc.abstractstaticmethod.__name__.__len__.__eq__, [20], true]
