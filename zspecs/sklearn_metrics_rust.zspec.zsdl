spec: sklearn_metrics_rust
version: ">=3.9"
backend: rust_module(sklearn_metrics_rust)

docs: https://scikit-learn.org/stable/modules/classes.html#module-sklearn.metrics

provenance:
  derived_from:
    - "https://scikit-learn.org/stable/modules/classes.html — scikit-learn metrics"
  not_derived_from:
    - "sklearn source: sklearn/metrics/_classification.py"
  notes:
    - "scikit-learn provides machine learning metrics."
    - "accuracy_score([0,1,1,0], [0,1,0,0]) == 0.75."
    - "accuracy_score([1,1,1], [1,1,1]) == 1.0 — perfect."
    - "accuracy_score([0,1], [1,0]) == 0.0 — all wrong."
    - "confusion_matrix([0,1,1,0], [0,1,0,0]) — 2x2 matrix."
    - "Expose accuracy_score(y_true, y_pred) -> float."
    - "Expose precision_binary(y_true, y_pred) -> float."
    - "Expose recall_binary(y_true, y_pred) -> float."
    - "precision([1,1,0,0], [1,0,0,0]) == 1.0 (1 TP, 0 FP)."
    - "recall([1,1,0,0], [1,0,0,0]) == 0.5 (1 TP, 1 FN)."
    - "All test vectors verified against scikit-learn 1.6.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# accuracy_score
table sklearn_metrics_rust.accuracy.vectors:
  kind: python_call_eq
  category: accuracy
  id_prefix: skm_acc
  function: accuracy_score

  columns: [id, args, expected]
  rows:
    - [perfect,   [[1, 1, 1], [1, 1, 1]],       1.0]
    - [all_wrong, [[0, 1], [1, 0]],              0.0]
    - [three_out_4, [[0, 1, 1, 0], [0, 1, 0, 0]], 0.75]

# precision_binary
invariant sklearn_metrics_rust.precision.perfect_prec:
  description: "precision([1,1,0,0], [1,0,0,0]) == 1.0"
  category: precision
  kind: python_call_eq
  function: precision_binary
  args: [[1, 1, 0, 0], [1, 0, 0, 0]]
  expected: 1.0

# recall_binary
invariant sklearn_metrics_rust.recall.half_recall:
  description: "recall([1,1,0,0], [1,0,0,0]) == 0.5"
  category: recall
  kind: python_call_eq
  function: recall_binary
  args: [[1, 1, 0, 0], [1, 0, 0, 0]]
  expected: 0.5

