spec: struct_extra246
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra245.zspec.zsdl — covers Struct network byte order sizes / pack/unpack round-trip for network formats / iter_unpack and pack_into module-level function identity (table + invariants)."
    - "struct_extra244.zspec.zsdl — covers Struct class identity (__name__/__module__/__qualname__/__bases__) / Struct.size for various formats / module-level pack/unpack/calcsize __name__/__module__ (table + invariants)."
  notes:
    - "Wave 295 theme: struct.Struct instance method identity — pack, unpack, pack_into, unpack_from, iter_unpack — and Struct attribute descriptor identity."
    - "struct.Struct.pack.__name__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__qualname__ == 'Struct.pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__name__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__name__ == 'pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__name__ == 'unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__name__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(struct.Struct.size).__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(struct.Struct.format).__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct methods (pack, unpack, pack_into, unpack_from, iter_unpack) are method_descriptors defined in Modules/_struct.c. Their __qualname__ includes the 'Struct.' prefix. This contrasts with the module-level struct.pack/unpack/calcsize which are builtin_function_or_method (not method_descriptors) with __module__=='_struct'."
    - "Note: struct.Struct.size and struct.Struct.format are getset_descriptors (C-level read-only computed properties implemented via PyGetSetDef). getset_descriptor differs from member_descriptor (which maps to a C struct field) and from property (which is a pure Python descriptor). getset_descriptor objects have __name__, __objclass__, and __doc__ but no fget."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct method identity: pack, unpack, pack_into, unpack_from,
# iter_unpack — __name__ and __qualname__
#
# Wave 295 theme: struct.Struct C method __name__ and __qualname__ identity.
#
# The five methods of struct.Struct are method_descriptors from Modules/_struct.c.
# Their __qualname__ always includes the 'Struct.' prefix. pack() serializes
# values according to the format string; unpack() deserializes; pack_into()
# writes into a mutable buffer at an offset; unpack_from() reads from a buffer
# at an offset; iter_unpack() returns an iterator over successive fixed-size
# chunks. struct_extra244 anchors Struct class identity; struct_extra245
# anchors module-level iter_unpack and pack_into identity; no prior spec
# anchors all five Struct instance method __name__/__qualname__ together in a
# grouped table under structmeth295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra246.Struct_method_name_and_qualname:
  description: "Struct.pack.__name__.__eq__('pack')==True / Struct.pack.__qualname__.__eq__('Struct.pack')==True / Struct.unpack.__name__.__eq__('unpack')==True / Struct.unpack.__qualname__.__eq__('Struct.unpack')==True / Struct.pack_into.__name__.__eq__('pack_into')==True / Struct.pack_into.__qualname__.__eq__('Struct.pack_into')==True / Struct.unpack_from.__name__.__eq__('unpack_from')==True / Struct.iter_unpack.__name__.__eq__('iter_unpack')==True / Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack')==True — all five are method_descriptors in _struct.c; qualname includes 'Struct.' prefix; extra244 anchors class identity; extra245 anchors module-level iter_unpack/pack_into; first structmeth295 anchor for Struct instance method __name__/__qualname__"
  kind: python_call_eq
  category: method_identity
  id_prefix: structmeth295

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name_eq,           "Struct.pack.__name__.__eq__",           ["pack"],             true, "struct.Struct.pack.__name__ is 'pack' (serializes values to bytes per format)"]
    - [pack_qualname_eq,       "Struct.pack.__qualname__.__eq__",       ["Struct.pack"],      true, "struct.Struct.pack.__qualname__ is 'Struct.pack' (qualified name includes class prefix)"]
    - [unpack_name_eq,         "Struct.unpack.__name__.__eq__",         ["unpack"],           true, "struct.Struct.unpack.__name__ is 'unpack' (deserializes bytes to tuple per format)"]
    - [unpack_qualname_eq,     "Struct.unpack.__qualname__.__eq__",     ["Struct.unpack"],    true, "struct.Struct.unpack.__qualname__ is 'Struct.unpack'"]
    - [pack_into_name_eq,      "Struct.pack_into.__name__.__eq__",      ["pack_into"],        true, "struct.Struct.pack_into.__name__ is 'pack_into' (writes into mutable buffer at offset)"]
    - [pack_into_qualname_eq,  "Struct.pack_into.__qualname__.__eq__",  ["Struct.pack_into"], true, "struct.Struct.pack_into.__qualname__ is 'Struct.pack_into'"]
    - [unpack_from_name_eq,    "Struct.unpack_from.__name__.__eq__",    ["unpack_from"],      true, "struct.Struct.unpack_from.__name__ is 'unpack_from' (reads from buffer at offset)"]
    - [unpack_from_qualname_eq, "Struct.unpack_from.__qualname__.__eq__", ["Struct.unpack_from"], true, "struct.Struct.unpack_from.__qualname__ is 'Struct.unpack_from'"]
    - [iter_unpack_name_eq,    "Struct.iter_unpack.__name__.__eq__",    ["iter_unpack"],      true, "struct.Struct.iter_unpack.__name__ is 'iter_unpack' (yields successive tuples)"]
    - [iter_unpack_qualname_eq, "Struct.iter_unpack.__qualname__.__eq__", ["Struct.iter_unpack"], true, "struct.Struct.iter_unpack.__qualname__ is 'Struct.iter_unpack'"]

# ---------------------------------------------------------------------------
# struct.Struct method __class__.__name__: method_descriptor for all five
#
# Wave 295 theme: struct.Struct method __class__.__name__ == 'method_descriptor'.
#
# All five struct.Struct methods are method_descriptors. This is the expected
# type for C-extension methods bound to a type via PyMethodDef. method_descriptor
# differs from builtin_function_or_method (the type for module-level C functions
# like struct.pack and struct.unpack). The distinction matters for introspection:
# method_descriptors carry __qualname__ with a class prefix; builtins do not.
# No prior spec anchors __class__.__name__ for all five Struct methods together
# in a grouped table under structmeth295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra246.Struct_method_class_names:
  description: "Struct.pack.__class__.__name__.__eq__('method_descriptor')==True / Struct.unpack.__class__.__name__.__eq__('method_descriptor')==True / Struct.pack_into.__class__.__name__.__eq__('method_descriptor')==True / Struct.unpack_from.__class__.__name__.__eq__('method_descriptor')==True / Struct.iter_unpack.__class__.__name__.__eq__('method_descriptor')==True — all five Struct methods are method_descriptors (C-extension PyMethodDef); contrasts with module-level struct.pack/unpack which are builtin_function_or_method; method_descriptor carries __qualname__ with class prefix; first structmeth295 anchor for Struct method class names"
  kind: python_call_eq
  category: method_identity
  id_prefix: structmeth295

  columns: [id, function, args, expected, description]
  rows:
    - [pack_class_eq,        "Struct.pack.__class__.__name__.__eq__",        ["method_descriptor"], true, "Struct.pack is a method_descriptor (C PyMethodDef, not builtin_function_or_method)"]
    - [unpack_class_eq,      "Struct.unpack.__class__.__name__.__eq__",      ["method_descriptor"], true, "Struct.unpack is a method_descriptor"]
    - [pack_into_class_eq,   "Struct.pack_into.__class__.__name__.__eq__",   ["method_descriptor"], true, "Struct.pack_into is a method_descriptor (writes packed bytes to mutable buffer)"]
    - [unpack_from_class_eq, "Struct.unpack_from.__class__.__name__.__eq__", ["method_descriptor"], true, "Struct.unpack_from is a method_descriptor (reads from buffer at offset)"]
    - [iter_unpack_class_eq, "Struct.iter_unpack.__class__.__name__.__eq__", ["method_descriptor"], true, "Struct.iter_unpack is a method_descriptor (returns iterator over successive chunks)"]

# ---------------------------------------------------------------------------
# struct.Struct attribute descriptor identity: size and format
# (both are getset_descriptors)
#
# Wave 295 theme: struct.Struct.size and struct.Struct.format as
# getset_descriptors.
#
# struct.Struct.size and struct.Struct.format are getset_descriptors — a C-level
# read-only computed property type implemented via PyGetSetDef in Modules/_struct.c.
# getset_descriptor differs from member_descriptor (PyMemberDef slot) and from
# Python property. Both are read-only: .size returns the byte size of the compiled
# format; .format returns the format string. struct_extra244 anchors Struct class
# identity and Struct.size for specific format strings; no prior spec anchors
# Struct.size and Struct.format as getset_descriptors in a grouped table under
# structmeth295. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra246.Struct_attribute_descriptor_identity:
  description: "Struct.size.__class__.__name__.__eq__('getset_descriptor')==True / Struct.format.__class__.__name__.__eq__('getset_descriptor')==True — Struct.size and Struct.format are C-level getset_descriptors (PyGetSetDef); read-only computed properties; getset_descriptor differs from member_descriptor (PyMemberDef) and Python property; .size returns pre-computed byte size; .format returns the format string; extra244 anchors Struct.size for specific formats; first structmeth295 anchor for Struct.size/format descriptor class identity"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: structmeth295

  columns: [id, function, args, expected, description]
  rows:
    - [size_class_eq,    "Struct.size.__class__.__name__.__eq__",    ["getset_descriptor"], true, "struct.Struct.size is a getset_descriptor (C PyGetSetDef; read-only; returns precomputed byte size)"]
    - [format_class_eq,  "Struct.format.__class__.__name__.__eq__",  ["getset_descriptor"], true, "struct.Struct.format is a getset_descriptor (C PyGetSetDef; read-only; returns format string)"]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__eq__('Struct.pack') — standalone
#
# struct.Struct.pack.__qualname__ is 'Struct.pack'. The __qualname__ attribute
# for a method_descriptor on struct.Struct includes the class name as a prefix.
# This is set by the C extension when defining the method via PyMethodDef within
# the Struct type. It distinguishes struct.Struct.pack (a bound method of a
# Struct instance) from the module-level struct.pack (a builtin_function_or_method
# whose __qualname__ is 'pack'). struct_extra244 and struct_extra245 do not
# anchor Struct.pack.__qualname__; no prior spec anchors it as a standalone under
# structmeth295. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra246.Struct_pack_qualname_eq:
  description: "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — Struct.pack.__qualname__ includes the 'Struct.' prefix; set by C extension via PyMethodDef; distinguishes from module-level struct.pack whose __qualname__=='pack'; Struct.pack is a method_descriptor; struct_extra244 anchors Struct class identity but not Struct.pack.__qualname__; first standalone under structmeth295"
  category: method_identity
  kind: python_call_eq
  function: "Struct.pack.__qualname__.__eq__"
  args: ["Struct.pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack') — standalone
#
# struct.Struct.iter_unpack.__qualname__ is 'Struct.iter_unpack'. iter_unpack
# is the most recently added (Python 3.4) of the five Struct methods. It returns
# an iterator that yields a tuple of values from successive fixed-size chunks of
# a buffer. The buffer size must be an exact multiple of the format's size (raises
# struct.error otherwise). Like pack and unpack, its __qualname__ includes the
# 'Struct.' prefix. struct_extra245 anchors the module-level struct.iter_unpack
# __name__; no prior spec anchors struct.Struct.iter_unpack.__qualname__ as a
# standalone under structmeth295. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra246.Struct_iter_unpack_qualname_eq:
  description: "struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack') == True — Struct.iter_unpack returns an iterator over successive fixed-size chunks; added in Python 3.4; buffer size must be exact multiple of format size (else struct.error); __qualname__=='Struct.iter_unpack' (not 'iter_unpack'); extra245 anchors module-level iter_unpack.__name__; first standalone for Struct.iter_unpack.__qualname__ under structmeth295"
  category: method_identity
  kind: python_call_eq
  function: "Struct.iter_unpack.__qualname__.__eq__"
  args: ["Struct.iter_unpack"]
  expected: true
