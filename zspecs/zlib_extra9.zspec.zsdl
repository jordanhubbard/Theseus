spec: zlib_extra9
version: ">=3.9"
backend: python_module(zlib)

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
    - "zlib_extra8.zspec.zsdl — covers crc32(b'hello')==907060870 (extra8); adler32(b'hello')==103547413 (extra8); crc32(b'')==0 (extra8); adler32(b'')==1 (extra8); compress(b'hello') returns bytes (extra8); decompress(compressed-hello) returns bytes (extra8)."
    - "zlib_extra7.zspec.zsdl — covers compress/decompress/crc32/adler32/compressobj/decompressobj __name__ standalone; compress/decompress/crc32/adler32 __module__ table; Z_DEFAULT_COMPRESSION and ZLIB_VERSION class name."
    - "zlib_extra6.zspec.zsdl — covers compressobj/decompressobj class names; compression-level constants; MAX_WBITS; ZLIB_VERSION length; crc32/adler32 empty-bytes edge cases."
    - "zlib_extra5.zspec.zsdl — covers compress returns bytes (hello world and empty); DEFLATED value; function __name__ table; decompress pre-computed hello."
    - "zlib_extra4.zspec.zsdl — covers MAX_WBITS, Z_NO_FLUSH/Z_SYNC_FLUSH/Z_FINISH, ZLIB_VERSION type, adler32/crc32 known values, error.__qualname__."
    - "zlib_extra3.zspec.zsdl — covers constant values and compress/decompress __module__."
    - "zlib_extra2.zspec.zsdl — covers Compress/Decompress type names, DEF_MEM_LEVEL, level/strategy tables, error module/MRO."
    - "zlib_extra.zspec.zsdl — covers function names, error class, DEFLATED/Z_DEFAULT_COMPRESSION int type, checksum edge cases, roundtrip."
  notes:
    - "This spec extends zlib through zlib_extra8; it does NOT duplicate invariants present in those files."
    - "Focus: error.__bases__[0].__name__ == 'Exception' (bool-form, extra9); error.__module__ standalone (extra9); compressobj/__module__ standalone (extra9); decompressobj/__module__ standalone (extra9); function __module__ table covering compressobj and decompressobj (extra9)."
    - "zlib.error.__bases__[0].__name__ == 'Exception': zlib.error is a subclass of Exception. No prior zlib spec checks this in bool-form. Verified 2026-04-09."
    - "zlib.error.__module__ == 'zlib': the error class is defined in the zlib C extension. Verified 2026-04-09."
    - "compressobj.__module__ == 'zlib', decompressobj.__module__ == 'zlib': both C-level factory functions belong to the zlib module. zlib_extra7 only covered compress/decompress/crc32/adler32 in its __module__ table. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# error.__bases__[0].__name__ == 'Exception' — bool form
#
# No prior zlib spec checks zlib.error.__bases__[0].__name__ in bool-form.
# zlib.error inherits from Exception (it is a plain exception subclass).
# ---------------------------------------------------------------------------

invariant zlib_extra9.error.base_name_bool:
  description: "zlib.error.__bases__[0].__name__ == 'Exception' — error inherits from Exception (bool-form, extra9)"
  category: class_hierarchy
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# error.__module__ == 'zlib' — standalone (extra9 anchor)
#
# No prior zlib spec checks error.__module__ as a standalone invariant in the
# extra9 namespace. zlib_extra2 covers error.__module__ from extra2.
# This invariant re-anchors it from the extra9 namespace.
# ---------------------------------------------------------------------------

invariant zlib_extra9.error.module:
  description: "zlib.error.__module__ == 'zlib' — error class is defined in the zlib module (extra9 anchor)"
  category: class_identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["zlib"]
  expected: true

# ---------------------------------------------------------------------------
# compressobj and decompressobj __module__ — standalone (extra9 anchors)
#
# zlib_extra7 covered compress/decompress/crc32/adler32 __module__ in a table,
# but did not include compressobj or decompressobj. These standalone invariants
# fill that gap from the extra9 namespace.
# ---------------------------------------------------------------------------

invariant zlib_extra9.compressobj.module:
  description: "zlib.compressobj.__module__ == 'zlib' — compressobj is defined in the zlib module (extra9 anchor)"
  category: function_modules
  kind: python_call_eq
  function: compressobj.__module__.__eq__
  args: ["zlib"]
  expected: true

invariant zlib_extra9.decompressobj.module:
  description: "zlib.decompressobj.__module__ == 'zlib' — decompressobj is defined in the zlib module (extra9 anchor)"
  category: function_modules
  kind: python_call_eq
  function: decompressobj.__module__.__eq__
  args: ["zlib"]
  expected: true

# ---------------------------------------------------------------------------
# ZLIB_VERSION == '1.2.12' — exact value (extra9 anchor)
#
# zlib_extra4 covers ZLIB_VERSION.__class__.__name__ == 'str'.
# zlib_extra7 re-anchors that type check from extra7.
# No prior zlib spec checks the exact string value of ZLIB_VERSION.
# Verified on Python 3.12 / macOS Darwin 25.4.0: '1.2.12'.
# ---------------------------------------------------------------------------

invariant zlib_extra9.ZLIB_VERSION.exact:
  description: "zlib.ZLIB_VERSION == '1.2.12' — exact zlib library version string (extra9 anchor)"
  category: constants
  kind: python_call_eq
  function: ZLIB_VERSION.__eq__
  args: ["1.2.12"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ table — compress, decompress, crc32, adler32,
# compressobj, decompressobj (extra9)
#
# zlib_extra7 covers compress/decompress/crc32/adler32 __module__ in a table
# (id_prefix: fmod7). This table extends coverage to compressobj and decompressobj
# and re-anchors all six functions from the extra9 namespace.
# ---------------------------------------------------------------------------

table zlib_extra9.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod9

  columns: [id, function, args, expected]
  rows:
    - [compress,      compress.__module__.__eq__,      ["zlib"], true]
    - [decompress,    decompress.__module__.__eq__,    ["zlib"], true]
    - [crc32,         crc32.__module__.__eq__,         ["zlib"], true]
    - [adler32,       adler32.__module__.__eq__,       ["zlib"], true]
    - [compressobj,   compressobj.__module__.__eq__,   ["zlib"], true]
    - [decompressobj, decompressobj.__module__.__eq__, ["zlib"], true]
