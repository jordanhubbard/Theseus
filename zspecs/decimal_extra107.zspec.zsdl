spec: decimal_extra107
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra106.zspec.zsdl."
    - "This spec covers: decimal.Decimal comparison method qualnames __lt__, __gt__, __le__, __ge__, __ne__, __eq__ — string equality."
    - "All comparison methods have type 'wrapper_descriptor' (C slot wrappers, unlike arithmetic methods which are 'method_descriptor')."
    - "decimal.Decimal.__lt__.__qualname__ == 'Decimal.__lt__' (len 14)."
    - "decimal.Decimal.__gt__.__qualname__ == 'Decimal.__gt__' (len 14)."
    - "decimal.Decimal.__le__.__qualname__ == 'Decimal.__le__' (len 14)."
    - "decimal.Decimal.__ge__.__qualname__ == 'Decimal.__ge__' (len 14)."
    - "decimal.Decimal.__ne__.__qualname__ == 'Decimal.__ne__' (len 14)."
    - "decimal.Decimal.__eq__.__qualname__ == 'Decimal.__eq__' (len 14)."
    - "All six comparison methods share the identical qualname length of 14 chars."
    - "Decimal.__lt__.__qualname__.__eq__('Decimal.__lt__') is True."
    - "decimal.Decimal has no __iadd__ or __and__ methods."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.__lt__ and __gt__ qualnames — string equality
# Both are 'wrapper_descriptor' (C slot wrappers, not 'method_descriptor').
# __lt__: 'Decimal.__lt__' (14 chars); string eq True.
# __gt__: 'Decimal.__gt__' (14 chars); string eq True.
# ---------------------------------------------------------------------------

table decimal_extra107.Decimal_lt_gt_qualnames:
  description: "decimal.Decimal __lt__/__gt__ qualname string equality: both 'Decimal.__lt__'/'Decimal.__gt__'(14 chars); type 'wrapper_descriptor' (C slot wrappers)"
  kind: python_call_eq
  category: qualnames
  id_prefix: deccmp107a

  columns: [id, function, args, expected, description]
  rows:
    - [lt_type,        "Decimal.__lt__.__class__.__name__.__eq__",  ["wrapper_descriptor"],  true,  "type(decimal.Decimal.__lt__).__name__ == 'wrapper_descriptor' (C slot wrapper, not method_descriptor)"]
    - [lt_qn_eq,       "Decimal.__lt__.__qualname__.__eq__",        ["Decimal.__lt__"],      true,  "decimal.Decimal.__lt__.__qualname__ == 'Decimal.__lt__' (implements the < comparison operator)"]
    - [lt_qn_len,      "Decimal.__lt__.__qualname__.__len__",       [],                      14,    "decimal.Decimal.__lt__.__qualname__.__len__() == 14 ('Decimal.__lt__' has 14 chars)"]
    - [gt_type,        "Decimal.__gt__.__class__.__name__.__eq__",  ["wrapper_descriptor"],  true,  "type(decimal.Decimal.__gt__).__name__ == 'wrapper_descriptor' (C slot wrapper)"]
    - [gt_qn_eq,       "Decimal.__gt__.__qualname__.__eq__",        ["Decimal.__gt__"],      true,  "decimal.Decimal.__gt__.__qualname__ == 'Decimal.__gt__' (implements the > comparison operator)"]
    - [gt_qn_len,      "Decimal.__gt__.__qualname__.__len__",       [],                      14,    "decimal.Decimal.__gt__.__qualname__.__len__() == 14 ('Decimal.__gt__' has 14 chars; same length as __lt__)"]
    - [lt_ne_gt_str,   "Decimal.__lt__.__qualname__.__eq__",        ["Decimal.__gt__"],      false, "decimal.Decimal.__lt__.__qualname__ != 'Decimal.__gt__' (distinct qualname strings though same length)"]
    - [lt_eq_gt_len,   "Decimal.__lt__.__qualname__.__len__.__eq__", [14],                   true,  "len('Decimal.__lt__') == len('Decimal.__gt__') == 14 (lt and gt share identical qualname length)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.__le__ and __ge__ qualnames — string equality
# Both are 'wrapper_descriptor' (C slot wrappers).
# __le__: 'Decimal.__le__' (14 chars); string eq True.
# __ge__: 'Decimal.__ge__' (14 chars); string eq True.
# ---------------------------------------------------------------------------

table decimal_extra107.Decimal_le_ge_qualnames:
  description: "decimal.Decimal __le__/__ge__ qualname string equality: both 'Decimal.__le__'/'Decimal.__ge__'(14 chars); type 'wrapper_descriptor'"
  kind: python_call_eq
  category: qualnames
  id_prefix: deccmp107b

  columns: [id, function, args, expected, description]
  rows:
    - [le_type,        "Decimal.__le__.__class__.__name__.__eq__",  ["wrapper_descriptor"],  true,  "type(decimal.Decimal.__le__).__name__ == 'wrapper_descriptor' (C slot wrapper for <= operator)"]
    - [le_qn_eq,       "Decimal.__le__.__qualname__.__eq__",        ["Decimal.__le__"],      true,  "decimal.Decimal.__le__.__qualname__ == 'Decimal.__le__' (implements the <= comparison operator)"]
    - [le_qn_len,      "Decimal.__le__.__qualname__.__len__",       [],                      14,    "decimal.Decimal.__le__.__qualname__.__len__() == 14 ('Decimal.__le__' has 14 chars)"]
    - [ge_type,        "Decimal.__ge__.__class__.__name__.__eq__",  ["wrapper_descriptor"],  true,  "type(decimal.Decimal.__ge__).__name__ == 'wrapper_descriptor' (C slot wrapper for >= operator)"]
    - [ge_qn_eq,       "Decimal.__ge__.__qualname__.__eq__",        ["Decimal.__ge__"],      true,  "decimal.Decimal.__ge__.__qualname__ == 'Decimal.__ge__' (implements the >= comparison operator)"]
    - [ge_qn_len,      "Decimal.__ge__.__qualname__.__len__",       [],                      14,    "decimal.Decimal.__ge__.__qualname__.__len__() == 14 ('Decimal.__ge__' has 14 chars; same length as __le__)"]
    - [le_ne_ge_str,   "Decimal.__le__.__qualname__.__eq__",        ["Decimal.__ge__"],      false, "decimal.Decimal.__le__.__qualname__ != 'Decimal.__ge__' (distinct qualname strings though same length)"]
    - [le_eq_ge_len,   "Decimal.__le__.__qualname__.__len__.__eq__", [14],                   true,  "len('Decimal.__le__') == len('Decimal.__ge__') == 14 (le and ge share identical qualname length)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.__ne__ and __eq__ qualnames — string equality
# Both are 'wrapper_descriptor' (C slot wrappers).
# __ne__: 'Decimal.__ne__' (14 chars); string eq True.
# __eq__: 'Decimal.__eq__' (14 chars); string eq True.
# All six comparison methods share the same qualname length of 14 chars.
# ---------------------------------------------------------------------------

table decimal_extra107.Decimal_ne_eq_qualnames:
  description: "decimal.Decimal __ne__/__eq__ qualname string equality: both 'Decimal.__ne__'/'Decimal.__eq__'(14 chars); all six comparison methods share qualname length 14"
  kind: python_call_eq
  category: qualnames
  id_prefix: deccmp107c

  columns: [id, function, args, expected, description]
  rows:
    - [ne_type,        "Decimal.__ne__.__class__.__name__.__eq__",  ["wrapper_descriptor"],  true,  "type(decimal.Decimal.__ne__).__name__ == 'wrapper_descriptor' (C slot wrapper for != operator)"]
    - [ne_qn_eq,       "Decimal.__ne__.__qualname__.__eq__",        ["Decimal.__ne__"],      true,  "decimal.Decimal.__ne__.__qualname__ == 'Decimal.__ne__' (implements the != comparison operator)"]
    - [ne_qn_len,      "Decimal.__ne__.__qualname__.__len__",       [],                      14,    "decimal.Decimal.__ne__.__qualname__.__len__() == 14 ('Decimal.__ne__' has 14 chars)"]
    - [eq_type,        "Decimal.__eq__.__class__.__name__.__eq__",  ["wrapper_descriptor"],  true,  "type(decimal.Decimal.__eq__).__name__ == 'wrapper_descriptor' (C slot wrapper for == operator)"]
    - [eq_qn_eq,       "Decimal.__eq__.__qualname__.__eq__",        ["Decimal.__eq__"],      true,  "decimal.Decimal.__eq__.__qualname__ == 'Decimal.__eq__' (implements the == comparison operator)"]
    - [eq_qn_len,      "Decimal.__eq__.__qualname__.__len__",       [],                      14,    "decimal.Decimal.__eq__.__qualname__.__len__() == 14 ('Decimal.__eq__' has 14 chars)"]
    - [all_six_eq_len, "Decimal.__ne__.__qualname__.__len__.__eq__", [14],                   true,  "all six comparison methods (__lt__/__gt__/__le__/__ge__/__ne__/__eq__) share qualname length 14"]
    - [ne_ne_eq_str,   "Decimal.__ne__.__qualname__.__eq__",        ["Decimal.__eq__"],      false, "decimal.Decimal.__ne__.__qualname__ != 'Decimal.__eq__' (distinct qualname strings though same length)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra107.Decimal.__lt___qualname:
  description: "decimal.Decimal.__lt__.__qualname__ == 'Decimal.__lt__' (length 14; type is 'wrapper_descriptor' — a C slot wrapper — unlike arithmetic methods such as __add__ which are 'method_descriptor'; __lt__ implements the < comparison operator; Decimal.__lt__.__qualname__.__eq__('Decimal.__lt__') returns True)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__lt__.__qualname__.__eq__"
  args: ["Decimal.__lt__"]
  expected: true

invariant decimal_extra107.Decimal.__gt___qualname:
  description: "decimal.Decimal.__gt__.__qualname__ == 'Decimal.__gt__' (length 14; type is 'wrapper_descriptor'; __gt__ implements the > comparison operator; all six comparison methods — __lt__, __gt__, __le__, __ge__, __ne__, __eq__ — share the identical qualname length of 14 chars)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__gt__.__qualname__.__eq__"
  args: ["Decimal.__gt__"]
  expected: true

invariant decimal_extra107.Decimal.__le___qualname:
  description: "decimal.Decimal.__le__.__qualname__ == 'Decimal.__le__' (length 14; type is 'wrapper_descriptor'; __le__ implements the <= comparison operator; 'Decimal.' (8) + '__le__' (6) == 14; the double-underscore wrapper name contributes 4 of those 6 chars)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__le__.__qualname__.__eq__"
  args: ["Decimal.__le__"]
  expected: true

invariant decimal_extra107.Decimal.__ge___qualname:
  description: "decimal.Decimal.__ge__.__qualname__ == 'Decimal.__ge__' (length 14; type is 'wrapper_descriptor'; __ge__ implements the >= comparison operator; length 14 is shared by all six comparison dunders; contrast with arithmetic dunders like __add__ which are 'method_descriptor' not 'wrapper_descriptor')"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__ge__.__qualname__.__eq__"
  args: ["Decimal.__ge__"]
  expected: true

invariant decimal_extra107.Decimal.__ne___qualname:
  description: "decimal.Decimal.__ne__.__qualname__ == 'Decimal.__ne__' (length 14; type is 'wrapper_descriptor'; __ne__ implements the != comparison operator; Decimal has no __iadd__ or __and__ methods; decimal.Decimal.__ne__.__qualname__.__eq__('Decimal.__ne__') returns True)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__ne__.__qualname__.__eq__"
  args: ["Decimal.__ne__"]
  expected: true
