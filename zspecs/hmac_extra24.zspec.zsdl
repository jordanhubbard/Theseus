spec: hmac_extra24
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hmac_extra23.zspec.zsdl — covers new/__qualname__.__len__()==3; digest/__qualname__.__len__()==6; compare_digest/__qualname__.__len__()==14; HMAC.__module__.__eq__."
    - "hmac_extra22.zspec.zsdl — covers HMAC.__mro__.__len__(); HMAC.__qualname__.__len__()==4; HMAC.__name__.__len__()==4; MRO member name/qualname table."
    - "hmac_extra19.zspec.zsdl — covers new/__qualname__.__eq__ and digest/__qualname__.__eq__ as standalone invariants."
    - "hmac_extra14.zspec.zsdl — covers new/digest/compare_digest __qualname__.__eq__ via standalone invariants; HMAC.__qualname__.__eq__."
    - "hmac_extra17.zspec.zsdl — covers new/compare_digest/digest __name__/__module__; HMAC __qualname__/__module__/__bases__."
  notes:
    - "This spec extends hmac through hmac_extra23; it does NOT duplicate invariants present in those files."
    - "Focus: __qualname__.__eq__ for HMAC instance methods — update, digest, hexdigest, copy. No prior spec checks __qualname__ for any HMAC method. hmac_extra14 covers HMAC.__qualname__ (the class itself) but not method qualnames."
    - "hmac.HMAC.update.__qualname__ == 'HMAC.update': bound method qualname includes class prefix. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.digest.__qualname__ == 'HMAC.digest': bound method qualname. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.hexdigest.__qualname__ == 'HMAC.hexdigest': bound method qualname. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.copy.__qualname__ == 'HMAC.copy': bound method qualname. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HMAC instance method __qualname__ table
#
# No prior hmac spec checks __qualname__ for any HMAC method.
# hmac_extra14 covers HMAC.__qualname__ == 'HMAC' (the class itself).
# hmac_extra14/19 cover module-level function qualnames (new, digest,
# compare_digest). The HMAC method qualnames below are entirely new coverage.
# On CPython, unbound method qualnames have the form 'ClassName.method_name'.
# Lengths: HMAC.update=11, HMAC.digest=11, HMAC.hexdigest=14, HMAC.copy=9.
# ---------------------------------------------------------------------------

table hmac_extra24.HMAC_method_qualnames:
  description: "HMAC instance method __qualname__ values — all include 'HMAC.' prefix"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: hmacmq24

  columns: [id, function, args, expected]
  rows:
    - [update,    "HMAC.update.__qualname__.__eq__",    ["HMAC.update"],    true]
    - [digest,    "HMAC.digest.__qualname__.__eq__",    ["HMAC.digest"],    true]
    - [hexdigest, "HMAC.hexdigest.__qualname__.__eq__", ["HMAC.hexdigest"], true]
    - [copy,      "HMAC.copy.__qualname__.__eq__",      ["HMAC.copy"],      true]

# ---------------------------------------------------------------------------
# HMAC method __qualname__.__len__() table
#
# No prior spec checks the length of HMAC method __qualname__ strings.
# Lengths: 'HMAC.update'=11, 'HMAC.digest'=11, 'HMAC.hexdigest'=14,
# 'HMAC.copy'=9.
# ---------------------------------------------------------------------------

table hmac_extra24.HMAC_method_qualname_lengths:
  description: "Length of HMAC instance method __qualname__ strings"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: hmacmqlen24

  columns: [id, function, args, expected]
  rows:
    - [update,    "HMAC.update.__qualname__.__len__",    [], 11]
    - [digest,    "HMAC.digest.__qualname__.__len__",    [], 11]
    - [hexdigest, "HMAC.hexdigest.__qualname__.__len__", [], 14]
    - [copy,      "HMAC.copy.__qualname__.__len__",      [],  9]
