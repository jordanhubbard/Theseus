spec: functools_extra60
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra59.zspec.zsdl."
    - "Prior specs covered __class__.__module__ for: reduce/wraps/lru_cache/partial/cached_property/total_ordering/singledispatch (extra53). partial.__class__.__module__=='_functools' (extra53); all others listed there are 'builtins'. No prior spec records __class__.__module__.__eq__('builtins') for: partialmethod, singledispatchmethod, cmp_to_key, update_wrapper, cache. No prior spec records __class__.__name__.__eq__('tuple') or __class__.__module__.__eq__('builtins') for WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES."
    - "This spec covers: functools.partialmethod.__class__.__module__.__eq__('builtins')==true; functools.singledispatchmethod.__class__.__module__.__eq__('builtins')==true; functools.cmp_to_key.__class__.__module__.__eq__('builtins')==true; functools.update_wrapper.__class__.__module__.__eq__('builtins')==true; functools.cache.__class__.__module__.__eq__('builtins')==true; functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple')==true; functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple')==true; functools.WRAPPER_ASSIGNMENTS.__class__.__module__.__eq__('builtins')==true; functools.WRAPPER_UPDATES.__class__.__module__.__eq__('builtins')==true."
    - "Key findings: partialmethod, singledispatchmethod are pure-Python classes in Lib/functools.py whose metaclass is the built-in 'type'; type.__module__ == 'builtins'. cmp_to_key is a C-extension builtin_function_or_method from Modules/_functoolsmodule.c; its __class__ is builtin_function_or_method whose __module__ == 'builtins'. update_wrapper and cache are pure-Python functions (function objects) whose __class__ is the 'function' type from builtins. WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES are module-level tuple constants; tuple is a built-in type with __name__ == 'tuple' and __module__ == 'builtins'. All nine invariants are new to extra60."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools class __class__.__module__ == 'builtins' — extra60
#
# partialmethod and singledispatchmethod are pure-Python classes defined in
# Lib/functools.py. Their metaclass is the built-in 'type' (a class whose class
# is type). Since 'type' is a C runtime built-in, type.__module__ == 'builtins'.
# Therefore partialmethod.__class__.__module__ == 'builtins' (8 chars).
# Prior extra53 confirmed __class__.__module__ for seven functools objects but
# did not include partialmethod or singledispatchmethod. New to extra60.
#
# cmp_to_key is a C-extension builtin_function_or_method in _functoolsmodule.c.
# Its __class__ is the builtin_function_or_method C type, which lives in the
# builtins C runtime module. Prior extra53 covered reduce and cmp_to_key
# __class__.__name__ but did NOT cover cmp_to_key.__class__.__module__. New.
#
# update_wrapper and cache are pure-Python functions. Their __class__ is the
# 'function' built-in type; function.__module__ == 'builtins'. Prior extra53
# covered wraps/lru_cache/total_ordering/singledispatch but not update_wrapper
# or cache. New to extra60.
# ---------------------------------------------------------------------------

table functools_extra60.class_module_builtins:
  description: "functools objects __class__.__module__ == 'builtins' — partialmethod/singledispatchmethod metaclass is 'type' from builtins; cmp_to_key/update_wrapper/cache __class__ is from builtins; not covered in extra53; new to extra60"
  kind: python_call_eq
  category: class_identity
  id_prefix: functoolsmod60

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_class_module,
       partialmethod.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "functools.partialmethod.__class__.__module__ == 'builtins' — partialmethod is a pure-Python class in Lib/functools.py (added Python 3.4) that creates a partial-like descriptor for defining methods; its metaclass is the built-in 'type'; type.__module__ == 'builtins' (8 chars); prior extra53 covered partialmethod.__class__.__name__=='type' but not __class__.__module__; new to extra60"]
    - [singledispatchmethod_class_module,
       singledispatchmethod.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "functools.singledispatchmethod.__class__.__module__ == 'builtins' — singledispatchmethod is a pure-Python class in Lib/functools.py (added Python 3.8) that enables single-dispatch for class methods; its metaclass is the built-in 'type'; type.__module__ == 'builtins' (8 chars); prior extra53 covered singledispatchmethod.__class__.__name__=='type' but not __class__.__module__; new to extra60"]
    - [cmp_to_key_class_module,
       cmp_to_key.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "functools.cmp_to_key.__class__.__module__ == 'builtins' — cmp_to_key is a C-extension function in Modules/_functoolsmodule.c that converts an old-style comparison function to a key function; its __class__ is builtin_function_or_method; builtin_function_or_method is defined in the C runtime 'builtins' module; type.__module__ == 'builtins' (8 chars); prior extra53 covered cmp_to_key.__class__.__name__=='builtin_function_or_method' but not __class__.__module__; new to extra60"]
    - [update_wrapper_class_module,
       update_wrapper.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "functools.update_wrapper.__class__.__module__ == 'builtins' — update_wrapper is a pure-Python function in Lib/functools.py that updates a wrapper function to look like the wrapped function; its __class__ is the 'function' built-in type; function.__module__ == 'builtins' (8 chars); prior extra53 covered wraps/lru_cache/total_ordering/singledispatch but not update_wrapper; new to extra60"]
    - [cache_class_module,
       cache.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "functools.cache.__class__.__module__ == 'builtins' — cache is a pure-Python function in Lib/functools.py (added Python 3.9) that is a simple unbounded memoize decorator equivalent to lru_cache(maxsize=None); its __class__ is the 'function' built-in type; function.__module__ == 'builtins' (8 chars); prior extra53 covered cache.__class__.__name__=='function' but not __class__.__module__; new to extra60"]

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES __class__.__name__ and __module__
# — extra60
#
# functools.WRAPPER_ASSIGNMENTS and functools.WRAPPER_UPDATES are module-level
# tuple constants in Lib/functools.py. WRAPPER_ASSIGNMENTS lists the function
# attributes copied by update_wrapper (__module__, __name__, __qualname__,
# __annotations__, __doc__). WRAPPER_UPDATES lists the attributes updated
# (__dict__). Since both are Python tuple objects, their __class__ is the
# built-in 'tuple' type. tuple.__name__ == 'tuple' (5 chars) and
# tuple.__module__ == 'builtins' (8 chars). No prior functools spec records
# __class__.__name__.__eq__('tuple') or __class__.__module__.__eq__('builtins')
# for WRAPPER_ASSIGNMENTS or WRAPPER_UPDATES. All four checks are new to extra60.
# ---------------------------------------------------------------------------

table functools_extra60.wrapper_constants_class_attrs:
  description: "WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES __class__.__name__=='tuple' and __class__.__module__=='builtins' — module-level tuple constants; tuple is a built-in type with __name__=='tuple' (5 chars) and __module__=='builtins' (8 chars); not recorded in any prior functools spec; new to extra60"
  kind: python_call_eq
  category: class_identity
  id_prefix: functoolsmod60

  columns: [id, function, args, expected, description]
  rows:
    - [WRAPPER_ASSIGNMENTS_class_name,
       WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a module-level tuple constant in Lib/functools.py listing the function attributes copied by update_wrapper; it is a Python tuple object so __class__ is the built-in tuple type; tuple.__name__ == 'tuple' (5 chars); no prior functools spec records __class__.__name__ for WRAPPER_ASSIGNMENTS; new to extra60"]
    - [WRAPPER_ASSIGNMENTS_class_module,
       WRAPPER_ASSIGNMENTS.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__module__ == 'builtins' — WRAPPER_ASSIGNMENTS is a Python tuple object; the tuple built-in type is defined in the C runtime 'builtins' module; tuple.__module__ == 'builtins' (8 chars); no prior functools spec records __class__.__module__ for WRAPPER_ASSIGNMENTS; new to extra60"]
    - [WRAPPER_UPDATES_class_name,
       WRAPPER_UPDATES.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' — WRAPPER_UPDATES is a module-level tuple constant in Lib/functools.py listing the attributes updated (not replaced) by update_wrapper; it is a Python tuple object so __class__ is the built-in tuple type; tuple.__name__ == 'tuple' (5 chars); no prior functools spec records __class__.__name__ for WRAPPER_UPDATES; new to extra60"]
    - [WRAPPER_UPDATES_class_module,
       WRAPPER_UPDATES.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__module__ == 'builtins' — WRAPPER_UPDATES is a Python tuple object; the tuple built-in type is defined in the C runtime 'builtins' module; tuple.__module__ == 'builtins' (8 chars); no prior functools spec records __class__.__module__ for WRAPPER_UPDATES; new to extra60"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra60
# ---------------------------------------------------------------------------

invariant functools_extra60.partialmethod_metaclass_from_builtins:
  description: "partialmethod metaclass is 'type' from builtins — pure-Python class; metaclass chain: partialmethod.__class__ is type; type.__module__ == 'builtins'"
  kind: python_call_eq
  function: partialmethod.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant functools_extra60.WRAPPER_ASSIGNMENTS_is_tuple:
  description: "WRAPPER_ASSIGNMENTS is a tuple constant — __class__.__name__ == 'tuple' and __class__.__module__ == 'builtins' confirm the built-in tuple type"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra60.cache_function_from_builtins:
  description: "cache is a pure-Python function — __class__.__module__ == 'builtins' confirms the function type lives in the C runtime builtins module"
  kind: python_call_eq
  function: cache.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true
