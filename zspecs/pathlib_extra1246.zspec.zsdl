spec: pathlib_extra1246
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib __doc__ class checks for module, Path, PurePath, PurePosixPath, PureWindowsPath, PosixPath, WindowsPath, and Path methods exists, open, read_text, write_text, mkdir, iterdir"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["All inspected pathlib items have str __doc__; none of these __doc__ class checks were covered in prior pathlib_extra specs (_extra1201, _extra1216, _extra1231)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1246.module_and_path_classes_doc_class:
  description: "pathlib module and its path classes all have str __doc__"
  kind: python_call_eq
  category: doc_class
  id_prefix: pl1246mc
  columns: [id, function, args, expected]
  rows:
    - [pl1246mc001, pathlib.__doc__.__class__.__name__.__eq__,              ["str"],     true]
    - [pl1246mc002, pathlib.__doc__.__class__.__name__.__eq__,              ["NoneType"], false]
    - [pl1246mc003, pathlib.Path.__doc__.__class__.__name__.__eq__,         ["str"],     true]
    - [pl1246mc004, pathlib.Path.__doc__.__class__.__name__.__eq__,         ["NoneType"], false]
    - [pl1246mc005, pathlib.PurePath.__doc__.__class__.__name__.__eq__,     ["str"],     true]
    - [pl1246mc006, pathlib.PurePath.__doc__.__class__.__name__.__eq__,     ["NoneType"], false]
    - [pl1246mc007, pathlib.PurePosixPath.__doc__.__class__.__name__.__eq__, ["str"],    true]
    - [pl1246mc008, pathlib.PurePosixPath.__doc__.__class__.__name__.__eq__, ["NoneType"], false]
    - [pl1246mc009, pathlib.PureWindowsPath.__doc__.__class__.__name__.__eq__, ["str"],  true]
    - [pl1246mc010, pathlib.PureWindowsPath.__doc__.__class__.__name__.__eq__, ["NoneType"], false]

