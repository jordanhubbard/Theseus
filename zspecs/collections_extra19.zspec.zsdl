spec: collections_extra19
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections.zspec.zsdl and prior extras through collections_extra18.zspec.zsdl."
    - "collections_extra18 covers: OrderedDict.__name__/__name__.__len__; defaultdict.__name__/__name__.__len__; empty-instance __len__ for OrderedDict and defaultdict; Counter('aab') __len__/__getitem__; defaultdict default_factory method_chain; Counter.__name__.__len__."
    - "collections_extra15 covers: deque.maxlen for unbounded (None), bounded (5), and zero; ChainMap.maps.__len__ for 2 and 3 maps."
    - "collections_extra3 covers: deque.__name__.__eq__('deque') as a standalone invariant."
    - "collections.zspec.zsdl covers: deque.__name__.__eq__('deque') in its table."
    - "No prior collections spec covers deque().__len__() == 0 (empty deque) as a standalone invariant."
    - "No prior collections spec covers deque([1,2,3]).__len__() == 3 as a standalone invariant."
    - "No prior collections spec covers deque([1,2,3]).__getitem__(0) == 1 or __getitem__(2) == 3 or __getitem__(-1) == 3."
    - "No prior collections spec covers deque.__name__.__len__() == 5 as a standalone invariant."
    - "No prior collections spec covers deque.__module__.__len__() == 11 — len('collections')."
    - "No prior collections spec covers ChainMap.__name__.__len__() == 8 — len('ChainMap')."
    - "No prior collections spec covers ChainMap().__len__() == 0 (empty ChainMap) as a standalone invariant."
    - "No prior collections spec covers ChainMap({'a':1}).__len__() == 1 as a standalone invariant."
    - "deque.__name__.__len__() == 5 — len('deque')."
    - "deque.__module__ == 'collections'; __module__.__len__() == 11 — len('collections')."
    - "ChainMap.__name__ == 'ChainMap'; __name__.__len__() == 8 — len('ChainMap')."
    - "ChainMap().__len__() == 0 — empty ChainMap has no keys."
    - "ChainMap({'a':1}).__len__() == 1 — single key from one map."
    - "deque().__len__() == 0 — empty deque has no elements."
    - "deque([1,2,3]).__len__() == 3 — three-element deque."
    - "deque([1,2,3]).__getitem__(0) == 1; __getitem__(2) == 3; __getitem__(-1) == 3 (last element)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# deque.__name__.__len__() — name length cross-check
#
# collections.zspec.zsdl and collections_extra3 cover deque.__name__.__eq__('deque').
# No prior spec records deque.__name__.__len__() == 5 as a standalone invariant.
# ---------------------------------------------------------------------------

invariant collections_extra19.deque.name_len:
  description: "collections.deque.__name__.__len__() == 5 — len('deque')"
  category: name_lengths
  kind: python_call_eq
  function: deque.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# deque.__module__.__len__() — module name length cross-check
#
# collections_extra17 covers deque.__module__.__eq__('collections').
# No prior spec records deque.__module__.__len__() == 11 as a standalone invariant.
# ---------------------------------------------------------------------------

invariant collections_extra19.deque.module_len:
  description: "collections.deque.__module__.__len__() == 11 — len('collections')"
  category: module_attr_lengths
  kind: python_call_eq
  function: deque.__module__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# Empty deque __len__() — zero elements at construction
#
# No prior collections spec records deque().__len__() == 0 as a standalone
# invariant. An empty deque constructed with no arguments has zero elements.
# ---------------------------------------------------------------------------

invariant collections_extra19.deque.empty_len:
  description: "deque().__len__() == 0 — newly constructed empty deque has no elements"
  category: instance_len
  kind: python_call_eq
  function: deque
  args: []
  method: __len__
  expected: 0

# ---------------------------------------------------------------------------
# deque([1,2,3]).__len__() — three-element deque
#
# No prior collections spec records deque([1,2,3]).__len__() == 3 as a standalone
# invariant. A deque constructed from a three-element list has length 3.
# ---------------------------------------------------------------------------

invariant collections_extra19.deque.three_len:
  description: "deque([1,2,3]).__len__() == 3 — three-element deque"
  category: instance_len
  kind: python_call_eq
  function: deque
  args: [[1, 2, 3]]
  method: __len__
  expected: 3

# ---------------------------------------------------------------------------
# deque([1,2,3]).__getitem__ — index access at positions 0, 2, and -1
#
# No prior collections spec covers __getitem__ on a deque instance.
# deque supports index access; position 0 is the leftmost element, -1 is the
# rightmost. For [1,2,3]: index 0 == 1, index 2 == 3, index -1 == 3.
# ---------------------------------------------------------------------------

invariant collections_extra19.deque.getitem_first:
  description: "deque([1,2,3]).__getitem__(0) == 1 — first element"
  category: instance_getitem
  kind: python_call_eq
  function: deque
  args: [[1, 2, 3]]
  method: __getitem__
  method_args: [0]
  expected: 1

invariant collections_extra19.deque.getitem_last_positive:
  description: "deque([1,2,3]).__getitem__(2) == 3 — last element by positive index"
  category: instance_getitem
  kind: python_call_eq
  function: deque
  args: [[1, 2, 3]]
  method: __getitem__
  method_args: [2]
  expected: 3

invariant collections_extra19.deque.getitem_last_negative:
  description: "deque([1,2,3]).__getitem__(-1) == 3 — last element by negative index"
  category: instance_getitem
  kind: python_call_eq
  function: deque
  args: [[1, 2, 3]]
  method: __getitem__
  method_args: [-1]
  expected: 3

# ---------------------------------------------------------------------------
# ChainMap.__name__.__len__() — name length cross-check
#
# collections_extra16 covers ChainMap.__qualname__.__eq__('ChainMap').
# No prior spec records ChainMap.__name__.__len__() == 8 as a standalone invariant.
# ---------------------------------------------------------------------------

invariant collections_extra19.ChainMap.name_len:
  description: "collections.ChainMap.__name__.__len__() == 8 — len('ChainMap')"
  category: name_lengths
  kind: python_call_eq
  function: ChainMap.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# ChainMap.__module__.__len__() — module name length cross-check
#
# collections_extra17 covers ChainMap.__module__.__eq__('collections').
# No prior spec records ChainMap.__module__.__len__() == 11 as a standalone invariant.
# ---------------------------------------------------------------------------

invariant collections_extra19.ChainMap.module_len:
  description: "collections.ChainMap.__module__.__len__() == 11 — len('collections')"
  category: module_attr_lengths
  kind: python_call_eq
  function: ChainMap.__module__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# Empty ChainMap __len__() — zero keys at construction
#
# No prior collections spec records ChainMap().__len__() == 0 as a standalone
# invariant. An empty ChainMap has no keys visible across its maps.
# ---------------------------------------------------------------------------

invariant collections_extra19.ChainMap.empty_len:
  description: "ChainMap().__len__() == 0 — empty ChainMap has no keys"
  category: instance_len
  kind: python_call_eq
  function: ChainMap
  args: []
  method: __len__
  expected: 0

# ---------------------------------------------------------------------------
# ChainMap({'a':1}).__len__() — single-key single-map ChainMap
#
# No prior collections spec records ChainMap({'a':1}).__len__() == 1.
# A ChainMap wrapping a single one-key dict exposes exactly one unique key.
# ---------------------------------------------------------------------------

invariant collections_extra19.ChainMap.single_key_len:
  description: "ChainMap({'a': 1}).__len__() == 1 — one key from one map"
  category: instance_len
  kind: python_call_eq
  function: ChainMap
  args: [{"a": 1}]
  method: __len__
  expected: 1
