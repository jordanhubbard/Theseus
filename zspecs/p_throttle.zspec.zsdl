spec: p_throttle
version: ">=8.0.0"
backend: node(p-throttle)
esm: true

docs: https://github.com/sindresorhus/p-throttle#readme

provenance:
  derived_from:
    - "p-throttle README — https://github.com/sindresorhus/p-throttle#readme"
    - "Test vectors verified with p-throttle via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "p-throttle source"
  notes:
    - "Rate-limit promise-returning calls via a configurable {limit, interval} window."
    - "Install: npm install p-throttle"
    - "v8 ESM only; default export pThrottle({limit, interval}) → wrapper(fn) → throttled(fn)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Wrapper function does not throw on registration; calls reject when the throttle is aborted."
  stderr: "null"
  stickiness: "Each pThrottle factory call yields a wrapper that owns one rate-limit window."
  codes: {}

invariant p_throttle.default_export_is_function:
  description: "Default export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "Function"

invariant p_throttle.default_name:
  description: "Default function name is 'pThrottle'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.name"}
  expected: "pThrottle"

invariant p_throttle.factory_returns_wrapper:
  description: "pThrottle({limit, interval}) returns a wrapper function"
  category: factory
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: [{"limit": 2, "interval": 1000}]}
    - {get: "constructor.name"}
  expected: "Function"

invariant p_throttle.wrapper_arity:
  description: "Wrapper takes 1 arg (the function to throttle)"
  category: factory
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: [{"limit": 2, "interval": 1000}]}
    - {get: length}
  expected: 1

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:23:00Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
