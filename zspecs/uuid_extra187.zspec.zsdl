spec: uuid_extra187
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__' (len=11); uuid.UUID.__le__.__qualname__ == 'UUID.__le__' (len=11) — rich comparison methods defined directly on UUID."
    - "uuid.UUID.__gt__.__qualname__ == 'UUID.__gt__' (len=11); uuid.UUID.__ge__.__qualname__ == 'UUID.__ge__' (len=11) — rich comparison methods defined directly on UUID."
    - "uuid.UUID.__ne__.__qualname__ == 'object.__ne__' (len=13) — __ne__ is inherited from object, not overridden in UUID."
    - "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__' (len=11) — UUID defines its own __eq__ for value comparison."
    - "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__' (len=13) — UUID defines its own __hash__; len=13 matches __ne__ (inherited from object)."
    - "The longer qualnames (len=13) are __ne__ ('object.__ne__') and __hash__ ('UUID.__hash__'); the shorter ones (len=11) are __lt__, __le__, __gt__, __ge__, __eq__ ('UUID.*')."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID ordering methods — __lt__, __le__, __gt__, __ge__
# All four are defined on UUID itself, qualname pattern: 'UUID.__XX__' len=11
# ---------------------------------------------------------------------------

table uuidcompare187.ordering_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: uuidcompare187

  columns: [id, function, args, expected, description]
  rows:
    - [lt_qualname, UUID.__lt__.__qualname__.__eq__, ["UUID.__lt__"], true, "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__' (defined on UUID)"]
    - [le_qualname, UUID.__le__.__qualname__.__eq__, ["UUID.__le__"], true, "uuid.UUID.__le__.__qualname__ == 'UUID.__le__' (defined on UUID)"]
    - [gt_qualname, UUID.__gt__.__qualname__.__eq__, ["UUID.__gt__"], true, "uuid.UUID.__gt__.__qualname__ == 'UUID.__gt__' (defined on UUID)"]
    - [ge_qualname, UUID.__ge__.__qualname__.__eq__, ["UUID.__ge__"], true, "uuid.UUID.__ge__.__qualname__ == 'UUID.__ge__' (defined on UUID)"]

# ---------------------------------------------------------------------------
# UUID equality and hash methods — __ne__, __eq__, __hash__
# __ne__ is inherited from object; __eq__ and __hash__ are defined on UUID.
# ---------------------------------------------------------------------------

table uuidcompare187.eq_hash_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: uuidcompare187

  columns: [id, function, args, expected, description]
  rows:
    - [ne_qualname,   UUID.__ne__.__qualname__.__eq__,   ["object.__ne__"],  true, "uuid.UUID.__ne__.__qualname__ == 'object.__ne__' (__ne__ is inherited from object, not overridden)"]
    - [eq_qualname,   UUID.__eq__.__qualname__.__eq__,   ["UUID.__eq__"],    true, "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__' (UUID defines its own value-based __eq__)"]
    - [hash_qualname, UUID.__hash__.__qualname__.__eq__, ["UUID.__hash__"],  true, "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__' (UUID defines its own __hash__)"]

# ---------------------------------------------------------------------------
# UUID qualname length comparisons
# __lt__, __le__, __gt__, __ge__, __eq__ qualnames have len=11
# __ne__ ('object.__ne__') and __hash__ ('UUID.__hash__') have len=13
# ---------------------------------------------------------------------------

table uuidcompare187.qualname_lengths:
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: uuidcompare187

  columns: [id, function, args, expected, description]
  rows:
    - [lt_qualname_len,   UUID.__lt__.__qualname__.__len__,   [], 11, "len(uuid.UUID.__lt__.__qualname__) == 11 ('UUID.__lt__' has 11 characters)"]
    - [ne_qualname_len,   UUID.__ne__.__qualname__.__len__,   [], 13, "len(uuid.UUID.__ne__.__qualname__) == 13 ('object.__ne__' has 13 characters — inherited from object)"]
    - [hash_qualname_len, UUID.__hash__.__qualname__.__len__, [], 13, "len(uuid.UUID.__hash__.__qualname__) == 13 ('UUID.__hash__' has 13 characters)"]

# ---------------------------------------------------------------------------
