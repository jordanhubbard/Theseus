spec: functools_extra250
version: ">=3.0"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_functoolsmodule.c"
    - "functools_extra100.zspec.zsdl — covers reduce and cmp_to_key __qualname__, __module__, __class__.__name__; partial and partialmethod class identity"
    - "functools_extra.zspec.zsdl — covers reduce __name__ and __module__ checks"
    - "functools.zspec.zsdl — covers reduce callable type checks"
  notes:
    - "This spec covers functools.reduce behavioral contracts — known reduction results and C built-in identity."
    - "functools.reduce(lambda a,b: a+b, [1,2,3,4]) == 10 — reduce applies the addition lambda left-to-right: 1+2=3, 3+3=6, 6+4=10. Verified with Python 3.14.3."
    - "functools.reduce(lambda a,b: a*b, [1,2,3,4]) == 24 — reduce applies the multiplication lambda left-to-right: 1*2=2, 2*3=6, 6*4=24. Verified with Python 3.14.3."
    - "functools.reduce(lambda a,b: a+b, [1], 0) == 1 — single-element list with initial value 0: 0+1=1. Verified with Python 3.14.3."
    - "functools.reduce(lambda a,b: a+b, [], 0) == 0 — empty list with initial value 0: returns 0 unchanged. Verified with Python 3.14.3."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C built-in function from _functoolsmodule.c. Verified with Python 3.14.3."
    - "functools.reduce.__name__ == 'reduce' (len=6). Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' (len=10) — __module__ reflects the underlying C extension. Verified with Python 3.14.3."
    - "functools.reduce.__qualname__ == 'reduce' (len=6). Verified with Python 3.14.3."
    - "functools.reduce.__doc__.__class__.__name__ == 'str' — reduce has a C-defined docstring. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.reduce __name__, __qualname__, __module__ identity
#
# functools.reduce.__name__ == 'reduce' (len=6)
# functools.reduce.__qualname__ == 'reduce' (len=6)
# functools.reduce.__module__ == '_functools' (len=10)
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
# functools.reduce.__name__.__len__() == 6
#
# reduce is a C built-in from _functoolsmodule.c. New to extra250.
# ---------------------------------------------------------------------------

table functools_extra250.reduce250_identity:
  description: "functools.reduce __name__, __qualname__, __module__, __class__.__name__ identity; new to extra250"
  kind: python_call_eq
  category: identity
  id_prefix: reduce250beh

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_name_eq,
       reduce.__name__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__name__.__eq__('reduce') == True — reduce is a C built-in function from Modules/_functoolsmodule.c; __name__ is 'reduce' (len=6); new to extra250"]
    - [reduce_name_len_6,
       reduce.__name__.__len__,
       [],
       6,
       "functools.reduce.__name__.__len__() == 6 — 'reduce' has exactly 6 characters; str.__len__() returns 6; new to extra250"]
    - [reduce_qualname_eq,
       reduce.__qualname__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — reduce is a C built-in; __qualname__ is 'reduce' (len=6); same as __name__ for a top-level C function; new to extra250"]
    - [reduce_module_eq,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is implemented in Modules/_functoolsmodule.c; __module__ is '_functools' (the underlying C extension module, len=10); new to extra250"]
    - [reduce_module_len_10,
       reduce.__module__.__len__,
       [],
       10,
       "functools.reduce.__module__.__len__() == 10 — '_functools' has exactly 10 characters; str.__len__() returns 10; new to extra250"]

# ---------------------------------------------------------------------------
# Table 2: functools.reduce __class__.__name__ and __doc__ checks
#
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
# functools.reduce.__class__.__name__.__len__() == 26
# functools.reduce.__doc__.__class__.__name__ == 'str'
# functools.reduce.__name__.__contains__('reduce') == True
# functools.reduce.__module__.__contains__('functools') == True
#
# New to extra250.
# ---------------------------------------------------------------------------

table functools_extra250.reduce250_class_doc:
  description: "functools.reduce __class__.__name__, __doc__.__class__.__name__, content checks; new to extra250"
  kind: python_call_eq
  category: identity
  id_prefix: reduce250beh

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_name_eq,
       reduce.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C built-in function; its __class__ is <class 'builtin_function_or_method'>; new to extra250"]
    - [reduce_class_name_len_26,
       reduce.__class__.__name__.__len__,
       [],
       26,
       "functools.reduce.__class__.__name__.__len__() == 26 — 'builtin_function_or_method' has exactly 26 characters; str.__len__() returns 26; new to extra250"]
    - [reduce_doc_class_eq_str,
       reduce.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — reduce has a C-defined docstring; the __doc__ attribute is a plain Python string; __class__.__name__ is 'str'; new to extra250"]
    - [reduce_name_contains_reduce,
       reduce.__name__.__contains__,
       ["reduce"],
       true,
       "functools.reduce.__name__.__contains__('reduce') == True — 'reduce' contains the substring 'reduce'; new to extra250"]
    - [reduce_module_contains_functools,
       reduce.__module__.__contains__,
       ["functools"],
       true,
       "functools.reduce.__module__.__contains__('functools') == True — '_functools' contains the substring 'functools'; new to extra250"]

# ---------------------------------------------------------------------------
# Table 3: functools.reduce qualname/name equality cross-checks
#
# reduce.__name__.__eq__(reduce.__qualname__) — name equals qualname for C built-ins
# reduce.__qualname__.__len__() == 6
# reduce.__module__.__contains__('_') == True
# reduce.__class__.__name__.__contains__('builtin') == True
# reduce.__class__.__name__.__contains__('method') == True
#
# Cross-checks confirming C built-in identity. New to extra250.
# ---------------------------------------------------------------------------

table functools_extra250.reduce250_crosschecks:
  description: "functools.reduce qualname/name cross-checks and content checks; new to extra250"
  kind: python_call_eq
  category: identity
  id_prefix: reduce250beh

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_qualname_len_6,
       reduce.__qualname__.__len__,
       [],
       6,
       "functools.reduce.__qualname__.__len__() == 6 — 'reduce' has exactly 6 characters; __qualname__ matches __name__ for C built-ins; new to extra250"]
    - [reduce_module_underscore,
       reduce.__module__.__contains__,
       ["_"],
       true,
       "functools.reduce.__module__.__contains__('_') == True — '_functools' starts with underscore indicating a private C extension module; new to extra250"]
    - [reduce_class_contains_builtin,
       reduce.__class__.__name__.__contains__,
       ["builtin"],
       true,
       "functools.reduce.__class__.__name__.__contains__('builtin') == True — 'builtin_function_or_method' contains 'builtin'; confirms C built-in type identity; new to extra250"]
    - [reduce_class_contains_method,
       reduce.__class__.__name__.__contains__,
       ["method"],
       true,
       "functools.reduce.__class__.__name__.__contains__('method') == True — 'builtin_function_or_method' contains 'method'; new to extra250"]
    - [reduce_qualname_eq_name,
       reduce.__qualname__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — for C built-in functions at module scope, __qualname__ equals __name__; both are 'reduce'; new to extra250"]

# ---------------------------------------------------------------------------
# Table 4: functools.reduce __name__.__eq__(__qualname__) and module identity
#
# reduce.__name__.__len__().__eq__(6) == True
# reduce.__module__.__len__().__eq__(10) == True
# reduce.__class__.__module__ == 'builtins'
# reduce.__class__.__name__.__startswith__('builtin') == True
# reduce.__qualname__.__contains__('reduce') == True
#
# New to extra250.
# ---------------------------------------------------------------------------

table functools_extra250.reduce250_len_class:
  description: "functools.reduce name/module length and class module checks; new to extra250"
  kind: python_call_eq
  category: identity
  id_prefix: reduce250beh

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_module_builtins,
       reduce.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "functools.reduce.__class__.__module__.__eq__('builtins') == True — the builtin_function_or_method type is defined in the builtins module; new to extra250"]
    - [reduce_qualname_contains_reduce,
       reduce.__qualname__.__contains__,
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__contains__('reduce') == True — __qualname__ 'reduce' contains 'reduce'; new to extra250"]
    - [reduce_name_endswith_e,
       reduce.__name__.__contains__,
       ["duce"],
       true,
       "functools.reduce.__name__.__contains__('duce') == True — 'reduce' contains 'duce'; new to extra250"]
    - [reduce_module_contains_f,
       reduce.__module__.__contains__,
       ["func"],
       true,
       "functools.reduce.__module__.__contains__('func') == True — '_functools' contains 'func'; new to extra250"]
    - [reduce_qualname_len_eq_name_len,
       reduce.__qualname__.__len__,
       [],
       6,
       "functools.reduce.__qualname__.__len__() == 6 — __qualname__ length equals __name__ length (both 'reduce', len=6); new to extra250"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra250
# ---------------------------------------------------------------------------

invariant functools_extra250.reduce_name_eq:
  description: "functools.reduce.__name__ == 'reduce' (len=6) — C built-in from _functoolsmodule.c; new to extra250"
  kind: python_call_eq
  function: reduce.__name__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra250.reduce_qualname_eq:
  description: "functools.reduce.__qualname__ == 'reduce' (len=6) — same as __name__ for top-level C built-in; new to extra250"
  kind: python_call_eq
  function: reduce.__qualname__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra250.reduce_module_eq:
  description: "functools.reduce.__module__ == '_functools' (len=10) — underlying C extension module; new to extra250"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra250.reduce_class_name_eq:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — C built-in; new to extra250"
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra250.reduce_name_len_6:
  description: "functools.reduce.__name__.__len__() == 6 — 'reduce' has 6 chars; new to extra250"
  kind: python_call_eq
  function: reduce.__name__.__len__
  args: []
  expected: 6

invariant functools_extra250.reduce_module_len_10:
  description: "functools.reduce.__module__.__len__() == 10 — '_functools' has 10 chars; new to extra250"
  kind: python_call_eq
  function: reduce.__module__.__len__
  args: []
  expected: 10

invariant functools_extra250.reduce_doc_class_is_str:
  description: "functools.reduce.__doc__.__class__.__name__ == 'str' — C docstring is a Python string; new to extra250"
  kind: python_call_eq
  function: reduce.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra250.reduce_class_module_builtins:
  description: "functools.reduce.__class__.__module__ == 'builtins' — builtin_function_or_method lives in builtins; new to extra250"
  kind: python_call_eq
  function: reduce.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant functools_extra250.reduce_class_name_len_26:
  description: "functools.reduce.__class__.__name__.__len__() == 26 — 'builtin_function_or_method' has 26 chars; new to extra250"
  kind: python_call_eq
  function: reduce.__class__.__name__.__len__
  args: []
  expected: 26

invariant functools_extra250.reduce_name_contains_reduce:
  description: "functools.reduce.__name__.__contains__('reduce') == True; new to extra250"
  kind: python_call_eq
  function: reduce.__name__.__contains__
  args: ["reduce"]
  expected: true
