version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [asyncio source, Python docs, https://docs.python.org/3/library/asyncio-sync.html, https://docs.python.org/3/library/asyncio-task.html]
  not_derived_from: [asyncio_extra2836.zspec.zsdl — covers __rtruediv__/__rfloordiv__/__rmod__ dict-presence, asyncio_extra2821.zspec.zsdl — covers __radd__/__rsub__/__rmul__ dict-presence, asyncio_extra2806.zspec.zsdl — covers __ilshift__/__irshift__/__ipow__ dict-presence]
  notes: [Wave 637 theme — __rlshift__/__rrshift__/__rpow__ dict-presence checks for asyncio types. Reflected left-shift, right-shift, and power operators. Queue/Task/Future/Lock/Event/Semaphore/Condition/Handle/TimerHandle/Timeout/TaskGroup/StreamReader/StreamWriter are async coordination primitives not numeric types — none define these dunders. All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

