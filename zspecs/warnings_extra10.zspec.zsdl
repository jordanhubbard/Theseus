spec: warnings_extra10
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Python/_warnings.c"
  notes:
    - "This spec extends warnings.zspec.zsdl through warnings_extra9.zspec.zsdl."
    - "warnings_extra9 covers: DeprecationWarning MRO[1..4].__name__; DeprecationWarning.__bases__[0].__name__=='Warning'; UserWarning.__bases__[0].__name__=='Warning'; FutureWarning/PendingDeprecationWarning/RuntimeWarning/SyntaxWarning MRO[1].__name__=='Warning'; filters.__class__.__name__=='list'."
    - "warnings_extra8 covers: WarningMessage/catch_warnings __module__; SyntaxWarning/ResourceWarning/UnicodeWarning/BytesWarning __name__/__qualname__; DeprecationWarning/UserWarning/RuntimeWarning/SyntaxWarning/ResourceWarning __module__=='builtins'."
    - "warnings_extra6 covers: filterwarnings/simplefilter/resetwarnings/showwarning/formatwarning __module__; DeprecationWarning/UserWarning/RuntimeWarning/FutureWarning/PendingDeprecationWarning __qualname__."
    - "NOT yet covered: FutureWarning.__bases__[0].__name__ == 'Warning' — direct parent is Warning."
    - "NOT yet covered: RuntimeWarning.__bases__[0].__name__ == 'Warning' — direct parent is Warning."
    - "NOT yet covered: SyntaxWarning.__bases__[0].__name__ == 'Warning' — direct parent is Warning."
    - "NOT yet covered: PendingDeprecationWarning.__bases__[0].__name__ == 'Warning' — direct parent is Warning."
    - "NOT yet covered: FutureWarning.__module__ == 'builtins' as a standalone invariant."
    - "NOT yet covered: PendingDeprecationWarning.__module__ == 'builtins' as a standalone invariant."
    - "NOT yet covered: UnicodeWarning.__module__ == 'builtins' as a standalone invariant."
    - "NOT yet covered: BytesWarning.__module__ == 'builtins' as a standalone invariant."
    - "NOT yet covered: warn_explicit.__module__ == '_warnings' as a standalone invariant."
    - "FutureWarning, RuntimeWarning, SyntaxWarning, PendingDeprecationWarning all inherit directly from Warning (same hierarchy as DeprecationWarning and UserWarning)."
    - "warn_explicit, like warn, is implemented in the C extension _warnings and has __module__ == '_warnings'."
    - "All standard built-in warning categories are defined in 'builtins'; FutureWarning/PendingDeprecationWarning/UnicodeWarning/BytesWarning confirm this."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Direct parent class (__bases__[0].__name__) — remaining warning categories
#
# warnings_extra9 covers DeprecationWarning and UserWarning __bases__[0].__name__.
# FutureWarning, RuntimeWarning, SyntaxWarning, and PendingDeprecationWarning
# also inherit directly from Warning. No prior spec records their
# __bases__[0].__name__ as standalone invariants.
# ---------------------------------------------------------------------------

invariant warnings_extra10.FutureWarning.base_is_Warning:
  description: "FutureWarning.__bases__[0].__name__ == 'Warning' — direct parent is Warning"
  category: category_bases
  kind: python_call_eq
  function: FutureWarning.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Warning"

invariant warnings_extra10.RuntimeWarning.base_is_Warning:
  description: "RuntimeWarning.__bases__[0].__name__ == 'Warning' — direct parent is Warning"
  category: category_bases
  kind: python_call_eq
  function: RuntimeWarning.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Warning"

invariant warnings_extra10.SyntaxWarning.base_is_Warning:
  description: "SyntaxWarning.__bases__[0].__name__ == 'Warning' — direct parent is Warning"
  category: category_bases
  kind: python_call_eq
  function: SyntaxWarning.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Warning"

invariant warnings_extra10.PendingDeprecationWarning.base_is_Warning:
  description: "PendingDeprecationWarning.__bases__[0].__name__ == 'Warning' — direct parent is Warning"
  category: category_bases
  kind: python_call_eq
  function: PendingDeprecationWarning.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Warning"

# ---------------------------------------------------------------------------
# __module__ for remaining built-in warning categories
#
# warnings_extra8 records __module__ == 'builtins' for DeprecationWarning,
# UserWarning, RuntimeWarning, SyntaxWarning, and ResourceWarning. No prior
# spec records __module__ for FutureWarning, PendingDeprecationWarning,
# UnicodeWarning, or BytesWarning as standalone invariants.
# ---------------------------------------------------------------------------

table warnings_extra10.remaining_category_modules:
  description: "Remaining built-in warning categories have __module__ == 'builtins'"
  kind: python_call_eq
  category: warning_category_modules
  id_prefix: catmod

  columns: [id, function, args, expected]
  rows:
    - [FutureWarning,             FutureWarning.__module__.__eq__,             ["builtins"], true]
    - [PendingDeprecationWarning, PendingDeprecationWarning.__module__.__eq__,  ["builtins"], true]
    - [UnicodeWarning,            UnicodeWarning.__module__.__eq__,            ["builtins"], true]
    - [BytesWarning,              BytesWarning.__module__.__eq__,              ["builtins"], true]

# ---------------------------------------------------------------------------
# warn_explicit.__module__ — C extension implementation
#
# warnings_extra records warn.__module__ == '_warnings'. No prior spec records
# warn_explicit.__module__ as a standalone invariant. warn_explicit is also
# implemented in the C extension _warnings and thus has __module__ == '_warnings'.
# ---------------------------------------------------------------------------

invariant warnings_extra10.warn_explicit.module:
  description: "warnings.warn_explicit.__module__ == '_warnings' — implemented in C extension"
  category: function_modules
  kind: python_call_eq
  function: warn_explicit.__module__.__eq__
  args: ["_warnings"]
  expected: true

# ---------------------------------------------------------------------------
# MRO[2] entries for standard warning categories
#
# warnings_extra9 records MRO[1] for FutureWarning, PendingDeprecationWarning,
# RuntimeWarning, and SyntaxWarning (confirming direct parent is Warning).
# MRO[2] is Exception for all standard warning categories. No prior spec
# records MRO[2] for these classes as standalone invariants.
# ---------------------------------------------------------------------------

invariant warnings_extra10.FutureWarning.mro_2:
  description: "FutureWarning.__mro__[2].__name__ == 'Exception'"
  category: category_mro
  kind: python_call_eq
  function: FutureWarning.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Exception"

invariant warnings_extra10.RuntimeWarning.mro_2:
  description: "RuntimeWarning.__mro__[2].__name__ == 'Exception'"
  category: category_mro
  kind: python_call_eq
  function: RuntimeWarning.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Exception"

invariant warnings_extra10.PendingDeprecationWarning.mro_2:
  description: "PendingDeprecationWarning.__mro__[2].__name__ == 'Exception'"
  category: category_mro
  kind: python_call_eq
  function: PendingDeprecationWarning.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Exception"
