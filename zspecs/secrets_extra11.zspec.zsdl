spec: secrets_extra11
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
    - "secrets_extra10.zspec.zsdl — covers token_bytes/hex/urlsafe/choice/randbelow __name__ (standalone); token_bytes(16) class/len; token_hex(8) class/len."
    - "secrets_extra9.zspec.zsdl — covers function __name__ table; __module__ table; token_bytes/hex/urlsafe return type class checks."
    - "secrets_extra8.zspec.zsdl — covers secrets.__name__; randbits __name__/__module__; choice.__module__; token_bytes n=25/50; token_hex n=25/50."
    - "secrets_extra4.zspec.zsdl — covers __qualname__ table; DEFAULT_ENTROPY == 32; token_urlsafe len 24/32; token_bytes/hex len axes."
    - "secrets_extra3.zspec.zsdl — covers function __module__ invariants; DEFAULT_ENTROPY class and >=16."
    - "secrets_extra2.zspec.zsdl — covers function __name__ table; SystemRandom __name__/__module__/__bases__; token_bytes len32."
    - "secrets_extra.zspec.zsdl — covers function __name__/__module__; return type class checks."
  notes:
    - "This spec extends the secrets chain through secrets_extra10; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: __module__.__len__() checks for token_bytes/token_hex/token_urlsafe/choice/randbelow; __class__.__name__.__len__() checks; token_urlsafe(16) and token_urlsafe(32) output length checks."
    - "secrets.token_bytes.__module__.__len__() == 7: len('secrets') == 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.choice.__module__.__len__() == 6: choice is sourced from 'random' (len 6), not 'secrets'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_bytes.__class__.__name__.__len__() == 8: len('function') == 8. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.choice.__class__.__name__.__len__() == 6: choice is a bound method; len('method') == 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_urlsafe(16).__len__() == 22: 16 bytes base64url-encoded yields 24 chars; padding stripped gives 22 chars. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_urlsafe(32).__len__() == 43: 32 bytes base64url-encoded yields 44 chars; one '=' padding char stripped gives 43 chars. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() checks — novel execution path
#
# secrets_extra3 and secrets_extra9 cover __module__ as __eq__ checks.
# No prior spec checks the length of the __module__ strings.
# token_bytes/token_hex/token_urlsafe/randbelow are in 'secrets' (len 7).
# choice is sourced from 'random' (len 6) because it is a bound method
# of SystemRandom, which is defined in the random module.
# ---------------------------------------------------------------------------

table secrets_extra11.function_module_lengths:
  description: "Length of __module__ string for each secrets callable"
  kind: python_call_eq
  category: module_metadata
  id_prefix: smodlen11

  columns: [id, function, args, expected]
  rows:
    - [token_bytes,    token_bytes.__module__.__len__,    [], 7]
    - [token_hex,      token_hex.__module__.__len__,      [], 7]
    - [token_urlsafe,  token_urlsafe.__module__.__len__,  [], 7]
    - [choice,         choice.__module__.__len__,         [], 6]
    - [randbelow,      randbelow.__module__.__len__,      [], 7]

# ---------------------------------------------------------------------------
# __class__.__name__.__len__() checks
#
# No prior spec checks the length of __class__.__name__ strings for
# secrets callables. token_bytes/token_hex/token_urlsafe/randbelow are
# plain functions (len('function') == 8). choice is a bound method
# (len('method') == 6).
# ---------------------------------------------------------------------------

invariant secrets_extra11.token_bytes.class_name_len:
  description: "secrets.token_bytes.__class__.__name__.__len__() == 8 — len('function') == 8"
  category: class_metadata
  kind: python_call_eq
  function: token_bytes.__class__.__name__.__len__
  args: []
  expected: 8

invariant secrets_extra11.choice.class_name_len:
  description: "secrets.choice.__class__.__name__.__len__() == 6 — choice is a bound method; len('method') == 6"
  category: class_metadata
  kind: python_call_eq
  function: choice.__class__.__name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# token_urlsafe(16) and token_urlsafe(32) output length
#
# secrets_extra4 covers token_urlsafe len for n=24 and n=32 return strings.
# secrets_extra6/7 cover token_urlsafe(6), token_urlsafe(8), token_urlsafe(12),
# token_urlsafe(15), token_urlsafe(20).
# No prior spec covers token_urlsafe(16).__len__() == 22 or
# token_urlsafe(32).__len__() == 43.
# token_urlsafe(n) encodes n random bytes as base64url and strips '=' padding.
# 16 bytes -> ceil(16*4/3) = 24 base64 chars; two '=' stripped -> 22 chars.
# 32 bytes -> ceil(32*4/3) = 44 base64 chars; one '=' stripped -> 43 chars.
# ---------------------------------------------------------------------------

invariant secrets_extra11.token_urlsafe.n16.len:
  description: "secrets.token_urlsafe(16).__len__() == 22 — 16 bytes base64url-encoded is 22 chars"
  category: output_lengths
  kind: python_call_eq
  function: token_urlsafe
  args: [16]
  method: __len__
  method_args: []
  expected: 22

invariant secrets_extra11.token_urlsafe.n32.len:
  description: "secrets.token_urlsafe(32).__len__() == 43 — 32 bytes base64url-encoded is 43 chars"
  category: output_lengths
  kind: python_call_eq
  function: token_urlsafe
  args: [32]
  method: __len__
  method_args: []
  expected: 43
