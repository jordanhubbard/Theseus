spec: re_extra1696
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_sre.c, Lib/re/*.py"
    - "re.zspec.zsdl — covers core re module attributes and compile/match interface"
  notes:
    - "Wave 560 (_extra1696): pickling protocol — which stdlib types define __reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__ in their own __dict__."
    - "re.Pattern defines __copy__ and __deepcopy__ in its __dict__ — but NOT __reduce__, __getstate__, __setstate__, __getnewargs__, or __getnewargs_ex__."
    - "re.Match defines __copy__ and __deepcopy__ in its __dict__ — same pattern as re.Pattern."
    - "Neither re.Pattern nor re.Match defines any of the five standard pickling protocol methods in its own __dict__."
    - "re.error is an alias for re.PatternError in Python 3.13+; neither defines any pickling or copy protocol methods."
    - "re.RegexFlag (IntFlag enum) defines none of the pickling or copy protocol methods in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: pickling_protocol
#
# Records whether each re type defines the five pickling dunder methods
# directly in its own __dict__.
#
# re.Pattern: all five → False (uses copy but not pickle protocol).
# re.Match: all five → False (same).
# re.PatternError: all five → False (inherits from Exception).
# re.RegexFlag: all five → False.
# ---------------------------------------------------------------------------

table re_extra1696.pickling_protocol:
  description: "re types pickling protocol dict-presence checks"
  kind: python_call_eq
  category: pickling_protocol
  id_prefix: re1696

  columns: [id, function, args, expected]
  rows:
    - ["re1696001", "re.Pattern.__dict__.__contains__",     ["__reduce__"],        false]
    - ["re1696002", "re.Pattern.__dict__.__contains__",     ["__getstate__"],      false]
    - ["re1696003", "re.Pattern.__dict__.__contains__",     ["__setstate__"],      false]
    - ["re1696004", "re.Pattern.__dict__.__contains__",     ["__getnewargs__"],    false]
    - ["re1696005", "re.Pattern.__dict__.__contains__",     ["__getnewargs_ex__"], false]
    - ["re1696006", "re.Match.__dict__.__contains__",       ["__reduce__"],        false]
    - ["re1696007", "re.Match.__dict__.__contains__",       ["__getstate__"],      false]
    - ["re1696008", "re.Match.__dict__.__contains__",       ["__setstate__"],      false]
    - ["re1696009", "re.Match.__dict__.__contains__",       ["__getnewargs__"],    false]
    - ["re1696010", "re.Match.__dict__.__contains__",       ["__getnewargs_ex__"], false]
    - ["re1696011", "re.error.__dict__.__contains__",       ["__reduce__"],        false]
    - ["re1696012", "re.error.__dict__.__contains__",       ["__getstate__"],      false]
    - ["re1696013", "re.error.__dict__.__contains__",       ["__setstate__"],      false]
    - ["re1696014", "re.RegexFlag.__dict__.__contains__",   ["__reduce__"],        false]
    - ["re1696015", "re.RegexFlag.__dict__.__contains__",   ["__getstate__"],      false]
    - ["re1696016", "re.RegexFlag.__dict__.__contains__",   ["__setstate__"],      false]
    - ["re1696017", "re.RegexFlag.__dict__.__contains__",   ["__getnewargs__"],    false]
    - ["re1696018", "re.RegexFlag.__dict__.__contains__",   ["__getnewargs_ex__"], false]

# ---------------------------------------------------------------------------
# Table 2: copy_protocol
#
# re.Pattern and re.Match each define __copy__ and __deepcopy__ in their
# own __dict__.  These C extension types support copy but not pickle.
# re.error and re.RegexFlag define neither __copy__ nor __deepcopy__.
# ---------------------------------------------------------------------------

table re_extra1696.copy_protocol:
  description: "re types copy protocol (__copy__, __deepcopy__) dict-presence checks"
  kind: python_call_eq
  category: copy_protocol
  id_prefix: re1696

  columns: [id, function, args, expected]
  rows:
    - ["re1696020", "re.Pattern.__dict__.__contains__",     ["__copy__"],     true]
    - ["re1696021", "re.Pattern.__dict__.__contains__",     ["__deepcopy__"], true]
    - ["re1696022", "re.Match.__dict__.__contains__",       ["__copy__"],     true]
    - ["re1696023", "re.Match.__dict__.__contains__",       ["__deepcopy__"], true]
    - ["re1696024", "re.error.__dict__.__contains__",       ["__copy__"],     false]
    - ["re1696025", "re.error.__dict__.__contains__",       ["__deepcopy__"], false]
    - ["re1696026", "re.RegexFlag.__dict__.__contains__",   ["__copy__"],     false]
    - ["re1696027", "re.RegexFlag.__dict__.__contains__",   ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# Table 3: copy_vs_pickle_contrast
#
# Highlights the asymmetry: re.Pattern and re.Match define __copy__ and
# __deepcopy__ but deliberately omit the five pickle-protocol methods.
# This confirms the design intent — compiled patterns are copyable but
# not serialisable via pickle.
# ---------------------------------------------------------------------------

table re_extra1696.copy_vs_pickle_contrast:
  description: "re.Pattern and re.Match: copy protocol present, pickle protocol absent"
  kind: python_call_eq
  category: copy_vs_pickle_contrast
  id_prefix: re1696

  columns: [id, function, args, expected]
  rows:
    - ["re1696030", "re.Pattern.__dict__.__contains__", ["__copy__"],          true]
    - ["re1696031", "re.Pattern.__dict__.__contains__", ["__deepcopy__"],      true]
    - ["re1696032", "re.Pattern.__dict__.__contains__", ["__reduce__"],        false]
    - ["re1696033", "re.Pattern.__dict__.__contains__", ["__getstate__"],      false]
    - ["re1696034", "re.Pattern.__dict__.__contains__", ["__getnewargs__"],    false]
    - ["re1696035", "re.Pattern.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["re1696036", "re.Match.__dict__.__contains__",   ["__copy__"],          true]
    - ["re1696037", "re.Match.__dict__.__contains__",   ["__deepcopy__"],      true]
    - ["re1696038", "re.Match.__dict__.__contains__",   ["__reduce__"],        false]
    - ["re1696039", "re.Match.__dict__.__contains__",   ["__getstate__"],      false]
    - ["re1696040", "re.Match.__dict__.__contains__",   ["__getnewargs__"],    false]
    - ["re1696041", "re.Match.__dict__.__contains__",   ["__getnewargs_ex__"], false]
