spec: theseus_sre_parse_cr
version: ">=3.0"
backend: python_cleanroom(theseus_sre_parse_cr)
blocks: sre_parse

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "CPython source: Lib/sre_parse.py"
  notes:
    - "Clean-room sre_parse module. Do NOT import sre_parse."

error_model: python_exceptions

invariant theseus_sre_parse_cr.srep2_parse:
  description: "parse() function parses a regex pattern string"
  category: behavior
  kind: python_call_eq
  function: srep2_parse
  args: []
  expected: true

invariant theseus_sre_parse_cr.srep2_state:
  description: "State class tracks parsing state"
  category: behavior
  kind: python_call_eq
  function: srep2_state
  args: []
  expected: true

invariant theseus_sre_parse_cr.srep2_subpattern:
  description: "SubPattern class represents a parsed sub-pattern"
  category: behavior
  kind: python_call_eq
  function: srep2_subpattern
  args: []
  expected: true
