spec: cryptography_extra_rust
version: ">=3.9"
backend: rust_module(cryptography_extra_rust)

docs: https://cryptography.io/

provenance:
  derived_from:
    - "https://cryptography.io/ — cryptography library"
  notes:
    - "cryptography provides cryptographic primitives."
    - "cryptography.hazmat.primitives.hashes.SHA256 is a class."
    - "cryptography.fernet.Fernet.generate_key() returns bytes."
    - "cryptography.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant cryptography_extra_rust.fernet_key_is_bytes:
  description: "Fernet.generate_key() returns bytes"
  category: fernet
  kind: python_call_eq
  function: cryptography_fernet_key_is_bytes
  args: []
  expected: true

invariant cryptography_extra_rust.has_sha256:
  description: "cryptography has SHA256 hash class"
  category: presence
  kind: python_call_eq
  function: cryptography_has_sha256
  args: []
  expected: true

invariant cryptography_extra_rust.version_nonempty:
  description: "cryptography.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: cryptography_extra_version_nonempty
  args: []
  expected: true

