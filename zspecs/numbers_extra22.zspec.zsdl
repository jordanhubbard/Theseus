spec: numbers_extra22
version: ">=3.9"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers_extra21.zspec.zsdl."
    - "Prior specs covered: __name__/__module__/__qualname__ and lengths for all 5 ABCs, __mro__.__len__() and __bases__[0].__name__ for all 5 ABCs, __abstractmethods__.__len__() for all 5 ABCs."
    - "This spec covers: numbers module-level attributes (__name__, __doc__.__class__.__name__, __all__) and their lengths; __dict__.__class__.__name__.__len__() (always 12, 'mappingproxy') for all 5 ABCs; __qualname__.__len__() for all 5 ABCs."
    - "numbers.__all__ == ['Number', 'Complex', 'Real', 'Rational', 'Integral'] — length 5, class 'list'."
    - "numbers.__name__ == 'numbers' (7 chars); numbers.__doc__.__class__.__name__ == 'str' (3 chars)."
    - "All ABC __dict__ objects are mappingproxy instances (12 chars)."
    - "Qualname lengths: Number=6, Complex=7, Real=4, Rational=8, Integral=8."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# numbers module-level identity attributes
#
# numbers.__name__ == 'numbers' (7 chars). numbers.__doc__ is a str (len 3).
# numbers.__all__ lists all 5 ABCs — length 5, class 'list'. No prior
# numbers spec records any of these module-level attribute values.
# ---------------------------------------------------------------------------

invariant numbers_extra22.module.name_len:
  description: "len(numbers.__name__) == 7 — 'numbers' is 7 chars"
  category: module_identity
  kind: python_call_eq
  function: numbers.__name__.__len__
  args: []
  expected: 7

invariant numbers_extra22.module.doc_class_name_len:
  description: "len(numbers.__doc__.__class__.__name__) == 3 — docstring is a 'str'"
  category: module_identity
  kind: python_call_eq
  function: numbers.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

invariant numbers_extra22.module.all_len:
  description: "len(numbers.__all__) == 5 — exports Number, Complex, Real, Rational, Integral"
  category: module_identity
  kind: python_call_eq
  function: numbers.__all__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() == 12 for all 5 ABCs
#
# Every class's __dict__ is a mappingproxy object. The string 'mappingproxy'
# is 12 chars. No prior numbers spec records __dict__.__class__.__name__.__len__()
# for any of the 5 ABCs. All five share the same value.
# ---------------------------------------------------------------------------

table numbers_extra22.abc_dict_class_name_lens:
  description: "__dict__.__class__.__name__.__len__() == 12 for all 5 numbers ABCs"
  kind: python_call_eq
  category: class_identity
  id_prefix: dict_cls_len

  columns: [id, function, args, expected, description]
  rows:
    - [Number,
       Number.__dict__.__class__.__name__.__len__,
       [],
       12,
       "numbers.Number.__dict__ is a 'mappingproxy' (12 chars)"]
    - [Complex,
       Complex.__dict__.__class__.__name__.__len__,
       [],
       12,
       "numbers.Complex.__dict__ is a 'mappingproxy' (12 chars)"]
    - [Real,
       Real.__dict__.__class__.__name__.__len__,
       [],
       12,
       "numbers.Real.__dict__ is a 'mappingproxy' (12 chars)"]
    - [Rational,
       Rational.__dict__.__class__.__name__.__len__,
       [],
       12,
       "numbers.Rational.__dict__ is a 'mappingproxy' (12 chars)"]
    - [Integral,
       Integral.__dict__.__class__.__name__.__len__,
       [],
       12,
       "numbers.Integral.__dict__ is a 'mappingproxy' (12 chars)"]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for all 5 numbers ABCs
#
# All 5 ABCs are top-level classes with no nesting prefix, so __qualname__
# equals __name__. Lengths: Number=6, Complex=7, Real=4, Rational=8, Integral=8.
# No prior numbers spec records __qualname__.__len__() in a combined table
# across all 5 ABCs (prior specs recorded them individually).
# ---------------------------------------------------------------------------

table numbers_extra22.abc_qualname_lens:
  description: "__qualname__.__len__() for all 5 numbers ABCs"
  kind: python_call_eq
  category: class_identity
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [Number,
       Number.__qualname__.__len__,
       [],
       6,
       "numbers.Number.__qualname__ == 'Number' (6 chars)"]
    - [Complex,
       Complex.__qualname__.__len__,
       [],
       7,
       "numbers.Complex.__qualname__ == 'Complex' (7 chars)"]
    - [Real,
       Real.__qualname__.__len__,
       [],
       4,
       "numbers.Real.__qualname__ == 'Real' (4 chars)"]
    - [Rational,
       Rational.__qualname__.__len__,
       [],
       8,
       "numbers.Rational.__qualname__ == 'Rational' (8 chars)"]
    - [Integral,
       Integral.__qualname__.__len__,
       [],
       8,
       "numbers.Integral.__qualname__ == 'Integral' (8 chars)"]

# ---------------------------------------------------------------------------
# numbers.__all__.__class__.__name__ == 'list' — standalone
#
# numbers.__all__ is a plain list object. Its class name is 'list' (4 chars).
# No prior numbers spec records the type of numbers.__all__.
# ---------------------------------------------------------------------------

invariant numbers_extra22.module.all_class_name_len:
  description: "len(numbers.__all__.__class__.__name__) == 4 — __all__ is a 'list'"
  category: module_identity
  kind: python_call_eq
  function: numbers.__all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Integral.__qualname__.__len__() == 8 — standalone
#
# numbers.Integral.__qualname__ == 'Integral' (8 chars). Integral and
# Rational share the longest __qualname__ length of any ABC in the numbers
# tower (both 8). No prior numbers spec records Integral.__qualname__.__len__()
# as a standalone invariant.
# ---------------------------------------------------------------------------

invariant numbers_extra22.Integral.qualname_len:
  description: "len(numbers.Integral.__qualname__) == 8 — 'Integral' is 8 chars"
  category: class_identity
  kind: python_call_eq
  function: Integral.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Number.__qualname__.__len__() == 6 — standalone
#
# numbers.Number.__qualname__ == 'Number' (6 chars). Number is the root of
# the numeric tower. No prior numbers spec records Number.__qualname__.__len__()
# as a standalone invariant.
# ---------------------------------------------------------------------------

invariant numbers_extra22.Number.qualname_len:
  description: "len(numbers.Number.__qualname__) == 6 — 'Number' is 6 chars"
  category: class_identity
  kind: python_call_eq
  function: Number.__qualname__.__len__
  args: []
  expected: 6
