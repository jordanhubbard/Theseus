spec: dataclasses_extra34
version: ">=3.10"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses_extra33.zspec.zsdl."
    - "Prior specs covered: all function/class __name__/__module__/__qualname__/__bases__; FrozenInstanceError/__mro__.__len__()==5; InitVar/__mro__.__len__()==2; Field method __qualname__.__len__(); KW_ONLY/__class__.__qualname__.__len__()==13; MISSING/__class__.__qualname__.__len__()==13; make_dataclass/__qualname__.__len__()==14; InitVar/__qualname__.__len__()==7; __dict__.__class__.__name__.__len__()==12 for Field/FrozenInstanceError/InitVar; module-level function __qualname__.__len__() for all 8 functions; dataclasses.__all__.__len__()==13; __all__.__class__.__name__.__len__()==4; FrozenInstanceError.__bases__[0].__name__.__len__()==14; MISSING/__class__.__name__.__len__()==13; KW_ONLY/__class__.__name__.__len__()==13."
    - "This spec covers: Field.__mro__.__len__()==2; InitVar.__mro__.__len__()==2; FrozenInstanceError.__mro__.__len__()==5; Field/__bases__[0].__name__.__len__()==6 ('object'); InitVar/__bases__[0].__name__.__len__()==6 ('object'); Field.__name__.__len__()==5; FrozenInstanceError.__name__.__len__()==19; InitVar.__name__.__len__()==7; Field.__qualname__.__len__()==5; FrozenInstanceError.__qualname__.__len__()==19; dataclasses.__name__.__len__()==11; Field.__slots__.__len__()==12."
    - "Field.__mro__.__len__() == 2 (Field → object) — Field is a plain class with no intermediate base."
    - "InitVar.__mro__.__len__() == 2 (InitVar → object) — InitVar is similarly a plain class."
    - "FrozenInstanceError.__mro__.__len__() == 5 (FrozenInstanceError → AttributeError → Exception → BaseException → object)."
    - "Field.__bases__[0].__name__ == 'object' (len=6); InitVar.__bases__[0].__name__ == 'object' (len=6)."
    - "Field.__name__ == 'Field' (len=5); Field.__qualname__ == 'Field' (len=5) — name equals qualname for a top-level class."
    - "FrozenInstanceError.__name__ == 'FrozenInstanceError' (len=19); __qualname__ also 19."
    - "InitVar.__name__ == 'InitVar' (len=7); __qualname__ also 7."
    - "dataclasses.__name__ == 'dataclasses' (len=11)."
    - "Field.__slots__.__len__() == 12 — Field has 12 slots: name, type, default, default_factory, repr, hash, init, compare, metadata, kw_only, doc, _field_type."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for the three dataclasses public classes (extra34 namespace)
#
# Field and InitVar are simple classes with no intermediate superclasses:
#   Field.__mro__   == (Field, object)   -> length 2
#   InitVar.__mro__ == (InitVar, object) -> length 2
# FrozenInstanceError inherits from the full exception hierarchy:
#   FrozenInstanceError.__mro__ == (FrozenInstanceError, AttributeError,
#                                   Exception, BaseException, object) -> length 5
# No prior dataclasses spec records these three MRO lengths together in the
# extra34 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra34.class_mro_lens:
  description: "__mro__.__len__() for Field/InitVar (2 each) and FrozenInstanceError (5)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mro_len

  columns: [id, function, args, expected]
  rows:
    - [Field,               Field.__mro__.__len__,               [], 2]
    - [InitVar,             InitVar.__mro__.__len__,             [], 2]
    - [FrozenInstanceError, FrozenInstanceError.__mro__.__len__, [], 5]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__() for Field and InitVar (extra34 namespace)
#
# Both Field and InitVar inherit directly from 'object' (6 characters). Neither
# class has an intermediate superclass — they are plain Python classes created
# at the top level of the dataclasses module. This contrasts with
# FrozenInstanceError whose base 'AttributeError' has 14 characters (recorded
# in dataclasses_extra33). No prior dataclasses spec records Field and InitVar
# base name lengths together in the extra34 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra34.object_base_name_lens:
  description: "__bases__[0].__name__.__len__()==6 ('object') for Field and InitVar"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base_name_len

  columns: [id, function, args, expected]
  rows:
    - [Field,   "Field.__bases__[0].__name__.__len__",   [], 6]
    - [InitVar, "InitVar.__bases__[0].__name__.__len__",  [], 6]

# ---------------------------------------------------------------------------
# __name__.__len__() for the three dataclasses public classes (extra34 namespace)
#
# Class __name__ lengths:
#   Field.__name__ == 'Field' (5 chars)
#   InitVar.__name__ == 'InitVar' (7 chars)
#   FrozenInstanceError.__name__ == 'FrozenInstanceError' (19 chars)
# For Field and InitVar, __name__ == __qualname__ (both 5 and 7 respectively),
# since they are defined at module top-level. FrozenInstanceError.__name__ is
# also 19, equal to its __qualname__. No prior dataclasses spec records these
# three __name__ lengths together in the extra34 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra34.class_name_lens:
  description: "__name__.__len__() for Field (5), InitVar (7), FrozenInstanceError (19)"
  kind: python_call_eq
  category: class_name_attrs
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [Field,               Field.__name__.__len__,               [], 5]
    - [InitVar,             InitVar.__name__.__len__,             [], 7]
    - [FrozenInstanceError, FrozenInstanceError.__name__.__len__, [], 19]

# ---------------------------------------------------------------------------
# dataclasses.__name__.__len__() == 11 — standalone (extra34 namespace)
#
# The module's own __name__ is 'dataclasses' — 11 characters. This matches
# the length of 'collections' (also 11), making these two stdlib modules
# equal in module name length. No prior dataclasses spec records this
# standalone in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra34.module_name_len:
  description: "dataclasses.__name__.__len__() == 11 — the module name 'dataclasses' has 11 characters"
  category: module_attrs
  kind: python_call_eq
  function: dataclasses.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# Field.__slots__.__len__() == 12 — standalone (extra34 namespace)
#
# dataclasses.Field defines 12 slots: name, type, default, default_factory,
# repr, hash, init, compare, metadata, kw_only, doc, and _field_type. These
# slots correspond directly to the parameters accepted by the field() factory
# function plus the private _field_type attribute used internally. No prior
# dataclasses spec records the slot count in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra34.Field.slots_len:
  description: "dataclasses.Field.__slots__.__len__() == 12 — Field has 12 slots covering all field() parameters plus the private _field_type sentinel"
  category: class_attrs
  kind: python_call_eq
  function: Field.__slots__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# FrozenInstanceError.__qualname__.__len__() == 19 — standalone
# (extra34 namespace)
#
# FrozenInstanceError.__qualname__ == 'FrozenInstanceError' (19 characters).
# As a top-level class, its qualname equals its name. 'FrozenInstanceError'
# is the longest class name in the dataclasses module — 19 characters vs
# 'Field' (5) and 'InitVar' (7). No prior dataclasses spec records this
# standalone in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra34.FrozenInstanceError.qualname_len:
  description: "dataclasses.FrozenInstanceError.__qualname__.__len__() == 19 — 'FrozenInstanceError' is the longest class name in dataclasses (19 chars)"
  category: qualname_attrs
  kind: python_call_eq
  function: FrozenInstanceError.__qualname__.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# Field.__qualname__.__len__() == 5 — standalone (extra34 namespace)
#
# dataclasses.Field.__qualname__ == 'Field' (5 characters). As a top-level
# class, __qualname__ == __name__. The Field class is not publicly
# constructable by users (the field() function should be used instead), but it
# is a public class in dataclasses.__all__ that appears in type annotations and
# repr output. No prior dataclasses spec records this standalone in the
# extra34 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra34.Field.qualname_len:
  description: "dataclasses.Field.__qualname__.__len__() == 5 — 'Field' is 5 chars; __qualname__ == __name__ for this top-level class"
  category: qualname_attrs
  kind: python_call_eq
  function: Field.__qualname__.__len__
  args: []
  expected: 5
