spec: unified
version: ">=11.0.0"
backend: node(unified)

docs: https://unifiedjs.com

provenance:
  derived_from:
    - "Unified docs — https://unifiedjs.com"
    - "Test vectors verified with unified via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "unified source"
  notes:
    - "Pluggable text-processing pipeline — base for remark, rehype, retext."
    - "Install: npm install unified"
    - "v11 ESM only; named export unified() returns a fresh Processor."
    - "Plugins are JS functions which the chain helper can't pass; spec covers the synchronous Processor shape."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factory; never throws."
  stderr: "null"
  stickiness: "N/A — Processors are immutable; .use() returns a new Processor."
  codes: {}

invariant unified.factory_returns_processor:
  description: "unified() returns a Processor object"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: unified
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "Processor"

invariant unified.processor_has_use:
  description: "Processor has .use method"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: unified
  entry_args: []
  chain:
    - {get: "use.constructor.name"}
  expected: "Function"

invariant unified.processor_has_parse:
  description: "Processor has .parse method"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: unified
  entry_args: []
  chain:
    - {get: "parse.constructor.name"}
  expected: "Function"

invariant unified.processor_has_run:
  description: "Processor has .run method"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: unified
  entry_args: []
  chain:
    - {get: "run.constructor.name"}
  expected: "Function"

invariant unified.processor_has_stringify:
  description: "Processor has .stringify method"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: unified
  entry_args: []
  chain:
    - {get: "stringify.constructor.name"}
  expected: "Function"

invariant unified.processor_has_process:
  description: "Processor has .process method"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: unified
  entry_args: []
  chain:
    - {get: "process.constructor.name"}
  expected: "Function"

invariant unified.processor_has_data:
  description: "Processor has .data accessor"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: unified
  entry_args: []
  chain:
    - {get: "data.constructor.name"}
  expected: "Function"

invariant unified.processor_attachers_empty:
  description: "Fresh Processor has empty .attachers (no plugins yet)"
  category: state
  kind: node_chain_eq
  entry: factory
  factory: unified
  entry_args: []
  chain:
    - {get: attachers}
    - {get: length}
  expected: 0

