spec: io_extra233
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
  notes:
    - "This spec covers: io.BytesIO and io.StringIO behavioral output contracts — read, getvalue, tell, and seek return values."
    - "io.BytesIO(b'hello').read() returns b'hello' — reads all bytes from position 0; verified Python 3.14.3 macOS."
    - "io.BytesIO(b'hello').read(3) returns b'hel' — reads first 3 bytes; verified Python 3.14.3 macOS."
    - "io.BytesIO(b'hello world').getvalue() returns b'hello world' — getvalue() returns full buffer regardless of position; verified Python 3.14.3 macOS."
    - "io.BytesIO(b'hello').getvalue().__len__() == 5 — length of the bytes buffer; verified Python 3.14.3 macOS."
    - "io.StringIO('hello').read() returns 'hello' — reads all text from position 0; verified Python 3.14.3 macOS."
    - "io.StringIO('hello world').getvalue() returns 'hello world' — getvalue() returns full buffer; verified Python 3.14.3 macOS."
    - "io.StringIO('hello').getvalue().__len__() == 5 — length of the string buffer; verified Python 3.14.3 macOS."
    - "io.BytesIO().tell() == 0 — initial stream position is 0; verified Python 3.14.3 macOS."
    - "io.BytesIO(b'abc').seek(0) == 0 — seek returns the new absolute position; verified Python 3.14.3 macOS."
    - "io.BytesIO(b'abc').seek(1) == 1 — seek to offset 1 returns 1; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO read behavioral contracts
# BytesIO(b'hello').read() reads all bytes from the initial position (0).
# BytesIO(b'hello').read(3) reads the first 3 bytes.
# BytesIO(b'hello world').getvalue() returns the full buffer contents.
# BytesIO(b'hello').getvalue().__len__() == 5.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra233.BytesIO.read_all_eq:
  description: "io.BytesIO(b'hello').read().__eq__(b'hello') == True — read() with no argument returns all bytes from position 0; BytesIO is initialised at position 0 so read() returns the full buffer; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: BytesIO
  args: ["b'hello'"]
  method: read().__eq__
  method_args: ["b'hello'"]
  expected: true

invariant io_extra233.BytesIO.read3_eq:
  description: "io.BytesIO(b'hello').read(3).__eq__(b'hel') == True — read(3) returns the first 3 bytes; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: BytesIO
  args: ["b'hello'"]
  method: read(3).__eq__
  method_args: ["b'hel'"]
  expected: true

invariant io_extra233.BytesIO.getvalue_eq:
  description: "io.BytesIO(b'hello world').getvalue().__eq__(b'hello world') == True — getvalue() returns the complete buffer contents regardless of stream position; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: BytesIO
  args: ["b'hello world'"]
  method: getvalue().__eq__
  method_args: ["b'hello world'"]
  expected: true

invariant io_extra233.BytesIO.getvalue_len:
  description: "io.BytesIO(b'hello').getvalue().__len__() == 5 — the buffer contains 5 bytes ('hello'); verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: BytesIO
  args: ["b'hello'"]
  method: getvalue().__len__
  method_args: []
  expected: 5

# ---------------------------------------------------------------------------
# io.StringIO read behavioral contracts
# StringIO('hello').read() reads all text from the initial position (0).
# StringIO('hello world').getvalue() returns the full buffer contents.
# StringIO('hello').getvalue().__len__() == 5.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra233.StringIO.read_all_eq:
  description: "io.StringIO('hello').read().__eq__('hello') == True — read() with no argument returns all text from position 0; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: read().__eq__
  method_args: ["hello"]
  expected: true

invariant io_extra233.StringIO.getvalue_eq:
  description: "io.StringIO('hello world').getvalue().__eq__('hello world') == True — getvalue() returns the complete string buffer; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: StringIO
  args: ["hello world"]
  method: getvalue().__eq__
  method_args: ["hello world"]
  expected: true

invariant io_extra233.StringIO.getvalue_len:
  description: "io.StringIO('hello').getvalue().__len__() == 5 — the string buffer contains 5 characters ('hello'); verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: getvalue().__len__
  method_args: []
  expected: 5

# ---------------------------------------------------------------------------
# io.BytesIO tell and seek behavioral contracts
# BytesIO().tell() == 0 — initial stream position is always 0.
# BytesIO(b'abc').seek(0) == 0 — seek returns the new absolute position.
# BytesIO(b'abc').seek(1) == 1 — seek to position 1 returns 1.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra233.BytesIO.tell_initial_zero:
  description: "io.BytesIO().tell().__eq__(0) == True — initial stream position is 0 for a newly constructed empty BytesIO; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: BytesIO
  args: []
  method: tell().__eq__
  method_args: [0]
  expected: true

invariant io_extra233.BytesIO.seek0_returns_0:
  description: "io.BytesIO(b'abc').seek(0).__eq__(0) == True — seek(0) moves to position 0 (SEEK_SET default) and returns the new position 0; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: BytesIO
  args: ["b'abc'"]
  method: seek(0).__eq__
  method_args: [0]
  expected: true

invariant io_extra233.BytesIO.seek1_returns_1:
  description: "io.BytesIO(b'abc').seek(1).__eq__(1) == True — seek(1) moves to position 1 (SEEK_SET default) and returns the new position 1; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: BytesIO
  args: ["b'abc'"]
  method: seek(1).__eq__
  method_args: [1]
  expected: true
