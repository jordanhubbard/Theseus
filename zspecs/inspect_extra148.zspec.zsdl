# inspect.__spec__.name == 'inspect' (len 7)
#
# getmembers and isfunction are Python functions defined in Lib/inspect.py.
# New to extra148.
# ---------------------------------------------------------------------------

table inspect_extra148.module_functions_identity:
  description: "inspect.getmembers: __qualname__ 'getmembers', __doc__ len 134; inspect.isfunction: __doc__ len 817; inspect.__spec__.name 'inspect' len 7; wave 277; new to extra148"
