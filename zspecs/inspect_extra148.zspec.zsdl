    - [getmembers_module_eq_inspect,
       "getmembers.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getmembers.__module__.__eq__('inspect') == True — getmembers is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra148"]
    - [getmembers_doc_len_eq_134,
       "getmembers.__doc__.__len__",
       [],
       134,
       "inspect.getmembers.__doc__.__len__() == 134 — the getmembers docstring has 134 characters in Python 3.14.3; len(__doc__) == 134; new to extra148"]
    - [isfunction_doc_len_eq_817,
       "isfunction.__doc__.__len__",
       [],
       817,
       "inspect.isfunction.__doc__.__len__() == 817 — the isfunction docstring has 817 characters in Python 3.14.3; len(__doc__) == 817; new to extra148"]
    - [spec_name_eq_inspect,
       "__spec__.name.__eq__",
       ["inspect"],
       true,
       "inspect.__spec__.name.__eq__('inspect') == True — the ModuleSpec name attribute is the fully-qualified module name 'inspect'; str.__eq__('inspect') returns True; new to extra148"]
    - [spec_name_len_eq_7,
       "__spec__.name.__len__",
       [],
       7,
       "inspect.__spec__.name.__len__() == 7 — __spec__.name is 'inspect' which has 7 characters; len('inspect') == 7; new to extra148"]

