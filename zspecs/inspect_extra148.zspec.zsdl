spec: inspect_extra148
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.ArgInfo namedtuple — __name__ 'ArgInfo' len 7, _fields len 4 ('args','varargs','keywords','locals'); inspect.Attribute namedtuple — __name__ 'Attribute' len 9, _fields len 4 ('name','kind','defining_class','object'), __bases__[0]=='tuple', MRO len 3; inspect.Parameter class — __name__ 'Parameter', __module__ 'inspect', __bases__[0]=='object', MRO len 2; inspect.getmembers — Python function, __qualname__ 'getmembers', __doc__ len 134; inspect.isfunction — Python function, __doc__ len 817; inspect.__spec__ — ModuleSpec, name 'inspect' len 7 (Wave 277)."
    - "inspect.ArgInfo is a namedtuple with 4 fields: 'args', 'varargs', 'keywords', 'locals'; __name__ == 'ArgInfo' (len 7); __bases__[0].__name__ == 'tuple'; MRO len == 3; __module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Attribute is a namedtuple with 4 fields: 'name', 'kind', 'defining_class', 'object'; __name__ == 'Attribute' (len 9); __bases__[0].__name__ == 'tuple'; MRO len == 3; __module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Parameter is a plain Python class defined in Lib/inspect.py; __name__ == 'Parameter'; __module__ == 'inspect'; __bases__[0].__name__ == 'object'; MRO len == 2. Verified with Python 3.14.3."
    - "inspect.getmembers is a Python function; __qualname__ == 'getmembers'; __module__ == 'inspect'; len(__doc__) == 134. Verified with Python 3.14.3."
    - "len(inspect.isfunction.__doc__) == 817 — the isfunction docstring has 817 characters. Verified with Python 3.14.3."
    - "inspect.__spec__.name == 'inspect' (len 7) — the ModuleSpec name is the module's qualified name. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.ArgInfo namedtuple identity and fields
#
# Wave 277 theme: inspect.ArgInfo namedtuple — fields and class identity.
#
# inspect.ArgInfo.__name__ == 'ArgInfo' (len 7)
# inspect.ArgInfo.__module__ == 'inspect'
# inspect.ArgInfo.__bases__[0].__name__ == 'tuple'
# len(inspect.ArgInfo.__mro__) == 3
# len(inspect.ArgInfo._fields) == 4
# inspect.ArgInfo.__qualname__ == 'ArgInfo'
#
# ArgInfo is a namedtuple with 4 fields: args, varargs, keywords, locals.
# It is returned by inspect.getargvalues(). New to extra148.
# Note: extra99 covered ArgInfo class/module/bases/mro/qualname; this table
# focuses on the _fields content and len, and name length.
# ---------------------------------------------------------------------------

table inspect_extra148.arginfo_fields_identity:
  description: "inspect.ArgInfo namedtuple: __name__ 'ArgInfo' len 7, _fields len 4 with fields args/varargs/keywords/locals, __module__ 'inspect'; wave 277; new to extra148"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectarginfo148

  columns: [id, function, args, expected, description]
  rows:
    - [arginfo_name_eq_arginfo,
       "ArgInfo.__name__.__eq__",
       ["ArgInfo"],
       true,
       "inspect.ArgInfo.__name__.__eq__('ArgInfo') == True — ArgInfo is a namedtuple defined at module scope in Lib/inspect.py; __name__ is 'ArgInfo'; str.__eq__('ArgInfo') returns True; new to extra148"]
    - [arginfo_name_len_eq_7,
       "ArgInfo.__name__.__len__",
       [],
       7,
       "inspect.ArgInfo.__name__.__len__() == 7 — __name__ is 'ArgInfo' which has 7 characters; len('ArgInfo') == 7; new to extra148"]
    - [arginfo_fields_len_eq_4,
       "ArgInfo._fields.__len__",
       [],
       4,
       "inspect.ArgInfo._fields.__len__() == 4 — ArgInfo is a namedtuple with 4 fields: 'args', 'varargs', 'keywords', 'locals'; len(_fields) == 4; new to extra148"]
    - [arginfo_module_eq_inspect,
       "ArgInfo.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.ArgInfo.__module__.__eq__('inspect') == True — ArgInfo is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra148"]
    - [arginfo_bases_first_eq_tuple,
       "ArgInfo.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.ArgInfo.__bases__[0].__name__.__eq__('tuple') == True — ArgInfo is a namedtuple and therefore a subclass of tuple; __bases__[0].__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra148"]
    - [arginfo_mro_len_eq_3,
       "ArgInfo.__mro__.__len__",
       [],
       3,
       "inspect.ArgInfo.__mro__.__len__() == 3 — the MRO of ArgInfo is [ArgInfo, tuple, object]; as a namedtuple subclassing tuple it has exactly 3 MRO entries; len() == 3; new to extra148"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Attribute namedtuple identity and fields
#
# Wave 277 theme: inspect.Attribute namedtuple — a namedtuple used by
# inspect.classify_class_attrs() to describe each attribute of a class.
#
# inspect.Attribute.__name__ == 'Attribute' (len 9)
# inspect.Attribute.__module__ == 'inspect'
# inspect.Attribute.__bases__[0].__name__ == 'tuple'
# len(inspect.Attribute.__mro__) == 3
# len(inspect.Attribute._fields) == 4
# inspect.Attribute.__qualname__ == 'Attribute'
#
# Attribute is a namedtuple with 4 fields: name, kind, defining_class, object.
# New to extra148.
# ---------------------------------------------------------------------------

table inspect_extra148.attribute_namedtuple_identity:
  description: "inspect.Attribute namedtuple: __name__ 'Attribute' len 9, _fields len 4 (name/kind/defining_class/object), __bases__[0]=='tuple', MRO len 3; wave 277; new to extra148"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectattribute148

  columns: [id, function, args, expected, description]
  rows:
    - [attribute_class_eq_type,
       "Attribute.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Attribute.__class__.__name__.__eq__('type') == True — Attribute is a namedtuple created via collections.namedtuple; namedtuples are classes whose metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra148"]
    - [attribute_name_eq_attribute,
       "Attribute.__name__.__eq__",
       ["Attribute"],
       true,
       "inspect.Attribute.__name__.__eq__('Attribute') == True — Attribute namedtuple is defined at module scope in Lib/inspect.py; __name__ is 'Attribute'; str.__eq__('Attribute') returns True; new to extra148"]
    - [attribute_name_len_eq_9,
       "Attribute.__name__.__len__",
       [],
       9,
       "inspect.Attribute.__name__.__len__() == 9 — __name__ is 'Attribute' which has 9 characters; len('Attribute') == 9; new to extra148"]
    - [attribute_module_eq_inspect,
       "Attribute.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Attribute.__module__.__eq__('inspect') == True — Attribute namedtuple is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra148"]
    - [attribute_fields_len_eq_4,
       "Attribute._fields.__len__",
       [],
       4,
       "inspect.Attribute._fields.__len__() == 4 — Attribute is a namedtuple with 4 fields: 'name', 'kind', 'defining_class', 'object'; len(_fields) == 4; new to extra148"]
    - [attribute_bases_first_eq_tuple,
       "Attribute.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.Attribute.__bases__[0].__name__.__eq__('tuple') == True — Attribute is a namedtuple and therefore inherits from tuple; __bases__[0].__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra148"]
    - [attribute_mro_len_eq_3,
       "Attribute.__mro__.__len__",
       [],
       3,
       "inspect.Attribute.__mro__.__len__() == 3 — MRO of Attribute is [Attribute, tuple, object]; as a namedtuple subclass of tuple it has exactly 3 MRO entries; len() == 3; new to extra148"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter class identity
#
# Wave 277 theme: inspect.Parameter — a plain Python class (not a namedtuple)
# that represents a callable parameter in a Signature.
#
# inspect.Parameter.__name__ == 'Parameter'
# inspect.Parameter.__module__ == 'inspect'
# inspect.Parameter.__qualname__ == 'Parameter'
# inspect.Parameter.__bases__[0].__name__ == 'object'
# len(inspect.Parameter.__mro__) == 2
#
# Parameter is a plain Python class defined in Lib/inspect.py.
# New to extra148.
# ---------------------------------------------------------------------------

table inspect_extra148.parameter_class_identity:
  description: "inspect.Parameter class: __name__ 'Parameter', __module__ 'inspect', __bases__[0]=='object', MRO len 2; wave 277; new to extra148"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparam148

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_class_eq_type,
       "Parameter.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.__class__.__name__.__eq__('type') == True — Parameter is a plain Python class (not a namedtuple) defined in Lib/inspect.py; it represents a parameter in a Signature; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra148"]
    - [parameter_name_eq,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter's __name__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra148"]
    - [parameter_module_eq_inspect,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra148"]
    - [parameter_qualname_eq,
       "Parameter.__qualname__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__.__eq__('Parameter') == True — Parameter is defined at module scope; __qualname__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra148"]
    - [parameter_bases_first_eq_object,
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra148"]
    - [parameter_mro_len_eq_2,
       "Parameter.__mro__.__len__",
       [],
       2,
       "inspect.Parameter.__mro__.__len__() == 2 — Parameter inherits directly from object; MRO is [Parameter, object]; len() == 2; new to extra148"]

# ---------------------------------------------------------------------------
