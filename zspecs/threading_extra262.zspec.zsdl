spec: threading_extra262
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading.zspec.zsdl — covers Barrier, BoundedSemaphore, Condition classnames; function names; TIMEOUT_MAX; Lock, Event, Semaphore, current_thread.is_alive"
    - "threading_extra.zspec.zsdl — covers BoundedSemaphore/Condition/Semaphore/Event/RLock __module__; local; get_ident return type; TIMEOUT_MAX; stack_size return type"
    - "threading_extra261.zspec.zsdl — covers local class identity; current_thread, main_thread, active_count, enumerate identity"
  notes:
    - "threading.get_ident is a C-level builtin re-exported from _thread: __module__ == '_thread'; __class__.__name__ == 'builtin_function_or_method'."
    - "threading.get_native_id is also a C-level builtin from _thread: __module__ == '_thread'; __class__.__name__ == 'builtin_function_or_method'."
    - "threading.settrace is a Python function: __module__ == 'threading'; __class__.__name__ == 'function'."
    - "threading.setprofile is a Python function: __module__ == 'threading'; __class__.__name__ == 'function'."
    - "threading.stack_size is a C-level builtin from _thread: __module__ == '_thread'; __class__.__name__ == 'builtin_function_or_method'."
    - "get_ident.__qualname__ == 'get_ident'; get_native_id.__qualname__ == 'get_native_id'."
    - "settrace.__qualname__ == 'settrace'; setprofile.__qualname__ == 'setprofile'; stack_size.__qualname__ == 'stack_size'."
    - "All values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks — five threading functions
# ---------------------------------------------------------------------------

table threading_extra262.function_names:
  description: "get_ident, get_native_id, settrace, setprofile, stack_size __name__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [get_ident,     get_ident.__name__.__eq__,     ["get_ident"],     true]
    - [get_native_id, get_native_id.__name__.__eq__, ["get_native_id"], true]
    - [settrace,      settrace.__name__.__eq__,      ["settrace"],      true]
    - [setprofile,    setprofile.__name__.__eq__,    ["setprofile"],    true]
    - [stack_size,    stack_size.__name__.__eq__,    ["stack_size"],    true]

# ---------------------------------------------------------------------------
# __qualname__ checks — all five match __name__ (not nested)
# ---------------------------------------------------------------------------

table threading_extra262.function_qualnames:
  description: "get_ident, get_native_id, settrace, setprofile, stack_size __qualname__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [get_ident,     get_ident.__qualname__.__eq__,     ["get_ident"],     true]
    - [get_native_id, get_native_id.__qualname__.__eq__, ["get_native_id"], true]
    - [settrace,      settrace.__qualname__.__eq__,      ["settrace"],      true]
    - [setprofile,    setprofile.__qualname__.__eq__,    ["setprofile"],    true]
    - [stack_size,    stack_size.__qualname__.__eq__,    ["stack_size"],    true]

# ---------------------------------------------------------------------------
# __module__ checks
#
# get_ident, get_native_id, stack_size are C-level builtins from _thread.
# settrace and setprofile are Python functions defined in threading.
# ---------------------------------------------------------------------------

invariant threading_extra262.get_ident.module:
  description: "threading.get_ident.__module__ == '_thread' — C-level builtin re-exported from _thread"
  category: identity
  kind: python_call_eq
  function: get_ident.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra262.get_native_id.module:
  description: "threading.get_native_id.__module__ == '_thread' — C-level builtin re-exported from _thread"
  category: identity
  kind: python_call_eq
  function: get_native_id.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra262.settrace.module:
  description: "threading.settrace.__module__ == 'threading' — Python function defined in threading"
  category: identity
  kind: python_call_eq
  function: settrace.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra262.setprofile.module:
  description: "threading.setprofile.__module__ == 'threading' — Python function defined in threading"
  category: identity
  kind: python_call_eq
  function: setprofile.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra262.stack_size.module:
  description: "threading.stack_size.__module__ == '_thread' — C-level builtin re-exported from _thread"
  category: identity
  kind: python_call_eq
  function: stack_size.__module__.__eq__
  args: ["_thread"]
  expected: true

# ---------------------------------------------------------------------------
# __class__.__name__ checks
#
# get_ident, get_native_id, stack_size: 'builtin_function_or_method' (C-level)
# settrace, setprofile: 'function' (Python-level)
# ---------------------------------------------------------------------------

table threading_extra262.function_class_names:
  description: "get_ident, get_native_id, stack_size are builtins; settrace, setprofile are functions"
  kind: python_call_eq
  category: identity
  id_prefix: fclass

  columns: [id, function, args, expected]
  rows:
    - [get_ident,     get_ident.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [get_native_id, get_native_id.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [settrace,      settrace.__class__.__name__.__eq__,      ["function"],                   true]
    - [setprofile,    setprofile.__class__.__name__.__eq__,    ["function"],                   true]
    - [stack_size,    stack_size.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
