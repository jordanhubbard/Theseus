spec: st3001
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct: Interpret bytes as packed binary data"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 647 (st3001): __getitem__, __setitem__, __delitem__ dict-presence checks for struct types."
    - "struct.Struct is a C extension type for packing/unpacking binary data — not a mapping or sequence type; item access protocol is absent."
    - "struct.error is an exception subclass — not a mapping or sequence type."
    - "None of the struct types define __getitem__, __setitem__, or __delitem__ in their own __dict__."
    - "Verified types: struct.Struct, struct.error."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table st3001.getitem:
  description: "struct types __getitem__ dict-presence checks; wave 647"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st3001
  columns: [id, function, args, expected]
  rows:
    - ["st3001001", operator.contains, [struct.Struct.__dict__, "__getitem__"], false]
    - ["st3001002", operator.contains, [struct.error.__dict__, "__getitem__"], false]

