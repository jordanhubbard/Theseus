spec: decimal_extra89
version: ">=3.9"
backend: python_module(decimal)
extends: decimal_extra88

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra88.zspec.zsdl."
    - "This spec covers: decimal exception class hierarchy — DecimalException, Clamped, InvalidOperation, DivisionByZero, Inexact, Rounded, Subnormal, Overflow, Underflow, FloatOperation."
    - "decimal.DecimalException.__bases__[0].__name__ = 'ArithmeticError' — root of decimal exception hierarchy."
    - "decimal.DecimalException.__mro__.__len__() = 5 — MRO: [DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.Clamped.__bases__[0].__name__ = 'DecimalException' — Clamped, InvalidOperation, Inexact, Rounded, Subnormal, FloatOperation all extend DecimalException directly."
    - "decimal.Clamped.__mro__.__len__() = 6 — one level deeper than DecimalException."
    - "decimal.DivisionByZero.__bases__[0].__name__ = 'DecimalException' — but also inherits ZeroDivisionError via multiple inheritance."
    - "decimal.DivisionByZero.__mro__.__len__() = 7 — MRO: [DivisionByZero, DecimalException, ZeroDivisionError, ArithmeticError, Exception, BaseException, object]."
    - "decimal.Overflow.__bases__[0].__name__ = 'Inexact' — Overflow and Underflow extend Inexact (not DecimalException directly)."
    - "decimal.Overflow.__mro__.__len__() = 8 — MRO: [Overflow, Inexact, Rounded, Subnormal, DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.Underflow.__bases__[0].__name__ = 'Inexact' — Underflow extends Inexact."
    - "decimal.Underflow.__mro__.__len__() = 9 — MRO: [Underflow, Inexact, Rounded, Subnormal, DecimalException, ArithmeticError, Exception, BaseException, object] — deepest MRO of all decimal exceptions."
    - "decimal.FloatOperation.__mro__.__len__() = 7 — FloatOperation has multiple bases (DecimalException and TypeError)."
    - "All decimal exception classes have __module__ == 'decimal'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal exception __bases__[0].__name__ grouped by base class
# DecimalException -> ArithmeticError (root of hierarchy).
# Clamped, InvalidOperation, Inexact, Rounded, Subnormal, FloatOperation -> DecimalException.
# DivisionByZero -> DecimalException (also inherits ZeroDivisionError).
# Overflow, Underflow -> Inexact.
# ---------------------------------------------------------------------------

table decimal_extra89.exception_bases:
  description: "decimal exception __bases__[0].__name__ for all exception classes, grouped by base class"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalexceptions89

  columns: [id, function, args, expected]
  rows:
    - [decexc_base_arith,   "DecimalException.__bases__[0].__name__.__eq__",  ["ArithmeticError"],  true]
    - [clamped_base_dec,    "Clamped.__bases__[0].__name__.__eq__",           ["DecimalException"], true]
    - [invop_base_dec,      "InvalidOperation.__bases__[0].__name__.__eq__",  ["DecimalException"], true]
    - [divbyz_base_dec,     "DivisionByZero.__bases__[0].__name__.__eq__",    ["DecimalException"], true]
    - [inexact_base_dec,    "Inexact.__bases__[0].__name__.__eq__",           ["DecimalException"], true]
    - [rounded_base_dec,    "Rounded.__bases__[0].__name__.__eq__",           ["DecimalException"], true]
    - [subnorm_base_dec,    "Subnormal.__bases__[0].__name__.__eq__",         ["DecimalException"], true]
    - [overflow_base_inex,  "Overflow.__bases__[0].__name__.__eq__",          ["Inexact"],          true]
    - [underflow_base_inex, "Underflow.__bases__[0].__name__.__eq__",         ["Inexact"],          true]
    - [floatop_base_dec,    "FloatOperation.__bases__[0].__name__.__eq__",    ["DecimalException"], true]

# ---------------------------------------------------------------------------
# decimal exception __mro__.__len__() for each exception class
# DecimalException=5, Clamped/InvalidOperation/Inexact/Rounded/Subnormal=6,
# DivisionByZero/FloatOperation=7, Overflow=8, Underflow=9.
# ---------------------------------------------------------------------------

table decimal_extra89.exception_mro_lengths:
  description: "decimal exception __mro__.__len__() for all exception classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalexceptions89

  columns: [id, function, args, expected]
  rows:
    - [decexc_mro_len,  DecimalException.__mro__.__len__,  [], 5]
    - [clamped_mro_len, Clamped.__mro__.__len__,           [], 6]
    - [invop_mro_len,   InvalidOperation.__mro__.__len__,  [], 6]
    - [divbyz_mro_len,  DivisionByZero.__mro__.__len__,    [], 7]
    - [inexact_mro_len, Inexact.__mro__.__len__,           [], 6]
    - [rounded_mro_len, Rounded.__mro__.__len__,           [], 6]
    - [subnorm_mro_len, Subnormal.__mro__.__len__,         [], 6]
    - [overflow_mro,    Overflow.__mro__.__len__,          [], 8]
    - [underflow_mro,   Underflow.__mro__.__len__,         [], 9]
    - [floatop_mro_len, FloatOperation.__mro__.__len__,    [], 7]

# ---------------------------------------------------------------------------
# decimal exception __module__ equality
# All decimal exception classes are defined in the 'decimal' module (not '_decimal').
# ---------------------------------------------------------------------------

table decimal_extra89.exception_module_eq:
  description: "decimal exception __module__ == 'decimal' for all exception classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalexceptions89

  columns: [id, function, args, expected]
  rows:
    - [decexc_mod_eq,  DecimalException.__module__.__eq__,  ["decimal"], true]
    - [clamped_mod_eq, Clamped.__module__.__eq__,           ["decimal"], true]
    - [invop_mod_eq,   InvalidOperation.__module__.__eq__,  ["decimal"], true]
    - [divbyz_mod_eq,  DivisionByZero.__module__.__eq__,    ["decimal"], true]
    - [inexact_mod_eq, Inexact.__module__.__eq__,           ["decimal"], true]
    - [rounded_mod_eq, Rounded.__module__.__eq__,           ["decimal"], true]
    - [subnorm_mod_eq, Subnormal.__module__.__eq__,         ["decimal"], true]
    - [overflow_mod,   Overflow.__module__.__eq__,          ["decimal"], true]
    - [underflow_mod,  Underflow.__module__.__eq__,         ["decimal"], true]
    - [floatop_mod_eq, FloatOperation.__module__.__eq__,    ["decimal"], true]

# ---------------------------------------------------------------------------
# decimal exception __name__ equality checks for selected exceptions
# Verifying canonical short class names (not module-prefixed).
# ---------------------------------------------------------------------------

table decimal_extra89.exception_name_eq:
  description: "decimal exception __name__ string equality for selected exceptions"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalexceptions89

  columns: [id, function, args, expected]
  rows:
    - [decexc_name_eq,  DecimalException.__name__.__eq__,  ["DecimalException"], true]
    - [clamped_name_eq, Clamped.__name__.__eq__,           ["Clamped"],          true]
    - [invop_name_eq,   InvalidOperation.__name__.__eq__,  ["InvalidOperation"], true]
    - [overflow_name,   Overflow.__name__.__eq__,          ["Overflow"],         true]
    - [underflow_name,  Underflow.__name__.__eq__,         ["Underflow"],        true]
    - [floatop_name_eq, FloatOperation.__name__.__eq__,    ["FloatOperation"],   true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra89.DecimalException.base_is_ArithmeticError:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' (root of decimal exception hierarchy is ArithmeticError)"
  category: class_identity
  kind: python_call_eq
  function: "DecimalException.__bases__[0].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true

invariant decimal_extra89.Overflow.base_is_Inexact:
  description: "decimal.Overflow.__bases__[0].__name__ == 'Inexact' (Overflow extends Inexact, not DecimalException directly)"
  category: class_identity
  kind: python_call_eq
  function: "Overflow.__bases__[0].__name__.__eq__"
  args: ["Inexact"]
  expected: true

invariant decimal_extra89.Underflow.mro_len_9:
  description: "decimal.Underflow.__mro__.__len__() == 9 (deepest MRO among all decimal exceptions: [Underflow, Inexact, Rounded, Subnormal, DecimalException, ArithmeticError, Exception, BaseException, object])"
  category: class_identity
  kind: python_call_eq
  function: Underflow.__mro__.__len__
  args: []
  expected: 9

invariant decimal_extra89.DivisionByZero.mro_len_7:
  description: "decimal.DivisionByZero.__mro__.__len__() == 7 (DivisionByZero inherits from both DecimalException and ZeroDivisionError)"
  category: class_identity
  kind: python_call_eq
  function: DivisionByZero.__mro__.__len__
  args: []
  expected: 7

invariant decimal_extra89.InvalidOperation.module_eq_decimal:
  description: "decimal.InvalidOperation.__module__ == 'decimal' (all decimal exception classes are defined in the decimal module)"
  category: class_identity
  kind: python_call_eq
  function: InvalidOperation.__module__.__eq__
  args: ["decimal"]
  expected: true
