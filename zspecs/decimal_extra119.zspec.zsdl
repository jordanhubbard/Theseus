spec: decimal_extra119
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec covers: decimal.Decimal arithmetic operator method __qualname__ string equality and lengths not yet covered."
    - "decimal.Decimal is a C extension type; its methods are wrapper_descriptor objects with no __code__ attribute."
    - "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (len=15)."
    - "decimal.Decimal.__sub__.__qualname__ == 'Decimal.__sub__' (len=15)."
    - "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__' (len=15)."
    - "decimal.Decimal.__mod__.__qualname__ == 'Decimal.__mod__' (len=15)."
    - "decimal.Decimal.__pow__.__qualname__ == 'Decimal.__pow__' (len=15)."
    - "decimal.Decimal.__neg__.__qualname__ == 'Decimal.__neg__' (len=15)."
    - "decimal.Decimal.__abs__.__qualname__ == 'Decimal.__abs__' (len=15)."
    - "decimal.Decimal.__truediv__.__qualname__ == 'Decimal.__truediv__' (len=19)."
    - "decimal.Decimal.__floordiv__.__qualname__ == 'Decimal.__floordiv__' (len=20)."
    - "decimal.Decimal.__eq__.__qualname__ == 'Decimal.__eq__' (len=14)."
    - "All methods are type wrapper_descriptor (C extension slot wrappers)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal short arithmetic operator __qualname__ string equality (len=15)
# __add__, __sub__, __mul__, __mod__, __pow__, __neg__, __abs__ all have
# __qualname__ == 'Decimal.<op>' where <op> is 5 chars, giving total len=15.
# All are wrapper_descriptor (C extension type slot wrappers).
# No prior decimal spec asserts __qualname__ for any of these methods.
# ---------------------------------------------------------------------------

table decimal_extra119.Decimal_arith_qualnames_len15:
  description: "decimal.Decimal arithmetic operator __qualname__ equality: __add__/__sub__/__mul__/__mod__/__pow__/__neg__/__abs__ all == 'Decimal.<5-char-op>'(len=15); all are wrapper_descriptor; all assertions novel"
  kind: python_call_eq
  category: qualnames
  id_prefix: decop119a

  columns: [id, function, args, expected, description]
  rows:
    - [add_qn_eq,   "Decimal.__add__.__qualname__.__eq__",  ["Decimal.__add__"],  true,  "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (15 chars; __add__ implements the + operator for Decimal addition; 'Decimal.'(8)+'__add__'(7)==15)"]
    - [add_qn_len,  "Decimal.__add__.__qualname__.__len__",  [],                  15,    "decimal.Decimal.__add__.__qualname__.__len__() == 15 ('Decimal.__add__' has 15 characters; this length is shared by __sub__, __mul__, __mod__, __pow__, __neg__, __abs__)"]
    - [sub_qn_eq,   "Decimal.__sub__.__qualname__.__eq__",  ["Decimal.__sub__"],  true,  "decimal.Decimal.__sub__.__qualname__ == 'Decimal.__sub__' (15 chars; __sub__ implements the - binary operator for Decimal subtraction; same qualname length as __add__)"]
    - [mul_qn_eq,   "Decimal.__mul__.__qualname__.__eq__",  ["Decimal.__mul__"],  true,  "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__' (15 chars; __mul__ implements the * operator for Decimal multiplication; same qualname length as __add__)"]
    - [mod_qn_eq,   "Decimal.__mod__.__qualname__.__eq__",  ["Decimal.__mod__"],  true,  "decimal.Decimal.__mod__.__qualname__ == 'Decimal.__mod__' (15 chars; __mod__ implements the % operator for Decimal modulo; same qualname length as __add__)"]
    - [pow_qn_eq,   "Decimal.__pow__.__qualname__.__eq__",  ["Decimal.__pow__"],  true,  "decimal.Decimal.__pow__.__qualname__ == 'Decimal.__pow__' (15 chars; __pow__ implements the ** operator for Decimal exponentiation; same qualname length as __add__)"]
    - [neg_qn_eq,   "Decimal.__neg__.__qualname__.__eq__",  ["Decimal.__neg__"],  true,  "decimal.Decimal.__neg__.__qualname__ == 'Decimal.__neg__' (15 chars; __neg__ implements the unary - operator for Decimal negation; same qualname length as __add__)"]
    - [abs_qn_eq,   "Decimal.__abs__.__qualname__.__eq__",  ["Decimal.__abs__"],  true,  "decimal.Decimal.__abs__.__qualname__ == 'Decimal.__abs__' (15 chars; __abs__ implements abs() for Decimal absolute value; same qualname length as __add__)"]

# ---------------------------------------------------------------------------
# decimal.Decimal longer arithmetic operator __qualname__ (len=19, 20)
# __truediv__ has len=19 ('Decimal.__truediv__': 'Decimal.'(8)+'__truediv__'(11)==19).
# __floordiv__ has len=20 ('Decimal.__floordiv__': 'Decimal.'(8)+'__floordiv__'(12)==20).
# Comparison operators __eq__/__lt__/__le__/__gt__/__ge__ have len=14.
# ---------------------------------------------------------------------------

table decimal_extra119.Decimal_division_qualnames:
  description: "decimal.Decimal division operator __qualname__: __truediv__=='Decimal.__truediv__'(19); __floordiv__=='Decimal.__floordiv__'(20); comparison ops __eq__/'lt'/'gt' have len=14; all assertions novel"
  kind: python_call_eq
  category: qualnames
  id_prefix: decop119b

  columns: [id, function, args, expected, description]
  rows:
    - [td_qn_eq,    "Decimal.__truediv__.__qualname__.__eq__",   ["Decimal.__truediv__"],  true,  "decimal.Decimal.__truediv__.__qualname__ == 'Decimal.__truediv__' (19 chars; __truediv__ implements the / operator for Decimal true division; 'Decimal.'(8)+'__truediv__'(11)==19; longer than the 5-letter arithmetic ops at 15)"]
    - [td_qn_len,   "Decimal.__truediv__.__qualname__.__len__",  [],                       19,    "decimal.Decimal.__truediv__.__qualname__.__len__() == 19 ('__truediv__' is 11 chars vs 7 chars for '__add__'; gives 'Decimal.__truediv__' at 19)"]
    - [fd_qn_eq,    "Decimal.__floordiv__.__qualname__.__eq__",  ["Decimal.__floordiv__"], true,  "decimal.Decimal.__floordiv__.__qualname__ == 'Decimal.__floordiv__' (20 chars; __floordiv__ implements the // operator for Decimal floor division; 'Decimal.'(8)+'__floordiv__'(12)==20; longest division operator qualname)"]
    - [fd_qn_len,   "Decimal.__floordiv__.__qualname__.__len__", [],                       20,    "decimal.Decimal.__floordiv__.__qualname__.__len__() == 20 ('__floordiv__' is 12 chars; 'Decimal.__floordiv__' at 20 is 1 char longer than '__truediv__' at 19)"]
    - [eq_qn_eq,    "Decimal.__eq__.__qualname__.__eq__",        ["Decimal.__eq__"],       true,  "decimal.Decimal.__eq__.__qualname__ == 'Decimal.__eq__' (14 chars; __eq__ implements == for Decimal equality comparison; 'Decimal.'(8)+'__eq__'(6)==14; 1 char shorter than the 15-char arithmetic ops)"]
    - [eq_qn_len,   "Decimal.__eq__.__qualname__.__len__",       [],                       14,    "decimal.Decimal.__eq__.__qualname__.__len__() == 14 ('__eq__' is 6 chars; 'Decimal.__eq__' at 14 is 1 char shorter than 'Decimal.__add__' at 15)"]
    - [td_gt_add,   "Decimal.__truediv__.__qualname__.__len__.__gt__", [15],               true,  "len('Decimal.__truediv__') > len('Decimal.__add__') (19 > 15; truediv qualname is 4 chars longer than add qualname because '__truediv__'(11) > '__add__'(7))"]
    - [fd_gt_td,    "Decimal.__floordiv__.__qualname__.__len__.__gt__", [19],              true,  "len('Decimal.__floordiv__') > len('Decimal.__truediv__') (20 > 19; floordiv is 1 char longer than truediv because '__floordiv__'(12) > '__truediv__'(11))"]

# ---------------------------------------------------------------------------
# decimal.Decimal method type verification and qualname cross-checks
# All arithmetic methods are wrapper_descriptor (C extension slot wrappers).
# This confirms Decimal is a C extension type (not a pure Python class).
# Cross-checks: __add__ and __sub__ have identical qualname strings modulo op name.
# ---------------------------------------------------------------------------

table decimal_extra119.Decimal_method_type_and_crosschecks:
  description: "decimal.Decimal arithmetic method type=='wrapper_descriptor'; cross-checks: __add__/__sub__/__neg__ all have len=15; __truediv__ len != __add__ len; __eq__ len != __add__ len; all novel"
  kind: python_call_eq
  category: qualnames
  id_prefix: decop119c

  columns: [id, function, args, expected, description]
  rows:
    - [add_type,      "Decimal.__add__.__class__.__name__.__eq__",         ["wrapper_descriptor"], true,  "decimal.Decimal.__add__.__class__.__name__ == 'wrapper_descriptor' (Decimal is a C extension type; its arithmetic methods are C-level slot wrappers exposed as wrapper_descriptor objects; they have __qualname__ but no __code__)"]
    - [neg_type,      "Decimal.__neg__.__class__.__name__.__eq__",         ["wrapper_descriptor"], true,  "decimal.Decimal.__neg__.__class__.__name__ == 'wrapper_descriptor' (same wrapper_descriptor type as __add__; all unary and binary arithmetic operators on Decimal are C extension slot wrappers)"]
    - [abs_type,      "Decimal.__abs__.__class__.__name__.__eq__",         ["wrapper_descriptor"], true,  "decimal.Decimal.__abs__.__class__.__name__ == 'wrapper_descriptor' (same type as __add__ and __neg__; __abs__ is a C-level slot wrapper for the nb_absolute numeric slot)"]
    - [add_ne_sub_qn, "Decimal.__add__.__qualname__.__eq__",               ["Decimal.__sub__"],    false, "decimal.Decimal.__add__.__qualname__ != 'Decimal.__sub__' (despite sharing the same length of 15, __add__ and __sub__ have distinct qualnames differing in the op name: 'add' vs 'sub')"]
    - [neg_len_eq_add,"Decimal.__neg__.__qualname__.__len__.__eq__",       [15],                   true,  "len('Decimal.__neg__') == len('Decimal.__add__') == 15 (neg and add share the same qualname length; both operator names have 5 chars when bracketed with double-underscores: '__neg__'(7)==__add__'(7))"]
    - [eq_lt_add,     "Decimal.__eq__.__qualname__.__len__.__lt__",        [15],                   true,  "len('Decimal.__eq__') < len('Decimal.__add__') (14 < 15; comparison operators like __eq__ have 6-char dunder names while arithmetic operators like __add__ have 7-char dunder names, making comparison op qualnames 1 char shorter)"]
    - [td_ne_add_qn,  "Decimal.__truediv__.__qualname__.__eq__",           ["Decimal.__add__"],    false, "decimal.Decimal.__truediv__.__qualname__ != 'Decimal.__add__' (truediv qualname is 'Decimal.__truediv__'(19) while add is 'Decimal.__add__'(15); distinct lengths confirm these are different operators)"]
    - [add_has_prefix, "Decimal.__add__.__qualname__.__contains__",        ["Decimal."],           true,  "decimal.Decimal.__add__.__qualname__.__contains__('Decimal.') == True (all Decimal arithmetic methods have the 'Decimal.' prefix in their __qualname__, reflecting that they are defined directly on the Decimal class)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra119.Decimal.__add___qualname_eq:
  description: "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (15 chars; __add__ implements the + binary operator for Decimal arithmetic; Decimal is a C extension type so __add__ is a wrapper_descriptor (not a function) and has no __code__ attribute; 'Decimal.__add__' uses 'Decimal.' as prefix because __add__ is defined on the Decimal class itself; all binary arithmetic operators of Decimal (__sub__, __mul__, __mod__, __pow__) share this qualname length of 15; no prior decimal spec asserts __add__.__qualname__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__add__.__qualname__.__eq__"
  args: ["Decimal.__add__"]
  expected: true

invariant decimal_extra119.Decimal.__neg___qualname_eq:
  description: "decimal.Decimal.__neg__.__qualname__ == 'Decimal.__neg__' (15 chars; __neg__ implements the unary minus operator for Decimal negation; like all Decimal arithmetic methods, it is a wrapper_descriptor with __qualname__ but no __code__; 'Decimal.__neg__' is 15 chars: 'Decimal.'(8)+'__neg__'(7)==15; same length as __add__/__sub__/__mul__/__mod__/__pow__/__abs__; no prior decimal spec asserts __neg__.__qualname__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__neg__.__qualname__.__eq__"
  args: ["Decimal.__neg__"]
  expected: true

invariant decimal_extra119.Decimal.__truediv___qualname_eq:
  description: "decimal.Decimal.__truediv__.__qualname__ == 'Decimal.__truediv__' (19 chars; __truediv__ implements the / operator for Decimal true division; 'Decimal.'(8)+'__truediv__'(11)==19; the 4-char longer qualname compared to __add__/(15) reflects the longer name '__truediv__'(11) vs '__add__'(7); Decimal true division is defined in the C extension and returns an exact or rounded Decimal result; no prior decimal spec asserts __truediv__.__qualname__ for Decimal); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__truediv__.__qualname__.__eq__"
  args: ["Decimal.__truediv__"]
  expected: true

invariant decimal_extra119.Decimal.__floordiv___qualname_eq:
  description: "decimal.Decimal.__floordiv__.__qualname__ == 'Decimal.__floordiv__' (20 chars; __floordiv__ implements the // floor division operator for Decimal; 'Decimal.'(8)+'__floordiv__'(12)==20; the longest arithmetic operator qualname on Decimal among the standard operators; 1 char longer than __truediv__ at 19 and 5 chars longer than __add__ at 15; no prior decimal spec asserts __floordiv__.__qualname__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__floordiv__.__qualname__.__eq__"
  args: ["Decimal.__floordiv__"]
  expected: true

invariant decimal_extra119.Decimal.__add___class_is_wrapper_descriptor:
  description: "decimal.Decimal.__add__.__class__.__name__ == 'wrapper_descriptor' (decimal.Decimal is implemented as a C extension type; its arithmetic operators are exposed as wrapper_descriptor objects, which are the C-level slot wrappers for numeric protocol methods like nb_add, nb_subtract, etc.; wrapper_descriptor objects have __qualname__ (as asserted here) but no __code__ attribute, distinguishing C extension types from pure Python classes; this is the first decimal spec to assert the wrapper_descriptor type of any Decimal arithmetic method); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__add__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true
