spec: theseus_codecs_cr
version: ">=3.8"
backend: python_cleanroom(theseus_codecs_cr)
blocks: codecs

docs: https://docs.python.org/3/library/codecs.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/codecs.html"
  not_derived_from:
    - "CPython source: Lib/codecs.py (internal implementation)"
  notes:
    - "Clean-room codecs module. Do NOT import codecs."
    - "encode(obj, encoding): encode object."
    - "decode(obj, encoding): decode bytes."
    - "lookup(encoding): return CodecInfo for named codec."
    - "open(file, mode, encoding): open file with specific encoding."

error_model: python_exceptions

invariant theseus_codecs_cr.codecs2_encode:
  description: "encode('hello', 'utf-8') returns bytes"
  category: encode
  kind: python_call_eq
  function: codecs2_encode
  args: []
  expected: true

invariant theseus_codecs_cr.codecs2_decode:
  description: "decode(b'hello', 'utf-8') returns 'hello'"
  category: decode
  kind: python_call_eq
  function: codecs2_decode
  args: []
  expected: "hello"

invariant theseus_codecs_cr.codecs2_hex:
  description: "encode using hex_codec produces hex string"
  category: encode
  kind: python_call_eq
  function: codecs2_hex
  args: []
  expected: true
