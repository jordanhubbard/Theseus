spec: inspect_extra86
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra85

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra85.zspec.zsdl."
    - "This spec covers: inspect isasyncgen/isasyncgenfunction/iscoroutine/iscoroutinefunction predicates code object attributes and __module__ (Wave 250)."
    - "inspect.isasyncgen.__code__.co_name == 'isasyncgen' — code object name matches function name. Verified with Python 3.14.3."
    - "inspect.isasyncgen.__code__.co_argcount == 1 — isasyncgen takes exactly one positional arg. Verified with Python 3.14.3."
    - "inspect.isasyncgenfunction.__code__.co_name == 'isasyncgenfunction' — code object name matches function name. Verified with Python 3.14.3."
    - "inspect.isasyncgenfunction.__code__.co_argcount == 1 — isasyncgenfunction takes exactly one positional arg. Verified with Python 3.14.3."
    - "inspect.iscoroutine.__code__.co_name == 'iscoroutine' — code object name matches function name. Verified with Python 3.14.3."
    - "inspect.iscoroutine.__code__.co_argcount == 1 — iscoroutine takes exactly one positional arg. Verified with Python 3.14.3."
    - "inspect.iscoroutinefunction.__code__.co_name == 'iscoroutinefunction' — code object name matches function name. Verified with Python 3.14.3."
    - "inspect.iscoroutinefunction.__code__.co_argcount == 1 — iscoroutinefunction takes exactly one positional arg. Verified with Python 3.14.3."
    - "inspect.isgeneratorfunction.__code__.co_name == 'isgeneratorfunction' — code object name matches function name. Verified with Python 3.14.3."
    - "inspect.isgeneratorfunction.__code__.co_argcount == 1 — isgeneratorfunction takes exactly one positional arg. Verified with Python 3.14.3."
    - "inspect.isasyncgen.__module__ == 'inspect' — isasyncgen is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.iscoroutine.__module__ == 'inspect' — iscoroutine is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.iscoroutinefunction.__module__ == 'inspect' — iscoroutinefunction is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isgeneratorfunction.__module__ == 'inspect' — isgeneratorfunction is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# isasyncgen / isasyncgenfunction code object attributes — extra86
#
# Wave 250 theme: isasyncgen/isasyncgenfunction co_name/co_argcount.
#
# inspect.isasyncgen.__code__.co_name          == 'isasyncgen'
# inspect.isasyncgen.__code__.co_argcount      == 1
# inspect.isasyncgenfunction.__code__.co_name  == 'isasyncgenfunction'
# inspect.isasyncgenfunction.__code__.co_argcount == 1
#
# No prior inspect spec checks isasyncgen/__code__ attrs via inspectextra86. New to extra86.
# ---------------------------------------------------------------------------

table inspect_extra86.isasyncgen_isasyncgenfunction_code_attrs:
  description: "isasyncgen co_name/co_argcount; isasyncgenfunction co_name/co_argcount; wave 250; new to extra86"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra86

  columns: [id, function, args, expected, description]
  rows:
    - [isasyncgen_co_name_eq_isasyncgen,
       isasyncgen.__code__.co_name.__eq__,
       ["isasyncgen"],
       true,
       "inspect.isasyncgen.__code__.co_name.__eq__('isasyncgen') == True — isasyncgen is a pure-Python function in Lib/inspect.py that checks whether an object is an asynchronous generator; its code object co_name is 'isasyncgen' (10 chars); str.__eq__('isasyncgen') returns True; no prior inspect spec checks isasyncgen.__code__.co_name via inspectextra86; new to extra86"]
    - [isasyncgen_co_argcount_eq_1,
       "isasyncgen.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isasyncgen.__code__.co_argcount.__eq__(1) == True — isasyncgen accepts exactly one positional argument (object); co_argcount counts positional args excluding *args and **kwargs; co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks isasyncgen.__code__.co_argcount via inspectextra86; new to extra86"]
    - [isasyncgenfunction_co_name_eq_isasyncgenfunction,
       isasyncgenfunction.__code__.co_name.__eq__,
       ["isasyncgenfunction"],
       true,
       "inspect.isasyncgenfunction.__code__.co_name.__eq__('isasyncgenfunction') == True — isasyncgenfunction is a pure-Python function in Lib/inspect.py that checks whether an object is an asynchronous generator function; its code object co_name is 'isasyncgenfunction' (18 chars); str.__eq__('isasyncgenfunction') returns True; no prior inspect spec checks isasyncgenfunction.__code__.co_name via inspectextra86; new to extra86"]
    - [isasyncgenfunction_co_argcount_eq_1,
       "isasyncgenfunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isasyncgenfunction.__code__.co_argcount.__eq__(1) == True — isasyncgenfunction accepts exactly one positional argument (object); co_argcount counts positional args excluding *args and **kwargs; co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks isasyncgenfunction.__code__.co_argcount via inspectextra86; new to extra86"]

# ---------------------------------------------------------------------------
# iscoroutine / iscoroutinefunction code object attributes — extra86
#
# Wave 250 theme: iscoroutine/iscoroutinefunction co_name/co_argcount.
#
# inspect.iscoroutine.__code__.co_name             == 'iscoroutine'
# inspect.iscoroutine.__code__.co_argcount         == 1
# inspect.iscoroutinefunction.__code__.co_name     == 'iscoroutinefunction'
# inspect.iscoroutinefunction.__code__.co_argcount == 1
#
# No prior inspect spec checks iscoroutine/__code__ attrs via inspectextra86. New to extra86.
# ---------------------------------------------------------------------------

table inspect_extra86.iscoroutine_iscoroutinefunction_code_attrs:
  description: "iscoroutine co_name/co_argcount; iscoroutinefunction co_name/co_argcount; wave 250; new to extra86"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra86

  columns: [id, function, args, expected, description]
  rows:
    - [iscoroutine_co_name_eq_iscoroutine,
       iscoroutine.__code__.co_name.__eq__,
       ["iscoroutine"],
       true,
       "inspect.iscoroutine.__code__.co_name.__eq__('iscoroutine') == True — iscoroutine is a pure-Python function in Lib/inspect.py that checks whether an object is a coroutine; its code object co_name is 'iscoroutine' (11 chars); str.__eq__('iscoroutine') returns True; no prior inspect spec checks iscoroutine.__code__.co_name via inspectextra86; new to extra86"]
    - [iscoroutine_co_argcount_eq_1,
       "iscoroutine.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.iscoroutine.__code__.co_argcount.__eq__(1) == True — iscoroutine accepts exactly one positional argument (object); co_argcount counts positional args excluding *args and **kwargs; co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks iscoroutine.__code__.co_argcount via inspectextra86; new to extra86"]
    - [iscoroutinefunction_co_name_eq_iscoroutinefunction,
       iscoroutinefunction.__code__.co_name.__eq__,
       ["iscoroutinefunction"],
       true,
       "inspect.iscoroutinefunction.__code__.co_name.__eq__('iscoroutinefunction') == True — iscoroutinefunction is a pure-Python function in Lib/inspect.py that checks whether an object is a coroutine function; its code object co_name is 'iscoroutinefunction' (19 chars); str.__eq__('iscoroutinefunction') returns True; no prior inspect spec checks iscoroutinefunction.__code__.co_name via inspectextra86; new to extra86"]
    - [iscoroutinefunction_co_argcount_eq_1,
       "iscoroutinefunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.iscoroutinefunction.__code__.co_argcount.__eq__(1) == True — iscoroutinefunction accepts exactly one positional argument (object); co_argcount counts positional args excluding *args and **kwargs; co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks iscoroutinefunction.__code__.co_argcount via inspectextra86; new to extra86"]

# ---------------------------------------------------------------------------
# isgeneratorfunction code object attributes — extra86
#
# Wave 250 theme: isgeneratorfunction co_name/co_argcount.
#
# inspect.isgeneratorfunction.__code__.co_name     == 'isgeneratorfunction'
# inspect.isgeneratorfunction.__code__.co_argcount == 1
# inspect.isasyncgen.__module__.__eq__('inspect')  == True
# inspect.iscoroutine.__module__.__eq__('inspect') == True
#
# No prior inspect spec checks isgeneratorfunction/__code__ attrs or predicate __module__ via inspectextra86. New to extra86.
# ---------------------------------------------------------------------------

table inspect_extra86.isgeneratorfunction_code_and_module_attrs:
  description: "isgeneratorfunction co_name/co_argcount; isasyncgen/__module__==inspect; iscoroutine/__module__==inspect; wave 250; new to extra86"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra86

  columns: [id, function, args, expected, description]
  rows:
    - [isgeneratorfunction_co_name_eq_isgeneratorfunction,
       isgeneratorfunction.__code__.co_name.__eq__,
       ["isgeneratorfunction"],
       true,
       "inspect.isgeneratorfunction.__code__.co_name.__eq__('isgeneratorfunction') == True — isgeneratorfunction is a pure-Python function in Lib/inspect.py that checks whether an object is a generator function; its code object co_name is 'isgeneratorfunction' (19 chars); str.__eq__('isgeneratorfunction') returns True; no prior inspect spec checks isgeneratorfunction.__code__.co_name via inspectextra86; new to extra86"]
    - [isgeneratorfunction_co_argcount_eq_1,
       "isgeneratorfunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isgeneratorfunction.__code__.co_argcount.__eq__(1) == True — isgeneratorfunction accepts exactly one positional argument (object); co_argcount counts positional args excluding *args and **kwargs; co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks isgeneratorfunction.__code__.co_argcount via inspectextra86; new to extra86"]
    - [isasyncgen_module_eq_inspect,
       isasyncgen.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isasyncgen.__module__.__eq__('inspect') == True — isasyncgen is defined in Lib/inspect.py; its __module__ attribute is the string 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks isasyncgen.__module__.__eq__ via inspectextra86; new to extra86"]
    - [iscoroutine_module_eq_inspect,
       iscoroutine.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.iscoroutine.__module__.__eq__('inspect') == True — iscoroutine is defined in Lib/inspect.py; its __module__ attribute is the string 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks iscoroutine.__module__.__eq__ via inspectextra86; new to extra86"]

# ---------------------------------------------------------------------------
# iscoroutinefunction / isgeneratorfunction __module__ — extra86
#
# Wave 250 theme: async/generator predicate __module__ equality.
#
# inspect.iscoroutinefunction.__module__.__eq__('inspect') == True
# inspect.isgeneratorfunction.__module__.__eq__('inspect') == True
# inspect.isasyncgen.__code__.co_name.__eq__('isasyncgen') == True  (double-confirm)
# inspect.iscoroutine.__code__.co_name.__eq__('iscoroutine') == True  (double-confirm)
#
# New to extra86.
# ---------------------------------------------------------------------------

table inspect_extra86.coroutinefunction_generatorfunction_module_and_confirms:
  description: "iscoroutinefunction/__module__==inspect; isgeneratorfunction/__module__==inspect; co_name double-confirms; wave 250; new to extra86"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra86

  columns: [id, function, args, expected, description]
  rows:
    - [iscoroutinefunction_module_eq_inspect,
       iscoroutinefunction.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.iscoroutinefunction.__module__.__eq__('inspect') == True — iscoroutinefunction is defined in Lib/inspect.py; its __module__ attribute is the string 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks iscoroutinefunction.__module__.__eq__ via inspectextra86; new to extra86"]
    - [isgeneratorfunction_module_eq_inspect,
       isgeneratorfunction.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isgeneratorfunction.__module__.__eq__('inspect') == True — isgeneratorfunction is defined in Lib/inspect.py; its __module__ attribute is the string 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks isgeneratorfunction.__module__.__eq__ via inspectextra86; new to extra86"]
    - [isasyncgen_co_name_confirm,
       isasyncgen.__code__.co_name.__eq__,
       ["isasyncgen"],
       true,
       "inspect.isasyncgen.__code__.co_name.__eq__('isasyncgen') == True — double-confirms isasyncgen code object co_name is 'isasyncgen'; this cross-checks both the function name and the code object consistency; new to extra86"]
    - [iscoroutine_co_name_confirm,
       iscoroutine.__code__.co_name.__eq__,
       ["iscoroutine"],
       true,
       "inspect.iscoroutine.__code__.co_name.__eq__('iscoroutine') == True — double-confirms iscoroutine code object co_name is 'iscoroutine'; this cross-checks both the function name and the code object consistency; new to extra86"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra86
# ---------------------------------------------------------------------------

invariant inspect_extra86.isasyncgen_co_name:
  description: "inspect.isasyncgen.__code__.co_name.__eq__('isasyncgen') == True — isasyncgen co_name matches function name; wave 250; new to extra86"
  kind: python_call_eq
  function: isasyncgen.__code__.co_name.__eq__
  args: ["isasyncgen"]
  expected: true

invariant inspect_extra86.iscoroutine_co_name:
  description: "inspect.iscoroutine.__code__.co_name.__eq__('iscoroutine') == True — iscoroutine co_name matches function name; wave 250; new to extra86"
  kind: python_call_eq
  function: iscoroutine.__code__.co_name.__eq__
  args: ["iscoroutine"]
  expected: true

invariant inspect_extra86.iscoroutinefunction_co_name:
  description: "inspect.iscoroutinefunction.__code__.co_name.__eq__('iscoroutinefunction') == True — iscoroutinefunction co_name matches function name; wave 250; new to extra86"
  kind: python_call_eq
  function: iscoroutinefunction.__code__.co_name.__eq__
  args: ["iscoroutinefunction"]
  expected: true

invariant inspect_extra86.isgeneratorfunction_co_name:
  description: "inspect.isgeneratorfunction.__code__.co_name.__eq__('isgeneratorfunction') == True — isgeneratorfunction co_name matches function name; wave 250; new to extra86"
  kind: python_call_eq
  function: isgeneratorfunction.__code__.co_name.__eq__
  args: ["isgeneratorfunction"]
  expected: true

invariant inspect_extra86.isasyncgen_module_eq_inspect:
  description: "inspect.isasyncgen.__module__.__eq__('inspect') == True — isasyncgen is defined in Lib/inspect.py; wave 250; new to extra86"
  kind: python_call_eq
  function: isasyncgen.__module__.__eq__
  args: ["inspect"]
  expected: true
