spec: itertools_extra21
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools.zspec.zsdl and prior extras through itertools_extra20.zspec.zsdl."
    - "itertools_extra20 covers: __bases__[0].__name__.__eq__ for ten classes; __module__.__eq__ anchors for chain/count/cycle/repeat/islice/product."
    - "itertools_extra19 covers: __name__.__eq__ for chain/cycle/repeat/count/zip_longest/takewhile/dropwhile/filterfalse; instance class names."
    - "No prior itertools spec records __mro__.__len__() for itertools classes in the extra21 namespace."
    - "All itertools iterator classes are C-level types that inherit directly from object. Every MRO has length 2: [<class>, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() table — twelve itertools classes
#
# Every itertools iterator class is a C-level type with exactly one base:
# object. Therefore every MRO is [<class>, object] and __len__() == 2.
# No prior itertools spec records all twelve MRO lengths in one table in
# the extra21 namespace.
# ---------------------------------------------------------------------------

table itertools_extra21.mro_lengths:
  kind: python_call_eq
  category: mro_depths
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra21.mro_lengths.chain,
       chain.__mro__.__len__,
       [],
       2,
       "itertools.chain.__mro__.__len__() == 2 — MRO is [chain, object]"]
    - [itertools_extra21.mro_lengths.count,
       count.__mro__.__len__,
       [],
       2,
       "itertools.count.__mro__.__len__() == 2 — MRO is [count, object]"]
    - [itertools_extra21.mro_lengths.cycle,
       cycle.__mro__.__len__,
       [],
       2,
       "itertools.cycle.__mro__.__len__() == 2 — MRO is [cycle, object]"]
    - [itertools_extra21.mro_lengths.repeat,
       repeat.__mro__.__len__,
       [],
       2,
       "itertools.repeat.__mro__.__len__() == 2 — MRO is [repeat, object]"]
    - [itertools_extra21.mro_lengths.product,
       product.__mro__.__len__,
       [],
       2,
       "itertools.product.__mro__.__len__() == 2 — MRO is [product, object]"]
    - [itertools_extra21.mro_lengths.permutations,
       permutations.__mro__.__len__,
       [],
       2,
       "itertools.permutations.__mro__.__len__() == 2 — MRO is [permutations, object]"]
    - [itertools_extra21.mro_lengths.combinations,
       combinations.__mro__.__len__,
       [],
       2,
       "itertools.combinations.__mro__.__len__() == 2 — MRO is [combinations, object]"]
    - [itertools_extra21.mro_lengths.islice,
       islice.__mro__.__len__,
       [],
       2,
       "itertools.islice.__mro__.__len__() == 2 — MRO is [islice, object]"]
    - [itertools_extra21.mro_lengths.starmap,
       starmap.__mro__.__len__,
       [],
       2,
       "itertools.starmap.__mro__.__len__() == 2 — MRO is [starmap, object]"]
    - [itertools_extra21.mro_lengths.compress,
       compress.__mro__.__len__,
       [],
       2,
       "itertools.compress.__mro__.__len__() == 2 — MRO is [compress, object]"]
    - [itertools_extra21.mro_lengths.groupby,
       groupby.__mro__.__len__,
       [],
       2,
       "itertools.groupby.__mro__.__len__() == 2 — MRO is [groupby, object]"]
    - [itertools_extra21.mro_lengths.accumulate,
       accumulate.__mro__.__len__,
       [],
       2,
       "itertools.accumulate.__mro__.__len__() == 2 — MRO is [accumulate, object]"]

# ---------------------------------------------------------------------------
# chain.__mro__.__len__() == 2 — standalone MRO depth invariant
#
# itertools.chain is a C-level type inheriting directly from object.
# No prior itertools spec records this invariant in the extra21 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra21.chain.mro_len:
  description: "itertools.chain.__mro__.__len__() == 2 — MRO is [chain, object]"
  category: mro_depths
  kind: python_call_eq
  function: chain.__mro__.__len__
  args: []
  expected: 2

