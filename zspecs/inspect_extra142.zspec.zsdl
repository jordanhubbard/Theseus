spec: inspect_extra142
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.isclass (Python function), inspect.isfunction (Python function), inspect.ismethod (Python function), inspect.ismodule (Python function), inspect.isbuiltin (Python function), inspect.getdoc (Python function) — __qualname__, __module__, __doc__ len, co_argcount (Wave 270)."
    - "inspect.isclass.__qualname__ == 'isclass' (len 7); doc len == 37; co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isfunction.__qualname__ == 'isfunction' (len 10); doc len == 817; co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.ismethod.__qualname__ == 'ismethod' (len 8); doc len == 48; co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.ismodule.__qualname__ == 'ismodule' (len 8); doc len == 38; co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__qualname__ == 'isbuiltin' (len 9); doc len == 284; co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.getdoc.__qualname__ == 'getdoc' (len 6); doc len == 237; co_argcount == 1. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.isclass and inspect.isfunction — qualname, doc, argcount
#
# Wave 270 theme: predicate functions for type classification.
#
# inspect.isclass.__class__.__name__ == 'function'
# inspect.isclass.__qualname__ == 'isclass' (len 7)
# inspect.isclass.__module__ == 'inspect' (len 7)
# len(inspect.isclass.__doc__) == 37
# inspect.isclass.__code__.co_argcount == 1
# inspect.isfunction.__qualname__ == 'isfunction' (len 10)
# inspect.isfunction.__module__ == 'inspect' (len 7)
# len(inspect.isfunction.__doc__) == 817
# inspect.isfunction.__code__.co_argcount == 1
#
# isclass(object) returns True if object is a class; isfunction returns True
# if object is a Python function. New to extra142.
# ---------------------------------------------------------------------------

table inspect_extra142.isclass_isfunction_attrs:
  description: "inspect.isclass (qualname len 7, doc len 37, co_argcount 1) and isfunction (qualname len 10, doc len 817, co_argcount 1); wave 270; new to extra142"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectisclsfn142

  columns: [id, function, args, expected, description]
  rows:
    - [isclass_class_eq_function,
       "isclass.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.isclass.__class__.__name__.__eq__('function') == True — isclass is a Python function defined in Lib/inspect.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra142"]
    - [isclass_qualname_eq,
       "isclass.__qualname__.__eq__",
       ["isclass"],
       true,
       "inspect.isclass.__qualname__.__eq__('isclass') == True — the function's __qualname__ is 'isclass'; str.__eq__('isclass') returns True; new to extra142"]
    - [isclass_qualname_len_eq_7,
       "isclass.__qualname__.__len__",
       [],
       7,
       "inspect.isclass.__qualname__.__len__() == 7 — __qualname__ is 'isclass' which has 7 characters; len('isclass') == 7; new to extra142"]
    - [isclass_module_eq_inspect,
       "isclass.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isclass.__module__.__eq__('inspect') == True — isclass is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra142"]
    - [isclass_doc_len_eq_37,
       "isclass.__doc__.__len__",
       [],
       37,
       "inspect.isclass.__doc__.__len__() == 37 — the isclass docstring has 37 characters; len(__doc__) == 37; verified with Python 3.14.3; new to extra142"]
    - [isclass_co_argcount_eq_1,
       "isclass.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isclass.__code__.co_argcount.__eq__(1) == True — isclass takes 1 positional-or-keyword argument: object; co_argcount is 1; int.__eq__(1) returns True; new to extra142"]
    - [isfunction_qualname_eq,
       "isfunction.__qualname__.__eq__",
       ["isfunction"],
       true,
       "inspect.isfunction.__qualname__.__eq__('isfunction') == True — the function's __qualname__ is 'isfunction'; str.__eq__('isfunction') returns True; new to extra142"]
    - [isfunction_qualname_len_eq_10,
       "isfunction.__qualname__.__len__",
       [],
       10,
       "inspect.isfunction.__qualname__.__len__() == 10 — __qualname__ is 'isfunction' which has 10 characters; len('isfunction') == 10; new to extra142"]
    - [isfunction_doc_len_eq_817,
       "isfunction.__doc__.__len__",
       [],
       817,
       "inspect.isfunction.__doc__.__len__() == 817 — the isfunction docstring has 817 characters; len(__doc__) == 817; verified with Python 3.14.3; new to extra142"]
    - [isfunction_co_argcount_eq_1,
       "isfunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isfunction.__code__.co_argcount.__eq__(1) == True — isfunction takes 1 positional-or-keyword argument: object; co_argcount is 1; int.__eq__(1) returns True; new to extra142"]

