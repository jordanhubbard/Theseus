error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_integer_x.isInteger:
  kind: node_module_call_eq
  function: "default"
  category: predicate
  id_prefix: isintx

  columns: [id, args, expected]
  rows:
    - [integer,     [5],    true]
    - [float,       [5.5],  false]
    - [zero,        [0],    true]
    - [neg_int,     [-3],   true]
    - [string,      ["5"],  false]

