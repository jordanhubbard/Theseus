spec: asyncio_extra63
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python function __defaults__ and __code__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec extends asyncio_extra62.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__()==13, Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__() tables, InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__/__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, Queue/Lock method qualname string equality, asyncio class __module__ string equality (extra52), Queue/Lock __doc__/__class__/__name__=='str' (extra50), asyncio.__all__.__class__.__name__=='list' (extra51), gather/sleep/__qualname__.__eq__ (extra3/extra22/extra26/extra28/extra43), Queue/__name__.__eq__ and Lock/__name__.__eq__ (extra/extra2/extra5), run/__qualname__.__eq__('run') (extra6/extra22/extra43), Condition/__name__/__qualname__/__len__() (extra53), BoundedSemaphore/__name__/__qualname__/__len__() (extra53), run/__name__.__eq__('run') (extra53), class __dict__.__class__.__name__/__qualname__ == 'mappingproxy' (extra54), class __class__.__module__.__eq__('builtins') (extra55), gather/sleep/wait __class__.__module__.__eq__('builtins') (extra55), Queue/Lock/Event/Semaphore/Condition __init__.__class__.__name__.__eq__('function') (extra55), class __repr__.__class__.__name__ (extra56), class __weakref__.__class__.__name__ (extra56), gather/sleep/wait function __repr__.__class__.__name__ (extra56), asyncio.__all__.__class__.__name__.__eq__('tuple') (extra57), class __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra57), class __subclasshook__.__class__.__name__ (extra57), asyncio.__all__.__contains__ membership checks (extra58), asyncio.__package__.__eq__('asyncio') (extra58), Queue/Lock __doc__.__class__.__name__.__eq__('str') (extra58), __loader__/__spec__/__file__/__cached__ __class__.__name__ (extra59), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__() (extra60), Queue/Lock __init__ and put/get/empty/full/qsize/acquire/release __qualname__.__eq__ (extra61), gather/sleep/wait __annotations__.__class__.__name__.__eq__('dict'), gather __globals__.__class__.__name__.__eq__('dict'), gather __globals__.__contains__('gather'), Queue.__doc__.__contains__('Queue') (extra62)."
    - "This spec covers (asynciocode63 namespace): wave 229 theme — __defaults__ and __code__ checks for function parameters + __closure__ identity. NEW in extra63: gather.__defaults__.__class__.__name__.__eq__('NoneType') — gather(*coros_or_futures, return_exceptions=False) has no positional defaults; __defaults__ is None; None.__class__.__name__ is 'NoneType'; no prior asyncio spec has checked gather.__defaults__.__class__.__name__ via __eq__; sleep.__defaults__.__class__.__name__.__eq__('tuple') — sleep(delay, result=None) has __defaults__==(None,) a one-element tuple; __class__.__name__ is 'tuple'; gather.__code__.__class__.__name__.__eq__('code') — gather is a pure-Python coroutine function; its __code__ attribute is a code object; __class__.__name__ is 'code'; sleep.__code__.__class__.__name__.__eq__('code') — sleep is a pure-Python coroutine function with a code object; Queue.__init__.__defaults__.__class__.__name__.__eq__('tuple') — Queue(maxsize=0) has __defaults__==(0,) a one-element tuple."
    - "asyncio.gather.__defaults__ is None. gather(*coros_or_futures, return_exceptions=False) takes only *args-style positional parameters and a keyword-only argument return_exceptions. The __defaults__ attribute holds defaults for positional-or-keyword parameters only, not keyword-only parameters (those go in __kwdefaults__). Since gather has no positional-or-keyword parameters with defaults, __defaults__ is None. None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__kwdefaults__ == {'return_exceptions': False}. The keyword-only default for return_exceptions is stored in __kwdefaults__, not __defaults__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__defaults__ == (None,). sleep(delay, result=None) has one positional-or-keyword parameter with a default (result=None). __defaults__ is a tuple of one element: (None,). __defaults__.__class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__code__.__class__.__name__ == 'code'. gather is a pure-Python coroutine function defined in Lib/asyncio/tasks.py. All pure-Python functions and coroutine functions have a __code__ attribute that is a code object. The type of a code object is <class 'code'>, so __class__.__name__ is 'code'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__code__.__class__.__name__ == 'code'. sleep is a pure-Python coroutine function defined in Lib/asyncio/tasks.py. Its __code__ attribute is a code object with __class__.__name__ == 'code'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__init__.__defaults__ == (0,). Queue(maxsize=0) has one positional-or-keyword parameter with a default (maxsize=0). __defaults__ is a tuple of one element: (0,). __defaults__.__class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio function __defaults__.__class__.__name__ checks — extra63
#
# Wave 229 theme: __defaults__ and __code__ checks for function parameters.
#
# gather(*coros_or_futures, return_exceptions=False) has no positional-or-keyword
# defaults, so __defaults__ is None (NoneType).
# sleep(delay, result=None) has __defaults__==(None,), a tuple.
# Queue(maxsize=0) has __defaults__==(0,), a tuple.
#
# NEW: no prior asyncio spec has checked __defaults__.__class__.__name__ via
# __eq__ for gather, sleep, or Queue.__init__.
# ---------------------------------------------------------------------------

table asyncio_extra63.function_defaults_class_name:
  description: "asyncio function __defaults__.__class__.__name__.__eq__ checks in asynciocode63 namespace — wave 229 theme: __defaults__ class identity; gather has no positional defaults so __defaults__ is None (NoneType); sleep(delay, result=None) has __defaults__==(None,) a tuple; Queue.__init__(maxsize=0) has __defaults__==(0,) a tuple; NEW in extra63: no prior asyncio spec has checked __defaults__.__class__.__name__ via __eq__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: asynciocode63

  columns: [id, function, args, expected, description]
  rows:
    - [gather_defaults_class, gather.__defaults__.__class__.__name__.__eq__, ["NoneType"], true, "gather.__defaults__.__class__.__name__ == 'NoneType' — gather(*coros_or_futures, return_exceptions=False) has no positional-or-keyword parameters with defaults; __defaults__ is None; keyword-only default return_exceptions=False goes in __kwdefaults__ not __defaults__; None.__class__.__name__ is 'NoneType'; NEW in extra63: first __defaults__.__class__.__name__.__eq__ check for gather in any asyncio spec; verified with Python 3.14.3"]
    - [sleep_defaults_class,  sleep.__defaults__.__class__.__name__.__eq__,  ["tuple"],    true, "sleep.__defaults__.__class__.__name__ == 'tuple' — sleep(delay, result=None) has one positional-or-keyword parameter with a default (result=None); __defaults__ is a one-element tuple (None,); tuple.__class__.__name__ is 'tuple'; NEW in extra63: first __defaults__.__class__.__name__.__eq__ check for sleep in any asyncio spec; verified with Python 3.14.3"]
    - [queue_init_defaults_class, Queue.__init__.__defaults__.__class__.__name__.__eq__, ["tuple"], true, "Queue.__init__.__defaults__.__class__.__name__ == 'tuple' — Queue(maxsize=0) has one positional-or-keyword parameter with a default (maxsize=0); __defaults__ is a one-element tuple (0,); tuple.__class__.__name__ is 'tuple'; NEW in extra63: first __defaults__.__class__.__name__.__eq__ check for Queue.__init__ in any asyncio spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio function __code__.__class__.__name__ checks — extra63
#
# Wave 229 theme: __code__ checks for function parameters.
#
# gather and sleep are pure-Python coroutine functions. All pure-Python
# functions have a __code__ attribute that is a code object. The type of a
# code object is <class 'code'>, so __class__.__name__ is 'code'.
#
# NEW: no prior asyncio spec has checked __code__.__class__.__name__ via
# __eq__ for gather or sleep.
# ---------------------------------------------------------------------------

table asyncio_extra63.function_code_class_name:
  description: "asyncio function __code__.__class__.__name__.__eq__('code') checks in asynciocode63 namespace — wave 229 theme: __code__ class identity; gather and sleep are pure-Python coroutine functions defined in Lib/asyncio/tasks.py; all pure-Python functions have a __code__ attribute that is a code object; __class__.__name__ of a code object is 'code'; NEW in extra63: no prior asyncio spec has checked __code__.__class__.__name__ via __eq__ for gather or sleep; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asynciocode63c

  columns: [id, function, args, expected, description]
  rows:
    - [gather_code_class, gather.__code__.__class__.__name__.__eq__, ["code"], true, "gather.__code__.__class__.__name__ == 'code' — gather is a pure-Python coroutine function defined in Lib/asyncio/tasks.py; all pure-Python functions have a __code__ attribute that is a code object; the type of a code object is <class 'code'>, so __class__.__name__ is 'code'; NEW in extra63: first __code__.__class__.__name__.__eq__ check for gather in any asyncio spec; verified with Python 3.14.3"]
    - [sleep_code_class,  sleep.__code__.__class__.__name__.__eq__,  ["code"], true, "sleep.__code__.__class__.__name__ == 'code' — sleep is a pure-Python coroutine function defined in Lib/asyncio/tasks.py; its __code__ attribute is a code object with __class__.__name__ == 'code'; NEW in extra63: first __code__.__class__.__name__.__eq__ check for sleep in any asyncio spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra63
# ---------------------------------------------------------------------------

invariant asyncio_extra63.gather_defaults_class_name_eq:
  description: "asyncio.gather.__defaults__.__class__.__name__.__eq__('NoneType') returns True — gather(*coros_or_futures, return_exceptions=False) has no positional-or-keyword parameters with defaults; __defaults__ is the None singleton; None.__class__.__name__ is 'NoneType'; keyword-only default return_exceptions=False goes in __kwdefaults__; NEW in extra63: no prior asyncio spec has checked gather.__defaults__.__class__.__name__ via __eq__; wave 229 first __defaults__ class identity invariant for gather in any asyncio spec; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: gather.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant asyncio_extra63.sleep_defaults_class_name_eq:
  description: "asyncio.sleep.__defaults__.__class__.__name__.__eq__('tuple') returns True — sleep(delay, result=None) has one positional-or-keyword parameter with a default (result=None); __defaults__ is the tuple (None,); tuple.__class__.__name__ is 'tuple'; NEW in extra63: no prior asyncio spec has checked sleep.__defaults__.__class__.__name__ via __eq__; wave 229 invariant alongside gather defaults check; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: sleep.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant asyncio_extra63.queue_init_defaults_class_name_eq:
  description: "asyncio.Queue.__init__.__defaults__.__class__.__name__.__eq__('tuple') returns True — Queue(maxsize=0) has one positional-or-keyword parameter with a default (maxsize=0); __defaults__ is the tuple (0,); tuple.__class__.__name__ is 'tuple'; NEW in extra63: no prior asyncio spec has checked Queue.__init__.__defaults__.__class__.__name__ via __eq__; wave 229 first __defaults__ class identity invariant for Queue.__init__ in any asyncio spec; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: Queue.__init__.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant asyncio_extra63.gather_code_class_name_eq:
  description: "asyncio.gather.__code__.__class__.__name__.__eq__('code') returns True — gather is a pure-Python coroutine function defined in Lib/asyncio/tasks.py; all pure-Python functions have a __code__ attribute that is a code object; the type of a code object is <class 'code'>, so __class__.__name__ is 'code'; NEW in extra63: no prior asyncio spec has checked gather.__code__.__class__.__name__ via __eq__; wave 229 first __code__ class identity invariant for gather in any asyncio spec; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: gather.__code__.__class__.__name__.__eq__
  args: ["code"]
  expected: true

invariant asyncio_extra63.sleep_code_class_name_eq:
  description: "asyncio.sleep.__code__.__class__.__name__.__eq__('code') returns True — sleep is a pure-Python coroutine function defined in Lib/asyncio/tasks.py; its __code__ attribute is a code object with __class__.__name__ == 'code'; NEW in extra63: no prior asyncio spec has checked sleep.__code__.__class__.__name__ via __eq__; wave 229 invariant alongside gather code check; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: sleep.__code__.__class__.__name__.__eq__
  args: ["code"]
  expected: true
