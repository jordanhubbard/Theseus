spec: inspect_extra129
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getfullargspec, inspect.getargvalues, and inspect.getcallargs code object attributes (co_varnames, co_argcount) (Wave 261)."
    - "inspect.getfullargspec.__code__.co_varnames[0] == 'func' — takes a single callable argument. Verified with Python 3.14.3."
    - "inspect.getfullargspec.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "len(inspect.getfullargspec.__code__.co_varnames) == 14 — includes func plus 13 local variables. Verified with Python 3.14.3."
    - "inspect.getargvalues.__code__.co_varnames[0] == 'frame' — takes a frame object. Verified with Python 3.14.3."
    - "inspect.getargvalues.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "len(inspect.getargvalues.__code__.co_varnames) == 4 — frame plus args, varargs, varkw locals. Verified with Python 3.14.3."
    - "inspect.getcallargs.__code__.co_varnames[0] == 'func' — takes a callable as first argument. Verified with Python 3.14.3."
    - "inspect.getcallargs.__code__.co_argcount == 1 — only func is a positional arg (rest are *args/**kwargs). Verified with Python 3.14.3."
    - "len(inspect.getcallargs.__code__.co_varnames) == 25 — func plus many local variables. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getfullargspec code object attributes
#
# Wave 261 theme: inspect.getfullargspec.__code__ attributes.
#
# inspect.getfullargspec.__code__.co_varnames[0].__eq__('func') == True
# inspect.getfullargspec.__code__.co_argcount.__eq__(1) == True
# inspect.getfullargspec.__code__.co_varnames.__len__() == 14
#
# getfullargspec is a pure-Python function in Lib/inspect.py; it takes one
# positional argument 'func'. co_varnames has 14 entries total
# (1 parameter + 13 local variables). New to extra129.
# ---------------------------------------------------------------------------

table inspect_extra129.getfullargspec_code_attrs:
  description: "inspect.getfullargspec.__code__ co_varnames[0]=='func', co_argcount==1, co_varnames len==14; wave 261; new to extra129"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectargspec129

  columns: [id, function, args, expected, description]
  rows:
    - [getfullargspec_co_varnames_0_eq_func,
       "getfullargspec.__code__.co_varnames[0].__eq__",
       ["func"],
       true,
       "inspect.getfullargspec.__code__.co_varnames[0].__eq__('func') == True — getfullargspec is defined in Lib/inspect.py with 'def getfullargspec(func):'; the only positional parameter is 'func' (the callable to inspect); co_varnames[0] is 'func'; str.__eq__('func') returns True; new to extra129"]
    - [getfullargspec_co_argcount_eq_1,
       "getfullargspec.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getfullargspec.__code__.co_argcount.__eq__(1) == True — getfullargspec takes a single positional argument 'func'; co_argcount is 1; int.__eq__(1) returns True; new to extra129"]
    - [getfullargspec_co_varnames_len_eq_14,
       "getfullargspec.__code__.co_varnames.__len__",
       [],
       14,
       "inspect.getfullargspec.__code__.co_varnames.__len__() == 14 — co_varnames contains the parameter 'func' plus 13 local variables (sig, ex, args, varargs, varkw, posonlyargs, kwonlyargs, annotations, defaults, kwdefaults, param, kind, name); total len is 14; new to extra129"]
    - [getfullargspec_co_varnames_class_eq_tuple,
       "getfullargspec.__code__.co_varnames.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "inspect.getfullargspec.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is a tuple of variable name strings; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra129"]
    - [getfullargspec_code_class_eq_code,
       "getfullargspec.__code__.__class__.__name__.__eq__",
       ["code"],
       true,
       "inspect.getfullargspec.__code__.__class__.__name__.__eq__('code') == True — the __code__ attribute of any Python function is a code object; __class__.__name__ is 'code'; str.__eq__('code') returns True; new to extra129"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getargvalues code object attributes
#
# Wave 261 theme: inspect.getargvalues.__code__ attributes.
#
# inspect.getargvalues.__code__.co_varnames[0].__eq__('frame') == True
# inspect.getargvalues.__code__.co_argcount.__eq__(1) == True
# inspect.getargvalues.__code__.co_varnames.__len__() == 4
#
# getargvalues is a pure-Python function in Lib/inspect.py that inspects a
# frame object. It takes one parameter 'frame' and has 3 local variables:
# args, varargs, varkw. Total co_varnames length is 4. New to extra129.
# ---------------------------------------------------------------------------

table inspect_extra129.getargvalues_code_attrs:
  description: "inspect.getargvalues.__code__ co_varnames[0]=='frame', co_argcount==1, co_varnames len==4 (frame + args/varargs/varkw); wave 261; new to extra129"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectargspec129

  columns: [id, function, args, expected, description]
  rows:
    - [getargvalues_co_varnames_0_eq_frame,
       "getargvalues.__code__.co_varnames[0].__eq__",
       ["frame"],
       true,
       "inspect.getargvalues.__code__.co_varnames[0].__eq__('frame') == True — getargvalues is defined in Lib/inspect.py with 'def getargvalues(frame):'; it inspects a frame object to retrieve argument values; co_varnames[0] is 'frame'; str.__eq__('frame') returns True; new to extra129"]
    - [getargvalues_co_argcount_eq_1,
       "getargvalues.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getargvalues.__code__.co_argcount.__eq__(1) == True — getargvalues takes a single positional argument 'frame'; co_argcount is 1; int.__eq__(1) returns True; new to extra129"]
    - [getargvalues_co_varnames_len_eq_4,
       "getargvalues.__code__.co_varnames.__len__",
       [],
       4,
       "inspect.getargvalues.__code__.co_varnames.__len__() == 4 — co_varnames contains exactly 4 entries: 'frame' (parameter) plus 'args', 'varargs', 'varkw' (local variables); len(co_varnames) is 4; new to extra129"]
    - [getargvalues_co_varnames_1_eq_args,
       "getargvalues.__code__.co_varnames[1].__eq__",
       ["args"],
       true,
       "inspect.getargvalues.__code__.co_varnames[1].__eq__('args') == True — the first local variable in getargvalues is 'args', which stores the list of positional argument names; co_varnames[1] is 'args'; str.__eq__('args') returns True; new to extra129"]
    - [getargvalues_code_class_eq_code,
       "getargvalues.__code__.__class__.__name__.__eq__",
       ["code"],
       true,
       "inspect.getargvalues.__code__.__class__.__name__.__eq__('code') == True — the __code__ attribute of any Python function is a code object; __class__.__name__ is 'code'; str.__eq__('code') returns True; new to extra129"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getcallargs code object attributes
#
# Wave 261 theme: inspect.getcallargs.__code__ attributes.
#
# inspect.getcallargs.__code__.co_varnames[0].__eq__('func') == True
# inspect.getcallargs.__code__.co_argcount.__eq__(1) == True
# inspect.getcallargs.__code__.co_varnames.__len__() == 25
#
# getcallargs is a pure-Python function in Lib/inspect.py; its first
# positional parameter is 'func'. The remaining parameters are
# *positional and **named (var-positional/var-keyword). co_argcount
# counts only positional parameters, so it is 1. co_varnames has 25
# entries (func + 24 local variables). New to extra129.
# ---------------------------------------------------------------------------

table inspect_extra129.getcallargs_code_attrs:
  description: "inspect.getcallargs.__code__ co_varnames[0]=='func', co_argcount==1 (only positional param), co_varnames len==25 (func + 24 locals); wave 261; new to extra129"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectargspec129

  columns: [id, function, args, expected, description]
  rows:
    - [getcallargs_co_varnames_0_eq_func,
       "getcallargs.__code__.co_varnames[0].__eq__",
       ["func"],
       true,
       "inspect.getcallargs.__code__.co_varnames[0].__eq__('func') == True — getcallargs is defined in Lib/inspect.py; it binds positional and keyword arguments to parameter names; the first positional parameter is 'func' (the callable whose signature is used); co_varnames[0] is 'func'; str.__eq__('func') returns True; new to extra129"]
    - [getcallargs_co_argcount_eq_1,
       "getcallargs.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getcallargs.__code__.co_argcount.__eq__(1) == True — co_argcount counts only formal positional parameters (not *args or **kwargs); getcallargs has 'func' as its only positional parameter; the remaining arguments are *positional and **named; co_argcount is 1; int.__eq__(1) returns True; new to extra129"]
    - [getcallargs_co_varnames_len_eq_25,
       "getcallargs.__code__.co_varnames.__len__",
       [],
       25,
       "inspect.getcallargs.__code__.co_varnames.__len__() == 25 — co_varnames contains the parameter 'func' plus all local variables used within getcallargs (including spec, args, varargs, varkw, defaults, kwonlyargs, kwonlydefaults, ann, f_name, arg2value, and many others); total len is 25; new to extra129"]
    - [getcallargs_co_varnames_class_eq_tuple,
       "getcallargs.__code__.co_varnames.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "inspect.getcallargs.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is a tuple of variable name strings; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra129"]
    - [getcallargs_code_class_eq_code,
       "getcallargs.__code__.__class__.__name__.__eq__",
       ["code"],
       true,
       "inspect.getcallargs.__code__.__class__.__name__.__eq__('code') == True — the __code__ attribute of any Python function is a code object; __class__.__name__ is 'code'; str.__eq__('code') returns True; new to extra129"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra129
# ---------------------------------------------------------------------------

invariant inspect_extra129.getfullargspec_co_varnames_0:
  description: "inspect.getfullargspec.__code__.co_varnames[0] == 'func' — single callable parameter; wave 261; new to extra129"
  kind: python_call_eq
  function: getfullargspec.__code__.co_varnames[0].__eq__
  args: ["func"]
  expected: true

invariant inspect_extra129.getfullargspec_co_argcount:
  description: "inspect.getfullargspec.__code__.co_argcount == 1 — takes single argument func; wave 261; new to extra129"
  kind: python_call_eq
  function: getfullargspec.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra129.getargvalues_co_varnames_0:
  description: "inspect.getargvalues.__code__.co_varnames[0] == 'frame' — inspects a frame object; wave 261; new to extra129"
  kind: python_call_eq
  function: getargvalues.__code__.co_varnames[0].__eq__
  args: ["frame"]
  expected: true

invariant inspect_extra129.getargvalues_co_varnames_len:
  description: "len(inspect.getargvalues.__code__.co_varnames) == 4 — frame + args/varargs/varkw; wave 261; new to extra129"
  kind: python_call_eq
  function: getargvalues.__code__.co_varnames.__len__
  args: []
  expected: 4

invariant inspect_extra129.getcallargs_co_varnames_0:
  description: "inspect.getcallargs.__code__.co_varnames[0] == 'func' — callable parameter; wave 261; new to extra129"
  kind: python_call_eq
  function: getcallargs.__code__.co_varnames[0].__eq__
  args: ["func"]
  expected: true
