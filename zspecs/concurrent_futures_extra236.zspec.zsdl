invariant concurrent_futures_extra236.ProcessPoolExecutor.shutdown_qualname:
  description: "ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown'; new to extra236"
  category: method_qualnames
  kind: python_call_eq
  function: ProcessPoolExecutor.shutdown.__qualname__.__eq__
  args: ["ProcessPoolExecutor.shutdown"]
