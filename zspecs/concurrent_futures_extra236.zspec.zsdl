spec: concurrent_futures_extra236
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers concurrent.futures.ProcessPoolExecutor class identity and method contracts."
    - "ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' — 19 characters."
    - "ProcessPoolExecutor.__module__ == 'concurrent.futures.process' — 26 characters; defined in process submodule."
    - "ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' — inherits from the Executor abstract base class."
    - "ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' — top-level class."
    - "submit.__qualname__ == 'ProcessPoolExecutor.submit' — 26 characters."
    - "shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' — 28 characters."
    - "map.__qualname__ == 'ProcessPoolExecutor.map' — method defined on the class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: ProcessPoolExecutor class identity contracts
#
# Verifies __name__, __module__, __qualname__, and __bases__[0].__name__ to
# confirm the class is in concurrent.futures.process and extends Executor.
# ---------------------------------------------------------------------------

table concurrent_futures_extra236.ppe_class_identity:
  description: "concurrent.futures.ProcessPoolExecutor class identity: name, module, qualname, base; new to extra236"
  kind: python_call_eq
  category: class_identity
  id_prefix: cf236ppe

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_name_eq,
       ProcessPoolExecutor.__name__.__eq__,
       ["ProcessPoolExecutor"],
       true,
       "ProcessPoolExecutor.__name__.__eq__('ProcessPoolExecutor') == True — class carries its unqualified name; new to extra236"]
    - [ppe_module_eq,
       ProcessPoolExecutor.__module__.__eq__,
       ["concurrent.futures.process"],
       true,
       "ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process') == True — defined in process submodule; new to extra236"]
    - [ppe_qualname_eq,
       ProcessPoolExecutor.__qualname__.__eq__,
       ["ProcessPoolExecutor"],
       true,
       "ProcessPoolExecutor.__qualname__.__eq__('ProcessPoolExecutor') == True — top-level class; qualname equals __name__; new to extra236"]
    - [ppe_base_name_eq,
       "ProcessPoolExecutor.__bases__[0].__name__.__eq__",
       ["Executor"],
       true,
       "ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor') == True — direct base is the Executor ABC; new to extra236"]
    - [ppe_name_len_19,
       ProcessPoolExecutor.__name__.__len__,
       [],
       19,
       "ProcessPoolExecutor.__name__.__len__() == 19 — 'ProcessPoolExecutor' has exactly 19 characters; new to extra236"]

# ---------------------------------------------------------------------------
# Table 2: ProcessPoolExecutor module length and base class module contracts
#
# Extra identity checks: module string length is 26; base class Executor is
# in concurrent.futures._base.
# ---------------------------------------------------------------------------

table concurrent_futures_extra236.ppe_module_contracts:
  description: "concurrent.futures.ProcessPoolExecutor module and base class identity; new to extra236"
  kind: python_call_eq
  category: class_identity
  id_prefix: cf236ppe

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_module_len_26,
       ProcessPoolExecutor.__module__.__len__,
       [],
       26,
       "ProcessPoolExecutor.__module__.__len__() == 26 — 'concurrent.futures.process' has 26 characters; new to extra236"]
    - [ppe_base_module_eq,
       "ProcessPoolExecutor.__bases__[0].__module__.__eq__",
       ["concurrent.futures._base"],
       true,
       "ProcessPoolExecutor.__bases__[0].__module__ == 'concurrent.futures._base' — Executor lives in _base; new to extra236"]

# ---------------------------------------------------------------------------
# Table 3: ProcessPoolExecutor method __qualname__ contracts
#
# submit, shutdown, and map are the key methods; qualnames follow the pattern
# 'ProcessPoolExecutor.<method>'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra236.ppe_method_qualnames:
  description: "concurrent.futures.ProcessPoolExecutor method __qualname__ contracts; new to extra236"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: cf236ppem

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_submit_qualname_eq,
       ProcessPoolExecutor.submit.__qualname__.__eq__,
       ["ProcessPoolExecutor.submit"],
       true,
       "ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit' (len=26); new to extra236"]
    - [ppe_shutdown_qualname_eq,
       ProcessPoolExecutor.shutdown.__qualname__.__eq__,
       ["ProcessPoolExecutor.shutdown"],
       true,
       "ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' (len=28); new to extra236"]
    - [ppe_map_qualname_eq,
       ProcessPoolExecutor.map.__qualname__.__eq__,
       ["ProcessPoolExecutor.map"],
       true,
       "ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map'; new to extra236"]
    - [ppe_submit_name_eq,
       ProcessPoolExecutor.submit.__name__.__eq__,
       ["submit"],
       true,
       "ProcessPoolExecutor.submit.__name__ == 'submit'; new to extra236"]
    - [ppe_shutdown_name_eq,
       ProcessPoolExecutor.shutdown.__name__.__eq__,
       ["shutdown"],
       true,
       "ProcessPoolExecutor.shutdown.__name__ == 'shutdown'; new to extra236"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra236
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra236.ProcessPoolExecutor.name:
  description: "ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor'; new to extra236"
  category: class_identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__name__.__eq__
  args: ["ProcessPoolExecutor"]
  expected: true

invariant concurrent_futures_extra236.ProcessPoolExecutor.module:
  description: "ProcessPoolExecutor.__module__ == 'concurrent.futures.process'; new to extra236"
  category: class_identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.process"]
  expected: true

invariant concurrent_futures_extra236.ProcessPoolExecutor.base_name:
  description: "ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' — inherits from Executor ABC; new to extra236"
  category: class_identity
  kind: python_call_eq
  function: "ProcessPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra236.ProcessPoolExecutor.module_len:
  description: "ProcessPoolExecutor.__module__.__len__() == 26; new to extra236"
  category: class_identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__module__.__len__
  args: []
