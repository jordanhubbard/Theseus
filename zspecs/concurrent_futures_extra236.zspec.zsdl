invariant concurrent_futures_extra236.ProcessPoolExecutor.submit_name:
  description: "ProcessPoolExecutor.submit.__name__ == 'submit'; new to extra236"
  category: method_names
  kind: python_call_eq
  function: ProcessPoolExecutor.submit.__name__.__eq__
  args: ["submit"]
