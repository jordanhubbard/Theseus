spec: mp3511
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 681 (mp3511): __get__, __set__, __delete__ dict-presence checks for multiprocessing types."
    - "All values false — multiprocessing types do not implement the descriptor protocol."
    - "multiprocessing.pool.Pool defines __enter__/__exit__ (true in prior waves) but NOT __get__/__set__/__delete__."
    - "None of the multiprocessing types define __get__, __set__, or __delete__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
# ---------------------------------------------------------------------------

table mp3511.get:
  description: "multiprocessing types __get__ dict-presence checks; wave 681"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3511
  columns: [id, function, args, expected]
  rows:
    - ["mp3511001", operator.contains, [multiprocessing.Process.__dict__,                 "__get__"], false]
    - ["mp3511002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__get__"], false]
    - ["mp3511003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__get__"], false]
    - ["mp3511004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__get__"], false]
    - ["mp3511005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__get__"], false]

