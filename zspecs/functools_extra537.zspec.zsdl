spec: functools_extra537
version: ">=3.9"
backend: python_module(functools)
docs: "Cover functools.singledispatch, singledispatchmethod, and cached_property method identity"
provenance:
  derived_from:
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"
error_model: exception_is_failure

table functools_extra537.singledispatch_identity:
  description: "singledispatch and singledispatchmethod identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: fce

  columns: [id, function, args, expected]
  rows:
    - [fce001, functools.singledispatch.__name__.__eq__, ["singledispatch"], true]
    - [fce002, functools.singledispatch.__qualname__.__eq__, ["singledispatch"], true]
    - [fce003, functools.singledispatch.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [fce004, functools.singledispatchmethod.__name__.__eq__, ["singledispatchmethod"], true]
    - [fce005, functools.singledispatchmethod.__module__.__eq__, ["functools"], true]
    - [fce006, "functools.singledispatchmethod.__bases__[0].__name__.__eq__", ["object"], true]

table functools_extra537.cached_property_methods:
  description: "cached_property dunder method name identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: fcp

  columns: [id, function, args, expected]
  rows:
    - [fcp001, functools.cached_property.__init__.__name__.__eq__, ["__init__"], true]
    - [fcp002, functools.cached_property.__set_name__.__name__.__eq__, ["__set_name__"], true]
    - [fcp003, functools.cached_property.__get__.__name__.__eq__, ["__get__"], true]
    - [fcp004, functools.cached_property.__set__.__name__.__eq__, ["__set__"], true]
