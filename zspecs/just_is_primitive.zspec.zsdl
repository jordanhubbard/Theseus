spec: just_is_primitive
version: ">=2.3.0"
backend: node(just-is-primitive)

docs: https://www.npmjs.com/package/just-is-primitive

provenance:
  derived_from:
    - "just-is-primitive README — https://www.npmjs.com/package/just-is-primitive"
    - "Test vectors verified with just-is-primitive via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-is-primitive source"
  notes:
    - "just-is-primitive is an npm package. Install: npm install just-is-primitive"
    - "The module exports a single function that returns true for primitives (number, string, boolean, null)."
    - "Objects and arrays return false."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_is_primitive.isPrimitive:
  kind: node_module_call_eq
  function: ~
  category: predicate
  id_prefix: jisprim

  columns: [id, args, expected]
  rows:
    - [number,  [5],          true]
    - [string,  ["hi"],       true]
    - [null,    [null],       true]
    - [object,  [{"a": 1}],  false]
    - [array,   [[1, 2, 3]], false]
