spec: socket_extra1786
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python socket documentation — https://docs.python.org/3/library/socket.html"
    - "RFC 793 — Transmission Control Protocol"
    - "RFC 768 — User Datagram Protocol"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "socket.zspec.zsdl — covers AF_INET/SOCK_STREAM constants, inet_aton, htonl"
    - "socket_extra.zspec.zsdl — covers additional constant and function checks"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra1771.zspec.zsdl — covers async protocol dict-presence checks for socket.socket (__aenter__/__aexit__/__aiter__/__anext__/__await__ all False) and complementary checks (settimeout, gettimeout, setblocking, makefile, __enter__, __exit__, detach, get_inheritable)."
  notes:
    - "Wave 566 (_extra1786): __class_getitem__ and __init_subclass__ class creation hooks dict-presence checks."
    - "Theme: which socket stdlib types define __class_getitem__ and __init_subclass__ in their own __dict__."
    - "socket.socket: the Python-level wrapper class around the C _socket.socket type. It is not a generic type (socket.socket[T] is not meaningful) -> __class_getitem__ False."
    - "socket.SocketType: an alias for socket.socket in CPython; it is the same class object -> same dict -> __class_getitem__ False."
    - "__init_subclass__ is a classmethod added by the type machinery; socket.socket does not redefine it in its own __dict__ -> False."
    - "socket.socket.__dict__.__contains__('__class_getitem__') -> False — socket is not a generic type; generic-alias syntax is not supported."
    - "socket.socket.__dict__.__contains__('__init_subclass__') -> False — socket.socket does not redefine __init_subclass__; inherited from object."
    - "socket.socket.__dict__.__contains__('__weakref__') -> False — socket.socket is a Python class but does not have __weakref__ in its own __dict__ because it inherits from the C-level _socket.socket base which controls the weak reference slot."
    - "socket.socket.__dict__.__contains__('__enter__') -> True — socket.socket defines a synchronous context manager (__enter__/__exit__) in its own __dict__."
    - "socket.socket.__dict__.__contains__('__exit__') -> True — socket.socket defines __exit__ as part of the synchronous context manager protocol."
    - "socket.socket.__module__.__eq__('socket') -> True — socket.socket is defined in the socket Python wrapper module."
    - "socket.AF_INET.__class__.__name__ -> 'AddressFamily' — AF_INET is an IntEnum member from socket.AddressFamily."
    - "socket.SOCK_STREAM.__class__.__name__ -> 'SocketKind' — SOCK_STREAM is an IntEnum member from socket.SocketKind."
    - "All expected values verified by running Python 3.14 socket module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __class_getitem__ and __init_subclass__ dict-presence checks
#          for socket.socket
#
# Wave 566 theme: which socket types define __class_getitem__ and
# __init_subclass__ in their own __dict__.
#
# socket.socket: the Python-level socket wrapper. It wraps _socket.socket
# (C base class) and adds Python-level methods. It is not a generic type
# and does not redefine __init_subclass__ -> both checks return False.
# ---------------------------------------------------------------------------

table socket_extra1786.class_creation_hooks:
  description: "socket.socket __class_getitem__ and __init_subclass__ dict-presence checks — all False — wave 566 _extra1786"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1786

  columns: [id, function, args, expected]
  rows:
    - ["sk1786001", "socket.socket.__dict__.__contains__", ["__class_getitem__"],  false]
    - ["sk1786002", "socket.socket.__dict__.__contains__", ["__init_subclass__"],  false]

# ---------------------------------------------------------------------------
# Table 2: complementary checks for socket.socket and module-level names
#
# The class-creation-hooks theme is all-False for socket.socket.
# Complementary checks confirm genuine socket-specific structural properties:
# - socket.socket defines context-manager dunders in its own __dict__
# - socket.socket does NOT have __weakref__ in its own __dict__
# - socket.socket defines Python-wrapper methods (settimeout, gettimeout, etc.)
# - AF_INET and SOCK_STREAM are enum members (not plain int)
# - socket.socket.__name__ and __module__ identity
# - socket.socket.__bases__[0].__name__ -> '_socket.socket' base class name
# - socket.AF_INET.__class__.__name__.__eq__('AddressFamily') -> True
# - socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind') -> True
# - socket.socket.__dict__.__contains__('detach') -> True
# - socket.socket.__dict__.__contains__('get_inheritable') -> True
# - socket.socket.__dict__.__contains__('setblocking') -> True
# - socket.socket.__dict__.__contains__('makefile') -> True
# - socket.socket.__dict__.__contains__('send') -> False (inherited from C base)
# ---------------------------------------------------------------------------

table socket_extra1786.complementary_checks:
  description: "socket.socket class creation hooks absent; context-manager and Python-wrapper attribute presence checks — wave 566 _extra1786"
  kind: python_call_eq
  category: complementary
  id_prefix: sk1786

  columns: [id, function, args, expected]
  rows:
    - ["sk1786003", "socket.socket.__dict__.__contains__", ["__enter__"],               true]
    - ["sk1786004", "socket.socket.__dict__.__contains__", ["__exit__"],                true]
    - ["sk1786005", "socket.socket.__dict__.__contains__", ["__weakref__"],             false]
    - ["sk1786006", "socket.socket.__dict__.__contains__", ["settimeout"],              true]
    - ["sk1786007", "socket.socket.__dict__.__contains__", ["gettimeout"],              true]
    - ["sk1786008", "socket.socket.__dict__.__contains__", ["setblocking"],             true]
    - ["sk1786009", "socket.socket.__dict__.__contains__", ["makefile"],                true]
    - ["sk1786010", "socket.socket.__dict__.__contains__", ["detach"],                  true]
    - ["sk1786011", "socket.socket.__dict__.__contains__", ["get_inheritable"],         true]
    - ["sk1786012", "socket.socket.__dict__.__contains__", ["send"],                    false]
    - ["sk1786013", "socket.socket.__name__.__eq__",        ["socket"],                 true]
    - ["sk1786014", "socket.socket.__module__.__eq__",      ["socket"],                 true]
    - ["sk1786015", "socket.AF_INET.__class__.__name__.__eq__",    ["AddressFamily"],   true]
    - ["sk1786016", "socket.SOCK_STREAM.__class__.__name__.__eq__", ["SocketKind"],     true]
    - ["sk1786017", "socket.AF_INET.__eq__",                [2],                        true]
    - ["sk1786018", "socket.SOCK_STREAM.__eq__",            [1],                        true]
    - ["sk1786019", "socket.socket.__dict__.__contains__", ["fileno"],                  false]
    - ["sk1786020", "socket.socket.__dict__.__contains__", ["accept"],                  false]
    - ["sk1786021", "socket.socket.__dict__.__contains__", ["bind"],                    false]
    - ["sk1786022", "socket.socket.__dict__.__contains__", ["connect"],                 false]
    - ["sk1786023", "socket.socket.__dict__.__contains__", ["recv"],                    false]
