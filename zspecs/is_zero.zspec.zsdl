spec: is_zero
version: ">=1.0.0"
backend: node(is-zero)

docs: https://www.npmjs.com/package/is-zero

provenance:
  derived_from:
    - "is-zero README — https://www.npmjs.com/package/is-zero"
    - "Test vectors verified with is-zero via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-zero source"
  notes:
    - "is-zero is an npm package. Install: npm install is-zero"
    - "isZero returns true if the number is exactly zero (positive or negative zero)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_zero.isZero:
  kind: node_module_call_eq
  function: isZero
  category: math
  id_prefix: iszero

  columns: [id, args, expected]
  rows:
    - [zero,      [0],   true]
    - [one,       [1],   false]
    - [negative,  [-5],  false]
