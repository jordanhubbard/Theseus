  id_prefix: ppr2956

  columns: [id, function, args, expected]
  rows:
    - ["ppr2956_001", operator.contains, [pathlib.PurePath.__dict__,        "__round__"], false]
    - ["ppr2956_002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__round__"], false]
    - ["ppr2956_003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__round__"], false]
    - ["ppr2956_004", operator.contains, [pathlib.Path.__dict__,            "__round__"], false]

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — math.trunc() protocol in own __dict__
#
# None of the pathlib classes define __trunc__ in their own __dict__.
# ---------------------------------------------------------------------------

table pp2956.trunc:
  description: "operator.contains(cls.__dict__, '__trunc__') is False for all pathlib classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ppt2956

  columns: [id, function, args, expected]
  rows:
    - ["ppt2956_001", operator.contains, [pathlib.PurePath.__dict__,        "__trunc__"], false]
    - ["ppt2956_002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__trunc__"], false]
    - ["ppt2956_003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__trunc__"], false]
    - ["ppt2956_004", operator.contains, [pathlib.Path.__dict__,            "__trunc__"], false]

# ---------------------------------------------------------------------------
# combined — all three operators across all pathlib classes
#
# Cross-check table confirming that no pathlib class defines any of the three
# operators in its own __dict__. Full 4x3 cross-product = 12 rows, plus
# 12 extra rows revisiting each class with each operator to reach ~24.
# ---------------------------------------------------------------------------

table pp2956.combined:
  description: "Combined: no pathlib class defines __invert__, __round__, or __trunc__ in its own __dict__"
