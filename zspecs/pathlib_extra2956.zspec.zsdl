spec: pp2956
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib class __dict__ bitwise invert / round / trunc presence"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib.py, Lib/pathlib/_local.py"
  notes:
    - "pathlib classes are filesystem path types; they do not define __invert__, __round__, or __trunc__."
    - "operator.contains(cls.__dict__, '__invert__') is False for all pathlib classes — paths are not numeric."
    - "operator.contains(cls.__dict__, '__round__') is False for all pathlib classes."
    - "operator.contains(cls.__dict__, '__trunc__') is False for all pathlib classes."
    - "PurePath, PurePosixPath, PureWindowsPath are pure (no I/O) path types."
    - "Path is the concrete I/O path type; also defines none of these operators."
    - "All values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __invert__ dict-presence — bitwise invert operator in own __dict__
#
# None of the pathlib classes define __invert__ in their own __dict__.
# These are filesystem path abstractions, not numeric types.
# ---------------------------------------------------------------------------

table pp2956.invert:
  description: "operator.contains(cls.__dict__, '__invert__') is False for all pathlib classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ppi2956

  columns: [id, function, args, expected]
  rows:
    - ["ppi2956_001", operator.contains, [pathlib.PurePath.__dict__,        "__invert__"], false]
    - ["ppi2956_002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__invert__"], false]
    - ["ppi2956_003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__invert__"], false]
    - ["ppi2956_004", operator.contains, [pathlib.Path.__dict__,            "__invert__"], false]

# ---------------------------------------------------------------------------
# __round__ dict-presence — round() protocol in own __dict__
#
# None of the pathlib classes define __round__ in their own __dict__.
# ---------------------------------------------------------------------------

table pp2956.round:
  description: "operator.contains(cls.__dict__, '__round__') is False for all pathlib classes"
  kind: python_call_eq
