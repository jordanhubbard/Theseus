spec: ofetch
version: ">=1.0.0"
backend: node(ofetch)

docs: https://github.com/unjs/ofetch#readme

provenance:
  derived_from:
    - "ofetch README — https://github.com/unjs/ofetch#readme"
    - "Test vectors verified with ofetch via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "ofetch source"
  notes:
    - "Better fetch API for Node — auto-JSON / retries / typed errors."
    - "Install: npm install ofetch"
    - "v1 ESM only; named exports ofetch / \\$fetch (alias) / FetchError."
    - "Spec covers shape only — actual HTTP requires network access."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "FetchError thrown on non-2xx responses by default; .data carries parsed body."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes:
    FetchError: "Wraps an HTTP error response with .status, .data, .response"

invariant ofetch.has_ofetch:
  description: "Module exports ofetch as an async function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "ofetch.constructor.name"}
  expected: "AsyncFunction"

invariant ofetch.has_dollar_fetch_alias:
  description: "Module exports \\$fetch alias (async function)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "$fetch.constructor.name"}
  expected: "AsyncFunction"

invariant ofetch.has_FetchError:
  description: "FetchError exported as a class"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "FetchError.constructor.name"}
  expected: "Function"

invariant ofetch.FetchError_message:
  description: "new FetchError('test').message preserves message"
  category: FetchError
  kind: node_chain_eq
  entry: constructor
  class: FetchError
  entry_args: ["test"]
  chain:
    - {get: message}
  expected: "test"

invariant ofetch.FetchError_name:
  description: "new FetchError().name is 'FetchError'"
  category: FetchError
  kind: node_chain_eq
  entry: constructor
  class: FetchError
  entry_args: ["x"]
  chain:
    - {get: name}
  expected: "FetchError"

invariant ofetch.FetchError_constructor_name:
  description: "FetchError instance constructor name"
  category: FetchError
  kind: node_chain_eq
  entry: constructor
  class: FetchError
  entry_args: ["x"]
  chain:
    - {get: "constructor.name"}
  expected: "FetchError"

invariant ofetch.has_createFetch:
  description: "createFetch() factory is exported (for instances with custom defaults)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "createFetch.constructor.name"}
  expected: "Function"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:15:47Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
