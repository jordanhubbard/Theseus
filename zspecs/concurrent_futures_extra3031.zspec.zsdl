    - ["cf3031006", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__init_subclass__"], false]
    - ["cf3031007", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__init_subclass__"], false]
    - ["cf3031008", operator.contains, [concurrent.futures.Executor.__dict__,            "__init_subclass__"], false]

# ---------------------------------------------------------------------------
# __class_getitem__ dict-presence — operator.contains(Cls.__dict__, '__class_getitem__')
#
# concurrent.futures.Future defines __class_getitem__ (true) — it supports
# Future[T] generic annotation syntax.
# ThreadPoolExecutor, ProcessPoolExecutor, and Executor do not define it
# in their own __dict__; all return false.
# ---------------------------------------------------------------------------

table cf3031.class_getitem:
  description: "concurrent.futures types __class_getitem__ dict-presence checks; wave 649"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3031

  columns: [id, function, args, expected]
  rows:
    - ["cf3031009", operator.contains, [concurrent.futures.Future.__dict__,              "__class_getitem__"], true]
    - ["cf3031010", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__class_getitem__"], false]
    - ["cf3031011", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__class_getitem__"], false]
    - ["cf3031012", operator.contains, [concurrent.futures.Executor.__dict__,            "__class_getitem__"], false]

