spec: cf3031
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 649 (cf3031): __missing__, __init_subclass__, __class_getitem__ dict-presence for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Key finding: concurrent.futures.Future defines __class_getitem__ (true) — supports Future[T] generic annotation syntax."
    - "ThreadPoolExecutor, ProcessPoolExecutor, and Executor do not define __class_getitem__ in their own __dict__."
    - "No concurrent.futures class defines __missing__ (none are dict subclasses) or __init_subclass__."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __missing__ dict-presence — operator.contains(Cls.__dict__, '__missing__')
#
# No concurrent.futures class defines __missing__; all results are false.
# None of these classes subclass dict or implement the missing-key protocol.
# ---------------------------------------------------------------------------

table cf3031.missing:
  description: "concurrent.futures types __missing__ dict-presence checks; wave 649"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3031

  columns: [id, function, args, expected]
  rows:
    - ["cf3031001", operator.contains, [concurrent.futures.Future.__dict__,              "__missing__"], false]
    - ["cf3031002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__missing__"], false]
    - ["cf3031003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__missing__"], false]
    - ["cf3031004", operator.contains, [concurrent.futures.Executor.__dict__,            "__missing__"], false]

# ---------------------------------------------------------------------------
