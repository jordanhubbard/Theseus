spec: re_extra631
version: ">=3.9"
backend: python_module(re)
docs: "Behavioral spec for re.Pattern and re.Match property descriptors and module identity"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re.Pattern and re.Match attributes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.Pattern and re.Match attributes are exposed as getset_descriptor objects at the class level"
    - "__module__ confirms these types belong to the re namespace"
  created_at: "2026-04-12T00:00:00Z"

table re_extra631.pattern_descriptors:
  description: "Descriptor type checks for re.Pattern attributes"
  kind: python_call_eq
  category: descriptors
  id_prefix: re631pt
  columns: [id, function, args, expected]
  rows:
    - [re631pt001, re.Pattern.pattern.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [re631pt002, re.Pattern.flags.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [re631pt003, re.Pattern.groups.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [re631pt004, re.Pattern.groupindex.__class__.__name__.__eq__, ["getset_descriptor"], true]

table re_extra631.match_descriptors:
  description: "Descriptor type checks for re.Match attributes"
  kind: python_call_eq
  category: descriptors
  id_prefix: re631mt
  columns: [id, function, args, expected]
  rows:
    - [re631mt001, re.Match.string.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [re631mt002, re.Match.re.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [re631mt003, re.Match.pos.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [re631mt004, re.Match.endpos.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [re631mt005, re.Match.lastindex.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [re631mt006, re.Match.lastgroup.__class__.__name__.__eq__, ["getset_descriptor"], true]

table re_extra631.module_identity:
  description: "Module identity checks for re.Pattern and re.Match types"
  kind: python_call_eq
  category: module_identity
  id_prefix: re631md
  columns: [id, function, args, expected]
  rows:
    - [re631md001, re.Pattern.__module__.__eq__, ["re"], true]
    - [re631md002, re.Match.__module__.__eq__, ["re"], true]
