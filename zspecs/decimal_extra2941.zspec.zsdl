spec: dc2941
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal class __dict__ unary operator presence"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "decimal.Decimal is a full numeric type and defines __neg__, __pos__, __abs__ in its own __dict__."
    - "operator.contains(decimal.Decimal.__dict__, '__neg__') is True — Decimal owns this method."
    - "operator.contains(decimal.Decimal.__dict__, '__pos__') is True — Decimal owns this method."
    - "operator.contains(decimal.Decimal.__dict__, '__abs__') is True — Decimal owns this method."
    - "decimal.Context is a configuration object, not a numeric type; it defines none of these operators."
    - "DecimalException and all its subclasses are exception types derived from ArithmeticError; none define unary numeric operators."
    - "Subclasses verified: InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded, Subnormal, FloatOperation, Clamped, ConversionSyntax, DivisionImpossible, DivisionUndefined."
    - "All values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __neg__ dict-presence — unary negation operator in own __dict__
#
# decimal.Decimal defines __neg__ directly in its own __dict__ (True).
# Context and all exception subclasses do not (False).
# ---------------------------------------------------------------------------

table dc2941.neg:
  description: "operator.contains(cls.__dict__, '__neg__'): True for Decimal, False for all others"
  kind: python_call_eq
  category: dict_presence
  id_prefix: dcn2941

  columns: [id, function, args, expected]
  rows:
    - ["dcn2941_001", operator.contains, [decimal.Decimal.__dict__,           "__neg__"], true]
    - ["dcn2941_002", operator.contains, [decimal.Context.__dict__,           "__neg__"], false]
    - ["dcn2941_003", operator.contains, [decimal.DecimalException.__dict__,  "__neg__"], false]
    - ["dcn2941_004", operator.contains, [decimal.InvalidOperation.__dict__,  "__neg__"], false]
    - ["dcn2941_005", operator.contains, [decimal.DivisionByZero.__dict__,    "__neg__"], false]
    - ["dcn2941_006", operator.contains, [decimal.Overflow.__dict__,          "__neg__"], false]
    - ["dcn2941_007", operator.contains, [decimal.Underflow.__dict__,         "__neg__"], false]
    - ["dcn2941_008", operator.contains, [decimal.Inexact.__dict__,           "__neg__"], false]
    - ["dcn2941_009", operator.contains, [decimal.Rounded.__dict__,           "__neg__"], false]
    - ["dcn2941_010", operator.contains, [decimal.Subnormal.__dict__,         "__neg__"], false]
    - ["dcn2941_011", operator.contains, [decimal.FloatOperation.__dict__,    "__neg__"], false]
    - ["dcn2941_012", operator.contains, [decimal.Clamped.__dict__,           "__neg__"], false]

