# ---------------------------------------------------------------------------
# combined — full cross-product for Decimal (True) and key non-numeric types
#
# Decimal owns all three; Context and DecimalException own none.
# This table focuses on the contrasting True/False split.
# ---------------------------------------------------------------------------

table dc2941.combined:
  description: "Combined: Decimal owns __neg__/__pos__/__abs__; Context and exception types do not"
  kind: python_call_eq
  category: dict_presence
  id_prefix: dcx2941

  columns: [id, function, args, expected]
  rows:
    - ["dcx2941_001", operator.contains, [decimal.Decimal.__dict__,           "__neg__"], true]
    - ["dcx2941_002", operator.contains, [decimal.Decimal.__dict__,           "__pos__"], true]
    - ["dcx2941_003", operator.contains, [decimal.Decimal.__dict__,           "__abs__"], true]
    - ["dcx2941_004", operator.contains, [decimal.Context.__dict__,           "__neg__"], false]
    - ["dcx2941_005", operator.contains, [decimal.Context.__dict__,           "__pos__"], false]
    - ["dcx2941_006", operator.contains, [decimal.Context.__dict__,           "__abs__"], false]
    - ["dcx2941_007", operator.contains, [decimal.DecimalException.__dict__,  "__neg__"], false]
