spec: functools_extra1921
version: ">=3.9"
backend: python_module(functools)

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 575 (_extra1921): __slots__ inheritance checks, __abstractmethods__ set membership, __subclasshook__ dict presence, __init_subclass__ dict presence."
    - "functools.partial is a C-level type; its __dict__ does not contain __slots__, __abstractmethods__, __subclasshook__, or __init_subclass__."
    - "functools.partialmethod is a Python class; its __dict__ does not contain __slots__, __abstractmethods__, __subclasshook__, or __init_subclass__."
    - "functools.cached_property is a Python class; its __dict__ does not contain __slots__, __abstractmethods__, __subclasshook__, or __init_subclass__."
    - "functools._lru_cache_wrapper is a C-level type; its __dict__ does not contain __slots__, __abstractmethods__, __subclasshook__, or __init_subclass__."
    - "functools.singledispatchmethod is a Python class; its __dict__ does not contain __slots__, __abstractmethods__, __subclasshook__, or __init_subclass__."
    - "functools._CacheInfo is a namedtuple subclass; its __dict__ contains __slots__ (empty tuple from NamedTuple metaclass)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table functools_extra1921.slots_protocol:
  description: "functools types __slots__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft1921

  columns: [id, function, args, expected]
  rows:
    - ["ft1921001", "functools.partial.__dict__.__contains__", ["__slots__"], false]
    - ["ft1921002", "functools.partialmethod.__dict__.__contains__", ["__slots__"], false]
    - ["ft1921003", "functools.cached_property.__dict__.__contains__", ["__slots__"], false]
    - ["ft1921004", "functools._lru_cache_wrapper.__dict__.__contains__", ["__slots__"], false]
    - ["ft1921005", "functools.singledispatchmethod.__dict__.__contains__", ["__slots__"], false]
    - ["ft1921006", "functools._CacheInfo.__dict__.__contains__", ["__slots__"], true]
    - ["ft1921007", "functools.partial.__dict__.__contains__", ["__dict__"], true]
    - ["ft1921008", "functools._lru_cache_wrapper.__dict__.__contains__", ["__dict__"], true]

