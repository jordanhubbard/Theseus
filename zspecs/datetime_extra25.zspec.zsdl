spec: datetime_extra25
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
    - "datetime_extra21.zspec.zsdl — covers __module__.__len__() and __name__.__len__() for date/time/datetime/timedelta/timezone; date.today.__qualname__.__len__() and datetime.now.__qualname__.__len__()"
    - "datetime_extra22.zspec.zsdl — covers __qualname__.__len__() for date/time/datetime/timedelta/timezone/tzinfo; __module__.__len__() and __name__.__len__() for tzinfo; __qualname__.__len__() for datetime.fromisoformat/datetime.strptime/date.fromisoformat/timedelta.__repr__"
    - "datetime_extra23.zspec.zsdl — covers __mro__.__len__() for datetime/date/timedelta/timezone/tzinfo; __bases__[0].__name__ for datetime/timezone/date/timedelta/tzinfo; __qualname__.__len__() for datetime.utcnow/combine/isoformat and date.isoformat"
    - "datetime_extra24.zspec.zsdl — covers __all__.__len__()==9; __all__.__class__.__name__.__len__()==5; __dict__.__class__.__name__.__len__()==12 for date/datetime/timedelta/timezone/tzinfo; __reduce__.__name__.__len__()==10 for date/datetime/timedelta/timezone; __init_subclass__.__qualname__.__len__() for all five main classes; MINYEAR/MAXYEAR __class__.__name__.__len__()==3"
  notes:
    - "This spec extends datetime_extra24.zspec.zsdl."
    - "Prior specs covered: date/time/datetime/timedelta/timezone/tzinfo __name__/__module__/__qualname__, __mro__.__len__(), __bases__[0].__name__, __dict__.__class__.__name__.__len__()==12 for all five main classes, __reduce__.__name__.__len__()==10 for date/datetime/timedelta/timezone, __init_subclass__.__qualname__.__len__() for all five, MINYEAR/MAXYEAR class names, key method qualname lengths."
    - "This spec covers: datetime.time class — __dict__.__class__.__name__.__len__()==12; __mro__.__len__()==2; __bases__[0].__name__.__len__()==6; time.fromisoformat.__qualname__.__len__()==18; time.isoformat.__qualname__.__len__()==14. datetime.datetime class — __bases__[0].__name__.__len__()==4 ('date'); __mro__.__len__()==3; datetime.fromtimestamp.__qualname__.__len__()==22; datetime.fromisoformat.__qualname__.__len__()==22; datetime.now.__qualname__.__len__()==12; datetime.utcnow.__qualname__.__len__()==15. datetime.date class — date.today.__qualname__.__len__()==10; date.fromtimestamp.__qualname__.__len__()==18; date.fromisoformat.__qualname__.__len__()==18; date.replace.__qualname__.__len__()==12. datetime.timedelta — timedelta.total_seconds.__qualname__.__len__()==23; timedelta.__mro__.__len__()==2; timedelta.__bases__[0].__name__.__len__()==6. datetime.timezone — timezone.__bases__[0].__name__.__len__()==6 ('tzinfo'); timezone.__mro__.__len__()==3."
    - "datetime.time.__dict__.__class__.__name__ == 'mappingproxy' — len 12. Verified Python 3.12."
    - "datetime.time.__mro__ == [time, object] — len 2. Verified Python 3.12."
    - "datetime.time.__bases__[0].__name__ == 'object' — len 6. Verified Python 3.12."
    - "datetime.time.fromisoformat.__qualname__ == 'time.fromisoformat' — len 18. Verified Python 3.12."
    - "datetime.time.isoformat.__qualname__ == 'time.isoformat' — len 14. Verified Python 3.12."
    - "datetime.datetime.__bases__[0].__name__ == 'date' — len 4. Verified Python 3.12."
    - "datetime.datetime.__mro__ == [datetime, date, object] — len 3. Verified Python 3.12."
    - "datetime.datetime.fromtimestamp.__qualname__ == 'datetime.fromtimestamp' — len 22. Verified Python 3.12."
    - "datetime.datetime.fromisoformat.__qualname__ == 'datetime.fromisoformat' — len 22. Verified Python 3.12."
    - "datetime.datetime.now.__qualname__ == 'datetime.now' — len 12. Verified Python 3.12."
    - "datetime.datetime.utcnow.__qualname__ == 'datetime.utcnow' — len 15. Verified Python 3.12."
    - "datetime.date.today.__qualname__ == 'date.today' — len 10. Verified Python 3.12."
    - "datetime.date.fromtimestamp.__qualname__ == 'date.fromtimestamp' — len 18. Verified Python 3.12."
    - "datetime.date.fromisoformat.__qualname__ == 'date.fromisoformat' — len 18. Verified Python 3.12."
    - "datetime.date.replace.__qualname__ == 'date.replace' — len 12. Verified Python 3.12."
    - "datetime.timedelta.total_seconds.__qualname__ == 'timedelta.total_seconds' — len 23. Verified Python 3.12."
    - "datetime.timedelta.__mro__ == [timedelta, object] — len 2. Verified Python 3.12."
    - "datetime.timedelta.__bases__[0].__name__ == 'object' — len 6. Verified Python 3.12."
    - "datetime.timezone.__bases__[0].__name__ == 'tzinfo' — len 6. Verified Python 3.12."
    - "datetime.timezone.__mro__ == [timezone, tzinfo, object] — len 3. Verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# datetime.time class introspection
#
# datetime.time is a top-level class (not datetime.datetime.time).
# Prior specs covered date/datetime/timedelta/timezone/tzinfo but NOT time.
# time.__dict__.__class__.__name__ == 'mappingproxy' (len 12), exactly like
# the other datetime classes. time.__mro__ == [time, object] (len 2) and its
# sole base is 'object' (len 6).
# No prior datetime spec checks time.__dict__.__class__.__name__.__len__(),
# time.__mro__.__len__(), or time.__bases__[0].__name__.__len__().
# ---------------------------------------------------------------------------

invariant datetime_extra25.time.dict_class_name_len:
  description: "datetime.time.__dict__.__class__.__name__.__len__() == 12 — class __dict__ is a 'mappingproxy' (12 chars)"
  category: class_introspection
  kind: python_call_eq
  function: time.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant datetime_extra25.time.mro_len:
  description: "datetime.time.__mro__.__len__() == 2 — MRO is [time, object]; time has no intermediate bases"
  category: class_hierarchy
  kind: python_call_eq
  function: time.__mro__.__len__
  args: []
  expected: 2

invariant datetime_extra25.time.base_name_len:
  description: "datetime.time.__bases__[0].__name__.__len__() == 6 — direct base is 'object' (6 chars)"
  category: class_hierarchy
  kind: python_call_eq
  "function": "time.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# datetime.time method qualname lengths
#
# time.fromisoformat and time.isoformat are the two most commonly used
# string-conversion methods on the time class. Their qualnames take the form
# 'time.<method_name>'.
#   time.fromisoformat -> 'time.fromisoformat' -> 18 chars
#   time.isoformat     -> 'time.isoformat'     -> 14 chars
# No prior datetime spec checks qualname lengths for any time method.
# ---------------------------------------------------------------------------

table datetime_extra25.time_method_qualname_lens:
  description: "datetime.time method __qualname__.__len__(): fromisoformat (18), isoformat (14)"
  kind: python_call_eq
  category: method_identity
  id_prefix: tmq25

  columns: [id, function, args, expected]
  rows:
    - [fromisoformat, time.fromisoformat.__qualname__.__len__, [], 18]
    - [isoformat,     time.isoformat.__qualname__.__len__,     [], 14]

# ---------------------------------------------------------------------------
# datetime.datetime class hierarchy
#
# datetime.datetime inherits from datetime.date, making it one of the few
# stdlib classes with a non-object direct base.
#   datetime.__bases__[0].__name__ == 'date' -> len 4
#   datetime.__mro__ == [datetime, date, object] -> len 3
# datetime_extra23 covered __mro__.__len__()==3 for datetime and __bases__[0]
# name as 'date' in string form, but did NOT check __bases__[0].__name__.__len__().
# ---------------------------------------------------------------------------

invariant datetime_extra25.datetime.base_name_len:
  description: "datetime.datetime.__bases__[0].__name__.__len__() == 4 — direct base is 'date' (4 chars); datetime inherits from date"
  category: class_hierarchy
  kind: python_call_eq
  "function": "datetime.__bases__[0].__name__.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# datetime.datetime class method qualname lengths
#
# These four factory/classmethod qualnames follow the 'datetime.<method>'
# pattern. datetime_extra22/23 covered datetime.fromisoformat, datetime.utcnow,
# datetime.combine, and datetime.isoformat qualname lengths.
# datetime_extra21 covered datetime.now.__qualname__.__len__().
# This spec checks datetime.fromtimestamp (not previously covered).
# ---------------------------------------------------------------------------

invariant datetime_extra25.datetime.fromtimestamp_qualname_len:
  description: "datetime.datetime.fromtimestamp.__qualname__.__len__() == 22 — 'datetime.fromtimestamp' has 22 characters"
  category: method_identity
  kind: python_call_eq
  function: datetime.fromtimestamp.__qualname__.__len__
  args: []
  expected: 22

# ---------------------------------------------------------------------------
# datetime.date class method qualname lengths
#
# date.today, date.fromtimestamp, and date.fromisoformat are the primary
# factory methods on datetime.date. date.replace is the canonical instance
# method for creating modified copies. All follow the 'date.<method>' pattern.
#   date.today         -> 'date.today'         -> 10 chars
#   date.fromtimestamp -> 'date.fromtimestamp' -> 18 chars  (same as datetime.fromtimestamp len)
#   date.fromisoformat -> 'date.fromisoformat' -> 18 chars
#   date.replace       -> 'date.replace'       -> 12 chars
# datetime_extra21 covered date.today.__qualname__.__len__().
# datetime_extra22 covered date.fromisoformat.__qualname__.__len__().
# No prior spec checks date.fromtimestamp or date.replace qualname lengths.
# ---------------------------------------------------------------------------

table datetime_extra25.date_method_qualname_lens:
  description: "datetime.date method __qualname__.__len__(): today (10), fromtimestamp (18), fromisoformat (18), replace (12)"
  kind: python_call_eq
  category: method_identity
  id_prefix: dmq25

  columns: [id, function, args, expected]
  rows:
    - [fromtimestamp, date.fromtimestamp.__qualname__.__len__, [], 18]
    - [fromisoformat, date.fromisoformat.__qualname__.__len__, [], 18]
    - [replace,       date.replace.__qualname__.__len__,       [], 12]

# ---------------------------------------------------------------------------
# datetime.timedelta class hierarchy and method qualname
#
# timedelta.__mro__ == [timedelta, object] (len 2), its base is 'object' (len 6).
# timedelta.total_seconds is the only public instance method on timedelta;
# its qualname is 'timedelta.total_seconds' (len 23).
# datetime_extra23 covered timedelta.__mro__.__len__()==2.
# No prior datetime spec checks timedelta.__bases__[0].__name__.__len__() or
# timedelta.total_seconds.__qualname__.__len__().
# ---------------------------------------------------------------------------

invariant datetime_extra25.timedelta.base_name_len:
  description: "datetime.timedelta.__bases__[0].__name__.__len__() == 6 — direct base is 'object' (6 chars)"
  category: class_hierarchy
  kind: python_call_eq
  "function": "timedelta.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant datetime_extra25.timedelta.total_seconds_qualname_len:
  description: "datetime.timedelta.total_seconds.__qualname__.__len__() == 23 — 'timedelta.total_seconds' has 23 characters"
  category: method_identity
  kind: python_call_eq
  function: timedelta.total_seconds.__qualname__.__len__
  args: []
  expected: 23

# ---------------------------------------------------------------------------
# datetime.timezone class hierarchy
#
# timezone.__mro__ == [timezone, tzinfo, object] (len 3).
# timezone.__bases__[0].__name__ == 'tzinfo' (len 6).
# datetime_extra23 covered timezone.__mro__.__len__()==3 and noted base as
# 'tzinfo' in string notes but did NOT check __bases__[0].__name__.__len__().
# ---------------------------------------------------------------------------

invariant datetime_extra25.timezone.base_name_len:
  description: "datetime.timezone.__bases__[0].__name__.__len__() == 6 — direct base is 'tzinfo' (6 chars)"
  category: class_hierarchy
  kind: python_call_eq
  "function": "timezone.__bases__[0].__name__.__len__"
  args: []
  expected: 6
