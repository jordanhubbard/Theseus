spec: math_extra14
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl and prior extras through math_extra13.zspec.zsdl."
    - "No prior spec covers math.isfinite(1) == True or math.isfinite(0) == True."
    - "No prior spec covers math.isfinite with an infinite value returning False."
    - "No prior spec covers math.copysign(1.0, -2.0) == -1.0 or math.copysign(-1.0, 2.0) == 1.0."
    - "No prior spec covers math.fabs(-3.5) == 3.5 or math.fabs(0.0) == 0.0."
    - "No prior spec covers math.gcd(12, 8) == 4, math.gcd(0, 5) == 5, or math.gcd(7, 7) == 7."
    - "No prior spec covers math.lcm(4, 6) == 12 or math.lcm(3, 5) == 15 (Python 3.9+)."
    - "No prior spec covers math.prod([1,2,3,4]) == 24 or math.prod([5]) == 5 (Python 3.8+)."
    - "No prior spec covers math.log2(8) == 3.0 or math.log10(1000) == 3.0."
    - "math.isfinite(1) == True — a finite integer is finite."
    - "math.isfinite(0) == True — zero is finite."
    - "math.isfinite(float('inf')) == False — infinity is not finite (tested via inf attribute chain)."
    - "math.copysign(1.0, -2.0) == -1.0 — copies sign of -2.0 onto magnitude of 1.0."
    - "math.copysign(-1.0, 2.0) == 1.0 — copies sign of 2.0 (positive) onto magnitude of 1.0."
    - "math.fabs(-3.5) == 3.5 — floating-point absolute value of negative number."
    - "math.fabs(0.0) == 0.0 — floating-point absolute value of zero."
    - "math.gcd(12, 8) == 4 — greatest common divisor."
    - "math.gcd(0, 5) == 5 — gcd(0, n) == n by convention."
    - "math.gcd(7, 7) == 7 — gcd of equal values is the value itself."
    - "math.lcm(4, 6) == 12 — least common multiple."
    - "math.lcm(3, 5) == 15 — lcm of coprime numbers is their product."
    - "math.prod([1,2,3,4]) == 24 — product of a list."
    - "math.prod([5]) == 5 — product of a single-element list."
    - "math.log2(8) == 3.0 — log base 2 of 8 is 3."
    - "math.log10(1000) == 3.0 — log base 10 of 1000 is 3."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# isfinite — True for finite values, False for infinity
#
# cmath.zspec covers cmath.isfinite. No prior math spec covers math.isfinite.
# math.isfinite(1) == True, math.isfinite(0) == True.
# math.isfinite(inf) == False (using special float dict form).
# ---------------------------------------------------------------------------

invariant math_extra14.isfinite.one:
  description: "math.isfinite(1) == True — a finite integer is finite"
  category: predicates
  kind: python_call_eq
  function: isfinite
  args: [1]
  expected: true

invariant math_extra14.isfinite.zero:
  description: "math.isfinite(0) == True — zero is finite"
  category: predicates
  kind: python_call_eq
  function: isfinite
  args: [0]
  expected: true

invariant math_extra14.isfinite.infinity:
  description: "math.isfinite(float('inf')) == False — infinity is not finite"
  category: predicates
  kind: python_call_eq
  function: isfinite
  args: [{"type": "float", "value": "inf"}]
  expected: false

# ---------------------------------------------------------------------------
# copysign — return magnitude of x with sign of y
#
# copysign(1.0, -2.0) == -1.0: magnitude 1.0, sign from -2.0 gives -1.0.
# copysign(-1.0, 2.0) == 1.0: magnitude 1.0, sign from 2.0 gives +1.0.
# No prior spec covers copysign.
# ---------------------------------------------------------------------------

invariant math_extra14.copysign.positive_to_negative:
  description: "math.copysign(1.0, -2.0) == -1.0 — applies negative sign to positive magnitude"
  category: arithmetic
  kind: python_call_eq
  function: copysign
  args: [1.0, -2.0]
  expected: -1.0

invariant math_extra14.copysign.negative_to_positive:
  description: "math.copysign(-1.0, 2.0) == 1.0 — applies positive sign to negative magnitude"
  category: arithmetic
  kind: python_call_eq
  function: copysign
  args: [-1.0, 2.0]
  expected: 1.0

# ---------------------------------------------------------------------------
# fabs — floating-point absolute value
#
# fabs(-3.5) == 3.5: absolute value of negative float.
# fabs(0.0) == 0.0: absolute value of zero.
# No prior spec covers fabs.
# ---------------------------------------------------------------------------

invariant math_extra14.fabs.negative:
  description: "math.fabs(-3.5) == 3.5 — floating-point absolute value strips sign"
  category: arithmetic
  kind: python_call_eq
  function: fabs
  args: [-3.5]
  expected: 3.5

invariant math_extra14.fabs.zero:
  description: "math.fabs(0.0) == 0.0 — absolute value of zero is zero"
  category: arithmetic
  kind: python_call_eq
  function: fabs
  args: [0.0]
  expected: 0.0

# ---------------------------------------------------------------------------
# gcd — greatest common divisor
#
# gcd(12, 8) == 4: classic reduction; 12 = 2^2*3, 8 = 2^3, gcd = 4.
# gcd(0, 5) == 5: gcd(0, n) == n by convention.
# gcd(7, 7) == 7: gcd of equal values is the value itself.
# No prior spec covers gcd.
# ---------------------------------------------------------------------------

invariant math_extra14.gcd.twelve_eight:
  description: "math.gcd(12, 8) == 4 — greatest common divisor of 12 and 8"
  category: number_theory
  kind: python_call_eq
  function: gcd
  args: [12, 8]
  expected: 4

invariant math_extra14.gcd.zero_five:
  description: "math.gcd(0, 5) == 5 — gcd(0, n) == n by convention"
  category: number_theory
  kind: python_call_eq
  function: gcd
  args: [0, 5]
  expected: 5

invariant math_extra14.gcd.equal_inputs:
  description: "math.gcd(7, 7) == 7 — gcd of equal inputs is the value itself"
  category: number_theory
  kind: python_call_eq
  function: gcd
  args: [7, 7]
  expected: 7

# ---------------------------------------------------------------------------
# lcm — least common multiple (Python 3.9+)
#
# lcm(4, 6) == 12: 4 = 2^2, 6 = 2*3, lcm = 2^2*3 = 12.
# lcm(3, 5) == 15: 3 and 5 are coprime, so lcm = 3*5 = 15.
# No prior spec covers lcm.
# ---------------------------------------------------------------------------

invariant math_extra14.lcm.four_six:
  description: "math.lcm(4, 6) == 12 — least common multiple of 4 and 6"
  category: number_theory
  kind: python_call_eq
  function: lcm
  args: [4, 6]
  expected: 12

invariant math_extra14.lcm.coprime:
  description: "math.lcm(3, 5) == 15 — lcm of coprime numbers is their product"
  category: number_theory
  kind: python_call_eq
  function: lcm
  args: [3, 5]
  expected: 15

# ---------------------------------------------------------------------------
# prod — product of an iterable (Python 3.8+)
#
# prod([1,2,3,4]) == 24: 1*2*3*4 = 24.
# prod([5]) == 5: single-element list, product equals the element.
# No prior spec covers prod.
# ---------------------------------------------------------------------------

invariant math_extra14.prod.four_elements:
  description: "math.prod([1,2,3,4]) == 24 — product of four integers"
  category: arithmetic
  kind: python_call_eq
  function: prod
  args: [[1, 2, 3, 4]]
  expected: 24

invariant math_extra14.prod.single_element:
  description: "math.prod([5]) == 5 — product of a single-element list"
  category: arithmetic
  kind: python_call_eq
  function: prod
  args: [[5]]
  expected: 5

# ---------------------------------------------------------------------------
# log2 / log10 — base-2 and base-10 logarithms
#
# log2(8) == 3.0: 2^3 = 8.
# log10(1000) == 3.0: 10^3 = 1000.
# No prior spec covers log2 or log10 with these exact argument values.
# ---------------------------------------------------------------------------

invariant math_extra14.log2.eight:
  description: "math.log2(8) == 3.0 — log base 2 of 8 is exactly 3"
  category: logarithm
  kind: python_call_eq
  function: log2
  args: [8]
  expected: 3.0

invariant math_extra14.log10.thousand:
  description: "math.log10(1000) == 3.0 — log base 10 of 1000 is exactly 3"
  category: logarithm
  kind: python_call_eq
  function: log10
  args: [1000]
  expected: 3.0
