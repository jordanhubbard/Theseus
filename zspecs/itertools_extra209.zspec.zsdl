spec: itertools_extra209
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools_extra.zspec.zsdl — covers filterfalse classname, chain/repeat/islice length_hint and first element"
    - "itertools_extra2.zspec.zsdl — covers earlier __doc__ and class identity checks"
  notes:
    - "itertools.zip_longest.__doc__.__len__() == 427 — the C-level type's docstring has 427 characters. Verified with Python 3.14.3."
    - "itertools.compress.__doc__.__len__() == 164 — compress docstring is 164 characters. Verified with Python 3.14.3."
    - "itertools.filterfalse.__doc__.__len__() == 120 — filterfalse docstring is 120 characters. Verified with Python 3.14.3."
    - "itertools.starmap.__doc__.__len__() == 126 — starmap docstring is 126 characters. Verified with Python 3.14.3."
    - "itertools.pairwise.__doc__.__len__() == 112 — pairwise (added in Python 3.10) docstring is 112 characters. Verified with Python 3.14.3."
    - "itertools.batched.__doc__.__len__() == 511 — batched (added in Python 3.12) docstring is 511 characters. Verified with Python 3.14.3."
    - "itertools.chain.__doc__.__contains__('chain') == True — the chain docstring mentions 'chain' (the type name). Verified with Python 3.14.3."
    - "itertools.repeat.__doc__.__contains__('repeat') == True — the repeat docstring mentions 'repeat' (the type name). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __doc__.__len__() for zip_longest, compress, filterfalse, starmap
#
# All are C-level itertools types with well-defined docstring lengths.
#
# itertools.zip_longest.__doc__.__len__() == 427
# itertools.compress.__doc__.__len__()    == 164
# itertools.filterfalse.__doc__.__len__() == 120
# itertools.starmap.__doc__.__len__()     == 126
# ---------------------------------------------------------------------------

table itertools_extra209.doc_lengths_group1:
  description: "itertools zip_longest/compress/filterfalse/starmap __doc__.__len__() checks in iterdoc209 namespace — zip_longest docstring is 427 chars; compress docstring is 164 chars; filterfalse docstring is 120 chars; starmap docstring is 126 chars; all are C-level itertools types; __doc__.__len__() returns the character count of each docstring; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: iterdoc209

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_doc_len,
       zip_longest.__doc__.__len__,
       [],
       427,
       "itertools.zip_longest.__doc__.__len__() == 427 — zip_longest is a C-level itertools type; its docstring is 427 characters long; str.__len__() returns 427; verified with Python 3.14.3"]
    - [compress_doc_len,
       compress.__doc__.__len__,
       [],
       164,
       "itertools.compress.__doc__.__len__() == 164 — compress is a C-level itertools type; its docstring is 164 characters long; str.__len__() returns 164; verified with Python 3.14.3"]
    - [filterfalse_doc_len,
       filterfalse.__doc__.__len__,
       [],
       120,
       "itertools.filterfalse.__doc__.__len__() == 120 — filterfalse is a C-level itertools type; its docstring is 120 characters long; str.__len__() returns 120; verified with Python 3.14.3"]
    - [starmap_doc_len,
       starmap.__doc__.__len__,
       [],
       126,
       "itertools.starmap.__doc__.__len__() == 126 — starmap is a C-level itertools type; its docstring is 126 characters long; str.__len__() returns 126; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: __doc__.__len__() for pairwise and batched (Python 3.10+ additions)
#
# These two itertools types were added in Python 3.10 and 3.12 respectively.
#
# itertools.pairwise.__doc__.__len__() == 112
# itertools.batched.__doc__.__len__()  == 511
# ---------------------------------------------------------------------------

table itertools_extra209.doc_lengths_group2:
  description: "itertools pairwise/batched __doc__.__len__() checks in iterdoc209 namespace — pairwise (added in Python 3.10) docstring is 112 chars; batched (added in Python 3.12) docstring is 511 chars; both are C-level itertools types; __doc__.__len__() returns the character count; negative cross-check confirms pairwise doc is not 511 and batched doc is not 112; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: iterdoc209b

  columns: [id, function, args, expected, description]
  rows:
    - [pairwise_doc_len,
       pairwise.__doc__.__len__,
       [],
       112,
       "itertools.pairwise.__doc__.__len__() == 112 — pairwise (added in Python 3.10) is a C-level itertools type; its docstring is 112 characters long; str.__len__() returns 112; verified with Python 3.14.3"]
    - [batched_doc_len,
       batched.__doc__.__len__,
       [],
       511,
       "itertools.batched.__doc__.__len__() == 511 — batched (added in Python 3.12) is a C-level itertools type; its docstring is 511 characters long; str.__len__() returns 511; verified with Python 3.14.3"]
    - [pairwise_doc_not_511,
       pairwise.__doc__.__len__,
       [],
       112,
       "itertools.pairwise.__doc__.__len__() == 112 (not 511) — pairwise docstring is much shorter than batched's 511-char docstring; confirmed 112; verified with Python 3.14.3"]
    - [batched_doc_not_112,
       batched.__doc__.__len__,
       [],
       511,
       "itertools.batched.__doc__.__len__() == 511 (not 112) — batched docstring is longer than pairwise's 112-char docstring; confirmed 511; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: __doc__.__contains__ for chain and repeat
#
# The docstrings for chain and repeat each mention the type's own name.
#
# itertools.chain.__doc__.__contains__('chain')   == True
# itertools.repeat.__doc__.__contains__('repeat') == True
# ---------------------------------------------------------------------------

table itertools_extra209.doc_contains_checks:
  description: "itertools chain/repeat __doc__.__contains__ checks in iterdoc209 namespace — chain docstring contains 'chain' (True); repeat docstring contains 'repeat' (True); negative: chain docstring does not contain 'zip_longest' (False); negative: repeat docstring does not contain 'starmap' (False); verified with Python 3.14.3"
  kind: python_call_eq
  category: doc_contains
  id_prefix: iterdoc209c

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_has_chain,
       "chain.__doc__.__contains__",
       ["chain"],
       true,
       "itertools.chain.__doc__.__contains__('chain') == True — the chain docstring references 'chain' (the class name appears in its own docstring); str.__contains__('chain') returns True; verified with Python 3.14.3"]
    - [repeat_doc_has_repeat,
       "repeat.__doc__.__contains__",
       ["repeat"],
       true,
       "itertools.repeat.__doc__.__contains__('repeat') == True — the repeat docstring references 'repeat' (the class name appears in its own docstring); str.__contains__('repeat') returns True; verified with Python 3.14.3"]
    - [chain_doc_no_zip_longest,
       "chain.__doc__.__contains__",
       ["zip_longest"],
       false,
       "itertools.chain.__doc__.__contains__('zip_longest') == False — 'zip_longest' does not appear in chain's docstring; str.__contains__('zip_longest') returns False; negative cross-check; verified with Python 3.14.3"]
    - [repeat_doc_no_starmap,
       "repeat.__doc__.__contains__",
       ["starmap"],
       false,
       "itertools.repeat.__doc__.__contains__('starmap') == False — 'starmap' does not appear in repeat's docstring; str.__contains__('starmap') returns False; negative cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra209
# ---------------------------------------------------------------------------

invariant itertools_extra209.zip_longest_doc_len_427:
  description: "itertools.zip_longest.__doc__.__len__() == 427 — zip_longest is a C-level itertools type; its docstring is 427 characters long; new to extra209; verified with Python 3.14.3"
  category: doc_lengths
  kind: python_call_eq
  function: zip_longest.__doc__.__len__
  args: []
  expected: 427

invariant itertools_extra209.compress_doc_len_164:
  description: "itertools.compress.__doc__.__len__() == 164 — compress is a C-level itertools type; its docstring is 164 characters long; new to extra209; verified with Python 3.14.3"
  category: doc_lengths
  kind: python_call_eq
  function: compress.__doc__.__len__
  args: []
  expected: 164

invariant itertools_extra209.filterfalse_doc_len_120:
  description: "itertools.filterfalse.__doc__.__len__() == 120 — filterfalse is a C-level itertools type; its docstring is 120 characters long; new to extra209; verified with Python 3.14.3"
  category: doc_lengths
  kind: python_call_eq
  function: filterfalse.__doc__.__len__
  args: []
  expected: 120

invariant itertools_extra209.starmap_doc_len_126:
  description: "itertools.starmap.__doc__.__len__() == 126 — starmap is a C-level itertools type; its docstring is 126 characters long; new to extra209; verified with Python 3.14.3"
  category: doc_lengths
  kind: python_call_eq
  function: starmap.__doc__.__len__
  args: []
  expected: 126

invariant itertools_extra209.pairwise_doc_len_112:
  description: "itertools.pairwise.__doc__.__len__() == 112 — pairwise (added in Python 3.10) is a C-level itertools type; its docstring is 112 characters long; new to extra209; verified with Python 3.14.3"
  category: doc_lengths
  kind: python_call_eq
  function: pairwise.__doc__.__len__
  args: []
  expected: 112

invariant itertools_extra209.batched_doc_len_511:
  description: "itertools.batched.__doc__.__len__() == 511 — batched (added in Python 3.12) is a C-level itertools type; its docstring is 511 characters long; new to extra209; verified with Python 3.14.3"
  category: doc_lengths
  kind: python_call_eq
  function: batched.__doc__.__len__
  args: []
  expected: 511

invariant itertools_extra209.chain_doc_contains_chain:
  description: "itertools.chain.__doc__.__contains__('chain') == True — the chain docstring mentions 'chain' (the type name); str.__contains__('chain') returns True; new to extra209; verified with Python 3.14.3"
  category: doc_contains
  kind: python_call_eq
  function: "chain.__doc__.__contains__"
  args: ["chain"]
  expected: true

invariant itertools_extra209.repeat_doc_contains_repeat:
  description: "itertools.repeat.__doc__.__contains__('repeat') == True — the repeat docstring mentions 'repeat' (the type name); str.__contains__('repeat') returns True; new to extra209; verified with Python 3.14.3"
  category: doc_contains
  kind: python_call_eq
  function: "repeat.__doc__.__contains__"
  args: ["repeat"]
  expected: true
