spec: dc3061
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 651 (dc3061): __aexit__, __await__, __anext__ dict-presence for decimal types."
    - "decimal.Context supports with-statement usage at runtime but does not define __aexit__ in its Python-level __dict__; the async variant __aexit__ is also absent."
    - "decimal.Decimal and all decimal exception types are numeric/exception types; none define __aexit__, __await__, or __anext__ in their own __dict__."
    - "None of the decimal types implement async protocols."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __aexit__ dict-presence — operator.contains(Cls.__dict__, '__aexit__')
#
# decimal types do not implement the async context manager protocol;
# none define __aexit__ in their own Python-level __dict__; all false.
# ---------------------------------------------------------------------------

table dc3061.aexit:
  description: "decimal types __aexit__ dict-presence checks; wave 651"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc3061
  columns: [id, function, args, expected]
  rows:
    - ["dc3061001", operator.contains, [decimal.Decimal.__dict__,          "__aexit__"], false]
    - ["dc3061002", operator.contains, [decimal.Context.__dict__,          "__aexit__"], false]
    - ["dc3061003", operator.contains, [decimal.DecimalException.__dict__, "__aexit__"], false]
    - ["dc3061004", operator.contains, [decimal.InvalidOperation.__dict__, "__aexit__"], false]
    - ["dc3061005", operator.contains, [decimal.Overflow.__dict__,         "__aexit__"], false]
    - ["dc3061006", operator.contains, [decimal.Underflow.__dict__,        "__aexit__"], false]

