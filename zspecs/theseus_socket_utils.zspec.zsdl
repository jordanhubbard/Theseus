spec: theseus_socket_utils
version: ">=3.9"
backend: python_cleanroom(theseus_socket_utils)
blocks: socket

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html"
  notes:
    - "Clean-room socket address utilities. Do NOT import socket or ipaddress."
    - "inet_aton(ip_string) -> bytes: convert dotted IPv4 to 4-byte packed binary."
    - "inet_ntoa(packed_ip) -> str: convert 4-byte packed to dotted decimal string."
    - "inet_aton('192.168.1.1') == b'\\xc0\\xa8\\x01\\x01'."
    - "inet_ntoa(b'\\xc0\\xa8\\x01\\x01') == '192.168.1.1'."
    - "gethostbyname_mock('localhost') == '127.0.0.1' (hardcoded mock, no DNS)."
    - "Export: inet_aton(ip_string) -> bytes, inet_ntoa(packed_ip) -> str."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_socket_utils.inet_aton:
  description: "inet_aton('192.168.1.1') == b'\\xc0\\xa8\\x01\\x01'"
  category: inet
  kind: python_call_eq
  function: socket_inet_aton
  args: []
  expected: true

invariant theseus_socket_utils.inet_ntoa:
  description: "inet_ntoa(b'\\xc0\\xa8\\x01\\x01') == '192.168.1.1'"
  category: inet
  kind: python_call_eq
  function: socket_inet_ntoa
  args: []
  expected: "192.168.1.1"

invariant theseus_socket_utils.round_trip:
  description: "inet_ntoa(inet_aton('10.0.0.1')) == '10.0.0.1'"
  category: round_trip
  kind: python_call_eq
  function: socket_round_trip
  args: []
  expected: true
