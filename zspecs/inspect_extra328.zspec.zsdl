spec: inspect_extra328
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.getdoc — identity
# ---------------------------------------------------------------------------

invariant inspect_extra328.getdoc.__name__:
  description: "inspect.getdoc.__name__ == 'getdoc'"
  category: identity
  kind: python_call_eq
  function: getdoc.__name__.__eq__
  args: ["getdoc"]
  expected: true

invariant inspect_extra328.getdoc.__module__:
  description: "inspect.getdoc.__module__ == 'inspect'"
  category: identity
  kind: python_call_eq
  function: getdoc.__module__.__eq__
  args: ["inspect"]
  expected: true

# ---------------------------------------------------------------------------
# inspect.cleandoc — identity
# ---------------------------------------------------------------------------

invariant inspect_extra328.cleandoc.__name__:
  description: "inspect.cleandoc.__name__ == 'cleandoc'"
  category: identity
  kind: python_call_eq
  function: cleandoc.__name__.__eq__
  args: ["cleandoc"]
  expected: true

invariant inspect_extra328.cleandoc.__module__:
  description: "inspect.cleandoc.__module__ == 'inspect'"
  category: identity
  kind: python_call_eq
  function: cleandoc.__module__.__eq__
  args: ["inspect"]
  expected: true

# ---------------------------------------------------------------------------
# inspect.getdoc — behavioral: int has a docstring, returns str
# ---------------------------------------------------------------------------

invariant inspect_extra328.getdoc_int_class:
  description: "inspect.getdoc(int).__class__.__name__ == 'str' — int has a docstring"
  category: behavioral
  kind: python_call_eq
  function: getdoc(int).__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# inspect.getdoc(None) — returns str (None has a docstring via NoneType)
# ---------------------------------------------------------------------------

invariant inspect_extra328.getdoc_none_class:
  description: "inspect.getdoc(None).__class__.__name__ == 'str' — None has a docstring via NoneType"
  category: behavioral
  kind: python_call_eq
  function: getdoc(None).__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# inspect.cleandoc — behavioral: strips and normalizes indented text
# ---------------------------------------------------------------------------

invariant inspect_extra328.cleandoc_indented:
  description: "inspect.cleandoc('  hello\\n  world') == 'hello\\nworld'"
  category: behavioral
  kind: python_call_eq
  function: cleandoc
  args: ["  hello\n  world"]
  expected: "hello\nworld"

invariant inspect_extra328.cleandoc_empty:
  description: "inspect.cleandoc('') == ''"
  category: behavioral
  kind: python_call_eq
  function: cleandoc
  args: [""]
  expected: ""

# ---------------------------------------------------------------------------
# Table: module affiliation for getdoc and cleandoc
# ---------------------------------------------------------------------------

table inspect_extra328.function_modules:
  kind: python_call_eq
  category: identity
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [getdoc,    getdoc.__module__.__eq__,    ["inspect"], true]
    - [cleandoc,  cleandoc.__module__.__eq__,  ["inspect"], true]
