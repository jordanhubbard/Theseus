spec: normalize_path
version: ">=3.0.0"
backend: node(normalize-path)

docs: https://www.npmjs.com/package/normalize-path

provenance:
  derived_from:
    - "normalize-path README — https://www.npmjs.com/package/normalize-path"
    - "Test vectors verified with normalize-path@3.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "normalize-path source"
  notes:
    - "normalize-path exports a function directly as module.exports."
    - "normalizePath(path) converts backslashes to forward slashes."
    - "Removes trailing slashes by default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns normalized path string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table normalize_path.normalize_path:
  kind: node_module_call_eq
  function: ~
  category: normalize_path
  id_prefix: npath

  columns: [id, args, expected]
  rows:
    - [backslash,    ["foo\\bar\\baz"],    "foo/bar/baz"]
    - [mixed,        ["foo/bar\\baz"],     "foo/bar/baz"]
    - [trailing,     ["foo/bar/"],         "foo/bar"]
    - [forward,      ["foo/bar/baz"],      "foo/bar/baz"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:03:35Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
