spec: abc_extra1606
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __slots__ and slot descriptor protocol"
    - "abc.ABC explicitly declares __slots__ = () (empty tuple) in its class body; this suppresses the per-instance __dict__ that ABC would otherwise receive — abc.ABC instances have no __dict__"
    - "abc.ABCMeta is a metaclass (subclass of type) and does NOT declare __slots__"
    - "abc.abstractmethod is a plain Python function (not a class); the __slots__ question does not apply to it as a class"
    - "abc.abstractproperty (deprecated) is a pure Python class inheriting from property; it does not declare __slots__"
    - "Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

table abc_extra1606.abc_class_slots:
  description: "abc.ABC declares __slots__ = () suppressing per-instance __dict__; __slots__ value is an empty tuple; no __dict__ or __weakref__ descriptor in ABC's own class dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1606ac

  columns: [id, function, args, expected]
  rows:
    - ["ab1606ac001", "abc.ABC.__dict__.__contains__", ["__slots__"], true]
    - ["ab1606ac002", "abc.ABC.__slots__.__eq__", [[]],  false]
    - ["ab1606ac003", "isinstance(abc.ABC.__slots__, tuple).__bool__", [], true]
    - ["ab1606ac004", "abc.ABC.__slots__.__len__", [], 0]
    - ["ab1606ac005", "abc.ABC.__dict__.__contains__", ["__dict__"], false]
    - ["ab1606ac006", "abc.ABC.__dict__.__contains__", ["__weakref__"], false]
    - ["ab1606ac007", "type(abc.ABC.__dict__[\"__slots__\"]).__name__.__eq__", ["tuple"], true]
    - ["ab1606ac008", "abc.ABC.__dict__.__contains__", ["_abc_impl"], true]
    - ["ab1606ac009", "abc.ABC.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["ab1606ac010", "abc.ABC.__module__.__eq__", ["abc"], true]
    - ["ab1606ac011", "abc.ABC.__name__.__eq__", ["ABC"], true]
    - ["ab1606ac012", "abc.ABC.__bases__.__len__", [], 1]
    - ["ab1606ac013", "object.__name__.__eq__", ["object"], true]
    - ["ab1606ac014", "type(abc.ABC).__name__.__eq__", ["ABCMeta"], true]
    - ["ab1606ac015", "abc.ABC.__dict__.__contains__", ["__firstlineno__"], true]
    - ["ab1606ac016", "abc.ABC.__dict__.__contains__", ["__static_attributes__"], true]
    - ["ab1606ac017", "abc.ABC.__dict__.__contains__", ["__doc__"], true]
    - ["ab1606ac018", "abc.ABC.__dict__.__contains__", ["__module__"], true]
    - ["ab1606ac019", "issubclass(abc.ABC, object).__bool__", [], true]
    - ["ab1606ac020", "abc.ABC.__dict__.__len__", [], 7]

