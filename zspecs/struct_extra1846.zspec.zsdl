    - ["st1846-arith-006", "struct.error.__dict__.__contains__", ["__mul__"], false]
    - ["st1846-arith-007", "struct.__dict__.__contains__", ["__add__"], false]
    - ["st1846-arith-008", "struct.__dict__.__contains__", ["__mul__"], false]

