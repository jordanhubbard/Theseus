spec: struct_extra1846
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from: []
  not_derived_from: []
  notes:
    - "Arithmetic and comparison operator protocol checks for struct module"
    - "Wave 570: __add__/__sub__/__mul__/__truediv__ and __gt__/__ge__/__le__/__ne__/__lt__/__eq__"
    - "struct.Struct is a C type with no custom arithmetic or comparison operators"
  created_at: "2026-04-12"

table struct_extra1846.arithmetic_operators:
  columns: [id, function, args, expected]
  rows:
    - ["st1846-arith-001", "struct.Struct.__dict__.__contains__", ["__add__"], false]
    - ["st1846-arith-002", "struct.Struct.__dict__.__contains__", ["__sub__"], false]
    - ["st1846-arith-003", "struct.Struct.__dict__.__contains__", ["__mul__"], false]
