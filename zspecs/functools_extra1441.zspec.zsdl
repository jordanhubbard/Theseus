# ---------------------------------------------------------------------------
# Standalone invariants — extra1441
# ---------------------------------------------------------------------------

invariant functools_extra1441.partial_subclasshook_is_builtin:
  description: "functools.partial.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — inherited from object, not ABCMeta; wave 543; new to extra1441"
  kind: python_call_eq
  function: partial.__subclasshook__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra1441.partial_subclasshook_not_in_dict:
  description: "'__subclasshook__' not in functools.partial.__dict__ — partial does not override __subclasshook__; wave 543; new to extra1441"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__subclasshook__"]
  expected: false

invariant functools_extra1441.partial_instancecheck_not_in_dict:
  description: "'__instancecheck__' not in functools.partial.__dict__ — partial does not define __instancecheck__; wave 543; new to extra1441"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__instancecheck__"]
  expected: false

invariant functools_extra1441.partial_subclasscheck_not_in_dict:
  description: "'__subclasscheck__' not in functools.partial.__dict__ — partial does not define __subclasscheck__; wave 543; new to extra1441"
