       ["__subclasshook__"],
       false,
       "functools.partialmethod.__dict__.__contains__('__subclasshook__') == False — partialmethod does not define __subclasshook__ in its own class __dict__; new to extra1441"]
    - [fu1441dm005,
       "partial.__dict__.__contains__",
       ["__instancecheck__"],
       false,
       "functools.partial.__dict__.__contains__('__instancecheck__') == False — partial does not define __instancecheck__ in its own class __dict__; new to extra1441"]
    - [fu1441dm006,
       "cached_property.__dict__.__contains__",
       ["__instancecheck__"],
       false,
       "functools.cached_property.__dict__.__contains__('__instancecheck__') == False — cached_property does not define __instancecheck__ in its own class __dict__; new to extra1441"]
    - [fu1441dm007,
       "singledispatchmethod.__dict__.__contains__",
       ["__instancecheck__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__instancecheck__') == False — singledispatchmethod does not define __instancecheck__ in its own class __dict__; new to extra1441"]
    - [fu1441dm008,
       "partialmethod.__dict__.__contains__",
       ["__instancecheck__"],
       false,
       "functools.partialmethod.__dict__.__contains__('__instancecheck__') == False — partialmethod does not define __instancecheck__ in its own class __dict__; new to extra1441"]

