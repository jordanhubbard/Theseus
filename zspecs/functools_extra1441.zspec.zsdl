spec: functools_extra1441
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
    - "functools_extra1426.zspec.zsdl — covers __format__ and __dir__ method type and dict-presence checks"
  notes:
    - "Wave 543 (_extra1441): focuses on __subclasshook__, __instancecheck__, and __subclasscheck__ ABC-machinery checks for functools classes."
    - "functools.partial.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — partial is a C extension type; __subclasshook__ is inherited from object (not ABCMeta) as a builtin_function_or_method. Verified Python 3.14.3."
    - "functools.cached_property.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "functools.singledispatchmethod.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "functools.partialmethod.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "None of partial, cached_property, singledispatchmethod, partialmethod define '__subclasshook__' in their own __dict__ — they are not ABC subclasses. Verified Python 3.14.3."
    - "None of partial, cached_property, singledispatchmethod, partialmethod define '__instancecheck__' in their own __dict__. Verified Python 3.14.3."
    - "None of partial, cached_property, singledispatchmethod, partialmethod define '__subclasscheck__' in their own __dict__. Verified Python 3.14.3."
    - "functools.partial.__subclasscheck__.__class__.__name__ == 'builtin_function_or_method' — inherited from object. Verified Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools class __subclasshook__ method type checks
#
# Wave 543 theme: __subclasshook__.__class__.__name__ checks for functools
# classes. All four classes — partial, cached_property, singledispatchmethod,
# partialmethod — inherit __subclasshook__ from object (not ABCMeta), so the
# attribute resolves as 'builtin_function_or_method'. None override it.
# ---------------------------------------------------------------------------

table functools_extra1441.subclasshook_class_name:
  description: "functools classes: __subclasshook__.__class__.__name__ == 'builtin_function_or_method' for partial, cached_property, singledispatchmethod, partialmethod; wave 543; new to extra1441"
  kind: python_call_eq
  category: subclasshook_class_name
  id_prefix: fu1441sc

  columns: [id, function, args, expected, description]
  rows:
    - [fu1441sc001,
       "partial.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.partial.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — partial is a C extension type; __subclasshook__ is inherited from object, not ABCMeta; new to extra1441"]
    - [fu1441sc002,
       "cached_property.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.cached_property.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — cached_property inherits __subclasshook__ from object; new to extra1441"]
    - [fu1441sc003,
       "singledispatchmethod.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.singledispatchmethod.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — singledispatchmethod inherits __subclasshook__ from object; new to extra1441"]
    - [fu1441sc004,
       "partialmethod.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.partialmethod.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — partialmethod inherits __subclasshook__ from object; new to extra1441"]
    - [fu1441sc005,
       "partial.__subclasscheck__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.partial.__subclasscheck__.__class__.__name__.__eq__('builtin_function_or_method') == True — partial inherits __subclasscheck__ from object; new to extra1441"]
    - [fu1441sc006,
       "cached_property.__subclasscheck__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.cached_property.__subclasscheck__.__class__.__name__.__eq__('builtin_function_or_method') == True — cached_property inherits __subclasscheck__ from object; new to extra1441"]
    - [fu1441sc007,
       "singledispatchmethod.__subclasscheck__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.singledispatchmethod.__subclasscheck__.__class__.__name__.__eq__('builtin_function_or_method') == True — singledispatchmethod inherits __subclasscheck__ from object; new to extra1441"]
    - [fu1441sc008,
       "partialmethod.__subclasscheck__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.partialmethod.__subclasscheck__.__class__.__name__.__eq__('builtin_function_or_method') == True — partialmethod inherits __subclasscheck__ from object; new to extra1441"]

# ---------------------------------------------------------------------------
# Table 2: functools class __subclasshook__ and __instancecheck__ dict absence
#
# Wave 543 theme: '__subclasshook__', '__instancecheck__', '__subclasscheck__'
# not in own __dict__ for functools classes. None of these classes use ABC
# machinery — they are plain C extension or pure-Python classes with no custom
# subclass/instance hooks.
# ---------------------------------------------------------------------------

table functools_extra1441.abc_hooks_dict_membership:
  description: "functools classes: '__subclasshook__', '__instancecheck__', '__subclasscheck__' not in own __dict__ for partial, cached_property, singledispatchmethod, partialmethod; wave 543; new to extra1441"
  kind: python_call_eq
  category: abc_hooks_dict_membership
  id_prefix: fu1441dm

  columns: [id, function, args, expected, description]
  rows:
    - [fu1441dm001,
       "partial.__dict__.__contains__",
       ["__subclasshook__"],
       false,
       "functools.partial.__dict__.__contains__('__subclasshook__') == False — partial does not define __subclasshook__ in its own class __dict__; not an ABC subclass; new to extra1441"]
    - [fu1441dm002,
       "cached_property.__dict__.__contains__",
       ["__subclasshook__"],
       false,
       "functools.cached_property.__dict__.__contains__('__subclasshook__') == False — cached_property does not define __subclasshook__ in its own class __dict__; new to extra1441"]
