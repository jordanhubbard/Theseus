spec: socket_extra127
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra126.zspec.zsdl — covers socket.socket/__name__/__module__/__qualname__ equality / socket.socket/__bases__[0]/__name__ / socket.socket/__mro__/__len__()==3 / socket.error/timeout alias identity (table + invariants)."
    - "socket_extra125.zspec.zsdl — covers socket.socket Python-level method __code__ attributes — co_name/co_argcount/co_varnames[0] for accept/__init__/close/makefile/detach/dup (table + invariants)."
    - "socket_extra124.zspec.zsdl — covers socket.socket.connect/bind/listen/accept/recv/close/setsockopt __qualname__.__eq__ string equality (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module function __qualname__.__len__() / socket.SocketIO class identity (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket method __qualname__.__len__() for connect/bind/listen/send/recv/__init__/accept/close/makefile (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6 class names / SOCK_STREAM/SOCK_DGRAM class names / AddressFamily/SocketKind __bases__ / gethostname/gethostbyname class names (table + invariants)."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names (table + invariants)."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names for bind/connect/recv/send (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in earlier socket specs."
    - "Wave 299 theme: socket.socket C-level method qualname equality and lengths for the send/recv-family and utility methods — sendto/recvfrom/recvfrom_into/recv_into/shutdown/getsockname."
    - "socket.socket.sendto.__qualname__ == 'socket.sendto'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(socket.socket.sendto.__qualname__) == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom.__qualname__ == 'socket.recvfrom'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(socket.socket.recvfrom.__qualname__) == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom_into.__qualname__ == 'socket.recvfrom_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(socket.socket.recvfrom_into.__qualname__) == 20. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv_into.__qualname__ == 'socket.recv_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(socket.socket.recv_into.__qualname__) == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.shutdown.__qualname__ == 'socket.shutdown'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(socket.socket.shutdown.__qualname__) == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockname.__qualname__ == 'socket.getsockname'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(socket.socket.getsockname.__qualname__) == 18. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra97 anchors send/sendall/fileno __qualname__.__eq__; extra98 anchors __qualname__.__len__() for connect/bind/listen/send/recv; extra124 anchors connect/bind/listen/accept/recv/close/setsockopt __qualname__.__eq__. This spec first anchors __qualname__.__eq__ for sendto/recvfrom/recvfrom_into/recv_into/shutdown/getsockname."
    - "Note: All six methods are C-level method_descriptor objects from _socket.c. Their __qualname__ follows the pattern 'socket.<name>' (using the class name 'socket', not 'socket.socket'). socket.socket.__qualname__ is 'socket' (the C-extension base class name), so methods inherit this prefix."
    - "Note: recvfrom_into.__qualname__.__len__() == 20 is the longest among the six ('socket.recvfrom_into' = 'socket.'7 + 'recvfrom_into'13). getsockname is 18 ('socket.'7 + 'getsockname'11). recvfrom and shutdown share 15."
    - "Note: The method names include an underscore-joined suffix (_into) for buffer-based receive variants. recv_into (len 16) and recvfrom_into (len 20) differ by 4 chars (the 'from' infix). recvfrom (15) and recvfrom_into (20) differ by 5 ('_into')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.sendto.__qualname__.__eq__('socket.sendto')
# socket.socket.sendto.__qualname__.__len__()==13
# socket.socket.recvfrom.__qualname__.__eq__('socket.recvfrom')
# socket.socket.recvfrom.__qualname__.__len__()==15
#
# Wave 299 theme: sendto and recvfrom qualname equality and lengths.
#
# sendto.__qualname__ is 'socket.sendto' (13 chars: 'socket.'7 + 'sendto'6).
# recvfrom.__qualname__ is 'socket.recvfrom' (15 chars: 'socket.'7 + 'recvfrom'8).
# extra97 anchors send/sendall/fileno __qualname__.__eq__; extra98 anchors
# sendto qualname length (13) implicitly via the table (not sendto specifically);
# no prior socket spec anchors sendto or recvfrom __qualname__.__eq__ under
# sockmethod127. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra127.sendto_recvfrom_qualnames:
  description: "socket.socket.sendto/__qualname__.__eq__('socket.sendto')==True / sendto/__qualname__/__len__()==13 / socket.socket.recvfrom/__qualname__.__eq__('socket.recvfrom')==True / recvfrom/__qualname__/__len__()==15 — sendto qualname is 13 chars ('socket.'7 + 'sendto'6); recvfrom is 15 ('socket.'7 + 'recvfrom'8); extra97 anchors send/sendall qualnames; first sockmethod127 anchor for sendto/recvfrom __qualname__.__eq__"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: sockmethod127

  columns: [id, function, args, expected, description]
  rows:
    - [sendto_qualname_eq,   "socket.sendto.__qualname__.__eq__",   ["socket.sendto"],   true,  "socket.socket.sendto.__qualname__ is 'socket.sendto' (13 chars; C-level method_descriptor)"]
    - [sendto_qualname_len,  "socket.sendto.__qualname__.__len__",  [],                  13,    "socket.socket.sendto.__qualname__.__len__() is 13 ('socket.'7 + 'sendto'6)"]
    - [recvfrom_qualname_eq, "socket.recvfrom.__qualname__.__eq__", ["socket.recvfrom"], true,  "socket.socket.recvfrom.__qualname__ is 'socket.recvfrom' (15 chars; receives with sender address)"]
    - [recvfrom_qlen,        "socket.recvfrom.__qualname__.__len__",[],                  15,    "socket.socket.recvfrom.__qualname__.__len__() is 15 ('socket.'7 + 'recvfrom'8)"]

# ---------------------------------------------------------------------------
# socket.socket.recvfrom_into.__qualname__.__eq__('socket.recvfrom_into')
# socket.socket.recvfrom_into.__qualname__.__len__()==20
# socket.socket.recv_into.__qualname__.__eq__('socket.recv_into')
# socket.socket.recv_into.__qualname__.__len__()==16
#
# Wave 299 theme: recvfrom_into and recv_into qualname equality and lengths.
#
# recvfrom_into.__qualname__ is 'socket.recvfrom_into' (20 chars: 'socket.'7 + 'recvfrom_into'13).
# recv_into.__qualname__ is 'socket.recv_into' (16 chars: 'socket.'7 + 'recv_into'9).
# recvfrom_into is the longest qualname among all six new methods in this spec
# (length 20). No prior socket spec anchors recvfrom_into or recv_into
# __qualname__.__eq__ under sockmethod127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra127.recvfrom_into_recv_into_qualnames:
  description: "socket.socket.recvfrom_into/__qualname__.__eq__('socket.recvfrom_into')==True / recvfrom_into/__qualname__/__len__()==20 / socket.socket.recv_into/__qualname__.__eq__('socket.recv_into')==True / recv_into/__qualname__/__len__()==16 — recvfrom_into (20 chars) is the longest qualname; recv_into (16) is 4 shorter; both are buffer-based receive variants; no prior socket spec anchors these qualname equalities; first sockmethod127 anchor"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: sockmethod127

  columns: [id, function, args, expected, description]
  rows:
    - [recvfrom_into_qeq,  "socket.recvfrom_into.__qualname__.__eq__",  ["socket.recvfrom_into"],  true,  "socket.socket.recvfrom_into.__qualname__ is 'socket.recvfrom_into' (20 chars; longest of the six)"]
    - [recvfrom_into_qlen, "socket.recvfrom_into.__qualname__.__len__", [],                         20,    "socket.socket.recvfrom_into.__qualname__.__len__() is 20 ('socket.'7 + 'recvfrom_into'13)"]
    - [recv_into_qeq,      "socket.recv_into.__qualname__.__eq__",      ["socket.recv_into"],       true,  "socket.socket.recv_into.__qualname__ is 'socket.recv_into' (16 chars)"]
    - [recv_into_qlen,     "socket.recv_into.__qualname__.__len__",     [],                          16,    "socket.socket.recv_into.__qualname__.__len__() is 16 ('socket.'7 + 'recv_into'9)"]

# ---------------------------------------------------------------------------
# socket.socket.shutdown.__qualname__.__eq__('socket.shutdown')
# socket.socket.shutdown.__qualname__.__len__()==15
# socket.socket.getsockname.__qualname__.__eq__('socket.getsockname')
# socket.socket.getsockname.__qualname__.__len__()==18
# socket.socket.shutdown.__class__.__name__.__eq__('method_descriptor')
#
# Wave 299 theme: shutdown and getsockname qualname equality and lengths.
#
# shutdown.__qualname__ is 'socket.shutdown' (15 chars). getsockname.__qualname__
# is 'socket.getsockname' (18 chars: 'socket.'7 + 'getsockname'11). shutdown shares
# length 15 with recvfrom. Both are C-level method_descriptor objects from _socket.c.
# No prior socket spec anchors shutdown or getsockname __qualname__.__eq__ under
# sockmethod127. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra127.shutdown_getsockname_qualnames:
  description: "socket.socket.shutdown/__qualname__.__eq__('socket.shutdown')==True / shutdown/__qualname__/__len__()==15 / socket.socket.getsockname/__qualname__.__eq__('socket.getsockname')==True / getsockname/__qualname__/__len__()==18 / shutdown/__class__.__name__.__eq__('method_descriptor')==True — shutdown (15) shares length with recvfrom; getsockname (18); both C-level method_descriptor; no prior socket spec anchors these; first sockmethod127 anchor"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: sockmethod127

  columns: [id, function, args, expected, description]
  rows:
    - [shutdown_qeq,       "socket.shutdown.__qualname__.__eq__",       ["socket.shutdown"],     true,  "socket.socket.shutdown.__qualname__ is 'socket.shutdown' (15 chars; same length as recvfrom)"]
    - [shutdown_qlen,      "socket.shutdown.__qualname__.__len__",      [],                       15,    "socket.socket.shutdown.__qualname__.__len__() is 15 ('socket.'7 + 'shutdown'8)"]
    - [getsockname_qeq,    "socket.getsockname.__qualname__.__eq__",    ["socket.getsockname"],  true,  "socket.socket.getsockname.__qualname__ is 'socket.getsockname' (18 chars)"]
    - [getsockname_qlen,   "socket.getsockname.__qualname__.__len__",   [],                       18,    "socket.socket.getsockname.__qualname__.__len__() is 18 ('socket.'7 + 'getsockname'11)"]
    - [shutdown_cls_name,  "socket.shutdown.__class__.__name__.__eq__", ["method_descriptor"],   true,  "socket.socket.shutdown.__class__.__name__ is 'method_descriptor' (C-level, from _socket.c)"]

# ---------------------------------------------------------------------------
# socket.socket.sendto.__qualname__.__eq__('socket.sendto') — standalone
#
# socket.socket.sendto.__qualname__ is 'socket.sendto'. sendto is the C-level
# method for sending data to a specific address (used with UDP sockets and
# connected TCP sockets). The qualname uses 'socket.' as prefix — the C-extension
# base class name (not 'socket.socket.'). extra97 anchors send/sendall/fileno
# __qualname__.__eq__; no prior socket spec anchors sendto.__qualname__.__eq__
# as a standalone under sockmethod127. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra127.sendto_qualname_eq:
  description: "socket.socket.sendto.__qualname__.__eq__('socket.sendto') == True — sendto qualname is 'socket.sendto' (13 chars); sends data to a specific address; C-level method_descriptor from _socket.c; extra97 anchors send/sendall; first standalone for sendto qualname under sockmethod127"
  category: method_qualnames
  kind: python_call_eq
  function: "socket.sendto.__qualname__.__eq__"
  args: ["socket.sendto"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.recvfrom_into.__qualname__.__len__()==20 — standalone
#
# socket.socket.recvfrom_into.__qualname__.__len__() is 20. 'socket.recvfrom_into'
# is the longest qualname among the six methods in this spec. recvfrom_into
# receives data into a pre-allocated buffer and returns the number of bytes
# received along with the sender's address. 'recvfrom_into' (13 chars) is longer
# than 'recvfrom' (8) by 5 chars ('_into'). No prior socket spec anchors
# recvfrom_into.__qualname__.__len__()==20 as a standalone under sockmethod127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra127.recvfrom_into_qualname_len_20:
  description: "socket.socket.recvfrom_into.__qualname__.__len__() == 20 — 'socket.recvfrom_into' is 20 chars ('socket.'7 + 'recvfrom_into'13); longest qualname in this wave; recvfrom_into extends recvfrom with buffer-based receive; no prior socket spec anchors this length as standalone; first standalone under sockmethod127"
  category: method_qualnames
  kind: python_call_eq
  function: "socket.recvfrom_into.__qualname__.__len__"
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# socket.socket.getsockname.__qualname__.__eq__('socket.getsockname') — standalone
#
# socket.socket.getsockname.__qualname__ is 'socket.getsockname'. getsockname
# returns the socket's own address as a tuple. It is a C-level method_descriptor
# from the _socket extension. 'socket.getsockname' is 18 chars. extra124 anchors
# connect/bind/listen/accept/recv/close/setsockopt __qualname__.__eq__; no prior
# socket spec anchors getsockname.__qualname__.__eq__ as a standalone under
# sockmethod127. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra127.getsockname_qualname_eq:
  description: "socket.socket.getsockname.__qualname__.__eq__('socket.getsockname') == True — getsockname qualname is 'socket.getsockname' (18 chars); returns socket's own address; C-level method_descriptor; extra124 anchors connect/bind/recv qualnames; first standalone for getsockname qualname under sockmethod127"
  category: method_qualnames
  kind: python_call_eq
  function: "socket.getsockname.__qualname__.__eq__"
  args: ["socket.getsockname"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.recv_into.__qualname__.__eq__('socket.recv_into') — standalone
#
# socket.socket.recv_into.__qualname__ is 'socket.recv_into'. recv_into receives
# data directly into a pre-allocated buffer (such as a bytearray), avoiding a
# copy. It is a C-level method_descriptor from _socket.c. 'socket.recv_into' is
# 16 chars. recvfrom_into (20) is the 'from' variant with 4 extra chars. No prior
# socket spec anchors recv_into.__qualname__.__eq__ as a standalone under
# sockmethod127. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra127.recv_into_qualname_eq:
  description: "socket.socket.recv_into.__qualname__.__eq__('socket.recv_into') == True — recv_into qualname is 'socket.recv_into' (16 chars); receives into a pre-allocated buffer; C-level method_descriptor; recvfrom_into adds 'from' for 20 chars; no prior socket spec anchors recv_into qualname as standalone; first standalone under sockmethod127"
  category: method_qualnames
  kind: python_call_eq
  function: "socket.recv_into.__qualname__.__eq__"
  args: ["socket.recv_into"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.shutdown.__qualname__.__eq__('socket.shutdown') — standalone
#
# socket.socket.shutdown.__qualname__ is 'socket.shutdown'. shutdown partially
# or fully closes the socket's send and/or receive channels without releasing
# the socket descriptor (unlike close()). It takes a 'how' argument (SHUT_RD,
# SHUT_WR, or SHUT_RDWR). It is a C-level method_descriptor. 'socket.shutdown'
# is 15 chars, sharing this length with recvfrom. No prior socket spec anchors
# shutdown.__qualname__.__eq__ as a standalone under sockmethod127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra127.shutdown_qualname_eq:
  description: "socket.socket.shutdown.__qualname__.__eq__('socket.shutdown') == True — shutdown qualname is 'socket.shutdown' (15 chars); partially closes send/receive channels; C-level method_descriptor; shares length 15 with recvfrom; no prior socket spec anchors shutdown qualname as standalone; first standalone under sockmethod127"
  category: method_qualnames
  kind: python_call_eq
  function: "socket.shutdown.__qualname__.__eq__"
  args: ["socket.shutdown"]
  expected: true
