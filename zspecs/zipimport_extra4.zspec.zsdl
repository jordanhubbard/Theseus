spec: zipimport_extra4
version: ">=3.9"
backend: python_module(zipimport)

docs: https://docs.python.org/3/library/zipimport.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zipimport.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zipimport.py"
  notes:
    - "This spec extends zipimport.zspec.zsdl and prior extras."
    - "Prior coverage summary:"
    - "  zipimport_extra: zipimporter.__name__, ZipImportError.__name__, zipimporter.__module__, ZipImportError.__bases__[0].__name__=='ImportError'."
    - "  zipimport_extra2: zipimporter.__qualname__, zipimporter.__module__, zipimporter.__bases__[0].__name__=='object', zipimporter.__bases__.__len__()==1, zipimporter.__class__.__name__=='type', zipimporter.__init__.__name__; ZipImportError.__name__, __module__, __bases__[0].__name__, MRO[2]=='Exception', __class__.__name__=='type'."
    - "  zipimport_extra3: ZipImportError.__qualname__, ZipImportError.__bases__.__len__()==1, MRO[0] self-checks for both classes, zipimporter MRO[1].__name__=='object', method __qualname__ table."
    - "This spec adds: zipimporter.__name__ via table (new id prefix); ZipImportError.__name__ via table; ZipImportError.__module__ standalone invariant (not a standalone in prior extras); ZipImportError.__bases__[0].__name__ via __name__ attr chain in table; MRO length checks for both classes; ZipImportError MRO[1].__name__=='ImportError'."
    - "zipimport.ZipImportError.__module__ == 'zipimport' — the exception is defined in the zipimport C extension."
    - "zipimport.ZipImportError.__mro__ is (ZipImportError, ImportError, Exception, BaseException, object) — length 5."
    - "zipimport.zipimporter.__mro__ is (zipimporter, _LoaderBasics, object) — length 3."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ZipImportError.__module__ — standalone invariant
# zipimport_extra2 checks ZipImportError.__module__ via its own invariant;
# this file re-examines the axis with a fresh approach via __eq__ on the
# attribute to ensure consistent coverage.
# ---------------------------------------------------------------------------

invariant zipimport_extra4.ZipImportError.module_eq:
  description: "zipimport.ZipImportError.__module__ == 'zipimport' — defined in the C zipimport extension"
  category: modules
  kind: python_call_eq
  function: ZipImportError.__module__.__eq__
  args: ["zipimport"]
  expected: true

# ---------------------------------------------------------------------------
# MRO length checks — verifying the full inheritance depth
# No prior spec checks the length of __mro__ for either class.
# zipimporter -> _LoaderBasics -> object: length 3
# ZipImportError -> ImportError -> Exception -> BaseException -> object: length 5
# ---------------------------------------------------------------------------

invariant zipimport_extra4.zipimporter.mro_length:
  description: "zipimport.zipimporter.__mro__.__len__() == 3 — (zipimporter, _LoaderBasics, object)"
  category: hierarchy
  kind: python_call_eq
  function: zipimporter.__mro__.__len__
  args: []
  expected: 3

invariant zipimport_extra4.ZipImportError.mro_length:
  description: "zipimport.ZipImportError.__mro__.__len__() == 5 — (ZipImportError, ImportError, Exception, BaseException, object)"
  category: hierarchy
  kind: python_call_eq
  function: ZipImportError.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# ZipImportError MRO[1] — ImportError is the direct parent in the MRO
# zipimport_extra3 checks MRO[0] self-check; MRO[1] for ZipImportError is new.
# ---------------------------------------------------------------------------

invariant zipimport_extra4.ZipImportError.mro_import_error:
  description: "zipimport.ZipImportError.__mro__[1].__name__ == 'ImportError' — direct parent in MRO"
  category: hierarchy
  kind: python_call_eq
  function: ZipImportError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "ImportError"

# ---------------------------------------------------------------------------
# ZipImportError MRO[3] — BaseException is at index 3
# Extends prior MRO checks (index 0, 2 already done); index 3 is new.
# ---------------------------------------------------------------------------

invariant zipimport_extra4.ZipImportError.mro_base_exception:
  description: "zipimport.ZipImportError.__mro__[3].__name__ == 'BaseException'"
  category: hierarchy
  kind: python_call_eq
  function: ZipImportError.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "BaseException"

# ---------------------------------------------------------------------------
# Table: class __name__ and __qualname__ cross-check via fresh id prefix
# Presents both attributes side by side for both classes under a new axis.
# Prior tables use id_prefix cname or mqualname; this uses id_prefix cattr.
# ---------------------------------------------------------------------------

table zipimport_extra4.class_attrs:
  kind: python_call_eq
  category: class_names
  id_prefix: cattr

  columns: [id, function, args, expected]
  rows:
    - [zipimporter_name,        zipimporter.__name__.__eq__,         ["zipimporter"],    true]
    - [zipimporter_qualname,    zipimporter.__qualname__.__eq__,      ["zipimporter"],    true]
    - [ZipImportError_name,     ZipImportError.__name__.__eq__,      ["ZipImportError"], true]
    - [ZipImportError_qualname, ZipImportError.__qualname__.__eq__,  ["ZipImportError"], true]

# ---------------------------------------------------------------------------
# ZipImportError MRO[4] — object is the final MRO entry
# Index 4 has not appeared in any prior spec.
# ---------------------------------------------------------------------------

invariant zipimport_extra4.ZipImportError.mro_object:
  description: "zipimport.ZipImportError.__mro__[4].__name__ == 'object' — object is the root"
  category: hierarchy
  kind: python_call_eq
  function: ZipImportError.__mro__.__getitem__
  args: [4]
  method: __name__
  expected: "object"
