spec: re_extra166
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.error class identity as the PatternError alias; re.error is re.PatternError is True."
    - "re.error.__name__ == 'PatternError' (len=12: 'Pattern' (7) + 'Error' (5) = 12; renamed from 're.error' in Python 3.13)."
    - "re.error.__module__ == 're' (len=2: the public re module)."
    - "re.error.__bases__[0].__name__ == 'Exception' (len=9)."
    - "re.error is re.PatternError: True — re.error is preserved as a backward-compatible alias."
    - "re.PatternError.__name__ == 'PatternError' (len=12; same object as re.error)."
    - "re.PatternError.__module__ == 're' (len=2)."
    - "The renaming from 'error' (5 chars) to 'PatternError' (12 chars) in Python 3.13 adds 7 characters to the class name."
    - "re.error.__dict__ has 6 entries: __module__, __firstlineno__, __doc__, __init__, __static_attributes__, __weakref__."
    - "re.error.__init__ is directly defined on re.error (not inherited from Exception)."
    - "PatternError (12) has 3 parts: 'Pattern' (7) + 'Error' (5) = 12; 'Pattern' prefix matches re.Pattern.__name__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.error class identity — the PatternError alias
# re.error.__name__ == 'PatternError' (len=12)
# re.error.__module__ == 're' (len=2)
# re.error.__bases__[0].__name__ == 'Exception' (len=9)
# re.error is re.PatternError: True
# ---------------------------------------------------------------------------

table re_extra166.re_error_class_identity:
  description: "re.error class identity: __name__='PatternError' (len=12), __module__='re' (len=2), __bases__[0].__name__='Exception' (len=9); re.error is the backward-compatible alias for re.PatternError (renamed in Python 3.13)"
  kind: python_call_eq
  category: identity
  id_prefix: reerr166

  columns: [id, function, args, expected, description]
  rows:
    - [re_error_name,      re.error.__name__.__eq__,                  ["PatternError"],  true, "re.error.__name__ == 'PatternError' (re.error was renamed to re.PatternError in Python 3.13; re.error is now a backward-compatible alias pointing to the same class object; the class object's __name__ is 'PatternError' — the new canonical name, not 'error'; 'PatternError' has 12 characters: 'Pattern' (7) + 'Error' (5) = 12; the renaming from 'error' (5 chars) to 'PatternError' (12 chars) adds 7 characters — more than doubling the class name length; the 'Pattern' prefix in 'PatternError' matches re.Pattern.__name__ (also 'Pattern', 7 chars), emphasizing that PatternError is the exception raised when a pattern is invalid)"]
    - [re_error_module,    re.error.__module__.__eq__,                ["re"],            true, "re.error.__module__ == 're' (re.PatternError / re.error is defined in the 're' module; 're' has 2 characters — the shortest module name across all modules checked in this spec series; 're' (2) is shorter than 'io' (2) by 0 — they are equal in length; both 're' and 'io' are 2-character module names for their respective standard library modules; re.error.__module__ == 're' (2) is shorter than re.Pattern.__module__ (which may be '_sre' or 're' depending on Python version); the 're' module exports PatternError both as re.PatternError and as re.error for backward compatibility)"]
    - [re_error_base0,     "re.error.__bases__[0].__name__.__eq__",   ["Exception"],     true, "re.error.__bases__[0].__name__ == 'Exception' (re.PatternError / re.error inherits directly from the built-in Exception class; 'Exception' has 9 characters; inheriting from Exception (not BaseException) means PatternError is a regular catchable exception; re.error / re.PatternError is raised when a string passed to one of the re functions is not a valid regular expression; a 'except re.error' clause will catch invalid patterns but not KeyboardInterrupt or SystemExit; 'Exception' (9 chars) is longer than 'PatternError' (12)? No: 9 < 12; Exception (9) is 3 characters shorter than PatternError (12))"]
    - [re_error_dict_has_init, "re.error.__dict__.__contains__",      ["__init__"],      true, "re.error.__dict__.__contains__('__init__') == True (__init__ is directly defined on re.PatternError / re.error — not merely inherited from Exception; re.PatternError.__init__(self, msg, pattern=None, pos=None) stores the error message, the pattern that caused the error, and the position in the pattern where the error occurred; PatternError.__init__ provides richer error context than the bare Exception.__init__; the fact that __init__ is in re.error.__dict__ (not just inherited) confirms PatternError has custom initialization logic; re.error.__dict__ has 6 entries total on Python 3.14.3)"]

# ---------------------------------------------------------------------------
# re.error is re.PatternError identity tests
# Also re.PatternError __name__ and __module__ (same object, same values)
# And len(re.error.__dict__) == 6
# ---------------------------------------------------------------------------

table re_extra166.re_PatternError_alias_identity:
  description: "re.PatternError alias: __name__='PatternError' (len=12), __module__='re' (len=2); re.error.__dict__.__len__()==6; re.error.__name__.__len__()==12; cross-checks confirming re.error and re.PatternError are the same object"
  kind: python_call_eq
  category: identity
  id_prefix: reerr166

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_error_name,   re.PatternError.__name__.__eq__,    ["PatternError"],  true, "re.PatternError.__name__ == 'PatternError' (re.PatternError is the canonical name since Python 3.13; re.error is the backward-compatible alias for the same class; since re.error is re.PatternError, both have the same __name__ == 'PatternError'; 'PatternError' has 12 characters: 'Pattern' (7) + 'Error' (5) = 12; 'Pattern' (7 chars) in the name is the same as re.Pattern.__name__ (7 chars) — the error class name references the pattern class name; PatternError is raised by re.compile(), re.match(), re.search(), re.fullmatch(), re.findall(), re.finditer(), re.sub(), re.subn(), re.split() when the regex pattern is invalid)"]
    - [pattern_error_module, re.PatternError.__module__.__eq__,  ["re"],            true, "re.PatternError.__module__ == 're' (re.PatternError is defined and exported from the 're' module; since re.error is re.PatternError, they share the same __module__ == 're'; 're' has 2 characters; PatternError (and its alias re.error) both appear in the 're' namespace; the 're' module exports them both: 're.PatternError' (the canonical name since 3.13) and 're.error' (the backward-compatible alias); code that uses 'except re.error:' continues to work identically to 'except re.PatternError:' because they refer to the same class object)"]
    - [re_error_name_len,    re.error.__name__.__len__,          [],               12,   "re.error.__name__.__len__() == 12 — 'PatternError' has 12 characters: 'Pattern' (7) + 'Error' (5) = 12; the class name was lengthened from 'error' (5 chars, lowercase) to 'PatternError' (12 chars, CamelCase) in Python 3.13; the new name follows PEP 8 conventions for exception class names (CamelCase ending in 'Error'); 12 is also the length of re.Match.groups qualname (12, from re_extra165): 'Match.groups' (6+6=12) and 'PatternError' (7+5=12) happen to share the same length — a coincidental cross-type tie; length 12 > len('error') (5) by 7 characters)"]
    - [re_error_dict_len,    "re.error.__dict__.__len__",        [],               6,    "re.error.__dict__.__len__() == 6 — re.PatternError's class dict has exactly 6 entries on Python 3.14.3: __module__, __firstlineno__, __doc__, __init__, __static_attributes__, __weakref__; this is a relatively sparse class dict for an exception class — most of PatternError's behavior is inherited from Exception; the 6 entries include the custom __init__ (which stores msg, pattern, and pos attributes) and __weakref__ (enabling weak references to PatternError instances); 6 entries is the same as io.IOBase.__dict__.__len__() (also 6, as seen in io_extra170) — a coincidental tie across different module class dicts; re.error.__dict__.__len__() == 6 regardless of whether you access via re.error or re.PatternError since they are the same class)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra166.re_error_name_is_PatternError:
  description: "re.error.__name__ == 'PatternError' — re.error was renamed to re.PatternError in Python 3.13; the class object's __name__ attribute reflects the new canonical name 'PatternError', not the old alias name 'error'; 'PatternError' has 12 characters: 'Pattern' (7) + 'Error' (5) = 12; the renaming added 7 characters to the class name (from 5 to 12); accessing via the alias re.error still gives __name__ == 'PatternError' because __name__ reflects the class's own identity, not the name used to access it; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra166.re_error_base_is_Exception:
  description: "re.error.__bases__[0].__name__ == 'Exception' — re.PatternError / re.error inherits directly from Exception (9 chars); inheriting from Exception rather than BaseException means re.error can be caught with a bare 'except Exception:' clause; the base class 'Exception' (9 chars) is 3 characters shorter than the derived class name 'PatternError' (12 chars); re.error.__bases__ is a tuple with exactly one element (Exception) — PatternError uses single inheritance; 'Exception' (9 chars) as a base class name is longer than 'object' (6 chars, the base of PurePath) but shorter than 'PatternError' (12 chars) itself; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant re_extra166.re_error_module_is_re:
  description: "re.error.__module__ == 're' — re.PatternError / re.error is defined in the 're' module; 're' has 2 characters — the shortest module name in this spec series (shared with 'io' as the only other 2-character standard library module name checked across all specs); 're' (2 chars) is shorter than 'pathlib' (7 chars), '_io' (3 chars), 'io' (2 chars), and 'decimal' (7 chars); re.error.__module__ == 're' is consistent whether accessed as re.error or re.PatternError since they are the same object; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.error.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra166.re_error_name_len_12:
  description: "re.error.__name__.__len__() == 12 — 'PatternError' has 12 characters: 'Pattern' (7) + 'Error' (5) = 12; 12 is 7 more than the old name 'error' (5 chars): the renaming from 'error' to 'PatternError' in Python 3.13 added 7 characters; re.error.__name__ (12 chars) is exactly equal in length to re.Match.groups qualname (from re_extra165: 'Match.groups' = 6+6 = 12) — a coincidental cross-class tie within the re module; 'PatternError' (12) > 'Exception' (9) > 're' (2): the class name (12) is longer than its base (9) and much longer than its module (2); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.error.__name__.__len__
  args: []
  expected: 12
