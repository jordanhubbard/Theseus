spec: pathlib_extra120
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra119.zspec.zsdl."
    - "This spec covers: pathlib.PurePath comparison operator qualname STRING equality for __le__, __gt__, __ge__, and PurePath method qualname string equality for with_segments and full_match."
    - "pathlib_extra43 covered PurePath.__le__/__gt__/__ge__ qualname LENGTHS via __qualname__.__len__(); this spec covers the qualname STRING EQUALITY via direct attribute access."
    - "pathlib_extra51 covered PurePath.with_segments qualname LENGTH; this spec covers the qualname STRING EQUALITY."
    - "pathlib_extra44 covered PurePath.full_match qualname LENGTH; this spec covers the qualname STRING EQUALITY."
    - "PurePath.__le__.__qualname__ == 'PurePath.__le__' (len 15); type 'function'."
    - "PurePath.__gt__.__qualname__ == 'PurePath.__gt__' (len 15); type 'function'."
    - "PurePath.__ge__.__qualname__ == 'PurePath.__ge__' (len 15); type 'function'."
    - "PurePath.with_segments.__qualname__ == 'PurePath.with_segments' (len 22); type 'function'."
    - "PurePath.full_match.__qualname__ == 'PurePath.full_match' (len 19); type 'function'."
    - "All five are pure Python functions defined on PurePath using the 'PurePath.' prefix."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath.__le__, __gt__, __ge__ qualname string equality
# All three comparison operators are pure Python functions defined on PurePath.
# Each has qualname 'PurePath.__le__', 'PurePath.__gt__', 'PurePath.__ge__' (15 chars).
# pathlib_extra43 covered their qualname LENGTHS via __qualname__.__len__() == 15.
# pathlib_extra42 covered __eq__.__qualname__ and __lt__.__qualname__ equality.
# This spec covers the remaining three comparison operator qualname STRING EQUALITY.
# 'PurePath.' prefix (9 chars) + '__le__'/'__gt__'/'__ge__' (6 chars each) == 15.
# ---------------------------------------------------------------------------

table pathlib_extra120.PurePath_comparison_operator_qualname_equality:
  description: "pathlib.PurePath.__le__ qualname='PurePath.__le__'(15), __gt__ qualname='PurePath.__gt__'(15), __ge__ qualname='PurePath.__ge__'(15); all type 'function'; string equality via direct attribute access"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibcmp120a

  columns: [id, function, args, expected, description]
  rows:
    - [le_type,       "PurePath.__le__.__class__.__name__.__eq__",    ["function"],        true,  "type(pathlib.PurePath.__le__).__name__ == 'function' (pure Python function defined on PurePath)"]
    - [le_qn_eq,      "PurePath.__le__.__qualname__.__eq__",          ["PurePath.__le__"], true,  "pathlib.PurePath.__le__.__qualname__ == 'PurePath.__le__' (15 chars; less-than-or-equal comparison operator)"]
    - [le_qn_len,     "PurePath.__le__.__qualname__.__len__",         [],                  15,    "pathlib.PurePath.__le__.__qualname__.__len__() == 15 ('PurePath.'(9)+'__le__'(6)==15)"]
    - [gt_type,       "PurePath.__gt__.__class__.__name__.__eq__",    ["function"],        true,  "type(pathlib.PurePath.__gt__).__name__ == 'function' (pure Python function defined on PurePath)"]
    - [gt_qn_eq,      "PurePath.__gt__.__qualname__.__eq__",          ["PurePath.__gt__"], true,  "pathlib.PurePath.__gt__.__qualname__ == 'PurePath.__gt__' (15 chars; greater-than comparison operator)"]
    - [gt_qn_len,     "PurePath.__gt__.__qualname__.__len__",         [],                  15,    "pathlib.PurePath.__gt__.__qualname__.__len__() == 15 ('PurePath.'(9)+'__gt__'(6)==15)"]
    - [ge_type,       "PurePath.__ge__.__class__.__name__.__eq__",    ["function"],        true,  "type(pathlib.PurePath.__ge__).__name__ == 'function' (pure Python function defined on PurePath)"]
    - [ge_qn_eq,      "PurePath.__ge__.__qualname__.__eq__",          ["PurePath.__ge__"], true,  "pathlib.PurePath.__ge__.__qualname__ == 'PurePath.__ge__' (15 chars; greater-than-or-equal comparison operator)"]
    - [le_eq_gt_len,  "PurePath.__le__.__qualname__.__len__.__eq__",  [15],                true,  "len('PurePath.__le__') == len('PurePath.__gt__') == len('PurePath.__ge__') == 15 (all share identical qualname length)"]
    - [le_ne_gt,      "PurePath.__le__.__qualname__.__eq__",          ["PurePath.__gt__"], false, "pathlib.PurePath.__le__.__qualname__ != 'PurePath.__gt__' (distinct qualname strings despite equal lengths)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath.with_segments and pathlib.PurePath.full_match qualname equality
# with_segments: 'PurePath.with_segments' (22 chars); added in Python 3.12.
#   Creates a new path from the given segments using the same class.
# full_match: 'PurePath.full_match' (19 chars); added in Python 3.12.
#   Tests whether the path matches a glob pattern against its full path.
# pathlib_extra51 covered with_segments qualname LENGTH (22).
# pathlib_extra44 covered full_match qualname LENGTH (19).
# This spec covers both qualname STRING EQUALITY via direct attribute access.
# ---------------------------------------------------------------------------

table pathlib_extra120.PurePath_with_segments_full_match_qualname_equality:
  description: "pathlib.PurePath.with_segments qualname='PurePath.with_segments'(22), full_match qualname='PurePath.full_match'(19); both type 'function'; added Python 3.12; string equality via direct attribute access"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibcmp120b

  columns: [id, function, args, expected, description]
  rows:
    - [ws_type,       "PurePath.with_segments.__class__.__name__.__eq__",  ["function"],                 true,  "type(pathlib.PurePath.with_segments).__name__ == 'function' (pure Python function; added in Python 3.12)"]
    - [ws_qn_eq,      "PurePath.with_segments.__qualname__.__eq__",        ["PurePath.with_segments"],   true,  "pathlib.PurePath.with_segments.__qualname__ == 'PurePath.with_segments' (22 chars; creates new path from segments using the calling class)"]
    - [ws_qn_len,     "PurePath.with_segments.__qualname__.__len__",       [],                           22,    "pathlib.PurePath.with_segments.__qualname__.__len__() == 22 ('PurePath.'(9)+'with_segments'(13)==22)"]
    - [fm_type,       "PurePath.full_match.__class__.__name__.__eq__",     ["function"],                 true,  "type(pathlib.PurePath.full_match).__name__ == 'function' (pure Python function; added in Python 3.12)"]
    - [fm_qn_eq,      "PurePath.full_match.__qualname__.__eq__",           ["PurePath.full_match"],      true,  "pathlib.PurePath.full_match.__qualname__ == 'PurePath.full_match' (19 chars; tests path against glob covering full path, not just filename)"]
    - [fm_qn_len,     "PurePath.full_match.__qualname__.__len__",          [],                           19,    "pathlib.PurePath.full_match.__qualname__.__len__() == 19 ('PurePath.'(9)+'full_match'(10)==19)"]
    - [ws_gt_fm,      "PurePath.with_segments.__qualname__.__len__.__gt__", [19],                        true,  "len('PurePath.with_segments') > len('PurePath.full_match') (22 > 19; with_segments is 3 chars longer than full_match)"]
    - [ws_ne_fm,      "PurePath.with_segments.__qualname__.__eq__",        ["PurePath.full_match"],      false, "pathlib.PurePath.with_segments.__qualname__ != 'PurePath.full_match' (distinct qualnames; with_segments constructs paths, full_match tests patterns)"]

# ---------------------------------------------------------------------------
# PurePath comparison operator and modern-method qualname ordering summary
# __le__/__gt__/__ge__ all share length 15; same as __eq__ and __lt__ from prior specs.
# full_match(19) > __le__/__gt__/__ge__(15); with_segments(22) > full_match(19).
# The 'PurePath.' prefix (9 chars) applies to all methods defined on PurePath.
# ---------------------------------------------------------------------------

table pathlib_extra120.PurePath_qualname_length_ordering:
  description: "pathlib.PurePath qualname length ordering: __le__/__gt__/__ge__ all 15; full_match 19; with_segments 22; all share 'PurePath.' prefix; with_segments is longest of the group"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibcmp120c

  columns: [id, function, args, expected, description]
  rows:
    - [ge_ne_ws,      "PurePath.__ge__.__qualname__.__eq__",           ["PurePath.with_segments"], false, "pathlib.PurePath.__ge__.__qualname__ != 'PurePath.with_segments' (15 chars vs 22 chars; very different lengths)"]
    - [fm_gt_le,      "PurePath.full_match.__qualname__.__len__.__gt__", [15],                    true,  "len('PurePath.full_match') > len('PurePath.__le__') (19 > 15; full_match is 4 chars longer than __le__)"]
    - [ws_gt_le,      "PurePath.with_segments.__qualname__.__len__.__gt__", [15],                 true,  "len('PurePath.with_segments') > len('PurePath.__le__') (22 > 15; with_segments is 7 chars longer than __le__)"]
    - [ws_prefix,     "PurePath.with_segments.__qualname__.__contains__", ["PurePath."],          true,  "pathlib.PurePath.with_segments.__qualname__ contains 'PurePath.' prefix (all PurePath methods use this 9-char prefix)"]
    - [fm_prefix,     "PurePath.full_match.__qualname__.__contains__", ["PurePath."],             true,  "pathlib.PurePath.full_match.__qualname__ contains 'PurePath.' prefix (same prefix as all PurePath-defined methods)"]
    - [ge_contains_ge, "PurePath.__ge__.__qualname__.__contains__",    ["__ge__"],                true,  "pathlib.PurePath.__ge__.__qualname__ contains '__ge__' (double-underscore-framed name within the qualname string)"]
    - [gt_ne_ge,      "PurePath.__gt__.__qualname__.__eq__",           ["PurePath.__ge__"],       false, "pathlib.PurePath.__gt__.__qualname__ != 'PurePath.__ge__' (distinct despite identical lengths; differ by 't' vs 'e')"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra120.PurePath.__le__qualname_eq:
  description: "pathlib.PurePath.__le__.__qualname__ == 'PurePath.__le__' (length 15; type is 'function'; __le__ implements the less-than-or-equal comparison operator for paths; it is defined on PurePath so all Path subclasses inherit it; pathlib_extra43 covered the qualname length via __qualname__.__len__() == 15; this spec covers the string equality via direct attribute access __qualname__.__eq__(); both approaches resolve to the same descriptor object but use distinct ZSDL function paths)"
  category: qualnames
  kind: python_call_eq
  function: "PurePath.__le__.__qualname__.__eq__"
  args: ["PurePath.__le__"]
  expected: true

invariant pathlib_extra120.PurePath.__gt__qualname_eq:
  description: "pathlib.PurePath.__gt__.__qualname__ == 'PurePath.__gt__' (length 15; type is 'function'; __gt__ implements the greater-than comparison operator for paths; pathlib_extra43 covered the qualname length (15) but not the string equality; __gt__ and __lt__ are mirror operators — __gt__ returns NotImplemented if the other operand is not a PurePath; all five comparison operators __eq__, __lt__, __le__, __gt__, __ge__ are defined on PurePath with the 'PurePath.' prefix)"
  category: qualnames
  kind: python_call_eq
  function: "PurePath.__gt__.__qualname__.__eq__"
  args: ["PurePath.__gt__"]
  expected: true

invariant pathlib_extra120.PurePath.__ge__qualname_eq:
  description: "pathlib.PurePath.__ge__.__qualname__ == 'PurePath.__ge__' (length 15; type is 'function'; __ge__ implements the greater-than-or-equal comparison operator for paths; it rounds out the set: __eq__(15), __lt__(15), __le__(15), __gt__(15), __ge__(15) — all five pure comparison operators on PurePath share qualname length 15 and the 'PurePath.' prefix; pathlib comparisons are case-sensitive on POSIX and case-insensitive on Windows)"
  category: qualnames
  kind: python_call_eq
  function: "PurePath.__ge__.__qualname__.__eq__"
  args: ["PurePath.__ge__"]
  expected: true

invariant pathlib_extra120.PurePath.with_segments_qualname_eq:
  description: "pathlib.PurePath.with_segments.__qualname__ == 'PurePath.with_segments' (length 22; type is 'function'; with_segments() was added in Python 3.12 as a hook for subclasses to control how new paths are constructed — it receives path segments and returns a new path object; 'PurePath.'(9) + 'with_segments'(13) == 22; pathlib_extra51 covered the qualname length via __qualname__.__len__() == 22; this spec covers the string equality via direct attribute access)"
  category: qualnames
  kind: python_call_eq
  function: "PurePath.with_segments.__qualname__.__eq__"
  args: ["PurePath.with_segments"]
  expected: true

invariant pathlib_extra120.PurePath.full_match_qualname_eq:
  description: "pathlib.PurePath.full_match.__qualname__ == 'PurePath.full_match' (length 19; type is 'function'; full_match() was added in Python 3.12 and tests whether the entire path string matches a given glob pattern, unlike match() which only matches against path suffixes; 'PurePath.'(9) + 'full_match'(10) == 19; pathlib_extra44 covered the qualname length via __qualname__.__len__() == 19; this spec covers the string equality via direct attribute access)"
  category: qualnames
  kind: python_call_eq
  function: "PurePath.full_match.__qualname__.__eq__"
  args: ["PurePath.full_match"]
  expected: true

