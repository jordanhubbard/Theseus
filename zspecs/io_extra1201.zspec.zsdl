spec: io_extra1201
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io class __bases__.__len__ checks for IOBase, RawIOBase, BufferedIOBase, TextIOBase, FileIO, BytesIO, StringIO, UnsupportedOperation; __mro__.__len__ checks for FileIO, BytesIO, StringIO, TextIOWrapper, UnsupportedOperation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks io.IOBase.__bases__.__len__, io.RawIOBase.__bases__.__len__, io.BufferedIOBase.__bases__.__len__, io.TextIOBase.__bases__.__len__, io.FileIO.__bases__.__len__, io.BytesIO.__bases__.__len__, io.StringIO.__bases__.__len__, io.UnsupportedOperation.__bases__.__len__; io.FileIO.__mro__.__len__, io.BytesIO.__mro__.__len__, io.StringIO.__mro__.__len__, io.TextIOWrapper.__mro__.__len__, io.UnsupportedOperation.__mro__.__len__; none of these __bases__.__len__ or __mro__.__len__ value checks were covered in _extra1171 or _extra1186"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1201.bases_len_abstract_classes:
  description: "io abstract class __bases__.__len__ checks — IOBase inherits from one base; RawIOBase, BufferedIOBase, TextIOBase from two"
  kind: python_call_eq
  category: bases_len_abstract_classes
  id_prefix: io1201ab
  columns: [id, function, args, expected]
  rows:
    - [io1201ab001, io.IOBase.__bases__.__len__,       [], 1]
    - [io1201ab002, io.RawIOBase.__bases__.__len__,    [], 2]
    - [io1201ab003, io.BufferedIOBase.__bases__.__len__, [], 2]
    - [io1201ab004, io.TextIOBase.__bases__.__len__,   [], 2]
    - [io1201ab005, io.IOBase.__bases__.__len__.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [io1201ab006, io.RawIOBase.__bases__.__len__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [io1201ab007, io.IOBase.__bases__.__len__.__class__.__name__.__eq__,    ["function"], false]
    - [io1201ab008, io.BufferedIOBase.__bases__.__len__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

