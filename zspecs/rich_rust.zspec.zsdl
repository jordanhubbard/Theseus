spec: rich_rust
version: ">=3.9"
backend: rust_module(rich_rust)

docs: https://rich.readthedocs.io/en/stable/markup.html

provenance:
  derived_from:
    - "https://rich.readthedocs.io/ — Rich library documentation"
  not_derived_from:
    - "Rich source: rich/markup.py"
  notes:
    - "Clean-room Rust reimplementation of Rich markup utilities, exposed via PyO3."
    - "escape is imported from rich.markup."
    - "escape('[bold]hello[/bold]') == '\\\\[bold]hello\\\\[/bold]' — escapes [ with \\\\[."
    - "escape('plain text') == 'plain text' — no markup to escape."
    - "escape('hello [world]') == 'hello \\\\[world]'."
    - "Text is imported from rich.text."
    - "Text.from_markup('[bold]hello[/bold]').plain == 'hello' — strips markup tags."
    - "All test vectors verified against Rich 14.3.3."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# rich.markup.escape — escape Rich markup brackets
table rich_rust.escape.vectors:
  kind: python_call_eq
  category: escape
  id_prefix: rich_esc
  function: escape

  columns: [id, args, expected]
  rows:
    - [plain,       ["plain text"],              "plain text"]
    - [bold_tag,    ["[bold]hello[/bold]"],      "\\[bold]hello\\[/bold]"]
    - [single_tag,  ["hello [world]"],           "hello \\[world]"]
    - [red_tag,     ["[red]danger[/red]"],       "\\[red]danger\\[/red]"]
    - [empty,       [""],                        ""]

# rich.text.Text.from_markup — parse markup and expose plain text
table rich_rust.text_from_markup.plain:
  kind: python_call_eq
  category: text
  id_prefix: rich_txt
  function: Text.from_markup
  method: plain

  columns: [id, args, expected]
  rows:
    - [bold,    ["[bold]hello[/bold]"],              "hello"]
    - [red,     ["[red]danger[/red]"],               "danger"]
    - [plain,   ["just text"],                       "just text"]
    - [nested,  ["[bold][red]bright[/red][/bold]"],  "bright"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T22:41:14Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
