spec: glob_extra11
version: ">=3.9"
backend: python_module(glob)

docs: https://docs.python.org/3/library/glob.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/glob.html — Python glob module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/glob.py"
    - "glob_extra10.zspec.zsdl — covers prior glob module attributes"
  notes:
    - "This spec extends glob.zspec.zsdl and all prior glob_extra specs through glob_extra10.zspec.zsdl."
    - "glob.glob.__module__ == 'glob' — function is defined in the glob module itself; verified at runtime."
    - "glob.iglob.__module__ == 'glob' — iterator variant lives in the same module; verified at runtime."
    - "glob.escape.__module__ == 'glob' — escape helper is also in glob; verified at runtime."
    - "glob.glob.__qualname__ == 'glob' — simple top-level function, qualname equals __name__; verified at runtime."
    - "glob.iglob.__qualname__ == 'iglob' — top-level function; verified at runtime."
    - "glob.escape.__qualname__ == 'escape' — top-level function; verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ table for glob public functions
#
# All three public glob functions (glob, iglob, escape) are defined directly
# in the glob module. This table groups them for a single coherent check.
# No prior glob_extra spec covers __module__ for all three in one table.
# ---------------------------------------------------------------------------

table glob_extra11.function_modules:
  description: "__module__ for glob public functions (all should be 'glob')"
  kind: python_call_eq
  category: module_identity
  id_prefix: globmod11

  columns: [id, function, args, expected]
  rows:
    - [glob,   "glob.__module__.__eq__",   ["glob"], true]
    - [iglob,  "iglob.__module__.__eq__",  ["glob"], true]
    - [escape, "escape.__module__.__eq__", ["glob"], true]

# ---------------------------------------------------------------------------
# Standalone __qualname__ invariants for glob public functions
#
# For top-level module functions, __qualname__ equals the simple function name
# (no class prefix). These invariants confirm each function is a plain
# module-level callable, not a nested or class method.
# ---------------------------------------------------------------------------

invariant glob_extra11.glob.qualname:
  description: "glob.glob.__qualname__ == 'glob' — top-level function, qualname equals function name"
  category: qualname
  kind: python_call_eq
  function: glob.__qualname__.__eq__
  args: ["glob"]
  expected: true

invariant glob_extra11.iglob.qualname:
  description: "glob.iglob.__qualname__ == 'iglob' — top-level function, qualname equals function name"
  category: qualname
  kind: python_call_eq
  function: iglob.__qualname__.__eq__
  args: ["iglob"]
  expected: true

invariant glob_extra11.escape.qualname:
  description: "glob.escape.__qualname__ == 'escape' — top-level function, qualname equals function name"
  category: qualname
  kind: python_call_eq
  function: escape.__qualname__.__eq__
  args: ["escape"]
  expected: true

invariant glob_extra11.glob.name:
  description: "glob.glob.__name__ == 'glob' — the function's simple name attribute"
  category: function_identity
  kind: python_call_eq
  function: glob.__name__.__eq__
  args: ["glob"]
  expected: true

invariant glob_extra11.iglob.name:
  description: "glob.iglob.__name__ == 'iglob' — the function's simple name attribute"
  category: function_identity
  kind: python_call_eq
  function: iglob.__name__.__eq__
  args: ["iglob"]
  expected: true

invariant glob_extra11.escape.name:
  description: "glob.escape.__name__ == 'escape' — the function's simple name attribute"
  category: function_identity
  kind: python_call_eq
  function: escape.__name__.__eq__
  args: ["escape"]
  expected: true
