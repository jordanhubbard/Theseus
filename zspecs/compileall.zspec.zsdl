spec: compileall
version: ">=3.2"
backend: python_module(compileall)

docs: https://docs.python.org/3/library/compileall.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/compileall.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "compileall source: Lib/compileall.py (PSF; source inspection permitted)"
  not_derived_from:
    - "compileall source: internal py_compile invocation details"
  notes:
    - "compileall.compile_file(fullname) compiles a single source file to bytecode (.pyc)."
    - "compileall.compile_dir(dir) recursively compiles all .py files under a directory."
    - "compileall.compile_path() compiles all source files found on sys.path."
    - "All three public functions live in the 'compileall' module (__module__ == 'compileall')."
    - "compile_file and compile_dir accept a 'quiet' keyword argument (0=verbose, 1=warnings, 2=silent)."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "compile_file and compile_dir return True on success, False if any file failed to compile. They do not raise on individual file compile errors by default — errors are printed to stderr and the function returns False."
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# Function name checks — compile_file, compile_dir, compile_path
# ---------------------------------------------------------------------------

table compileall.function_names:
  kind: python_call_eq
  category: names
  id_prefix: funcname

  columns: [id, function, args, expected]
  rows:
    - [compile_file, compile_file.__name__.__eq__, ["compile_file"], true]
    - [compile_dir,  compile_dir.__name__.__eq__,  ["compile_dir"],  true]
    - [compile_path, compile_path.__name__.__eq__,  ["compile_path"], true]

# ---------------------------------------------------------------------------
# Module checks — all three functions belong to the compileall module
# ---------------------------------------------------------------------------

table compileall.module_checks:
  kind: python_call_eq
  category: modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [compile_file_module, compile_file.__module__.__eq__, ["compileall"], true]
    - [compile_dir_module,  compile_dir.__module__.__eq__,  ["compileall"], true]
    - [compile_path_module, compile_path.__module__.__eq__, ["compileall"], true]

# ---------------------------------------------------------------------------
# Type checks — all three are plain Python functions
# ---------------------------------------------------------------------------

table compileall.type_checks:
  kind: python_call_eq
  category: types
  id_prefix: typecheck

  columns: [id, function, args, expected]
  rows:
    - [compile_file_is_function, compile_file.__class__.__name__.__eq__, ["function"], true]
    - [compile_dir_is_function,  compile_dir.__class__.__name__.__eq__,  ["function"], true]
    - [compile_path_is_function, compile_path.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# Docstring checks — each function has a docstring (type is str)
# ---------------------------------------------------------------------------

invariant compileall.compile_file.doc_is_str:
  description: "type(compileall.compile_file.__doc__).__name__ == 'str' — compile_file has a docstring"
  category: docs
  kind: python_call_eq
  function: compile_file.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant compileall.compile_dir.doc_is_str:
  description: "type(compileall.compile_dir.__doc__).__name__ == 'str' — compile_dir has a docstring"
  category: docs
  kind: python_call_eq
  function: compile_dir.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Qualified name checks — compile_file and compile_dir are module-level functions
# ---------------------------------------------------------------------------

invariant compileall.compile_file.qualname:
  description: "compileall.compile_file.__qualname__ == 'compile_file'"
  category: names
  kind: python_call_eq
  function: compile_file.__qualname__.__eq__
  args: ["compile_file"]
  expected: true

invariant compileall.compile_dir.qualname:
  description: "compileall.compile_dir.__qualname__ == 'compile_dir'"
  category: names
  kind: python_call_eq
  function: compile_dir.__qualname__.__eq__
  args: ["compile_dir"]
  expected: true
