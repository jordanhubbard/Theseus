spec: abc_extra871
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - abc
  not_derived_from:
    - typing
    - inspect
  notes:
    - abc module-level attributes and class __bases__ and __dict__ types
  created_at: "2026-04-12"

table abc_extra871.module_and_class_attributes:
  description: Verify abc module-level attributes and class __bases__ and __dict__ type identities
  kind: python_call_eq
  category: type_identity
  id_prefix: as871xx
  columns: [id, function, args, expected]
  rows:
    - [as871xx001, abc.__name__.__eq__, ["abc"], true]
    - [as871xx002, abc.__package__.__eq__, ["abc"], true]
    - [as871xx003, abc.__all__.__class__.__name__.__eq__, ["list"], true]
    - [as871xx004, abc.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true]
    - [as871xx005, abc.ABC.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [as871xx006, abc.ABCMeta.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [as871xx007, abc.ABC.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true]
    - [as871xx008, abc.ABC.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [as871xx009, abc.ABCMeta.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [as871xx010, abc.abstractmethod.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [as871xx011, abc.ABC.__subclasshook__.__qualname__.__eq__, ["ABC.__subclasshook__"], true]
    - [as871xx012, abc.abstractproperty.__bases__.__class__.__name__.__eq__, ["tuple"], true]
