spec: textwrap
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap documentation"
    - "Test vectors verified by running Python 3.12 textwrap module on macOS/Darwin 25.4.0, 2026-04-08"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "wrap(text, width) returns a list of strings, each at most width characters wide."
    - "fill(text, width) returns a single string of wrapped lines joined by newlines."
    - "dedent(text) removes any common leading whitespace from all lines."
    - "indent(text, prefix) adds prefix to the beginning of every non-empty line."
    - "shorten(text, width) collapses whitespace and truncates to width characters."
    - "TextWrapper(width=N).width is a plain attribute access, not a method call."
    - "wrap('', width) returns an empty list — empty input yields no wrapped lines."
  created_at: "2026-04-08T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# wrap() — returns list of strings
# ---------------------------------------------------------------------------

invariant textwrap.wrap.basic:
  description: "wrap('hello world foo bar', 10) splits at word boundaries within width"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["hello world foo bar", 10]
  expected: ["hello", "world foo", "bar"]

invariant textwrap.wrap.empty_string:
  description: "wrap('', 10) returns an empty list — no lines produced for empty input"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["", 10]
  expected: []

invariant textwrap.wrap.short_string_wide_width:
  description: "wrap('short', 80) returns a single-element list when the string fits in the width"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["short", 80]
  expected: ["short"]

invariant textwrap.wrap.multi_word_narrow:
  description: "wrap('a b c d e f g', 5) fits two-letter words into 5-char lines"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["a b c d e f g", 5]
  expected: ["a b c", "d e f", "g"]

invariant textwrap.wrap.single_word_fits:
  description: "wrap('hello world', 20) fits both words on one line"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["hello world", 20]
  expected: ["hello world"]

# ---------------------------------------------------------------------------
# fill() — returns single wrapped string
# ---------------------------------------------------------------------------

invariant textwrap.fill.basic:
  description: "fill('hello world', 5) wraps into two lines joined by newline"
  category: fill
  kind: python_call_eq
  function: fill
  args: ["hello world", 5]
  expected: "hello\nworld"

invariant textwrap.fill.wide_width:
  description: "fill('hello world foo', 10) wraps at word boundary"
  category: fill
  kind: python_call_eq
  function: fill
  args: ["hello world foo", 10]
  expected: "hello\nworld foo"

# ---------------------------------------------------------------------------
# dedent() — removes common leading whitespace
# ---------------------------------------------------------------------------

invariant textwrap.dedent.common_indent:
  description: "dedent('    hello\\n    world') removes the 4-space common indent"
  category: dedent
  kind: python_call_eq
  function: dedent
  args: ["    hello\n    world"]
  expected: "hello\nworld"

invariant textwrap.dedent.no_indent:
  description: "dedent('no indent') returns the string unchanged when there is no leading whitespace"
  category: dedent
  kind: python_call_eq
  function: dedent
  args: ["no indent"]
  expected: "no indent"

invariant textwrap.dedent.uniform_two_space:
  description: "dedent('  foo\\n  bar\\n  baz') removes 2-space common indent"
  category: dedent
  kind: python_call_eq
  function: dedent
  args: ["  foo\n  bar\n  baz"]
  expected: "foo\nbar\nbaz"

# ---------------------------------------------------------------------------
# indent() — adds prefix to lines
# ---------------------------------------------------------------------------

invariant textwrap.indent.basic:
  description: "indent('hello\\nworld', '>> ') prepends '>> ' to each line"
  category: indent
  kind: python_call_eq
  function: indent
  args: ["hello\nworld", ">> "]
  expected: ">> hello\n>> world"

invariant textwrap.indent.empty_string:
  description: "indent('', '--') returns empty string — no lines to prefix"
  category: indent
  kind: python_call_eq
  function: indent
  args: ["", "--"]
  expected: ""

invariant textwrap.indent.two_space_prefix:
  description: "indent('hello\\nworld', '  ') adds two-space indent to each line"
  category: indent
  kind: python_call_eq
  function: indent
  args: ["hello\nworld", "  "]
  expected: "  hello\n  world"

# ---------------------------------------------------------------------------
# shorten() — collapses whitespace and truncates with placeholder
# ---------------------------------------------------------------------------

invariant textwrap.shorten.truncates:
  description: "shorten('The quick brown fox', 15) truncates with default placeholder '[...]'"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["The quick brown fox", 15]
  expected: "The quick [...]"

invariant textwrap.shorten.fits_without_truncation:
  description: "shorten('short', 80) returns the string unchanged when it fits within width"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["short", 80]
  expected: "short"

# ---------------------------------------------------------------------------
# TextWrapper class — attribute access
# ---------------------------------------------------------------------------

invariant textwrap.TextWrapper.width_attr:
  description: "TextWrapper(width=40).width == 40 — constructor stores width as attribute"
  category: TextWrapper
  kind: python_call_eq
  function: TextWrapper
  kwargs: {width: 40}
  method: width
  expected: 40
