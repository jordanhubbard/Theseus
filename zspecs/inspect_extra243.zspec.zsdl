spec: inspect_extra243
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra242.zspec.zsdl — covers signature and Signature/Parameter class identity"
    - "inspect_extra241.zspec.zsdl — covers getsource and getfile identity"
    - "inspect_extra.zspec.zsdl — covers ismethod/isgenerator/iscoroutine/getsourcefile names and modules"
    - "inspect.zspec.zsdl — covers isfunction/isbuiltin/isclass/ismodule names"
  notes:
    - "This spec covers inspect.classify_class_attrs, inspect.getdoc, and inspect.cleandoc function identity contracts."
    - "inspect.classify_class_attrs.__name__ == 'classify_class_attrs' (len=20) — classify_class_attrs is a Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__module__ == 'inspect' (len=7) — classify_class_attrs is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__qualname__ == 'classify_class_attrs' (len=20) — same as __name__ for top-level function. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__class__.__name__ == 'function' — classify_class_attrs is a plain Python function. Verified with Python 3.14.3."
    - "inspect.getdoc.__name__ == 'getdoc' (len=6) — getdoc is a Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getdoc.__module__ == 'inspect' (len=7) — getdoc is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getdoc.__qualname__ == 'getdoc' (len=6) — same as __name__ for top-level function. Verified with Python 3.14.3."
    - "inspect.getdoc.__class__.__name__ == 'function' — getdoc is a plain Python function. Verified with Python 3.14.3."
    - "inspect.cleandoc.__name__ == 'cleandoc' (len=8) — cleandoc is a Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.cleandoc.__module__ == 'inspect' (len=7) — cleandoc is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.cleandoc.__qualname__ == 'cleandoc' (len=8) — same as __name__ for top-level function. Verified with Python 3.14.3."
    - "inspect.cleandoc.__class__.__name__ == 'function' — cleandoc is a plain Python function. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.classify_class_attrs function identity contracts
#
# inspect.classify_class_attrs.__name__ == 'classify_class_attrs' (len=20)
# inspect.classify_class_attrs.__module__ == 'inspect' (len=7)
# inspect.classify_class_attrs.__qualname__ == 'classify_class_attrs' (len=20)
# inspect.classify_class_attrs.__class__.__name__ == 'function'
# inspect.classify_class_attrs.__name__.__len__() == 20
#
# classify_class_attrs is a Python function in Lib/inspect.py. New to extra243.
# ---------------------------------------------------------------------------

table inspect_extra243.inspcls243_cca_identity:
  description: "inspect.classify_class_attrs function identity: name, module, qualname, class; new to extra243"
  kind: python_call_eq
  category: identity
  id_prefix: inspcls243

  columns: [id, function, args, expected, description]
  rows:
    - [cca_name_eq,
       classify_class_attrs.__name__.__eq__,
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__name__.__eq__('classify_class_attrs') == True — classify_class_attrs is a Python function in Lib/inspect.py; __name__ is 'classify_class_attrs' (len=20); new to extra243"]
    - [cca_name_len_20,
       classify_class_attrs.__name__.__len__,
       [],
       20,
       "inspect.classify_class_attrs.__name__.__len__() == 20 — 'classify_class_attrs' has exactly 20 characters; str.__len__() returns 20; new to extra243"]
    - [cca_module_eq,
       classify_class_attrs.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.classify_class_attrs.__module__.__eq__('inspect') == True — classify_class_attrs is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra243"]
    - [cca_module_len_7,
       classify_class_attrs.__module__.__len__,
       [],
       7,
       "inspect.classify_class_attrs.__module__.__len__() == 7 — 'inspect' has exactly 7 characters; str.__len__() returns 7; new to extra243"]
    - [cca_qualname_eq,
       classify_class_attrs.__qualname__.__eq__,
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__qualname__.__eq__('classify_class_attrs') == True — __qualname__ is 'classify_class_attrs' (len=20); same as __name__ for top-level function; new to extra243"]

# ---------------------------------------------------------------------------
# Table 2: inspect.classify_class_attrs class type and content checks
#
# inspect.classify_class_attrs.__class__.__name__ == 'function'
# inspect.classify_class_attrs.__name__.__contains__('classify') == True
# inspect.classify_class_attrs.__name__.__contains__('attrs') == True
# inspect.classify_class_attrs.__module__.__contains__('inspect') == True
# inspect.classify_class_attrs.__qualname__.__len__() == 20
#
# New to extra243.
# ---------------------------------------------------------------------------

table inspect_extra243.inspcls243_cca_class:
  description: "inspect.classify_class_attrs class type and name/module content checks; new to extra243"
  kind: python_call_eq
  category: identity
  id_prefix: inspcls243c

  columns: [id, function, args, expected, description]
  rows:
    - [cca_class_is_function,
       classify_class_attrs.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.classify_class_attrs.__class__.__name__.__eq__('function') == True — classify_class_attrs is a plain Python function; its __class__ is the built-in function type; new to extra243"]
    - [cca_name_contains_classify,
       classify_class_attrs.__name__.__contains__,
       ["classify"],
       true,
       "inspect.classify_class_attrs.__name__.__contains__('classify') == True — 'classify_class_attrs' contains the prefix 'classify'; new to extra243"]
    - [cca_name_contains_attrs,
       classify_class_attrs.__name__.__contains__,
       ["attrs"],
       true,
       "inspect.classify_class_attrs.__name__.__contains__('attrs') == True — 'classify_class_attrs' contains the suffix 'attrs'; new to extra243"]
    - [cca_module_contains_inspect,
       classify_class_attrs.__module__.__contains__,
       ["inspect"],
       true,
       "inspect.classify_class_attrs.__module__.__contains__('inspect') == True — 'inspect' contains the substring 'inspect'; new to extra243"]
    - [cca_qualname_len_20,
       classify_class_attrs.__qualname__.__len__,
       [],
       20,
       "inspect.classify_class_attrs.__qualname__.__len__() == 20 — 'classify_class_attrs' has exactly 20 characters; str.__len__() returns 20; new to extra243"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getdoc function identity contracts
#
# inspect.getdoc.__name__ == 'getdoc' (len=6)
# inspect.getdoc.__module__ == 'inspect' (len=7)
# inspect.getdoc.__qualname__ == 'getdoc' (len=6)
# inspect.getdoc.__class__.__name__ == 'function'
# inspect.getdoc.__name__.__len__() == 6
#
# getdoc is a Python function in Lib/inspect.py. New to extra243.
# ---------------------------------------------------------------------------

table inspect_extra243.inspcls243_getdoc_identity:
  description: "inspect.getdoc function identity: name, module, qualname, class; new to extra243"
  kind: python_call_eq
  category: identity
  id_prefix: inspcls243gd

  columns: [id, function, args, expected, description]
  rows:
    - [gd_name_eq,
       getdoc.__name__.__eq__,
       ["getdoc"],
       true,
       "inspect.getdoc.__name__.__eq__('getdoc') == True — getdoc is a Python function in Lib/inspect.py; __name__ is 'getdoc' (len=6); new to extra243"]
    - [gd_name_len_6,
       getdoc.__name__.__len__,
       [],
       6,
       "inspect.getdoc.__name__.__len__() == 6 — 'getdoc' has exactly 6 characters; str.__len__() returns 6; new to extra243"]
    - [gd_module_eq,
       getdoc.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getdoc.__module__.__eq__('inspect') == True — getdoc is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra243"]
    - [gd_qualname_eq,
       getdoc.__qualname__.__eq__,
       ["getdoc"],
       true,
       "inspect.getdoc.__qualname__.__eq__('getdoc') == True — __qualname__ is 'getdoc' (len=6); same as __name__ for top-level function; new to extra243"]
    - [gd_class_is_function,
       getdoc.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getdoc.__class__.__name__.__eq__('function') == True — getdoc is a plain Python function; its __class__ is the built-in function type; new to extra243"]

# ---------------------------------------------------------------------------
# Table 4: inspect.cleandoc function identity contracts
#
# inspect.cleandoc.__name__ == 'cleandoc' (len=8)
# inspect.cleandoc.__module__ == 'inspect' (len=7)
# inspect.cleandoc.__qualname__ == 'cleandoc' (len=8)
# inspect.cleandoc.__class__.__name__ == 'function'
# inspect.cleandoc.__name__.__len__() == 8
#
# cleandoc is a Python function in Lib/inspect.py. New to extra243.
# ---------------------------------------------------------------------------

table inspect_extra243.inspcls243_cleandoc_identity:
  description: "inspect.cleandoc function identity: name, module, qualname, class; new to extra243"
  kind: python_call_eq
  category: identity
  id_prefix: inspcls243cd

  columns: [id, function, args, expected, description]
  rows:
    - [cd_name_eq,
       cleandoc.__name__.__eq__,
       ["cleandoc"],
       true,
       "inspect.cleandoc.__name__.__eq__('cleandoc') == True — cleandoc is a Python function in Lib/inspect.py; __name__ is 'cleandoc' (len=8); new to extra243"]
    - [cd_name_len_8,
       cleandoc.__name__.__len__,
       [],
       8,
       "inspect.cleandoc.__name__.__len__() == 8 — 'cleandoc' has exactly 8 characters; str.__len__() returns 8; new to extra243"]
    - [cd_module_eq,
       cleandoc.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.cleandoc.__module__.__eq__('inspect') == True — cleandoc is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra243"]
    - [cd_qualname_eq,
       cleandoc.__qualname__.__eq__,
       ["cleandoc"],
       true,
       "inspect.cleandoc.__qualname__.__eq__('cleandoc') == True — __qualname__ is 'cleandoc' (len=8); same as __name__ for top-level function; new to extra243"]
    - [cd_class_is_function,
       cleandoc.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.cleandoc.__class__.__name__.__eq__('function') == True — cleandoc is a plain Python function; its __class__ is the built-in function type; new to extra243"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra243
# ---------------------------------------------------------------------------

invariant inspect_extra243.cca_name_eq:
  description: "inspect.classify_class_attrs.__name__ == 'classify_class_attrs' (len=20); new to extra243"
  kind: python_call_eq
  function: classify_class_attrs.__name__.__eq__
  args: ["classify_class_attrs"]
  expected: true

invariant inspect_extra243.cca_module_eq:
  description: "inspect.classify_class_attrs.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra243"
  kind: python_call_eq
  function: classify_class_attrs.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra243.cca_qualname_eq:
  description: "inspect.classify_class_attrs.__qualname__ == 'classify_class_attrs' (len=20); new to extra243"
  kind: python_call_eq
  function: classify_class_attrs.__qualname__.__eq__
  args: ["classify_class_attrs"]
  expected: true

invariant inspect_extra243.cca_class_is_function:
  description: "inspect.classify_class_attrs.__class__.__name__ == 'function' — plain Python function; new to extra243"
  kind: python_call_eq
  function: classify_class_attrs.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra243.cca_name_len_20:
  description: "inspect.classify_class_attrs.__name__.__len__() == 20; new to extra243"
  kind: python_call_eq
  function: classify_class_attrs.__name__.__len__
  args: []
  expected: 20

invariant inspect_extra243.gd_name_eq:
  description: "inspect.getdoc.__name__ == 'getdoc' (len=6); new to extra243"
  kind: python_call_eq
  function: getdoc.__name__.__eq__
  args: ["getdoc"]
  expected: true

invariant inspect_extra243.gd_module_eq:
  description: "inspect.getdoc.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra243"
  kind: python_call_eq
  function: getdoc.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra243.gd_qualname_eq:
  description: "inspect.getdoc.__qualname__ == 'getdoc' (len=6); new to extra243"
  kind: python_call_eq
  function: getdoc.__qualname__.__eq__
  args: ["getdoc"]
  expected: true

invariant inspect_extra243.gd_class_is_function:
  description: "inspect.getdoc.__class__.__name__ == 'function' — plain Python function; new to extra243"
  kind: python_call_eq
  function: getdoc.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra243.cd_name_eq:
  description: "inspect.cleandoc.__name__ == 'cleandoc' (len=8); new to extra243"
  kind: python_call_eq
  function: cleandoc.__name__.__eq__
  args: ["cleandoc"]
  expected: true

invariant inspect_extra243.cd_module_eq:
  description: "inspect.cleandoc.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra243"
  kind: python_call_eq
  function: cleandoc.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra243.cd_class_is_function:
  description: "inspect.cleandoc.__class__.__name__ == 'function' — plain Python function; new to extra243"
  kind: python_call_eq
  function: cleandoc.__class__.__name__.__eq__
  args: ["function"]
  expected: true
