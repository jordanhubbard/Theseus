    - ["mp3196010",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__lshift__"], false]
    - ["mp3196011",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__lshift__"], false]
    - ["mp3196012",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__lshift__"], false]
    - ["mp3196013",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__lshift__"], false]
    - ["mp3196014",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__lshift__"], false]
    - ["mp3196015",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__lshift__"], false]
    - ["mp3196016",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__lshift__"], false]

# ---------------------------------------------------------------------------
# __rshift__ dict-presence — operator.contains(Cls.__dict__, '__rshift__')
#
# All 8 multiprocessing classes return false for __rshift__.
# Right-shift (>>) is also absent from all multiprocessing types.
# Proxy types (BaseListProxy, _BaseDictProxy, _BaseSetProxy) are thin RPC
#   wrappers that forward named method calls to manager-hosted objects via
#   inter-process communication. They expose no operator overloads.
# pool.AsyncResult and pool.MapResult are result polling handles:
#   get()/wait()/ready()/successful() are the canonical interface — no >>.
# multiprocessing.Process manages subprocess lifecycle via start()/join()/
#   terminate()/kill(); no pipeline or bitshift operator is defined.
# managers.SyncManager is a server process that hosts shared objects;
#   it has no arithmetic or bitwise data model.
# ---------------------------------------------------------------------------

