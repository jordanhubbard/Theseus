spec: mp3196
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 660 (mp3196): __pow__, __lshift__, __rshift__ dict-presence for multiprocessing types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: multiprocessing.Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.BaseListProxy, managers._BaseDictProxy, managers._BaseSetProxy."
    - "Key finding (__pow__): all 8 multiprocessing classes return false for __pow__. Process management and proxy types are not numeric — none define exponentiation in their own __dict__. multiprocessing.Process manages a subprocess via start()/join()/terminate(); raising a process to a power is semantically undefined. pool.Pool dispatches work to a pool of worker processes via apply()/map()/starmap() — no arithmetic operators. pool.AsyncResult and pool.MapResult are result handle types analogous to concurrent.futures.Future; ** is not defined. managers.BaseListProxy proxies list — list itself has no __pow__. managers._BaseDictProxy proxies dict — dict has no __pow__. managers._BaseSetProxy proxies set — set has no __pow__. All proxy types mirror their underlying container types, which also return false."
    - "Key finding (__lshift__): all 8 multiprocessing classes return false for __lshift__. Left-shift has no role in process management or proxy dispatch. managers.BaseListProxy does not define << for appending items — the proxy forwards list methods (append, extend, insert, etc.) as explicit named methods, not operator overloads. managers._BaseDictProxy does not define << for update operations. managers._BaseSetProxy does not define << for union or subset operations — set uses | for union. pool.Pool does not define << as a task submission shorthand; submit is via apply_async() and map_async()."
    - "Key finding (__rshift__): all 8 multiprocessing classes return false for __rshift__. Right-shift is also absent. multiprocessing proxies are thin RPC wrappers around manager-hosted objects; they only expose the method interface of their proxied type — not operator overloads. pool.AsyncResult and pool.MapResult are polling/blocking result handles; >> is not defined for result pipelines. SyncManager is a manager server process that hosts shared objects; it has no arithmetic or bitwise protocol."
    - "All 24 values in this wave are false. multiprocessing is a process-based concurrency library; its entire API is expressed through explicit method calls, subprocess lifecycle management, and IPC (inter-process communication) — never through Python's arithmetic or bitwise data model."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __pow__ dict-presence — operator.contains(Cls.__dict__, '__pow__')
#
# All 8 multiprocessing classes return false for __pow__.
# Process management types (Process, Pool, AsyncResult, MapResult) are
#   concurrency abstractions with no numeric data model.
# Proxy types (BaseListProxy, _BaseDictProxy, _BaseSetProxy, SyncManager)
#   mirror their underlying container types (list, dict, set, manager) —
#   none of which define __pow__ either.
# ---------------------------------------------------------------------------

table mp3196.pow:
  description: "multiprocessing types __pow__ dict-presence checks; wave 660"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3196

  columns: [id, function, args, expected]
  rows:
    - ["mp3196001", operator.contains, [multiprocessing.Process.__dict__,                 "__pow__"], false]
    - ["mp3196002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__pow__"], false]
    - ["mp3196003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__pow__"], false]
    - ["mp3196004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__pow__"], false]
    - ["mp3196005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__pow__"], false]
    - ["mp3196006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__pow__"], false]
    - ["mp3196007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__pow__"], false]
    - ["mp3196008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__pow__"], false]

# ---------------------------------------------------------------------------
# __lshift__ dict-presence — operator.contains(Cls.__dict__, '__lshift__')
#
# All 8 multiprocessing classes return false for __lshift__.
# Left-shift (<<) has no role in process management or IPC proxy dispatch.
# managers.BaseListProxy proxies list — list does not define __lshift__.
#   Item insertion is via list's append()/insert()/extend() method interface,
#   forwarded as named proxy methods, not operator overloads.
# managers._BaseDictProxy proxies dict — dict does not define << for update.
# managers._BaseSetProxy proxies set — set does not define __lshift__; it
#   uses | for union and &= for in-place intersection. << is undefined.
# pool.Pool: task submission is via apply_async()/map_async(), not <<.
# ---------------------------------------------------------------------------

table mp3196.lshift:
  description: "multiprocessing types __lshift__ dict-presence checks; wave 660"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3196

  columns: [id, function, args, expected]
