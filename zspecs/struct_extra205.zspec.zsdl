spec: struct_extra205
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html
rfcs:
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic (for float/double format strings)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified by running Python 3.14.3 struct module on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec extends struct.zspec.zsdl and struct_extra.zspec.zsdl through struct_extra204.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "struct_extra204.zspec.zsdl covers: struct.error.__dict__ contains '__doc__', '__module__', '__weakref__'; struct.__doc__ content checks; struct.Struct.__dict__ contains '__repr__', '__sizeof__', '__new__', 'pack'; struct.error.__bases__[0].__name__ == 'Exception'."
    - "struct.Struct.__dict__.__contains__('__new__') == True (verified on Python 3.14.3 macOS/Darwin 25.4.0)."
    - "struct.Struct.__dict__.__contains__('__repr__') == True (verified on Python 3.14.3 macOS/Darwin 25.4.0)."
    - "struct.Struct.__dict__.__contains__('__sizeof__') == True (verified on Python 3.14.3 macOS/Darwin 25.4.0)."
    - "struct.Struct.__dict__.__contains__('__reduce_ex__') == False — __reduce_ex__ is inherited from object, not defined on Struct (verified on Python 3.14.3 macOS/Darwin 25.4.0)."
    - "struct.Struct.__dict__.__len__() == 16 (verified on Python 3.14.3 macOS/Darwin 25.4.0)."
    - "struct.error.__bases__[0].__name__ == 'Exception' (verified on Python 3.14.3 macOS/Darwin 25.4.0)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "struct.error is raised for mismatched buffer sizes and invalid format strings. It is a subclass of Exception."
  stderr: "null"
  stickiness: "N/A — all tested invariants are class dict membership or length checks."
  codes: {}

# ---------------------------------------------------------------------------
# struct.Struct.__dict__ — dunder slot membership (known-true values)
# Struct is a C-implemented type; these dunder slots are defined directly on it.
# ---------------------------------------------------------------------------

table structmethods205.Struct_dict.dunders_true:
  description: "struct.Struct.__dict__ contains expected dunder slot descriptors"
  kind: python_call_eq
  category: class_metadata
  id_prefix: structmethods205_Struct_dunders_true

  columns: [id, function, args, expected, description]
  rows:
    - [new,      "Struct.__dict__.__contains__", ["__new__"],      true, "Struct.__dict__ contains '__new__' — Struct defines its own __new__"]
    - [repr,     "Struct.__dict__.__contains__", ["__repr__"],     true, "Struct.__dict__ contains '__repr__' — Struct defines its own __repr__"]
    - [sizeof,   "Struct.__dict__.__contains__", ["__sizeof__"],   true, "Struct.__dict__ contains '__sizeof__' — Struct defines __sizeof__ for accurate memory size"]
    - [init,     "Struct.__dict__.__contains__", ["__init__"],     true, "Struct.__dict__ contains '__init__' — Struct defines its own __init__"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__ — absent entries (known-false values)
# __reduce_ex__ is inherited from object, NOT defined on Struct.
# ---------------------------------------------------------------------------

table structmethods205.Struct_dict.dunders_false:
  description: "struct.Struct.__dict__ does NOT contain inherited dunder methods"
  kind: python_call_eq
  category: class_metadata
  id_prefix: structmethods205_Struct_dunders_false

  columns: [id, function, args, expected, description]
  rows:
    - [no_reduce_ex,    "Struct.__dict__.__contains__", ["__reduce_ex__"],  false, "__reduce_ex__ is NOT in Struct.__dict__ — inherited from object"]
    - [no_str,          "Struct.__dict__.__contains__", ["__str__"],        false, "__str__ is NOT in Struct.__dict__ — inherited from object"]
    - [no_hash,         "Struct.__dict__.__contains__", ["__hash__"],       false, "__hash__ is NOT in Struct.__dict__ — Struct is unhashable but __hash__ not redefined here"]
    - [no_fake,         "Struct.__dict__.__contains__", ["not_a_method"],   false, "arbitrary name is NOT in Struct.__dict__"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__ — length and error base class
# Struct.__dict__.__len__() == 16 on Python 3.14.3.
# struct.error.__bases__[0].__name__ == 'Exception'.
# ---------------------------------------------------------------------------

table structmethods205.Struct_dict.meta:
  description: "struct.Struct.__dict__ length and struct.error base class checks"
  kind: python_call_eq
  category: class_metadata
  id_prefix: structmethods205_meta

  columns: [id, function, args, expected, description]
  rows:
    - [dict_len,       "Struct.__dict__.__len__",                           [], 16,    "Struct.__dict__.__len__() == 16 on Python 3.14.3"]
    - [error_base,     "error.__bases__[0].__name__.__eq__",                ["Exception"], true, "struct.error.__bases__[0].__name__ == 'Exception'"]
    - [has_size,       "Struct.__dict__.__contains__",                      ["size"],   true,  "Struct.__dict__ contains 'size' attribute descriptor"]
    - [has_format,     "Struct.__dict__.__contains__",                      ["format"], true,  "Struct.__dict__ contains 'format' attribute descriptor"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant structmethods205.Struct_dict.has_new:
  description: "struct.Struct.__dict__.__contains__('__new__') == True — Struct defines its own __new__"
  category: class_metadata
  kind: python_call_eq
  function: "Struct.__dict__.__contains__"
  args: ["__new__"]
  expected: true

invariant structmethods205.Struct_dict.has_repr:
  description: "struct.Struct.__dict__.__contains__('__repr__') == True — Struct defines its own __repr__"
  category: class_metadata
  kind: python_call_eq
  function: "Struct.__dict__.__contains__"
  args: ["__repr__"]
  expected: true

invariant structmethods205.Struct_dict.has_sizeof:
  description: "struct.Struct.__dict__.__contains__('__sizeof__') == True — Struct defines __sizeof__ for accurate memory reporting"
  category: class_metadata
  kind: python_call_eq
  function: "Struct.__dict__.__contains__"
  args: ["__sizeof__"]
  expected: true

invariant structmethods205.Struct_dict.no_reduce_ex:
  description: "struct.Struct.__dict__.__contains__('__reduce_ex__') == False — __reduce_ex__ is inherited from object, not defined on Struct"
  category: class_metadata
  kind: python_call_eq
  function: "Struct.__dict__.__contains__"
  args: ["__reduce_ex__"]
  expected: false

invariant structmethods205.Struct_dict.len:
  description: "struct.Struct.__dict__.__len__() == 16 — Struct defines exactly 16 entries in its __dict__ on Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: "Struct.__dict__.__len__"
  args: []
  expected: 16

invariant structmethods205.error.base_is_exception:
  description: "struct.error.__bases__[0].__name__.__eq__('Exception') == True — struct.error is a direct subclass of Exception"
  category: class_metadata
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant structmethods205.Struct_dict.has_size:
  description: "struct.Struct.__dict__.__contains__('size') == True — Struct exposes 'size' as a read-only attribute"
  category: class_metadata
  kind: python_call_eq
  function: "Struct.__dict__.__contains__"
  args: ["size"]
  expected: true

invariant structmethods205.Struct_dict.has_format:
  description: "struct.Struct.__dict__.__contains__('format') == True — Struct exposes 'format' as a read-only attribute"
  category: class_metadata
  kind: python_call_eq
  function: "Struct.__dict__.__contains__"
  args: ["format"]
  expected: true
