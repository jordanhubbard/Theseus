spec: struct_extra40
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra39.zspec.zsdl — covers Struct/__mro__[1]/__name__.__eq__('object') and error/__mro__[3]/__name__.__eq__('object'); Struct.size.__qualname__.__eq__('Struct.size') and Struct.size.__qualname__.__len__()==11."
    - "struct_extra32.zspec.zsdl — covers Struct METHOD pack/unpack/pack_into/unpack_from/iter_unpack __name__.__len__() (Struct method descriptor length checks)."
    - "struct_extra27.zspec.zsdl — covers Struct METHOD __qualname__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack."
    - "struct_extra21.zspec.zsdl — covers Struct.__init__/__repr__ __qualname__.__eq__('Struct.__init__'/'Struct.__repr__') and __qualname__.__len__()==15."
    - "struct_extra9.zspec.zsdl — covers Struct METHOD pack/unpack/pack_into/unpack_from/iter_unpack __name__.__eq__ and __qualname__.__eq__."
    - "struct_extra4.zspec.zsdl — covers module-level pack/unpack/pack_into/unpack_from/iter_unpack/calcsize __qualname__.__eq__; error.__qualname__.__eq__."
  notes:
    - "This spec extends struct through struct_extra39; it does NOT duplicate invariants present in those files."
    - "Coverage gap: struct_extra21 covers Struct.__init__.__qualname__.__eq__('Struct.__init__') and Struct.__repr__.__qualname__.__eq__('Struct.__repr__') (__qualname__ axis). struct_extra32 covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __name__.__len__() for Struct method descriptors. struct_extra9 covers Struct method descriptor __name__.__eq__ for pack/unpack/pack_into/unpack_from/iter_unpack. But NO prior spec checks Struct.__init__.__name__.__eq__('__init__') or Struct.__repr__.__name__.__eq__('__repr__') as string eq values. The __name__ attribute gives the bare unqualified method name (e.g., '__init__') while __qualname__ gives the class-prefixed form ('Struct.__init__'). These are distinct attribute chains from __qualname__ (extra21) and provide independent regression vectors for the Struct constructor and repr dunder. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__name__ == '__init__'. The bare unqualified name of the Struct constructor. extra21 covers __qualname__.__eq__('Struct.__init__') and __qualname__.__len__()==15. No prior spec checks __name__.__eq__('__init__') for Struct.__init__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__repr__.__name__ == '__repr__'. The bare unqualified name of the Struct repr. extra21 covers __qualname__.__eq__('Struct.__repr__') and __qualname__.__len__()==15. No prior spec checks __name__.__eq__('__repr__') for Struct.__repr__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__name__.__len__() == 8. len('__init__') == 8. No prior spec checks Struct.__init__.__name__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__repr__.__name__.__len__() == 8. len('__repr__') == 8. No prior spec checks Struct.__repr__.__name__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__init__ and Struct.__repr__ __name__.__eq__ string values
#
# struct_extra21 covers Struct.__init__.__qualname__.__eq__('Struct.__init__') and
#   Struct.__repr__.__qualname__.__eq__('Struct.__repr__') (__qualname__ axis).
# struct_extra9 covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack
#   __name__.__eq__ (Struct method descriptors, not dunder methods).
# No prior spec checks __name__.__eq__ for Struct.__init__ or Struct.__repr__.
# The __name__ attribute gives the bare unqualified name: '__init__', '__repr__'.
# These are distinct from __qualname__ ('Struct.__init__', 'Struct.__repr__').
# ---------------------------------------------------------------------------

table struct_extra40.Struct_dunder_name_eq:
  description: "struct.Struct.__init__/__repr__ __name__.__eq__ string values — novel: extra21 covers __qualname__.__eq__ for these; extra9 covers Struct method descriptor __name__.__eq__ (pack/unpack etc, not __init__/__repr__); no prior spec checks __name__.__eq__ for Struct.__init__ or Struct.__repr__"
  kind: python_call_eq
  category: function_names
  id_prefix: sdne40

  columns: [id, function, args, expected]
  rows:
    - [init_name_eq, "Struct.__init__.__name__.__eq__", ["__init__"], true]
    - [repr_name_eq, "Struct.__repr__.__name__.__eq__", ["__repr__"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__init__ and Struct.__repr__ __name__.__len__()
#
# len('__init__') == 8 and len('__repr__') == 8.
# struct_extra32 covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack
#   __name__.__len__() for Struct method descriptors (not dunder methods).
# No prior spec checks __name__.__len__() for Struct.__init__ or Struct.__repr__.
# These are wrapper_descriptor objects on the Struct type.
# ---------------------------------------------------------------------------

table struct_extra40.Struct_dunder_name_len:
  description: "struct.Struct.__init__/__repr__ __name__.__len__() == 8 — len('__init__') == len('__repr__') == 8; novel: extra32 covers Struct method descriptor __name__.__len__ for pack/unpack etc; no prior spec checks __name__.__len__ for Struct.__init__ or Struct.__repr__"
  kind: python_call_eq
  category: function_names
  id_prefix: sdnl40

  columns: [id, function, args, expected]
  rows:
    - [init_name_len, Struct.__init__.__name__.__len__, [], 8]
    - [repr_name_len, Struct.__repr__.__name__.__len__, [], 8]
