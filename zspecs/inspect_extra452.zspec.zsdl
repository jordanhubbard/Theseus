spec: inspect_extra452
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect.Parameter constants and Signature identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers Parameter kind constants, Parameter.empty, Signature, and BoundArguments identity"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra452.parameter_kind_identity:
  description: "inspect.Parameter kind constant class name checks"
  kind: python_call_eq
  category: identity
  id_prefix: ipk

  columns: [id, function, args, expected]
  rows:
    - [ipk001, inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__, ["_ParameterKind"], true]
    - [ipk002, inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__, ["_ParameterKind"], true]
    - [ipk003, inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__, ["_ParameterKind"], true]
    - [ipk004, inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__, ["_ParameterKind"], true]
    - [ipk005, inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__, ["_ParameterKind"], true]

table inspect_extra452.parameter_empty_identity:
  description: "inspect.Parameter.empty class name check"
  kind: python_call_eq
  category: identity
  id_prefix: ipe

  columns: [id, function, args, expected]
  rows:
    - [ipe001, inspect.Parameter.empty.__class__.__name__.__eq__, ["_empty"], true]

table inspect_extra452.signature_identity:
  description: "inspect.Signature name and module identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: isig

  columns: [id, function, args, expected]
  rows:
    - [isig001, inspect.Signature.__name__.__eq__, ["Signature"], true]
    - [isig002, inspect.Signature.__module__.__eq__, ["inspect"], true]
    - [isig003, "inspect.Signature.__bases__[0].__name__.__eq__", ["object"], true]

table inspect_extra452.boundarguments_identity:
  description: "inspect.BoundArguments name and module identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: iba

  columns: [id, function, args, expected]
  rows:
    - [iba001, inspect.BoundArguments.__name__.__eq__, ["BoundArguments"], true]
    - [iba002, inspect.BoundArguments.__module__.__eq__, ["inspect"], true]
