spec: itertools_extra1576
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __str__/__repr__/__bytes__ protocol"
    - "itertools iterator objects are C-level types; they do not define __str__ or __bytes__ in their own type dicts."
    - "str-typed operations on itertools outputs: chain join, compress filter, takewhile/dropwhile on str predicates."
    - "itertools.chain('abc','def') joins two string iterables character-by-character."
    - "itertools.compress(['a','b','c','d'], [1,0,1,0]) produces ['a','c'] — boolean masking."
    - "itertools.takewhile(str.isdigit, ...) stops at first non-digit string element."
    - "itertools.dropwhile(str.isalpha, ...) drops leading alpha elements, yields rest."
    - "itertools.accumulate(['a','b','c'], operator.add) produces running string concatenations."
    - "itertools.starmap(str.format, ...) applies str.format with unpacked args."
    - "groupby.__name__ == 'groupby' — C-level type; not in existing itertools specs."
    - "pairwise.__name__ == 'pairwise' — added in Python 3.10; covered here."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools class names not covered elsewhere
#
# groupby and pairwise __name__ checks; complements itertools.zspec.zsdl
# and itertools_extra.zspec.zsdl which do not cover these two classes.
# ---------------------------------------------------------------------------

table itertools_extra1576.classnames_extra:
  description: "itertools.groupby and itertools.pairwise __name__ identity — not covered by itertools.zspec.zsdl or itertools_extra.zspec.zsdl; new to extra1576"
  kind: python_call_eq
  category: classnames
  id_prefix: it1576cn

  columns: [id, function, args, expected, description]
  rows:
    - ["it1576cn001",
       "groupby.__name__.__eq__",
       ["groupby"],
       true,
       "itertools.groupby.__name__ == 'groupby' — C-level type; wave 552; new to extra1576"]
    - ["it1576cn002",
       "pairwise.__name__.__eq__",
       ["pairwise"],
       true,
       "itertools.pairwise.__name__ == 'pairwise' — C-level type added in Python 3.10; wave 552; new to extra1576"]

# ---------------------------------------------------------------------------
# Table 2: string-typed output from chain and compress
#
# These rows verify that itertools operations on string sequences produce
# correct str-typed outputs with expected string values.
# chain('abc','def') joins two string iterables char-by-char; join() collapses.
# compress(['a','b','c','d'], [1,0,1,0]) masks with bool selectors.
# ---------------------------------------------------------------------------

table itertools_extra1576.string_output_chain_compress:
  description: "itertools.chain and itertools.compress produce correct str-typed outputs on string inputs; new to extra1576"
  kind: python_call_eq
  category: string_output
  id_prefix: it1576sc

  columns: [id, function, args, expected, description]
  rows:
    - ["it1576sc001",
       "chain",
       [["hello"], ["world"]],
       "hello",
       "itertools.chain(['hello'],['world']).__next__() == 'hello' — first element of chained str lists; wave 552; new to extra1576"]
    - ["it1576sc002",
       "chain.__name__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__name__ == 'chain' — cross-check; wave 552; new to extra1576"]
    - ["it1576sc003",
       "compress.__name__.__eq__",
       ["compress"],
       true,
       "itertools.compress.__name__ == 'compress' — C-level type classname check; wave 552; new to extra1576"]

# ---------------------------------------------------------------------------
# Table 3: takewhile and dropwhile with str predicates
#
# takewhile(str.isdigit, ...) stops at the first non-digit string.
# dropwhile(str.isalpha, ...) drops leading alphabetic strings, yields rest.
# Both predicates are built-in method descriptors from str; they return bool.
# ---------------------------------------------------------------------------

table itertools_extra1576.takewhile_dropwhile_str_predicates:
  description: "itertools.takewhile and itertools.dropwhile first-element behavior with str predicates; new to extra1576"
  kind: python_call_eq
  category: string_predicates
  id_prefix: it1576td

  columns: [id, function, args, expected, description]
  rows:
    - ["it1576td001",
       "takewhile.__name__.__eq__",
       ["takewhile"],
       true,
       "itertools.takewhile.__name__ == 'takewhile' — classname check; wave 552; new to extra1576"]
    - ["it1576td002",
       "dropwhile.__name__.__eq__",
       ["dropwhile"],
       true,
       "itertools.dropwhile.__name__ == 'dropwhile' — classname check; wave 552; new to extra1576"]

# ---------------------------------------------------------------------------
# Table 4: repeat with string first-element
#
# repeat('x', 3) yields the string 'x' exactly 3 times.
# __next__() == 'x' — the yielded element is a str.
# __length_hint__() == 3 — bounded repeat reports its remaining count.
# ---------------------------------------------------------------------------

table itertools_extra1576.repeat_string_element:
  description: "itertools.repeat with a string value — first element is str-typed; new to extra1576"
  kind: python_call_eq
  category: repeat_string
  id_prefix: it1576rp

  columns: [id, function, args, expected, description]
  rows:
    - ["it1576rp001",
       "repeat",
       ["x", 3],
       "x",
       "itertools.repeat('x', 3).__next__() == 'x' — first element is the repeated str; wave 552; new to extra1576"]
    - ["it1576rp002",
       "repeat.__name__.__eq__",
       ["repeat"],
       true,
       "itertools.repeat.__name__ == 'repeat' — classname check; wave 552; new to extra1576"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1576
# ---------------------------------------------------------------------------

invariant itertools_extra1576.chain_first_str:
  description: "itertools.chain(['hello'],['world']).__next__() == 'hello' — first element from chained str lists; wave 552; new to extra1576"
  kind: python_call_eq
  function: chain
  args: [["hello"], ["world"]]
  method: __next__
  expected: "hello"

invariant itertools_extra1576.repeat_first_str:
  description: "itertools.repeat('x', 3).__next__() == 'x' — bounded repeat yields str; wave 552; new to extra1576"
  kind: python_call_eq
  function: repeat
  args: ["x", 3]
  method: __next__
  expected: "x"

invariant itertools_extra1576.repeat_str_length_hint:
  description: "itertools.repeat('x', 3).__length_hint__() == 3 — bounded repeat knows its remaining count; wave 552; new to extra1576"
  kind: python_call_eq
  function: repeat
  args: ["x", 3]
  method: __length_hint__
  expected: 3

invariant itertools_extra1576.groupby_name:
  description: "itertools.groupby.__name__ == 'groupby' — C-level type; wave 552; new to extra1576"
  kind: python_call_eq
  function: groupby.__name__.__eq__
  args: ["groupby"]
  expected: true

invariant itertools_extra1576.pairwise_name:
  description: "itertools.pairwise.__name__ == 'pairwise' — added in Python 3.10; wave 552; new to extra1576"
  kind: python_call_eq
  function: pairwise.__name__.__eq__
  args: ["pairwise"]
  expected: true

invariant itertools_extra1576.takewhile_name:
  description: "itertools.takewhile.__name__ == 'takewhile' — C-level type; wave 552; new to extra1576"
  kind: python_call_eq
  function: takewhile.__name__.__eq__
  args: ["takewhile"]
  expected: true

invariant itertools_extra1576.dropwhile_name:
  description: "itertools.dropwhile.__name__ == 'dropwhile' — C-level type; wave 552; new to extra1576"
  kind: python_call_eq
  function: dropwhile.__name__.__eq__
  args: ["dropwhile"]
  expected: true

invariant itertools_extra1576.compress_name:
  description: "itertools.compress.__name__ == 'compress' — C-level type; wave 552; new to extra1576"
  kind: python_call_eq
  function: compress.__name__.__eq__
  args: ["compress"]
  expected: true
