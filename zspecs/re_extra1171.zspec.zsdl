spec: re_extra1171
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re.__all__ membership checks for compile/match/search/sub/error/Pattern/Match/RegexFlag/IGNORECASE/DOTALL, re.__all__.__len__, and re.__version__.__class__.__name__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.__all__.__contains__ for compile, match, search, sub, error, Pattern, Match, RegexFlag, IGNORECASE, DOTALL and non-members; re.__all__.__len__ type check; re.__version__.__class__.__name__; none of these __all__ membership or __version__ checks were covered in _extra1141 or _extra1156"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1171.all_contains_functions_and_classes:
  description: "re.__all__.__contains__ membership checks for compile, match, search, sub, error, Pattern, Match"
  kind: python_call_eq
  category: all_contains_functions_and_classes
  id_prefix: re1171fc
  columns: [id, function, args, expected]
  rows:
    - [re1171fc001, re.__all__.__contains__, ["compile"], true]
    - [re1171fc002, re.__all__.__contains__, ["match"],   true]
    - [re1171fc003, re.__all__.__contains__, ["search"],  true]
    - [re1171fc004, re.__all__.__contains__, ["sub"],     true]
    - [re1171fc005, re.__all__.__contains__, ["error"],   true]
    - [re1171fc006, re.__all__.__contains__, ["Pattern"], true]
    - [re1171fc007, re.__all__.__contains__, ["Match"],   true]
    - [re1171fc008, re.__all__.__contains__, ["_compile"], false]
    - [re1171fc009, re.__all__.__contains__, ["pattern"], false]
    - [re1171fc010, re.__all__.__contains__, ["Error"],   false]

table re_extra1171.all_contains_flags_and_constants:
  description: "re.__all__.__contains__ membership checks for RegexFlag, IGNORECASE, DOTALL, and non-members"
  kind: python_call_eq
  category: all_contains_flags_and_constants
  id_prefix: re1171fg
  columns: [id, function, args, expected]
  rows:
    - [re1171fg001, re.__all__.__contains__, ["RegexFlag"],  true]
    - [re1171fg002, re.__all__.__contains__, ["IGNORECASE"], true]
    - [re1171fg003, re.__all__.__contains__, ["DOTALL"],     true]
    - [re1171fg004, re.__all__.__contains__, ["MULTILINE"],  true]
    - [re1171fg005, re.__all__.__contains__, ["VERBOSE"],    true]
    - [re1171fg006, re.__all__.__contains__, ["ignorecase"], false]
    - [re1171fg007, re.__all__.__contains__, ["dotall"],     false]
    - [re1171fg008, re.__all__.__contains__, ["FLAGS"],      false]

table re_extra1171.all_len_and_version_class_name:
  description: "re.__all__.__len__ type check and re.__version__.__class__.__name__ checks"
  kind: python_call_eq
  category: all_len_and_version_class_name
  id_prefix: re1171av
  columns: [id, function, args, expected]
  rows:
    - [re1171av001, re.__all__.__len__.__class__.__name__.__eq__,       ["builtin_function_or_method"], true]
    - [re1171av002, re.__all__.__class__.__name__.__eq__,               ["list"],  true]
    - [re1171av003, re.__all__.__class__.__name__.__eq__,               ["tuple"], false]
    - [re1171av004, re.__version__.__class__.__name__.__eq__,           ["str"],   true]
    - [re1171av005, re.__version__.__class__.__name__.__eq__,           ["int"],   false]
    - [re1171av006, re.__version__.__class__.__name__.__eq__,           ["float"], false]
    - [re1171av007, re.__all__.__len__.__class__.__name__.__eq__,       ["function"], false]
    - [re1171av008, re.__version__.__class__.__name__.__eq__,           ["bytes"], false]
