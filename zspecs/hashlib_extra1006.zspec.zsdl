spec: hashlib_extra1006
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __doc__.__class__.__name__ == 'str' for hashlib functions and module attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1006.hash_constructor_docs:
  description: "hashlib hash constructor __doc__ class name checks"
  kind: python_call_eq
  category: hash_constructor_docs
  id_prefix: hl1006hc
  columns: [id, function, args, expected]
  rows:
    - [hl1006hc001, hashlib.md5.__doc__.__class__.__name__.__eq__,       ["str"], true]
    - [hl1006hc002, hashlib.sha1.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [hl1006hc003, hashlib.sha224.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [hl1006hc004, hashlib.sha256.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [hl1006hc005, hashlib.sha384.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [hl1006hc006, hashlib.sha512.__doc__.__class__.__name__.__eq__,    ["str"], true]

table hashlib_extra1006.hash_function_docs:
  description: "hashlib utility function __doc__ class name checks"
  kind: python_call_eq
  category: hash_function_docs
  id_prefix: hl1006hf
  columns: [id, function, args, expected]
  rows:
    - [hl1006hf001, hashlib.new.__doc__.__class__.__name__.__eq__,          ["str"], true]
    - [hl1006hf002, hashlib.pbkdf2_hmac.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [hl1006hf003, hashlib.scrypt.__doc__.__class__.__name__.__eq__,       ["str"], true]
    - [hl1006hf004, hashlib.blake2b.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [hl1006hf005, hashlib.blake2s.__doc__.__class__.__name__.__eq__,      ["str"], true]

table hashlib_extra1006.module_attributes:
  description: "hashlib module-level attribute class name checks"
  kind: python_call_eq
  category: module_attributes
  id_prefix: hl1006ma
  columns: [id, function, args, expected]
  rows:
    - [hl1006ma001, hashlib.__all__.__class__.__name__.__eq__,               ["list"],  true]
    - [hl1006ma002, hashlib.__doc__.__class__.__name__.__eq__,               ["str"],   true]
    - [hl1006ma003, hashlib.__name__.__class__.__name__.__eq__,              ["str"],   true]
    - [hl1006ma004, hashlib.algorithms_available.__class__.__name__.__eq__,  ["set"],   true]
    - [hl1006ma005, hashlib.algorithms_guaranteed.__class__.__name__.__eq__, ["set"],   true]
