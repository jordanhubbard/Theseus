spec: weakref_extra27
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
  notes:
    - "This spec extends weakref_extra26.zspec.zsdl."
    - "Prior specs covered: ref/__name__/__module__/__qualname__, WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize __name__/__module__/__qualname__, ref.__bases__[0].__name__, WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize __bases__[0].__name__, ref.__init__.__name__, __module__.__len__() and __name__.__len__() for proxy/getweakrefcount/getweakrefs/ReferenceType/ProxyType/CallableProxyType/WeakMethod, finalize method __qualname__.__len__(), WeakValueDictionary/WeakKeyDictionary method __qualname__.__len__(), __mro__.__len__() for WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize, __slots__ class name len for WeakValueDictionary/finalize."
    - "This spec covers: weakref.__all__.__len__() and .__class__.__name__.__len__(); __dict__.__class__.__name__.__len__() for ref/WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize (all mappingproxy=12); __qualname__.__len__() for WeakValueDictionary/WeakKeyDictionary/WeakSet/ref (via ReferenceType)/finalize/proxy; __bases__[0].__name__.__len__() for WeakValueDictionary/WeakKeyDictionary/WeakSet; weakref.ref.__mro__.__len__()."
    - "weakref.__all__.__len__() == 13 — verified on Python 3.12."
    - "weakref.ref.__qualname__ == 'ReferenceType' (length 13) — the C-level internal name is 'ReferenceType', not 'ref'. weakref.ref is a module-level alias."
    - "weakref.ref.__mro__ == (weakref.ReferenceType, object) — length 2; ReferenceType directly subclasses object."
    - "WeakValueDictionary.__bases__[0].__name__ == 'MutableMapping' (length 14); same for WeakKeyDictionary."
    - "WeakSet.__bases__[0].__name__ == 'object' (length 6) — WeakSet is defined in _weakrefset and directly subclasses object."
    - "weakref.finalize.__qualname__ == 'finalize' (length 8); weakref.proxy.__qualname__ == 'proxy' (length 5)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# weakref.__all__.__len__() and .__class__.__name__.__len__()
#
# weakref.__all__ is a list with 13 entries (Python 3.12). The list class
# name 'list' has length 4. No prior weakref spec records the total export
# count or the type of __all__.
# ---------------------------------------------------------------------------

table weakref_extra27.all_list_attrs:
  description: "weakref.__all__ length (13) and its class name length (4 — 'list')"
  kind: python_call_eq
  category: module_all_attrs
  id_prefix: all

  columns: [id, function, args, expected]
  rows:
    - [len,            __all__.__len__,                   [], 13]
    - [class_name_len, __all__.__class__.__name__.__len__, [], 4]

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() for ref/WeakValueDictionary/
# WeakKeyDictionary/WeakSet/finalize
#
# All five classes store their class __dict__ as a mappingproxy (length 12):
# ref is a C-type, WeakValueDictionary/WeakKeyDictionary/WeakSet are Python
# classes defined in _weakrefset/weakref.py, and finalize is a C-type. The
# mappingproxy type applies uniformly across both C and Python implementations
# when describing a class namespace. No prior weakref spec records
# __dict__.__class__.__name__.__len__() for any of these classes.
# ---------------------------------------------------------------------------

table weakref_extra27.class_dict_type_lens:
  description: "__dict__.__class__.__name__.__len__() for weakref classes — all are mappingproxy (12)"
  kind: python_call_eq
  category: dict_type_checks
  id_prefix: dict_class_name_len

  columns: [id, function, args, expected]
  rows:
    - [ref,                  ref.__dict__.__class__.__name__.__len__,                  [], 12]
    - [WeakValueDictionary,  WeakValueDictionary.__dict__.__class__.__name__.__len__,  [], 12]
    - [WeakKeyDictionary,    WeakKeyDictionary.__dict__.__class__.__name__.__len__,    [], 12]
    - [WeakSet,              WeakSet.__dict__.__class__.__name__.__len__,              [], 12]
    - [finalize,             finalize.__dict__.__class__.__name__.__len__,             [], 12]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for weakref classes
#
# weakref.ref.__qualname__ == 'ReferenceType' (length 13) — the C internal name
# exposed through weakref.ref is actually 'ReferenceType'; 'ref' is just a
# module-level alias. WeakValueDictionary (19), WeakKeyDictionary (17), and
# WeakSet (7) use their Python class names as qualnames. finalize.__qualname__
# == 'finalize' (8) and proxy.__qualname__ == 'proxy' (5). No prior weakref
# spec records __qualname__.__len__() for ref, WeakValueDictionary,
# WeakKeyDictionary, WeakSet, finalize, or proxy as class-level qualnames.
# ---------------------------------------------------------------------------

table weakref_extra27.class_qualname_lens:
  description: "__qualname__.__len__() for weakref classes — ref reports C name 'ReferenceType' (13), not 'ref' (3)"
  kind: python_call_eq
  category: qualname_attr_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [ref,                 ref.__qualname__.__len__,                 [], 13]
    - [WeakValueDictionary, WeakValueDictionary.__qualname__.__len__, [], 19]
    - [WeakKeyDictionary,   WeakKeyDictionary.__qualname__.__len__,   [], 17]
    - [WeakSet,             WeakSet.__qualname__.__len__,             [], 7]
    - [finalize,            finalize.__qualname__.__len__,            [], 8]
    - [proxy,               proxy.__qualname__.__len__,               [], 5]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__() for WeakValueDictionary/WeakKeyDictionary/
# WeakSet
#
# WeakValueDictionary and WeakKeyDictionary directly inherit from MutableMapping
# (length 14). WeakSet directly subclasses object (length 6). This table records
# the base class name length for all three, complementing the __mro__.__len__()
# invariants in extra26 which showed WeakValueDictionary/WeakKeyDictionary at
# depth 8 (MutableMapping chain) and WeakSet at depth 2 (direct object). No
# prior weakref spec records __bases__[0].__name__.__len__() for these three.
# ---------------------------------------------------------------------------

table weakref_extra27.class_bases0_name_lens:
  description: "__bases__[0].__name__.__len__() for WeakValueDictionary/WeakKeyDictionary (MutableMapping=14) and WeakSet (object=6)"
  kind: python_call_eq
  category: base_class_names
  id_prefix: bases0_name_len

  columns: [id, function, args, expected]
  rows:
    - [WeakValueDictionary, "WeakValueDictionary.__bases__[0].__name__.__len__", [], 14]
    - [WeakKeyDictionary,   "WeakKeyDictionary.__bases__[0].__name__.__len__",   [], 14]
    - [WeakSet,             "WeakSet.__bases__[0].__name__.__len__",             [], 6]

# ---------------------------------------------------------------------------
# weakref.ref.__mro__.__len__() == 2 — standalone
#
# weakref.ref (internally 'ReferenceType') has __mro__ == (ReferenceType,
# object), length 2. ReferenceType is a C-implemented type that directly
# subclasses object, consistent with finalize and WeakSet (also depth 2 in
# extra26). This invariant completes the MRO depth picture for all major
# weakref classes: ref/WeakSet/finalize at depth 2;
# WeakValueDictionary/WeakKeyDictionary at depth 8.
# ---------------------------------------------------------------------------

invariant weakref_extra27.ref.mro_len:
  description: "weakref.ref.__mro__.__len__() == 2 — MRO is (ReferenceType, object); ref directly subclasses object (depth 2)"
  category: mro_lengths
  kind: python_call_eq
  function: ref.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# weakref.__all__.__len__() == 13 — standalone
#
# weakref.__all__ contains 13 exported names in Python 3.12. This anchors the
# module's public API surface area and provides a reference count for detecting
# additions across Python versions.
# ---------------------------------------------------------------------------

invariant weakref_extra27.all_len:
  description: "weakref.__all__.__len__() == 13 — 13 public exports in Python 3.12"
  category: module_all_attrs
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# weakref.ref.__qualname__.__len__() == 13 — standalone
#
# weakref.ref.__qualname__ == 'ReferenceType' (length 13). Although the module
# exposes this class as 'ref', the class itself carries the C internal name
# 'ReferenceType' as both __name__ and __qualname__. This is a notable
# divergence between the public alias and the class identity, unlike most
# weakref names (WeakValueDictionary, WeakKeyDictionary, WeakSet, finalize,
# proxy) where the attribute name and qualname agree.
# ---------------------------------------------------------------------------

invariant weakref_extra27.ref.qualname_len:
  description: "weakref.ref.__qualname__.__len__() == 13 — qualname is 'ReferenceType' (13), not 'ref' (3); 'ref' is a module-level alias for the C class ReferenceType"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: ref.__qualname__.__len__
  args: []
  expected: 13
