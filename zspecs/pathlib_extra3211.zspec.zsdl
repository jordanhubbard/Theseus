spec: pp3211
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 661 (pp3211): __and__, __or__, __xor__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "No pathlib class defines __and__ in its own __dict__: path objects do not support the bitwise AND operator."
    - "No pathlib class defines __or__ in its own __dict__: path objects do not support the bitwise OR operator."
    - "No pathlib class defines __xor__ in its own __dict__: path objects do not support the bitwise XOR operator."
    - "Contrast with wave 659 where pathlib.PurePath.__truediv__ was True (path joining via /); __and__, __or__, and __xor__ are not defined on PurePath or any subclass."
    - "pathlib defines __truediv__ (wave 659) but NOT __and__, __or__, or __xor__."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __and__ dict-presence — operator.contains(Cls.__dict__, '__and__')
#
# No pathlib class defines __and__ in its own __dict__; all false.
# pathlib types represent immutable filesystem paths; bitwise AND is not
# supported. Contrast with __truediv__ (wave 659) which PurePath does define.
# ---------------------------------------------------------------------------

table pp3211.and_:
  description: "pathlib types __and__ dict-presence checks; wave 661"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3211

  columns: [id, function, args, expected]
  rows:
    - ["pp3211001", operator.contains, [pathlib.PurePath.__dict__,         "__and__"], false]
    - ["pp3211002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__and__"], false]
    - ["pp3211003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__and__"], false]
    - ["pp3211004", operator.contains, [pathlib.Path.__dict__,             "__and__"], false]
    - ["pp3211005", operator.contains, [pathlib.PosixPath.__dict__,        "__and__"], false]

