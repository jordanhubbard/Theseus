spec: itertools_extra
version: ">=3.0"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "Python itertools documentation — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers aspects not in itertools.zspec.zsdl or itertools_product.zspec.zsdl."
    - "filterfalse.__name__ is not present in the existing itertools spec; covered here."
    - "chain([1,2],[3,4]) yields 4 elements; __length_hint__ reports 4 before any consumption."
    - "repeat(7, 3) is a bounded repeat; __length_hint__() == 3 and first element is 7."
    - "islice([0..4], 3).__length_hint__() == 3; first element is 0."
    - "Lambda-based tests (takewhile, dropwhile, filterfalse with predicates) cannot be serialized to ZSDL and are omitted."
    - "All expected values verified by running Python 3.14 on macOS Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# filterfalse — class identity (not in itertools.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant itertools_extra.classnames.filterfalse:
  description: "itertools.filterfalse.__name__ == 'filterfalse'"
  category: classnames
  kind: python_call_eq
  function: filterfalse.__name__.__eq__
  args: ["filterfalse"]
  expected: true

# ---------------------------------------------------------------------------
# chain — length hint for two-list chain
#
# chain([1,2],[3,4]) has __length_hint__() == 4 before any elements are consumed.
# First element verified via __next__ (already in itertools.zspec.zsdl for [10,20],[30];
# here we use a different fixture to avoid exact duplication).
# ---------------------------------------------------------------------------

invariant itertools_extra.chain.length_hint_four:
  description: "chain([1,2],[3,4]).__length_hint__() == 4 — total elements across both iterables"
  category: chain
  kind: python_call_eq
  function: chain
  args: [[1, 2], [3, 4]]
  method: __length_hint__
  expected: 4

# ---------------------------------------------------------------------------
# repeat — bounded repeat length hint and element value
#
# repeat(7, 3) yields 7 exactly 3 times.
# __length_hint__() == 3 before consumption.
# __next__() == 7 — each yielded value is 7.
# ---------------------------------------------------------------------------

invariant itertools_extra.repeat.bounded_length_hint:
  description: "repeat(7, 3).__length_hint__() == 3 — bounded repeat knows its remaining count"
  category: repeat
  kind: python_call_eq
  function: repeat
  args: [7, 3]
  method: __length_hint__
  expected: 3

invariant itertools_extra.repeat.bounded_first_element:
  description: "repeat(7, 3).__next__() == 7"
  category: repeat
  kind: python_call_eq
  function: repeat
  args: [7, 3]
  method: __next__
  expected: 7

# ---------------------------------------------------------------------------
# islice — first element and length hint
#
# islice([0,1,2,3,4], 3) yields 0, 1, 2.
# __length_hint__() == 3 before any consumption.
# __next__() == 0 — first element.
# ---------------------------------------------------------------------------

invariant itertools_extra.islice.length_hint_three:
  description: "islice([0,1,2,3,4], 3).__length_hint__() == 3"
  category: islice
  kind: python_call_eq
  function: islice
  args: [[0, 1, 2, 3, 4], 3]
  method: __length_hint__
  expected: 3

invariant itertools_extra.islice.first_element_zero:
  description: "islice([0,1,2,3,4], 3).__next__() == 0"
  category: islice
  kind: python_call_eq
  function: islice
  args: [[0, 1, 2, 3, 4], 3]
  method: __next__
  expected: 0
