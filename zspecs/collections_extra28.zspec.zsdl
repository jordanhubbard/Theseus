spec: collections_extra28
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections_extra27.zspec.zsdl."
    - "collections_extra27 covers: deque.pop/popleft/extend method qualnames; defaultdict.__missing__ qualname."
    - "collections_extra26 covers: OrderedDict.__setitem__/move_to_end; Counter.update/most_common; deque.append/appendleft/rotate; ChainMap.new_child method qualnames."
    - "collections_extra25 covers: __qualname__.__len__() for nine core collections classes."
    - "No prior collections spec records __qualname__/__module__ for OrderedDict/ChainMap, or class-level qualnames for UserDict/UserList/UserString, or their __bases__[0].__name__, together in the extra28 namespace."
    - "Focus: class __qualname__ and __module__ for OrderedDict and ChainMap; class qualnames and base class names for UserDict/UserList/UserString; UserDict/UserList method qualnames."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — OrderedDict and ChainMap class qualnames
#
# collections.OrderedDict and collections.ChainMap are Python-level classes
# defined in Lib/collections/__init__.py. Their qualnames are simple names
# equal to their class names, confirming module-level (non-nested) definition.
# No prior collections spec records both OrderedDict and ChainMap class
# qualnames together in the extra28 namespace.
# ---------------------------------------------------------------------------

table collections_extra28.ordereddict_chainmap_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra28.ordereddict_chainmap_qualnames.ordereddict,
       OrderedDict.__qualname__.__eq__,
       ["OrderedDict"],
       true,
       "collections.OrderedDict.__qualname__ == 'OrderedDict'"]
    - [collections_extra28.ordereddict_chainmap_qualnames.chainmap,
       ChainMap.__qualname__.__eq__,
       ["ChainMap"],
       true,
       "collections.ChainMap.__qualname__ == 'ChainMap'"]

# ---------------------------------------------------------------------------
# __module__.__eq__ table — OrderedDict and ChainMap module membership
#
# Both OrderedDict and ChainMap are defined in the 'collections' module.
# Their __module__ attributes confirm the public module name, not any
# private implementation module.
# No prior collections spec records these __module__ values in the extra28
# namespace.
# ---------------------------------------------------------------------------

table collections_extra28.ordereddict_chainmap_modules:
  kind: python_call_eq
  category: module_membership
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra28.ordereddict_chainmap_modules.ordereddict,
       OrderedDict.__module__.__eq__,
       ["collections"],
       true,
       "collections.OrderedDict.__module__ == 'collections'"]
    - [collections_extra28.ordereddict_chainmap_modules.chainmap,
       ChainMap.__module__.__eq__,
       ["collections"],
       true,
       "collections.ChainMap.__module__ == 'collections'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — UserDict, UserList, UserString class qualnames
#
# UserDict, UserList, and UserString are Python-level wrapper classes defined
# in Lib/collections/__init__.py. Each has a simple qualname equal to its
# class name, confirming they are top-level (non-nested) definitions.
# No prior collections spec records all three User* class qualnames together
# in the extra28 namespace.
# ---------------------------------------------------------------------------

table collections_extra28.user_class_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra28.user_class_qualnames.userdict,
       UserDict.__qualname__.__eq__,
       ["UserDict"],
       true,
       "collections.UserDict.__qualname__ == 'UserDict'"]
    - [collections_extra28.user_class_qualnames.userlist,
       UserList.__qualname__.__eq__,
       ["UserList"],
       true,
       "collections.UserList.__qualname__ == 'UserList'"]
    - [collections_extra28.user_class_qualnames.userstring,
       UserString.__qualname__.__eq__,
       ["UserString"],
       true,
       "collections.UserString.__qualname__ == 'UserString'"]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__eq__ table — base classes for User* types
#
# UserDict inherits from MutableMapping, UserList from MutableSequence, and
# UserString from Sequence. These ABC base classes reflect the abstract
# interface each User* type implements.
# No prior collections spec records all three User* base class names together
# in the extra28 namespace.
# ---------------------------------------------------------------------------

table collections_extra28.user_class_bases:
  kind: python_call_eq
  category: inheritance
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra28.user_class_bases.userdict,
       "UserDict.__bases__[0].__name__.__eq__",
       ["MutableMapping"],
       true,
       "collections.UserDict.__bases__[0].__name__ == 'MutableMapping'"]
    - [collections_extra28.user_class_bases.userlist,
       "UserList.__bases__[0].__name__.__eq__",
       ["MutableSequence"],
       true,
       "collections.UserList.__bases__[0].__name__ == 'MutableSequence'"]
    - [collections_extra28.user_class_bases.userstring,
       "UserString.__bases__[0].__name__.__eq__",
       ["Sequence"],
       true,
       "collections.UserString.__bases__[0].__name__ == 'Sequence'"]

# ---------------------------------------------------------------------------
# UserDict method qualnames table
#
# UserDict.__getitem__, __setitem__, __delitem__, and __contains__ are
# Python-level methods defined in Lib/collections/__init__.py. Their qualnames
# follow the 'UserDict.<method>' nested pattern.
# No prior collections spec records these UserDict method qualnames in the
# extra28 namespace.
# ---------------------------------------------------------------------------

table collections_extra28.userdict_method_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra28.userdict_method_qualnames.getitem,
       "UserDict.__getitem__.__qualname__.__eq__",
       ["UserDict.__getitem__"],
       true,
       "collections.UserDict.__getitem__.__qualname__ == 'UserDict.__getitem__'"]
    - [collections_extra28.userdict_method_qualnames.setitem,
       "UserDict.__setitem__.__qualname__.__eq__",
       ["UserDict.__setitem__"],
       true,
       "collections.UserDict.__setitem__.__qualname__ == 'UserDict.__setitem__'"]
    - [collections_extra28.userdict_method_qualnames.delitem,
       "UserDict.__delitem__.__qualname__.__eq__",
       ["UserDict.__delitem__"],
       true,
       "collections.UserDict.__delitem__.__qualname__ == 'UserDict.__delitem__'"]
    - [collections_extra28.userdict_method_qualnames.contains,
       "UserDict.__contains__.__qualname__.__eq__",
       ["UserDict.__contains__"],
       true,
       "collections.UserDict.__contains__.__qualname__ == 'UserDict.__contains__'"]

# ---------------------------------------------------------------------------
# OrderedDict.__qualname__.__eq__ — standalone class qualname
#
# collections.OrderedDict is a Python-level class defined at module scope.
# Its qualname is 'OrderedDict', equal to its __name__, confirming it is not
# nested inside any other class or function.
# No prior collections spec records this standalone in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra28.OrderedDict.qualname:
  description: "collections.OrderedDict.__qualname__ == 'OrderedDict'"
  category: qualnames
  kind: python_call_eq
  function: OrderedDict.__qualname__.__eq__
  args: ["OrderedDict"]
  expected: true

# ---------------------------------------------------------------------------
# UserList.append.__qualname__.__eq__ — standalone method qualname
#
# collections.UserList.append is a Python-level method that delegates to the
# underlying list. Its qualname is 'UserList.append', confirming scope within
# the UserList class.
# No prior collections spec records this standalone in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra28.UserList.append.qualname:
  description: "collections.UserList.append.__qualname__ == 'UserList.append'"
  category: qualnames
  kind: python_call_eq
  function: UserList.append.__qualname__.__eq__
  args: ["UserList.append"]
  expected: true

# ---------------------------------------------------------------------------
# UserDict.__module__.__eq__ — standalone module membership
#
# collections.UserDict.__module__ is 'collections', confirming it is exported
# from the public collections namespace rather than a private submodule.
# No prior collections spec records this standalone in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra28.UserDict.module:
  description: "collections.UserDict.__module__ == 'collections'"
  category: module_membership
  kind: python_call_eq
  function: UserDict.__module__.__eq__
  args: ["collections"]
  expected: true
