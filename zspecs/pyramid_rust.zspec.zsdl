spec: pyramid_rust
version: ">=3.9"
backend: rust_module(pyramid_rust)

docs: https://trypyramid.com/

provenance:
  derived_from:
    - "https://trypyramid.com/ — Pyramid web framework"
  notes:
    - "Pyramid is a Python web framework."
    - "pyramid.config.Configurator is a class."
    - "pyramid.request.Request is a class."
    - "pyramid.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pyramid_rust.has_configurator:
  description: "pyramid.config.Configurator is a class"
  category: presence
  kind: python_call_eq
  function: pyramid_has_configurator
  args: []
  expected: true

invariant pyramid_rust.has_request:
  description: "pyramid.request.Request is a class"
  category: presence
  kind: python_call_eq
  function: pyramid_has_request
  args: []
  expected: true

invariant pyramid_rust.version_nonempty:
  description: "pyramid.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pyramid_version_nonempty
  args: []
  expected: true

