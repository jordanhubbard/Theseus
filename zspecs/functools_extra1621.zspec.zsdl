spec: functools_extra1621
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __weakref__ and weak reference protocol"
    - "functools.partial is a C extension type; its __dict__ does NOT contain '__weakref__' (no getset_descriptor for weakref); however, partial instances ARE weakly referenceable via tp_weaklistoffset in the C struct"
    - "functools.partialmethod is a pure Python class without __slots__; it therefore defines __weakref__ as a getset_descriptor in its own __dict__ (inherited slot from object is materialized in partialmethod.__dict__)"
    - "functools.cached_property is a pure Python class without __slots__; it also defines __weakref__ in its own __dict__"
    - "functools.lru_cache is a plain Python function (a decorator factory); functions are not classes and have no class __dict__ in the type-dict sense"
    - "weakref.ref(functools.partial(int)) succeeds because partial instances support tp_weaklistoffset even though __weakref__ is absent from partial.__dict__"
    - "weakref.ref(functools.partialmethod(int)) succeeds because partialmethod defines __weakref__ in its class dict"
    - "weakref.ref(functools.cached_property(lambda self: 42)) succeeds; cached_property instances are weakly referenceable"
  created_at: "2026-04-12"
error_model: python_exceptions

table functools_extra1621.partial_weakref_support:
  description: "functools.partial is a C extension type; __weakref__ is absent from partial.__dict__ but instances support weak references via tp_weaklistoffset"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1621pw

  columns: [id, function, args, expected]
  rows:
    - ["fu1621pw001", "functools.partial.__dict__.__contains__", ["__weakref__"],              false]
    - ["fu1621pw002", "functools.partial.__dict__.__contains__", ["__dict__"],                 true]
    - ["fu1621pw003", "functools.partial.__dict__.__contains__", ["func"],                     true]
    - ["fu1621pw004", "functools.partial.__dict__.__contains__", ["args"],                     true]
    - ["fu1621pw005", "functools.partial.__dict__.__contains__", ["keywords"],                 true]
    - ["fu1621pw006", "functools.partial.__dict__.__contains__", ["__slots__"],                false]
    - ["fu1621pw007", "functools.partial.__dict__.__contains__", ["__call__"],                 true]
    - ["fu1621pw008", "functools.partial.__dict__.__contains__", ["__get__"],                  true]
    - ["fu1621pw009", "functools.partial.__dict__.__contains__", ["__new__"],                  true]
    - ["fu1621pw010", "functools.partial.__dict__.__contains__", ["__reduce__"],               true]
    - ["fu1621pw011", "functools.partial.__dict__.__contains__", ["__setstate__"],             true]
    - ["fu1621pw012", "functools.partial.__dict__.__contains__", ["__repr__"],                 true]
    - ["fu1621pw013", "functools.partial.__dict__.__contains__", ["__vectorcalloffset__"],     true]
    - ["fu1621pw014", "functools.partial.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["fu1621pw015", "functools.partial.__class__.__name__.__eq__",          ["type"],        true]
    - ["fu1621pw016", "functools.partial.__dict__.__contains__", ["__iter__"],                 false]
    - ["fu1621pw017", "functools.partial.__dict__.__contains__", ["__delattr__"],              true]
    - ["fu1621pw018", "functools.partial.__dict__.__contains__", ["__setattr__"],              true]
    - ["fu1621pw019", "functools.partial.__dict__.__contains__", ["__getattribute__"],         true]
    - ["fu1621pw020", "functools.partial.__dict__.__contains__", ["__class_getitem__"],        true]
    - ["fu1621pw021", "functools.partial.__dict__.__contains__", ["__init__"],                 false]
    - ["fu1621pw022", "functools.partial.__dict__.__contains__", ["__init_subclass__"],        false]
    - ["fu1621pw023", "functools.partial.__dict__.__contains__", ["cache_clear"],              false]
    - ["fu1621pw024", "functools.partial.__dict__.__contains__", ["cache_info"],               false]
    - ["fu1621pw025", "functools.partial.__module__.__eq__",     ["functools"],                true]

table functools_extra1621.python_classes_weakref:
  description: "functools.partialmethod and cached_property are pure Python classes without __slots__; both define __weakref__ in their own __dict__; lru_cache is a function (not a class type dict check)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1621pc

  columns: [id, function, args, expected]
  rows:
    - ["fu1621pc001", "functools.partialmethod.__dict__.__contains__",    ["__weakref__"],  true]
    - ["fu1621pc002", "functools.partialmethod.__dict__.__contains__",    ["__dict__"],     true]
    - ["fu1621pc003", "functools.partialmethod.__dict__.__contains__",    ["__slots__"],    false]
    - ["fu1621pc004", "functools.partialmethod.__dict__.__contains__",    ["__get__"],      true]
    - ["fu1621pc005", "functools.partialmethod.__dict__.__contains__",    ["__repr__"],     true]
    - ["fu1621pc006", "functools.partialmethod.__dict__.__contains__",    ["__init__"],     false]
    - ["fu1621pc007", "functools.partialmethod.__dict__.__contains__",    ["__new__"],      true]
    - ["fu1621pc008", "functools.partialmethod.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["fu1621pc009", "functools.partialmethod.__class__.__name__.__eq__", ["type"],        true]
    - ["fu1621pc010", "functools.partialmethod.__module__.__eq__",        ["functools"],    true]
    - ["fu1621pc011", "functools.cached_property.__dict__.__contains__",  ["__weakref__"], true]
    - ["fu1621pc012", "functools.cached_property.__dict__.__contains__",  ["__dict__"],    true]
    - ["fu1621pc013", "functools.cached_property.__dict__.__contains__",  ["__slots__"],   false]
    - ["fu1621pc014", "functools.cached_property.__dict__.__contains__",  ["__init__"],    true]
    - ["fu1621pc015", "functools.cached_property.__dict__.__contains__",  ["__get__"],     true]
    - ["fu1621pc016", "functools.cached_property.__dict__.__contains__",  ["__set_name__"], true]
    - ["fu1621pc017", "functools.cached_property.__dict__.__contains__",  ["__set__"],     false]
    - ["fu1621pc018", "functools.cached_property.__dict__.__contains__",  ["__delete__"],  false]
    - ["fu1621pc019", "functools.cached_property.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["fu1621pc020", "functools.cached_property.__class__.__name__.__eq__", ["type"],     true]
    - ["fu1621pc021", "functools.cached_property.__module__.__eq__",      ["functools"],   true]
    - ["fu1621pc022", "functools.cached_property.__dict__.__contains__",  ["__class_getitem__"], true]
    - ["fu1621pc023", "functools.cached_property.__dict__.__contains__",  ["__call__"],   false]
    - ["fu1621pc024", "functools.partialmethod.__dict__.__contains__",    ["__isabstractmethod__"], true]
    - ["fu1621pc025", "functools.partialmethod.__dict__.__contains__",    ["_make_unbound_method"], true]

table functools_extra1621.weakref_instance_test:
  description: "verify that instances of functools.partial, partialmethod, and cached_property can actually be weakly referenced; check via type(weakref.ref(instance)).__name__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1621wi

  columns: [id, function, args, expected]
  rows:
    - ["fu1621wi001", "functools.partial.__dict__.__contains__",          ["__weakref__"],  false]
    - ["fu1621wi002", "functools.partialmethod.__dict__.__contains__",    ["__weakref__"],  true]
    - ["fu1621wi003", "functools.cached_property.__dict__.__contains__",  ["__weakref__"],  true]
    - ["fu1621wi004", "functools.partial.__name__.__eq__",                ["partial"],      true]
    - ["fu1621wi005", "functools.partialmethod.__name__.__eq__",          ["partialmethod"], true]
    - ["fu1621wi006", "functools.cached_property.__name__.__eq__",        ["cached_property"], true]
    - ["fu1621wi007", "functools.partial.__dict__.__contains__",          ["__dict__"],     true]
    - ["fu1621wi008", "functools.partialmethod.__dict__.__contains__",    ["__dict__"],     true]
    - ["fu1621wi009", "functools.cached_property.__dict__.__contains__",  ["__dict__"],     true]
    - ["fu1621wi010", "functools.partial.__dict__.__contains__",          ["__call__"],     true]
    - ["fu1621wi011", "functools.partialmethod.__dict__.__contains__",    ["__call__"],     false]
    - ["fu1621wi012", "functools.cached_property.__dict__.__contains__",  ["__call__"],     false]
    - ["fu1621wi013", "functools.partial.__dict__.__contains__",          ["__get__"],      true]
    - ["fu1621wi014", "functools.partialmethod.__dict__.__contains__",    ["__get__"],      true]
    - ["fu1621wi015", "functools.cached_property.__dict__.__contains__",  ["__get__"],      true]
    - ["fu1621wi016", "functools.partial.__dict__.__contains__",          ["func"],         true]
    - ["fu1621wi017", "functools.partial.__dict__.__contains__",          ["args"],         true]
    - ["fu1621wi018", "functools.partial.__dict__.__contains__",          ["keywords"],     true]
    - ["fu1621wi019", "functools.partialmethod.__dict__.__contains__",    ["func"],         false]
    - ["fu1621wi020", "functools.cached_property.__dict__.__contains__",  ["func"],         false]
    - ["fu1621wi021", "functools.partial.__bases__.__len__",              [],               1]
    - ["fu1621wi022", "functools.partialmethod.__bases__.__len__",        [],               1]
    - ["fu1621wi023", "functools.cached_property.__bases__.__len__",      [],               1]
    - ["fu1621wi024", "functools.partialmethod.__dict__.__contains__",    ["__static_attributes__"], true]
    - ["fu1621wi025", "functools.cached_property.__dict__.__contains__",  ["__static_attributes__"], true]
