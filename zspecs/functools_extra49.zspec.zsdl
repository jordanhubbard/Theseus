spec: functools_extra49
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra48.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps/partial/lru_cache/total_ordering/singledispatch/cached_property/reduce/cmp_to_key/partialmethod/singledispatchmethod/update_wrapper; __qualname__.__len__() for update_wrapper/partialmethod/singledispatchmethod/cache/total_ordering/singledispatch/cmp_to_key/cached_property/lru_cache/wraps/reduce/partial; WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES lengths; __all__ lengths and indexed elements; partial/__class__.__name__; cached_property/__set_name__/__get__/__init__.__qualname__; total_ordering/__dict__.__class__.__name__; partial/__new__.__qualname__; class __dict__.__class__.__name__.__len__ for partial/partialmethod/singledispatchmethod/cached_property; partial/__doc__/reduce/__doc__; reduce with initial value; lru_cache(128).__ne__(None)==True; C-extension vs pure-Python __module__ lengths; lru_cache(maxsize=2) behavioral; reduce.__qualname__=='reduce'; lru_cache.__qualname__=='lru_cache'; cache/__name__/__qualname__/__module__; cached_property/__name__/__qualname__/__module__/__bases__[0].__name__; total_ordering/__name__/__qualname__/__module__; singledispatch/__name__/__qualname__/__module__; wraps/__name__/__qualname__/__module__; update_wrapper/__name__/__qualname__/__module__; partial/__bases__[0].__name__=='object'; partial.__name__/'partial'; partial.__qualname__/'partial'; partial.__module__/'functools'; lru_cache/__name__/__module__; cmp_to_key/__name__=='cmp_to_key'; cmp_to_key.__module__.__len__()==10; partialmethod.__name__/__qualname__/__module__/__bases__[0].__name__; partial.__qualname__=='partial'; reduce.__name__.__len__()==6; cmp_to_key.__module__=='_functools'."
    - "This spec covers: functools.partialmethod.__qualname__.__len__() == 13; functools.wraps.__qualname__.__len__() == 5; functools.update_wrapper.__qualname__.__len__() == 14; functools.cmp_to_key.__qualname__ == 'cmp_to_key'; functools.cmp_to_key.__qualname__.__len__() == 10; functools.reduce.__module__.__len__() == 10; functools.singledispatchmethod.__name__ == 'singledispatchmethod'; functools.singledispatchmethod.__module__ == 'functools'; functools.singledispatchmethod.__qualname__ == 'singledispatchmethod'."
    - "Key findings: functools.partialmethod.__qualname__.__len__() is 13 — 'partialmethod' is 13 chars; pure-Python class at module level; prior specs recorded partialmethod.__qualname__=='partialmethod' (extra48) so the length is implicit but no prior spec isolated the len() call directly. functools.wraps.__qualname__.__len__() is 5 — 'wraps' is 5 chars; pure-Python decorator function at module level. functools.update_wrapper.__qualname__.__len__() is 14 — 'update_wrapper' is 14 chars. functools.cmp_to_key.__qualname__ is 'cmp_to_key' — a C-extension builtin_function_or_method; as a module-level C function its __qualname__ equals __name__ ('cmp_to_key'); prior specs recorded cmp_to_key.__name__=='cmp_to_key' and __module__=='_functools' but not __qualname__ string equality. functools.cmp_to_key.__qualname__.__len__() is 10 (same string as __name__ and __module__). functools.reduce.__module__.__len__() is 10 — 'reduce' is in the C extension '_functools'; len('_functools')==10; prior specs recorded cmp_to_key.__module__.__len__()==10 and reduce.__module__.__eq__('_functools') would follow the same path but the direct __len__() call is new. functools.singledispatchmethod.__name__ is 'singledispatchmethod' (20 chars), __module__ is 'functools' (9 chars), and __qualname__ is 'singledispatchmethod' (20 chars) — pure-Python class defined at module level in Lib/functools.py; prior specs recorded singledispatchmethod.__qualname__.__len__() (==20) but not the string equality invariants for __name__, __module__, or __qualname__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools qualname __len__() invariants — extra49 namespace
#
# functools.partialmethod.__qualname__.__len__() == 13 ('partialmethod'),
# functools.wraps.__qualname__.__len__() == 5 ('wraps'), and
# functools.update_wrapper.__qualname__.__len__() == 14 ('update_wrapper').
# All three are pure-Python objects defined at module level in Lib/functools.py;
# __qualname__ == __name__ in each case. Prior specs recorded the string equality
# invariants for these names (via extra48 and earlier) so the lengths are
# derivable, but no prior spec recorded these specific __len__() calls as
# standalone invariants. These three are new to extra49.
# ---------------------------------------------------------------------------

table functools_extra49.qualname_lengths:
  description: "functools partialmethod/wraps/update_wrapper __qualname__.__len__() — pure-Python module-level objects; __qualname__ == __name__ in each case"
  kind: python_call_eq
  category: string_properties
  id_prefix: qlen49

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_qualname_len,
       partialmethod.__qualname__.__len__,
       [],
       13,
       "len(functools.partialmethod.__qualname__) == 13 — 'partialmethod' is 13 chars; pure-Python class; top-level so __qualname__ == __name__"]
    - [wraps_qualname_len,
       wraps.__qualname__.__len__,
       [],
       5,
       "len(functools.wraps.__qualname__) == 5 — 'wraps' is 5 chars; pure-Python decorator; top-level function so __qualname__ == __name__"]
    - [update_wrapper_qualname_len,
       update_wrapper.__qualname__.__len__,
       [],
       14,
       "len(functools.update_wrapper.__qualname__) == 14 — 'update_wrapper' is 14 chars; pure-Python function; top-level so __qualname__ == __name__"]

# ---------------------------------------------------------------------------
# functools.cmp_to_key __qualname__ — extra49 namespace
#
# functools.cmp_to_key.__qualname__ is 'cmp_to_key' (10 chars). cmp_to_key is
# a C-extension builtin_function_or_method defined in Modules/_functoolsmodule.c.
# For C-extension functions at module level, __qualname__ == __name__. Prior
# specs recorded cmp_to_key.__name__ == 'cmp_to_key' (extra4) and
# cmp_to_key.__module__ == '_functools' (extra48) but no prior spec recorded
# the string equality invariant for cmp_to_key.__qualname__. Both the equality
# and __len__() invariants are new to extra49.
# ---------------------------------------------------------------------------

table functools_extra49.cmp_to_key_qualname:
  description: "functools.cmp_to_key __qualname__ string equality and length — C-extension function; __qualname__ == __name__ == 'cmp_to_key'; 10 chars"
  kind: python_call_eq
  category: identity
  id_prefix: ctkq49

  columns: [id, function, args, expected, description]
  rows:
    - [cmp_to_key_qualname,
       cmp_to_key.__qualname__.__eq__,
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__qualname__ == 'cmp_to_key' — C-extension function in _functoolsmodule.c; module-level function; __qualname__ == __name__; 10 chars"]
    - [cmp_to_key_qualname_len,
       cmp_to_key.__qualname__.__len__,
       [],
       10,
       "len(functools.cmp_to_key.__qualname__) == 10 — 'cmp_to_key' is 10 chars; same length as __module__ '_functools' (also 10 chars)"]

# ---------------------------------------------------------------------------
# functools.reduce __module__.__len__() — extra49 namespace
#
# functools.reduce.__module__.__len__() is 10 — reduce is a C-extension
# builtin_function_or_method defined in Modules/_functoolsmodule.c; its
# __module__ is '_functools' (10 chars, same as cmp_to_key.__module__). Prior
# spec extra43 recorded cmp_to_key.__module__.__len__()==10 and extra48 recorded
# cmp_to_key.__module__=='_functools', but no prior spec recorded the __len__()
# call specifically on reduce.__module__. This invariant is new to extra49.
# ---------------------------------------------------------------------------

invariant functools_extra49.reduce_module_len:
  description: "len(functools.reduce.__module__) == 10 — '__module__' is '_functools'; 10-char C extension name; same length as cmp_to_key.__module__; both are C-extension objects in _functoolsmodule.c"
  category: string_properties
  kind: python_call_eq
  function: reduce.__module__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# functools.singledispatchmethod identity metadata — extra49 namespace
#
# functools.singledispatchmethod.__name__ is 'singledispatchmethod' (20 chars),
# functools.singledispatchmethod.__module__ is 'functools' (9 chars), and
# functools.singledispatchmethod.__qualname__ is 'singledispatchmethod' (20 chars).
# singledispatchmethod is a pure-Python class defined at module level in
# Lib/functools.py. As a top-level class __qualname__ == __name__. Prior specs
# recorded singledispatchmethod.__qualname__.__len__()==20 and
# singledispatchmethod.__name__.__len__()==20 but not the string equality
# invariants for __name__, __module__, or __qualname__. These three are new.
# ---------------------------------------------------------------------------

table functools_extra49.singledispatchmethod_identity:
  description: "functools.singledispatchmethod __name__, __module__, and __qualname__ string equality — pure-Python class at module level in Lib/functools.py"
  kind: python_call_eq
  category: identity
  id_prefix: sdmid49

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatchmethod_name,
       singledispatchmethod.__name__.__eq__,
       ["singledispatchmethod"],
       true,
       "functools.singledispatchmethod.__name__ == 'singledispatchmethod' — pure-Python class; 20-char name; descriptor enabling single-dispatch on methods (not bare functions)"]
    - [singledispatchmethod_module,
       singledispatchmethod.__module__.__eq__,
       ["functools"],
       true,
       "functools.singledispatchmethod.__module__ == 'functools' — pure-Python class defined in Lib/functools.py; 9-char module name; same as all pure-Python functools classes"]
    - [singledispatchmethod_qualname,
       singledispatchmethod.__qualname__.__eq__,
       ["singledispatchmethod"],
       true,
       "functools.singledispatchmethod.__qualname__ == 'singledispatchmethod' — top-level class; __qualname__ == __name__ (no enclosing class scope); 20 chars; same string as __name__"]
