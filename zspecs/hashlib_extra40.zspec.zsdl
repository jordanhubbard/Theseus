spec: hashlib_extra40
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "hashlib_extra39.zspec.zsdl — covers sha3_512 hexdigest len (128); hashlib.__class__.__name__.__len__()==6; sha256.__doc__.__class__.__name__.__len__()==3; scrypt.__name__.__len__()==6."
    - "hashlib_extra38.zspec.zsdl — covers pbkdf2_hmac.__name__.__len__()==11; sha3_256/sha3_224/sha3_384/blake2b/blake2s hexdigest lengths via method_chain."
    - "hashlib_extra36.zspec.zsdl — covers sha3_224/sha3_384 __name__.__len__()==16 and __module__.__len__()==8; shake_128/shake_256 __qualname__.__len__()==17."
    - "hashlib_extra34.zspec.zsdl — covers hashlib.__all__.__class__.__name__.__len__()==5; new.__class__.__name__.__len__()==8."
    - "hashlib_extra33.zspec.zsdl — covers sha3_512/shake_128/shake_256 __name__.__len__()==16; algorithms_guaranteed/__class__/__name__.__len__()==3."
    - "hashlib_extra32.zspec.zsdl — covers sha1/sha512/sha224/sha384/blake2b/blake2s/sha3_256 __module__.__len__(); blake2b/blake2s __name__.__len__()==7; sha3_256.__name__.__len__()==16."
    - "hashlib_extra31.zspec.zsdl — covers md5/sha1/sha256/sha512/sha224/sha384 __name__.__len__()."
    - "hashlib_extra24.zspec.zsdl — covers md5/sha1/sha256/sha512/sha224/sha384/new/pbkdf2_hmac __qualname__.__len__()."
  notes:
    - "This spec extends hashlib through hashlib_extra39; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: sha3_256/sha3_224/sha3_384/sha3_512 __module__.__len__() for sha3_256 (extra32) and sha3_224/sha3_384 (extra36); sha3_512 __module__ NOT covered. Prior: scrypt.__name__.__len__()==6 (extra39) but NOT __qualname__.__len__(). Prior: sha256.__doc__.__class__.__name__.__len__()==3 (extra39) but NOT md5 or blake2b.__doc__ class name len."
    - "sha3_512.__module__ == '_hashlib' (len 8). extra32 covers sha3_256.__module__.__len__()==8; extra36 covers sha3_224/sha3_384.__module__.__len__()==8; sha3_512 is absent from all prior __module__.__len__() tables. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "scrypt.__qualname__ == 'scrypt' (len 6). extra39 covers scrypt.__name__.__len__()==6; for C-level builtin functions __qualname__==__name__; but __qualname__.__len__() has not been checked. The __qualname__ axis is a distinct regression invariant from __name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "scrypt.__module__ == '_hashlib' (len 8). No prior spec checks scrypt.__module__ in any capacity. scrypt is OpenSSL-backed and lives in _hashlib. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "md5.__doc__.__class__.__name__ == 'str' (len 3). extra39 checks sha256.__doc__.__class__.__name__.__len__()==3 but NOT md5. The same pattern applied to md5 is novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "sha256(b'').digest_size == 32. The digest_size attribute of a HASH instance gives the number of bytes in the digest. sha256 produces 32 bytes. No prior spec checks digest_size directly for any HASH instance. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "sha512(b'').digest_size == 64. SHA-512 produces 64 bytes. No prior spec checks sha512 digest_size. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "md5(b'').digest_size == 16. MD5 produces 16 bytes. No prior spec checks md5 digest_size. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "sha1(b'').digest_size == 20. SHA-1 produces 20 bytes. No prior spec checks sha1 digest_size. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sha3_512.__module__.__len__()
#
# extra32 covers sha3_256.__module__.__len__()==8 ('_hashlib').
# extra36 covers sha3_224.__module__.__len__()==8 and sha3_384.__module__.__len__()==8.
# sha3_512 is absent from both tables. sha3_512.__module__ == '_hashlib' (len 8).
# This invariant closes that gap for the sha3_512 variant.
# ---------------------------------------------------------------------------

invariant hashlib_extra40.sha3_512.module_len:
  description: "hashlib.sha3_512.__module__.__len__() == 8 — '_hashlib' has 8 chars; novel: extra32 covers sha3_256; extra36 covers sha3_224/sha3_384; sha3_512 absent from all prior __module__.__len__() tables"
  category: module_metadata
  kind: python_call_eq
  function: sha3_512.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# scrypt.__qualname__.__len__() and scrypt.__module__.__len__()
#
# extra39 covers scrypt.__name__.__len__()==6.
# For C-level builtin_function_or_method objects, __qualname__ == __name__,
# so scrypt.__qualname__ == 'scrypt' (len 6). The __qualname__ axis is a
# distinct regression invariant from __name__.
#
# scrypt.__module__ == '_hashlib' (len 8). No prior spec checks scrypt.__module__
# in any capacity — neither via __eq__ nor via __len__().
# ---------------------------------------------------------------------------

table hashlib_extra40.scrypt_qualname_and_module:
  description: "hashlib.scrypt __qualname__.__len__()==6 (novel __qualname__ axis vs extra39 __name__) and __module__.__len__()==8 (novel; no prior spec checks scrypt.__module__)"
  kind: python_call_eq
  category: function_names
  id_prefix: scrqm40

  columns: [id, function, args, expected]
  rows:
    - [qualname_len, scrypt.__qualname__.__len__, [], 6]
    - [module_len,   scrypt.__module__.__len__,   [], 8]

# ---------------------------------------------------------------------------
# md5.__doc__.__class__.__name__.__len__()
#
# extra39 checks sha256.__doc__.__class__.__name__.__len__()==3 — the docstring
# of sha256 is a str, and 'str' has 3 chars.
# No prior spec checks this same pattern for md5. md5.__doc__ is also a str,
# so md5.__doc__.__class__.__name__ == 'str' (len 3). Novel: different algorithm.
# ---------------------------------------------------------------------------

invariant hashlib_extra40.md5_doc.class_name_len:
  description: "hashlib.md5.__doc__.__class__.__name__.__len__() == 3 — md5 docstring is a str; 'str' has 3 chars; novel: extra39 covers sha256.__doc__ only; md5 is absent"
  category: module_metadata
  kind: python_call_eq
  function: md5.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# HASH instance digest_size values
#
# The digest_size attribute of a HASH instance gives the digest byte-length.
# No prior spec checks digest_size for any HASH instance.
# extra19 checks hexdigest string lengths (which are 2 * digest_size) but
# does not directly check the digest_size attribute itself.
# Values verified:
#   sha256(b'').digest_size == 32  (256 bits)
#   sha512(b'').digest_size == 64  (512 bits)
#   md5(b'').digest_size   == 16  (128 bits)
#   sha1(b'').digest_size  == 20  (160 bits)
# Expressed using the constructor + method_chain pattern.
# ---------------------------------------------------------------------------

invariant hashlib_extra40.sha256.digest_size:
  description: "hashlib.sha256(b'').digest_size == 32 — SHA-256 produces 32-byte digest; novel: no prior spec checks digest_size for any HASH instance (extra19 checks hexdigest string len only)"
  category: behavioral
  kind: python_call_eq
  function: sha256
  args: [!b64 ""]
  method: digest_size.__eq__
  method_args: [32]
  expected: true

invariant hashlib_extra40.sha512.digest_size:
  description: "hashlib.sha512(b'').digest_size == 64 — SHA-512 produces 64-byte digest; novel: no prior spec checks sha512 digest_size"
  category: behavioral
  kind: python_call_eq
  function: sha512
  args: [!b64 ""]
  method: digest_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra40.md5.digest_size:
  description: "hashlib.md5(b'').digest_size == 16 — MD5 produces 16-byte digest; novel: no prior spec checks md5 digest_size"
  category: behavioral
  kind: python_call_eq
  function: md5
  args: [!b64 ""]
  method: digest_size.__eq__
  method_args: [16]
  expected: true

invariant hashlib_extra40.sha1.digest_size:
  description: "hashlib.sha1(b'').digest_size == 20 — SHA-1 produces 20-byte digest; novel: no prior spec checks sha1 digest_size"
  category: behavioral
  kind: python_call_eq
  function: sha1
  args: [!b64 ""]
  method: digest_size.__eq__
  method_args: [20]
  expected: true
