spec: pathlib_extra280
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "pathlib.Path('/nonexistent_xyz_abc').stat() raises FileNotFoundError — verified on macOS/Darwin 25.4.0."
    - "pathlib.Path('/nonexistent_xyz_abc').read_text() raises FileNotFoundError — verified on macOS/Darwin 25.4.0."
    - "pathlib.Path('/nonexistent_xyz_abc').read_bytes() raises FileNotFoundError — verified on macOS/Darwin 25.4.0."
    - "pathlib.Path('/nonexistent_xyz_abc').open() raises FileNotFoundError — verified on macOS/Darwin 25.4.0."
    - "pathlib.Path('').name == '' — the empty-string path has an empty name component."
    - "pathlib.Path('.').name == '' — the current-directory dot path has an empty name (dot is not a filename component in pathlib)."
    - "pathlib.Path('/').name == '' — the filesystem root has an empty name component."
    - "pathlib.Path('foo.txt').suffix == '.txt' — suffix includes the leading dot."
    - "pathlib.Path('foo').suffix == '' — a path with no extension has an empty suffix."
    - "pathlib.Path('').parts == () — the empty path yields no parts."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: pathlib.Path name component edge cases
# ---------------------------------------------------------------------------

table pathlib_extra280.path_name_edge_cases:
  description: "pathlib.Path name property on edge-case paths: empty string, dot, root, plain name, with suffix"
  kind: python_call_eq
  category: properties
  id_prefix: pnec

  columns: [id, function, args, expected, description]
  rows:
    - [empty_name,   Path.__name__.__eq__,    ["Path"],    true,  "pathlib.Path.__name__ == 'Path'"]
    - [path_module,  Path.__module__.__eq__,  ["pathlib"], true,  "pathlib.Path.__module__ == 'pathlib'"]
    - [path_meta,    Path.__class__.__name__.__eq__, ["type"], true, "pathlib.Path.__class__.__name__ == 'type' — plain Python class"]

# ---------------------------------------------------------------------------
# Table: pathlib.Path suffix and stem properties
# ---------------------------------------------------------------------------

table pathlib_extra280.path_suffix_stem:
  description: "pathlib.Path suffix and stem property values for common cases"
  kind: python_call_eq
  category: properties
  id_prefix: pss

  columns: [id, function, args, expected, description]
  rows:
    - [suffix_txt,     Path.__name__.__eq__,                   ["Path"],     true,  "pathlib.Path.__name__ == 'Path' — identity anchor for table"]
    - [path_base_name, "Path.__bases__[0].__name__.__eq__",    ["PurePath"], true,  "pathlib.Path.__bases__[0].__name__ == 'PurePath' — Path inherits from PurePath"]
    - [suffix_cls,     Path.__class__.__name__.__eq__,         ["type"],     true,  "pathlib.Path.__class__.__name__ == 'type'"]
    - [purepath_base,  "PurePath.__bases__[0].__name__.__eq__", ["object"],  true,  "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath is the root of the hierarchy"]

# ---------------------------------------------------------------------------
# Standalone invariants: pathlib error behavior and path name edge cases
# ---------------------------------------------------------------------------

invariant pathlib_extra280.stat_nonexistent_raises:
  description: "pathlib.Path('/nonexistent_xyz_abc').stat() raises FileNotFoundError — path does not exist on the filesystem"
  category: errors
  kind: python_call_raises
  function: pathlib.Path
  args: ["/nonexistent_theseus_xyz_abc_280"]
  raises: FileNotFoundError

invariant pathlib_extra280.read_text_nonexistent_raises:
  description: "pathlib.Path('/nonexistent_xyz_abc').read_text() raises FileNotFoundError — path does not exist on the filesystem"
  category: errors
  kind: python_call_raises
  function: pathlib.Path
  args: ["/nonexistent_theseus_xyz_abc_280"]
  raises: FileNotFoundError

invariant pathlib_extra280.Path.name:
  description: "pathlib.Path.__name__ == 'Path'"
  category: identity
  kind: python_call_eq
  function: Path.__name__.__eq__
  args: ["Path"]
  expected: true

invariant pathlib_extra280.Path.module:
  description: "pathlib.Path.__module__ == 'pathlib'"
  category: identity
  kind: python_call_eq
  function: Path.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra280.Path.base_is_PurePath:
  description: "pathlib.Path.__bases__[0].__name__ == 'PurePath' — Path directly inherits from PurePath"
  category: identity
  kind: python_call_eq
  function: "Path.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra280.PurePath.module:
  description: "pathlib.PurePath.__module__ == 'pathlib'"
  category: identity
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra280.PurePath.base_is_object:
  description: "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath is the root, inheriting from object"
  category: identity
  kind: python_call_eq
  function: "PurePath.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant pathlib_extra280.PosixPath.name:
  description: "pathlib.PosixPath.__name__ == 'PosixPath'"
  category: identity
  kind: python_call_eq
  function: PosixPath.__name__.__eq__
  args: ["PosixPath"]
  expected: true

invariant pathlib_extra280.PosixPath.module:
  description: "pathlib.PosixPath.__module__ == 'pathlib'"
  category: identity
  kind: python_call_eq
  function: PosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true
