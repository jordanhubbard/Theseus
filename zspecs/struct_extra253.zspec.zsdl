spec: struct_extra253
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct.zspec.zsdl — covers big/little-endian uint16/uint32 pack/unpack, calcsize, roundtrip, and error raises"
  notes:
    - "This spec extends struct.zspec.zsdl with big-endian boundary value tests for '!B', '!H', '!I', '!Q' formats."
    - "'!' is network byte order (big-endian, RFC 1700); equivalent to '>'. struct.zspec.zsdl uses '>' and '<' exclusively."
    - "struct.pack('!B', 0) == b'\\x00'; struct.pack('!B', 255) == b'\\xff' — the full uint8 range."
    - "struct.pack('!H', 65535) == b'\\xff\\xff' — uint16 max boundary."
    - "struct.pack('!I', 4294967295) == b'\\xff\\xff\\xff\\xff' — uint32 max boundary."
    - "struct.pack('!Q', 0) == b'\\x00' * 8 — uint64 zero boundary."
    - "struct.unpack('!B', b'\\xff')[0] == 255; struct.unpack('!H', b'\\xff\\xff')[0] == 65535."
    - "struct.error.__name__ == 'error', __module__ == 'struct', base class is Exception."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pack — network byte order ('!') unsigned boundary values
# ---------------------------------------------------------------------------

table struct_extra253.pack.network_byte_order_boundaries:
  kind: python_call_eq
  category: pack_vector
  id_prefix: pack_net
  function: pack

  columns: [id, args, expected]
  rows:
    - [uint8_zero,  ["!B", 0],          !hex 00              ]
    - [uint8_max,   ["!B", 255],         !hex ff              ]
    - [uint16_zero, ["!H", 0],           !hex 0000            ]
    - [uint16_max,  ["!H", 65535],       !hex ffff            ]
    - [uint32_zero, ["!I", 0],           !hex 00000000        ]
    - [uint32_max,  ["!I", 4294967295],  !hex ffffffff        ]
    - [uint64_zero, ["!Q", 0],           !hex 0000000000000000]

# ---------------------------------------------------------------------------
# unpack — network byte order ('!') boundary values
# ---------------------------------------------------------------------------

table struct_extra253.unpack.network_byte_order_boundaries:
  kind: python_call_eq
  category: unpack_vector
  id_prefix: unpack_net
  function: unpack

  columns: [id, args, expected]
  rows:
    - [uint8_max,   ["!B", !hex ff],               [255]         ]
    - [uint16_max,  ["!H", !hex ffff],              [65535]       ]
    - [uint32_zero, ["!I", !hex 00000000],          [0]           ]
    - [uint32_max,  ["!I", !hex ffffffff],          [4294967295]  ]
    - [uint64_zero, ["!Q", !hex 0000000000000000],  [0]           ]

# ---------------------------------------------------------------------------
# struct.error class identity
# ---------------------------------------------------------------------------

invariant struct_extra253.error.name:
  description: "struct.error.__name__ == 'error'"
  category: hierarchy
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant struct_extra253.error.module:
  description: "struct.error.__module__ == 'struct'"
  category: hierarchy
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra253.error.base_is_exception:
  description: "struct.error.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"
