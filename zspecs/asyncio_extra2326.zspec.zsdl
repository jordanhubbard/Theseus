spec: asyncio_extra2326
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2326 (_extra2326): numeric constants and fixed-size attributes — class __name__ checks."
    - "Covers asyncio queue classes, synchronization primitives, task/future types, and stream classes."
    - "All __name__ values are class-level string attributes verified directly from the module."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table asyncio_extra2326.queue_names:
  description: "asyncio queue and queue exception class __name__ attribute checks"
  kind: python_call_eq
  category: class_name
  id_prefix: as2326

  columns: [id, function, args, expected]
  rows:
    - ["as2326001", "asyncio.Queue.__name__", [], "Queue"]
    - ["as2326002", "asyncio.PriorityQueue.__name__", [], "PriorityQueue"]
    - ["as2326003", "asyncio.LifoQueue.__name__", [], "LifoQueue"]
    - ["as2326004", "asyncio.QueueEmpty.__name__", [], "QueueEmpty"]
    - ["as2326005", "asyncio.QueueFull.__name__", [], "QueueFull"]

