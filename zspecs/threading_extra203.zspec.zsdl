spec: threading_extra203
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers module-level dunder attributes of threading: __name__, __package__, __spec__.name, __loader__.__class__.__name__, __builtins__.__class__.__name__."
    - "threading.__name__ == 'threading' — module identity attribute. Verified with Python 3.14.3."
    - "threading.__package__ == '' — top-level module; __package__ is empty string. Verified with Python 3.14.3."
    - "threading.__spec__.name == 'threading' — ModuleSpec.name attribute equals module name. Verified with Python 3.14.3."
    - "threading.__loader__.__class__.__name__ == 'SourceFileLoader' — threading is a pure Python source file; loader is SourceFileLoader. Verified with Python 3.14.3."
    - "threading.__builtins__.__class__.__name__ == 'dict' — in a module context __builtins__ is a dict. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading module __name__ and __package__ identity
#
# threading.__name__ == 'threading'
# threading.__package__ == ''
# threading.__name__.__class__.__name__ == 'str'
# threading.__package__.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table threading_extra203.module_name_package:
  description: "threading.__name__ and __package__ identity; new to extra203"
  kind: python_call_eq
  category: module_identity
  id_prefix: threadingmod203

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,
       __name__.__eq__,
       ["threading"],
       true,
       "threading.__name__.__eq__('threading') == True — module __name__ attribute equals 'threading'; new to extra203"]
    - [module_name_class_str,
       __name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.__name__.__class__.__name__.__eq__('str') == True — module __name__ is a str; new to extra203"]
    - [module_package_eq,
       __package__.__eq__,
       [""],
       true,
       "threading.__package__.__eq__('') == True — top-level module; __package__ is empty string; new to extra203"]
    - [module_package_class_str,
       __package__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.__package__.__class__.__name__.__eq__('str') == True — module __package__ is a str; new to extra203"]

# ---------------------------------------------------------------------------
# Table 2: threading __spec__ attributes
#
# threading.__spec__.name == 'threading'
# threading.__spec__.__class__.__name__ == 'ModuleSpec'
# threading.__spec__.parent == ''
# threading.__spec__.has_location == True
# ---------------------------------------------------------------------------

table threading_extra203.module_spec_attrs:
  description: "threading.__spec__ name, class, parent and has_location identity; new to extra203"
  kind: python_call_eq
  category: module_spec
  id_prefix: threadingmod203

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,
       __spec__.name.__eq__,
       ["threading"],
       true,
       "threading.__spec__.name.__eq__('threading') == True — ModuleSpec.name attribute equals 'threading'; new to extra203"]
    - [spec_class_name_eq,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "threading.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — __spec__ is a ModuleSpec instance; new to extra203"]
    - [spec_parent_eq,
       __spec__.parent.__eq__,
       [""],
       true,
       "threading.__spec__.parent.__eq__('') == True — top-level module; spec.parent is empty string; new to extra203"]
    - [spec_has_location_eq,
       __spec__.has_location.__eq__,
       [true],
       true,
       "threading.__spec__.has_location.__eq__(True) == True — threading is a source file module; has_location is True; new to extra203"]

# ---------------------------------------------------------------------------
# Table 3: threading __loader__, __builtins__ and __doc__ class identity
#
# threading.__loader__.__class__.__name__ == 'SourceFileLoader'
# threading.__builtins__.__class__.__name__ == 'dict'
# threading.__doc__.__class__.__name__ == 'str'
# threading.__spec__.origin.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table threading_extra203.loader_builtins_identity:
  description: "threading __loader__.__class__.__name__, __builtins__ type, __doc__ type and spec.origin type; new to extra203"
  kind: python_call_eq
  category: loader_builtins
  id_prefix: threadingmod203

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_name_eq,
       __loader__.__class__.__name__.__eq__,
       ["SourceFileLoader"],
       true,
       "threading.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — threading uses SourceFileLoader (pure Python source file); new to extra203"]
    - [builtins_class_name_eq,
       "__builtins__.__class__.__name__.__eq__",
       ["dict"],
       true,
       "threading.__builtins__.__class__.__name__.__eq__('dict') == True — in module context __builtins__ is a dict; new to extra203"]
    - [doc_class_name_eq,
       __doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.__doc__.__class__.__name__.__eq__('str') == True — module __doc__ is a str; new to extra203"]
    - [spec_origin_class_name_eq,
       __spec__.origin.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.__spec__.origin.__class__.__name__.__eq__('str') == True — spec.origin is a str (file path); new to extra203"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra203
# ---------------------------------------------------------------------------

invariant threading_extra203.module_name_eq:
  description: "threading.__name__ == 'threading' — module identity attribute is 'threading'; new to extra203"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra203.module_package_eq:
  description: "threading.__package__ == '' — top-level module; __package__ is empty string; new to extra203"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant threading_extra203.spec_name_eq:
  description: "threading.__spec__.name == 'threading' — ModuleSpec.name attribute equals module name; new to extra203"
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra203.spec_class_name_eq:
  description: "threading.__spec__.__class__.__name__ == 'ModuleSpec' — __spec__ is a ModuleSpec instance; new to extra203"
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__eq__"
  args: ["ModuleSpec"]
  expected: true

invariant threading_extra203.spec_parent_eq:
  description: "threading.__spec__.parent == '' — top-level module; spec.parent is empty string; new to extra203"
  kind: python_call_eq
  function: __spec__.parent.__eq__
  args: [""]
  expected: true

invariant threading_extra203.spec_has_location_eq:
  description: "threading.__spec__.has_location == True — threading is a source file module; has_location is True; new to extra203"
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true

invariant threading_extra203.loader_class_name_eq:
  description: "threading.__loader__.__class__.__name__ == 'SourceFileLoader' — threading uses SourceFileLoader; new to extra203"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant threading_extra203.builtins_class_name_eq:
  description: "threading.__builtins__.__class__.__name__ == 'dict' — in module context __builtins__ is a dict; new to extra203"
  kind: python_call_eq
  function: "__builtins__.__class__.__name__.__eq__"
  args: ["dict"]
  expected: true
