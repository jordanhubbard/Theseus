spec: inspect_extra65
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra64.zspec.zsdl."
    - "Wave 231 theme: __code__ attribute chains — co_varnames, co_filename, co_flags for isfunction/isclass/ismodule/signature."
    - "isfunction.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple of local variable names in CPython code objects. Verified with Python 3.14.3."
    - "isfunction.__code__.co_varnames[0] == 'object' — the first argument of isfunction is 'object' as defined in def isfunction(object):. Verified with Python 3.14.3."
    - "isclass.__code__.co_varnames[0] == 'object' — the first argument of isclass is 'object' as defined in def isclass(object):. Verified with Python 3.14.3."
    - "ismodule.__code__.co_varnames[0] == 'object' — the first argument of ismodule is 'object' as defined in def ismodule(object):. Verified with Python 3.14.3."
    - "signature.__code__.co_varnames[0] == 'obj' — the first argument of signature is 'obj' as defined in def signature(obj, *, follow_wrapped=True, globals=None, locals=None, eval_str=False):. Verified with Python 3.14.3."
    - "isfunction.__code__.co_filename.__class__.__name__ == 'str' — co_filename is always a str object holding the source file path. Verified with Python 3.14.3."
    - "isfunction.__code__.co_filename.__contains__('.py') == True — inspect is a pure-Python module (Lib/inspect.py), so co_filename ends with '.py'. Verified with Python 3.14.3."
    - "signature.__code__.co_filename.__contains__('.py') == True — signature is also defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "isfunction.__code__.co_flags.__class__.__name__ == 'int' — co_flags is always a plain Python int bitmask. Verified with Python 3.14.3."
    - "signature.__code__.co_flags.__class__.__name__ == 'int' — same invariant for signature. Verified with Python 3.14.3."
    - "No prior inspect spec checks co_varnames[0] (the first local variable name), co_filename, or co_flags for any inspect function. All checks in this spec are new to extra65."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect __code__.co_varnames.__class__.__name__ — extra65
#
# Wave 231 theme: co_varnames is always a tuple.
#
# co_varnames (PyCodeObject.co_varnames) is a tuple of strings containing the
# names of all local variables (parameters first, then locals) in a code object.
# In CPython this is always stored as a Python tuple.
#
# isfunction.__code__.co_varnames.__class__.__name__ == 'tuple'
# isclass.__code__.co_varnames.__class__.__name__ == 'tuple'
# ismodule.__code__.co_varnames.__class__.__name__ == 'tuple'
#
# All are pure-Python functions in Lib/inspect.py.
# No prior inspect spec checks co_varnames.__class__.__name__. New to extra65.
# ---------------------------------------------------------------------------

table inspect_extra65.co_varnames_class_name:
  description: "inspect function __code__.co_varnames.__class__.__name__.__eq__('tuple')==true — co_varnames is always a tuple in CPython; wave 231 co_varnames chains; new to extra65"
  kind: python_call_eq
  category: co_varnames
  id_prefix: inspcode3_65

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_code_co_varnames_class_name_eq_tuple,
       isfunction.__code__.co_varnames.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "inspect.isfunction.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — isfunction is a pure-Python function (Lib/inspect.py); its __code__ is a PyCodeObject; PyCodeObject.co_varnames is a tuple of strings for all local variable names (parameters first); the tuple built-in type has __name__ == 'tuple' (5 chars); __eq__ returns True; no prior inspect spec checks co_varnames.__class__.__name__ for isfunction; new to extra65"]
    - [isclass_code_co_varnames_class_name_eq_tuple,
       isclass.__code__.co_varnames.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "inspect.isclass.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — isclass is a pure-Python function (Lib/inspect.py); its co_varnames is a tuple of strings for all local variable names; tuple.__name__ == 'tuple'; __eq__ returns True; no prior inspect spec checks co_varnames.__class__.__name__ for isclass; new to extra65"]
    - [ismodule_code_co_varnames_class_name_eq_tuple,
       ismodule.__code__.co_varnames.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "inspect.ismodule.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — ismodule is a pure-Python function (Lib/inspect.py); its co_varnames is a tuple of strings for all local variable names; tuple.__name__ == 'tuple'; __eq__ returns True; no prior inspect spec checks co_varnames.__class__.__name__ for ismodule; new to extra65"]

# ---------------------------------------------------------------------------
# inspect __code__.co_varnames[0] — extra65
#
# Wave 231 theme: co_varnames[0] is the first parameter name.
#
# co_varnames[0] is the name of the first positional parameter, since
# co_varnames lists all locals with parameters first.
#
# isfunction(object) → co_varnames[0] == 'object'
# isclass(object)    → co_varnames[0] == 'object'
# ismodule(object)   → co_varnames[0] == 'object'
# signature(obj, *, ...) → co_varnames[0] == 'obj'
#
# Function values containing '[' MUST be double-quoted in table rows.
# No prior inspect spec checks co_varnames[0]. New to extra65.
# ---------------------------------------------------------------------------

table inspect_extra65.co_varnames_first_arg:
  description: "inspect function __code__.co_varnames[0].__eq__ — first parameter name; wave 231 co_varnames first arg; new to extra65"
  kind: python_call_eq
  category: co_varnames
  id_prefix: inspcode3_65

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_code_co_varnames_0_eq_object,
       "isfunction.__code__.co_varnames[0].__eq__",
       ["object"],
       true,
       "inspect.isfunction.__code__.co_varnames[0].__eq__('object') == True — isfunction is a pure-Python function (Lib/inspect.py) with signature isfunction(object); co_varnames lists all locals with parameters first; co_varnames[0] is the first parameter name, which is 'object' (6 chars); __eq__ on the str 'object' returns True when the argument equals 'object'; no prior inspect spec checks co_varnames[0] for isfunction; new to extra65"]
    - [isclass_code_co_varnames_0_eq_object,
       "isclass.__code__.co_varnames[0].__eq__",
       ["object"],
       true,
       "inspect.isclass.__code__.co_varnames[0].__eq__('object') == True — isclass is a pure-Python function (Lib/inspect.py) with signature isclass(object); co_varnames[0] is the first parameter name, which is 'object' (6 chars); __eq__ returns True; no prior inspect spec checks co_varnames[0] for isclass; new to extra65"]
    - [ismodule_code_co_varnames_0_eq_object,
       "ismodule.__code__.co_varnames[0].__eq__",
       ["object"],
       true,
       "inspect.ismodule.__code__.co_varnames[0].__eq__('object') == True — ismodule is a pure-Python function (Lib/inspect.py) with signature ismodule(object); co_varnames[0] is the first parameter name, which is 'object' (6 chars); __eq__ returns True; no prior inspect spec checks co_varnames[0] for ismodule; new to extra65"]
    - [signature_code_co_varnames_0_eq_obj,
       "signature.__code__.co_varnames[0].__eq__",
       ["obj"],
       true,
       "inspect.signature.__code__.co_varnames[0].__eq__('obj') == True — signature is a pure-Python function (Lib/inspect.py) with signature signature(obj, *, follow_wrapped=True, globals=None, locals=None, eval_str=False); co_varnames[0] is the first parameter name, which is 'obj' (3 chars); __eq__ returns True; note that 'obj' differs from 'object' used by the is* predicates; no prior inspect spec checks co_varnames[0] for signature; new to extra65"]

# ---------------------------------------------------------------------------
# inspect __code__.co_filename.__class__.__name__ — extra65
#
# Wave 231 theme: co_filename is always a str.
#
# co_filename (PyCodeObject.co_filename) stores the path of the source file
# where the function was defined, as a Python str. For inspect (a pure-Python
# module in Lib/inspect.py), co_filename is a str object.
#
# isfunction.__code__.co_filename.__class__.__name__ == 'str'
# isclass.__code__.co_filename.__class__.__name__ == 'str'
# ismodule.__code__.co_filename.__class__.__name__ == 'str'
#
# No prior inspect spec checks co_filename.__class__.__name__. New to extra65.
# ---------------------------------------------------------------------------

table inspect_extra65.co_filename_class_name:
  description: "inspect function __code__.co_filename.__class__.__name__.__eq__('str')==true — co_filename is always a str; wave 231 co_filename chains; new to extra65"
  kind: python_call_eq
  category: co_filename
  id_prefix: inspcode3_65

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_code_co_filename_class_name_eq_str,
       isfunction.__code__.co_filename.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.isfunction.__code__.co_filename.__class__.__name__.__eq__('str') == True — isfunction is a pure-Python function (Lib/inspect.py); its __code__ is a PyCodeObject; PyCodeObject.co_filename is a str holding the absolute path of the source file; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior inspect spec checks co_filename.__class__.__name__ for isfunction; new to extra65"]
    - [isclass_code_co_filename_class_name_eq_str,
       isclass.__code__.co_filename.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.isclass.__code__.co_filename.__class__.__name__.__eq__('str') == True — isclass is a pure-Python function (Lib/inspect.py); co_filename is a str holding the path to Lib/inspect.py; str.__name__ == 'str'; __eq__ returns True; no prior inspect spec checks co_filename.__class__.__name__ for isclass; new to extra65"]
    - [ismodule_code_co_filename_class_name_eq_str,
       ismodule.__code__.co_filename.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.ismodule.__code__.co_filename.__class__.__name__.__eq__('str') == True — ismodule is a pure-Python function (Lib/inspect.py); co_filename is a str holding the path to Lib/inspect.py; str.__name__ == 'str'; __eq__ returns True; no prior inspect spec checks co_filename.__class__.__name__ for ismodule; new to extra65"]

# ---------------------------------------------------------------------------
# inspect __code__.co_filename.__contains__('.py') — extra65
#
# Wave 231 theme: co_filename ends with '.py' for pure-Python inspect.
#
# inspect is a pure-Python module (Lib/inspect.py). Therefore the co_filename
# attribute of every function defined there contains the substring '.py'.
#
# isfunction.__code__.co_filename.__contains__('.py') == True
# isclass.__code__.co_filename.__contains__('.py') == True
# signature.__code__.co_filename.__contains__('.py') == True
#
# No prior inspect spec checks co_filename.__contains__. New to extra65.
# ---------------------------------------------------------------------------

table inspect_extra65.co_filename_contains_py:
  description: "inspect function __code__.co_filename.__contains__('.py')==true — inspect is pure-Python so co_filename contains '.py'; wave 231 co_filename chains; new to extra65"
  kind: python_call_eq
  category: co_filename
  id_prefix: inspcode3_65

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_code_co_filename_contains_py,
       isfunction.__code__.co_filename.__contains__,
       [".py"],
       true,
       "inspect.isfunction.__code__.co_filename.__contains__('.py') == True — isfunction is defined in Lib/inspect.py; PyCodeObject.co_filename is the absolute path to that file as a str; the path necessarily contains the substring '.py' (the .py file extension); str.__contains__ returns True; no prior inspect spec checks co_filename.__contains__('.py') for isfunction; new to extra65"]
    - [isclass_code_co_filename_contains_py,
       isclass.__code__.co_filename.__contains__,
       [".py"],
       true,
       "inspect.isclass.__code__.co_filename.__contains__('.py') == True — isclass is defined in Lib/inspect.py; co_filename is the absolute path to Lib/inspect.py; the path contains '.py'; __contains__ returns True; no prior inspect spec checks co_filename.__contains__('.py') for isclass; new to extra65"]
    - [signature_code_co_filename_contains_py,
       signature.__code__.co_filename.__contains__,
       [".py"],
       true,
       "inspect.signature.__code__.co_filename.__contains__('.py') == True — signature is defined in Lib/inspect.py; co_filename is the absolute path to Lib/inspect.py; the path contains '.py'; __contains__ returns True; no prior inspect spec checks co_filename.__contains__('.py') for signature; new to extra65"]

# ---------------------------------------------------------------------------
# inspect __code__.co_flags.__class__.__name__ — extra65
#
# Wave 231 theme: co_flags is always an int.
#
# co_flags (PyCodeObject.co_flags) is a bitmask of integer flags describing
# properties of the code object. In CPython this field is always a plain int.
#
# isfunction.__code__.co_flags.__class__.__name__ == 'int'
# isclass.__code__.co_flags.__class__.__name__ == 'int'
# signature.__code__.co_flags.__class__.__name__ == 'int'
#
# No prior inspect spec checks co_flags.__class__.__name__. New to extra65.
# ---------------------------------------------------------------------------

table inspect_extra65.co_flags_class_name:
  description: "inspect function __code__.co_flags.__class__.__name__.__eq__('int')==true — co_flags is always a plain int bitmask; wave 231 co_flags chains; new to extra65"
  kind: python_call_eq
  category: co_flags
  id_prefix: inspcode3_65

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_code_co_flags_class_name_eq_int,
       isfunction.__code__.co_flags.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.isfunction.__code__.co_flags.__class__.__name__.__eq__('int') == True — isfunction is a pure-Python function (Lib/inspect.py); its __code__ is a PyCodeObject; PyCodeObject.co_flags is a bitmask of integer flags (e.g., CO_OPTIMIZED, CO_NEWLOCALS) stored as a Python int; int.__name__ == 'int' (3 chars); __eq__ returns True; no prior inspect spec checks co_flags.__class__.__name__ for isfunction; new to extra65"]
    - [isclass_code_co_flags_class_name_eq_int,
       isclass.__code__.co_flags.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.isclass.__code__.co_flags.__class__.__name__.__eq__('int') == True — isclass is a pure-Python function (Lib/inspect.py); co_flags is a Python int bitmask; int.__name__ == 'int'; __eq__ returns True; no prior inspect spec checks co_flags.__class__.__name__ for isclass; new to extra65"]
    - [signature_code_co_flags_class_name_eq_int,
       signature.__code__.co_flags.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.signature.__code__.co_flags.__class__.__name__.__eq__('int') == True — signature is a pure-Python function (Lib/inspect.py); co_flags is a Python int bitmask; int.__name__ == 'int'; __eq__ returns True; no prior inspect spec checks co_flags.__class__.__name__ for signature; new to extra65"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra65
# ---------------------------------------------------------------------------

invariant inspect_extra65.isfunction_co_varnames_tuple:
  description: "inspect.isfunction.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is always a tuple in CPython; wave 231 co_varnames chains; new to extra65"
  kind: python_call_eq
  function: isfunction.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra65.isfunction_co_varnames_first_arg:
  description: "inspect.isfunction.__code__.co_varnames[0].__eq__('object') == True — first parameter of isfunction is 'object'; wave 231 co_varnames first arg; new to extra65"
  kind: python_call_eq
  function: "isfunction.__code__.co_varnames[0].__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra65.isfunction_co_filename_contains_py:
  description: "inspect.isfunction.__code__.co_filename.__contains__('.py') == True — inspect is pure-Python so co_filename contains '.py'; wave 231 co_filename chains; new to extra65"
  kind: python_call_eq
  function: isfunction.__code__.co_filename.__contains__
  args: [".py"]
  expected: true

invariant inspect_extra65.isfunction_co_flags_int:
  description: "inspect.isfunction.__code__.co_flags.__class__.__name__.__eq__('int') == True — co_flags is always a plain int bitmask; wave 231 co_flags chains; new to extra65"
  kind: python_call_eq
  function: isfunction.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant inspect_extra65.signature_co_varnames_first_arg:
  description: "inspect.signature.__code__.co_varnames[0].__eq__('obj') == True — first parameter of signature is 'obj'; wave 231 co_varnames first arg; new to extra65"
  kind: python_call_eq
  function: "signature.__code__.co_varnames[0].__eq__"
  args: ["obj"]
  expected: true
