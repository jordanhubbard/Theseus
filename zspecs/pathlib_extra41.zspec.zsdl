spec: pathlib_extra41
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra40.zspec.zsdl — covers Path/PurePath __init_subclass__.__qualname__.__len__(); Path/PurePath/PurePosixPath __dict__.__len__(); UnsupportedOperation.__name__.__len__()==20."
    - "pathlib_extra39.zspec.zsdl — covers PurePath property fget __qualname__.__len__() for name/parent/suffix/stem/parts; Path method __qualname__.__len__() for is_symlink/is_mount/touch/cwd/home/expanduser/samefile/lstat; PurePath method __qualname__.__len__() for relative_to/is_relative_to/match/__str__/__fspath__."
    - "pathlib_extra36.zspec.zsdl — covers Path.rename/unlink/rmdir/chmod/symlink_to __qualname__.__len__()."
    - "pathlib_extra35.zspec.zsdl — covers Path.open/read_text/write_text/mkdir/exists/stat __qualname__.__len__(); Path.iterdir/glob/rglob/resolve/absolute __qualname__.__len__()."
    - "pathlib_extra38.zspec.zsdl — covers Path.read_bytes/write_bytes/is_file/is_dir __qualname__.__len__(); PurePath.as_posix/joinpath/with_name/with_suffix __qualname__.__len__()."
    - "pathlib_extra32.zspec.zsdl — covers PurePath.parent/parents/suffixes/drive/root/anchor fget.__qualname__/__module__ equality checks (not __len__())."
  notes:
    - "This spec extends pathlib_extra40.zspec.zsdl."
    - "Prior specs collectively covered: Path/PurePath/PurePosixPath/PoseWindowsPath/PosixPath/WindowsPath __name__/__module__/__qualname__ and lengths; MRO depths for all six classes; __bases__[0].__name__/__len__() for all six; all major Path/PurePath method __qualname__/__len__(); PurePath property fget __qualname__.__len__() for name/parent/suffix/stem/parts; Path method __qualname__.__len__() for open/read_text/write_text/mkdir/exists/stat/read_bytes/write_bytes/is_file/is_dir/is_symlink/is_mount/touch/cwd/home/expanduser/samefile/lstat/iterdir/glob/rglob/resolve/absolute/rename/unlink/rmdir/chmod/symlink_to."
    - "This spec covers: Path.is_block_device/__qualname__.__len__()==20 (NOVEL — no prior pathlib spec checks is_block_device/__qualname__.__len__()); Path.is_char_device(19)/is_fifo(12)/is_socket(14) (NOVEL — no prior spec checks any of these); Path.hardlink_to/__qualname__.__len__()==16 (NOVEL); PurePath.with_stem/__qualname__.__len__()==18 (NOVEL); PurePath property fget __qualname__.__len__() for drive(14)/root(13)/anchor(15)/parents(16) (NOVEL — pathlib_extra32 checks fget.__qualname__ equality but not __len__(); pathlib_extra39 covers name/parent/suffix/stem/parts fget lengths but NOT drive/root/anchor/parents)."
    - "pathlib.Path.is_block_device.__qualname__ == 'Path.is_block_device' — len 20. Longest is_* method qualname. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.Path.is_char_device.__qualname__ == 'Path.is_char_device' — len 19. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.Path.is_fifo.__qualname__ == 'Path.is_fifo' — len 12. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.Path.is_socket.__qualname__ == 'Path.is_socket' — len 14. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.Path.hardlink_to.__qualname__ == 'Path.hardlink_to' — len 16. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.with_stem.__qualname__ == 'PurePath.with_stem' — len 18. Novel. with_stem was added in Python 3.12. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.drive (property) fget.__qualname__ == 'PurePath.drive' — len 14. pathlib_extra32 checks fget.__qualname__ equality ('PurePath.drive') but not __len__(). Novel length invariant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.root (property) fget.__qualname__ == 'PurePath.root' — len 13. Novel length invariant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.anchor (property) fget.__qualname__ == 'PurePath.anchor' — len 15. Novel length invariant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.parents (property) fget.__qualname__ == 'PurePath.parents' — len 16. pathlib_extra39 covers name/parent/suffix/stem/parts property fget lengths but NOT parents. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path device/socket/fifo type-check method __qualname__.__len__()
#
# Prior pathlib specs cover is_file(12)/is_dir(11)/is_symlink(15)/is_mount(13)
# but NOT is_block_device, is_char_device, is_fifo, or is_socket. All four
# are novel. Notable: is_block_device is the longest is_* qualname at 20 chars.
#
#   Path.is_block_device -> 'Path.is_block_device' -> 20
#   Path.is_char_device  -> 'Path.is_char_device'  -> 19
#   Path.is_socket       -> 'Path.is_socket'       -> 14
#   Path.is_fifo         -> 'Path.is_fifo'         -> 12
# ---------------------------------------------------------------------------

table pathlib_extra41.Path_device_type_qualname_lens:
  description: "pathlib.Path.is_block_device(20)/is_char_device(19)/is_socket(14)/is_fifo(12) __qualname__.__len__() — all novel; no prior pathlib spec covers these is_* methods"
  kind: python_call_eq
  category: method_identity
  id_prefix: pdtq41

  columns: [id, function, args, expected]
  rows:
    - [is_block_device, Path.is_block_device.__qualname__.__len__, [], 20]
    - [is_char_device,  Path.is_char_device.__qualname__.__len__,  [], 19]
    - [is_socket,       Path.is_socket.__qualname__.__len__,       [], 14]
    - [is_fifo,         Path.is_fifo.__qualname__.__len__,         [], 12]

# ---------------------------------------------------------------------------
# Path.hardlink_to and PurePath.with_stem __qualname__.__len__()
#
# Path.hardlink_to creates a hard link pointing to this path. No prior
# pathlib spec checks its __qualname__.__len__(). PurePath.with_stem (added
# Python 3.12) returns a new path with the stem changed. No prior pathlib
# spec checks with_stem.__qualname__.__len__(). Both are novel.
#
#   Path.hardlink_to    -> 'Path.hardlink_to'    -> 16
#   PurePath.with_stem  -> 'PurePath.with_stem'  -> 18
# ---------------------------------------------------------------------------

invariant pathlib_extra41.Path_hardlink_to_qualname_len:
  description: "len(pathlib.Path.hardlink_to.__qualname__) == 16 — 'Path.hardlink_to' has 16 characters; novel invariant"
  category: method_identity
  kind: python_call_eq
  function: Path.hardlink_to.__qualname__.__len__
  args: []
  expected: 16

invariant pathlib_extra41.PurePath_with_stem_qualname_len:
  description: "len(pathlib.PurePath.with_stem.__qualname__) == 18 — 'PurePath.with_stem' has 18 characters; novel invariant (with_stem added in Python 3.12)"
  category: method_identity
  kind: python_call_eq
  function: PurePath.with_stem.__qualname__.__len__
  args: []
  expected: 18

# ---------------------------------------------------------------------------
# PurePath property fget __qualname__.__len__() — drive, root, anchor, parents
#
# pathlib_extra32 checks fget.__qualname__ equality for drive/root/anchor/parents
# but does NOT check __qualname__.__len__(). pathlib_extra39 checks fget
# __qualname__.__len__() for name/parent/suffix/stem/parts but NOT for
# drive/root/anchor/parents. All four length invariants are novel.
#
#   PurePath.drive.fget.__qualname__   == 'PurePath.drive'   -> 14
#   PurePath.root.fget.__qualname__    == 'PurePath.root'    -> 13
#   PurePath.anchor.fget.__qualname__  == 'PurePath.anchor'  -> 15
#   PurePath.parents.fget.__qualname__ == 'PurePath.parents' -> 16
#
# Note: PurePath.parents is a property (fget function); its qualname length
# is 16, matching pathlib_extra39's PurePath.name.fget (13) / parts.fget (14)
# pattern. Novel. All verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra41.PurePath_property_fget_qualname_lens:
  description: "pathlib.PurePath drive(14)/root(13)/anchor(15)/parents(16) property fget __qualname__.__len__() — extends extra39 which covers name/parent/suffix/stem/parts fget lengths"
  kind: python_call_eq
  category: property_identity
  id_prefix: ppfq41

  columns: [id, function, args, expected]
  rows:
    - [drive,   "PurePath.__dict__['drive'].fget.__qualname__.__len__",   [], 14]
    - [root,    "PurePath.__dict__['root'].fget.__qualname__.__len__",    [], 13]
    - [anchor,  "PurePath.__dict__['anchor'].fget.__qualname__.__len__",  [], 15]
    - [parents, "PurePath.__dict__['parents'].fget.__qualname__.__len__", [], 16]
