spec: crypt_extra2
version: ">=3.9,<3.13"
backend: python_module(crypt)

docs: https://docs.python.org/3/library/crypt.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/crypt.html — Python crypt documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/crypt.py"
  notes:
    - "This spec extends crypt.zspec.zsdl and prior extras."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "crypt.crypt() raises OSError if the underlying crypt(3) call fails. mksalt() raises ValueError for an unknown method."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Module name check
# ---------------------------------------------------------------------------

invariant crypt_extra2.module_name:
  description: "crypt.__name__ == 'crypt'"
  category: module_meta
  kind: python_call_eq
  function: __name__.__eq__
  args: ["crypt"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ attribute checks
# ---------------------------------------------------------------------------

invariant crypt_extra2.crypt_func_name_str:
  description: "crypt.crypt.__name__ is a str"
  category: functions
  kind: python_call_eq
  function: crypt.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant crypt_extra2.mksalt_name_str:
  description: "crypt.mksalt.__name__ is a str"
  category: functions
  kind: python_call_eq
  function: mksalt.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# METHOD_SHA512 namedtuple checks
# ---------------------------------------------------------------------------

invariant crypt_extra2.METHOD_SHA512_class_name:
  description: "crypt.METHOD_SHA512.__class__.__name__ == '_Method' — SHA512 is a _Method namedtuple"
  category: method_constants
  kind: python_call_eq
  function: METHOD_SHA512.__class__.__name__.__eq__
  args: ["_Method"]
  expected: true

invariant crypt_extra2.METHOD_SHA512_name_attr:
  description: "crypt.METHOD_SHA512.name == 'sha512'"
  category: method_constants
  kind: python_call_eq
  function: METHOD_SHA512.name.__eq__
  args: ["sha512"]
  expected: true

# ---------------------------------------------------------------------------
# METHOD_SHA256 namedtuple checks
# ---------------------------------------------------------------------------

invariant crypt_extra2.METHOD_SHA256_class_name:
  description: "crypt.METHOD_SHA256.__class__.__name__ == '_Method' — SHA256 is a _Method namedtuple"
  category: method_constants
  kind: python_call_eq
  function: METHOD_SHA256.__class__.__name__.__eq__
  args: ["_Method"]
  expected: true

invariant crypt_extra2.METHOD_SHA256_name_attr:
  description: "crypt.METHOD_SHA256.name == 'sha256'"
  category: method_constants
  kind: python_call_eq
  function: METHOD_SHA256.name.__eq__
  args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# methods list class check
# ---------------------------------------------------------------------------

invariant crypt_extra2.methods_class_name:
  description: "crypt.methods.__class__.__name__ == 'list'"
  category: methods_list
  kind: python_call_eq
  function: methods.__class__.__name__.__eq__
  args: ["list"]
  expected: true
