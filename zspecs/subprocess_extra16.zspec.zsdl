spec: subprocess_extra16
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
    - "subprocess_extra6.zspec.zsdl — covers __qualname__ equality for Popen/CompletedProcess/CalledProcessError/TimeoutExpired/SubprocessError/run/call/check_call/check_output/getoutput/getstatusoutput (class and module-level functions only; not Popen methods)"
    - "subprocess_extra15.zspec.zsdl — covers __qualname__ string lengths for subprocess classes and functions"
  notes:
    - "This spec extends subprocess.zspec.zsdl and all prior subprocess_extra specs through subprocess_extra15.zspec.zsdl."
    - "Focus: __qualname__ values for Popen instance methods — communicate, wait, poll, kill, terminate, send_signal."
    - "For methods defined directly on a class, __qualname__ takes the form 'ClassName.method_name'."
    - "subprocess.Popen.communicate.__qualname__ == 'Popen.communicate' — dotted qualname for class method."
    - "subprocess.Popen.wait.__qualname__ == 'Popen.wait' — dotted qualname for class method."
    - "subprocess.Popen.poll.__qualname__ == 'Popen.poll' — dotted qualname for class method."
    - "subprocess.Popen.kill.__qualname__ == 'Popen.kill' — dotted qualname for class method."
    - "subprocess.Popen.terminate.__qualname__ == 'Popen.terminate' — dotted qualname for class method."
    - "subprocess.Popen.send_signal.__qualname__ == 'Popen.send_signal' — dotted qualname for class method."
    - "No prior subprocess spec covers __qualname__ for any Popen instance method."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Popen method __qualname__ equality table
#
# For methods defined directly on Popen, __qualname__ is 'Popen.<method>'.
# subprocess_extra6 covers qualnames for Popen the class and module-level
# functions (run/call/check_call/check_output) but no prior subprocess spec
# covers __qualname__ for any Popen instance method. This table is the first
# coverage of Popen method qualnames in the subprocess spec collection.
# ---------------------------------------------------------------------------

table subprocess_extra16.popen_method_qualnames:
  description: "__qualname__ for Popen instance methods has dotted form 'Popen.<method>'"
  kind: python_call_eq
  category: function_identity
  id_prefix: qname16

  columns: [id, function, args, expected]
  rows:
    - [communicate, "Popen.communicate.__qualname__.__eq__", ["Popen.communicate"], true]
    - [wait,        "Popen.wait.__qualname__.__eq__",        ["Popen.wait"],        true]
    - [poll,        "Popen.poll.__qualname__.__eq__",        ["Popen.poll"],        true]
    - [kill,        "Popen.kill.__qualname__.__eq__",        ["Popen.kill"],        true]
    - [terminate,   "Popen.terminate.__qualname__.__eq__",   ["Popen.terminate"],   true]
    - [send_signal, "Popen.send_signal.__qualname__.__eq__", ["Popen.send_signal"], true]

# ---------------------------------------------------------------------------
# Standalone Popen method __qualname__ invariants
#
# Each invariant below provides an individually addressable check for one
# Popen method's qualname — separate from the table above, anchored in the
# extra16 standalone namespace.
# ---------------------------------------------------------------------------

invariant subprocess_extra16.Popen.communicate.qualname:
  description: "subprocess.Popen.communicate.__qualname__ == 'Popen.communicate' — dotted qualname for class method"
  category: function_identity
  kind: python_call_eq
  function: "Popen.communicate.__qualname__.__eq__"
  args: ["Popen.communicate"]
  expected: true

invariant subprocess_extra16.Popen.wait.qualname:
  description: "subprocess.Popen.wait.__qualname__ == 'Popen.wait' — dotted qualname for class method"
  category: function_identity
  kind: python_call_eq
  function: "Popen.wait.__qualname__.__eq__"
  args: ["Popen.wait"]
  expected: true

invariant subprocess_extra16.Popen.poll.qualname:
  description: "subprocess.Popen.poll.__qualname__ == 'Popen.poll' — dotted qualname for class method"
  category: function_identity
  kind: python_call_eq
  function: "Popen.poll.__qualname__.__eq__"
  args: ["Popen.poll"]
  expected: true

invariant subprocess_extra16.Popen.kill.qualname:
  description: "subprocess.Popen.kill.__qualname__ == 'Popen.kill' — dotted qualname for class method"
  category: function_identity
  kind: python_call_eq
  function: "Popen.kill.__qualname__.__eq__"
  args: ["Popen.kill"]
  expected: true

invariant subprocess_extra16.Popen.terminate.qualname:
  description: "subprocess.Popen.terminate.__qualname__ == 'Popen.terminate' — dotted qualname for class method"
  category: function_identity
  kind: python_call_eq
  function: "Popen.terminate.__qualname__.__eq__"
  args: ["Popen.terminate"]
  expected: true

invariant subprocess_extra16.Popen.send_signal.qualname:
  description: "subprocess.Popen.send_signal.__qualname__ == 'Popen.send_signal' — dotted qualname for class method"
  category: function_identity
  kind: python_call_eq
  function: "Popen.send_signal.__qualname__.__eq__"
  args: ["Popen.send_signal"]
  expected: true
