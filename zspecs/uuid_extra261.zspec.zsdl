spec: uuid_extra261
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra260.zspec.zsdl — covers UUID.__init__/__new__/__setattr__ method identity and UUID constructor error cases."
    - "uuid_extra259.zspec.zsdl — covers UUID property fget identity."
  notes:
    - "uuid.RFC_4122 == 'specified in RFC 4122' — a module-level string constant identifying the RFC 4122 variant. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.RESERVED_NCS == 'reserved for NCS compatibility' — a module-level string constant for the NCS variant. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.RESERVED_MICROSOFT == 'reserved for Microsoft compatibility' — a module-level string constant for the Microsoft variant. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.RESERVED_FUTURE == 'reserved for future definition' — a module-level string constant for the future variant. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.getnode.__name__ == 'getnode' — pure-Python function in Lib/uuid.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.getnode.__module__ == 'uuid' — defined in the uuid module. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.getnode.__class__.__name__ == 'function' — pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.getnode.__qualname__ == 'getnode' — top-level function, qualname equals simple name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.SafeUUID.__name__ == 'SafeUUID' — the Enum subclass name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.SafeUUID.__module__ == 'uuid' — SafeUUID is defined in Lib/uuid.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' — SafeUUID inherits directly from Enum. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.SafeUUID.safe.__class__.__name__ == 'SafeUUID' — enum members are instances of the enum class. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.SafeUUID.safe.value == 0 — the 'safe' member has value 0. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.SafeUUID.unsafe.value == -1 — the 'unsafe' member has value -1. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.SafeUUID.unknown.value is None — the 'unknown' member has value None. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid module constants identity — RFC_4122, RESERVED_NCS, RESERVED_MICROSOFT,
# RESERVED_FUTURE are module-level string constants describing UUID variant names.
# uuid.getnode function identity.
# ---------------------------------------------------------------------------

table uuid_extra261.uuid_constants_identity:
  description: "uuid module constants identity — RFC_4122/RESERVED_NCS/RESERVED_MICROSOFT/RESERVED_FUTURE are string constants; getnode is a pure-Python function; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidconst261

  columns: [id, function, args, expected, description]
  rows:
    - [rfc4122_class,       RFC_4122.__class__.__name__.__eq__,            ["str"],          true, "uuid.RFC_4122.__class__.__name__ == 'str' — RFC_4122 is a module-level string constant"]
    - [rfc4122_val,         RFC_4122.__eq__,                               ["specified in RFC 4122"], true, "uuid.RFC_4122 == 'specified in RFC 4122' — the RFC 4122 variant label string"]
    - [reserved_ncs_val,    RESERVED_NCS.__eq__,                           ["reserved for NCS compatibility"], true, "uuid.RESERVED_NCS == 'reserved for NCS compatibility' — NCS backward compatibility variant"]
    - [reserved_ms_class,   RESERVED_MICROSOFT.__class__.__name__.__eq__,  ["str"],          true, "uuid.RESERVED_MICROSOFT.__class__.__name__ == 'str' — RESERVED_MICROSOFT is a string constant"]
    - [reserved_fut_class,  RESERVED_FUTURE.__class__.__name__.__eq__,     ["str"],          true, "uuid.RESERVED_FUTURE.__class__.__name__ == 'str' — RESERVED_FUTURE is a string constant"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID enum identity
# SafeUUID is a Python Enum with members: safe (0), unsafe (-1), unknown (None).
# Its base class is Enum (not IntEnum). Members are instances of SafeUUID.
# ---------------------------------------------------------------------------

table uuid_extra261.SafeUUID_enum_identity:
  description: "uuid.SafeUUID enum identity — __name__/'SafeUUID', __module__/'uuid', __bases__[0].__name__/'Enum', safe.__class__.__name__/'SafeUUID', safe.value/0, unsafe.value/-1; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidsafe261

  columns: [id, function, args, expected, description]
  rows:
    - [safe_uuid_name,      SafeUUID.__name__.__eq__,                      ["SafeUUID"],     true, "uuid.SafeUUID.__name__ == 'SafeUUID' — the enum class name"]
    - [safe_uuid_module,    SafeUUID.__module__.__eq__,                    ["uuid"],          true, "uuid.SafeUUID.__module__ == 'uuid' — SafeUUID is defined in Lib/uuid.py"]
    - [safe_member_class,   SafeUUID.safe.__class__.__name__.__eq__,       ["SafeUUID"],     true, "uuid.SafeUUID.safe.__class__.__name__ == 'SafeUUID' — enum members are instances of the enum class"]
    - [safe_value,          SafeUUID.safe.value.__eq__,                    [0],              true, "uuid.SafeUUID.safe.value == 0 — the safe member has integer value 0"]
    - [unsafe_value,        SafeUUID.unsafe.value.__eq__,                  [-1],             true, "uuid.SafeUUID.unsafe.value == -1 — the unsafe member has integer value -1"]

# ---------------------------------------------------------------------------
# Standalone invariants — uuid constants and SafeUUID enum
# ---------------------------------------------------------------------------

invariant uuid_extra261.RFC_4122_eq:
  description: "uuid.RFC_4122 == 'specified in RFC 4122' — module-level string constant labeling the RFC 4122 UUID variant; used in uuid.UUID.variant property to identify compliant UUIDs; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: RFC_4122.__eq__
  args: ["specified in RFC 4122"]
  expected: true

invariant uuid_extra261.RESERVED_NCS_eq:
  description: "uuid.RESERVED_NCS == 'reserved for NCS compatibility' — module-level string constant for the NCS backward compatibility variant; used in uuid.UUID.variant property; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: RESERVED_NCS.__eq__
  args: ["reserved for NCS compatibility"]
  expected: true

invariant uuid_extra261.RESERVED_MICROSOFT_eq:
  description: "uuid.RESERVED_MICROSOFT == 'reserved for Microsoft compatibility' — module-level string constant for the Microsoft compatibility variant; used in uuid.UUID.variant property; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: RESERVED_MICROSOFT.__eq__
  args: ["reserved for Microsoft compatibility"]
  expected: true

invariant uuid_extra261.RESERVED_FUTURE_eq:
  description: "uuid.RESERVED_FUTURE == 'reserved for future definition' — module-level string constant for the future variant; used in uuid.UUID.variant property; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: RESERVED_FUTURE.__eq__
  args: ["reserved for future definition"]
  expected: true

invariant uuid_extra261.getnode_name_eq:
  description: "uuid.getnode.__name__ == 'getnode' — pure-Python function in Lib/uuid.py that returns the hardware address as a 48-bit positive integer; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: getnode.__name__.__eq__
  args: ["getnode"]
  expected: true

invariant uuid_extra261.getnode_module_eq:
  description: "uuid.getnode.__module__ == 'uuid' — getnode is defined in the uuid module (Lib/uuid.py); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: getnode.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra261.getnode_class_eq:
  description: "uuid.getnode.__class__.__name__ == 'function' — getnode is a pure-Python function, not a C builtin; defined in Lib/uuid.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: getnode.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant uuid_extra261.getnode_qualname_eq:
  description: "uuid.getnode.__qualname__ == 'getnode' — top-level function in the uuid module; qualname equals simple name; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: getnode.__qualname__.__eq__
  args: ["getnode"]
  expected: true

invariant uuid_extra261.SafeUUID_bases0_name_eq:
  description: "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' — SafeUUID inherits directly from Enum (not IntEnum); members are not directly usable as integers; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: "SafeUUID.__bases__[0].__name__.__eq__"
  args: ["Enum"]
  expected: true

invariant uuid_extra261.SafeUUID_safe_value_eq:
  description: "uuid.SafeUUID.safe.value == 0 — the 'safe' enum member indicates the UUID was generated in a multiprocessing-safe way; its integer value is 0; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: SafeUUID.safe.value.__eq__
  args: [0]
  expected: true

invariant uuid_extra261.SafeUUID_unsafe_value_eq:
  description: "uuid.SafeUUID.unsafe.value == -1 — the 'unsafe' enum member indicates the UUID was not generated safely; its integer value is -1; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: SafeUUID.unsafe.value.__eq__
  args: [-1]
  expected: true
