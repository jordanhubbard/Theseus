spec: socket_extra135
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra134.zspec.zsdl — covers socket.herror/__name__/__qualname__/__module__/__bases__[0].__name__/__class__.__name__/__mro__.__len__() / socket.gaierror identity / socket.timeout/__name__/__module__ (alias for TimeoutError) / socket.error/__name__/__module__ (alias for OSError) (table + invariants)."
    - "socket_extra133.zspec.zsdl — covers socket.gethostname/__name__/__qualname__/__module__ equality / socket.gethostbyname identity / socket.getfqdn __name__/__module__/co_varnames[0] / socket.getaddrinfo co_varnames.__len__()==12 / socket.socket class identity (table + invariants)."
    - "socket_extra132.zspec.zsdl — covers socket.socket.bind/connect/listen qualname equality / socket.socket.send/recv qualname equality / bind/connect/listen/send/recv __class__.__name__=='method_descriptor' / socket.socket.__init__ and accept qualname equality (table + invariants)."
    - "socket_extra131.zspec.zsdl — covers socket.AF_INET/AF_INET6/AF_UNIX/SOCK_STREAM/SOCK_DGRAM/SOCK_RAW enum value equality / AddressFamily and SocketKind class name lengths (table + invariants)."
    - "socket_extra130.zspec.zsdl — covers socket module Python function code attributes — create_connection/getfqdn/getaddrinfo co_name/co_argcount/co_varnames[0]/co_varnames.__len__() (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module function __qualname__.__len__() / SocketIO class identity (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC __class__.__name__=='AddressFamily' / gethostname/gethostbyname as C builtins / getaddrinfo/create_connection as Python functions (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior socket spec files."
    - "Wave 356 theme: socket.socket.recvfrom/sendto/shutdown/settimeout/gettimeout qualname equality and __class__.__name__=='method_descriptor' / socket.socket.close __class__.__name__=='function' and __module__=='socket' / socket.socket.setblocking qualname and class name."
    - "socket.socket.recvfrom.__qualname__ == 'socket.recvfrom'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendto.__qualname__ == 'socket.sendto'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.shutdown.__qualname__ == 'socket.shutdown'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__qualname__ == 'socket.settimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.gettimeout.__qualname__ == 'socket.gettimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendto.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.shutdown.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.gettimeout.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setblocking.__qualname__ == 'socket.setblocking'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setblocking.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__class__.__name__ == 'function'. close is a Python function defined in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__qualname__ == 'socket.close'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket_extra132 covers bind/connect/listen/send/recv qualname and class name. socket_extra97 covers init/accept/makefile/close __class__.__name__=='function'. This spec is the first to anchor recvfrom/sendto/shutdown/settimeout/gettimeout/setblocking qualname and class name via __eq__ calls, and to anchor close.__qualname__=='socket.close' and close.__module__=='socket' under sockmethod135."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.recvfrom.__qualname__.__eq__('socket.recvfrom')
# socket.socket.sendto.__qualname__.__eq__('socket.sendto')
# socket.socket.shutdown.__qualname__.__eq__('socket.shutdown')
# socket.socket.recvfrom.__class__.__name__.__eq__('method_descriptor')
# socket.socket.sendto.__class__.__name__.__eq__('method_descriptor')
#
# Wave 356 theme: socket.socket recvfrom/sendto/shutdown qualname equality.
#
# socket.socket.recvfrom, .sendto, and .shutdown are method_descriptor objects
# inherited from _socket.socket (the C extension). Like bind/connect/listen/send/recv
# (anchored in extra132), their qualnames use the 'socket.' prefix (the C-level
# class name) rather than 'socket.socket.'. socket_extra132 covers bind/connect/
# listen/send/recv qualname; this spec covers the complementary set: recvfrom,
# sendto, and shutdown. No prior socket spec anchors recvfrom/sendto/shutdown
# qualname via __eq__ under sockmethod135. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra135.recvfrom_sendto_shutdown_qualname:
  description: "socket.socket/recvfrom/__qualname__.__eq__('socket.recvfrom')==True / sendto/__qualname__.__eq__('socket.sendto')==True / shutdown/__qualname__.__eq__('socket.shutdown')==True / recvfrom/__class__/__name__.__eq__('method_descriptor')==True / sendto/__class__/__name__.__eq__('method_descriptor')==True — recvfrom/sendto/shutdown are method_descriptor inherited from _socket.socket; qualname uses 'socket.' prefix (C class name); extra132 covers bind/connect/listen/send/recv; first sockmethod135 anchor for recvfrom/sendto/shutdown qualname"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockmethod135

  columns: [id, function, args, expected, description]
  rows:
    - [recvfrom_qual,    socket.recvfrom.__qualname__.__eq__,              ["socket.recvfrom"],      true, "socket.recvfrom.__qualname__ is 'socket.recvfrom' (C-level class prefix 'socket.', not 'socket.socket.')"]
    - [sendto_qual,      socket.sendto.__qualname__.__eq__,                ["socket.sendto"],        true, "socket.sendto.__qualname__ is 'socket.sendto' (C method_descriptor from _socket.socket)"]
    - [shutdown_qual,    socket.shutdown.__qualname__.__eq__,              ["socket.shutdown"],      true, "socket.shutdown.__qualname__ is 'socket.shutdown' (C method_descriptor; initiates graceful close)"]
    - [recvfrom_cls,     socket.recvfrom.__class__.__name__.__eq__,        ["method_descriptor"],    true, "socket.recvfrom.__class__.__name__ is 'method_descriptor' (C method from _socket.socket)"]
    - [sendto_cls,       socket.sendto.__class__.__name__.__eq__,          ["method_descriptor"],    true, "socket.sendto.__class__.__name__ is 'method_descriptor' (C method from _socket.socket)"]

# ---------------------------------------------------------------------------
# socket.socket.shutdown.__class__.__name__.__eq__('method_descriptor')
# socket.socket.settimeout.__qualname__.__eq__('socket.settimeout')
# socket.socket.gettimeout.__qualname__.__eq__('socket.gettimeout')
# socket.socket.settimeout.__class__.__name__.__eq__('method_descriptor')
# socket.socket.gettimeout.__class__.__name__.__eq__('method_descriptor')
#
# Wave 356 theme: shutdown/settimeout/gettimeout class names and qualnames.
#
# socket.socket.settimeout and gettimeout control the socket's timeout mode:
# settimeout(None) sets blocking mode, settimeout(0) sets non-blocking mode, and
# settimeout(float) sets a timeout. Both are method_descriptor objects inherited
# from the C-level _socket.socket. Their qualnames follow the 'socket.' prefix
# pattern. No prior socket spec anchors settimeout/gettimeout qualname via __eq__
# calls, nor shutdown __class__.__name__ == 'method_descriptor', under sockmethod135.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra135.shutdown_settimeout_gettimeout_identity:
  description: "socket.socket/shutdown/__class__/__name__.__eq__('method_descriptor')==True / settimeout/__qualname__.__eq__('socket.settimeout')==True / gettimeout/__qualname__.__eq__('socket.gettimeout')==True / settimeout/__class__/__name__.__eq__('method_descriptor')==True / gettimeout/__class__/__name__.__eq__('method_descriptor')==True — shutdown/settimeout/gettimeout are all method_descriptor from _socket.socket; settimeout/gettimeout control blocking/timeout mode; first sockmethod135 anchor for shutdown class and settimeout/gettimeout qualname and class"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockmethod135

  columns: [id, function, args, expected, description]
  rows:
    - [shutdown_cls,     socket.shutdown.__class__.__name__.__eq__,        ["method_descriptor"],    true, "socket.shutdown.__class__.__name__ is 'method_descriptor' (C method for graceful connection shutdown)"]
    - [settimeout_qual,  socket.settimeout.__qualname__.__eq__,            ["socket.settimeout"],    true, "socket.settimeout.__qualname__ is 'socket.settimeout' (C method controlling timeout mode)"]
    - [gettimeout_qual,  socket.gettimeout.__qualname__.__eq__,            ["socket.gettimeout"],    true, "socket.gettimeout.__qualname__ is 'socket.gettimeout' (C method returning current timeout)"]
    - [settimeout_cls,   socket.settimeout.__class__.__name__.__eq__,      ["method_descriptor"],    true, "socket.settimeout.__class__.__name__ is 'method_descriptor' (C method from _socket.socket)"]
    - [gettimeout_cls,   socket.gettimeout.__class__.__name__.__eq__,      ["method_descriptor"],    true, "socket.gettimeout.__class__.__name__ is 'method_descriptor' (C method from _socket.socket)"]

# ---------------------------------------------------------------------------
# socket.socket.setblocking.__qualname__.__eq__('socket.setblocking')
# socket.socket.setblocking.__class__.__name__.__eq__('method_descriptor')
# socket.socket.close.__qualname__.__eq__('socket.close')
# socket.socket.close.__class__.__name__.__eq__('function')
# socket.socket.close.__module__.__eq__('socket')
#
# Wave 356 theme: setblocking identity and close as Python function.
#
# socket.socket.setblocking is a method_descriptor (C-level, from _socket.socket)
# that sets the socket to blocking or non-blocking mode — it is equivalent to
# calling settimeout(None) for blocking or settimeout(0) for non-blocking.
# socket.socket.close, by contrast, is a Python function defined in Lib/socket.py
# (not a C method_descriptor). This is a key behavioral distinction: close is
# pure Python and has __module__=='socket' and __class__.__name__=='function',
# while all the I/O methods (recv, send, recvfrom, sendto, etc.) are C-level
# method_descriptor objects from _socket.socket. socket_extra97 anchors close
# __class__.__name__=='function'; this spec also anchors close.__qualname__ and
# __module__ under sockmethod135. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra135.setblocking_and_close_identity:
  description: "socket.socket/setblocking/__qualname__.__eq__('socket.setblocking')==True / setblocking/__class__/__name__.__eq__('method_descriptor')==True / close/__qualname__.__eq__('socket.close')==True / close/__class__/__name__.__eq__('function')==True / close/__module__.__eq__('socket')==True — setblocking is a C method_descriptor (like settimeout/gettimeout); close is a Python function from Lib/socket.py (like __init__/accept/makefile); extra97 anchors close class name but not qualname or module; first sockmethod135 anchor for setblocking qualname and close qualname/module"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockmethod135

  columns: [id, function, args, expected, description]
  rows:
    - [setblocking_qual, socket.setblocking.__qualname__.__eq__,           ["socket.setblocking"],   true, "socket.setblocking.__qualname__ is 'socket.setblocking' (C method_descriptor; equivalent to settimeout(0) or settimeout(None))"]
    - [setblocking_cls,  socket.setblocking.__class__.__name__.__eq__,     ["method_descriptor"],    true, "socket.setblocking.__class__.__name__ is 'method_descriptor' (C method from _socket.socket)"]
    - [close_qual,       socket.close.__qualname__.__eq__,                 ["socket.close"],         true, "socket.close.__qualname__ is 'socket.close' (Python function from Lib/socket.py; not a C method_descriptor)"]
    - [close_cls,        socket.close.__class__.__name__.__eq__,           ["function"],             true, "socket.close.__class__.__name__ is 'function' (Python function; contrasts with recv/send/etc. method_descriptor)"]
    - [close_module,     socket.close.__module__.__eq__,                   ["socket"],               true, "socket.close.__module__ is 'socket' (defined in Lib/socket.py; contrasts with _socket for C methods)"]

# ---------------------------------------------------------------------------
# socket.socket.recvfrom.__qualname__.__eq__('socket.recvfrom') — standalone
#
# socket.socket.recvfrom.__qualname__ is 'socket.recvfrom'. recvfrom is a
# C-level method_descriptor inherited from _socket.socket. It is the counterpart
# to sendto for connectionless protocols (UDP): it receives data and returns
# both the data and the sender's address. The qualname 'socket.recvfrom' uses
# the C-level class name 'socket' (not the Python-level 'socket.socket'). This
# qualname pattern is consistent across all I/O method_descriptors: recv, send,
# recvfrom, sendto, bind, connect, listen all use the 'socket.' prefix. No prior
# socket spec anchors recvfrom.__qualname__ via __eq__ as a standalone under
# sockmethod135. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra135.recvfrom_qualname:
  description: "socket.socket.recvfrom.__qualname__.__eq__('socket.recvfrom') == True — recvfrom is a C method_descriptor from _socket.socket; qualname uses C-level class name 'socket.' (not 'socket.socket.'); counterpart to sendto for UDP; extra132 covers recv/send qualname; first standalone for recvfrom.__qualname__.__eq__ under sockmethod135"
  category: type_identity
  kind: python_call_eq
  function: socket.recvfrom.__qualname__.__eq__
  args: ["socket.recvfrom"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.sendto.__qualname__.__eq__('socket.sendto') — standalone
#
# socket.socket.sendto.__qualname__ is 'socket.sendto'. sendto is the
# connectionless counterpart to send: it sends data to a specific address
# without requiring a prior connect() call. Like recvfrom, it is a C-level
# method_descriptor inherited from _socket.socket. Its qualname 'socket.sendto'
# follows the 'socket.' prefix convention for all C methods. sendto is essential
# for UDP socket communication where no persistent connection exists. No prior
# socket spec anchors sendto.__qualname__ via __eq__ as a standalone under
# sockmethod135. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra135.sendto_qualname:
  description: "socket.socket.sendto.__qualname__.__eq__('socket.sendto') == True — sendto is a C method_descriptor from _socket.socket; connectionless counterpart to send (no prior connect() needed); qualname uses C-level 'socket.' prefix; extra132 covers send qualname; first standalone for sendto.__qualname__.__eq__ under sockmethod135"
  category: type_identity
  kind: python_call_eq
  function: socket.sendto.__qualname__.__eq__
  args: ["socket.sendto"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.settimeout.__qualname__.__eq__('socket.settimeout') — standalone
#
# socket.socket.settimeout.__qualname__ is 'socket.settimeout'. settimeout is
# a C-level method_descriptor that controls the socket's timeout behavior: a
# float argument sets a timeout in seconds, None sets blocking mode (infinite
# timeout), and 0 sets non-blocking mode. It is inherited from _socket.socket
# and follows the 'socket.' qualname prefix. settimeout is one of two timeout-
# control methods alongside gettimeout (which reads the current timeout value).
# Together they replace the older POSIX-style blocking flag API. No prior socket
# spec anchors settimeout.__qualname__ via __eq__ as a standalone under sockmethod135.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra135.settimeout_qualname:
  description: "socket.socket.settimeout.__qualname__.__eq__('socket.settimeout') == True — settimeout is a C method_descriptor controlling timeout: float=timeout seconds, None=blocking, 0=non-blocking; qualname 'socket.settimeout' uses C-level prefix; first standalone for settimeout.__qualname__.__eq__ under sockmethod135"
  category: type_identity
  kind: python_call_eq
  function: socket.settimeout.__qualname__.__eq__
  args: ["socket.settimeout"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.close.__qualname__.__eq__('socket.close') — standalone
#
# socket.socket.close.__qualname__ is 'socket.close'. Unlike nearly all other
# socket I/O methods (recv, send, recvfrom, sendto, bind, connect, listen,
# shutdown, settimeout, gettimeout, setblocking), which are C-level
# method_descriptor objects inherited from _socket.socket, close is a Python
# function defined in Lib/socket.py. Its qualname 'socket.close' reflects the
# class it is defined in (socket.socket in Python, but accessed via the 'socket'
# prefix in qualname). socket_extra97 anchors close.__class__.__name__=='function';
# this is the first standalone for close.__qualname__.__eq__('socket.close')
# under sockmethod135. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra135.close_qualname:
  description: "socket.socket.close.__qualname__.__eq__('socket.close') == True — close is a Python function (not C method_descriptor); defined in Lib/socket.py; qualname 'socket.close'; extra97 anchors close.__class__.__name__=='function'; first standalone for close.__qualname__.__eq__ under sockmethod135"
  category: type_identity
  kind: python_call_eq
  function: socket.close.__qualname__.__eq__
  args: ["socket.close"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.setblocking.__class__.__name__.__eq__('method_descriptor') — standalone
#
# socket.socket.setblocking.__class__.__name__ is 'method_descriptor'. setblocking
# is a convenience method equivalent to settimeout(None) for blocking or
# settimeout(0) for non-blocking mode. It is a C-level method_descriptor (like
# settimeout/gettimeout/recv/send/etc.) inherited from _socket.socket. The fact
# that both setblocking and settimeout are method_descriptor objects (rather than
# Python functions like close) means they have no __code__ attribute and no
# __module__ == 'socket'. Their qualnames use the 'socket.' C-level prefix.
# No prior socket spec anchors setblocking.__class__.__name__ via __eq__ as a
# standalone under sockmethod135. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra135.setblocking_class_method_descriptor:
  description: "socket.socket.setblocking.__class__.__name__.__eq__('method_descriptor') == True — setblocking is a C method_descriptor (equivalent to settimeout(None/0)); like settimeout/gettimeout (all C-level); contrasts with close which is a Python function; first standalone for setblocking.__class__.__name__.__eq__ under sockmethod135"
  category: type_identity
  kind: python_call_eq
  function: socket.setblocking.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

