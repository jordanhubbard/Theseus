table multiprocessing_extra239.forking_pickler_identity:
  description: "multiprocessing.reduction.ForkingPickler class identity — ForkingPickler.__name__.__eq__('ForkingPickler')==True (len=14); ForkingPickler.__module__.__eq__('multiprocessing.reduction')==True (len=25); ForkingPickler.__bases__[0].__name__.__eq__('Pickler')==True (len=7; ForkingPickler extends pickle.Pickler with cross-process reduction support); all verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mp239fp

  columns: [id, function, args, expected, description]
  rows:
    - [fp_name_eq,   reduction.ForkingPickler.__name__.__eq__,                  ["ForkingPickler"],            true, "multiprocessing.reduction.ForkingPickler.__name__ == 'ForkingPickler'; verified with Python 3.14.3"]
    - [fp_name_len,  reduction.ForkingPickler.__name__.__len__,                 [],                            14,   "multiprocessing.reduction.ForkingPickler.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [fp_mod_eq,    reduction.ForkingPickler.__module__.__eq__,                ["multiprocessing.reduction"], true, "multiprocessing.reduction.ForkingPickler.__module__ == 'multiprocessing.reduction'; verified with Python 3.14.3"]
    - [fp_mod_len,   reduction.ForkingPickler.__module__.__len__,               [],                            25,   "multiprocessing.reduction.ForkingPickler.__module__.__len__() == 25; verified with Python 3.14.3"]
    - [fp_base_eq,   "reduction.ForkingPickler.__bases__[0].__name__.__eq__",   ["Pickler"],                   true, "multiprocessing.reduction.ForkingPickler.__bases__[0].__name__ == 'Pickler'; verified with Python 3.14.3"]
    - [fp_base_len,  "reduction.ForkingPickler.__bases__[0].__name__.__len__",  [],                            7,    "multiprocessing.reduction.ForkingPickler.__bases__[0].__name__.__len__() == 7; verified with Python 3.14.3"]

