spec: multiprocessing_extra239
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.reduction.ForkingPickler — ForkingPickler"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Process — Process class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/reduction.py (internal implementation)"
    - "CPython source: Lib/multiprocessing/process.py (internal implementation)"
    - "CPython source: Lib/multiprocessing/context.py (internal implementation)"
  notes:
    - "multiprocessing.reduction.ForkingPickler.__name__ == 'ForkingPickler' (len=14); __module__ == 'multiprocessing.reduction' (len=25); __bases__[0].__name__ == 'Pickler' (len=7)."
    - "multiprocessing.reduction.dump.__name__ == 'dump' (len=4); __module__ == 'multiprocessing.reduction' (len=25); __class__.__name__ == 'function' (len=8)."
    - "multiprocessing.process.BaseProcess.__name__ == 'BaseProcess' (len=11); __module__ == 'multiprocessing.process' (len=23); __bases__[0].__name__ == 'object' (len=6)."
    - "multiprocessing.Process.__name__ == 'Process' (len=7); __module__ == 'multiprocessing.context' (len=23); __bases__[0].__name__ == 'BaseProcess' (len=11)."
    - "Process.__module__ is 'multiprocessing.context' rather than 'multiprocessing.process' because the concrete Process class is created dynamically in context.py to bind to the platform-specific start method."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

