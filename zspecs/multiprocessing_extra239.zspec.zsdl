table multiprocessing_extra239.process_identity:
  description: "multiprocessing.Process class identity — Process.__name__.__eq__('Process')==True (len=7); Process.__module__.__eq__('multiprocessing.context')==True (len=23; the concrete Process class is created in context.py bound to the platform start method, NOT multiprocessing.process — this is a key finding); Process.__bases__[0].__name__.__eq__('BaseProcess')==True (len=11; Process extends BaseProcess which lives in multiprocessing.process); all verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mp239pr

  columns: [id, function, args, expected, description]
  rows:
    - [pr_name_eq,   Process.__name__.__eq__,                  ["Process"],                     true, "multiprocessing.Process.__name__ == 'Process'; verified with Python 3.14.3"]
    - [pr_name_len,  Process.__name__.__len__,                 [],                              7,    "multiprocessing.Process.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [pr_mod_eq,    Process.__module__.__eq__,                ["multiprocessing.context"],     true, "multiprocessing.Process.__module__ == 'multiprocessing.context' (not multiprocessing.process); verified with Python 3.14.3"]
    - [pr_mod_len,   Process.__module__.__len__,               [],                              23,   "multiprocessing.Process.__module__.__len__() == 23; verified with Python 3.14.3"]
    - [pr_base_eq,   "Process.__bases__[0].__name__.__eq__",   ["BaseProcess"],                 true, "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess'; verified with Python 3.14.3"]
    - [pr_base_len,  "Process.__bases__[0].__name__.__len__",  [],                              11,   "multiprocessing.Process.__bases__[0].__name__.__len__() == 11; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra239
# ---------------------------------------------------------------------------

invariant multiprocessing_extra239.forking_pickler_base_is_pickler:
  description: "multiprocessing.reduction.ForkingPickler.__bases__[0].__name__.__eq__('Pickler') returns True — ForkingPickler extends pickle.Pickler (len=7) with cross-process object reduction; ForkingPickler.__name__ == 'ForkingPickler' (len=14); ForkingPickler.__module__ == 'multiprocessing.reduction' (len=25); BaseProcess.__bases__[0].__name__ == 'object' (both are single-base classes); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "reduction.ForkingPickler.__bases__[0].__name__.__eq__"
  args: ["Pickler"]
  expected: true

invariant multiprocessing_extra239.process_module_is_context_not_process:
  description: "multiprocessing.Process.__module__.__eq__('multiprocessing.context') returns True — the concrete Process class bound to the platform's default start method is constructed in context.py; its __module__ is 'multiprocessing.context' (len=23), NOT 'multiprocessing.process' (len=23, same length); BaseProcess lives in 'multiprocessing.process'; Process.__name__ == 'Process' (len=7); Process.__bases__[0].__name__ == 'BaseProcess' (len=11); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra239.base_process_bases_index_1_raises:
  description: "multiprocessing.process.BaseProcess.__bases__[1].__name__.__eq__ raises IndexError — BaseProcess has exactly one direct base class (object); __bases__ is a 1-element tuple; accessing __bases__[1] is out of range and raises IndexError; this confirms single-inheritance: BaseProcess -> object; BaseProcess.__name__ == 'BaseProcess' (len=11); verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: "process.BaseProcess.__bases__[1].__name__.__eq__"
  args: ["ShouldNotReach"]
  raises: IndexError

invariant multiprocessing_extra239.reduction_dump_module_eq_forking_pickler_module:
  description: "multiprocessing.reduction.dump.__module__.__eq__('multiprocessing.reduction') returns True — dump and ForkingPickler share the same __module__ 'multiprocessing.reduction' (len=25); dump.__name__ == 'dump' (len=4); dump.__class__.__name__ == 'function' (len=8; plain Python function in contrast to ForkingPickler which is a class); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: reduction.dump.__module__.__eq__
  args: ["multiprocessing.reduction"]
  expected: true
