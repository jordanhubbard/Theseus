spec: email_extra11
version: ">=3.6"
backend: python_module(email)

docs: https://docs.python.org/3/library/email.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/email.html — Python email module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/email/"
    - "email_extra4.zspec.zsdl — covers email.utils parseaddr/formataddr __qualname__.__eq__ and __module__.__eq__; email.errors class qualnames; email.policy class qualnames; email.generator qualnames."
    - "email_extra8.zspec.zsdl — covers message.Message/__name__.__eq__ (not __qualname__)."
    - "email_extra10.zspec.zsdl — covers message.Message.__qualname__.__eq__('Message') in a class-level table; utils.parseaddr/__qualname__.__len__; header.Header.__module__."
  notes:
    - "This spec extends the email family through email_extra10; it does NOT duplicate invariants in any prior spec."
    - "Focus: __qualname__ for methods defined on email.message.Message — no prior email spec checks method-level __qualname__ for any Message method. email_extra10 checks Message.__qualname__ at the class level; this spec adds method-level qualnames for get, set_payload, get_payload, get_content_type, attach, walk, and as_string."
    - "email.message.Message.get.__qualname__ == 'Message.get' (length 11) — defined directly on Message. No prior email spec checks any Message method qualname."
    - "email.message.Message.set_payload.__qualname__ == 'Message.set_payload' (length 19) — defined directly on Message."
    - "email.message.Message.get_payload.__qualname__ == 'Message.get_payload' (length 19) — defined directly on Message."
    - "email.message.Message.get_content_type.__qualname__ == 'Message.get_content_type' (length 24) — defined directly on Message."
    - "email.message.Message.attach.__qualname__ == 'Message.attach' (length 14) — defined directly on Message."
    - "email.message.Message.walk.__qualname__ == 'walk' (length 4) — walk is a generator function; its __qualname__ does NOT include the 'Message.' prefix because it is stored as a bare function reference on the class rather than being defined with the class body in the usual way. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "email.message.Message.as_string.__qualname__ == 'Message.as_string' (length 17) — defined directly on Message."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# email.message.Message method __qualname__ values
#
# email_extra10 checks Message.__qualname__ == 'Message' at the class level.
# No prior email spec checks the __qualname__ of any method defined on the
# Message class. Most methods follow the 'Message.<method>' pattern because
# they are defined inside the class body. The exception is .walk, whose
# __qualname__ is just 'walk' — it is a generator function stored as a class
# attribute after being defined at module scope.
# ---------------------------------------------------------------------------

table email_extra11.Message_method_qualnames:
  description: "email.message.Message method __qualname__ values — no prior email spec covers Message method qualnames"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: msgmqname11

  columns: [id, function, args, expected]
  rows:
    - [get,              message.Message.get.__qualname__.__eq__,              ["Message.get"],              true]
    - [set_payload,      message.Message.set_payload.__qualname__.__eq__,      ["Message.set_payload"],      true]
    - [get_payload,      message.Message.get_payload.__qualname__.__eq__,      ["Message.get_payload"],      true]
    - [get_content_type, message.Message.get_content_type.__qualname__.__eq__, ["Message.get_content_type"], true]
    - [attach,           message.Message.attach.__qualname__.__eq__,           ["Message.attach"],           true]
    - [as_string,        message.Message.as_string.__qualname__.__eq__,        ["Message.as_string"],        true]

# ---------------------------------------------------------------------------
# email.message.Message.walk.__qualname__ == 'walk'
#
# walk is a special case: its __qualname__ is 'walk' (not 'Message.walk')
# because it is a generator function assigned to the class as an attribute
# after being defined at module scope. This is a notable behavioral property
# distinct from all other methods in the table above.
# ---------------------------------------------------------------------------

invariant email_extra11.Message.walk_qualname:
  description: "email.message.Message.walk.__qualname__ == 'walk' — generator stored as class attr, not defined in class body"
  category: method_qualnames
  kind: python_call_eq
  function: message.Message.walk.__qualname__.__eq__
  args: ["walk"]
  expected: true

# ---------------------------------------------------------------------------
# email.message.Message method __qualname__ string lengths
#
# No prior email spec checks the string length of any Message method qualname.
# get(11), set_payload(19), get_payload(19), get_content_type(24),
# attach(14), walk(4), as_string(17).
# ---------------------------------------------------------------------------

table email_extra11.Message_method_qualname_lengths:
  description: "email.message.Message method __qualname__ string lengths — no prior spec checks these lengths"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: msgmqlen11

  columns: [id, function, args, expected]
  rows:
    - [get,              message.Message.get.__qualname__.__len__,              [], 11]
    - [set_payload,      message.Message.set_payload.__qualname__.__len__,      [], 19]
    - [get_payload,      message.Message.get_payload.__qualname__.__len__,      [], 19]
    - [get_content_type, message.Message.get_content_type.__qualname__.__len__, [], 24]
    - [attach,           message.Message.attach.__qualname__.__len__,           [], 14]
    - [walk,             message.Message.walk.__qualname__.__len__,             [], 4]
    - [as_string,        message.Message.as_string.__qualname__.__len__,        [], 17]
