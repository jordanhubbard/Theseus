spec: threading_extra2491
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: __setitem__, __delitem__, and __missing__ dict-presence checks for threading module classes."
    - "Theme: mutable item access and missing-key protocol — checking class __dict__ membership via __contains__."
    - "threading.Thread, Lock, Condition, Semaphore, BoundedSemaphore, Event, Timer, Barrier, local — none define __setitem__, __delitem__, or __missing__."
    - "threading.Thread is a pure-Python class managing OS-level threads via attributes (name, daemon, etc.) but not mapping-style item access. Verified with Python 3.14."
    - "threading.Lock and threading.RLock are thin wrappers over C-level lock primitives; they expose acquire/release/context manager protocol, not item-mutation protocol. Verified with Python 3.14."
    - "threading.Condition, Semaphore, BoundedSemaphore, Event, Barrier are synchronization primitives; they hold internal state via attributes, not via __setitem__/__delitem__. Verified with Python 3.14."
    - "threading.local supports per-thread attribute access (getattr/setattr), not item access (__getitem__/__setitem__). Even though each thread sees a separate namespace, the class defines no __setitem__, __delitem__, or __missing__. Verified with Python 3.14."
    - "threading.Timer is a subclass of Thread that also holds no item-mutation protocol. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread and threading.Timer — item protocol absence
#
# Theme: __setitem__, __delitem__, __missing__ absent from Thread and Timer.
# Thread manages OS threads via start/join/run; Timer subclasses Thread
# to run a function after a delay. Neither implements the mutable mapping protocol.
# ---------------------------------------------------------------------------

table threading_extra2491.thread_timer_item_protocol:
  description: "__setitem__, __delitem__, __missing__ absent from threading.Thread and threading.Timer __dict__; wave 2491"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: th2491

  columns: [id, function, args, expected]
  rows:
    - ["th2491-001", "Thread.__dict__.__contains__", ["__setitem__"], false]
    - ["th2491-002", "Thread.__dict__.__contains__", ["__delitem__"], false]
    - ["th2491-003", "Thread.__dict__.__contains__", ["__missing__"], false]
    - ["th2491-004", "Timer.__dict__.__contains__", ["__setitem__"], false]
    - ["th2491-005", "Timer.__dict__.__contains__", ["__delitem__"], false]
    - ["th2491-006", "Timer.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# Table 2: threading lock/condition primitives — item protocol absence
#
# Theme: __setitem__, __delitem__, __missing__ absent from Lock, Condition,
# Semaphore, and BoundedSemaphore.
# These synchronization primitives expose acquire/release and context manager
# protocol only; they hold no mutable mapping protocol.
# ---------------------------------------------------------------------------

table threading_extra2491.lock_condition_item_protocol:
  description: "__setitem__, __delitem__, __missing__ absent from threading.Lock, Condition, Semaphore, BoundedSemaphore __dict__; wave 2491"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: th2491

  columns: [id, function, args, expected]
  rows:
    - ["th2491-007", "Lock.__dict__.__contains__", ["__setitem__"], false]
    - ["th2491-008", "Lock.__dict__.__contains__", ["__delitem__"], false]
    - ["th2491-009", "Lock.__dict__.__contains__", ["__missing__"], false]
    - ["th2491-010", "Condition.__dict__.__contains__", ["__setitem__"], false]
    - ["th2491-011", "Condition.__dict__.__contains__", ["__delitem__"], false]
    - ["th2491-012", "Condition.__dict__.__contains__", ["__missing__"], false]
    - ["th2491-013", "Semaphore.__dict__.__contains__", ["__setitem__"], false]
    - ["th2491-014", "Semaphore.__dict__.__contains__", ["__delitem__"], false]
    - ["th2491-015", "Semaphore.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# Table 3: threading.Event, threading.Barrier, threading.local — item protocol absence
#
# Theme: __setitem__, __delitem__, __missing__ absent from Event, Barrier, local.
# Event and Barrier are higher-level synchronization tools; local provides
# per-thread attribute namespaces via attribute access (not item access).
# None define __setitem__, __delitem__, or __missing__.
# ---------------------------------------------------------------------------

table threading_extra2491.event_barrier_local_item_protocol:
  description: "__setitem__, __delitem__, __missing__ absent from threading.Event, Barrier, local __dict__; wave 2491"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: th2491

  columns: [id, function, args, expected]
  rows:
    - ["th2491-016", "Event.__dict__.__contains__", ["__setitem__"], false]
    - ["th2491-017", "Event.__dict__.__contains__", ["__delitem__"], false]
    - ["th2491-018", "Event.__dict__.__contains__", ["__missing__"], false]
    - ["th2491-019", "Barrier.__dict__.__contains__", ["__setitem__"], false]
    - ["th2491-020", "Barrier.__dict__.__contains__", ["__delitem__"], false]
    - ["th2491-021", "Barrier.__dict__.__contains__", ["__missing__"], false]
    - ["th2491-022", "local.__dict__.__contains__", ["__setitem__"], false]
    - ["th2491-023", "local.__dict__.__contains__", ["__delitem__"], false]
    - ["th2491-024", "local.__dict__.__contains__", ["__missing__"], false]
