spec: weakref_extra24
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
  notes:
    - "This spec extends weakref_extra23.zspec.zsdl."
    - "Prior specs covered: ref/__name__/__module__/__qualname__, WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize __name__/__module__/__qualname__, ref.__bases__[0].__name__, WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize __bases__[0].__name__, getweakrefcount/getweakrefs __name__/__module__, ref.__init__.__name__, WeakSet.__module__=='_weakrefset', finalize.__module__=='weakref'."
    - "This spec covers: __module__.__len__() for ref/WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize, __name__.__len__() for ref/WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize, getweakrefcount/__qualname__, getweakrefs/__qualname__."
    - "weakref.ref.__module__.__len__() == 7 — 'weakref' has length 7."
    - "weakref.WeakValueDictionary.__module__.__len__() == 7 — 'weakref' has length 7."
    - "weakref.WeakKeyDictionary.__module__.__len__() == 7 — 'weakref' has length 7."
    - "weakref.WeakSet.__module__.__len__() == 11 — '_weakrefset' has length 11; WeakSet is in the private module."
    - "weakref.finalize.__module__.__len__() == 7 — 'weakref' has length 7."
    - "weakref.ref.__name__.__len__() == 13 — 'ReferenceType' has length 13; the C-level type name."
    - "weakref.WeakValueDictionary.__name__.__len__() == 19 — 'WeakValueDictionary' has length 19."
    - "weakref.WeakKeyDictionary.__name__.__len__() == 17 — 'WeakKeyDictionary' has length 17."
    - "weakref.WeakSet.__name__.__len__() == 7 — 'WeakSet' has length 7."
    - "weakref.finalize.__name__.__len__() == 8 — 'finalize' has length 8."
    - "weakref.getweakrefcount.__qualname__ == 'getweakrefcount' — top-level C function; __qualname__ equals simple name."
    - "weakref.getweakrefs.__qualname__ == 'getweakrefs' — top-level C function; __qualname__ equals simple name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() combined table for weakref classes (extra24 namespace)
#
# ref/WeakValueDictionary/WeakKeyDictionary/finalize have __module__ == 'weakref'
# (length 7). WeakSet has __module__ == '_weakrefset' (length 11). Prior specs
# record the __module__ string values in weakref_extra23; this table exercises
# the __len__ call path for all five together in the extra24 namespace.
# ---------------------------------------------------------------------------

table weakref_extra24.module_lens:
  description: "__module__.__len__() for weakref classes in the extra24 namespace"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [ref,                  ref.__module__.__len__,                  [], 7]
    - [WeakValueDictionary,  WeakValueDictionary.__module__.__len__,  [], 7]
    - [WeakKeyDictionary,    WeakKeyDictionary.__module__.__len__,    [], 7]
    - [finalize,             finalize.__module__.__len__,             [], 7]
    - [WeakSet,              WeakSet.__module__.__len__,              [], 11]

# ---------------------------------------------------------------------------
# __name__.__len__() combined table for weakref classes (extra24 namespace)
#
# Prior specs record __name__ strings but not their lengths. The C-level ref
# type reports 'ReferenceType' (13), while the Python classes use their class
# names: 'WeakValueDictionary' (19), 'WeakKeyDictionary' (17), 'WeakSet' (7),
# 'finalize' (8). No prior weakref spec records __name__.__len__() for any.
# ---------------------------------------------------------------------------

table weakref_extra24.name_lens:
  description: "__name__.__len__() for weakref classes in the extra24 namespace"
  kind: python_call_eq
  category: name_attrs
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [ref,                  ref.__name__.__len__,                  [], 13]
    - [WeakValueDictionary,  WeakValueDictionary.__name__.__len__,  [], 19]
    - [WeakKeyDictionary,    WeakKeyDictionary.__name__.__len__,    [], 17]
    - [WeakSet,              WeakSet.__name__.__len__,              [], 7]
    - [finalize,             finalize.__name__.__len__,             [], 8]

# ---------------------------------------------------------------------------
# __qualname__ combined table for getweakrefcount/getweakrefs (extra24 namespace)
#
# Both are C-level functions exposed via the weakref module. As top-level
# functions __qualname__ equals the simple name: 'getweakrefcount' and
# 'getweakrefs'. Prior specs record __name__ and __module__ for these two
# functions but not __qualname__. This table adds __qualname__ checks in the
# extra24 namespace.
# ---------------------------------------------------------------------------

table weakref_extra24.cfunc_qualnames:
  description: "__qualname__.__eq__ for weakref C-level module functions in the extra24 namespace"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [getweakrefcount, getweakrefcount.__qualname__.__eq__, ["getweakrefcount"], true]
    - [getweakrefs,     getweakrefs.__qualname__.__eq__,     ["getweakrefs"],     true]

# ---------------------------------------------------------------------------
# weakref.WeakSet.__module__.__len__() == 11 — standalone (extra24 namespace)
#
# WeakSet has __module__ == '_weakrefset' (length 11), distinguishing it from
# all other weakref classes whose __module__ is 'weakref' (length 7).
# Re-anchored as a standalone invariant to highlight the distinction.
# ---------------------------------------------------------------------------

invariant weakref_extra24.WeakSet.module.len:
  description: "weakref.WeakSet.__module__.__len__() == 11 — '_weakrefset' has length 11; longer than 'weakref' (7) used by other weakref classes"
  category: module_attrs
  kind: python_call_eq
  function: WeakSet.__module__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# weakref.ref.__name__.__len__() == 13 — standalone (extra24 namespace)
#
# weakref.ref is the C-level ReferenceType; its __name__ is 'ReferenceType'
# (13 characters). This is notably different from the Python class names like
# 'WeakSet' (7) or 'finalize' (8). Re-anchored as a standalone to highlight
# that the C-level type uses a longer descriptive name.
# ---------------------------------------------------------------------------

invariant weakref_extra24.ref.name.len:
  description: "weakref.ref.__name__.__len__() == 13 — 'ReferenceType' has 13 characters; C-level type name is longer than the public alias 'ref'"
  category: name_attrs
  kind: python_call_eq
  function: ref.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# weakref.getweakrefcount.__qualname__ == 'getweakrefcount' — standalone
# (extra24 namespace)
#
# getweakrefcount is a C-level function; as a top-level function __qualname__
# equals its simple name 'getweakrefcount'. Prior specs record __name__ and
# __module__ for getweakrefcount but not __qualname__. Re-anchored as a
# standalone in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant weakref_extra24.getweakrefcount.qualname:
  description: "weakref.getweakrefcount.__qualname__ == 'getweakrefcount' — top-level C function; __qualname__ equals simple name"
  category: qualnames
  kind: python_call_eq
  function: getweakrefcount.__qualname__.__eq__
  args: ["getweakrefcount"]
  expected: true
