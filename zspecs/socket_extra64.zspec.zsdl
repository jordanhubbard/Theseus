spec: socket_extra64
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra63.zspec.zsdl — covers socket.socket.accept.__code__.co_name ('accept') / makefile.__code__.co_name ('makefile') / accept.__code__.co_argcount==1 / makefile.__code__.co_argcount==3 / gethostbyname.__doc__.__contains__('host') / getfqdn.__doc__.__contains__('hostname') (table + invariants)."
    - "socket_extra62.zspec.zsdl — covers socket.socket.accept.__defaults__.__class__.__name__.__eq__('NoneType') / makefile.__defaults__.__class__.__name__.__eq__('tuple') / accept.__code__.__class__.__name__.__eq__('code') / makefile.__code__.__class__.__name__.__eq__('code') / gethostname.__doc__.__contains__('host') (table + invariants)."
    - "socket_extra61.zspec.zsdl — covers socket.socket.accept/close/detach/makefile __annotations__.__class__.__name__.__eq__('dict') / __annotations__.__len__()==0 / getfqdn.__annotations__.__class__.__name__.__eq__('dict') / socket module __doc__.__class__.__name__.__eq__('str') / __doc__.__len__()==2021 / socket.socket.__doc__.__contains__('socket') / __contains__('makefile') (table + invariants)."
    - "socket_extra60.zspec.zsdl — covers socket.socket recv_into/recvfrom_into/getblocking/get_inheritable/set_inheritable __qualname__.__eq__ string values (table + invariants)."
    - "socket_extra59.zspec.zsdl — covers socket.__spec__.origin.__class__.__name__.__eq__('str') / submodule_search_locations.__class__.__name__.__eq__('NoneType') / has_location==True / __loader__.__class__.__name__.__len__()==16 (table + invariants)."
    - "socket_extra50.zspec.zsdl — covers socket.socket.connect/bind/listen/accept/send/recv/close __qualname__.__eq__ string values."
    - "socket_extra49.zspec.zsdl — covers socket.gethostname/__doc__.__class__.__name__.__eq__('str') (type identity axis for gethostname docstring)."
    - "socket_extra42.zspec.zsdl — covers socket.socket shutdown/sendall/recvfrom/sendto/connect_ex/dup/makefile/detach __qualname__.__eq__ string values."
    - "socket_extra22.zspec.zsdl — covers socket.socket connect/bind/listen/accept/close/recv/send __qualname__.__eq__ string values."
    - "socket_extra8.zspec.zsdl — covers gethostname/gethostbyname/getaddrinfo/getfqdn/create_connection __qualname__.__eq__ string values (module-level functions)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra63; it does NOT duplicate invariants present in those files."
    - "Wave 231 theme: __code__.co_varnames / co_filename / co_flags chains for Python socket.socket methods + AF_INET/SOCK_STREAM enum class identity checks."
    - "In python_module(socket) backend, 'socket' in the module namespace refers to the socket.socket class (the class named 'socket' within the socket module's __dict__). So 'socket.accept' means 'socket.socket.accept', the Python method defined in Lib/socket.py. This is consistent with prior socket specs (socket_extra63 etc.) which use 'socket.accept' to mean the method."
    - "socket.socket.accept.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple for Python code objects; accept is a pure Python method in Lib/socket.py. socket_extra63 checks accept.__code__.co_name (co_name axis). No prior socket spec checks accept.__code__.co_varnames. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__code__.co_varnames.__class__.__name__ == 'tuple' — makefile is a pure Python method in Lib/socket.py. No prior socket spec checks makefile.__code__.co_varnames. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__code__.co_varnames[0] == 'self' — accept(self) has 'self' as the first and only positional parameter; co_varnames[0]=='self'. No prior socket spec checks accept.__code__.co_varnames[0]. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__code__.co_varnames[0] == 'self' — makefile(self, mode='r', buffering=None, ...) has 'self' as the first parameter; co_varnames[0]=='self'. No prior socket spec checks makefile.__code__.co_varnames[0]. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__code__.co_filename.__contains__('.py') == True — accept is defined in Lib/socket.py. No prior socket spec checks accept.__code__.co_filename. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__code__.co_filename.__contains__('.py') == True — makefile is defined in Lib/socket.py. No prior socket spec checks makefile.__code__.co_filename. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily' — in Python 3.4+ AF_INET is an IntEnum member of socket.AddressFamily with value 2. No prior socket spec checks AF_INET.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — in Python 3.4+ SOCK_STREAM is an IntEnum member of socket.SocketKind with value 1. No prior socket spec checks SOCK_STREAM.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.accept and makefile __code__.co_varnames class name
#
# Wave 231 theme: __code__.co_varnames chains for Python socket methods.
#
# co_varnames is a tuple of local variable names (parameters first, then
# locals). Both accept and makefile are pure Python methods in Lib/socket.py
# so their co_varnames is a tuple. socket_extra63 checks the co_name and
# co_argcount axes for both. No prior socket spec checks co_varnames.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra64.co_varnames_class_name:
  description: "socket.socket.accept.__code__.co_varnames.__class__.__name__=='tuple' and makefile.__code__.co_varnames.__class__.__name__=='tuple' — co_varnames is always a tuple for Python code objects; both accept and makefile are pure Python methods in Lib/socket.py; socket_extra63 checks co_name and co_argcount axes; no prior socket spec checks co_varnames for any socket.socket method; first co_varnames anchor for socket"
  kind: python_call_eq
  category: code_objects
  id_prefix: socketcode3_64

  columns: [id, function, args, expected]
  rows:
    - [accept_co_varnames_class_name,   socket.accept.__code__.co_varnames.__class__.__name__.__eq__,   ["tuple"], true]
    - [makefile_co_varnames_class_name, socket.makefile.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true]

# ---------------------------------------------------------------------------
# socket.socket.accept and makefile __code__.co_varnames first element
#
# Wave 231 theme: __code__.co_varnames[0] for Python socket methods.
#
# accept(self) and makefile(self, mode='r', buffering=None, ...) both have
# 'self' as the first parameter, so co_varnames[0] == 'self' for both.
# The [0] subscript in the function attribute chain requires double-quoting
# in table rows per ZSDL rules. No prior socket spec checks co_varnames[0].
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra64.co_varnames_first_arg:
  description: "socket.socket.accept.__code__.co_varnames[0].__eq__('self') and makefile.__code__.co_varnames[0].__eq__('self') — accept(self) and makefile(self, mode, ...) both have 'self' as the first parameter so co_varnames[0]=='self'; no prior socket spec checks co_varnames[0] for any socket.socket method; first co_varnames element anchor for socket"
  kind: python_call_eq
  category: code_objects
  id_prefix: socketcode3_64

  columns: [id, function, args, expected]
  rows:
    - [accept_co_varnames_0_self,   "socket.accept.__code__.co_varnames[0].__eq__",   ["self"], true]
    - [makefile_co_varnames_0_self, "socket.makefile.__code__.co_varnames[0].__eq__", ["self"], true]

# ---------------------------------------------------------------------------
# socket.socket.accept and makefile __code__.co_filename contains '.py'
#
# Wave 231 theme: __code__.co_filename chains for Python socket methods.
#
# co_filename records the source file path. Both accept and makefile are
# defined in Lib/socket.py so co_filename ends in '.py'. socket_extra63
# checks co_name; no prior socket spec checks co_filename for any method.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra64.co_filename_contains_py:
  description: "socket.socket.accept.__code__.co_filename.__contains__('.py') and makefile.__code__.co_filename.__contains__('.py') — co_filename records the source file path; both methods are defined in Lib/socket.py so co_filename ends in '.py'; socket_extra63 checks co_name (co_name axis); no prior socket spec checks co_filename for any socket.socket method; first co_filename anchor for socket"
  kind: python_call_eq
  category: code_objects
  id_prefix: socketcode3_64

  columns: [id, function, args, expected]
  rows:
    - [accept_co_filename_contains_py,   socket.accept.__code__.co_filename.__contains__,   [".py"], true]
    - [makefile_co_filename_contains_py, socket.makefile.__code__.co_filename.__contains__, [".py"], true]

# ---------------------------------------------------------------------------
# socket.AF_INET and SOCK_STREAM enum class identity checks
#
# Wave 231 theme: socket constant type identity via IntEnum subclasses.
#
# In Python 3.4+, socket constants AF_INET and SOCK_STREAM are IntEnum
# members. AF_INET belongs to socket.AddressFamily (value 2). SOCK_STREAM
# belongs to socket.SocketKind (value 1). No prior socket spec checks the
# __class__.__name__ of any socket constant. Verified Python 3.14.3 macOS.
# ---------------------------------------------------------------------------

table socket_extra64.socket_constants_enum_class:
  description: "socket.AF_INET.__class__.__name__=='AddressFamily' and SOCK_STREAM.__class__.__name__=='SocketKind' — in Python 3.4+ AF_INET is an IntEnum member of socket.AddressFamily (value 2) and SOCK_STREAM is an IntEnum member of socket.SocketKind (value 1); no prior socket spec checks __class__.__name__ for any socket constant; first enum class identity anchor for socket constants"
  kind: python_call_eq
  category: module_constants
  id_prefix: socketcode3_64

  columns: [id, function, args, expected]
  rows:
    - [AF_INET_class_AddressFamily,   AF_INET.__class__.__name__.__eq__,    ["AddressFamily"], true]
    - [SOCK_STREAM_class_SocketKind,  SOCK_STREAM.__class__.__name__.__eq__, ["SocketKind"],    true]

# ---------------------------------------------------------------------------
# socket.socket.accept.__code__.co_varnames.__class__.__name__=='tuple' — standalone
#
# socket.socket.accept is a pure Python method in Lib/socket.py. Its code
# object's co_varnames is a tuple — the standard type for variable name
# sequences in Python code objects. socket_extra63 checks co_name and
# co_argcount axes. No prior socket spec checks accept.__code__.co_varnames.
# First co_varnames anchor for any socket.socket method.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra64.socket_accept_co_varnames_tuple:
  description: "socket.socket.accept.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is always a tuple for Python code objects; accept is a pure Python method in Lib/socket.py; socket_extra63 checks co_name and co_argcount axes; no prior socket spec checks accept.__code__.co_varnames; first co_varnames anchor for any socket.socket method"
  category: code_objects
  kind: python_call_eq
  function: socket.accept.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.accept.__code__.co_varnames[0] == 'self' — standalone
#
# socket.socket.accept(self) has 'self' as its only parameter. co_varnames[0]
# is the first entry in the variable names tuple, which is 'self'. This
# anchors the first co_varnames element for accept. No prior socket spec checks
# accept.__code__.co_varnames[0]. First co_varnames element anchor for socket.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra64.socket_accept_co_varnames_self:
  description: "socket.socket.accept.__code__.co_varnames[0].__eq__('self') == True — accept(self) has 'self' as its only parameter and co_varnames[0]=='self'; no prior socket spec checks accept.__code__.co_varnames[0]; first co_varnames element anchor for socket.socket methods"
  category: code_objects
  kind: python_call_eq
  function: socket.accept.__code__.co_varnames
  method_chain: ["__getitem__", "__eq__"]
  method_chain_args: [[0], ["self"]]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.accept.__code__.co_filename.__contains__('.py') — standalone
#
# socket.socket.accept is defined in Lib/socket.py. The code object's
# co_filename records the source file path which ends in '.py'. This confirms
# accept is a Python function (not a C builtin). socket_extra63 checks co_name
# (name axis) and co_argcount (count axis). No prior socket spec checks
# co_filename for any socket.socket method. First co_filename anchor for socket.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra64.socket_accept_co_filename_contains_py:
  description: "socket.socket.accept.__code__.co_filename.__contains__('.py') == True — accept is defined in Lib/socket.py; co_filename ends in '.py' confirming it is a Python (not C) function; socket_extra63 checks co_name and co_argcount axes; no prior socket spec checks co_filename for any socket.socket method; first co_filename anchor for socket"
  category: code_objects
  kind: python_call_eq
  function: socket.accept.__code__.co_filename.__contains__
  args: [".py"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__name__.__eq__('AddressFamily') — standalone
#
# socket.AF_INET is a constant representing the address family for IPv4.
# In Python 3.4+, AF_INET is an IntEnum member of socket.AddressFamily with
# integer value 2. Its class name is 'AddressFamily'. No prior socket spec
# checks AF_INET.__class__.__name__. First enum class identity anchor for
# socket address family constants. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra64.AF_INET_class_AddressFamily:
  description: "socket.AF_INET.__class__.__name__.__eq__('AddressFamily') == True — AF_INET is an IntEnum member of socket.AddressFamily with value 2 in Python 3.4+; no prior socket spec checks AF_INET.__class__.__name__; first enum class identity anchor for socket address family constants"
  category: module_constants
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true
