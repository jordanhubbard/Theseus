spec: doctest_extra3
version: ">=3.9"
backend: python_module(doctest)

docs: https://docs.python.org/3/library/doctest.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/doctest.html — Python doctest module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/doctest.py"
  notes:
    - "This spec extends doctest.zspec.zsdl, doctest_extra.zspec.zsdl, and doctest_extra2.zspec.zsdl."
    - "doctest_extra covers: DocTest/__name__, DocTestFinder/__name__, DocTestRunner/__name__, DocTestParser/__name__, DocTest/__module__, ELLIPSIS/NORMALIZE_WHITESPACE/IGNORE_EXCEPTION_DETAIL as int, testmod/testfile/run_docstring_examples names."
    - "doctest_extra2 covers: DocTestFinder/__module__, DocTestRunner/__module__, DocTestParser/__module__, testmod/testfile/run_docstring_examples __name__ and __module__, ELLIPSIS==8, NORMALIZE_WHITESPACE==2, SKIP==16."
    - "This spec adds: DocTestFailure/__name__, UnexpectedException/__name__, DocTestFailure/__module__, UnexpectedException/__module__, DocTestFailure base class, IGNORE_EXCEPTION_DETAIL value, FAIL_FAST value."
    - "DocTestFailure and UnexpectedException are exception classes raised by DocTestRunner."
    - "DocTestFailure.__name__ == 'DocTestFailure' — raised when an expected output does not match actual output."
    - "UnexpectedException.__name__ == 'UnexpectedException' — raised when an unexpected exception occurs."
    - "DocTestFailure.__module__ == 'doctest', UnexpectedException.__module__ == 'doctest'."
    - "DocTestFailure.__bases__[0].__name__ == 'Exception' — DocTestFailure inherits from Exception."
    - "UnexpectedException.__bases__[0].__name__ == 'Exception' — UnexpectedException inherits from Exception."
    - "IGNORE_EXCEPTION_DETAIL == 32 in Python 3.12 (bit 5)."
    - "FAIL_FAST == 64 in Python 3.12 (bit 6)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception class names — DocTestFailure and UnexpectedException
# Not covered by doctest_extra or doctest_extra2.
# ---------------------------------------------------------------------------

invariant doctest_extra3.exceptions.DocTestFailure_name:
  description: "doctest.DocTestFailure.__name__ == 'DocTestFailure'"
  category: exceptions
  kind: python_call_eq
  function: DocTestFailure.__name__.__eq__
  args: ["DocTestFailure"]
  expected: true

invariant doctest_extra3.exceptions.UnexpectedException_name:
  description: "doctest.UnexpectedException.__name__ == 'UnexpectedException'"
  category: exceptions
  kind: python_call_eq
  function: UnexpectedException.__name__.__eq__
  args: ["UnexpectedException"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class modules — both defined in doctest
# ---------------------------------------------------------------------------

invariant doctest_extra3.exception_modules.DocTestFailure_module:
  description: "doctest.DocTestFailure.__module__ == 'doctest'"
  category: exception_modules
  kind: python_call_eq
  function: DocTestFailure.__module__.__eq__
  args: ["doctest"]
  expected: true

invariant doctest_extra3.exception_modules.UnexpectedException_module:
  description: "doctest.UnexpectedException.__module__ == 'doctest'"
  category: exception_modules
  kind: python_call_eq
  function: UnexpectedException.__module__.__eq__
  args: ["doctest"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class hierarchy — both inherit from Exception
# ---------------------------------------------------------------------------

invariant doctest_extra3.hierarchy.DocTestFailure_base:
  description: "doctest.DocTestFailure.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: DocTestFailure.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

invariant doctest_extra3.hierarchy.UnexpectedException_base:
  description: "doctest.UnexpectedException.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: UnexpectedException.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# Option flag values — IGNORE_EXCEPTION_DETAIL and FAIL_FAST
# doctest_extra2 covers ELLIPSIS==8, NORMALIZE_WHITESPACE==2, SKIP==16.
# We add IGNORE_EXCEPTION_DETAIL==32 and FAIL_FAST==64.
# ---------------------------------------------------------------------------

invariant doctest_extra3.constants.IGNORE_EXCEPTION_DETAIL_value:
  description: "doctest.IGNORE_EXCEPTION_DETAIL == 32 in Python 3.12 (bit 5)"
  category: constants
  kind: python_call_eq
  function: IGNORE_EXCEPTION_DETAIL.__eq__
  args: [32]
  expected: true

invariant doctest_extra3.constants.FAIL_FAST_value:
  description: "doctest.FAIL_FAST == 64 in Python 3.12 (bit 6)"
  category: constants
  kind: python_call_eq
  function: FAIL_FAST.__eq__
  args: [64]
  expected: true

# ---------------------------------------------------------------------------
# Table of class names: DocTest, DocTestFinder, DocTestRunner, DocTestParser
# doctest_extra covers these as standalone invariants; this table format is new
# and groups all four together as a table for compact coverage.
# The table uses a per-row function column to keep each check self-contained.
# ---------------------------------------------------------------------------

table doctest_extra3.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [DocTest,       DocTest.__name__.__eq__,       ["DocTest"],       true]
    - [DocTestFinder, DocTestFinder.__name__.__eq__,  ["DocTestFinder"], true]
    - [DocTestRunner, DocTestRunner.__name__.__eq__,  ["DocTestRunner"], true]
    - [DocTestParser, DocTestParser.__name__.__eq__,  ["DocTestParser"], true]

# ---------------------------------------------------------------------------
# Table of option flags — ELLIPSIS, NORMALIZE_WHITESPACE, IGNORE_EXCEPTION_DETAIL
# checking that each is an int (via __class__.__name__ == 'int').
# doctest_extra has standalone invariants for each; this table is a new grouped form.
# ---------------------------------------------------------------------------

table doctest_extra3.flag_types:
  kind: python_call_eq
  category: flag_types
  id_prefix: flagtype

  columns: [id, function, args, expected]
  rows:
    - [ELLIPSIS,                ELLIPSIS.__class__.__name__.__eq__,                ["int"], true]
    - [NORMALIZE_WHITESPACE,    NORMALIZE_WHITESPACE.__class__.__name__.__eq__,    ["int"], true]
    - [IGNORE_EXCEPTION_DETAIL, IGNORE_EXCEPTION_DETAIL.__class__.__name__.__eq__, ["int"], true]
