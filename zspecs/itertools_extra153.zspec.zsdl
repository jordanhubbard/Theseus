spec: itertools_extra153
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools C-type __bases__[0].__name__ == 'object' for chain, product, combinations, permutations, islice, starmap, zip_longest; all these types inherit directly from object so __mro__.__len__() == 2 for each (Wave 282)."
    - "itertools.chain.__bases__[0].__name__ == 'object' — chain is a C extension type that inherits directly from object; __bases__ is (object,) so __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "itertools.product.__bases__[0].__name__ == 'object' — product is a C extension type inheriting directly from object. Verified with Python 3.14.3."
    - "itertools.combinations.__bases__[0].__name__ == 'object' — combinations is a C extension type inheriting directly from object. Verified with Python 3.14.3."
    - "itertools.permutations.__bases__[0].__name__ == 'object' — permutations is a C extension type inheriting directly from object. Verified with Python 3.14.3."
    - "itertools.islice.__bases__[0].__name__ == 'object' — islice is a C extension type inheriting directly from object. Verified with Python 3.14.3."
    - "itertools.starmap.__bases__[0].__name__ == 'object' — starmap is a C extension type inheriting directly from object. Verified with Python 3.14.3."
    - "itertools.zip_longest.__bases__[0].__name__ == 'object' — zip_longest is a C extension type inheriting directly from object. Verified with Python 3.14.3."
    - "All __mro__.__len__() == 2 for all seven types — MRO is always [type, object] for C types inheriting directly from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools C-type __bases__[0].__name__ — chain, product, combinations
#
# Wave 282 theme: itertools C types all inherit directly from object.
#
# itertools.chain.__bases__[0].__name__ == 'object'
# itertools.product.__bases__[0].__name__ == 'object'
# itertools.combinations.__bases__[0].__name__ == 'object'
#
# All C extension types in itertoolsmodule.c have a single base class: object.
# This means __bases__ == (object,) and __mro__ == [type, object] (len 2).
# New to extra153.
# ---------------------------------------------------------------------------

table itertools_extra153.chain_product_combinations_bases:
  description: "itertools chain/product/combinations: __bases__[0].__name__ 'object', MRO len 2; all C types inherit directly from object; wave 282; new to extra153"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscpcbases153

  columns: [id, function, args, expected, description]
  rows:
    - ["chain_bases_0_name_eq_object",
       "chain.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.chain.__bases__[0].__name__.__eq__('object') == True — chain is a C extension type defined in Modules/itertoolsmodule.c; it inherits directly from object; __bases__ is (object,) so __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra153"]
    - [chain_mro_len_eq_2,
       "chain.__mro__.__len__",
       [],
       2,
       "itertools.chain.__mro__.__len__() == 2 — chain's MRO is [chain, object]; len 2 confirms single-level inheritance from object; new to extra153"]
    - ["product_bases_0_name_eq_object",
       "product.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.product.__bases__[0].__name__.__eq__('object') == True — product is a C extension type computing Cartesian products; it inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra153"]
    - [product_mro_len_eq_2,
       "product.__mro__.__len__",
       [],
       2,
       "itertools.product.__mro__.__len__() == 2 — product's MRO is [product, object]; len 2 confirms single-level inheritance from object; new to extra153"]
    - ["combinations_bases_0_name_eq_object",
       "combinations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations.__bases__[0].__name__.__eq__('object') == True — combinations is a C extension type yielding r-length subsequences without repetition; it inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra153"]
    - [combinations_mro_len_eq_2,
       "combinations.__mro__.__len__",
       [],
       2,
       "itertools.combinations.__mro__.__len__() == 2 — combinations' MRO is [combinations, object]; len 2 confirms single-level inheritance from object; new to extra153"]

# ---------------------------------------------------------------------------
# Table 2: itertools C-type __bases__[0].__name__ — permutations, islice, starmap
#
# Wave 282 theme: itertools C types all inherit directly from object (continued).
#
# itertools.permutations.__bases__[0].__name__ == 'object'
# itertools.islice.__bases__[0].__name__ == 'object'
# itertools.starmap.__bases__[0].__name__ == 'object'
#
# The pattern holds uniformly for all C types in itertoolsmodule.c.
# New to extra153.
# ---------------------------------------------------------------------------

