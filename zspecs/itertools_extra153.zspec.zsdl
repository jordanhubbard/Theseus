  columns: [id, function, args, expected, description]
  rows:
    - ["permutations_bases_0_name_eq_object",
       "permutations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.permutations.__bases__[0].__name__.__eq__('object') == True — permutations is a C extension type yielding r-length permutations; it inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra153"]
    - [permutations_mro_len_eq_2,
       "permutations.__mro__.__len__",
       [],
       2,
       "itertools.permutations.__mro__.__len__() == 2 — permutations' MRO is [permutations, object]; len 2 confirms single-level inheritance; new to extra153"]
    - ["islice_bases_0_name_eq_object",
       "islice.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.islice.__bases__[0].__name__.__eq__('object') == True — islice is a C extension type for slicing iterators; it inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra153"]
    - [islice_mro_len_eq_2,
       "islice.__mro__.__len__",
       [],
       2,
       "itertools.islice.__mro__.__len__() == 2 — islice's MRO is [islice, object]; len 2 confirms single-level inheritance; new to extra153"]
    - ["starmap_bases_0_name_eq_object",
       "starmap.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.starmap.__bases__[0].__name__.__eq__('object') == True — starmap is a C extension type applying a function using arguments from an iterable of tuples; it inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra153"]
    - [starmap_mro_len_eq_2,
       "starmap.__mro__.__len__",
