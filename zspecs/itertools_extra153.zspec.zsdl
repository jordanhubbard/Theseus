       2,
       "itertools.starmap.__mro__.__len__() == 2 — starmap's MRO is [starmap, object]; len 2 confirms single-level inheritance; new to extra153"]

# ---------------------------------------------------------------------------
# Table 3: itertools.zip_longest — __bases__[0].__name__ and MRO length
#
# Wave 282 theme: zip_longest C type bases check.
#
# itertools.zip_longest.__bases__[0].__name__ == 'object'
# itertools.zip_longest.__mro__.__len__() == 2
# itertools.zip_longest.__name__.__eq__('zip_longest') == True
#
# zip_longest is a C extension type that aggregates elements from iterables,
# padding shorter ones with a fillvalue. New to extra153.
# ---------------------------------------------------------------------------

table itertools_extra153.zip_longest_identity:
  description: "itertools.zip_longest: __bases__[0].__name__ 'object', MRO len 2, __name__ 'zip_longest'; C type inheriting from object; wave 282; new to extra153"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolszlid153

  columns: [id, function, args, expected, description]
  rows:
    - ["zip_longest_bases_0_name_eq_object",
       "zip_longest.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.zip_longest.__bases__[0].__name__.__eq__('object') == True — zip_longest is a C extension type that aggregates iterables padding shorter ones with a fillvalue; it inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra153"]
    - [zip_longest_mro_len_eq_2,
       "zip_longest.__mro__.__len__",
       [],
       2,
       "itertools.zip_longest.__mro__.__len__() == 2 — zip_longest's MRO is [zip_longest, object]; len 2 confirms single-level inheritance from object; new to extra153"]
    - [zip_longest_name_eq,
       "zip_longest.__name__.__eq__",
       ["zip_longest"],
       true,
       "itertools.zip_longest.__name__.__eq__('zip_longest') == True — zip_longest is the C extension type for aggregating iterables with fill values; its __name__ is 'zip_longest'; str.__eq__('zip_longest') returns True; new to extra153"]
    - [starmap_name_eq,
       "starmap.__name__.__eq__",
       ["starmap"],
       true,
       "itertools.starmap.__name__.__eq__('starmap') == True — starmap is the C extension type applying a function using arguments from a tuple iterable (like map(*args)); its __name__ is 'starmap'; str.__eq__('starmap') returns True; new to extra153"]

