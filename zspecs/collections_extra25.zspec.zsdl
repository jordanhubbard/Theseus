spec: collections_extra25
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections_extra24.zspec.zsdl."
    - "collections_extra24 covers: __qualname__.__eq__ for eight collections classes; __mro__.__len__() for deque/OrderedDict/Counter/defaultdict/ChainMap/UserList."
    - "collections_extra23 covers: __bases__[0].__name__.__eq__ for seven classes; __module__.__eq__ anchors for OrderedDict/UserDict/UserList/ChainMap/Counter/UserString."
    - "collections_extra22 covers: __name__.__eq__ for all eight collections classes; defaultdict(int) missing key; UserDict/UserList length invariants."
    - "No prior collections spec records __qualname__.__len__() for OrderedDict/defaultdict/Counter/deque/ChainMap/namedtuple/UserDict/UserList/UserString together in the extra25 namespace."
    - "Focus: string length of __qualname__ for nine core collections classes. Since qualname == name for all module-level classes, len(qualname) == len(name)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — nine collections classes
#
# Verifies the string length of each class's __qualname__. All collections
# classes are defined at module level so qualname == name. This records the
# character count of each qualname string as a regression anchor.
# No prior collections spec records all nine qualname lengths together in one
# table in the extra25 namespace.
# ---------------------------------------------------------------------------

table collections_extra25.qualname_lengths:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra25.qualname_lengths.OrderedDict,
       OrderedDict.__qualname__.__len__,
       [],
       11,
       "len(collections.OrderedDict.__qualname__) == 11 — 'OrderedDict'"]
    - [collections_extra25.qualname_lengths.defaultdict,
       defaultdict.__qualname__.__len__,
       [],
       11,
       "len(collections.defaultdict.__qualname__) == 11 — 'defaultdict'"]
    - [collections_extra25.qualname_lengths.Counter,
       Counter.__qualname__.__len__,
       [],
       7,
       "len(collections.Counter.__qualname__) == 7 — 'Counter'"]
    - [collections_extra25.qualname_lengths.deque,
       deque.__qualname__.__len__,
       [],
       5,
       "len(collections.deque.__qualname__) == 5 — 'deque'"]
    - [collections_extra25.qualname_lengths.ChainMap,
       ChainMap.__qualname__.__len__,
       [],
       8,
       "len(collections.ChainMap.__qualname__) == 8 — 'ChainMap'"]
    - [collections_extra25.qualname_lengths.namedtuple,
       namedtuple.__qualname__.__len__,
       [],
       10,
       "len(collections.namedtuple.__qualname__) == 10 — 'namedtuple'"]
    - [collections_extra25.qualname_lengths.UserDict,
       UserDict.__qualname__.__len__,
       [],
       8,
       "len(collections.UserDict.__qualname__) == 8 — 'UserDict'"]
    - [collections_extra25.qualname_lengths.UserList,
       UserList.__qualname__.__len__,
       [],
       8,
       "len(collections.UserList.__qualname__) == 8 — 'UserList'"]
    - [collections_extra25.qualname_lengths.UserString,
       UserString.__qualname__.__len__,
       [],
       10,
       "len(collections.UserString.__qualname__) == 10 — 'UserString'"]

# ---------------------------------------------------------------------------
# OrderedDict.__qualname__.__len__() == 11 — standalone qualname length
#
# The qualname string 'OrderedDict' has 11 characters.
# No prior collections spec records this invariant in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra25.OrderedDict.qualname.len:
  description: "len(collections.OrderedDict.__qualname__) == 11 — len('OrderedDict') == 11"
  category: qualnames
  kind: python_call_eq
  function: OrderedDict.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# Counter.__qualname__.__len__() == 7 — standalone qualname length
#
# The qualname string 'Counter' has 7 characters.
# No prior collections spec records this invariant in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra25.Counter.qualname.len:
  description: "len(collections.Counter.__qualname__) == 7 — len('Counter') == 7"
  category: qualnames
  kind: python_call_eq
  function: Counter.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# namedtuple.__qualname__.__len__() == 10 — standalone qualname length
#
# The qualname string 'namedtuple' has 10 characters.
# No prior collections spec records this invariant in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra25.namedtuple.qualname.len:
  description: "len(collections.namedtuple.__qualname__) == 10 — len('namedtuple') == 10"
  category: qualnames
  kind: python_call_eq
  function: namedtuple.__qualname__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# deque.__qualname__.__len__() == 5 — standalone qualname length
#
# The qualname string 'deque' has 5 characters.
# No prior collections spec records this invariant in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra25.deque.qualname.len:
  description: "len(collections.deque.__qualname__) == 5 — len('deque') == 5"
  category: qualnames
  kind: python_call_eq
  function: deque.__qualname__.__len__
  args: []
  expected: 5
