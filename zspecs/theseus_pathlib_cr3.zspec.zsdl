spec: theseus_pathlib_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_pathlib_cr3)
blocks: pathlib

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html"
  notes:
    - "Clean-room extended path utilities. Do NOT import pathlib, os, or os.path."
    - "PurePosixPath: pure (no I/O) POSIX path object."
    - "PurePosixPath.stem: filename without extension."
    - "PurePosixPath.suffix: file extension including dot."
    - "PurePosixPath.parents: ancestor paths."
    - "pathlib3_stem(): PurePosixPath('dir/file.txt').stem == 'file'."
    - "pathlib3_suffix(): PurePosixPath('dir/file.txt').suffix == '.txt'."
    - "pathlib3_parent(): PurePosixPath('/a/b/c').parent == PurePosixPath('/a/b')."
    - "Export: PurePosixPath class."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_pathlib_cr3.stem:
  description: "PurePosixPath('dir/file.txt').stem == 'file'"
  category: stem
  kind: python_call_eq
  function: pathlib3_stem
  args: []
  expected: "file"

invariant theseus_pathlib_cr3.suffix:
  description: "PurePosixPath('dir/file.txt').suffix == '.txt'"
  category: suffix
  kind: python_call_eq
  function: pathlib3_suffix
  args: []
  expected: ".txt"

invariant theseus_pathlib_cr3.parent_str:
  description: "str(PurePosixPath('/a/b/c').parent) == '/a/b'"
  category: parent
  kind: python_call_eq
  function: pathlib3_parent
  args: []
  expected: "/a/b"
