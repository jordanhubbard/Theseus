spec: socket_extra205
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "socket.create_connection.__defaults__ is a tuple of length 2 — create_connection(address, timeout=_GLOBAL_DEFAULT_TIMEOUT, source_address=None); first default is a sentinel object, second is None. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.create_connection.__defaults__[0].__class__.__name__ == 'object' — the sentinel default for timeout is an instance of the base object class. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.getfqdn.__defaults__ is a tuple of length 1 — getfqdn(name=''); first default is the empty string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.create_server.__defaults__ is None — create_server(address, *, family=AF_INET, backlog=None, reuse_port=False, dualstack_ipv6=False) has only keyword-only defaults (in __kwdefaults__); __defaults__ is None. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.getaddrinfo.__defaults__ is a tuple of length 4 — getaddrinfo(host, port, family=0, type=0, proto=0, flags=0); four optional positional defaults all 0. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.create_connection __defaults__ — tuple with sentinel and None
#
# create_connection(address, timeout=_GLOBAL_DEFAULT_TIMEOUT, source_address=None)
# __defaults__ is a tuple of length 2.
# defaults[0] is the sentinel object instance (class: 'object').
# defaults[1] is None (class: 'NoneType').
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra205.create_connection_defaults:
  description: "socket.create_connection.__defaults__.__class__.__name__ and __len__() — create_connection has two defaults (timeout sentinel, source_address=None); defaults is a tuple of length 2; first element is an object sentinel"
  kind: python_call_eq
  category: function_defaults
  id_prefix: socketdefaults205

  columns: [id, function, args, expected, description]
  rows:
    - [cc_defaults_classname,   create_connection.__defaults__.__class__.__name__.__eq__,   ["tuple"],   true,  "socket.create_connection.__defaults__.__class__.__name__ == 'tuple' — defaults is a tuple"]
    - [cc_defaults_len,         create_connection.__defaults__.__len__,                     [],          2,     "socket.create_connection.__defaults__.__len__() == 2 — two default values"]
    - [cc_defaults_0_classname, "create_connection.__defaults__[0].__class__.__name__.__eq__", ["object"], true, "socket.create_connection.__defaults__[0].__class__.__name__ == 'object' — timeout sentinel is an object instance"]
    - [cc_defaults_1_classname, "create_connection.__defaults__[1].__class__.__name__.__eq__", ["NoneType"], true, "socket.create_connection.__defaults__[1].__class__.__name__ == 'NoneType' — source_address default is None"]

# ---------------------------------------------------------------------------
# socket.getfqdn and socket.create_server __defaults__
#
# getfqdn(name='') — __defaults__ is ('',), a tuple of length 1.
# create_server has only keyword-only defaults — __defaults__ is None.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra205.getfqdn_and_create_server_defaults:
  description: "socket.getfqdn.__defaults__.__class__.__name__ and __len__(); socket.create_server.__defaults__.__class__.__name__ — getfqdn has one positional default (empty string); create_server has only keyword-only defaults so __defaults__ is None"
  kind: python_call_eq
  category: function_defaults
  id_prefix: socketdefaults205

  columns: [id, function, args, expected, description]
  rows:
    - [getfqdn_defaults_classname,  getfqdn.__defaults__.__class__.__name__.__eq__,   ["tuple"],    true,  "socket.getfqdn.__defaults__.__class__.__name__ == 'tuple' — defaults is a tuple"]
    - [getfqdn_defaults_len,        getfqdn.__defaults__.__len__,                     [],           1,     "socket.getfqdn.__defaults__.__len__() == 1 — one default value (name='')"]
    - [cs_defaults_classname,       create_server.__defaults__.__class__.__name__.__eq__, ["NoneType"], true, "socket.create_server.__defaults__.__class__.__name__ == 'NoneType' — create_server has no positional defaults"]
    - [getaddrinfo_defaults_len,    getaddrinfo.__defaults__.__len__,                 [],           4,     "socket.getaddrinfo.__defaults__.__len__() == 4 — four positional defaults (family, type, proto, flags)"]

# ---------------------------------------------------------------------------
# socket.getaddrinfo and socket.fromfd __defaults__
#
# getaddrinfo(host, port, family=0, type=0, proto=0, flags=0)
#   __defaults__ == (0, 0, 0, 0) — tuple of length 4.
# fromfd(fd, family, type, proto=0) — __defaults__ == (0,) — tuple of length 1.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra205.getaddrinfo_and_fromfd_defaults:
  description: "socket.getaddrinfo.__defaults__ and socket.fromfd.__defaults__ — getaddrinfo has four int defaults all zero; fromfd has one int default zero"
  kind: python_call_eq
  category: function_defaults
  id_prefix: socketdefaults205

  columns: [id, function, args, expected, description]
  rows:
    - [getaddrinfo_defaults_classname,  getaddrinfo.__defaults__.__class__.__name__.__eq__,  ["tuple"],  true,  "socket.getaddrinfo.__defaults__.__class__.__name__ == 'tuple' — defaults is a tuple"]
    - [getaddrinfo_defaults_len2,       getaddrinfo.__defaults__.__len__,                    [],         4,     "socket.getaddrinfo.__defaults__.__len__() == 4 — four defaults (family, type, proto, flags all 0)"]
    - [fromfd_defaults_classname,       fromfd.__defaults__.__class__.__name__.__eq__,       ["tuple"],  true,  "socket.fromfd.__defaults__.__class__.__name__ == 'tuple' — defaults is a tuple"]
    - [fromfd_defaults_len,             fromfd.__defaults__.__len__,                         [],         1,     "socket.fromfd.__defaults__.__len__() == 1 — one default value (proto=0)"]

