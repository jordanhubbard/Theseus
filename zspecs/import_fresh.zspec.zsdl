spec: import_fresh
version: ">=4.0.0"
backend: node(import-fresh)

docs: https://github.com/sindresorhus/import-fresh#readme

provenance:
  derived_from:
    - "import-fresh README — https://github.com/sindresorhus/import-fresh#readme"
    - "Test vectors verified with import-fresh via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "import-fresh source"
  notes:
    - "Import a module bypassing the require cache — used by tools that need to reload config files."
    - "Install: npm install import-fresh"
    - "v4 ESM only; default export is the import function (named 'createImportFresh' internally)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws MODULE_NOT_FOUND on missing modules."
  stderr: "null"
  stickiness: "Bypasses require cache by design."
  codes: {}

invariant import_fresh.default_is_function:
  description: "Default export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "Function"

invariant import_fresh.default_arity:
  description: "Function takes (moduleId) — function.length 1"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 1

invariant import_fresh.default_name:
  description: "Internal function name is 'createImportFresh'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.name"}
  expected: "createImportFresh"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:16:02Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
