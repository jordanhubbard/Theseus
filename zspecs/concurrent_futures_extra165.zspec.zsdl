spec: concurrent_futures_extra165
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.as_completed function name and module identity; concurrent.futures.wait function name and module identity; concurrent.futures.FIRST_COMPLETED string constant identity; concurrent.futures.FIRST_EXCEPTION string constant identity; concurrent.futures.ALL_COMPLETED string constant identity. All three string constants are plain str values defined in Lib/concurrent/futures/_base.py; their __module__ is '_base' (via the module); as_completed and wait are also defined in _base. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.as_completed.__name__=='as_completed' (len=12: 'as'=2+'_'=1+'completed'=9=12); __module__=='concurrent.futures._base' (len=24; same module as Future and Executor from extra163; '_base'=5 submodule); concurrent.futures.wait.__name__=='wait' (len=4: 'w'+'a'+'i'+'t'=4; wait is the shortest function name in the module); wait.__module__=='concurrent.futures._base' (len=24; same as as_completed). Verified with Python 3.14.3."
    - "concurrent.futures.FIRST_COMPLETED is a str constant: FIRST_COMPLETED.__eq__('FIRST_COMPLETED')==True (len=15: 'FIRST'=5+'_'=1+'COMPLETED'=9=15); FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION')==True (len=15: 'FIRST'=5+'_'=1+'EXCEPTION'=9=15; same length as FIRST_COMPLETED=15); ALL_COMPLETED.__eq__('ALL_COMPLETED')==True (len=13: 'ALL'=3+'_'=1+'COMPLETED'=9=13; 2 shorter than FIRST_COMPLETED=15 because 'ALL'=3 < 'FIRST'=5 by 2). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.as_completed function identity — extra165
#
# concurrent.futures.as_completed.__name__.__eq__('as_completed')              == True
# concurrent.futures.as_completed.__name__.__len__()                           == 12
# concurrent.futures.as_completed.__module__.__eq__('concurrent.futures._base') == True
# concurrent.futures.as_completed.__module__.__len__()                         == 24
# ---------------------------------------------------------------------------

table concurrent_futures_extra165.cf_as_completed_identity:
  description: "concurrent.futures.as_completed function name and module identity checks in cfasc165 namespace — concurrent.futures.as_completed.__name__.__eq__('as_completed')==True (as_completed.__name__=='as_completed' (len=12: 'as'=2+'_'=1+'completed'=9=12); concurrent.futures.as_completed(fs, timeout=None) is a generator that yields Futures as they complete (in order of completion rather than submission order); it takes an iterable of Futures (typically from submit() calls on an Executor) and yields each one as it finishes; cancelled or timed-out futures are also yielded; as_completed is the go-to function for processing results as soon as they are available in any order); concurrent.futures.as_completed.__name__.__len__()==12 ('as_completed'=12: 'as'=2+'_completed'=10: '_'=1+'completed'=9=10; 2+10=12); concurrent.futures.as_completed.__module__.__eq__('concurrent.futures._base')==True (__module__=='concurrent.futures._base' (len=24: same module as Future and Executor from extra163)); concurrent.futures.as_completed.__module__.__len__()==24 ('concurrent.futures._base'=24; same length as Future and Executor module=24); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfasc165

  columns: [id, function, args, expected, description]
  rows:
    - [asc_name_eq,  concurrent.futures.as_completed.__name__.__eq__,    ["as_completed"],              true,  "as_completed.__name__ == 'as_completed' (len=12: 'as'=2+'_completed'=10=12); verified with Python 3.14.3"]
    - [asc_name_len, concurrent.futures.as_completed.__name__.__len__,   [],                            12,    "as_completed.__name__.__len__() == 12 ('as_completed'=12; 8 longer than wait=4); verified with Python 3.14.3"]
    - [asc_mod_eq,   concurrent.futures.as_completed.__module__.__eq__,  ["concurrent.futures._base"],  true,  "as_completed.__module__ == 'concurrent.futures._base' (len=24; same as Future/Executor module); verified with Python 3.14.3"]
    - [asc_mod_len,  concurrent.futures.as_completed.__module__.__len__, [],                            24,    "as_completed.__module__.__len__() == 24 ('concurrent.futures._base'=24); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.wait function identity — extra165
#
# concurrent.futures.wait.__name__.__eq__('wait')                            == True
# concurrent.futures.wait.__name__.__len__()                                 == 4
# concurrent.futures.wait.__module__.__eq__('concurrent.futures._base')      == True
# concurrent.futures.wait.__module__.__len__()                               == 24
# ---------------------------------------------------------------------------

table concurrent_futures_extra165.cf_wait_identity:
  description: "concurrent.futures.wait function name and module identity checks in cfwait165 namespace — concurrent.futures.wait.__name__.__eq__('wait')==True (wait.__name__=='wait' (len=4: 'w'+'a'+'i'+'t'=4); concurrent.futures.wait(fs, timeout=None, return_when=ALL_COMPLETED) blocks until futures complete according to return_when: FIRST_COMPLETED yields as soon as any future finishes; FIRST_EXCEPTION yields as soon as any future raises; ALL_COMPLETED (default) yields when all are done; wait returns a named tuple (done, not_done) where done and not_done are sets of Futures; unlike as_completed which is a generator, wait collects results in one blocking call); concurrent.futures.wait.__name__.__len__()==4 ('wait'=4; the shortest function name in the concurrent.futures module; same length as asyncio.Task.__name__='Task'=4 from extra166); concurrent.futures.wait.__module__.__eq__('concurrent.futures._base')==True (__module__=='concurrent.futures._base' (len=24; same module as as_completed)); concurrent.futures.wait.__module__.__len__()==24; wait name len(4) < as_completed name len(12) by 8 chars; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfwait165

  columns: [id, function, args, expected, description]
  rows:
    - [wait_name_eq,  concurrent.futures.wait.__name__.__eq__,    ["wait"],                      true,  "wait.__name__ == 'wait' (len=4: 'wait'=4; shortest cf function name; same len as Task=4); verified with Python 3.14.3"]
    - [wait_name_len, concurrent.futures.wait.__name__.__len__,   [],                            4,     "wait.__name__.__len__() == 4 ('wait'=4; 8 shorter than as_completed=12); verified with Python 3.14.3"]
    - [wait_mod_eq,   concurrent.futures.wait.__module__.__eq__,  ["concurrent.futures._base"],  true,  "wait.__module__ == 'concurrent.futures._base' (len=24; same module as as_completed); verified with Python 3.14.3"]
    - [wait_mod_len,  concurrent.futures.wait.__module__.__len__, [],                            24,    "wait.__module__.__len__() == 24 ('concurrent.futures._base'=24; same as as_completed=24); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.FIRST_COMPLETED and FIRST_EXCEPTION constants — extra165
#
# concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED') == True
# concurrent.futures.FIRST_COMPLETED.__len__()                 == 15
# concurrent.futures.FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION') == True
# concurrent.futures.FIRST_EXCEPTION.__len__()                 == 15
# ---------------------------------------------------------------------------

table concurrent_futures_extra165.cf_first_constants_identity:
  description: "concurrent.futures.FIRST_COMPLETED and FIRST_EXCEPTION string constant identity checks in cffirstconst165 namespace — concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED')==True (FIRST_COMPLETED is a str constant defined as 'FIRST_COMPLETED' in Lib/concurrent/futures/_base.py; it is passed as the return_when argument to concurrent.futures.wait() to indicate that the call should return as soon as any future completes — either by finishing normally, raising an exception, or being cancelled; FIRST_COMPLETED len=15: 'FIRST'=5+'_'=1+'COMPLETED'=9=15); concurrent.futures.FIRST_COMPLETED.__len__()==15 ('FIRST_COMPLETED'=15; same length as FIRST_EXCEPTION=15: 'FIRST'=5+'_'=1+'EXCEPTION'=9=15; both constants share the same 5-char 'FIRST' prefix and 9-char suffix giving the same total length 15); concurrent.futures.FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION')==True (FIRST_EXCEPTION is the return_when value for wait() that causes it to return when any future finishes with an exception or when all futures finish without exception; compare FIRST_COMPLETED which returns on ANY completion vs FIRST_EXCEPTION which waits for an exception-raising completion); concurrent.futures.FIRST_EXCEPTION.__len__()==15 ('FIRST_EXCEPTION'=15; same len as FIRST_COMPLETED=15: 'EXCEPTION'=9=='COMPLETED'=9 in length); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffirstconst165

  columns: [id, function, args, expected, description]
  rows:
    - [fc_eq,   concurrent.futures.FIRST_COMPLETED.__eq__,  ["FIRST_COMPLETED"],  true,  "FIRST_COMPLETED == 'FIRST_COMPLETED' (len=15: 'FIRST'=5+'_COMPLETED'=10=15); verified with Python 3.14.3"]
    - [fc_len,  concurrent.futures.FIRST_COMPLETED.__len__, [],                   15,    "FIRST_COMPLETED.__len__() == 15 ('FIRST_COMPLETED'=15; same as FIRST_EXCEPTION=15); verified with Python 3.14.3"]
    - [fe_eq,   concurrent.futures.FIRST_EXCEPTION.__eq__,  ["FIRST_EXCEPTION"],  true,  "FIRST_EXCEPTION == 'FIRST_EXCEPTION' (len=15: 'FIRST'=5+'_EXCEPTION'=10=15); verified with Python 3.14.3"]
    - [fe_len,  concurrent.futures.FIRST_EXCEPTION.__len__, [],                   15,    "FIRST_EXCEPTION.__len__() == 15 (same as FIRST_COMPLETED=15; 'EXCEPTION'=9=='COMPLETED'=9); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.ALL_COMPLETED constant and cross-comparison — extra165
#
# concurrent.futures.ALL_COMPLETED.__eq__('ALL_COMPLETED') == True
# concurrent.futures.ALL_COMPLETED.__len__()               == 13
# FIRST_COMPLETED.__len__() == 15  vs  ALL_COMPLETED.__len__() == 13
# wait.__name__.__len__() == 4  vs  as_completed.__name__.__len__() == 12
# ---------------------------------------------------------------------------

table concurrent_futures_extra165.cf_all_completed_and_cross_comparison:
  description: "concurrent.futures.ALL_COMPLETED string constant identity and cross-comparison in cfallconst165 namespace — concurrent.futures.ALL_COMPLETED.__eq__('ALL_COMPLETED')==True (ALL_COMPLETED is a str constant defined as 'ALL_COMPLETED' in Lib/concurrent/futures/_base.py; it is the DEFAULT return_when value for concurrent.futures.wait() — wait blocks until ALL futures in the iterable have completed; compare: FIRST_COMPLETED returns as soon as one future completes; ALL_COMPLETED waits for every future to finish; ALL_COMPLETED len=13: 'ALL'=3+'_'=1+'COMPLETED'=9=13); concurrent.futures.ALL_COMPLETED.__len__()==13 ('ALL_COMPLETED'=13; 2 shorter than FIRST_COMPLETED=15 because 'ALL'=3 < 'FIRST'=5 by 2; 2 shorter than FIRST_EXCEPTION=15 for the same reason); FIRST_COMPLETED.__len__()==15 (cross-check; FIRST_COMPLETED=15 > ALL_COMPLETED=13 by 2); wait.__name__.__len__()==4 (cross-check; wait=4 is the shortest function name); as_completed.__name__.__len__()==12 (cross-check; as_completed=12 is the longest function name in this spec; 12 > wait=4 by 8; 12 < ALL_COMPLETED=13 by 1); KEY LENGTH ORDERING: wait(4) < as_completed(12) < ALL_COMPLETED(13) < FIRST_COMPLETED=FIRST_EXCEPTION(15); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfallconst165

  columns: [id, function, args, expected, description]
  rows:
    - [ac_eq,    concurrent.futures.ALL_COMPLETED.__eq__,   ["ALL_COMPLETED"],   true,  "ALL_COMPLETED == 'ALL_COMPLETED' (len=13: 'ALL'=3+'_COMPLETED'=10=13; default return_when); verified with Python 3.14.3"]
    - [ac_len,   concurrent.futures.ALL_COMPLETED.__len__,  [],                  13,    "ALL_COMPLETED.__len__() == 13 (2 shorter than FIRST_COMPLETED=15; 'ALL'=3 < 'FIRST'=5 by 2); verified with Python 3.14.3"]
    - [fc_len2,  concurrent.futures.FIRST_COMPLETED.__len__, [],                 15,    "FIRST_COMPLETED.__len__() == 15 (cross-check; 2 longer than ALL_COMPLETED=13); verified with Python 3.14.3"]
    - [wait_len2, concurrent.futures.wait.__name__.__len__, [],                  4,     "wait.__name__.__len__() == 4 (cross-check; shortest function name; 8 shorter than as_completed=12); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra165
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra165.cf_as_completed_name_eq:
  description: "concurrent.futures.as_completed.__name__.__eq__('as_completed') returns True — concurrent.futures.as_completed.__name__=='as_completed' (len=12: 'as'=2+'_'=1+'completed'=9=12); concurrent.futures.as_completed(fs, timeout=None) is a generator function that iterates over the given futures in the order they COMPLETE rather than the order they were submitted; this is the key distinction from simply iterating over the futures list: as_completed yields whatever finishes first regardless of submission order; the generator yields each future exactly once when it completes (done, cancelled, or raises); if timeout is given and exceeded, as_completed raises TimeoutError (the unconsumed futures are abandoned, not cancelled); as_completed.__module__=='concurrent.futures._base' (len=24; same module as Future and Executor — all three defined in _base.py); compare: concurrent.futures.wait.__name__=='wait' (len=4; 8 shorter than as_completed=12); NEW in extra165: first standalone as_completed.__name__ identity invariant in cfasc165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.as_completed.__name__.__eq__
  args: ["as_completed"]
  expected: true

invariant concurrent_futures_extra165.cf_as_completed_module_eq:
  description: "concurrent.futures.as_completed.__module__.__eq__('concurrent.futures._base') returns True — concurrent.futures.as_completed.__module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24); as_completed is defined in Lib/concurrent/futures/_base.py alongside Future and Executor (established in extra163); the _base module is the foundational module for the entire concurrent.futures framework — it defines: Future, Executor, PENDING/RUNNING/CANCELLED/FINISHED states, as_completed, wait, FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED, and exception types; as_completed.__module__.__len__()==24 == wait.__module__.__len__()==24 == Future.__module__.__len__()==24 — all four are in _base (len=24); compare: ThreadPoolExecutor.__module__.__len__()==25 (thread, len=25 > _base=24 by 1); ProcessPoolExecutor.__module__.__len__()==26 (process, len=26 > _base=24 by 2); NEW in extra165: first standalone as_completed.__module__ identity invariant in cfasc165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.as_completed.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra165.cf_wait_name_eq:
  description: "concurrent.futures.wait.__name__.__eq__('wait') returns True — concurrent.futures.wait.__name__=='wait' (len=4: 'w'+'a'+'i'+'t'=4); concurrent.futures.wait(fs, timeout=None, return_when=ALL_COMPLETED) is the blocking version of future collection: it waits for futures to complete and returns a named tuple (done, not_done) containing sets of futures; unlike as_completed (a generator), wait returns all at once after the specified condition is met; the return_when parameter controls when wait returns: FIRST_COMPLETED (as soon as any finishes), FIRST_EXCEPTION (as soon as any raises), ALL_COMPLETED (when every future is done — the default); wait.__name__.__len__()==4 is the shortest function name in concurrent.futures; compare: asyncio.Task.__name__.__len__()==4 (from extra166: 'Task'=4; same length as 'wait'=4 — both are 4-char identifiers in their respective async libraries); compare: as_completed.__name__.__len__()==12 (8 longer than wait=4); NEW in extra165: first standalone wait.__name__ identity invariant in cfwait165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant concurrent_futures_extra165.cf_FIRST_COMPLETED_eq:
  description: "concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED') returns True — concurrent.futures.FIRST_COMPLETED is a str constant with value 'FIRST_COMPLETED' (len=15: 'FIRST'=5+'_'=1+'COMPLETED'=9=15); FIRST_COMPLETED is passed as the return_when argument to concurrent.futures.wait() to signal that wait should return as soon as the FIRST future in the set completes — regardless of whether it completed normally, raised an exception, or was cancelled; this is distinct from FIRST_EXCEPTION (which waits for an exception-raising future specifically) and ALL_COMPLETED (which waits for ALL futures); as a plain str constant, FIRST_COMPLETED supports all str methods: len(), eq(), startswith(), etc.; FIRST_COMPLETED.__len__()==15 == FIRST_EXCEPTION.__len__()==15 (both share the same 15-char length because both start with 'FIRST'=5 and end with a 9-char word: 'COMPLETED'=9 and 'EXCEPTION'=9 both have length 9); NEW in extra165: first standalone FIRST_COMPLETED.__eq__ invariant in cffirstconst165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.FIRST_COMPLETED.__eq__
  args: ["FIRST_COMPLETED"]
  expected: true

invariant concurrent_futures_extra165.cf_FIRST_EXCEPTION_eq:
  description: "concurrent.futures.FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION') returns True — concurrent.futures.FIRST_EXCEPTION is a str constant with value 'FIRST_EXCEPTION' (len=15: 'FIRST'=5+'_'=1+'EXCEPTION'=9=15); FIRST_EXCEPTION is the return_when value for concurrent.futures.wait() that causes it to return when any future raises an exception; if no future raises an exception and all complete normally, wait returns as if ALL_COMPLETED were specified; the distinction between FIRST_COMPLETED and FIRST_EXCEPTION: FIRST_COMPLETED returns on any completion (success, failure, or cancel) while FIRST_EXCEPTION specifically waits for an exception-raising future; FIRST_EXCEPTION.__len__()==15 == FIRST_COMPLETED.__len__()==15 (both are 15 chars; 'EXCEPTION'=9 has the same length as 'COMPLETED'=9 — key: both are 9-char words); compare: ALL_COMPLETED.__len__()==13 (2 shorter than FIRST_EXCEPTION=15 because 'ALL'=3 < 'FIRST'=5 by 2); NEW in extra165: first standalone FIRST_EXCEPTION.__eq__ invariant in cffirstconst165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.FIRST_EXCEPTION.__eq__
  args: ["FIRST_EXCEPTION"]
  expected: true

invariant concurrent_futures_extra165.cf_ALL_COMPLETED_eq:
  description: "concurrent.futures.ALL_COMPLETED.__eq__('ALL_COMPLETED') returns True — concurrent.futures.ALL_COMPLETED is a str constant with value 'ALL_COMPLETED' (len=13: 'ALL'=3+'_'=1+'COMPLETED'=9=13); ALL_COMPLETED is the DEFAULT return_when argument for concurrent.futures.wait() — when omitted, wait blocks until every future in the input set has finished; ALL_COMPLETED is the most common use case: submit all work, then wait for everything to finish before proceeding; ALL_COMPLETED.__len__()==13 is 2 shorter than FIRST_COMPLETED=15 and FIRST_EXCEPTION=15 because 'ALL'=3 < 'FIRST'=5 by 2; the 'COMPLETED'=9 suffix appears in both ALL_COMPLETED(13) and FIRST_COMPLETED(15) — the suffix is shared but the prefix differs: 'ALL'=3 vs 'FIRST'=5; KEY LENGTH ORDERING among the three wait constants: ALL_COMPLETED(13) < FIRST_COMPLETED(15) == FIRST_EXCEPTION(15); NEW in extra165: first standalone ALL_COMPLETED.__eq__ invariant in cfallconst165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ALL_COMPLETED.__eq__
  args: ["ALL_COMPLETED"]
  expected: true

invariant concurrent_futures_extra165.cf_wait_module_eq:
  description: "concurrent.futures.wait.__module__.__eq__('concurrent.futures._base') returns True — concurrent.futures.wait.__module__=='concurrent.futures._base' (len=24); wait is defined in the same _base.py file as as_completed, Future, Executor, and the wait-condition constants (FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED); wait, as_completed, and the three constants are co-located in _base.py because they are tightly coupled: wait uses the constants as its return_when argument; wait.__module__ == as_completed.__module__ == concurrent.futures.Future.__module__ == concurrent.futures.Executor.__module__ == 'concurrent.futures._base' — all four are in the same module; wait.__module__.__len__()==24 == as_completed.__module__.__len__()==24 (both functions in _base have the same 24-char module path); compare: the two concrete executor modules are longer: thread(25) and process(26) — both longer than _base(24); NEW in extra165: first standalone wait.__module__ identity invariant in cfwait165 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.wait.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true
