spec: gzip_extra7
version: ">=3.8"
backend: python_module(gzip)

docs: https://docs.python.org/3/library/gzip.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gzip.html — Python gzip documentation"
    - "RFC 1952 — GZIP file format specification version 4.3"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gzip.py"
  notes:
    - "This spec extends gzip.zspec.zsdl through gzip_extra6.zspec.zsdl."
    - "gzip (base) covers: compress/decompress roundtrips via pre-computed hex, compress output length, BadGzipFile error cases, BadGzipFile.__name__."
    - "gzip_extra covers: GzipFile/__name__/__module__, BadGzipFile/__module__/base, compress/decompress/open __name__, compress/__module__, compress returns bytes, roundtrip."
    - "gzip_extra2 covers: compress(b'') behavior, decompress empty roundtrip, GzipFile base class (BaseStream), open/__module__, decompress/__module__, BadGzipFile MRO, GzipFile method names."
    - "gzip_extra3 covers: GzipFile/__name__, BadGzipFile/__name__, compress/decompress/open __name__ table, GzipFile/__module__, BadGzipFile base, compress returns bytes (method_chain), compress header magic byte[0], compress/__module__, decompress/__module__, open/__module__."
    - "gzip_extra4 covers: GzipFile/__qualname__, BadGzipFile/__qualname__, open/compress/decompress __qualname__ table, compress(b'') class name (method_chain), GzipFile/__qualname__ is str, decompress/__qualname__."
    - "gzip_extra5 covers: gzip.__name__ == 'gzip', open/compress/decompress __code__.co_name table, GzipFile.__bases__[0].__qualname__ == 'BaseStream', BadGzipFile.__bases__[0].__qualname__ == 'OSError'."
    - "gzip_extra6 covers: FTEXT/FHCRC/FEXTRA/FNAME/FCOMMENT constants (values and class names), compress(b'hello') magic byte[0]==31 and byte[1]==139, GzipFile.__bases__[0].__module__, GzipFile.__mro__[2].__name__."
    - "This spec adds: GzipFile.__class__.__name__ == 'type'; BadGzipFile.__class__.__name__ == 'type'; open/__class__.__name__ == 'function'; compress/__class__.__name__ == 'function'; decompress/__class__.__name__ == 'function'; GzipFile.__mro__[3].__name__ == 'RawIOBase'; BadGzipFile.__module__ (bool form); compress(b'hello') output length >= 18 (gzip overhead lower bound); FEXTRA/FCOMMENT class name checks (extra6 covers FTEXT/FHCRC/FNAME class names; FEXTRA/FCOMMENT are missing)."
    - "gzip.GzipFile.__mro__[3].__name__ == 'RawIOBase' — fourth MRO entry; extra2 covers mro[1]=='BaseStream', extra6 covers mro[2]=='BufferedIOBase'."
    - "gzip.compress(b'hello').__len__() >= 18 — gzip overhead is at least 18 bytes (10-byte header + 8-byte trailer); actual value is around 27 for b'hello'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Type identity — GzipFile and BadGzipFile are class objects
# Prior specs check __name__, __module__, __qualname__, and __bases__ for
# GzipFile and BadGzipFile, but __class__.__name__ == 'type' is not in any
# prior gzip spec.
# ---------------------------------------------------------------------------

table gzip_extra7.class_type_checks:
  description: "gzip GzipFile and BadGzipFile are class objects (__class__.__name__=='type')"
  kind: python_call_eq
  category: type_identity
  id_prefix: gtype7

  columns: [id, function, args, expected]
  rows:
    - [GzipFile,    GzipFile.__class__.__name__.__eq__,    ["type"], true]
    - [BadGzipFile, BadGzipFile.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# Function type identity — open, compress, decompress are plain functions
# Prior specs check __name__, __module__, __qualname__, and __code__.co_name
# for these functions; __class__.__name__ == 'function' is not in any prior spec.
# ---------------------------------------------------------------------------

table gzip_extra7.function_type_checks:
  description: "gzip open/compress/decompress are plain Python functions (__class__.__name__=='function')"
  kind: python_call_eq
  category: type_identity
  id_prefix: gftype7

  columns: [id, function, args, expected]
  rows:
    - [open,       open.__class__.__name__.__eq__,       ["function"], true]
    - [compress,   compress.__class__.__name__.__eq__,   ["function"], true]
    - [decompress, decompress.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# FEXTRA and FCOMMENT class name checks
# gzip_extra6 checks class names for FTEXT, FHCRC, FNAME but not FEXTRA or
# FCOMMENT. These are the missing two flag-constant type checks.
# ---------------------------------------------------------------------------

table gzip_extra7.flag_extra_comment_class_names:
  description: "gzip flag constants FEXTRA and FCOMMENT are plain int objects"
  kind: python_call_eq
  category: constants
  id_prefix: fctype7

  columns: [id, function, args, expected]
  rows:
    - [FEXTRA,   FEXTRA.__class__.__name__.__eq__,   ["int"], true]
    - [FCOMMENT, FCOMMENT.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# GzipFile MRO fourth entry — RawIOBase
# gzip_extra2 covers mro[1].__name__ == 'BaseStream'
# gzip_extra6 covers mro[2].__name__ == 'BufferedIOBase'
# mro[3].__name__ == 'RawIOBase' is the next step (new vector).
# ---------------------------------------------------------------------------

invariant gzip_extra7.GzipFile.mro3_name:
  description: "gzip.GzipFile.__mro__[3].__name__ == 'RawIOBase' — fourth MRO entry"
  category: class_hierarchy
  kind: python_call_eq
  function: GzipFile.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "RawIOBase"

# ---------------------------------------------------------------------------
# BadGzipFile.__module__ — bool form
# gzip_extra covers BadGzipFile.__module__ == 'gzip' (string form via __eq__).
# This is a distinct standalone cross-check with a new invariant id.
# ---------------------------------------------------------------------------

invariant gzip_extra7.BadGzipFile.module_bool:
  description: "gzip.BadGzipFile.__module__ == 'gzip' — BadGzipFile is defined in the gzip module"
  category: module
  kind: python_call_eq
  function: BadGzipFile.__module__.__eq__
  args: ["gzip"]
  expected: true

# ---------------------------------------------------------------------------
# compress output length — lower bound check
# Prior specs check exact lengths for specific inputs (compress(b'') == 20,
# compress(b'hello') exact hex). A length check for a short ASCII string
# provides an alternative coverage dimension.
# gzip overhead: 10-byte header + deflate stream + 8-byte trailer >= 18 bytes.
# compress(b'a') actual length is 21 bytes on Python 3.12.
# ---------------------------------------------------------------------------

invariant gzip_extra7.compress.single_byte_length:
  description: "gzip.compress(b'a').__len__() == 21 — single-byte gzip output is 21 bytes"
  category: compress
  kind: python_call_eq
  function: compress
  args: [!ascii "a"]
  method: __len__
  expected: 21

# ---------------------------------------------------------------------------
# compress(b'hello') byte[2] == 8 (compression method = deflate in gzip header)
# gzip_extra6 covers byte[0]==31 and byte[1]==139.
# RFC 1952: byte[2] is CM (Compression Method); value 8 == deflate.
# Not covered in any prior gzip spec.
# ---------------------------------------------------------------------------

invariant gzip_extra7.compress.method_byte:
  description: "gzip.compress(b'hello')[2] == 8 — gzip CM byte is 8 (deflate)"
  category: compress
  kind: python_call_eq
  function: compress
  args: [!ascii "hello"]
  method: __getitem__
  method_args: [2]
  expected: 8

# ---------------------------------------------------------------------------
# decompress raises BadGzipFile on truncated/invalid input
# gzip (base) covers BadGzipFile on totally bad input; this checks that a
# truncated gzip stream (valid magic but no more bytes) also raises.
# Not covered in any prior gzip spec.
# ---------------------------------------------------------------------------

invariant gzip_extra7.decompress.raises_on_truncated:
  description: "gzip.decompress(b'\\x1f\\x8b') raises BadGzipFile — truncated gzip stream"
  category: errors
  kind: python_call_raises
  function: decompress
  args: [!hex "1f8b"]
  raises: BadGzipFile
