spec: sniffio_rust
version: ">=3.9"
backend: rust_module(sniffio_rust)

docs: https://github.com/python-trio/sniffio

provenance:
  derived_from:
    - "https://github.com/python-trio/sniffio — sniffio"
  notes:
    - "sniffio detects which async library is running."
    - "sniffio.current_async_library is callable."
    - "sniffio.AsyncLibraryNotFoundError is an exception class."
    - "sniffio.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant sniffio_rust.has_current_async_library:
  description: "sniffio.current_async_library is callable"
  category: presence
  kind: python_call_eq
  function: sniffio_has_current_async_library
  args: []
  expected: true

invariant sniffio_rust.has_error_class:
  description: "sniffio.AsyncLibraryNotFoundError is a class"
  category: presence
  kind: python_call_eq
  function: sniffio_has_error_class
  args: []
  expected: true

invariant sniffio_rust.version_nonempty:
  description: "sniffio.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: sniffio_version_nonempty
  args: []
  expected: true

