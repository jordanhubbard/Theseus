table concurrent_futures_extra204.cf_code_attr_types:
  description: "concurrent.futures function __code__ attribute type name checks in cfcoflags204 namespace — wait.__code__.co_flags.__class__.__name__=='int' (co_flags is always an integer bitmask; wait.co_flags==67108867 with CO_OPTIMIZED|CO_NEWLOCALS); as_completed.__code__.co_flags.__class__.__name__=='int' (as_completed.co_flags==67108899; includes CO_GENERATOR bit because as_completed uses yield); ThreadPoolExecutor.__init__.__code__.co_stacksize.__class__.__name__=='int' (co_stacksize is always int; __init__.co_stacksize==5); all __code__ numeric attributes are plain Python int regardless of which function they describe; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attr_types
  id_prefix: cfcoflags204

  columns: [id, function, args, expected, description]
