invariant concurrent_futures_extra204.wait_coflags_type_int:
  description: "concurrent.futures.wait.__code__.co_flags.__class__.__name__.__eq__('int') returns True — concurrent.futures.wait is a regular (non-async, non-generator) function defined in Lib/concurrent/futures/_base.py; co_flags is always an integer bitmask; wait.co_flags==67108867 with CO_OPTIMIZED|CO_NEWLOCALS; co_flags.__class__ is the built-in int type; co_flags.__class__.__name__ is 'int' (len=3: i-n-t); NEW in extra204: first standalone cf.wait co_flags type invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attr_types
  kind: python_call_eq
  function: concurrent.futures.wait.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant concurrent_futures_extra204.as_completed_coflags_type_int:
  description: "concurrent.futures.as_completed.__code__.co_flags.__class__.__name__.__eq__('int') returns True — concurrent.futures.as_completed is a generator function (uses yield) defined in Lib/concurrent/futures/_base.py; as_completed.co_flags==67108899 includes CO_GENERATOR (0x20=32) which distinguishes it from wait (67108867); co_flags.__class__.__name__ is 'int' regardless of whether CO_GENERATOR is set; NEW in extra204; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attr_types
  kind: python_call_eq
  function: concurrent.futures.as_completed.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant concurrent_futures_extra204.tpe_init_costacksize_type_int:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_stacksize.__class__.__name__.__eq__('int') returns True — ThreadPoolExecutor.__init__ is a regular method defined in Lib/concurrent/futures/thread.py; co_stacksize is always an integer representing the required stack depth; __init__.co_stacksize==5; co_stacksize.__class__.__name__ is 'int' (len=3); __init__.co_flags==201326603; NEW in extra204; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attr_types
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant concurrent_futures_extra204.wait_coflags_value:
  description: "concurrent.futures.wait.__code__.co_flags.__eq__(67108867) returns True — wait.co_flags is 67108867; this is the same value as abc.abstractmethod.co_flags and abc.update_abstractmethods.co_flags (all regular non-generator functions share this base flag pattern); wait.co_stacksize==8; wait is defined in _base.py; wait.co_flags (67108867) < as_completed.co_flags (67108899) because as_completed has the additional CO_GENERATOR bit (32); NEW in extra204; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_flag_values
  kind: python_call_eq
  function: concurrent.futures.wait.__code__.co_flags.__eq__
  args: [67108867]
  expected: true

invariant concurrent_futures_extra204.as_completed_coflags_value:
  description: "concurrent.futures.as_completed.__code__.co_flags.__eq__(67108899) returns True — as_completed.co_flags is 67108899; the difference from wait (67108867) is 32 which is CO_GENERATOR (0x20); as_completed uses yield to return futures as they complete, making it a generator function; as_completed.co_stacksize==10 (larger than wait.co_stacksize==8 due to generator overhead); both functions are defined in _base.py; NEW in extra204; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_flag_values
  kind: python_call_eq
  function: concurrent.futures.as_completed.__code__.co_flags.__eq__
  args: [67108899]
  expected: true

invariant concurrent_futures_extra204.tpe_init_coflags_value:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_flags.__eq__(201326603) returns True — ThreadPoolExecutor.__init__.co_flags is 201326603; this is substantially larger than wait (67108867) and as_completed (67108899) because it includes additional interpreter optimization flags applied to class methods; ThreadPoolExecutor.__init__ is defined in thread.py (not _base.py); __init__.co_stacksize==5; NEW in extra204; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_flag_values
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_flags.__eq__
  args: [201326603]
  expected: true

invariant concurrent_futures_extra204.tpe_init_costacksize_value:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_stacksize.__eq__(5) returns True — ThreadPoolExecutor.__init__.co_stacksize is 5; this is smaller than wait.co_stacksize (8) and as_completed.co_stacksize (10) because __init__ primarily sets instance attributes with less deep expression evaluation; co_stacksize represents the maximum Python value stack depth needed; __init__.co_flags==201326603; __init__.co_filename points to thread.py; NEW in extra204; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_flag_values
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_stacksize.__eq__
  args: [5]
  expected: true

invariant concurrent_futures_extra204.wait_cofilename_type_str:
  description: "concurrent.futures.wait.__code__.co_filename.__class__.__name__.__eq__('str') returns True — co_filename is the source file path string; concurrent.futures.wait is defined in Lib/concurrent/futures/_base.py; co_filename.__class__.__name__ is 'str' (len=3: s-t-r); concurrent.futures functions are not frozen modules so their co_filename is a real filesystem path (unlike abc functions whose co_filename is '<frozen abc>'); NEW in extra204; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attr_types
  kind: python_call_eq
  function: concurrent.futures.wait.__code__.co_filename.__class__.__name__.__eq__
  args: ["str"]
  expected: true

