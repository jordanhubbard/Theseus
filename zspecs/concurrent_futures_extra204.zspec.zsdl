    - [wait_costacksize_val,       concurrent.futures.wait.__code__.co_stacksize.__eq__,                   [8],         true, "concurrent.futures.wait.__code__.co_stacksize == 8; verified Python 3.14.3"]
    - [as_completed_costacksize_val, concurrent.futures.as_completed.__code__.co_stacksize.__eq__,         [10],        true, "concurrent.futures.as_completed.__code__.co_stacksize == 10 (generator, more complex); verified Python 3.14.3"]
    - [tpe_init_costacksize_val,  concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_stacksize.__eq__, [5],     true, "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_stacksize == 5; verified Python 3.14.3"]

