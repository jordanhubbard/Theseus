spec: concurrent_futures_extra204
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py, Lib/concurrent/futures/thread.py"
  notes:
    - "concurrent.futures.wait.__code__.co_flags == 67108867 — wait is a regular (non-async) function defined in _base.py; CO_OPTIMIZED|CO_NEWLOCALS bits set; co_flags.__class__.__name__ == 'int'."
    - "concurrent.futures.as_completed.__code__.co_flags == 67108899 — as_completed is a generator function (CO_GENERATOR bit set); flags include CO_OPTIMIZED, CO_NEWLOCALS, CO_GENERATOR (0x20=32); co_flags.__class__.__name__ == 'int'."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_stacksize == 5 — __init__ requires a stack depth of 5 slots; co_stacksize.__class__.__name__ == 'int'."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_flags == 201326603 — __init__ is a regular method; high value due to interpreter-specific optimization flags."
    - "concurrent.futures.wait co_stacksize == 8; as_completed co_stacksize == 10 — as_completed has larger stack depth because it is a generator with more complex iteration logic."
    - "concurrent.futures.wait and as_completed are both defined in _base.py; ThreadPoolExecutor.__init__ is in thread.py."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

