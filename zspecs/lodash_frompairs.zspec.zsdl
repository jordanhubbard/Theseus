spec: lodash_frompairs
version: ">=4.0.0"
backend: node(lodash.frompairs)

docs: https://lodash.com/docs/#fromPairs

provenance:
  derived_from:
    - "lodash.frompairs README — https://www.npmjs.com/package/lodash.frompairs"
    - "Test vectors verified with lodash.frompairs@4.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.frompairs exports the _.fromPairs function directly as module.exports."
    - "fromPairs(pairs) creates an object from an array of [key, value] pairs."
    - "Inverse of toPairs."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns object from key-value pairs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_frompairs.frompairs:
  kind: node_module_call_eq
  function: ~
  category: frompairs
  id_prefix: lfp

  columns: [id, args, expected]
  rows:
    - [basic,  [[["a", 1], ["b", 2]]],   {"a": 1, "b": 2}]
    - [one,    [[["x", 42]]],             {"x": 42}]
    - [empty,  [[]],                       {}]
