spec: hashlib_extra1801
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python hashlib documentation — https://docs.python.org/3/library/hashlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "hashlib.zspec.zsdl — covers known vectors and hash object attrs"
    - "hashlib_extra.zspec.zsdl — covers BLAKE2/SHA3 attrs, algorithms_guaranteed, pbkdf2_hmac"
    - "hashlib_extra2.zspec.zsdl — covers hexdigest vectors, new() API"
    - "hashlib_extra1786.zspec.zsdl — covers __class_getitem__/__init_subclass__ hooks; HASH dict presence (hexdigest, name, digest_size, block_size, copy, update, digest)"
    - "hashlib_extra1771.zspec.zsdl — covers async protocol dict-presence checks for hashlib._hashlib.HASH"
  notes:
    - "Wave 567 (_extra1801): __bool__/__len__ truth-value protocol; container and context manager protocol presence."
    - "Theme: which hashlib types define __bool__/__len__ and context-manager/container protocol methods in their own __dict__."
    - "hashlib.__dict__.__contains__('sha256') -> True — sha256 is a module-level constructor in hashlib's dict."
    - "hashlib.__dict__.__contains__('algorithms_guaranteed') -> True — public frozenset attribute."
    - "hashlib.__dict__.__contains__('__bool__') -> False — modules do not define __bool__ in their own __dict__."
    - "hashlib.__dict__.__contains__('__len__') -> False — modules do not define __len__ in their own __dict__."
    - "hashlib.__dict__.__contains__('__contains__') -> False — hashlib is not a container; no __contains__ in module dict."
    - "hashlib.__dict__.__contains__('__iter__') -> False — hashlib is not iterable; no __iter__ in module dict."
    - "hashlib.sha256.__class__.__dict__.__contains__('__enter__') -> False — hashlib.sha256 is a builtin_function_or_method; its class dict does not define context manager protocol."
    - "hashlib.sha256.__class__.__dict__.__contains__('__exit__') -> False — same rationale."
    - "All expected values verified by running Python 3.14 hashlib module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra1801.module_attrs:
  description: "hashlib module __dict__ presence checks for public constructors and attributes — wave 567 _extra1801"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1801

  columns: [id, function, args, expected]
  rows:
    - ["hl1801001", "hashlib.__dict__.__contains__", ["sha256"],               true]
    - ["hl1801002", "hashlib.__dict__.__contains__", ["sha512"],               true]
    - ["hl1801003", "hashlib.__dict__.__contains__", ["sha1"],                 true]
    - ["hl1801004", "hashlib.__dict__.__contains__", ["md5"],                  true]
    - ["hl1801005", "hashlib.__dict__.__contains__", ["sha224"],               true]
    - ["hl1801006", "hashlib.__dict__.__contains__", ["sha384"],               true]
    - ["hl1801007", "hashlib.__dict__.__contains__", ["new"],                  true]
    - ["hl1801008", "hashlib.__dict__.__contains__", ["algorithms_available"], true]
    - ["hl1801009", "hashlib.__dict__.__contains__", ["algorithms_guaranteed"],true]
    - ["hl1801010", "hashlib.__dict__.__contains__", ["pbkdf2_hmac"],          true]

table hashlib_extra1801.sha3_attrs:
  description: "hashlib module __dict__ presence checks for SHA3 and BLAKE2 constructors — wave 567 _extra1801"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1801

  columns: [id, function, args, expected]
  rows:
    - ["hl1801011", "hashlib.__dict__.__contains__", ["sha3_256"],   true]
    - ["hl1801012", "hashlib.__dict__.__contains__", ["sha3_512"],   true]
    - ["hl1801013", "hashlib.__dict__.__contains__", ["sha3_224"],   true]
    - ["hl1801014", "hashlib.__dict__.__contains__", ["sha3_384"],   true]
    - ["hl1801015", "hashlib.__dict__.__contains__", ["blake2b"],    true]
    - ["hl1801016", "hashlib.__dict__.__contains__", ["blake2s"],    true]
    - ["hl1801017", "hashlib.__dict__.__contains__", ["shake_128"],  true]
    - ["hl1801018", "hashlib.__dict__.__contains__", ["shake_256"],  true]
    - ["hl1801019", "hashlib.__dict__.__contains__", ["scrypt"],     true]
    - ["hl1801020", "hashlib.__dict__.__contains__", ["openssl_md5"],false]

table hashlib_extra1801.context_manager_protocol:
  description: "hashlib module and sha256 builtin class __bool__/__len__/context-manager/container protocol absence — wave 567 _extra1801"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1801

  columns: [id, function, args, expected]
  rows:
    - ["hl1801021", "hashlib.sha256.__class__.__dict__.__contains__", ["__enter__"],   false]
    - ["hl1801022", "hashlib.sha256.__class__.__dict__.__contains__", ["__exit__"],    false]
    - ["hl1801023", "hashlib.__dict__.__contains__",                  ["__bool__"],    false]
    - ["hl1801024", "hashlib.__dict__.__contains__",                  ["__contains__"],false]
    - ["hl1801025", "hashlib.__dict__.__contains__",                  ["__iter__"],    false]
    - ["hl1801026", "hashlib.__dict__.__contains__",                  ["__len__"],     false]
