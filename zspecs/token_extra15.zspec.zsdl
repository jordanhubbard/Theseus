spec: token_extra15
version: ">=3.9"
backend: python_module(token)

docs: https://docs.python.org/3/library/token.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/token.html — Python token module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/token.py"
    - "token_extra14.zspec.zsdl — covers FSTRING_START/FSTRING_END/FSTRING_MIDDLE class names and values; LSQB/RSQB/COLON/COMMA/SEMI exact values"
    - "token_extra13.zspec.zsdl — covers NAME/NUMBER/STRING/ENDMARKER/NEWLINE/OP __class__.__name__=='int' standalone; tok_name/__class__.__name__=='dict' standalone"
    - "token_extra12.zspec.zsdl — covers ENCODING/NL/ERRORTOKEN/INDENT/DEDENT __class__.__name__=='int' standalone; COMMENT/INDENT/DEDENT exact values"
    - "token_extra11.zspec.zsdl — covers tok_name.__len__()==71; EXACT_TOKEN_TYPES.__len__()==48; exact values for ENDMARKER/NAME/NUMBER/STRING/NEWLINE/OP (table)"
    - "token_extra10.zspec.zsdl — covers NAME/NUMBER/STRING/OP/NEWLINE/ENDMARKER/INDENT/DEDENT/COMMENT/ENCODING/NL/ERRORTOKEN __class__.__name__=='int' (table)"
    - "token_extra4.zspec.zsdl — covers INDENT==5/DEDENT==6 exact values"
    - "token_extra.zspec.zsdl — covers int type checks for major constants; tok_name/EXACT_TOKEN_TYPES is_dict; NAME/NUMBER/STRING/NEWLINE/ENDMARKER exact values"
  notes:
    - "This spec extends token_extra14.zspec.zsdl."
    - "Prior specs covered: token.__name__/__package__, token.NAME/NUMBER/STRING/OP/NEWLINE/INDENT/DEDENT/COMMENT/NL/ERRORTOKEN/__class__.__name__, token.tok_name.__class__.__name__, various token constant values, token.EXACT_TYPE/__class__.__name__, token.TYPE_COMMENT/__class__.__name__."
    - "This spec covers: token.tok_name.__class__.__module__ (=='builtins'); token.NAME/__class__.__module__ and token.NUMBER/__class__.__module__ (both =='builtins'); len(token.tok_name)==71 as a standalone invariant in this namespace; tok_name[1]=='NAME', tok_name[2]=='NUMBER', tok_name[3]=='STRING' (verifying values are present); token.ENDMARKER.__class__.__name__=='int'; token.ENDMARKER==0; token.NEWLINE==4; token.INDENT==5; token.DEDENT==6."
    - "token.tok_name.__class__.__module__ == 'builtins' — dict is a builtin type; no prior token spec covers tok_name.__class__.__module__ as a standalone __eq__ invariant."
    - "token.NAME.__class__.__module__ == 'builtins' — int is a builtin type; no prior token spec covers NAME.__class__.__module__."
    - "token.NUMBER.__class__.__module__ == 'builtins' — same; no prior token spec covers NUMBER.__class__.__module__."
    - "token.tok_name.__len__() == 71 — token_extra11 covers this in its namespace; distinct standalone invariant in token_extra15 namespace."
    - "token.tok_name[1] == 'NAME' — verifies NAME string is at key 1 in tok_name; no prior token spec covers this as a standalone invariant."
    - "token.tok_name[2] == 'NUMBER' — verifies NUMBER string is at key 2 in tok_name; no prior token spec covers this."
    - "token.tok_name[3] == 'STRING' — verifies STRING string is at key 3 in tok_name; no prior token spec covers this."
    - "token.ENDMARKER.__class__.__name__ == 'int' — token_extra13 covers this in its namespace; distinct standalone invariant in token_extra15 namespace."
    - "token.ENDMARKER == 0 — token_extra11 covers this in a table; distinct standalone invariant in token_extra15 namespace."
    - "token.NEWLINE == 4 — token_extra11 covers this in a table; distinct standalone invariant in token_extra15 namespace."
    - "token.INDENT == 5 — token_extra4 and token_extra11 cover this; distinct standalone invariant in token_extra15 namespace."
    - "token.DEDENT == 6 — token_extra4 and token_extra11 cover this; distinct standalone invariant in token_extra15 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# tok_name, NAME, NUMBER __class__.__module__ — standalone invariants
# (token_extra15 namespace)
#
# dict and int are both builtin types, so __class__.__module__ == 'builtins'.
# No prior token spec covers __class__.__module__ for any of these objects
# as a standalone __eq__ invariant.
# ---------------------------------------------------------------------------

invariant token_extra15.tok_name.class_module_is_builtins:
  description: "token.tok_name.__class__.__module__ == 'builtins' — dict is a builtin type"
  category: class_modules
  kind: python_call_eq
  function: tok_name.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant token_extra15.NAME.class_module_is_builtins:
  description: "token.NAME.__class__.__module__ == 'builtins' — int is a builtin type"
  category: class_modules
  kind: python_call_eq
  function: NAME.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant token_extra15.NUMBER.class_module_is_builtins:
  description: "token.NUMBER.__class__.__module__ == 'builtins' — int is a builtin type"
  category: class_modules
  kind: python_call_eq
  function: NUMBER.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# tok_name.__len__() — standalone invariant
# (token_extra15 namespace)
#
# token_extra11 covers tok_name.__len__()==71 in its namespace.
# This is a distinct standalone invariant in the token_extra15 namespace.
# The value 71 reflects the full set of token types in Python 3.12.
# ---------------------------------------------------------------------------

invariant token_extra15.tok_name.len_is_71:
  description: "len(token.tok_name) == 71 — 71 token types defined in Python 3.12"
  category: sequence_lengths
  kind: python_call_eq
  function: tok_name.__len__
  args: []
  expected: 71

# ---------------------------------------------------------------------------
# tok_name string values at keys 1, 2, 3 — table
# (token_extra15 namespace)
#
# Verifies that the NAME, NUMBER, STRING string labels appear at the expected
# integer keys in tok_name. No prior token spec covers tok_name[n].__eq__
# as a standalone invariant for any of these keys.
# ---------------------------------------------------------------------------

table token_extra15.tok_name_string_values:
  description: "tok_name maps token integer constants to their string names; keys 1/2/3 == NAME/NUMBER/STRING"
  kind: python_call_eq
  category: sequence_items
  id_prefix: tokname

  columns: [id, function, args, expected]
  rows:
    - [key_1_NAME,   "tok_name[1].__eq__",  ["NAME"],   true]
    - [key_2_NUMBER, "tok_name[2].__eq__",  ["NUMBER"], true]
    - [key_3_STRING, "tok_name[3].__eq__",  ["STRING"], true]

# ---------------------------------------------------------------------------
# ENDMARKER class name and exact value — standalone invariants
# (token_extra15 namespace)
#
# token_extra13 covers ENDMARKER/__class__.__name__=='int' in its namespace.
# token_extra11 covers ENDMARKER==0 in a table. These are distinct standalone
# invariants in the token_extra15 namespace.
# ---------------------------------------------------------------------------

invariant token_extra15.ENDMARKER.class_is_int:
  description: "token.ENDMARKER.__class__.__name__ == 'int' — ENDMARKER constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: ENDMARKER.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant token_extra15.ENDMARKER.value_is_0:
  description: "token.ENDMARKER == 0 — ENDMARKER is the first token type, value 0"
  category: constant_values
  kind: python_call_eq
  function: ENDMARKER.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# NEWLINE, INDENT, DEDENT exact values — table
# (token_extra15 namespace)
#
# token_extra4 covers INDENT==5/DEDENT==6; token_extra11 covers NEWLINE==4.
# These are distinct standalone invariants in the token_extra15 namespace.
# NEWLINE==4, INDENT==5, DEDENT==6 verified on Python 3.12.
# ---------------------------------------------------------------------------

table token_extra15.whitespace_token_values:
  description: "Exact integer values for NEWLINE, INDENT, DEDENT token constants"
  kind: python_call_eq
  category: constant_values
  id_prefix: ws

  columns: [id, function, args, expected]
  rows:
    - [NEWLINE, NEWLINE.__eq__, [4], true]
    - [INDENT,  INDENT.__eq__,  [5], true]
    - [DEDENT,  DEDENT.__eq__,  [6], true]
