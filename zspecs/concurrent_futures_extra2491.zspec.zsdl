spec: concurrent_futures_extra2491
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#future-objects — Future"
    - "https://docs.python.org/3/library/concurrent.futures.html#executor-objects — Executor"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Theme: __setitem__, __delitem__, and __missing__ dict-presence — checking whether concurrent.futures classes define mutable item access and missing-key protocol in their class __dict__."
    - "concurrent.futures.Future.__dict__.__contains__('__setitem__') == False — Future does not define __setitem__; verified Python 3.14.4."
    - "concurrent.futures.Future.__dict__.__contains__('__delitem__') == False — Future does not define __delitem__; verified Python 3.14.4."
    - "concurrent.futures.Future.__dict__.__contains__('__missing__') == False — Future does not define __missing__; verified Python 3.14.4."
    - "concurrent.futures.Executor.__dict__.__contains__('__setitem__') == False — Executor does not define __setitem__; verified Python 3.14.4."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__setitem__') == False — ThreadPoolExecutor does not define __setitem__; verified Python 3.14.4."
    - "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__setitem__') == False — ProcessPoolExecutor does not define __setitem__; verified Python 3.14.4."
    - "Accessing a missing key via __dict__.__getitem__ raises KeyError for all concurrent.futures classes; verified Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures class __dict__ __contains__ checks — __setitem__,
# __delitem__, __missing__ dict-presence theme
#
# None of the concurrent.futures classes define __setitem__, __delitem__, or
# __missing__ in their own class __dict__. These classes represent futures
# and executor pools and do not expose mutable item access or missing-key
# fallback.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2491.future_dict_mutable_item:
  description: "concurrent.futures.Future.__dict__.__contains__ checks for __setitem__, __delitem__, __missing__ — Future defines __init__, __repr__, cancel, result but NOT mutable item access methods; verified Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: cf2491

  columns: [id, function, args, expected]
  rows:
    - ["cf2491001", concurrent.futures.Future.__dict__.__contains__, ["__init__"],      true]
    - ["cf2491002", concurrent.futures.Future.__dict__.__contains__, ["__repr__"],      true]
    - ["cf2491003", concurrent.futures.Future.__dict__.__contains__, ["cancel"],        true]
    - ["cf2491004", concurrent.futures.Future.__dict__.__contains__, ["__setitem__"],   false]
    - ["cf2491005", concurrent.futures.Future.__dict__.__contains__, ["__delitem__"],   false]
    - ["cf2491006", concurrent.futures.Future.__dict__.__contains__, ["__missing__"],   false]

