spec: tarfile_extra6
version: ">=3.9"
backend: python_module(tarfile)

docs: https://docs.python.org/3/library/tarfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tarfile.html — Python tarfile documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tarfile.py"
  notes:
    - "This spec extends tarfile.zspec.zsdl and prior extras."
    - "tarfile (base) covers: USTAR/GNU/PAX/DEFAULT_FORMAT values, BLOCKSIZE, RECORDSIZE, ENCODING, type flag bytes, TarInfo construction, class __name__ for TarFile/TarInfo/TarError/ReadError, exception hierarchy, is_tarfile."
    - "tarfile_extra covers: class __name__ table for TarFile/TarInfo/TarError/ReadError/CompressionError, open/__name__, is_tarfile/__name__, TarError base, ENCODING class name."
    - "tarfile_extra2 covers: TarFile/__name__/__module__, TarInfo/__name__/__module__, CompressionError/__name__/base, ENCODING class, REGULAR_TYPES/SUPPORTED_TYPES class, open/__name__, TarFile/TarInfo is_type, REGULAR_TYPES/SUPPORTED_TYPES membership."
    - "tarfile_extra3 covers: class __name__ table for TarFile/TarInfo/TarError/ReadError/CompressionError/ExtractError/HeaderError, open/__name__, is_tarfile/__name__, TarFile __module__, TarError base, ReadError base, REGTYPE/DIRTYPE/SYMTYPE values, TarInfo instance class."
    - "tarfile_extra4 covers: __qualname__ for TarFile/TarInfo (table), exception __qualname__ table, is_tarfile/__qualname__, open/__qualname__, HeaderError/__qualname__, StreamError/__qualname__, GNU/PAX/USTAR format constant type as int."
    - "tarfile_extra5 covers: TarInfo.__module__, TarError.__module__, ReadError.__module__ (table), TarFile.__bases__[0].__name__ == 'object', TarInfo.__bases__[0].__name__ == 'object', tarfile.__name__ == 'tarfile'."
    - "This spec adds: GNU-extension type flag byte decoding (CONTTYPE, GNUTYPE_LONGNAME, GNUTYPE_LONGLINK, GNUTYPE_SPARSE — new; base only covers REGTYPE/LNKTYPE/SYMTYPE/CHRTYPE/BLKTYPE/DIRTYPE/FIFOTYPE), ExFileObject class metadata (__name__/__module__/__qualname__/__bases__[0].__name__ — not in any prior tarfile spec), and __module__ for the remaining exception classes (ExtractError/CompressionError/HeaderError/StreamError — complementary to tarfile_extra5 which covers TarError/ReadError), and base-class name checks for ExtractError/CompressionError/HeaderError/StreamError."
    - "tarfile.CONTTYPE == b'7' — contiguous file type flag (GNU/POSIX extension)."
    - "tarfile.GNUTYPE_LONGNAME == b'L' — GNU long name type flag."
    - "tarfile.GNUTYPE_LONGLINK == b'K' — GNU long link type flag."
    - "tarfile.GNUTYPE_SPARSE == b'S' — GNU sparse file type flag."
    - "tarfile.ExFileObject is the file-like object returned by TarFile.extractfile(); it wraps a tar member's data stream."
    - "tarfile.ExFileObject.__bases__[0].__name__ == 'BufferedReader' — ExFileObject inherits from io.BufferedReader."
    - "ExtractError/CompressionError/HeaderError/StreamError all have __bases__[0].__name__ == 'TarError'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# GNU extension type flag bytes — not covered in any prior tarfile spec.
# base spec covers REGTYPE/LNKTYPE/SYMTYPE/CHRTYPE/BLKTYPE/DIRTYPE/FIFOTYPE.
# CONTTYPE=b'7', GNUTYPE_LONGNAME=b'L', GNUTYPE_LONGLINK=b'K', GNUTYPE_SPARSE=b'S'.
# ---------------------------------------------------------------------------

table tarfile_extra6.gnu_type_flags:
  kind: python_call_eq
  category: type_flags
  id_prefix: gnuflag

  columns: [id, function, args, expected]
  rows:
    - [CONTTYPE,          CONTTYPE.decode,          ["ascii"], "7"]
    - [GNUTYPE_LONGNAME,  GNUTYPE_LONGNAME.decode,  ["ascii"], "L"]
    - [GNUTYPE_LONGLINK,  GNUTYPE_LONGLINK.decode,  ["ascii"], "K"]
    - [GNUTYPE_SPARSE,    GNUTYPE_SPARSE.decode,    ["ascii"], "S"]

# ---------------------------------------------------------------------------
# ExFileObject class metadata — not covered in any prior tarfile spec.
# ExFileObject is the file-like object returned by TarFile.extractfile().
# ---------------------------------------------------------------------------

invariant tarfile_extra6.ExFileObject.class_name:
  description: "tarfile.ExFileObject.__name__ == 'ExFileObject'"
  category: class_metadata
  kind: python_call_eq
  function: ExFileObject.__name__.__eq__
  args: ["ExFileObject"]
  expected: true

invariant tarfile_extra6.ExFileObject.module:
  description: "tarfile.ExFileObject.__module__ == 'tarfile'"
  category: module_affiliation
  kind: python_call_eq
  function: ExFileObject.__module__.__eq__
  args: ["tarfile"]
  expected: true

invariant tarfile_extra6.ExFileObject.qualname:
  description: "tarfile.ExFileObject.__qualname__ == 'ExFileObject'"
  category: qualnames
  kind: python_call_eq
  function: ExFileObject.__qualname__.__eq__
  args: ["ExFileObject"]
  expected: true

invariant tarfile_extra6.ExFileObject.base_name:
  description: "tarfile.ExFileObject.__bases__[0].__name__ == 'BufferedReader'"
  category: hierarchy
  kind: python_call_eq
  function: ExFileObject.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BufferedReader"

# ---------------------------------------------------------------------------
# __module__ for remaining exception classes not covered by tarfile_extra5.
# tarfile_extra5 covers TarError and ReadError; these four are new.
# ---------------------------------------------------------------------------

table tarfile_extra6.exception_modules:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: excmod6

  columns: [id, function, args, expected]
  rows:
    - [ExtractError,     ExtractError.__module__.__eq__,     ["tarfile"], true]
    - [CompressionError, CompressionError.__module__.__eq__, ["tarfile"], true]
    - [HeaderError,      HeaderError.__module__.__eq__,      ["tarfile"], true]
    - [StreamError,      StreamError.__module__.__eq__,      ["tarfile"], true]

# ---------------------------------------------------------------------------
# Exception base class checks: ExtractError/CompressionError/HeaderError/StreamError
# all inherit directly from TarError. Not covered in any prior tarfile spec for
# all four together.
# ---------------------------------------------------------------------------

invariant tarfile_extra6.ExtractError.base_name:
  description: "tarfile.ExtractError.__bases__[0].__name__ == 'TarError'"
  category: hierarchy
  kind: python_call_eq
  function: ExtractError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "TarError"

invariant tarfile_extra6.CompressionError.base_name:
  description: "tarfile.CompressionError.__bases__[0].__name__ == 'TarError'"
  category: hierarchy
  kind: python_call_eq
  function: CompressionError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "TarError"

invariant tarfile_extra6.HeaderError.base_name:
  description: "tarfile.HeaderError.__bases__[0].__name__ == 'TarError'"
  category: hierarchy
  kind: python_call_eq
  function: HeaderError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "TarError"

invariant tarfile_extra6.StreamError.base_name:
  description: "tarfile.StreamError.__bases__[0].__name__ == 'TarError'"
  category: hierarchy
  kind: python_call_eq
  function: StreamError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "TarError"
