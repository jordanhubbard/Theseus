spec: pickle_extra18
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl through pickle_extra17.zspec.zsdl."
    - "pickle_extra17 covers: Pickler.clear_memo/__qualname__; Pickler.dispatch_table/__qualname__; Unpickler.persistent_load/__qualname__."
    - "pickle_extra16 covers: Pickler.dump/__qualname__; Pickler.persistent_id/__qualname__; Unpickler.load/__qualname__; Unpickler.find_class/__qualname__."
    - "pickle_extra15 covers: Pickler/__qualname__.__class__.__name__; Unpickler/__qualname__.__class__.__name__."
    - "pickle_extra14 covers: Pickler/__qualname__; Unpickler/__qualname__; PickleBuffer/__qualname__; __bases__[0].__name__ for Pickler/Unpickler/PickleBuffer."
    - "pickle_extra12 covers: Pickler/__module__ == '_pickle'; Unpickler/__module__ == '_pickle'."
    - "pickle_extra10 covers: PickleError/__qualname__; PicklingError/__qualname__; UnpicklingError/__qualname__."
    - "Focus: __qualname__ for Pickler.__init__ and Unpickler.__init__; PickleBuffer.__qualname__.__class__.__name__ type axis."
    - "No prior pickle spec checks Pickler.__init__.__qualname__."
    - "No prior pickle spec checks Unpickler.__init__.__qualname__."
    - "No prior pickle spec checks PickleBuffer.__qualname__.__class__.__name__."
    - "pickle.Pickler.__init__.__qualname__ == 'Pickler.__init__' — C wrapper_descriptor; compound dunder qualname."
    - "pickle.Unpickler.__init__.__qualname__ == 'Unpickler.__init__' — C wrapper_descriptor; compound dunder qualname."
    - "pickle.PickleBuffer.__qualname__.__class__.__name__ == 'str' — qualname attribute is a string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pickler.__init__ and Unpickler.__init__ — __qualname__
#
# pickle_extra16 and pickle_extra17 check __qualname__ for Pickler.dump,
# Pickler.persistent_id, Unpickler.load, Unpickler.find_class,
# Pickler.clear_memo, Pickler.dispatch_table, and Unpickler.persistent_load.
# No prior pickle spec checks __qualname__ for __init__ on either class.
# These are C wrapper_descriptor objects whose __qualname__ uses the compound
# dotted form 'ClassName.__init__'.
# ---------------------------------------------------------------------------

invariant pickle_extra18.Pickler.__init__.qualname:
  description: "pickle.Pickler.__init__.__qualname__ == 'Pickler.__init__' — compound dunder method qualname"
  category: method_attrs
  kind: python_call_eq
  function: Pickler.__init__.__qualname__.__eq__
  args: ["Pickler.__init__"]
  expected: true

invariant pickle_extra18.Unpickler.__init__.qualname:
  description: "pickle.Unpickler.__init__.__qualname__ == 'Unpickler.__init__' — compound dunder method qualname"
  category: method_attrs
  kind: python_call_eq
  function: Unpickler.__init__.__qualname__.__eq__
  args: ["Unpickler.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# PickleBuffer.__qualname__.__class__.__name__ — type axis
#
# pickle_extra14 checks PickleBuffer.__qualname__ == 'PickleBuffer'.
# pickle_extra15 checks Pickler/__qualname__.__class__.__name__ == 'str' and
# Unpickler/__qualname__.__class__.__name__ == 'str'.
# No prior pickle spec checks PickleBuffer.__qualname__.__class__.__name__.
# The qualname string of PickleBuffer is itself a str, so the type name is 'str'.
# ---------------------------------------------------------------------------

invariant pickle_extra18.PickleBuffer.qualname.class_name:
  description: "pickle.PickleBuffer.__qualname__.__class__.__name__ == 'str' — qualname is a string"
  category: type_attrs
  kind: python_call_eq
  function: PickleBuffer.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table: Pickler/__init__, Unpickler/__init__, PickleBuffer qualname type
#
# All three invariants are first covered in this spec (pickle_extra18).
# ---------------------------------------------------------------------------

table pickle_extra18.init_qualnames_and_type:
  description: "pickle Pickler/Unpickler __init__ __qualname__ and PickleBuffer __qualname__ type"
  kind: python_call_eq
  category: method_attrs
  id_prefix: pmq18

  columns: [id, function, args, expected]
  rows:
    - [Pickler_init_qn,           Pickler.__init__.__qualname__.__eq__,              ["Pickler.__init__"],   true]
    - [Unpickler_init_qn,         Unpickler.__init__.__qualname__.__eq__,            ["Unpickler.__init__"], true]
    - [PickleBuffer_qn_class_name, PickleBuffer.__qualname__.__class__.__name__.__eq__, ["str"],             true]
