spec: doctest_extra5
version: ">=3.9"
backend: python_module(doctest)

docs: https://docs.python.org/3/library/doctest.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/doctest.html — Python doctest module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/doctest.py"
  notes:
    - "Extends doctest.zspec.zsdl through doctest_extra4.zspec.zsdl."
    - "doctest (base) covers: testmod/testfile/run_docstring_examples/register_optionflag/__name__, DocTest/DocTestFinder/DocTestRunner/DocTestParser/OutputChecker/Example/DocTestFailure/UnexpectedException/DebugRunner/TestResults.__name__, DocTest.__module__, ELLIPSIS/NORMALIZE_WHITESPACE/IGNORE_EXCEPTION_DETAIL/SKIP/FAIL_FAST is_int."
    - "doctest_extra covers: DocTest/DocTestFinder/DocTestRunner/DocTestSuite/DocTestCase/DocTestParser/Example __name__, testmod/testfile/run_docstring_examples __name__, ELLIPSIS/NORMALIZE_WHITESPACE/IGNORE_EXCEPTION_DETAIL/FAIL_FAST is_int."
    - "doctest_extra2 covers: DocTestFinder/DocTestRunner/DocTestParser __name__/__module__, testmod/testfile/run_docstring_examples __name__/__module__, ELLIPSIS==8, NORMALIZE_WHITESPACE==2, SKIP==16."
    - "doctest_extra3 covers: DocTestFailure/UnexpectedException __name__/__module__/__bases__[0]/__name__, IGNORE_EXCEPTION_DETAIL==32, FAIL_FAST==64, class_names table (DocTest/DocTestFinder/DocTestRunner/DocTestParser), flag_types table."
    - "doctest_extra4 covers: class_qualnames table (DocTest/DocTestFinder/DocTestRunner/DocTestSuite/DocTestParser/Example/DocTestFailure/UnexpectedException), function_qualnames table (testmod/testfile/run_docstring_examples), flag_class_names table (ELLIPSIS/NORMALIZE_WHITESPACE), DocTest.__module__."
    - "This spec adds: OutputChecker/__name__/__module__/__qualname__/__bases__[0]/__name__, DebugRunner/__name__/__module__/__qualname__/__bases__[0]/__name__, TestResults/__name__/__module__/__qualname__, DocTestCase/__name__/__module__/__qualname__/__bases__[0]/__name__/__bases__[0].__module__, register_optionflag/__name__/__module__/__qualname__, BLANKLINE_MARKER is str, ELLIPSIS_MARKER is str."
    - "doctest.OutputChecker inherits from object directly."
    - "doctest.DebugRunner inherits from DocTestRunner."
    - "doctest.TestResults is a namedtuple (its base is TestResults — namedtuple pattern)."
    - "doctest.DocTestCase.__bases__[0].__name__ == 'TestCase' from unittest.case."
    - "doctest.BLANKLINE_MARKER == '<BLANKLINE>' (str, length 11)."
    - "doctest.ELLIPSIS_MARKER == '...' (str, length 3)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# OutputChecker — name, module, qualname, and base class
# No prior doctest spec covers OutputChecker beyond its __name__ in the
# base spec. All attributes here are new.
# ---------------------------------------------------------------------------

invariant doctest_extra5.OutputChecker.name:
  description: "doctest.OutputChecker.__name__ == 'OutputChecker'"
  category: classes
  kind: python_call_eq
  function: OutputChecker.__name__.__eq__
  args: ["OutputChecker"]
  expected: true

invariant doctest_extra5.OutputChecker.module:
  description: "doctest.OutputChecker.__module__ == 'doctest'"
  category: classes
  kind: python_call_eq
  function: OutputChecker.__module__.__eq__
  args: ["doctest"]
  expected: true

invariant doctest_extra5.OutputChecker.qualname:
  description: "doctest.OutputChecker.__qualname__ == 'OutputChecker'"
  category: classes
  kind: python_call_eq
  function: OutputChecker.__qualname__.__eq__
  args: ["OutputChecker"]
  expected: true

invariant doctest_extra5.OutputChecker.base_is_object:
  description: "doctest.OutputChecker.__bases__[0].__name__ == 'object' — OutputChecker inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: OutputChecker.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# DebugRunner — name, module, qualname, and base class
# DebugRunner inherits from DocTestRunner (not from object directly).
# No prior doctest spec covers DebugRunner beyond its __name__ in the base spec.
# ---------------------------------------------------------------------------

invariant doctest_extra5.DebugRunner.name:
  description: "doctest.DebugRunner.__name__ == 'DebugRunner'"
  category: classes
  kind: python_call_eq
  function: DebugRunner.__name__.__eq__
  args: ["DebugRunner"]
  expected: true

invariant doctest_extra5.DebugRunner.module:
  description: "doctest.DebugRunner.__module__ == 'doctest'"
  category: classes
  kind: python_call_eq
  function: DebugRunner.__module__.__eq__
  args: ["doctest"]
  expected: true

invariant doctest_extra5.DebugRunner.qualname:
  description: "doctest.DebugRunner.__qualname__ == 'DebugRunner'"
  category: classes
  kind: python_call_eq
  function: DebugRunner.__qualname__.__eq__
  args: ["DebugRunner"]
  expected: true

invariant doctest_extra5.DebugRunner.base_is_DocTestRunner:
  description: "doctest.DebugRunner.__bases__[0].__name__ == 'DocTestRunner' — DebugRunner inherits from DocTestRunner"
  category: hierarchy
  kind: python_call_eq
  function: DebugRunner.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "DocTestRunner"

# ---------------------------------------------------------------------------
# DocTestCase — name, module, qualname, base class name and module
# No prior doctest spec covers DocTestCase beyond its __name__ in doctest_extra.
# ---------------------------------------------------------------------------

invariant doctest_extra5.DocTestCase.name:
  description: "doctest.DocTestCase.__name__ == 'DocTestCase'"
  category: classes
  kind: python_call_eq
  function: DocTestCase.__name__.__eq__
  args: ["DocTestCase"]
  expected: true

invariant doctest_extra5.DocTestCase.module:
  description: "doctest.DocTestCase.__module__ == 'doctest'"
  category: classes
  kind: python_call_eq
  function: DocTestCase.__module__.__eq__
  args: ["doctest"]
  expected: true

invariant doctest_extra5.DocTestCase.qualname:
  description: "doctest.DocTestCase.__qualname__ == 'DocTestCase'"
  category: classes
  kind: python_call_eq
  function: DocTestCase.__qualname__.__eq__
  args: ["DocTestCase"]
  expected: true

invariant doctest_extra5.DocTestCase.base_name:
  description: "doctest.DocTestCase.__bases__[0].__name__ == 'TestCase' — DocTestCase inherits from unittest.TestCase"
  category: hierarchy
  kind: python_call_eq
  function: DocTestCase.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "TestCase"

invariant doctest_extra5.DocTestCase.base_module:
  description: "doctest.DocTestCase.__bases__[0].__module__ == 'unittest.case' — TestCase is from unittest.case"
  category: hierarchy
  kind: python_call_eq
  function: DocTestCase.__bases__.__getitem__
  args: [0]
  method: __module__
  method_args: []
  expected: "unittest.case"

# ---------------------------------------------------------------------------
# register_optionflag — name, module, qualname
# The base spec checks its __name__ only; __module__ and __qualname__ are new.
# ---------------------------------------------------------------------------

invariant doctest_extra5.register_optionflag.module:
  description: "doctest.register_optionflag.__module__ == 'doctest'"
  category: functions
  kind: python_call_eq
  function: register_optionflag.__module__.__eq__
  args: ["doctest"]
  expected: true

invariant doctest_extra5.register_optionflag.qualname:
  description: "doctest.register_optionflag.__qualname__ == 'register_optionflag'"
  category: functions
  kind: python_call_eq
  function: register_optionflag.__qualname__.__eq__
  args: ["register_optionflag"]
  expected: true

# ---------------------------------------------------------------------------
# String constants — BLANKLINE_MARKER and ELLIPSIS_MARKER
# No prior doctest spec covers these module-level string constants.
# ---------------------------------------------------------------------------

invariant doctest_extra5.BLANKLINE_MARKER.is_str:
  description: "type(doctest.BLANKLINE_MARKER).__name__ == 'str' — BLANKLINE_MARKER is a string constant"
  category: constants
  kind: python_call_eq
  function: BLANKLINE_MARKER.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant doctest_extra5.BLANKLINE_MARKER.value:
  description: "doctest.BLANKLINE_MARKER == '<BLANKLINE>'"
  category: constants
  kind: python_call_eq
  function: BLANKLINE_MARKER.__eq__
  args: ["<BLANKLINE>"]
  expected: true

invariant doctest_extra5.ELLIPSIS_MARKER.is_str:
  description: "type(doctest.ELLIPSIS_MARKER).__name__ == 'str' — ELLIPSIS_MARKER is a string constant"
  category: constants
  kind: python_call_eq
  function: ELLIPSIS_MARKER.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant doctest_extra5.ELLIPSIS_MARKER.value:
  description: "doctest.ELLIPSIS_MARKER == '...'"
  category: constants
  kind: python_call_eq
  function: ELLIPSIS_MARKER.__eq__
  args: ["..."]
  expected: true
