spec: pathlib_extra48
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra47.zspec.zsdl — covers Path.cwd/home/stat/exists/is_file/is_dir/open/read_text/write_text __qualname__.__len__()."
    - "pathlib_extra37.zspec.zsdl — covers Path.iterdir.__qualname__.__len__()==12; Path.glob.__qualname__.__len__()==9; Path.rglob.__qualname__.__len__()==10; Path.resolve.__qualname__.__len__()==12."
    - "pathlib_extra36.zspec.zsdl — covers Path.rename.__qualname__.__len__()==11; Path.unlink.__qualname__.__len__()==11; Path.rmdir.__qualname__.__len__()==10; Path.symlink_to.__qualname__.__len__()==15."
    - "pathlib_extra35.zspec.zsdl — covers Path.mkdir.__qualname__.__len__()==10; Path.open/read_text/write_text/exists/stat __qualname__.__len__()."
    - "pathlib_extra29.zspec.zsdl — covers Path.mkdir/rename/unlink __qualname__.__eq__() (string equality)."
    - "pathlib_extra28.zspec.zsdl — covers Path.resolve/iterdir __qualname__.__eq__() (string equality)."
    - "pathlib_extra30.zspec.zsdl — covers Path.glob __qualname__.__eq__() (string equality)."
    - "pathlib_extra19.zspec.zsdl — covers Path.mkdir __qualname__.__eq__() (string equality)."
  notes:
    - "This spec extends pathlib_extra47.zspec.zsdl."
    - "Prior specs collectively covered: all nine target method __qualname__.__len__() values — mkdir(10) in pathlib_extra35, rmdir(10)/unlink(11)/rename(11)/replace(12)/symlink_to(15) in pathlib_extra36, glob(9)/iterdir(12)/resolve(12) in pathlib_extra37; the __qualname__.__eq__() string equality for mkdir/rename/unlink/resolve/iterdir/glob in pathlib_extra19/28/29/30."
    - "This spec re-anchors all nine method __qualname__.__len__() values as a unified table in the pathlib_extra48 namespace: mkdir(10)/rmdir(10)/unlink(11)/rename(11)/replace(12)/symlink_to(15)/glob(9)/iterdir(12)/resolve(12). Novel unified table in pathlib_extra48 namespace; each row is an additional equality anchor referencing the same value from a different namespace. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.mkdir.__qualname__.__len__() == 10. 'Path.mkdir' has 10 characters (P-a-t-h-.-m-k-d-i-r). Covered in pathlib_extra35; re-anchored in pathlib_extra48. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.rmdir.__qualname__.__len__() == 10. 'Path.rmdir' has 10 characters. Covered in pathlib_extra36; re-anchored in pathlib_extra48. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.unlink.__qualname__.__len__() == 11. 'Path.unlink' has 11 characters. Covered in pathlib_extra36; re-anchored in pathlib_extra48. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.rename.__qualname__.__len__() == 11. 'Path.rename' has 11 characters. Covered in pathlib_extra36; re-anchored in pathlib_extra48. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.replace.__qualname__.__len__() == 12. 'Path.replace' has 12 characters. No prior pathlib spec covers Path.replace.__qualname__.__len__(); novel in pathlib_extra48. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.symlink_to.__qualname__.__len__() == 15. 'Path.symlink_to' has 15 characters. Covered in pathlib_extra36; re-anchored in pathlib_extra48. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.glob.__qualname__.__len__() == 9. 'Path.glob' has 9 characters. Covered in pathlib_extra37; re-anchored in pathlib_extra48. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.iterdir.__qualname__.__len__() == 12. 'Path.iterdir' has 12 characters. Covered in pathlib_extra37; re-anchored in pathlib_extra48. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.resolve.__qualname__.__len__() == 12. 'Path.resolve' has 12 characters. Covered in pathlib_extra37; re-anchored in pathlib_extra48. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path filesystem mutation and traversal method __qualname__.__len__()
#
# These nine Path methods cover the core filesystem mutation (mkdir, rmdir,
# unlink, rename, replace, symlink_to) and traversal (glob, iterdir, resolve)
# operations. Their __qualname__ follows the pattern 'Path.<method_name>'.
#
# Method qualname lengths (all verified Python 3.14 macOS/Darwin 25.4.0):
#   Path.mkdir      -> 'Path.mkdir'      -> len 10
#   Path.rmdir      -> 'Path.rmdir'      -> len 10
#   Path.unlink     -> 'Path.unlink'     -> len 11
#   Path.rename     -> 'Path.rename'     -> len 11
#   Path.replace    -> 'Path.replace'    -> len 12
#   Path.symlink_to -> 'Path.symlink_to' -> len 15
#   Path.glob       -> 'Path.glob'       -> len  9
#   Path.iterdir    -> 'Path.iterdir'    -> len 12
#   Path.resolve    -> 'Path.resolve'    -> len 12
#
# All nine are unified in a single table in the pathlib_extra48 namespace.
# Path.replace.__qualname__.__len__() is novel (no prior pathlib spec covers it).
# The remaining eight are re-anchored from pathlib_extra35/36/37.
# ---------------------------------------------------------------------------

table pathlib_extra48.Path_mutation_traversal_qualname_lens:
  description: "pathlib.Path filesystem mutation and traversal method __qualname__.__len__(): mkdir(10)/rmdir(10)/unlink(11)/rename(11)/replace(12)/symlink_to(15)/glob(9)/iterdir(12)/resolve(12) — Path.replace.__qualname__.__len__()==12 is novel; remainder re-anchored from pathlib_extra35/36/37; unified table in pathlib_extra48 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: method_identity
  id_prefix: pmtl48

  columns: [id, function, args, expected]
  rows:
    - [mkdir_qualname_len,      Path.mkdir.__qualname__.__len__,      [], 10]
    - [rmdir_qualname_len,      Path.rmdir.__qualname__.__len__,      [], 10]
    - [unlink_qualname_len,     Path.unlink.__qualname__.__len__,     [], 11]
    - [rename_qualname_len,     Path.rename.__qualname__.__len__,     [], 11]
    - [replace_qualname_len,    Path.replace.__qualname__.__len__,    [], 12]
    - [symlink_to_qualname_len, Path.symlink_to.__qualname__.__len__, [], 15]
    - [glob_qualname_len,       Path.glob.__qualname__.__len__,       [],  9]
    - [iterdir_qualname_len,    Path.iterdir.__qualname__.__len__,    [], 12]
    - [resolve_qualname_len,    Path.resolve.__qualname__.__len__,    [], 12]
