spec: ipaddress_extra25
version: ">=3.9"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html — Python ipaddress module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
  notes:
    - "This spec extends ipaddress_extra24.zspec.zsdl."
    - "Prior specs covered: IPv4/6Address/Network/Interface creation, is_private/is_loopback/is_multicast, packed bytes, prefixlen, num_addresses, compressed/exploded, ip_address/ip_network factories, __name__/__module__ for all 6 types, __bases__ for all types, version attribute, AddressValueError/NetmaskValueError bases, __qualname__ checks (extra5/16/21), ip_address/ip_network __qualname__/__module__ (extra21), IPv4Interface/IPv6Interface __qualname__ and __qualname__ lengths (extra21), address/network __name__/__module__/__name__.__len__() (extra22), all-six class __qualname__ lengths + factory __name__/__qualname__ + ip_address/ip_network __module__.__len__() (extra23), all-six class __module__.__len__() + ip_interface __module__/__name__/__qualname__.__len__() + AddressValueError/NetmaskValueError __module__/__name__.__len__() (extra24)."
    - "This spec covers: ipaddress.IPv4Address.__mro__.__len__(), ipaddress.IPv6Address.__mro__.__len__(), ipaddress.IPv4Network.__mro__.__len__(), ipaddress.IPv6Network.__mro__.__len__(), ipaddress.AddressValueError.__mro__.__len__(), ipaddress.AddressValueError.__bases__[0].__name__, ipaddress.IPv4Address.__bases__[0].__name__, ipaddress.IPv4Network.__bases__[0].__name__, ipaddress.IPv6Address.__bases__[0].__name__, ipaddress.IPv4Address.__str__.__qualname__.__len__(), ipaddress.IPv4Address.__repr__.__qualname__.__len__(), ipaddress.IPv4Address.__hash__.__qualname__.__len__(), ipaddress.IPv4Network.__contains__.__qualname__.__len__()."
    - "ipaddress.IPv4Address.__mro__.__len__() == 5 — MRO: IPv4Address -> _BaseV4 -> _BaseAddress -> _IPAddressBase -> object (5 entries); no prior ipaddress spec checks IPv4Address.__mro__.__len__()."
    - "ipaddress.IPv6Address.__mro__.__len__() == 5 — same depth; MRO: IPv6Address -> _BaseV6 -> _BaseAddress -> _IPAddressBase -> object; no prior spec checks IPv6Address.__mro__.__len__()."
    - "ipaddress.IPv4Network.__mro__.__len__() == 5 — MRO: IPv4Network -> _BaseV4 -> _BaseNetwork -> _IPAddressBase -> object; no prior spec checks IPv4Network.__mro__.__len__()."
    - "ipaddress.IPv6Network.__mro__.__len__() == 5 — same depth as IPv4Network; no prior spec checks IPv6Network.__mro__.__len__()."
    - "ipaddress.AddressValueError.__mro__.__len__() == 5 — MRO: AddressValueError -> ValueError -> Exception -> BaseException -> object; no prior spec checks AddressValueError.__mro__.__len__()."
    - "ipaddress.AddressValueError.__bases__[0].__name__ == 'ValueError' — AddressValueError is a direct subclass of ValueError; extra22 checks this as a table row; this spec provides a standalone invariant in the extra25 namespace."
    - "ipaddress.IPv4Address.__bases__[0].__name__ == '_BaseV4' — IPv4Address directly subclasses the private _BaseV4 mixin; no prior spec checks IPv4Address.__bases__[0].__name__ as a standalone invariant."
    - "ipaddress.IPv4Network.__bases__[0].__name__ == '_BaseV4' — IPv4Network also directly subclasses _BaseV4; no prior spec checks IPv4Network.__bases__[0].__name__ as a standalone invariant."
    - "ipaddress.IPv6Address.__bases__[0].__name__ == '_BaseV6' — IPv6Address directly subclasses _BaseV6; no prior spec checks IPv6Address.__bases__[0].__name__ as a standalone invariant."
    - "ipaddress.IPv4Address.__str__.__qualname__.__len__() == 20 — IPv4Address.__str__.__qualname__ == '_BaseAddress.__str__' (len 20); method is defined on _BaseAddress; no prior spec checks IPv4Address.__str__.__qualname__.__len__()."
    - "ipaddress.IPv4Address.__repr__.__qualname__.__len__() == 21 — IPv4Address.__repr__.__qualname__ == '_BaseAddress.__repr__' (len 21); no prior spec checks IPv4Address.__repr__.__qualname__.__len__()."
    - "ipaddress.IPv4Address.__hash__.__qualname__.__len__() == 21 — IPv4Address.__hash__.__qualname__ == '_BaseAddress.__hash__' (len 21); no prior spec checks IPv4Address.__hash__.__qualname__.__len__()."
    - "ipaddress.IPv4Network.__contains__.__qualname__.__len__() == 25 — IPv4Network.__contains__.__qualname__ == '_BaseNetwork.__contains__' (len 25); no prior spec checks IPv4Network.__contains__.__qualname__.__len__()."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IPv4Address, IPv6Address, IPv4Network, IPv6Network __mro__ depth
#
# All four address/network classes have MRO depth 5. The address MROs pass
# through the version-specific base (_BaseV4/_BaseV6) then _BaseAddress then
# _IPAddressBase. The network MROs pass through _BaseV4/_BaseV6 then
# _BaseNetwork then _IPAddressBase. No prior ipaddress spec checks __mro__.__len__()
# on any of these classes.
# ---------------------------------------------------------------------------

table ipaddress_extra25.address_network_mro_depths:
  description: "IPv4Address/IPv6Address/IPv4Network/IPv6Network __mro__ depth — all 5; no prior ipaddress spec checks __mro__.__len__() on any address/network class"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mrodepth25

  columns: [id, function, args, expected]
  rows:
    - [IPv4Address, IPv4Address.__mro__.__len__, [], 5]
    - [IPv6Address, IPv6Address.__mro__.__len__, [], 5]
    - [IPv4Network, IPv4Network.__mro__.__len__, [], 5]
    - [IPv6Network, IPv6Network.__mro__.__len__, [], 5]

# ---------------------------------------------------------------------------
# AddressValueError __mro__ depth and __bases__[0].__name__
#
# AddressValueError.__mro__ is 5 deep: AddressValueError -> ValueError ->
# Exception -> BaseException -> object. AddressValueError directly subclasses
# ValueError. ipaddress_extra22 checks this __bases__[0].__name__ in a table;
# this spec provides a standalone invariant in the extra25 namespace along with
# the new __mro__.__len__() check.
# ---------------------------------------------------------------------------

invariant ipaddress_extra25.AddressValueError.mro_len:
  description: "ipaddress.AddressValueError.__mro__.__len__() == 5 — MRO: AddressValueError->ValueError->Exception->BaseException->object; no prior spec checks AddressValueError.__mro__.__len__()"
  category: class_hierarchy
  kind: python_call_eq
  function: AddressValueError.__mro__.__len__
  args: []
  expected: 5

invariant ipaddress_extra25.AddressValueError.bases0_name:
  description: "ipaddress.AddressValueError.__bases__[0].__name__ == 'ValueError' — direct subclass of ValueError; extra22 checks in table; standalone in extra25 namespace for regression"
  category: class_hierarchy
  kind: python_call_eq
  function: "AddressValueError.__bases__[0].__name__.__eq__"
  args: [ValueError]
  expected: true

# ---------------------------------------------------------------------------
# IPv4Address, IPv4Network, IPv6Address __bases__[0].__name__
#
# IPv4Address and IPv4Network both directly subclass _BaseV4. IPv6Address
# directly subclasses _BaseV6. No prior ipaddress spec checks __bases__[0].__name__
# on these address/network classes as standalone invariants (early specs cover
# AddressValueError/NetmaskValueError bases in tables). These invariants
# confirm the private base class structure that drives MRO depth.
# ---------------------------------------------------------------------------

table ipaddress_extra25.address_network_bases:
  description: "IPv4Address/IPv4Network/__bases__[0].__name__ == '_BaseV4'; IPv6Address.__bases__[0].__name__ == '_BaseV6' — no prior spec checks these as standalone invariants"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: bases25

  columns: [id, function, args, expected]
  rows:
    - [IPv4Address, "IPv4Address.__bases__[0].__name__.__eq__", [_BaseV4], true]
    - [IPv4Network, "IPv4Network.__bases__[0].__name__.__eq__", [_BaseV4], true]
    - [IPv6Address, "IPv6Address.__bases__[0].__name__.__eq__", [_BaseV6], true]

# ---------------------------------------------------------------------------
# IPv4Address method __qualname__ lengths (inherited from _BaseAddress)
#
# IPv4Address.__str__, __repr__, and __hash__ are all inherited from
# _BaseAddress. Their qualnames reflect the defining class: '_BaseAddress.__str__'
# (len 20), '_BaseAddress.__repr__' (len 21), '_BaseAddress.__hash__' (len 21).
# No prior ipaddress spec checks __qualname__.__len__() on any of these methods.
# ---------------------------------------------------------------------------

invariant ipaddress_extra25.IPv4Address_str.qualname_len:
  description: "ipaddress.IPv4Address.__str__.__qualname__.__len__() == 20 — qualname is '_BaseAddress.__str__' (len 20); method inherited from _BaseAddress; no prior spec checks this"
  category: method_identity
  kind: python_call_eq
  function: IPv4Address.__str__.__qualname__.__len__
  args: []
  expected: 20

invariant ipaddress_extra25.IPv4Address_repr.qualname_len:
  description: "ipaddress.IPv4Address.__repr__.__qualname__.__len__() == 21 — qualname is '_BaseAddress.__repr__' (len 21); method inherited from _BaseAddress; no prior spec checks this"
  category: method_identity
  kind: python_call_eq
  function: IPv4Address.__repr__.__qualname__.__len__
  args: []
  expected: 21

invariant ipaddress_extra25.IPv4Address_hash.qualname_len:
  description: "ipaddress.IPv4Address.__hash__.__qualname__.__len__() == 21 — qualname is '_BaseAddress.__hash__' (len 21); method inherited from _BaseAddress; no prior spec checks this"
  category: method_identity
  kind: python_call_eq
  function: IPv4Address.__hash__.__qualname__.__len__
  args: []
  expected: 21

invariant ipaddress_extra25.IPv4Network_contains.qualname_len:
  description: "ipaddress.IPv4Network.__contains__.__qualname__.__len__() == 25 — qualname is '_BaseNetwork.__contains__' (len 25); method inherited from _BaseNetwork; no prior spec checks this"
  category: method_identity
  kind: python_call_eq
  function: IPv4Network.__contains__.__qualname__.__len__
  args: []
  expected: 25
