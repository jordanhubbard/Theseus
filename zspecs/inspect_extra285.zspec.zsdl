spec: inspect_extra285
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module function identity and predicate naming"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "All inspect predicates are pure-Python functions with __module__ == 'inspect'"
    - "inspect.Parameter is a pure-Python class nested inside inspect module"
    - "inspect.signature wraps _signature_from_callable internally"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table inspect_extra285.predicate_names:
  description: "Verify __name__ for inspect predicate functions"
  kind: python_call_eq
  category: identity
  id_prefix: ipn

  columns: [id, function, args, expected, description]
  rows:
    - [ipn001, inspect.ismodule.__name__.__eq__, ["ismodule"], true, "inspect.ismodule.__name__ is 'ismodule'"]
    - [ipn002, inspect.isclass.__name__.__eq__, ["isclass"], true, "inspect.isclass.__name__ is 'isclass'"]
    - [ipn003, inspect.isfunction.__name__.__eq__, ["isfunction"], true, "inspect.isfunction.__name__ is 'isfunction'"]
    - [ipn004, inspect.isbuiltin.__name__.__eq__, ["isbuiltin"], true, "inspect.isbuiltin.__name__ is 'isbuiltin'"]
    - [ipn005, inspect.ismethod.__name__.__eq__, ["ismethod"], true, "inspect.ismethod.__name__ is 'ismethod'"]
    - [ipn006, inspect.isgenerator.__name__.__eq__, ["isgenerator"], true, "inspect.isgenerator.__name__ is 'isgenerator'"]
    - [ipn007, inspect.isgeneratorfunction.__name__.__eq__, ["isgeneratorfunction"], true, "inspect.isgeneratorfunction.__name__ is 'isgeneratorfunction'"]
    - [ipn008, inspect.iscoroutine.__name__.__eq__, ["iscoroutine"], true, "inspect.iscoroutine.__name__ is 'iscoroutine'"]
    - [ipn009, inspect.iscoroutinefunction.__name__.__eq__, ["iscoroutinefunction"], true, "inspect.iscoroutinefunction.__name__ is 'iscoroutinefunction'"]

table inspect_extra285.predicate_modules:
  description: "Verify __module__ for inspect predicate functions"
  kind: python_call_eq
  category: identity
  id_prefix: ipm

  columns: [id, function, args, expected, description]
  rows:
    - [ipm001, inspect.ismodule.__module__.__eq__, ["inspect"], true, "inspect.ismodule.__module__ is 'inspect'"]
    - [ipm002, inspect.isclass.__module__.__eq__, ["inspect"], true, "inspect.isclass.__module__ is 'inspect'"]
    - [ipm003, inspect.isfunction.__module__.__eq__, ["inspect"], true, "inspect.isfunction.__module__ is 'inspect'"]
    - [ipm004, inspect.isbuiltin.__module__.__eq__, ["inspect"], true, "inspect.isbuiltin.__module__ is 'inspect'"]
    - [ipm005, inspect.ismethod.__module__.__eq__, ["inspect"], true, "inspect.ismethod.__module__ is 'inspect'"]
    - [ipm006, inspect.isgenerator.__module__.__eq__, ["inspect"], true, "inspect.isgenerator.__module__ is 'inspect'"]
    - [ipm007, inspect.isgeneratorfunction.__module__.__eq__, ["inspect"], true, "inspect.isgeneratorfunction.__module__ is 'isgeneratorfunction'"]
    - [ipm008, inspect.iscoroutine.__module__.__eq__, ["inspect"], true, "inspect.iscoroutine.__module__ is 'inspect'"]
    - [ipm009, inspect.iscoroutinefunction.__module__.__eq__, ["inspect"], true, "inspect.iscoroutinefunction.__module__ is 'inspect'"]

invariant inspect_extra285.getmembers_module:
  description: "inspect.getmembers.__module__ equals 'inspect'"
  category: identity
  kind: python_call_eq
  function: inspect.getmembers.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra285.signature_qualname_is_str:
  description: "inspect.signature.__qualname__ is a non-empty str"
  category: identity
  kind: python_call_eq
  function: inspect.signature.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant inspect_extra285.parameter_name:
  description: "inspect.Parameter.__name__ equals 'Parameter'"
  category: identity
  kind: python_call_eq
  function: inspect.Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra285.parameter_module:
  description: "inspect.Parameter.__module__ equals 'inspect'"
  category: identity
  kind: python_call_eq
  function: inspect.Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true
