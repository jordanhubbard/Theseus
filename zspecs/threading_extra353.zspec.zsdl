spec: threading_extra353
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.Timer.__name__ == 'Timer' — verified with Python 3.14.3."
    - "threading.Timer.__module__ == 'threading' — verified with Python 3.14.3."
    - "threading.Timer.__qualname__ == 'Timer' — verified with Python 3.14.3."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer subclasses Thread. Verified with Python 3.14.3."
    - "threading.Timer.__doc__.__class__.__name__ == 'str' — Timer docstring is a str. Verified with Python 3.14.3."
    - "threading.Timer(0.001, lambda: None).__class__.__name__ == 'Timer' — instance class name is 'Timer'. Verified with Python 3.14.3."
    - "threading.Timer(0.001, lambda: None).interval.__eq__(0.001) == True — the interval attribute stores the delay as passed. Verified with Python 3.14.3."
    - "threading.Timer(0.001, lambda: None).function.__class__.__name__ == 'function' — the function attribute holds the callable; a lambda's __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Timer class identity
#
# threading.Timer.__name__ == 'Timer'
# threading.Timer.__module__ == 'threading'
# threading.Timer.__qualname__ == 'Timer'
# threading.Timer.__bases__[0].__name__ == 'Thread'
# threading.Timer.__doc__.__class__.__name__ == 'str'
#
# Timer is a pure-Python class defined in Lib/threading.py as a subclass
# of Thread. Its MRO is [Timer, Thread, object].
# ---------------------------------------------------------------------------

table threading_extra353.timer_class_identity:
  description: "threading.Timer class identity: __name__, __module__, __qualname__, __bases__[0].__name__, __doc__ class; Timer is a Thread subclass defined in Lib/threading.py; new to extra353"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtimer353

  columns: [id, function, args, expected, description]
  rows:
    - [timer_name_eq,
       "Timer.__name__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — Timer is a pure-Python class defined in Lib/threading.py; its __name__ attribute is 'Timer'; str.__eq__('Timer') returns True; new to extra353"]
    - [timer_module_eq,
       "Timer.__module__.__eq__",
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — Timer is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra353"]
    - [timer_qualname_eq,
       "Timer.__qualname__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__qualname__.__eq__('Timer') == True — Timer is a top-level class in threading; its __qualname__ equals its __name__, 'Timer'; str.__eq__('Timer') returns True; new to extra353"]
    - [timer_bases_first_eq_Thread,
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer is defined as 'class Timer(Thread):' in Lib/threading.py; it has a single base class, Thread; __bases__[0].__name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra353"]
    - [timer_doc_class_name_eq_str,
       "Timer.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.Timer.__doc__.__class__.__name__.__eq__('str') == True — Timer has a docstring which is a Python str object; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra353"]

# ---------------------------------------------------------------------------
# Table 2: threading.Timer instance behaviors
#
# threading.Timer(0.001, lambda: None).__class__.__name__ == 'Timer'
# threading.Timer(0.001, lambda: None).interval.__eq__(0.001) == True
# threading.Timer(0.001, lambda: None).function.__class__.__name__ == 'function'
#
# A Timer instance stores the delay in the 'interval' attribute and the
# callable in the 'function' attribute. The function argument is stored as-is.
# A lambda's __class__.__name__ is 'function'.
# ---------------------------------------------------------------------------

table threading_extra353.timer_instance_behaviors:
  description: "threading.Timer instance: __class__.__name__=='Timer', interval stores the delay, function.__class__.__name__=='function'; new to extra353"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtimer353

  columns: [id, function, args, expected, description]
  rows:
    - [timer_instance_class_name_eq,
       "Timer(0.001, lambda: None).__class__.__name__.__eq__",
       ["Timer"],
       true,
       "threading.Timer(0.001, lambda: None).__class__.__name__.__eq__('Timer') == True — constructing a Timer instance returns an object whose __class__ is threading.Timer; __class__.__name__ is 'Timer'; str.__eq__('Timer') returns True; new to extra353"]
    - [timer_instance_interval_eq,
       "Timer(0.001, lambda: None).interval.__eq__",
       [0.001],
       true,
       "threading.Timer(0.001, lambda: None).interval.__eq__(0.001) == True — the Timer constructor stores the delay argument in the 'interval' attribute; calling interval.__eq__(0.001) returns True; new to extra353"]
    - [timer_instance_function_class_name_eq,
       "Timer(0.001, lambda: None).function.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Timer(0.001, lambda: None).function.__class__.__name__.__eq__('function') == True — the Timer constructor stores the callable argument in the 'function' attribute; a lambda is a Python function object whose __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra353"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra353
# ---------------------------------------------------------------------------

invariant threading_extra353.timer_name:
  description: "threading.Timer.__name__ == 'Timer' — pure-Python class in Lib/threading.py; new to extra353"
  kind: python_call_eq
  function: Timer.__name__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra353.timer_module:
  description: "threading.Timer.__module__ == 'threading' — defined in Lib/threading.py; new to extra353"
  kind: python_call_eq
  function: Timer.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra353.timer_qualname:
  description: "threading.Timer.__qualname__ == 'Timer' — top-level class, qualname equals name; new to extra353"
  kind: python_call_eq
  function: Timer.__qualname__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra353.timer_bases_thread:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer is defined as 'class Timer(Thread):'; new to extra353"
  kind: python_call_eq
  function: Timer.__bases__[0].__name__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra353.timer_doc_class:
  description: "threading.Timer.__doc__.__class__.__name__ == 'str' — Timer has a string docstring; new to extra353"
  kind: python_call_eq
  function: Timer.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# timer_instance_class, timer_instance_interval, and timer_instance_function_class
# covered by table threading_extra353.timer_instance_behaviors above
