spec: multiprocessing_extra299
version: ">=3.3"
backend: python_module(multiprocessing.managers)

docs: https://docs.python.org/3/library/multiprocessing.html#managers

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All managers classes are defined in multiprocessing.managers (pure Python)."
    - "multiprocessing.managers.BaseManager.__bases__[0].__name__ == 'object' — BaseManager inherits from object."
    - "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager' — SyncManager inherits from BaseManager."
    - "multiprocessing.managers.BaseProxy.__bases__[0].__name__ == 'object' — BaseProxy inherits from object."
    - "DictProxy, ListProxy, and ValueProxy are auto-generated proxy classes; they live in multiprocessing.managers."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.managers.BaseManager — class identity and inheritance
#
# BaseManager is the root manager class. It inherits from object.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra299.BaseManager.name:
  description: "multiprocessing.managers.BaseManager.__name__ == 'BaseManager'"
  category: base_manager
  kind: python_call_eq
  function: BaseManager.__name__.__eq__
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra299.BaseManager.module:
  description: "multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers'"
  category: base_manager
  kind: python_call_eq
  function: BaseManager.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true

invariant multiprocessing_extra299.BaseManager.base_is_object:
  description: "multiprocessing.managers.BaseManager.__bases__[0].__name__ == 'object'"
  category: base_manager
  kind: python_call_eq
  function: BaseManager.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# multiprocessing.managers.SyncManager — class identity and inheritance
#
# SyncManager provides shared memory types (Lock, Queue, dict, list, etc.).
# It inherits from BaseManager.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra299.SyncManager.name:
  description: "multiprocessing.managers.SyncManager.__name__ == 'SyncManager'"
  category: sync_manager
  kind: python_call_eq
  function: SyncManager.__name__.__eq__
  args: ["SyncManager"]
  expected: true

invariant multiprocessing_extra299.SyncManager.module:
  description: "multiprocessing.managers.SyncManager.__module__ == 'multiprocessing.managers'"
  category: sync_manager
  kind: python_call_eq
  function: SyncManager.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true

invariant multiprocessing_extra299.SyncManager.base_is_BaseManager:
  description: "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager'"
  category: sync_manager
  kind: python_call_eq
  function: SyncManager.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseManager"

# ---------------------------------------------------------------------------
# multiprocessing.managers.BaseProxy — class identity and inheritance
#
# BaseProxy is the root proxy class for all auto-generated manager proxies.
# It inherits from object.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra299.BaseProxy.name:
  description: "multiprocessing.managers.BaseProxy.__name__ == 'BaseProxy'"
  category: base_proxy
  kind: python_call_eq
  function: BaseProxy.__name__.__eq__
  args: ["BaseProxy"]
  expected: true

invariant multiprocessing_extra299.BaseProxy.module:
  description: "multiprocessing.managers.BaseProxy.__module__ == 'multiprocessing.managers'"
  category: base_proxy
  kind: python_call_eq
  function: BaseProxy.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true

invariant multiprocessing_extra299.BaseProxy.base_is_object:
  description: "multiprocessing.managers.BaseProxy.__bases__[0].__name__ == 'object'"
  category: base_proxy
  kind: python_call_eq
  function: BaseProxy.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

