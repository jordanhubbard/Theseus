spec: builtins_extra11
version: ">=3.9"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/functions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functions.html — Python built-in functions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/bltinmodule.c"
    - "builtins_extra3.zspec.zsdl — covers __module__ for int/str/list/dict/tuple/set/frozenset/bytes/bytearray/bool/float/complex/type/object"
    - "builtins_extra9.zspec.zsdl — covers __bases__[0].__name__ for range/type/memoryview/slice/property"
    - "builtins_extra10.zspec.zsdl — covers __bases__[0].__name__ and MRO lengths for filter/map/zip/reversed/super/staticmethod/classmethod"
  notes:
    - "This spec adds new axes not covered in any prior builtins spec."
    - "Axis 1: __name__ for int, float, complex, bool, bytes, bytearray, memoryview, frozenset, object, type."
    - "Axis 2: __mro__ length for int, float, complex, bytes, bytearray, memoryview, frozenset, type (all 2); bool (3); object (1)."
    - "No prior spec checks __name__ for int, float, complex, bool, bytes, bytearray, memoryview, frozenset, object, or type."
    - "builtins_extra3 covers __module__ (not __name__) for the numeric/sequence types."
    - "bool.__mro__ length is 3 — MRO is [bool, int, object]; bool subclasses int."
    - "object.__mro__ length is 1 — object has no base class, so its MRO is just [object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ for core numeric and sequence built-in types
#
# No prior builtins spec covers __name__ for int, float, complex, bool,
# bytes, bytearray, memoryview, frozenset, object, or type.
# builtins_extra3 covers __module__ for these types (not __name__).
# ---------------------------------------------------------------------------

table builtins_extra11.type_names:
  kind: python_call_eq
  category: class_names
  id_prefix: tname

  columns: [id, function, args, expected]
  rows:
    - [int,        int.__name__.__eq__,        ["int"],        true]
    - [float,      float.__name__.__eq__,      ["float"],      true]
    - [complex,    complex.__name__.__eq__,    ["complex"],    true]
    - [bool,       bool.__name__.__eq__,       ["bool"],       true]
    - [bytes,      bytes.__name__.__eq__,      ["bytes"],      true]
    - [bytearray,  bytearray.__name__.__eq__,  ["bytearray"],  true]
    - [memoryview, memoryview.__name__.__eq__, ["memoryview"], true]
    - [frozenset,  frozenset.__name__.__eq__,  ["frozenset"],  true]
    - [object,     object.__name__.__eq__,     ["object"],     true]
    - [type,       type.__name__.__eq__,       ["type"],       true]

# ---------------------------------------------------------------------------
# __mro__ length for core built-in types
#
# builtins_extra9 covers MRO lengths for dict/tuple/set/float/complex/range.
# builtins_extra10 covers MRO lengths for filter/map/zip/reversed/super/
# staticmethod/classmethod.
# No prior spec covers MRO lengths for int, bool, bytes, bytearray, memoryview,
# frozenset, object, or type.
# int/float/complex/bytes/bytearray/memoryview/frozenset/type: MRO length 2.
# bool: MRO length 3 — [bool, int, object] because bool subclasses int.
# object: MRO length 1 — [object] only; object has no base class.
# ---------------------------------------------------------------------------

invariant builtins_extra11.int.mro_length:
  description: "len(int.__mro__) == 2 — [int, object]"
  category: mro_lengths
  kind: python_call_eq
  function: int.__mro__.__len__
  args: []
  expected: 2

invariant builtins_extra11.bool.mro_length:
  description: "len(bool.__mro__) == 3 — [bool, int, object]; bool subclasses int"
  category: mro_lengths
  kind: python_call_eq
  function: bool.__mro__.__len__
  args: []
  expected: 3

invariant builtins_extra11.bytes.mro_length:
  description: "len(bytes.__mro__) == 2 — [bytes, object]"
  category: mro_lengths
  kind: python_call_eq
  function: bytes.__mro__.__len__
  args: []
  expected: 2

invariant builtins_extra11.bytearray.mro_length:
  description: "len(bytearray.__mro__) == 2 — [bytearray, object]"
  category: mro_lengths
  kind: python_call_eq
  function: bytearray.__mro__.__len__
  args: []
  expected: 2

invariant builtins_extra11.frozenset.mro_length:
  description: "len(frozenset.__mro__) == 2 — [frozenset, object]"
  category: mro_lengths
  kind: python_call_eq
  function: frozenset.__mro__.__len__
  args: []
  expected: 2

invariant builtins_extra11.object.mro_length:
  description: "len(object.__mro__) == 1 — [object] only; object is the root type with no base"
  category: mro_lengths
  kind: python_call_eq
  function: object.__mro__.__len__
  args: []
  expected: 1
