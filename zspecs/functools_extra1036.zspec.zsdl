spec: functools_extra1036
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks functools.partial and functools.cached_property descriptor attribute class names and module-level __doc__ type"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1036.partial_class_attr_descriptors:
  description: "functools.partial class-level attribute descriptor __class__.__name__ checks"
  kind: python_call_eq
  category: partial_attr_descriptors
  id_prefix: ft1036pa
  columns: [id, function, args, expected]
  rows:
    - [ft1036pa001, functools.partial.args.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [ft1036pa002, functools.partial.func.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [ft1036pa003, functools.partial.keywords.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [ft1036pa004, functools.partial.__class__.__name__.__eq__,          ["type"],              true]
    - [ft1036pa005, functools.partial.__module__.__eq__,                  ["functools"],         true]
    - [ft1036pa006, functools.partial.__doc__.__class__.__name__.__eq__,  ["str"],               true]

table functools_extra1036.cached_property_attr_descriptors:
  description: "functools.cached_property class-level attribute descriptor __class__.__name__ checks"
  kind: python_call_eq
  category: cached_property_attr_descriptors
  id_prefix: ft1036cp
  columns: [id, function, args, expected]
  rows:
    - [ft1036cp001, functools.cached_property.func.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [ft1036cp002, functools.cached_property.attrname.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [ft1036cp003, functools.cached_property.__class__.__name__.__eq__,          ["type"],              true]
    - [ft1036cp004, functools.cached_property.__module__.__eq__,                  ["functools"],         true]
    - [ft1036cp005, functools.cached_property.__doc__.__class__.__name__.__eq__,  ["str"],               true]

table functools_extra1036.module_level_attrs:
  description: "functools module-level attribute type checks"
  kind: python_call_eq
  category: module_attrs
  id_prefix: ft1036ml
  columns: [id, function, args, expected]
  rows:
    - [ft1036ml001, functools.__doc__.__class__.__name__.__eq__,          ["str"],  true]
    - [ft1036ml002, functools.__name__.__eq__,                            ["functools"], true]
    - [ft1036ml003, functools.__spec__.__class__.__name__.__eq__,         ["ModuleSpec"], true]
    - [ft1036ml004, functools.reduce.__class__.__name__.__eq__,           ["builtin_function_or_method"], true]
    - [ft1036ml005, functools.lru_cache.__class__.__name__.__eq__,        ["function"], true]
