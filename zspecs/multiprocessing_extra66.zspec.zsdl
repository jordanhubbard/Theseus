table multiprocessing_extra66.Process_identity:
  description: "multiprocessing Process class identity checks in mpkw66 namespace — wave 234 theme: Process class identity; Process.__name__=='Process'; Process.__module__=='multiprocessing.process' (defined in Lib/multiprocessing/process.py); Process.__qualname__=='Process'; NEW in extra66: first __name__/__module__/__qualname__ string equality checks for Process in the mpkw66 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpkw66c

  columns: [id, function, args, expected, description]
  rows:
    - [process_name,     Process.__name__.__eq__,     ["Process"],                    true, "Process.__name__ == 'Process' — Process is a top-level class; its __name__ attribute is the simple class name 'Process'; NEW in extra66: first __name__.__eq__ check for Process in the mpkw66 namespace; verified with Python 3.14.3"]
    - [process_module,   Process.__module__.__eq__,   ["multiprocessing.process"],    true, "Process.__module__ == 'multiprocessing.process' — Process is defined in Lib/multiprocessing/process.py; the module sets its __name__ to 'multiprocessing.process'; Process.__module__ is 'multiprocessing.process'; NEW in extra66: first __module__.__eq__ check for Process in the mpkw66 namespace; verified with Python 3.14.3"]
