spec: multiprocessing_extra66
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python function __kwdefaults__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec extends multiprocessing_extra65.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__.__class__.__name__/__len__() tables, Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__name__=='function', ProcessError/AuthenticationError/__class__.__name__=='type', Process/__class__.__module__=='builtins', current_process/__class__.__module__=='builtins', cpu_count/__class__.__module__=='builtins', Pool/__doc__/__class__/__module__=='builtins', Pool/__class__.__name__=='type', Pool/active_children/ProcessError/AuthenticationError __class__.__module__.__eq__('builtins'), Process/__init__.__class__.__name__.__eq__('function'), Process/Pool __repr__.__class__.__name__, Process __weakref__.__class__.__name__, ProcessError/AuthenticationError exception __repr__.__class__.__name__, mp.__all__.__class__.__name__.__eq__('list'), mp.__all__.__len__()==37, Process/ProcessError/AuthenticationError __eq__.__class__.__name__.__eq__('wrapper_descriptor'), mp.__all__.__contains__ membership checks, mp.__package__.__eq__('multiprocessing'), Queue/Pool __doc__.__class__.__name__.__eq__('str'), __loader__/__spec__/__file__/__cached__ __class__.__name__, __spec__ attributes, Process method __qualname__ string equality, Process.__init__/__annotations__/__globals__ class identity, Process.__init__/__defaults__/__code__/__class__.__name__ checks, current_process/__defaults__/__code__/__class__.__name__ checks (extra61), Process.__init__/Process.start/current_process __code__.co_name equality and co_argcount values (extra62), Process.__init__/Process.start/current_process co_varnames/co_filename/co_flags attribute chains (extra63), Process.__init__/Process.start/current_process co_consts/co_nlocals/co_stacksize type identity (extra64), Process.__init__/__defaults__.__class__.__name__=='tuple', Process.__init__/__defaults__.__len__()==5, Process.start/__defaults__.__class__.__name__=='NoneType', current_process/__defaults__.__class__.__name__=='NoneType', Pool class identity, Pool MRO and base class checks (extra65)."
    - "This spec covers (mpkw66 namespace): wave 234 theme — __kwdefaults__ type identity and length for Process.__init__ (daemon is keyword-only giving __kwdefaults__=={'daemon': None}, len==1); NoneType identity for Process.start/__kwdefaults__ and current_process/__kwdefaults__; Pool class identity (__name__=='Pool', __module__=='multiprocessing.pool', __qualname__=='Pool'); Process class identity (__name__=='Process', __module__=='multiprocessing.process', __qualname__=='Process'). NEW in extra66: Process.__init__.__kwdefaults__.__class__.__name__=='dict'; Process.__init__.__kwdefaults__.__len__()==1; Process.start.__kwdefaults__.__class__.__name__=='NoneType'; current_process.__kwdefaults__.__class__.__name__=='NoneType'; Pool.__name__=='Pool'; Pool.__module__=='multiprocessing.pool'; Pool.__qualname__=='Pool'; Pool.__bases__[0].__name__=='object'; Process.__name__=='Process'; Process.__module__=='multiprocessing.process'; Process.__qualname__=='Process'."
    - "multiprocessing.Process.__init__.__kwdefaults__.__class__.__name__ == 'dict'. Process.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, *, daemon=None) has one keyword-only parameter with a default (daemon=None). __kwdefaults__ is {'daemon': None}, a one-entry dict. __class__.__name__ is 'dict'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__init__.__kwdefaults__.__len__() == 1. Process.__init__.__kwdefaults__ is {'daemon': None}, a one-entry dict. len({'daemon': None}) == 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.start.__kwdefaults__ is None. Process.start(self) has no keyword-only parameters. __kwdefaults__ is None. None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.current_process.__kwdefaults__ is None. current_process() has no keyword-only parameters. __kwdefaults__ is None. None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__name__ == 'Pool'. Pool is a top-level class in multiprocessing.pool; its __name__ attribute is the simple class name 'Pool'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__module__ == 'multiprocessing.pool'. Pool is defined in Lib/multiprocessing/pool.py which sets __name__ to 'multiprocessing.pool'. Pool.__module__ is 'multiprocessing.pool'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__qualname__ == 'Pool'. Pool is a top-level class; its qualified name is simply 'Pool'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__name__ == 'Process'. Process is defined in Lib/multiprocessing/process.py; its __name__ is 'Process'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__module__ == 'multiprocessing.process'. Process is defined in Lib/multiprocessing/process.py which sets __name__ to 'multiprocessing.process'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__qualname__ == 'Process'. Process is a top-level class in multiprocessing.process; its qualified name is simply 'Process'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Process.__init__ __kwdefaults__ checks — extra66
#
# Wave 234 theme: __kwdefaults__ type identity and length.
#
# Process.__init__(self, group=None, target=None, name=None, args=(), kwargs={},
#                  *, daemon=None) has one keyword-only parameter with a default.
# __kwdefaults__ is {'daemon': None}, a one-entry dict.
# __class__.__name__ == 'dict' and __len__() == 1.
# ---------------------------------------------------------------------------

table multiprocessing_extra66.Process_kwdefaults:
  description: "multiprocessing Process.__init__/__kwdefaults__ type identity and length checks in mpkw66 namespace — wave 234 theme: __kwdefaults__ type identity; Process.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, *, daemon=None) has one keyword-only parameter with a default (daemon=None); __kwdefaults__ is {'daemon': None} a one-entry dict; __class__.__name__=='dict' and __len__()==1; NEW in extra66: first __kwdefaults__.__class__.__name__ and __len__() checks for Process.__init__ in the mpkw66 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: kwdefaults
  id_prefix: mpkw66

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_kwdefaults_class, Process.__init__.__kwdefaults__.__class__.__name__.__eq__, ["dict"], true, "Process.__init__.__kwdefaults__.__class__.__name__ == 'dict' — Process.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, *, daemon=None) has one keyword-only parameter with a default (daemon=None); __kwdefaults__ is {'daemon': None} a one-entry dict; dict.__class__.__name__ is 'dict'; NEW in extra66: first __kwdefaults__.__class__.__name__.__eq__ check for Process.__init__ in the mpkw66 namespace; verified with Python 3.14.3"]
    - [process_init_kwdefaults_len,   Process.__init__.__kwdefaults__.__len__,                   [],       1,    "Process.__init__.__kwdefaults__.__len__() == 1 — Process.__init__.__kwdefaults__ is {'daemon': None} a one-entry dict; len({'daemon': None}) == 1; NEW in extra66: first __kwdefaults__.__len__() check for Process.__init__ in the mpkw66 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process.start / current_process __kwdefaults__ NoneType — extra66
#
# Wave 234 theme: __kwdefaults__ NoneType identity.
#
# Process.start(self) has no keyword-only parameters; __kwdefaults__ is None.
# current_process() has no keyword-only parameters; __kwdefaults__ is None.
# ---------------------------------------------------------------------------

table multiprocessing_extra66.none_kwdefaults:
  description: "multiprocessing Process.start/__kwdefaults__ and current_process/__kwdefaults__ NoneType checks in mpkw66 namespace — wave 234 theme: __kwdefaults__ NoneType identity; Process.start(self) has no keyword-only parameters (__kwdefaults__ is None, NoneType); current_process() has no keyword-only parameters (__kwdefaults__ is None, NoneType); NEW in extra66: first __kwdefaults__.__class__.__name__.__eq__('NoneType') checks for Process.start and current_process in the mpkw66 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: kwdefaults
  id_prefix: mpkw66a

  columns: [id, function, args, expected, description]
  rows:
    - [process_start_kwdefaults_class,   Process.start.__kwdefaults__.__class__.__name__.__eq__,   ["NoneType"], true, "Process.start.__kwdefaults__.__class__.__name__ == 'NoneType' — Process.start(self) has no keyword-only parameters; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra66: first __kwdefaults__.__class__.__name__.__eq__ check for Process.start in the mpkw66 namespace; verified with Python 3.14.3"]
    - [current_process_kwdefaults_class, current_process.__kwdefaults__.__class__.__name__.__eq__, ["NoneType"], true, "current_process.__kwdefaults__.__class__.__name__ == 'NoneType' — current_process() has no keyword-only parameters; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra66: first __kwdefaults__.__class__.__name__.__eq__ check for current_process in the mpkw66 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Pool class identity checks — extra66
#
# Wave 234 theme: Pool class identity.
#
# Pool.__name__ == 'Pool'
# Pool.__module__ == 'multiprocessing.pool'
# Pool.__qualname__ == 'Pool'
# Pool.__bases__[0].__name__ == 'object' (Pool directly subclasses object)
# Note: Pool.__bases__[0].__name__ contains '[' and must be double-quoted.
# ---------------------------------------------------------------------------

table multiprocessing_extra66.Pool_identity:
  description: "multiprocessing Pool class identity checks in mpkw66 namespace — wave 234 theme: Pool class identity; Pool.__name__=='Pool'; Pool.__module__=='multiprocessing.pool' (defined in Lib/multiprocessing/pool.py); Pool.__qualname__=='Pool'; NEW in extra66: first __name__/__module__/__qualname__ string equality checks for Pool in the mpkw66 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpkw66b

  columns: [id, function, args, expected, description]
  rows:
    - [pool_name,     Pool.__name__.__eq__,     ["Pool"],                 true, "Pool.__name__ == 'Pool' — Pool is a top-level class; its __name__ attribute is the simple class name 'Pool'; NEW in extra66: first __name__.__eq__ check for Pool in the mpkw66 namespace; verified with Python 3.14.3"]
    - [pool_module,   Pool.__module__.__eq__,   ["multiprocessing.pool"], true, "Pool.__module__ == 'multiprocessing.pool' — Pool is defined in Lib/multiprocessing/pool.py; the module sets its __name__ to 'multiprocessing.pool'; Pool.__module__ is 'multiprocessing.pool'; NEW in extra66: first __module__.__eq__ check for Pool in the mpkw66 namespace; verified with Python 3.14.3"]
    - [pool_qualname, Pool.__qualname__.__eq__, ["Pool"],                 true, "Pool.__qualname__ == 'Pool' — Pool is a top-level class in multiprocessing.pool; its qualified name is simply 'Pool'; __qualname__.__eq__('Pool') returns True; NEW in extra66: first __qualname__.__eq__ check for Pool in the mpkw66 namespace; verified with Python 3.14.3"]

