# ---------------------------------------------------------------------------
# Standalone invariants — extra66
# ---------------------------------------------------------------------------

invariant multiprocessing_extra66.Process_init_kwdefaults_dict:
  description: "multiprocessing.Process.__init__.__kwdefaults__.__class__.__name__.__eq__('dict') returns True — Process.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, *, daemon=None) has one keyword-only parameter with a default (daemon=None); __kwdefaults__ is {'daemon': None} a one-entry dict; dict.__class__.__name__ is 'dict'; NEW in extra66: first standalone __kwdefaults__.__class__.__name__.__eq__('dict') invariant for Process.__init__ in the mpkw66 namespace; wave 234 first __kwdefaults__ type identity invariant for Process.__init__; verified with Python 3.14.3"
  category: kwdefaults
  kind: python_call_eq
  function: Process.__init__.__kwdefaults__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant multiprocessing_extra66.Process_init_kwdefaults_len_1:
  description: "multiprocessing.Process.__init__.__kwdefaults__.__len__() == 1 — Process.__init__.__kwdefaults__ is {'daemon': None}, a one-entry dict; len({'daemon': None}) == 1; __len__() returns 1; NEW in extra66: first standalone __kwdefaults__.__len__() invariant for Process.__init__ in the mpkw66 namespace; wave 234 first __kwdefaults__ length invariant for Process.__init__; verified with Python 3.14.3"
  category: kwdefaults
  kind: python_call_eq
  function: Process.__init__.__kwdefaults__.__len__
  args: []
  expected: 1

invariant multiprocessing_extra66.Process_start_kwdefaults_NoneType:
  description: "multiprocessing.Process.start.__kwdefaults__.__class__.__name__.__eq__('NoneType') returns True — Process.start(self) has no keyword-only parameters; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra66: first standalone __kwdefaults__.__class__.__name__.__eq__('NoneType') invariant for Process.start in the mpkw66 namespace; wave 234 first __kwdefaults__ NoneType identity invariant for Process.start; verified with Python 3.14.3"
  category: kwdefaults
  kind: python_call_eq
  function: Process.start.__kwdefaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant multiprocessing_extra66.Pool_module_mp_pool:
  description: "multiprocessing.Pool.__module__.__eq__('multiprocessing.pool') returns True — Pool is defined in Lib/multiprocessing/pool.py; the module sets its __name__ to 'multiprocessing.pool'; Pool.__module__ is 'multiprocessing.pool'; NEW in extra66: first standalone __module__.__eq__('multiprocessing.pool') invariant for Pool in the mpkw66 namespace; wave 234 first module identity invariant for Pool; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Pool.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra66.Process_module_mp_process:
  description: "multiprocessing.Process.__module__.__eq__('multiprocessing.process') returns True — Process is defined in Lib/multiprocessing/process.py; the module sets its __name__ to 'multiprocessing.process'; Process.__module__ is 'multiprocessing.process'; NEW in extra66: first standalone __module__.__eq__('multiprocessing.process') invariant for Process in the mpkw66 namespace; wave 234 first module identity invariant for Process; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true
