spec: itertools_extra2281
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 599 (_extra2281): class hierarchy metrics — MRO depth, base count, dict size, __flags__ dict-presence."
    - "Subjects: itertools.chain, itertools.cycle, itertools.count, itertools.combinations, itertools.permutations, itertools.product, itertools.islice, itertools.repeat, itertools.groupby, itertools.compress, itertools.takewhile, itertools.dropwhile."
    - "All itertools types are C extension types with __mro__.__len__ == 2 (type -> object) and __bases__.__len__ == 1."
    - "itertools.chain: __dict__.__len__ == 8. itertools.cycle: __dict__.__len__ == 6. itertools.count: __dict__.__len__ == 7."
    - "itertools.combinations: __dict__.__len__ == 7. itertools.permutations: __dict__.__len__ == 7. itertools.product: __dict__.__len__ == 7."
    - "itertools.islice: __dict__.__len__ == 6. itertools.repeat: __dict__.__len__ == 8. itertools.groupby: __dict__.__len__ == 6."
    - "itertools.compress: __dict__.__len__ == 6. itertools.takewhile: __dict__.__len__ == 6. itertools.dropwhile: __dict__.__len__ == 6."
    - "__flags__ is not present in any of these types' __dict__ (it is a C-level slot, not a Python-level dict entry)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table itertools_extra2281.chain_mro:
  description: "itertools.chain MRO depth, base count, dict size, and __flags__ dict-presence"
  kind: python_call_eq
  category: mro_depth
  id_prefix: it2281

  columns: [id, function, args, expected]
  rows:
    - ["it2281001", "itertools.chain.__mro__.__len__", [], 2]
    - ["it2281002", "itertools.chain.__bases__.__len__", [], 1]
    - ["it2281003", "itertools.chain.__dict__.__len__", [], 8]
    - ["it2281004", "itertools.chain.__dict__.__contains__", ["__flags__"], false]

