spec: re_extra1366
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module error, Pattern, Match documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 538 (_extra1366): focuses on __flags__, __basicsize__, and __itemsize__ C-type attribute checks for re module classes."
    - "re.error is a pure-Python exception class (subclass of Exception); re.Pattern and re.Match are C extension types from the _sre module."
    - "All three classes have integer-typed __flags__, __basicsize__, and __itemsize__ attributes."
    - "Only the type (int) is checked — exact values are platform-specific and intentionally not tested."
    - "re.error.__flags__.__class__.__name__ == 'int'; re.Pattern.__flags__.__class__.__name__ == 'int'; re.Match.__flags__.__class__.__name__ == 'int'; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1366.error_flags_basicsize_itemsize:
  description: "re.error __flags__, __basicsize__, __itemsize__ type checks — wave 538 theme: re.error is a pure-Python exception class; it still carries integer-typed C-slot attributes __flags__, __basicsize__, and __itemsize__ via Python's type machinery; only the type name 'int' is checked, not exact values; verified with Python 3.12"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: re1366er
  columns: [id, function, args, expected, description]
  rows:
    - [re1366er001, re.error.__flags__.__class__.__name__.__eq__,           ["int"], true, "re.error.__flags__.__class__.__name__ == 'int' (C-slot integer attribute on exception class); verified with Python 3.12"]
    - [re1366er002, re.error.__basicsize__.__class__.__name__.__eq__,       ["int"], true, "re.error.__basicsize__.__class__.__name__ == 'int' (C-slot integer attribute on exception class); verified with Python 3.12"]
    - [re1366er003, re.error.__itemsize__.__class__.__name__.__eq__,        ["int"], true, "re.error.__itemsize__.__class__.__name__ == 'int' (C-slot integer attribute on exception class); verified with Python 3.12"]
    - [re1366er004, re.Pattern.__flags__.__class__.__name__.__eq__,         ["int"], true, "re.Pattern.__flags__.__class__.__name__ == 'int' (cross-check: C extension type also uses int); verified with Python 3.12"]
    - [re1366er005, re.Match.__flags__.__class__.__name__.__eq__,           ["int"], true, "re.Match.__flags__.__class__.__name__ == 'int' (cross-check: all three re types use int for __flags__); verified with Python 3.12"]
    - [re1366er006, re.error.__basicsize__.__class__.__name__.__eq__,       ["int"], true, "re.error.__basicsize__ is int (consistency: exception class basicsize same type as C extension types); verified with Python 3.12"]

table re_extra1366.pattern_flags_basicsize_itemsize:
  description: "re.Pattern __flags__, __basicsize__, __itemsize__ type checks — wave 538 theme: re.Pattern is a C extension type from the _sre module; __flags__, __basicsize__, and __itemsize__ are all integer-typed; only the type name 'int' is checked; verified with Python 3.12"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: re1366pa
  columns: [id, function, args, expected, description]
  rows:
    - [re1366pa001, re.Pattern.__flags__.__class__.__name__.__eq__,        ["int"], true, "re.Pattern.__flags__.__class__.__name__ == 'int' (C extension type attribute); verified with Python 3.12"]
    - [re1366pa002, re.Pattern.__basicsize__.__class__.__name__.__eq__,    ["int"], true, "re.Pattern.__basicsize__.__class__.__name__ == 'int' (C extension type attribute); verified with Python 3.12"]
    - [re1366pa003, re.Pattern.__itemsize__.__class__.__name__.__eq__,     ["int"], true, "re.Pattern.__itemsize__.__class__.__name__ == 'int' (C extension type attribute); verified with Python 3.12"]
    - [re1366pa004, re.error.__flags__.__class__.__name__.__eq__,          ["int"], true, "re.error.__flags__ is int (cross-check: exception class consistent with C extension pattern); verified with Python 3.12"]
    - [re1366pa005, re.Match.__basicsize__.__class__.__name__.__eq__,      ["int"], true, "re.Match.__basicsize__ is int (cross-check: sibling C extension type also uses int); verified with Python 3.12"]
    - [re1366pa006, re.Match.__itemsize__.__class__.__name__.__eq__,       ["int"], true, "re.Match.__itemsize__ is int (cross-check: sibling C extension type also uses int); verified with Python 3.12"]

table re_extra1366.match_flags_basicsize_itemsize:
  description: "re.Match __flags__, __basicsize__, __itemsize__ type checks and cross-class consistency — wave 538 theme: re.Match is a C extension type from the _sre module; __flags__, __basicsize__, and __itemsize__ are all integer-typed; cross-checks with re.error and re.Pattern to confirm consistency across all three re public types; verified with Python 3.12"
