spec: pathlib_extra59
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra58.zspec.zsdl — covers pathlib class __module__.__eq__('pathlib') for Path/PurePath/PurePosixPath/PureWindowsPath (NOVEL in extra58); __module__.__len__()==7 for Path/PurePath; Path attribute descriptor __class__.__name__.__eq__('property') for name/suffix/parent/stem/parts/drive/root/anchor/suffixes/parents (all NOVEL in extra58)."
    - "pathlib_extra57.zspec.zsdl — covers 9 Path method qualname equality checks (write_text/read_bytes/write_bytes/mkdir/unlink/is_file/is_dir/stat/rename)."
    - "pathlib_extra56.zspec.zsdl — covers __doc__.__class__.__name__/qualname/module for Path/PurePath/PurePosixPath/PureWindowsPath/pathlib-module."
    - "pathlib_extra55.zspec.zsdl — covers 12 Path method qualname lengths."
    - "pathlib_extra54.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __class__.__qualname__.__eq__('type')."
    - "pathlib_extra53.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __class__.__name__.__eq__('type') and __class__.__name__.__len__()==4."
    - "pathlib_extra49.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__.__eq__()."
    - "pathlib_extra31.zspec.zsdl — covers PurePath.parts/name/stem/suffix fget.__qualname__."
    - "pathlib_extra32.zspec.zsdl — covers PurePath.suffixes/drive/root/anchor fget.__qualname__."
  notes:
    - "This spec extends pathlib_extra58.zspec.zsdl."
    - "Prior specs collectively covered: all pathlib class __qualname__ equality and lengths (pathlib_extra49/pathlib_extra50); class __class__.__name__/__qualname__ equality (pathlib_extra53/pathlib_extra54); Path property descriptor __class__.__name__.__eq__('property') for name/suffix/parent/stem/parts/drive/root/anchor/suffixes/parents (pathlib_extra58); PurePath property fget __qualname__.__eq__() for parts/name/stem/suffix/suffixes/drive/root/anchor (pathlib_extra31/pathlib_extra32); pathlib class __module__.__eq__('pathlib') for Path/PurePath/PurePosixPath/PureWindowsPath (pathlib_extra58); NO prior pathlib spec checks Path property descriptor __class__.__qualname__.__eq__('property') for any attribute; NO prior pathlib spec checks PurePath property descriptor __class__.__name__.__eq__('property') for name/suffix/parent/stem."
    - "This spec covers: pathlib.Path.name.__class__.__qualname__.__eq__('property') (NOVEL — pathlib_extra58 checks __class__.__name__ for Path properties but not __class__.__qualname__; for the builtin property type, __qualname__ == __name__ == 'property'; no prior pathlib spec checks __class__.__qualname__ of any Path attribute descriptor; novel __qualname__ path for property type); pathlib.Path.suffix.__class__.__qualname__.__eq__('property') (NOVEL); pathlib.Path.parent.__class__.__qualname__.__eq__('property') (NOVEL); pathlib.Path.stem.__class__.__qualname__.__eq__('property') (NOVEL); pathlib.Path.parts.__class__.__qualname__.__eq__('property') (NOVEL); pathlib.Path.drive.__class__.__qualname__.__eq__('property') (NOVEL); pathlib.Path.root.__class__.__qualname__.__eq__('property') (NOVEL); pathlib.Path.anchor.__class__.__qualname__.__eq__('property') (NOVEL); pathlib.PurePath.name.__class__.__name__.__eq__('property') (NOVEL — pathlib_extra58 checks Path property __class__.__name__; no prior pathlib spec checks PurePath property __class__.__name__ as standalone invariants; novel PurePath axis); pathlib.PurePath.suffix.__class__.__name__.__eq__('property') (NOVEL); pathlib.PurePath.parent.__class__.__name__.__eq__('property') (NOVEL); pathlib.PurePath.stem.__class__.__name__.__eq__('property') (NOVEL)."
    - "pathlib.Path.name.__class__.__qualname__ == 'property'. Path.name is a Python property descriptor; its __class__ is the builtin property type. For the builtin property type, __qualname__ == __name__ == 'property'. pathlib_extra58 checks __class__.__name__ but not __class__.__qualname__ for Path properties. Novel __qualname__ axis. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.suffix.__class__.__qualname__ == 'property'. Same reasoning as name. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.parent.__class__.__qualname__ == 'property'. Path.parent returns the logical parent of the path. It is a property descriptor; __class__.__qualname__ == 'property'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.stem.__class__.__qualname__ == 'property'. Path.stem is the final path component without its suffix. property type __qualname__ == 'property'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.parts.__class__.__qualname__ == 'property'. Path.parts is a tuple of the path's components. property __qualname__ == 'property'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.drive.__class__.__qualname__ == 'property'. Path.drive is the drive letter (empty on POSIX). property __qualname__ == 'property'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.root.__class__.__qualname__ == 'property'. Path.root is the root component. property __qualname__ == 'property'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.anchor.__class__.__qualname__ == 'property'. Path.anchor is drive + root. property __qualname__ == 'property'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.name.__class__.__name__ == 'property'. PurePath defines the same named-component properties as Path (Path inherits from PurePath). Accessing PurePath.name on the class returns the property descriptor object; its __class__.__name__ is 'property'. pathlib_extra58 checks this on Path but NOT on PurePath. Novel PurePath axis. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.suffix.__class__.__name__ == 'property'. PurePath.suffix returns the file extension. It is a property descriptor; __class__.__name__ == 'property'. Novel PurePath axis. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.parent.__class__.__name__ == 'property'. PurePath.parent returns the logical parent. property descriptor. Novel PurePath axis. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.stem.__class__.__name__ == 'property'. PurePath.stem is the final component without suffix. property descriptor. Novel PurePath axis. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path property descriptor __class__.__qualname__ (novel qualname axis)
#
# pathlib_extra58 verified that Path's named-component attributes are property
# descriptors by checking __class__.__name__ == 'property'. The builtin
# property type has __qualname__ == __name__ == 'property' (it is a top-level
# builtin; no enclosing class scope). No prior pathlib spec checks
# __class__.__qualname__ for any Path property attribute. This table adds the
# __qualname__ complementary axis for eight of those same properties.
#
#   Path.name.__class__.__qualname__   == 'property'
#   Path.suffix.__class__.__qualname__ == 'property'
#   Path.parent.__class__.__qualname__ == 'property'
#   Path.stem.__class__.__qualname__   == 'property'
#   Path.parts.__class__.__qualname__  == 'property'
#   Path.drive.__class__.__qualname__  == 'property'
#   Path.root.__class__.__qualname__   == 'property'
#   Path.anchor.__class__.__qualname__ == 'property'
#
# All eight equality anchors are novel in the pathlibprop59 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra59.path_property_qualnames:
  description: "pathlib.Path attribute descriptor __class__.__qualname__.__eq__('property') for name/suffix/parent/stem/parts/drive/root/anchor — property type __qualname__=='property' (same as __name__ for builtin types); pathlib_extra58 covers __class__.__name__; no prior pathlib spec checks __class__.__qualname__ of any Path attribute descriptor; all eight novel equality anchors in pathlibprop59 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibprop59pq

  columns: [id, function, args, expected]
  rows:
    - [Path_name_class_qualname,   "Path.name.__class__.__qualname__.__eq__",   ["property"], true]
    - [Path_suffix_class_qualname, "Path.suffix.__class__.__qualname__.__eq__", ["property"], true]
    - [Path_parent_class_qualname, "Path.parent.__class__.__qualname__.__eq__", ["property"], true]
    - [Path_stem_class_qualname,   "Path.stem.__class__.__qualname__.__eq__",   ["property"], true]
    - [Path_parts_class_qualname,  "Path.parts.__class__.__qualname__.__eq__",  ["property"], true]
    - [Path_drive_class_qualname,  "Path.drive.__class__.__qualname__.__eq__",  ["property"], true]
    - [Path_root_class_qualname,   "Path.root.__class__.__qualname__.__eq__",   ["property"], true]
    - [Path_anchor_class_qualname, "Path.anchor.__class__.__qualname__.__eq__", ["property"], true]

# ---------------------------------------------------------------------------
# pathlib.PurePath property descriptor __class__.__name__ (novel PurePath axis)
#
# Path inherits from PurePath; the named-component properties are defined on
# PurePath. Accessing PurePath.name etc. on the class returns the underlying
# property descriptor; its __class__.__name__ is 'property'. pathlib_extra58
# checks this axis on Path but not on PurePath. These are novel standalone
# invariants for PurePath.
#
#   PurePath.name.__class__.__name__   == 'property'
#   PurePath.suffix.__class__.__name__ == 'property'
#   PurePath.parent.__class__.__name__ == 'property'
#   PurePath.stem.__class__.__name__   == 'property'
#
# All four equality anchors are novel in the pathlibprop59 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra59.purepath_property_descriptors:
  description: "pathlib.PurePath attribute descriptor __class__.__name__.__eq__('property') for name/suffix/parent/stem — PurePath defines these property descriptors inherited by Path; pathlib_extra58 covers this axis on Path but not PurePath; all four novel equality anchors in pathlibprop59 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibprop59pp

  columns: [id, function, args, expected]
  rows:
    - [PurePath_name_class_name,   "PurePath.name.__class__.__name__.__eq__",   ["property"], true]
    - [PurePath_suffix_class_name, "PurePath.suffix.__class__.__name__.__eq__", ["property"], true]
    - [PurePath_parent_class_name, "PurePath.parent.__class__.__name__.__eq__", ["property"], true]
    - [PurePath_stem_class_name,   "PurePath.stem.__class__.__name__.__eq__",   ["property"], true]
