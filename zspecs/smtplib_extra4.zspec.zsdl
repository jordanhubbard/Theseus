spec: smtplib_extra4
version: ">=3.9"
backend: python_module(smtplib)

docs: https://docs.python.org/3/library/smtplib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/smtplib.html — Python smtplib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/smtplib.py internal socket/TLS implementation details"
  notes:
    - "This spec extends smtplib.zspec.zsdl, smtplib_extra.zspec.zsdl, smtplib_extra2.zspec.zsdl, and smtplib_extra3.zspec.zsdl."
    - "smtplib.zspec.zsdl covers: __name__ table for SMTP/SMTP_SSL/SMTPException/SMTPAuthenticationError/SMTPConnectError/SMTPRecipientsRefused/SMTPSenderRefused/SMTPDataError/SMTPNotSupportedError/SMTPHeloError; SMTP.__module__; port constants values."
    - "smtplib_extra.zspec.zsdl covers: standalone __name__ invariants for SMTP/SMTP_SSL/SMTPException/SMTPConnectError/SMTPAuthenticationError; SMTPException hierarchy; SMTP_PORT type and value."
    - "smtplib_extra2.zspec.zsdl covers: SMTPServerDisconnected/SMTPResponseException __name__; SMTP_SSL base; SMTPServerDisconnected/SMTPResponseException/SMTPSenderRefused bases; SMTP.default_port type and value."
    - "smtplib_extra3.zspec.zsdl covers: __qualname__ table for all major SMTP classes; SMTPException.__module__; SMTP_SSL_PORT type."
    - "This spec adds: SMTP.__name__ length check; SMTPException.__name__ length check; SMTP_SSL.__name__ length check; SMTPException.__class__.__name__=='type' (metaclass check); SMTP.__class__.__name__=='type'; SMTP_SSL.__class__.__name__=='type'."
    - "smtplib.SMTP.__name__ has 4 characters; smtplib.SMTP_SSL.__name__ has 8 characters; smtplib.SMTPException.__name__ has 13 characters."
    - "All three main smtplib classes (SMTP, SMTP_SSL, SMTPException) are regular Python classes: their metaclass is 'type'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ length checks — SMTP, SMTP_SSL, SMTPException
# No prior smtplib spec has verified the character length of any class __name__.
# ---------------------------------------------------------------------------

invariant smtplib_extra4.SMTP.name_len:
  description: "smtplib.SMTP.__name__.__len__() == 4 — 'SMTP' has 4 characters"
  category: class_identity
  kind: python_call_eq
  function: SMTP.__name__.__len__
  args: []
  expected: 4

invariant smtplib_extra4.SMTP_SSL.name_len:
  description: "smtplib.SMTP_SSL.__name__.__len__() == 8 — 'SMTP_SSL' has 8 characters"
  category: class_identity
  kind: python_call_eq
  function: SMTP_SSL.__name__.__len__
  args: []
  expected: 8

invariant smtplib_extra4.SMTPException.name_len:
  description: "smtplib.SMTPException.__name__.__len__() == 13 — 'SMTPException' has 13 characters"
  category: class_identity
  kind: python_call_eq
  function: SMTPException.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# Metaclass checks — SMTP, SMTP_SSL, SMTPException are regular Python classes
# Their __class__.__name__ == 'type', confirming no custom metaclass is in use.
# No prior smtplib spec has verified metaclass identity for any smtplib class.
# ---------------------------------------------------------------------------

table smtplib_extra4.metaclass_checks:
  kind: python_call_eq
  category: class_types
  id_prefix: metaclass

  columns: [id, function, args, expected]
  rows:
    - [SMTP,          SMTP.__class__.__name__.__eq__,          ["type"], true]
    - [SMTP_SSL,      SMTP_SSL.__class__.__name__.__eq__,      ["type"], true]
    - [SMTPException, SMTPException.__class__.__name__.__eq__, ["type"], true]
