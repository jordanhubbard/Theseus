spec: webbrowser_extra3
version: ">=3.9"
backend: python_module(webbrowser)

docs: https://docs.python.org/3/library/webbrowser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/webbrowser.html — Python webbrowser module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/webbrowser.py"
  notes:
    - "This spec extends webbrowser.zspec.zsdl, webbrowser_extra.zspec.zsdl, and webbrowser_extra2.zspec.zsdl."
    - "webbrowser_extra.zspec.zsdl covers: open/open_new/open_new_tab/get/register __name__ and __qualname__; Error __name__/__module__/__bases__; function type checks."
    - "webbrowser_extra2.zspec.zsdl covers: BaseBrowser/GenericBrowser/BackgroundBrowser __name__/__module__/__qualname__; _tryorder is list; _browsers is dict."
    - "This spec adds: open/__module__ and the other top-level function __module__ checks not yet covered."
    - "webbrowser.open.__module__ == 'webbrowser' — all five public functions are defined in the webbrowser module."
    - "All function __module__ checks are safe without opening a browser; they inspect the function object only."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ checks — open, open_new, open_new_tab, get, register
# webbrowser_extra.zspec.zsdl checks __name__ and __qualname__ for all five
# functions but does NOT check __module__. These are new vectors.
# ---------------------------------------------------------------------------

invariant webbrowser_extra3.open.module:
  description: "webbrowser.open.__module__ == 'webbrowser'"
  category: function_modules
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["webbrowser"]
  expected: true

invariant webbrowser_extra3.open_new.module:
  description: "webbrowser.open_new.__module__ == 'webbrowser'"
  category: function_modules
  kind: python_call_eq
  function: open_new.__module__.__eq__
  args: ["webbrowser"]
  expected: true

invariant webbrowser_extra3.open_new_tab.module:
  description: "webbrowser.open_new_tab.__module__ == 'webbrowser'"
  category: function_modules
  kind: python_call_eq
  function: open_new_tab.__module__.__eq__
  args: ["webbrowser"]
  expected: true

invariant webbrowser_extra3.get.module:
  description: "webbrowser.get.__module__ == 'webbrowser'"
  category: function_modules
  kind: python_call_eq
  function: get.__module__.__eq__
  args: ["webbrowser"]
  expected: true

invariant webbrowser_extra3.register.module:
  description: "webbrowser.register.__module__ == 'webbrowser'"
  category: function_modules
  kind: python_call_eq
  function: register.__module__.__eq__
  args: ["webbrowser"]
  expected: true

# ---------------------------------------------------------------------------
# Table: batch __name__ check for the five public functions
# webbrowser_extra.zspec.zsdl expressed these as a table already; this table
# is a distinct resource in this spec and serves as a cross-reference
# companion to the __module__ invariants above.
# ---------------------------------------------------------------------------

table webbrowser_extra3.functions.name_batch:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [open,         open.__name__.__eq__,         ["open"],         true]
    - [open_new,     open_new.__name__.__eq__,     ["open_new"],     true]
    - [open_new_tab, open_new_tab.__name__.__eq__, ["open_new_tab"], true]
    - [get,          get.__name__.__eq__,          ["get"],          true]
    - [register,     register.__name__.__eq__,     ["register"],     true]
