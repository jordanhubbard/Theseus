spec: hashlib_extra176
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra175.zspec.zsdl — covers hashlib.algorithms_guaranteed/__available __len__() sizes (14/19) and __contains__ membership for sha256/md5/blake2b/sha3_512 (table + invariants)."
    - "hashlib_extra174.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module-level identity attributes (table + invariants)."
    - "hashlib_extra173.zspec.zsdl — covers hashlib constructor __qualname__ attributes and algorithms_guaranteed/available.__class__.__name__=='set' (table + invariants)."
    - "hashlib_extra172.zspec.zsdl — covers hashlib constructor __name__.__len__() integer values for all eight constructors (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__=='hashlib' and hashlib.__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra175."
    - "Wave 354 theme: hashlib HASH object class identity — hashlib.md5().__class__.__name__=='HASH'; hashlib.md5().__class__.__module__=='_hashlib'; hashlib.sha1().__class__.__name__=='HASH'; hashlib.sha256().__class__.__name__=='HASH'; hashlib.new.__name__=='__hash_new'; hashlib.new.__module__=='hashlib'; hashlib.algorithms_available.__class__.__name__=='set'; hashlib.algorithms_guaranteed.__class__.__name__=='set'. These anchor HASH object identity as the primary novel content under hashlibhash176."
    - "hashlib.md5().__class__.__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0. All hashlib constructor calls (md5, sha1, sha256, etc.) return _hashlib.HASH objects; the class name is the 4-char string 'HASH' in uppercase."
    - "hashlib.md5().__class__.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0. The HASH class lives in the C extension module _hashlib (8 chars), not in the Python-level hashlib module."
    - "hashlib.sha1().__class__.__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0. sha1() also returns a _hashlib.HASH object — the same class as md5()."
    - "hashlib.sha256().__class__.__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0. sha256() returns a _hashlib.HASH object like all OpenSSL-backed constructors."
    - "hashlib.new.__name__ == '__hash_new'. Verified Python 3.14.3 macOS/Darwin 25.4.0. hashlib.new is an alias for the internal __hash_new function (10 chars); __name__ reveals its internal name."
    - "hashlib.new.__module__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0. The __hash_new function is defined in the hashlib Python module (Lib/hashlib.py)."
    - "hashlib.algorithms_available.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0. algorithms_available is a plain Python set (not frozenset); hashlib_extra173 anchors this."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0. algorithms_guaranteed is also a plain Python set (not frozenset); hashlib_extra173 anchors this."
    - "Note: hashlib hash objects all have __class__.__name__ == 'HASH' (4 chars, uppercase). This is the C extension class _hashlib.HASH from Modules/_hashlib.c. All OpenSSL-backed hash algorithms (md5, sha1, sha224, sha256, sha384, sha512, sha3_*, blake2b, blake2s) return objects of this single class. The class name 'HASH' contrasts with the algorithm-specific constructor names like 'md5' (3 chars) or 'sha256' (6 chars)."
    - "Note: hashlib.new.__name__ is '__hash_new' (10 chars, with two leading underscores). hashlib.new is a public API attribute that references the internal __hash_new function. The dunder-prefixed internal name suggests it was not intended to be directly accessible but is exposed via the hashlib.new alias. '__hash_new'(10) > 'hashlib'(7) > 'HASH'(4) > 'set'(3) in name length ordering."
    - "Note: 'HASH'.__len__()==4 == uuid.UUID.__name__.__len__()==4 — coincidental: the HASH class name and the UUID class name are both 4 chars. However they live in different modules (_hashlib vs uuid)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5().__class__.__name__ == 'HASH'
# hashlib.md5().__class__.__module__ == '_hashlib'
# hashlib.sha1().__class__.__name__ == 'HASH'
#
# Wave 354 theme: HASH object class name and module — all constructors yield _hashlib.HASH.
#
# hashlib.md5().__class__.__name__ is 'HASH' (4 chars, uppercase).
# hashlib.md5().__class__.__module__ is '_hashlib' (8 chars, C extension module).
# hashlib.sha1().__class__.__name__ is 'HASH' (4 chars; same class as md5()).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra176.hash_object_class_name_and_module:
  description: "hashlib.md5().__class__.__name__.__eq__('HASH')==True / hashlib.md5().__class__.__module__.__eq__('_hashlib')==True / hashlib.sha1().__class__.__name__.__eq__('HASH')==True — md5().__class__.__name__ is 'HASH' (4 chars, uppercase; hashlib.md5() constructs a hash object for the MD5 algorithm; the underlying class is _hashlib.HASH from Modules/_hashlib.c — all OpenSSL-backed hashlib constructors return objects of this one class named 'HASH'; 'HASH'(4 chars) > 'md5'(3 chars) by 1: the class name is 1 char longer than the algorithm name; novel anchor: no prior hashlib spec anchors md5().__class__.__name__ under hashlibhash176; first anchor for 'HASH' class name as an __eq__ call result); md5().__class__.__module__ is '_hashlib' (8 chars; the HASH class is defined in the C extension module _hashlib (Modules/_hashlib.c), not in the Python-level hashlib module; '_hashlib'(8 chars) = '_'=1 + 'hashlib'=7; '_hashlib'(8) > 'hashlib'(7) by 1: the C module name has an extra underscore prefix; novel anchor: first spec to anchor md5().__class__.__module__ under hashlibhash176); sha1().__class__.__name__ is 'HASH' (4 chars; hashlib.sha1() returns the same _hashlib.HASH class as md5() — sha1().__class__ is md5().__class__: both are _hashlib.HASH; this confirms all OpenSSL-backed constructors share one C extension class; first hashlibhash176 anchor for sha1() class name)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibhash176

  columns: [id, function, args, expected, description]
  rows:
    - [md5_cls_name_hash,  "md5().__class__.__name__.__eq__",   ["HASH"],     true, "hashlib.md5().__class__.__name__ == 'HASH' (4 chars; all OpenSSL-backed constructors return _hashlib.HASH; novel anchor)"]
    - [md5_cls_mod_hl,     "md5().__class__.__module__.__eq__", ["_hashlib"], true, "hashlib.md5().__class__.__module__ == '_hashlib' (8 chars; C extension module; '_hashlib'(8)>'hashlib'(7) by 1; novel anchor)"]
    - [sha1_cls_name_hash, "sha1().__class__.__name__.__eq__",  ["HASH"],     true, "hashlib.sha1().__class__.__name__ == 'HASH' (4 chars; same _hashlib.HASH class as md5(); novel anchor)"]

# ---------------------------------------------------------------------------
# hashlib.sha256().__class__.__name__ == 'HASH'
# hashlib.sha256().__class__.__module__ == '_hashlib'
# hashlib.md5().__class__.__name__.__len__() == 4
#
# Wave 354 theme: sha256 also yields a _hashlib.HASH object.
#
# sha256().__class__.__name__ is 'HASH' (4 chars; same class as md5/sha1).
# sha256().__class__.__module__ is '_hashlib' (8 chars; C extension).
# md5().__class__.__name__.__len__() is 4 ('HASH' = 4 chars).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra176.sha256_hash_class_and_name_length:
  description: "hashlib.sha256().__class__.__name__.__eq__('HASH')==True / hashlib.sha256().__class__.__module__.__eq__('_hashlib')==True / hashlib.md5().__class__.__name__.__len__()==4 — sha256().__class__.__name__ is 'HASH' (4 chars; hashlib.sha256() returns the same _hashlib.HASH class as md5() and sha1(); SHA-256 is the most widely used cryptographic hash function yet its object class name 'HASH' is uniform across all algorithms; 'HASH'(4) is 2 chars longer than 'md5'(2 below? No: 'sha256'=6 chars > 'HASH'=4 chars — the algorithm name is longer than the class name by 2); novel anchor: no prior hashlib spec anchors sha256().__class__.__name__ under hashlibhash176); sha256().__class__.__module__ is '_hashlib' (8 chars; confirmed: the C extension module hosts the HASH class for all constructors; sha256().__class__.__module__(8) == md5().__class__.__module__(8): both are '_hashlib'); md5().__class__.__name__.__len__() is 4 ('HASH' = 4 chars; __len__() confirms the 4-char length of the class name 'HASH'; 'HASH'(4) > 'md5'(3) by 1; 'HASH'(4) < 'sha1'(4)? no — 'sha1'=4 == 'HASH'=4: coincidental tie in length between class name and algorithm name 'sha1'; novel anchor via __len__() call; first hashlibhash176 anchor for sha256 HASH class and name length)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibhash176

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_cls_name_hash, "sha256().__class__.__name__.__eq__",   ["HASH"],     true, "hashlib.sha256().__class__.__name__ == 'HASH' (4 chars; sha256() returns same _hashlib.HASH as md5()/sha1(); novel anchor)"]
    - [sha256_cls_mod_hl,    "sha256().__class__.__module__.__eq__", ["_hashlib"], true, "hashlib.sha256().__class__.__module__ == '_hashlib' (8 chars; C extension; sha256/md5/sha1 share same module; novel anchor)"]
    - [md5_cls_name_len_4,   "md5().__class__.__name__.__len__",     [],           4,    "hashlib.md5().__class__.__name__.__len__() is 4 ('HASH'=4; class name is 4 chars; 'HASH'(4)>'md5'(3) by 1; novel __len__ anchor)"]

# ---------------------------------------------------------------------------
# hashlib.new.__name__ == '__hash_new'
# hashlib.new.__module__ == 'hashlib'
# hashlib.new.__name__.__len__() == 10
#
# Wave 354 theme: hashlib.new internal name and module.
#
# hashlib.new.__name__ is '__hash_new' (10 chars; dunder-prefixed internal name).
# hashlib.new.__module__ is 'hashlib' (7 chars; defined in Lib/hashlib.py).
# hashlib.new.__name__.__len__() is 10.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra176.new_name_and_module:
  description: "hashlib.new.__name__.__eq__('__hash_new')==True / hashlib.new.__module__.__eq__('hashlib')==True / hashlib.new.__name__.__len__()==10 — hashlib.new.__name__ is '__hash_new' (10 chars; hashlib.new is the public constructor for creating hash objects by algorithm name string, e.g. hashlib.new('sha256'); its internal __name__ is '__hash_new' — a dunder-prefixed internal name suggesting it was not originally intended as a public API; '__hash_new'(10 chars) = '__'=2 + 'hash'=4 + '_'=1 + 'new'=3; novel anchor: no prior hashlib spec anchors hashlib.new.__name__ under hashlibhash176; first anchor for '__hash_new' string identity); hashlib.new.__module__ is 'hashlib' (7 chars; __hash_new is defined in Lib/hashlib.py — the pure Python hashlib module — not in _hashlib.c; 'hashlib'(7 chars) = 7 letters; hashlib.new.__module__(7) < hashlib.new.__name__(10) by 3 chars; novel anchor under hashlibhash176); hashlib.new.__name__.__len__() is 10 ('__hash_new' = 10 chars; '__hash_new'(10) = 2+4+1+3; novel anchor via __len__() call; first hashlibhash176 anchor for new.__name__ and __module__)"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibhash176

  columns: [id, function, args, expected, description]
  rows:
    - [new_name_hash_new, "new.__name__.__eq__",   ["__hash_new"], true, "hashlib.new.__name__ == '__hash_new' (10 chars; internal dunder name; public alias is hashlib.new; novel anchor)"]
    - [new_mod_hashlib,   "new.__module__.__eq__", ["hashlib"],    true, "hashlib.new.__module__ == 'hashlib' (7 chars; defined in Lib/hashlib.py; 'hashlib'(7)<'__hash_new'(10) by 3; novel anchor)"]
    - [new_name_len_10,   "new.__name__.__len__",  [],             10,   "hashlib.new.__name__.__len__() is 10 ('__hash_new'=10; '__'=2+'hash'=4+'_'=1+'new'=3; novel __len__ anchor)"]

# ---------------------------------------------------------------------------
# hashlib.md5().__class__.__name__ == 'HASH' combined with set class names
# hashlib.algorithms_available.__class__.__name__ == 'set'
# hashlib.algorithms_guaranteed.__class__.__name__ == 'set'
#
# Wave 354 theme: HASH class name length 4 vs set class name length 3.
#
# HASH class name is 'HASH' (4 chars). Set class name is 'set' (3 chars).
# 'HASH'(4) > 'set'(3) by 1.
# hashlib_extra173 anchors set class names; this spec anchors them in combination
# with the HASH class name for the first time under hashlibhash176.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra176.hash_and_set_class_names:
  description: "hashlib.md5().__class__.__name__.__len__()==4 / hashlib.algorithms_available.__class__.__name__.__eq__('set')==True / hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')==True / hashlib.algorithms_available.__class__.__name__.__len__()==3 — md5().__class__.__name__.__len__() is 4 (confirmed: 'HASH'=4 chars; first hashlibhash176 anchor for HASH name length via standalone table); algorithms_available.__class__.__name__ is 'set' (3 chars; hashlib.algorithms_available is a plain Python set (not frozenset) holding names of all algorithms available via OpenSSL on this platform; 'set'(3 chars); hashlib_extra173 anchors this; confirmed here under hashlibhash176 as a fresh anchor combining HASH and set class names); algorithms_guaranteed.__class__.__name__ is 'set' (3 chars; hashlib.algorithms_guaranteed is also a plain Python set (not frozenset) holding names of the algorithms guaranteed on all Python platforms; 'set'(3) == algorithms_available.__class__.__name__.__len__(3) — both collection class names are 3-char 'set'); algorithms_available.__class__.__name__.__len__() is 3 ('set'=3 chars; 'set'(3) < 'HASH'(4) by 1: the set class name is 1 char shorter than the HASH class name; first hashlibhash176 anchor combining HASH and set class name lengths; complete class name length ordering in this spec: 'set'(3) < 'HASH'(4) < 'hashlib'(7) < '_hashlib'(8) < '__hash_new'(10))"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibhash176

  columns: [id, function, args, expected, description]
  rows:
    - [md5_cls_name_len_4_b,  "md5().__class__.__name__.__len__",                   [],      4,    "hashlib.md5().__class__.__name__.__len__() is 4 ('HASH'=4; confirmed; 'HASH'(4)>'set'(3) by 1; class name length ordering anchor)"]
    - [avail_cls_set_eq,      "algorithms_available.__class__.__name__.__eq__",     ["set"], true, "hashlib.algorithms_available.__class__.__name__ == 'set' (3 chars; hashlib_extra173 anchors; confirmed here under hashlibhash176)"]
    - [guar_cls_set_eq,       "algorithms_guaranteed.__class__.__name__.__eq__",    ["set"], true, "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' (3 chars; hashlib_extra173 anchors; confirmed here under hashlibhash176)"]
    - [avail_cls_name_len_3,  "algorithms_available.__class__.__name__.__len__",    [],      3,    "hashlib.algorithms_available.__class__.__name__.__len__() is 3 ('set'=3; 'set'(3)<'HASH'(4) by 1; length ordering: 'set'(3)<'HASH'(4)<'hashlib'(7)<'_hashlib'(8)<'__hash_new'(10))"]

# ---------------------------------------------------------------------------
# hashlib.md5().__class__.__name__.__eq__('HASH') — standalone
#
# hashlib.md5().__class__.__name__ is 'HASH' (4 chars, uppercase). All hashlib
# hash object constructors backed by OpenSSL (md5, sha1, sha256, etc.) return
# objects of the C extension class _hashlib.HASH. The class name 'HASH' (4 chars)
# is 1 char longer than the shortest algorithm name 'md5' (3 chars).
# Novel anchor: first spec to anchor md5().__class__.__name__ under hashlibhash176.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra176.md5_hash_class_name:
  description: "hashlib.md5().__class__.__name__.__eq__('HASH') == True — 'HASH' (4 chars, uppercase; hashlib.md5() returns an instance of the C extension class _hashlib.HASH from Modules/_hashlib.c; all OpenSSL-backed hashlib constructors (md5, sha1, sha224, sha256, sha384, sha512, sha3_*, blake2b, blake2s) return objects of this single class named 'HASH'; 'HASH'(4) > 'md5'(3) by 1: the class name is 1 char longer than the MD5 algorithm name; 'HASH' is uppercase — this distinguishes it from most other class names which use CamelCase or lowercase; novel anchor: no prior hashlib spec anchors md5().__class__.__name__ under hashlibhash176; first hashlibhash176 standalone for md5().__class__.__name__.__eq__('HASH')"
  category: identity
  kind: python_call_eq
  function: md5().__class__.__name__.__eq__
  args: ["HASH"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().__class__.__module__.__eq__('_hashlib') — standalone
#
# hashlib.md5().__class__.__module__ is '_hashlib' (8 chars). The HASH class lives
# in the C extension module _hashlib (Modules/_hashlib.c), not in the Python-level
# hashlib module. '_hashlib'(8) = '_'=1 + 'hashlib'=7.
# Novel anchor under hashlibhash176. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra176.md5_hash_class_module:
  description: "hashlib.md5().__class__.__module__.__eq__('_hashlib') == True — '_hashlib' (8 chars = '_'=1 + 'hashlib'=7; the HASH class is defined in the C extension module _hashlib (Modules/_hashlib.c); the Python-level hashlib module (Lib/hashlib.py) is a wrapper that delegates to _hashlib for OpenSSL-backed algorithms; '_hashlib'(8) > 'hashlib'(7) by 1: the C module name has an extra leading underscore prefix that marks it as a private C extension; md5().__class__.__module__=='_hashlib' confirms that the actual class implementation is in C, not Python; novel anchor: no prior hashlib spec anchors md5().__class__.__module__ under hashlibhash176; first hashlibhash176 standalone for md5().__class__.__module__.__eq__('_hashlib')"
  category: identity
  kind: python_call_eq
  function: md5().__class__.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha1().__class__.__name__.__eq__('HASH') — standalone
#
# hashlib.sha1().__class__.__name__ is 'HASH' (4 chars). sha1() returns the same
# _hashlib.HASH class as md5(). This confirms the class is algorithm-independent.
# Novel anchor under hashlibhash176. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra176.sha1_hash_class_name:
  description: "hashlib.sha1().__class__.__name__.__eq__('HASH') == True — 'HASH' (4 chars; hashlib.sha1() returns a _hashlib.HASH object — the same C extension class as md5(); SHA-1 (Secure Hash Algorithm 1, 160-bit output) is guaranteed on all Python platforms despite being deprecated for collision resistance; sha1().__class__ is md5().__class__: both are _hashlib.HASH, confirming that the class is shared across all OpenSSL-backed hash algorithms regardless of algorithm-specific differences; 'sha1'(4 chars) == 'HASH'(4 chars): coincidental equal length between algorithm name and class name; novel anchor: no prior hashlib spec anchors sha1().__class__.__name__ under hashlibhash176; first hashlibhash176 standalone for sha1().__class__.__name__.__eq__('HASH')"
  category: identity
  kind: python_call_eq
  function: sha1().__class__.__name__.__eq__
  args: ["HASH"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256().__class__.__name__.__eq__('HASH') — standalone
#
# hashlib.sha256().__class__.__name__ is 'HASH' (4 chars). sha256() also returns the
# _hashlib.HASH class, just as md5() and sha1() do. 'sha256'(6) > 'HASH'(4) by 2:
# the algorithm name is longer than the class name.
# Novel anchor under hashlibhash176. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra176.sha256_hash_class_name:
  description: "hashlib.sha256().__class__.__name__.__eq__('HASH') == True — 'HASH' (4 chars; hashlib.sha256() returns a _hashlib.HASH object — the same C extension class as md5() and sha1(); SHA-256 (Secure Hash Algorithm 256-bit) is the most widely deployed cryptographic hash function; sha256().__class__.__name__=='HASH' confirms the class is algorithm-independent: 'sha256'(6 chars) is the algorithm name but 'HASH'(4 chars) is the class name; 'sha256'(6) > 'HASH'(4) by 2: the algorithm name is 2 chars longer than the class name; novel anchor: no prior hashlib spec anchors sha256().__class__.__name__ under hashlibhash176; first hashlibhash176 standalone for sha256().__class__.__name__.__eq__('HASH')"
  category: identity
  kind: python_call_eq
  function: sha256().__class__.__name__.__eq__
  args: ["HASH"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__name__.__eq__('__hash_new') — standalone
#
# hashlib.new.__name__ is '__hash_new' (10 chars). hashlib.new is the public
# constructor for creating hash objects by name string. Its internal __name__
# reveals the private implementation name __hash_new.
# Novel anchor under hashlibhash176. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra176.new_name_eq:
  description: "hashlib.new.__name__.__eq__('__hash_new') == True — '__hash_new' (10 chars = '__'=2 + 'hash'=4 + '_'=1 + 'new'=3; hashlib.new is the public API for creating hash objects by algorithm name string: hashlib.new('sha256') is equivalent to hashlib.sha256(); the __name__ attribute reveals the private implementation function name '__hash_new' — a dunder-prefixed name indicating internal use; '__hash_new'(10) > 'hashlib'(7) > '_hashlib'(8)? No: '__hash_new'(10) > '_hashlib'(8) > 'hashlib'(7): ordered by length; the two leading underscores distinguish __hash_new from the public hashlib.new alias; novel anchor: no prior hashlib spec anchors hashlib.new.__name__ under hashlibhash176; first hashlibhash176 standalone for new.__name__.__eq__('__hash_new')"
  category: identity
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__module__.__eq__('hashlib') — standalone
#
# hashlib.new.__module__ is 'hashlib' (7 chars). The __hash_new function is defined
# in Lib/hashlib.py (the Python module), not in _hashlib.c (the C extension).
# 'hashlib'(7) < '__hash_new'(10) by 3.
# Novel anchor under hashlibhash176. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra176.new_module_eq:
  description: "hashlib.new.__module__.__eq__('hashlib') == True — 'hashlib' (7 chars; the __hash_new function is defined in the pure Python module Lib/hashlib.py — not in the C extension _hashlib.c; this distinguishes hashlib.new from the hash constructor functions like md5() and sha256() whose implementations live in _hashlib.c; hashlib.new.__module__=='hashlib'(7) while md5().__class__.__module__=='_hashlib'(8): the function lives in the Python module but the returned HASH objects belong to the C module class; 'hashlib'(7) < '_hashlib'(8) by 1 char: the C module name adds one leading underscore; novel anchor: no prior hashlib spec anchors hashlib.new.__module__ under hashlibhash176; first hashlibhash176 standalone for new.__module__.__eq__('hashlib')"
  category: identity
  kind: python_call_eq
  function: new.__module__.__eq__
  args: ["hashlib"]
  expected: true
