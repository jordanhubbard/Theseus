spec: pathlib_extra298
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "pathlib.Path('/nonexistent/path/xyz123').stat() raises FileNotFoundError — stat requires the path to exist."
    - "pathlib.Path('/nonexistent/path/xyz123').read_text() raises FileNotFoundError."
    - "pathlib.Path('/nonexistent/path/xyz123').read_bytes() raises FileNotFoundError."
    - "pathlib.Path('/nonexistent/path/xyz123').open() raises FileNotFoundError."
    - "pathlib.Path('').absolute().__class__.__name__ == 'PosixPath' on macOS/POSIX systems."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath'; __module__ == 'pathlib'; __bases__[0].__name__ == 'PurePath'."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath'; __module__ == 'pathlib'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# FileNotFoundError: filesystem operations on non-existent paths
#
# stat(), read_text(), read_bytes(), and open() all require the path to exist.
# All raise FileNotFoundError when the path does not exist on the filesystem.
# ---------------------------------------------------------------------------

invariant pathlib_extra298.path_stat_nonexistent_raises:
  description: "pathlib.Path('/nonexistent/path/xyz123').stat() raises FileNotFoundError — path does not exist"
  category: errors
  kind: python_call_raises
  function: "Path('/nonexistent/path/xyz123').stat"
  args: []
  raises: FileNotFoundError

invariant pathlib_extra298.path_read_text_nonexistent_raises:
  description: "pathlib.Path('/nonexistent/path/xyz123').read_text() raises FileNotFoundError — path does not exist"
  category: errors
  kind: python_call_raises
  function: "Path('/nonexistent/path/xyz123').read_text"
  args: []
  raises: FileNotFoundError

invariant pathlib_extra298.path_read_bytes_nonexistent_raises:
  description: "pathlib.Path('/nonexistent/path/xyz123').read_bytes() raises FileNotFoundError — path does not exist"
  category: errors
  kind: python_call_raises
  function: "Path('/nonexistent/path/xyz123').read_bytes"
  args: []
  raises: FileNotFoundError

invariant pathlib_extra298.path_open_nonexistent_raises:
  description: "pathlib.Path('/nonexistent/path/xyz123').open() raises FileNotFoundError — path does not exist"
  category: errors
  kind: python_call_raises
  function: "Path('/nonexistent/path/xyz123').open"
  args: []
  raises: FileNotFoundError

# ---------------------------------------------------------------------------
# Path('').absolute() returns a PosixPath on macOS/POSIX
#
# The empty string path resolves to the current working directory when
# absolute() is called. On POSIX systems (macOS, Linux), the result is
# a PosixPath instance whose __class__.__name__ == 'PosixPath'.
# ---------------------------------------------------------------------------

invariant pathlib_extra298.empty_path_absolute_class_name:
  description: "pathlib.Path('').absolute().__class__.__name__ == 'PosixPath' on macOS/POSIX"
  category: class_identity
  kind: python_call_eq
  function: "Path('').absolute().__class__.__name__.__eq__"
  args: ["PosixPath"]
  expected: true

# ---------------------------------------------------------------------------
# PurePosixPath class metadata
#
# PurePosixPath.__name__, __module__, and __bases__[0].__name__ are stable
# class identity facts that do not depend on the filesystem.
# ---------------------------------------------------------------------------

invariant pathlib_extra298.pureposixpath_name:
  description: "pathlib.PurePosixPath.__name__ == 'PurePosixPath'"
  category: class_identity
  kind: python_call_eq
  function: PurePosixPath.__name__.__eq__
  args: ["PurePosixPath"]
  expected: true

invariant pathlib_extra298.pureposixpath_module:
  description: "pathlib.PurePosixPath.__module__ == 'pathlib'"
  category: class_identity
  kind: python_call_eq
  function: PurePosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra298.pureposixpath_base_name:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath directly subclasses PurePath"
  category: class_identity
  kind: python_call_eq
  function: PurePosixPath.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "PurePath"

# ---------------------------------------------------------------------------
# PureWindowsPath class metadata
#
# PureWindowsPath is available on all platforms for pure (non-filesystem)
# path manipulation. Its class metadata is stable cross-platform.
# ---------------------------------------------------------------------------

invariant pathlib_extra298.purewindowspath_name:
  description: "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath'"
  category: class_identity
  kind: python_call_eq
  function: PureWindowsPath.__name__.__eq__
  args: ["PureWindowsPath"]
  expected: true

invariant pathlib_extra298.purewindowspath_module:
  description: "pathlib.PureWindowsPath.__module__ == 'pathlib'"
  category: class_identity
  kind: python_call_eq
  function: PureWindowsPath.__module__.__eq__
  args: ["pathlib"]
  expected: true
