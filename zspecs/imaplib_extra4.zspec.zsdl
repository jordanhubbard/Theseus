spec: imaplib_extra4
version: ">=3.9"
backend: python_module(imaplib)

docs: https://docs.python.org/3/library/imaplib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/imaplib.html — Python imaplib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/imaplib.py"
  notes:
    - "This spec extends imaplib.zspec.zsdl through imaplib_extra3.zspec.zsdl."
    - "imaplib.zspec.zsdl covers: class names table (IMAP4/IMAP4_SSL/IMAP4_stream/error/abort/readonly), IMAP4.__module__, IMAP4.port=143, IMAP4_SSL.port=993, abort/__bases__, readonly/__bases__, method names."
    - "imaplib_extra.zspec.zsdl covers: IMAP4/__name__/__module__, IMAP4_SSL/__name__/__bases__[0], IMAP4.error/abort/readonly __name__ and hierarchy, method names."
    - "imaplib_extra2.zspec.zsdl covers: IMAP4_stream/__name__/__module__/__bases__[0], IMAP4_SSL/__module__, module-level error/abort/readonly __name__, error/abort hierarchy, port type checks."
    - "imaplib_extra3.zspec.zsdl covers: __qualname__ for IMAP4/IMAP4_SSL/IMAP4_stream and nested error/abort/readonly; IMAP4_PORT and IMAP4_SSL_PORT constants and type checks."
    - "This spec adds: metatype checks (__class__.__name__ == 'type') for IMAP4, IMAP4_SSL, IMAP4_stream, and the nested exception classes IMAP4.error/abort/readonly — no prior spec covers these."
    - "It also adds __bases__.__len__ checks for IMAP4 (1 base: object), IMAP4_SSL (1 base: IMAP4), IMAP4_stream (1 base: IMAP4)."
    - "It also adds __module__ checks for the nested IMAP4.error, IMAP4.abort, and IMAP4.readonly classes — no prior spec covers these."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Metatype checks — IMAP4, IMAP4_SSL, IMAP4_stream
# Each is a plain Python class whose metaclass is 'type'.
# No prior imaplib spec checks __class__.__name__ for these classes.
# ---------------------------------------------------------------------------

table imaplib_extra4.class_metatypes:
  kind: python_call_eq
  category: metatypes
  id_prefix: metatype

  columns: [id, function, args, expected]
  rows:
    - [IMAP4,        IMAP4.__class__.__name__.__eq__,        ["type"], true]
    - [IMAP4_SSL,    IMAP4_SSL.__class__.__name__.__eq__,    ["type"], true]
    - [IMAP4_stream, IMAP4_stream.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# Nested exception class metatypes — IMAP4.error, IMAP4.abort, IMAP4.readonly
# No prior spec checks __class__.__name__ for nested exception classes.
# ---------------------------------------------------------------------------

invariant imaplib_extra4.IMAP4.error.metatype:
  description: "imaplib.IMAP4.error.__class__.__name__ == 'type' — nested exception class is a plain type"
  category: metatypes
  kind: python_call_eq
  function: IMAP4.error.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant imaplib_extra4.IMAP4.abort.metatype:
  description: "imaplib.IMAP4.abort.__class__.__name__ == 'type' — nested exception class is a plain type"
  category: metatypes
  kind: python_call_eq
  function: IMAP4.abort.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant imaplib_extra4.IMAP4.readonly.metatype:
  description: "imaplib.IMAP4.readonly.__class__.__name__ == 'type' — nested exception class is a plain type"
  category: metatypes
  kind: python_call_eq
  function: IMAP4.readonly.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# __bases__ length checks — IMAP4, IMAP4_SSL, IMAP4_stream
# No prior spec checks __len__ of __bases__ for these three classes.
# ---------------------------------------------------------------------------

invariant imaplib_extra4.IMAP4.bases_len:
  description: "len(imaplib.IMAP4.__bases__) == 1 — IMAP4 has exactly one direct base class (object)"
  category: hierarchy
  kind: python_call_eq
  function: IMAP4.__bases__.__len__
  args: []
  expected: 1

invariant imaplib_extra4.IMAP4_SSL.bases_len:
  description: "len(imaplib.IMAP4_SSL.__bases__) == 1 — IMAP4_SSL has exactly one direct base class (IMAP4)"
  category: hierarchy
  kind: python_call_eq
  function: IMAP4_SSL.__bases__.__len__
  args: []
  expected: 1

invariant imaplib_extra4.IMAP4_stream.bases_len:
  description: "len(imaplib.IMAP4_stream.__bases__) == 1 — IMAP4_stream has exactly one direct base class (IMAP4)"
  category: hierarchy
  kind: python_call_eq
  function: IMAP4_stream.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Nested exception class __module__ checks
# No prior spec checks __module__ for the nested IMAP4.error/abort/readonly.
# (imaplib_extra2 checks module-level error/abort/readonly __name__ only.)
# ---------------------------------------------------------------------------

invariant imaplib_extra4.IMAP4.error.module:
  description: "imaplib.IMAP4.error.__module__ == 'imaplib' — nested error exception is defined in imaplib"
  category: class_modules
  kind: python_call_eq
  function: IMAP4.error.__module__.__eq__
  args: ["imaplib"]
  expected: true

invariant imaplib_extra4.IMAP4.abort.module:
  description: "imaplib.IMAP4.abort.__module__ == 'imaplib' — nested abort exception is defined in imaplib"
  category: class_modules
  kind: python_call_eq
  function: IMAP4.abort.__module__.__eq__
  args: ["imaplib"]
  expected: true

invariant imaplib_extra4.IMAP4.readonly.module:
  description: "imaplib.IMAP4.readonly.__module__ == 'imaplib' — nested readonly exception is defined in imaplib"
  category: class_modules
  kind: python_call_eq
  function: IMAP4.readonly.__module__.__eq__
  args: ["imaplib"]
  expected: true
