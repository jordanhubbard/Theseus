    - ["ab1636ct014", "abc.__name__.__eq__",                                        ["abc"],             true]
    - ["ab1636ct015", "abc.__spec__.__name__.__eq__",                               ["abc"],             true]
    - ["ab1636ct016", "abc.ABCMeta.__dict__.__contains__",                          ["__instancecheck__"], true]
    - ["ab1636ct017", "abc.ABCMeta.__dict__.__contains__",                          ["__subclasscheck__"], true]
    - ["ab1636ct018", "abc.ABCMeta.__dict__.__contains__",                          ["register"],        true]
    - ["ab1636ct019", "abc.ABC.__class__.__name__.__eq__",                          ["ABCMeta"],         true]
    - ["ab1636ct020", "abc.abstractmethod.__isabstractmethod__.__eq__",             [true],              true]
    - ["ab1636ct021", "abc.ABC.__dict__.__contains__",                              ["__subclasshook__"], false]
    - ["ab1636ct022", "abc.ABCMeta.__dict__.__contains__",                          ["__subclasshook__"], false]
    - ["ab1636ct023", "abc.abstractmethod.__dict__.__contains__",                   ["__isabstractmethod__"], true]
    - ["ab1636ct024", "abc.abstractmethod.__dict__.__contains__",                   ["__subclasshook__"], false]
    - ["ab1636ct025", "abc.get_cache_token.__dict__.__contains__",                  ["__subclasshook__"], false]
