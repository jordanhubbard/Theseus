    - ["ab1636ct006", "abc.get_cache_token.__qualname__.__eq__",                    ["get_cache_token"], true]
    - ["ab1636ct007", "abc.__dict__.__contains__",                                  ["get_cache_token"], true]
    - ["ab1636ct008", "abc.__dict__.__contains__",                                  ["ABCMeta"],         true]
    - ["ab1636ct009", "abc.__dict__.__contains__",                                  ["ABC"],             true]
    - ["ab1636ct010", "abc.__dict__.__contains__",                                  ["abstractmethod"],  true]
