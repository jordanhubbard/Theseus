spec: abc_extra1636
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html — abc: Abstract Base Classes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "behavioral invariants for ABC virtual subclassing protocol"
    - "Wave 1636: theme is __subclasshook__, __instancecheck__, __subclasscheck__ — the ABC virtual subclassing protocol."
    - "abc.ABCMeta defines both __instancecheck__ and __subclasscheck__ in its own __dict__ — these are the entry points for isinstance() and issubclass() delegation."
    - "abc.ABCMeta does NOT define __subclasshook__ in its own __dict__; __subclasshook__ is defined on individual ABC subclasses, not on the metaclass itself."
    - "abc.ABC is a plain helper class whose metaclass is ABCMeta; ABC itself does not define __subclasshook__ in its own __dict__."
    - "The default __subclasshook__ classmethod (inherited from ABC or defined by each ABC) returns NotImplemented to defer to the normal MRO-based subclass check."
    - "ABCMeta.register() stores virtual subclass relationships in an internal registry; after MyABC.register(SomeClass), isinstance(SomeClass(), MyABC) returns True."
    - "abc.get_cache_token() returns an int that increments each time the ABC inheritance cache is invalidated (i.e. each time register() is called)."
    - "ABCMeta._dump_registry(), _abc_registry_clear(), _abc_caches_clear() are internal diagnostic/testing methods present on ABCMeta instances in CPython."
    - "abstractmethod.__isabstractmethod__ == True at class definition time — the decorator marks itself abstract so ABCMeta can detect it."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: ABCMeta defines __instancecheck__ and __subclasscheck__
#
# ABCMeta is the metaclass that powers the ABC virtual subclassing protocol.
# It defines __instancecheck__ and __subclasscheck__ in its own __dict__ so
# that isinstance() and issubclass() calls on ABC classes are intercepted and
# can consult the virtual-subclass registry.
# ABCMeta does NOT define __subclasshook__ — that is for individual ABCs to
# define; ABCMeta only calls it during __subclasscheck__.
# ---------------------------------------------------------------------------

table abc_extra1636.abcmeta_has_instancecheck:
  description: "abc.ABCMeta defines __instancecheck__ and __subclasscheck__ in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1636mi

  columns: [id, function, args, expected]
  rows:
    - ["ab1636mi001", "abc.ABCMeta.__dict__.__contains__",              ["__instancecheck__"],   true]
    - ["ab1636mi002", "abc.ABCMeta.__dict__.__contains__",              ["__subclasscheck__"],   true]
    - ["ab1636mi003", "abc.ABCMeta.__dict__.__contains__",              ["__subclasshook__"],    false]
    - ["ab1636mi004", "abc.ABCMeta.__instancecheck__.__name__.__eq__",  ["__instancecheck__"],   true]
    - ["ab1636mi005", "abc.ABCMeta.__subclasscheck__.__name__.__eq__",  ["__subclasscheck__"],   true]
    - ["ab1636mi006", "abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__", ["function"],   true]
    - ["ab1636mi007", "abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__", ["function"],   true]
    - ["ab1636mi008", "abc.ABCMeta.__name__.__eq__",                    ["ABCMeta"],             true]
    - ["ab1636mi009", "abc.ABCMeta.__module__.__eq__",                  ["abc"],                 true]
    - ["ab1636mi010", "abc.ABCMeta.__dict__.__contains__",              ["register"],            true]
    - ["ab1636mi011", "abc.ABCMeta.__dict__.__contains__",              ["__abstractmethods__"], false]
    - ["ab1636mi012", "abc.ABCMeta.__bases__.__getitem__",              [0],                     null]
    - ["ab1636mi013", "abc.ABCMeta.__class__.__name__.__eq__",          ["type"],                true]
    - ["ab1636mi014", "abc.ABCMeta.__dict__.__contains__",              ["__init__"],            false]
    - ["ab1636mi015", "abc.ABCMeta.__dict__.__contains__",              ["__new__"],             true]
    - ["ab1636mi016", "abc.ABCMeta.__dict__.__contains__",              ["__or__"],              false]
    - ["ab1636mi017", "abc.ABCMeta.__dict__.__contains__",              ["__ror__"],             false]
    - ["ab1636mi018", "abc.ABCMeta.__instancecheck__.__qualname__.__contains__", ["ABCMeta"],   true]
    - ["ab1636mi019", "abc.ABCMeta.__subclasscheck__.__qualname__.__contains__", ["ABCMeta"],   true]
    - ["ab1636mi020", "abc.ABCMeta.__dict__.__contains__",              ["_dump_registry"],      true]
    - ["ab1636mi021", "abc.ABCMeta.__dict__.__contains__",              ["_abc_registry_clear"], false]
    - ["ab1636mi022", "abc.ABCMeta.__dict__.__contains__",              ["_abc_caches_clear"],   false]
    - ["ab1636mi023", "abc.ABCMeta.__dict__.__contains__",              ["__doc__"],             false]
    - ["ab1636mi024", "abc.ABCMeta.__dict__.__contains__",              ["__subclasses__"],      false]
    - ["ab1636mi025", "abc.ABCMeta.__dict__.__contains__",              ["mro"],                 false]

# ---------------------------------------------------------------------------
# Table 2: abc.ABC and abc.abstractmethod do not define ABC hooks
#
# abc.ABC is the helper base class (metaclass=ABCMeta). It does NOT define
# __subclasshook__, __instancecheck__, or __subclasscheck__ in its own
# __dict__. Those come from its metaclass (ABCMeta) at a different level.
# abc.abstractmethod is a decorator class; it also defines none of these hooks.
# abc.abstractmethod does define __isabstractmethod__ = True, which ABCMeta
# reads when constructing a new class to build __abstractmethods__.
# ---------------------------------------------------------------------------

table abc_extra1636.abc_class_no_hooks:
  description: "abc.ABC and abc.abstractmethod do not define ABC virtual subclassing hooks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1636ah

  columns: [id, function, args, expected]
  rows:
    - ["ab1636ah001", "abc.ABC.__dict__.__contains__",                  ["__subclasshook__"],    false]
    - ["ab1636ah002", "abc.ABC.__dict__.__contains__",                  ["__instancecheck__"],   false]
    - ["ab1636ah003", "abc.ABC.__dict__.__contains__",                  ["__subclasscheck__"],   false]
    - ["ab1636ah004", "abc.abstractmethod.__dict__.__contains__",       ["__subclasshook__"],    false]
    - ["ab1636ah005", "abc.abstractmethod.__dict__.__contains__",       ["__instancecheck__"],   false]
    - ["ab1636ah006", "abc.abstractmethod.__dict__.__contains__",       ["__subclasscheck__"],   false]
    - ["ab1636ah007", "abc.abstractmethod.__dict__.__contains__",       ["__isabstractmethod__"], true]
    - ["ab1636ah008", "abc.abstractmethod.__isabstractmethod__.__eq__", [true],                  true]
    - ["ab1636ah009", "abc.ABC.__name__.__eq__",                        ["ABC"],                 true]
    - ["ab1636ah010", "abc.ABC.__module__.__eq__",                      ["abc"],                 true]
    - ["ab1636ah011", "abc.ABC.__class__.__name__.__eq__",              ["ABCMeta"],             true]
    - ["ab1636ah012", "abc.ABC.__abstractmethods__.__class__.__name__.__eq__", ["frozenset"],    true]
    - ["ab1636ah013", "abc.ABC.__abstractmethods__.__len__",            [],                      0]
    - ["ab1636ah014", "abc.abstractmethod.__name__.__eq__",             ["abstractmethod"],      true]
    - ["ab1636ah015", "abc.abstractmethod.__module__.__eq__",           ["abc"],                 true]
    - ["ab1636ah016", "abc.abstractmethod.__class__.__name__.__eq__",   ["type"],                true]
    - ["ab1636ah017", "abc.ABC.__dict__.__contains__",                  ["__abstractmethods__"], false]
    - ["ab1636ah018", "abc.ABC.__dict__.__contains__",                  ["__dict__"],            false]
    - ["ab1636ah019", "abc.abstractmethod.__dict__.__contains__",       ["__wrapped__"],         false]
    - ["ab1636ah020", "abc.abstractmethod.__dict__.__contains__",       ["__func__"],            false]
    - ["ab1636ah021", "abc.ABC.__dict__.__contains__",                  ["register"],            false]
    - ["ab1636ah022", "abc.ABC.__dict__.__contains__",                  ["__init_subclass__"],   false]
    - ["ab1636ah023", "abc.ABC.__dict__.__contains__",                  ["__class_getitem__"],   false]
    - ["ab1636ah024", "abc.abstractmethod.__dict__.__contains__",       ["__call__"],            true]
    - ["ab1636ah025", "abc.abstractmethod.__dict__.__contains__",       ["__get__"],             true]

# ---------------------------------------------------------------------------
# Table 3: ABCMeta registry and diagnostic methods
#
# ABCMeta defines register() in its __dict__ so that MyABC.register(SomeClass)
# can add SomeClass to MyABC's virtual-subclass registry without SomeClass
# actually inheriting from MyABC in the MRO.
# _dump_registry() is a diagnostic method present in ABCMeta.__dict__.
# _abc_caches_clear() and _abc_registry_clear() are on _abc.ABCMeta instances
# (i.e. on individual ABC class objects), not on ABCMeta itself.
# ---------------------------------------------------------------------------

table abc_extra1636.abcmeta_registry_methods:
  description: "abc.ABCMeta registry and diagnostic method presence in __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1636rm

  columns: [id, function, args, expected]
  rows:
    - ["ab1636rm001", "abc.ABCMeta.__dict__.__contains__",              ["register"],            true]
    - ["ab1636rm002", "abc.ABCMeta.__dict__.__contains__",              ["_dump_registry"],      true]
    - ["ab1636rm003", "abc.ABCMeta.register.__name__.__eq__",           ["register"],            true]
    - ["ab1636rm004", "abc.ABCMeta.register.__class__.__name__.__eq__", ["function"],            true]
    - ["ab1636rm005", "abc.ABCMeta._dump_registry.__name__.__eq__",     ["_dump_registry"],      true]
    - ["ab1636rm006", "abc.ABCMeta._dump_registry.__class__.__name__.__eq__", ["function"],      true]
    - ["ab1636rm007", "abc.ABCMeta.__dict__.__contains__",              ["__subclasshook__"],    false]
    - ["ab1636rm008", "abc.ABCMeta.__dict__.__contains__",              ["__abstractmethods__"], false]
    - ["ab1636rm009", "abc.ABCMeta.register.__qualname__.__contains__", ["ABCMeta"],             true]
    - ["ab1636rm010", "abc.ABCMeta._dump_registry.__qualname__.__contains__", ["ABCMeta"],       true]
    - ["ab1636rm011", "abc.ABCMeta.__dict__.__contains__",              ["__instancecheck__"],   true]
    - ["ab1636rm012", "abc.ABCMeta.__dict__.__contains__",              ["__subclasscheck__"],   true]
    - ["ab1636rm013", "abc.ABCMeta.__dict__.__contains__",              ["__new__"],             true]
    - ["ab1636rm014", "abc.ABCMeta.__new__.__class__.__name__.__eq__",  ["staticmethod"],        true]
    - ["ab1636rm015", "abc.ABCMeta.__dict__.__contains__",              ["__module__"],          false]
    - ["ab1636rm016", "abc.ABCMeta.__dict__.__contains__",              ["__qualname__"],        false]
    - ["ab1636rm017", "abc.ABCMeta.__dict__.__contains__",              ["__name__"],            false]
    - ["ab1636rm018", "abc.ABCMeta.__dict__.__contains__",              ["__bases__"],           false]
    - ["ab1636rm019", "abc.ABCMeta.__dict__.__contains__",              ["__mro__"],             false]
    - ["ab1636rm020", "abc.ABCMeta.__dict__.__contains__",              ["__weakref__"],         false]
    - ["ab1636rm021", "abc.ABCMeta.__dict__.__contains__",              ["__slots__"],           false]
    - ["ab1636rm022", "abc.ABCMeta.__dict__.__contains__",              ["__repr__"],            false]
    - ["ab1636rm023", "abc.ABCMeta.__dict__.__contains__",              ["__str__"],             false]
    - ["ab1636rm024", "abc.ABCMeta.__dict__.__contains__",              ["__hash__"],            false]
    - ["ab1636rm025", "abc.ABCMeta.__dict__.__contains__",              ["__eq__"],              false]

# ---------------------------------------------------------------------------
# Table 4: abc.get_cache_token() — return type and callability
#
# get_cache_token() returns an opaque non-negative integer that increments
# each time the ABC inheritance cache is invalidated (register() is called).
# We confirm: the function is callable, the return value is an int, and the
# type name of the return value is 'int'.
# ---------------------------------------------------------------------------

table abc_extra1636.abc_cache_token:
  description: "abc.get_cache_token() is callable and returns an int"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1636ct

  columns: [id, function, args, expected]
  rows:
    - ["ab1636ct001", "abc.get_cache_token.__name__.__eq__",                        ["get_cache_token"], true]
