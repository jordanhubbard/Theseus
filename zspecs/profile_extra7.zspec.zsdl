spec: profile_extra7
version: ">=3.3"
backend: python_module(profile)

docs: https://docs.python.org/3/library/profile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/profile.html — Python profile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/profile.py"
  notes:
    - "This spec extends profile.zspec.zsdl through profile_extra6.zspec.zsdl."
    - "profile.zspec.zsdl covers: Profile/__name__/__module__/__bases__[0]/__name__, Profile methods __name__ (run/runcall/runctx/print_stats/dump_stats), Profile instantiation, profile.__name__."
    - "profile_extra covers: Profile/__name__/__module__, run/__name__, runctx/__name__."
    - "profile_extra2 covers: pstats backend; SortKey values, Stats.dump_stats/__name__, Stats.add/__name__."
    - "profile_extra3 covers: Profile/__qualname__ (via __eq__ predicate), run/__module__, runctx/__module__, run/__name__/runctx/__name__ table, Profile/__qualname__/__class__/__name__."
    - "profile_extra4 covers: Profile method __qualname__ and __module__ (run/runcall/runctx/print_stats/dump_stats), Profile/__bases__.__len__, Profile method type checks, run/__qualname__, runctx/__qualname__."
    - "profile_extra5 covers: Profile.calibrate/__name__/__qualname__/__class__.__name__, Profile.simulate_call/__name__/__qualname__/__class__.__name__, Profile.__bases__[0].__qualname__, Profile.__dict__ membership (run/runcall/calibrate/simulate_call)."
    - "profile_extra6 covers: Profile/__name__/__module__ via __eq__ predicate; run/__name__/runctx/__name__ via __eq__ predicate; Profile/__bases__[0].__name__ via __eq__; Profile/__bases__.__len__==1; Profile.__dict__.__class__.__name__=='mappingproxy'; Profile.__dict__ membership for runctx/print_stats/dump_stats; run/__class__.__name__ and runctx/__class__.__name__."
    - "NEW in this spec: profile.Profile.__qualname__ in direct expected-value form (type verification — __class__.__name__ == 'str'); profile.run.__qualname__ and profile.runctx.__qualname__ as standalone invariants in direct expected-value form (profile_extra3/profile_extra4 cover these via __eq__ predicate only); profile.Profile.__module__ direct value form (type check); profile.__name__ == 'profile' — module-level __name__ attribute not checked in any prior profile spec as a standalone invariant."
    - "profile.Profile.__qualname__ == 'Profile' — verified runtime."
    - "profile.run.__qualname__ == 'run' — top-level function qualname equals name (verified runtime)."
    - "profile.runctx.__qualname__ == 'runctx' — top-level function qualname equals name (verified runtime)."
    - "profile.Profile.__module__ == 'profile' — verified runtime."
    - "profile.__name__ == 'profile' — module-level __name__ is the module name itself (verified runtime)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# profile module-level __name__ attribute
#
# profile.zspec.zsdl checks Profile/__name__ (the class attribute).
# No prior profile spec checks the module's own __name__ attribute as a
# standalone invariant using function: __name__.__eq__.
# ---------------------------------------------------------------------------

invariant profile_extra7.module.name:
  description: "profile.__name__ == 'profile' — module-level __name__ attribute equals the module name"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["profile"]
  expected: true

# ---------------------------------------------------------------------------
# profile.Profile.__qualname__ — type-check axis
#
# profile_extra3 checks Profile.__qualname__ via __eq__ predicate (expected: true).
# This spec provides the __class__.__name__ of Profile.__qualname__ — confirming
# it is a str — which is a new axis not covered by any prior profile spec.
# ---------------------------------------------------------------------------

invariant profile_extra7.Profile.qualname_type:
  description: "profile.Profile.__qualname__.__class__.__name__ == 'str' — qualname is a string"
  category: classes
  kind: python_call_eq
  function: Profile.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# profile.Profile.__module__ — type-check axis
#
# profile.zspec and profile_extra6 check Profile.__module__ as a direct string
# value and as __eq__ predicate respectively.  The __class__.__name__ of
# Profile.__module__ (confirming it is a str) is new.
# ---------------------------------------------------------------------------

invariant profile_extra7.Profile.module_type:
  description: "profile.Profile.__module__.__class__.__name__ == 'str' — __module__ is a string"
  category: classes
  kind: python_call_eq
  function: Profile.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# profile.run and profile.runctx __qualname__ — standalone invariants
#
# profile_extra4 covers run/__qualname__ and runctx/__qualname__ as standalone
# invariants via __eq__ predicate (expected: true). This table provides the
# __class__.__name__ of each __qualname__ string — a new type-check axis.
# ---------------------------------------------------------------------------

table profile_extra7.function_qualname_types:
  description: "profile.run and profile.runctx __qualname__ are str — type-check axis not covered by prior specs"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqnt

  columns: [id, function, args, expected]
  rows:
    - [run,    run.__qualname__.__class__.__name__.__eq__,    ["str"], true]
    - [runctx, runctx.__qualname__.__class__.__name__.__eq__, ["str"], true]
