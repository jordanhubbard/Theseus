spec: ipaddress_extra24
version: ">=3.9"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html — Python ipaddress module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
  notes:
    - "This spec extends ipaddress_extra23.zspec.zsdl."
    - "Prior specs covered: IPv4/6Address/Network/Interface creation, is_private/is_loopback/is_multicast, packed bytes, prefixlen, num_addresses, compressed/exploded, ip_address/ip_network factories, __name__/__module__ for all 6 types, __bases__ for all types, version attribute, AddressValueError/NetmaskValueError bases, __qualname__ checks (extra5/16/21), ip_address/ip_network __qualname__/__module__ (extra21), IPv4Interface/IPv6Interface __qualname__ and __qualname__ lengths (extra21), address/network __name__/__module__/__name__.__len__() (extra22), all-six class __qualname__ lengths + factory __name__/__qualname__ + ip_address/ip_network __module__.__len__() (extra23)."
    - "This spec covers: ipaddress.IPv4Address.__module__.__len__(), ipaddress.IPv6Address.__module__.__len__(), ipaddress.IPv4Network.__module__.__len__(), ipaddress.IPv6Network.__module__.__len__(), ipaddress.IPv4Interface.__module__.__len__(), ipaddress.IPv6Interface.__module__.__len__(), ipaddress.ip_interface.__module__.__len__(), ipaddress.ip_interface.__name__.__len__(), ipaddress.ip_interface.__qualname__.__len__(), ipaddress.AddressValueError.__module__.__len__(), ipaddress.NetmaskValueError.__module__.__len__(), ipaddress.AddressValueError.__name__.__len__(), ipaddress.NetmaskValueError.__name__.__len__()."
    - "ipaddress.IPv4Address.__module__.__len__() == 9 — len('ipaddress') == 9; extra21 checks IPv4Address.__module__.__eq__('ipaddress'); extra22 checks IPv4Interface/IPv6Interface __module__.__eq__; no prior ipaddress spec checks __module__.__len__() on any address, network, or interface class."
    - "ipaddress.IPv6Address.__module__.__len__() == 9 — same rationale."
    - "ipaddress.IPv4Network.__module__.__len__() == 9 — same rationale."
    - "ipaddress.IPv6Network.__module__.__len__() == 9 — same rationale."
    - "ipaddress.IPv4Interface.__module__.__len__() == 9 — extra22 checks IPv4Interface.__module__.__eq__('ipaddress'); no prior spec checks IPv4Interface.__module__.__len__()."
    - "ipaddress.IPv6Interface.__module__.__len__() == 9 — same rationale as IPv4Interface.__module__.__len__()."
    - "ipaddress.ip_interface.__module__.__len__() == 9 — ip_interface.__module__ == 'ipaddress' (len 9); extra21 checks ip_address/ip_network __module__.__eq__; no prior spec checks ip_interface.__module__.__len__()."
    - "ipaddress.ip_interface.__name__.__len__() == 12 — len('ip_interface') == 12; no prior ipaddress spec checks ip_interface.__name__.__len__()."
    - "ipaddress.ip_interface.__qualname__.__len__() == 12 — ip_interface.__qualname__ == 'ip_interface' (len 12); no prior ipaddress spec checks ip_interface.__qualname__.__len__()."
    - "ipaddress.AddressValueError.__module__.__len__() == 9 — AddressValueError.__module__ == 'ipaddress' (len 9); extra22 checks AddressValueError.__bases__[0].__name__; no prior spec checks AddressValueError.__module__.__len__()."
    - "ipaddress.NetmaskValueError.__module__.__len__() == 9 — same rationale as AddressValueError.__module__.__len__()."
    - "ipaddress.AddressValueError.__name__.__len__() == 17 — len('AddressValueError') == 17; no prior ipaddress spec checks AddressValueError.__name__.__len__()."
    - "ipaddress.NetmaskValueError.__name__.__len__() == 17 — len('NetmaskValueError') == 17; no prior ipaddress spec checks NetmaskValueError.__name__.__len__()."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# All six address/network/interface class __module__ string lengths
#
# ipaddress_extra21 checks IPv4Address/IPv6Address/IPv4Network/IPv6Network
# __module__.__eq__('ipaddress') in a table. ipaddress_extra22 checks
# IPv4Interface/IPv6Interface __module__.__eq__('ipaddress') in a table.
# No prior ipaddress spec checks __module__.__len__() on any of these six
# classes. All six have __module__ == 'ipaddress' (len 9).
# ---------------------------------------------------------------------------

table ipaddress_extra24.class_module_lengths:
  description: "All six address/network/interface class __module__ string lengths — no prior spec checks __module__.__len__() on these classes"
  kind: python_call_eq
  category: class_modules
  id_prefix: cmodlen24

  columns: [id, function, args, expected]
  rows:
    - [IPv4Address,   IPv4Address.__module__.__len__,   [], 9]
    - [IPv6Address,   IPv6Address.__module__.__len__,   [], 9]
    - [IPv4Network,   IPv4Network.__module__.__len__,   [], 9]
    - [IPv6Network,   IPv6Network.__module__.__len__,   [], 9]
    - [IPv4Interface, IPv4Interface.__module__.__len__, [], 9]
    - [IPv6Interface, IPv6Interface.__module__.__len__, [], 9]

# ---------------------------------------------------------------------------
# ip_interface __module__, __name__, and __qualname__ string lengths
#
# ipaddress_extra21 checks ip_address/ip_network __module__.__eq__ and their
# __qualname__. ipaddress_extra23 checks ip_address/ip_network __module__.__len__()
# as standalone invariants. No prior ipaddress spec checks ip_interface's
# __module__.__len__(), __name__.__len__(), or __qualname__.__len__(). The
# ip_interface function has __name__ == __qualname__ == 'ip_interface' (len 12).
# ---------------------------------------------------------------------------

invariant ipaddress_extra24.ip_interface.module_len:
  description: "ipaddress.ip_interface.__module__.__len__() == 9 — len('ipaddress') == 9; no prior spec checks ip_interface.__module__.__len__()"
  category: function_modules
  kind: python_call_eq
  function: ip_interface.__module__.__len__
  args: []
  expected: 9

invariant ipaddress_extra24.ip_interface.name_len:
  description: "ipaddress.ip_interface.__name__.__len__() == 12 — len('ip_interface') == 12; no prior ipaddress spec checks ip_interface.__name__.__len__()"
  category: function_identity
  kind: python_call_eq
  function: ip_interface.__name__.__len__
  args: []
  expected: 12

invariant ipaddress_extra24.ip_interface.qualname_len:
  description: "ipaddress.ip_interface.__qualname__.__len__() == 12 — len('ip_interface') == 12; no prior ipaddress spec checks ip_interface.__qualname__.__len__()"
  category: function_identity
  kind: python_call_eq
  function: ip_interface.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# AddressValueError and NetmaskValueError __module__.__len__() and __name__.__len__()
#
# ipaddress_extra22 checks AddressValueError/NetmaskValueError __bases__[0].__name__.
# No prior ipaddress spec checks __module__.__len__() or __name__.__len__() on
# either exception class. Both have __module__ == 'ipaddress' (len 9) and
# __name__ lengths of 17 ('AddressValueError' and 'NetmaskValueError').
# ---------------------------------------------------------------------------

table ipaddress_extra24.error_module_lengths:
  description: "AddressValueError/NetmaskValueError __module__ string lengths — no prior spec checks __module__.__len__() on error classes"
  kind: python_call_eq
  category: class_modules
  id_prefix: errmodlen24

  columns: [id, function, args, expected]
  rows:
    - [AddressValueError, AddressValueError.__module__.__len__, [], 9]
    - [NetmaskValueError, NetmaskValueError.__module__.__len__, [], 9]

table ipaddress_extra24.error_name_lengths:
  description: "AddressValueError/NetmaskValueError __name__ string lengths — no prior spec checks __name__.__len__() on error classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: errnlen24

  columns: [id, function, args, expected]
  rows:
    - [AddressValueError, AddressValueError.__name__.__len__, [], 17]
    - [NetmaskValueError, NetmaskValueError.__name__.__len__, [], 17]
