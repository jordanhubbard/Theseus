spec: io_extra147
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: __doc__ attribute lengths and class identity for io.BufferedReader, io.BufferedWriter, io.StringIO, io.BytesIO, io.FileIO, and io.TextIOWrapper; also io.IOBase, io.RawIOBase, io.BufferedIOBase, and io.TextIOBase docstring lengths."
    - "io.BufferedReader.__doc__ is a 68-character str (short one-liner; no newlines)."
    - "io.BufferedWriter.__doc__ is a 196-character str (multi-line constructor doc)."
    - "io.StringIO.__doc__ is a 174-character str; __module__ == '_io' (C extension)."
    - "io.BytesIO.__doc__ is a 60-character str; __module__ == '_io' (C extension)."
    - "io.FileIO.__doc__ is a 778-character str (long open() mode docs)."
    - "io.TextIOWrapper.__doc__ is a 1330-character str (longest among the concrete IO classes)."
    - "io.IOBase.__doc__ is a 1235-character str; io.RawIOBase.__doc__ is 30 characters."
    - "io.BufferedIOBase.__doc__ is 496 characters; io.TextIOBase.__doc__ is 176 characters."
    - "io.BufferedRandom.__doc__ is 214 characters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedReader and io.BufferedWriter __doc__ lengths
# BufferedReader.__doc__ == 68 characters (single-line constructor doc).
# BufferedWriter.__doc__ == 196 characters (multi-line constructor doc).
# Both are str instances (not None).
# ---------------------------------------------------------------------------

table io_extra147.BufferedReader_BufferedWriter_doc_len:
  description: "io.BufferedReader.__doc__ len=68 (str, single-line), io.BufferedWriter.__doc__ len=196 (str, multi-line)"
  kind: python_call_eq
  category: doc_identity
  id_prefix: iodoc147

  columns: [id, function, args, expected]
  rows:
    - [br_doc_cls_eq,  BufferedReader.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [br_doc_len,     BufferedReader.__doc__.__len__,                   [],      68]
    - [bw_doc_cls_eq,  BufferedWriter.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [bw_doc_len,     BufferedWriter.__doc__.__len__,                   [],      196]

# ---------------------------------------------------------------------------
# io.StringIO and io.BytesIO __doc__ lengths
# StringIO.__doc__ == 174 characters; BytesIO.__doc__ == 60 characters.
# Both are _io C extension types; __module__ == '_io'.
# ---------------------------------------------------------------------------

table io_extra147.StringIO_BytesIO_doc_len:
  description: "io.StringIO.__doc__ len=174 (str), io.BytesIO.__doc__ len=60 (str); both __module__='_io'"
  kind: python_call_eq
  category: doc_identity
  id_prefix: iodoc147

  columns: [id, function, args, expected]
  rows:
    - [sio_doc_cls_eq,    StringIO.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sio_doc_len,       StringIO.__doc__.__len__,                   [],      174]
    - [sio_module_eq,     StringIO.__module__.__eq__,                 ["_io"], true]
    - [bio_doc_cls_eq,    BytesIO.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [bio_doc_len,       BytesIO.__doc__.__len__,                    [],      60]
    - [bio_module_eq,     BytesIO.__module__.__eq__,                  ["_io"], true]

# ---------------------------------------------------------------------------
# io.FileIO and io.TextIOWrapper __doc__ lengths
# FileIO.__doc__ == 778 characters (full open() mode description).
# TextIOWrapper.__doc__ == 1330 characters (longest concrete IO class doc).
# ---------------------------------------------------------------------------

table io_extra147.FileIO_TextIOWrapper_doc_len:
  description: "io.FileIO.__doc__ len=778 (str, full mode docs), io.TextIOWrapper.__doc__ len=1330 (str, longest concrete IO doc)"
  kind: python_call_eq
  category: doc_identity
  id_prefix: iodoc147

  columns: [id, function, args, expected]
  rows:
    - [fio_doc_cls_eq,   FileIO.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [fio_doc_len,      FileIO.__doc__.__len__,                         [],      778]
    - [tiow_doc_cls_eq,  TextIOWrapper.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [tiow_doc_len,     TextIOWrapper.__doc__.__len__,                   [],      1330]

# ---------------------------------------------------------------------------
# io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase __doc__ lengths
# IOBase.__doc__ == 1235 characters (longest ABC doc; covers all IO conventions).
# RawIOBase.__doc__ == 30 characters (short single-line).
# BufferedIOBase.__doc__ == 496 characters (covers buffering differences from raw).
# TextIOBase.__doc__ == 176 characters.
# ---------------------------------------------------------------------------

table io_extra147.abstract_base_doc_len:
  description: "io abstract base class __doc__ lengths: IOBase=1235, RawIOBase=30, BufferedIOBase=496, TextIOBase=176"
  kind: python_call_eq
  category: doc_identity
  id_prefix: iodoc147

  columns: [id, function, args, expected]
  rows:
    - [iobase_doc_cls_eq,   IOBase.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [iobase_doc_len,      IOBase.__doc__.__len__,                          [],      1235]
    - [rawio_doc_cls_eq,    RawIOBase.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [rawio_doc_len,       RawIOBase.__doc__.__len__,                       [],      30]
    - [bufio_doc_cls_eq,    BufferedIOBase.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [bufio_doc_len,       BufferedIOBase.__doc__.__len__,                  [],      496]
    - [textio_doc_cls_eq,   TextIOBase.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [textio_doc_len,      TextIOBase.__doc__.__len__,                      [],      176]

# ---------------------------------------------------------------------------
# io.BufferedRandom __doc__ length
# BufferedRandom.__doc__ == 214 characters.
# ---------------------------------------------------------------------------

table io_extra147.BufferedRandom_doc_len:
  description: "io.BufferedRandom.__doc__ len=214 (str); covers seekable stream buffering for both read and write"
  kind: python_call_eq
  category: doc_identity
  id_prefix: iodoc147

  columns: [id, function, args, expected]
  rows:
    - [brand_doc_cls_eq,  BufferedRandom.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [brand_doc_len,     BufferedRandom.__doc__.__len__,                    [],      214]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra147.BufferedReader.doc_len_68:
  description: "io.BufferedReader.__doc__.__len__() == 68 (a single-line constructor docstring: 'Create a new buffered reader using the given readable raw IO object.'; shorter than BufferedWriter.__doc__ (196) because BufferedWriter has a multi-line class-level doc)"
  category: doc_identity
  kind: python_call_eq
  function: BufferedReader.__doc__.__len__
  args: []
  expected: 68

invariant io_extra147.BufferedWriter.doc_len_196:
  description: "io.BufferedWriter.__doc__.__len__() == 196 (multi-line class docstring covering the constructor and buffer_size parameter; longer than BufferedReader.__doc__ (68) which is a single constructor line)"
  category: doc_identity
  kind: python_call_eq
  function: BufferedWriter.__doc__.__len__
  args: []
  expected: 196

invariant io_extra147.StringIO.doc_len_174:
  description: "io.StringIO.__doc__.__len__() == 174 (documents initial_value and newline arguments to the StringIO constructor; longer than BytesIO.__doc__ (60) because StringIO has more constructor parameters)"
  category: doc_identity
  kind: python_call_eq
  function: StringIO.__doc__.__len__
  args: []
  expected: 174

invariant io_extra147.BytesIO.doc_len_60:
  description: "io.BytesIO.__doc__.__len__() == 60 (a concise single-sentence doc: 'Buffered I/O implementation using an in-memory bytes buffer.'; the shortest among the concrete IO classes with non-None docs)"
  category: doc_identity
  kind: python_call_eq
  function: BytesIO.__doc__.__len__
  args: []
  expected: 60

invariant io_extra147.FileIO.doc_len_778:
  description: "io.FileIO.__doc__.__len__() == 778 (the longest-named concrete IO class doc after TextIOWrapper; FileIO.__doc__ covers 'r', 'w', 'x', 'a' modes, O_CREAT/O_EXCL flags, and the closefd/opener arguments at length)"
  category: doc_identity
  kind: python_call_eq
  function: FileIO.__doc__.__len__
  args: []
  expected: 778

invariant io_extra147.TextIOWrapper.doc_len_1330:
  description: "io.TextIOWrapper.__doc__.__len__() == 1330 (the longest __doc__ among all concrete io C extension classes; covers encoding, errors, newline, line_buffering, and write_through parameters in detail)"
  category: doc_identity
  kind: python_call_eq
  function: TextIOWrapper.__doc__.__len__
  args: []
  expected: 1330

invariant io_extra147.IOBase.doc_len_1235:
  description: "io.IOBase.__doc__.__len__() == 1235 (the comprehensive abstract base class docstring covering the binary/text contract, iterator protocol, context manager support, and the with-statement example)"
  category: doc_identity
  kind: python_call_eq
  function: IOBase.__doc__.__len__
  args: []
  expected: 1235

invariant io_extra147.RawIOBase.doc_len_30:
  description: "io.RawIOBase.__doc__.__len__() == 30 (the shortest non-None __doc__ in the io ABC hierarchy: 'Base class for raw binary I/O.'; RawIOBase documents itself in a single sentence)"
  category: doc_identity
  kind: python_call_eq
  function: RawIOBase.__doc__.__len__
  args: []
  expected: 30

invariant io_extra147.BufferedIOBase.doc_len_496:
  description: "io.BufferedIOBase.__doc__.__len__() == 496 (covers the key differences from RawIOBase: omittable size in read(), non-None returns, BlockingIOError semantics, and the 'wrap don't inherit' pattern)"
  category: doc_identity
  kind: python_call_eq
  function: BufferedIOBase.__doc__.__len__
  args: []
  expected: 496
