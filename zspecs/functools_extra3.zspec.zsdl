spec: functools_extra3
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "Extends functools.zspec.zsdl, functools_extra.zspec.zsdl, functools_extra2.zspec.zsdl, and functools_lru.zspec.zsdl."
    - "functools.singledispatch.__name__ == 'singledispatch' — Python decorator function."
    - "functools.singledispatch.__module__ == 'functools' — defined in functools, not a C extension."
    - "functools.singledispatchmethod.__name__ == 'singledispatchmethod' — added in Python 3.8."
    - "functools.singledispatchmethod.__module__ == 'functools'."
    - "functools.cached_property.__name__ == 'cached_property' — descriptor class added in Python 3.8."
    - "functools.cached_property.__module__ == 'functools'."
    - "functools.total_ordering.__name__ == 'total_ordering' — class decorator, pure Python."
    - "functools.total_ordering.__module__ == 'functools'."
    - "functools.cmp_to_key.__name__ == 'cmp_to_key' — C-level builtin in _functools."
    - "functools.cmp_to_key.__module__ == 'functools'."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — already in functools_extra.zspec.zsdl but we verify length here."
    - "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'."
    - "singledispatchmethod.__qualname__ == 'singledispatchmethod' — top-level class."
    - "cached_property.__qualname__ == 'cached_property' — top-level class."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# singledispatch — __name__ and __module__
#
# functools.singledispatch is a Python decorator factory function. Its
# __name__ is 'singledispatch' and its __module__ is 'functools'.
# ---------------------------------------------------------------------------

invariant functools_extra3.singledispatch.name:
  description: "functools.singledispatch.__name__ == 'singledispatch'"
  category: singledispatch
  kind: python_call_eq
  function: singledispatch.__name__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra3.singledispatch.module:
  description: "functools.singledispatch.__module__ == 'functools'"
  category: singledispatch
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra3.singledispatch.qualname:
  description: "functools.singledispatch.__qualname__ == 'singledispatch'"
  category: singledispatch
  kind: python_call_eq
  function: singledispatch.__qualname__.__eq__
  args: ["singledispatch"]
  expected: true

# ---------------------------------------------------------------------------
# singledispatchmethod — __name__ and __module__
#
# functools.singledispatchmethod is a descriptor class added in Python 3.8.
# Its __name__ is 'singledispatchmethod' and __module__ is 'functools'.
# ---------------------------------------------------------------------------

invariant functools_extra3.singledispatchmethod.name:
  description: "functools.singledispatchmethod.__name__ == 'singledispatchmethod'"
  category: singledispatchmethod
  kind: python_call_eq
  function: singledispatchmethod.__name__.__eq__
  args: ["singledispatchmethod"]
  expected: true

invariant functools_extra3.singledispatchmethod.module:
  description: "functools.singledispatchmethod.__module__ == 'functools'"
  category: singledispatchmethod
  kind: python_call_eq
  function: singledispatchmethod.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra3.singledispatchmethod.qualname:
  description: "functools.singledispatchmethod.__qualname__ == 'singledispatchmethod'"
  category: singledispatchmethod
  kind: python_call_eq
  function: singledispatchmethod.__qualname__.__eq__
  args: ["singledispatchmethod"]
  expected: true

# ---------------------------------------------------------------------------
# cached_property — __name__ and __module__
#
# functools.cached_property is a descriptor class (Python >= 3.8). Its
# __name__ is 'cached_property' and its __module__ is 'functools'.
# ---------------------------------------------------------------------------

invariant functools_extra3.cached_property.name:
  description: "functools.cached_property.__name__ == 'cached_property'"
  category: cached_property
  kind: python_call_eq
  function: cached_property.__name__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra3.cached_property.module:
  description: "functools.cached_property.__module__ == 'functools'"
  category: cached_property
  kind: python_call_eq
  function: cached_property.__module__.__eq__
  args: ["functools"]
  expected: true

# ---------------------------------------------------------------------------
# total_ordering — __name__ and __module__
#
# functools.total_ordering is a pure-Python class decorator. Its __name__
# is 'total_ordering' and its __module__ is 'functools'.
# ---------------------------------------------------------------------------

invariant functools_extra3.total_ordering.name:
  description: "functools.total_ordering.__name__ == 'total_ordering'"
  category: total_ordering
  kind: python_call_eq
  function: total_ordering.__name__.__eq__
  args: ["total_ordering"]
  expected: true

invariant functools_extra3.total_ordering.module:
  description: "functools.total_ordering.__module__ == 'functools'"
  category: total_ordering
  kind: python_call_eq
  function: total_ordering.__module__.__eq__
  args: ["functools"]
  expected: true

# ---------------------------------------------------------------------------
# cmp_to_key — __name__ and __module__
#
# functools.cmp_to_key converts an old-style comparison function into a
# key function suitable for sorted(). It is C-level (in _functools) but
# re-exported through functools. Its __name__ is 'cmp_to_key'.
# ---------------------------------------------------------------------------

invariant functools_extra3.cmp_to_key.name:
  description: "functools.cmp_to_key.__name__ == 'cmp_to_key'"
  category: cmp_to_key
  kind: python_call_eq
  function: cmp_to_key.__name__.__eq__
  args: ["cmp_to_key"]
  expected: true

invariant functools_extra3.cmp_to_key.module:
  description: "functools.cmp_to_key.__module__ == 'functools'"
  category: cmp_to_key
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["functools"]
  expected: true

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS — is a tuple
#
# functools.WRAPPER_ASSIGNMENTS is the tuple of attributes copied by wraps().
# This spec verifies its type name and that it is non-empty.
# The class-name invariant is in functools_extra.zspec.zsdl; here we verify
# the length is at least 1 to confirm it contains elements.
# ---------------------------------------------------------------------------

invariant functools_extra3.WRAPPER_ASSIGNMENTS.is_tuple:
  description: "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra3.WRAPPER_ASSIGNMENTS.nonempty:
  description: "len(functools.WRAPPER_ASSIGNMENTS) >= 1 — tuple contains at least one attribute name"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  method: __ge__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# WRAPPER_UPDATES — is a tuple
#
# functools.WRAPPER_UPDATES is the tuple of attributes merged by wraps().
# We verify its type name and non-emptiness.
# ---------------------------------------------------------------------------

invariant functools_extra3.WRAPPER_UPDATES.is_tuple:
  description: "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'"
  category: constants
  kind: python_call_eq
  function: WRAPPER_UPDATES.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra3.WRAPPER_UPDATES.nonempty:
  description: "len(functools.WRAPPER_UPDATES) >= 1 — tuple contains at least one attribute name"
  category: constants
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  method: __ge__
  method_args: [1]
  expected: true
