version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec extends multiprocessing_extra118.zspec.zsdl."
    - "This spec covers: wave 260 theme — multiprocessing.pool.Pool method co_varnames element equality not previously covered. Prior specs covered: extra69 covered Process.__init__.__code__.co_varnames.__class__.__name__=='tuple'; extra112 covered pool.Pool class method co_qualname (imap/imap_unordered/map_async/starmap_async); extra115 covered pool.Pool factory co_qualname and co_varnames length. NOT previously covered at element level: Pool.map.__code__.co_varnames[1].__eq__('func'); co_varnames[2].__eq__('iterable'); co_varnames[3].__eq__('chunksize'); Pool.starmap.__code__.co_varnames[1].__eq__('func'); Pool.apply.__code__.co_varnames[1].__eq__('func'); Pool.apply.__code__.co_varnames[2].__eq__('args'); Pool.apply.__code__.co_varnames[3].__eq__('kwds'); Pool.map/starmap/apply co_varnames.__len__()==4. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.pool.Pool.map.__code__.co_varnames == ('self','func','iterable','chunksize'): len=4. co_argcount==4. co_qualname=='Pool.map' (len=8). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.pool.Pool.starmap.__code__.co_varnames == ('self','func','iterable','chunksize'): len=4 (identical structure to Pool.map). co_qualname=='Pool.starmap' (len=12). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.pool.Pool.apply.__code__.co_varnames == ('self','func','args','kwds'): len=4. co_qualname=='Pool.apply' (len=10). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool.map co_varnames element equality — extra119
#
# Wave 260 theme: Pool.map co_varnames[1]-[3] element equality.
#
# Pool.map.__code__.co_varnames[0] == 'self'      (len=4)
# Pool.map.__code__.co_varnames[1] == 'func'      (len=4, tied with self)
# Pool.map.__code__.co_varnames[2] == 'iterable'  (len=8)
# Pool.map.__code__.co_varnames[3] == 'chunksize' (len=9, longest)
# Pool.map.__code__.co_qualname    == 'Pool.map'  (len=8, shortest in spec)
# ---------------------------------------------------------------------------

table multiprocessing_extra119.pool_map_co_varnames:
  description: "multiprocessing.pool.Pool.map co_varnames element equality checks in mppool119 namespace — wave 260 theme: first element-level coverage of Pool.map co_varnames; co_varnames==('self','func','iterable','chunksize') len=4; Pool.map(func, iterable, chunksize=None) applies func to every element of iterable using worker processes; co_varnames[0].__eq__('self')==True (len=4); co_varnames[1].__eq__('func')==True (len=4: func is the callable to apply to each element; tied in length with 'self'=4; 'func' is a common abbreviation similar to ThreadPoolExecutor.submit's 'fn'=2 but longer; co_argcount==4 confirms func is a real parameter); co_varnames[2].__eq__('iterable')==True (len=8: iterable is the sequence of input elements to map over; Pool.map eagerly converts it to a list internally; 'iterable'=8 is the second-longest element at 8 chars); co_varnames[3].__eq__('chunksize')==True (len=9: chunksize divides iterable into chunks submitted to workers as single tasks; larger chunksize reduces overhead; 'chunksize'=9 is the longest element: 'chunk'=5+'size'=4=9); co_varnames.__len__()==4 (all params including self; no local-only variables in map: all 4 co_varnames are real parameters); co_qualname=='Pool.map' (len=8: 'Pool.'=5+'map'=3=8; shortest qualname in this spec); element length ordering: self==func=4 (tied, shortest) < iterable=8 < chunksize=9 (longest); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: mppool119

  columns: [id, function, args, expected, description]
  rows:
    - [map_vlen,   "pool.Pool.map.__code__.co_varnames.__len__",    [],             4,    "Pool.map co_varnames.__len__() == 4 (('self','func','iterable','chunksize'); all params, no locals); verified with Python 3.14.3"]
    - [map_v1_eq,  "pool.Pool.map.__code__.co_varnames[1].__eq__",  ["func"],       true, "Pool.map co_varnames[1] == 'func' (len=4; callable to apply to each element); verified with Python 3.14.3"]
    - [map_v1_len, "pool.Pool.map.__code__.co_varnames[1].__len__", [],             4,    "Pool.map co_varnames[1].__len__() == 4 ('func'=4; tied with self=4); verified with Python 3.14.3"]
    - [map_v2_eq,  "pool.Pool.map.__code__.co_varnames[2].__eq__",  ["iterable"],   true, "Pool.map co_varnames[2] == 'iterable' (len=8; sequence of input elements); verified with Python 3.14.3"]
    - [map_v2_len, "pool.Pool.map.__code__.co_varnames[2].__len__", [],             8,    "Pool.map co_varnames[2].__len__() == 8 ('iterable'=8); verified with Python 3.14.3"]
    - [map_v3_eq,  "pool.Pool.map.__code__.co_varnames[3].__eq__",  ["chunksize"],  true, "Pool.map co_varnames[3] == 'chunksize' (len=9; longest element; chunk submit size); verified with Python 3.14.3"]
    - [map_v3_len, "pool.Pool.map.__code__.co_varnames[3].__len__", [],             9,    "Pool.map co_varnames[3].__len__() == 9 ('chunksize'=9; longest in spec); verified with Python 3.14.3"]
    - [map_qn_eq,  "pool.Pool.map.__code__.co_qualname.__eq__",     ["Pool.map"],   true, "Pool.map.__code__.co_qualname == 'Pool.map' (len=8; shortest qualname in spec); verified with Python 3.14.3"]
    - [map_qn_len, "pool.Pool.map.__code__.co_qualname.__len__",    [],             8,    "Pool.map.__code__.co_qualname.__len__() == 8 ('Pool.map': 'Pool.'=5+'map'=3=8); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool.starmap co_varnames element equality — extra119
#
# Wave 260 theme: Pool.starmap co_varnames[1] equality (identical structure to map).
#
# Pool.starmap.__code__.co_varnames == ('self','func','iterable','chunksize')
# Pool.starmap.__code__.co_qualname == 'Pool.starmap' (len=12)
# Pool.starmap and Pool.map have identical co_varnames structure.
# ---------------------------------------------------------------------------

table multiprocessing_extra119.pool_starmap_co_varnames:
  description: "multiprocessing.pool.Pool.starmap co_varnames element equality checks in mppool119a namespace — wave 260 theme: Pool.starmap co_varnames structure is identical to Pool.map; co_varnames==('self','func','iterable','chunksize') len=4 (same as Pool.map; both methods iterate over an iterable and apply func using worker processes; starmap differs from map in that iterable must yield tuples unpacked as func arguments — func(*item) instead of func(item)); co_varnames[1].__eq__('func')==True (len=4: tied with Pool.map co_varnames[1]='func'=4; same name, same index, same length — the callable to star-apply); co_varnames[2].__eq__('iterable')==True (len=8: same as Pool.map co_varnames[2]='iterable'=8; each element of iterable is unpacked as args to func); co_varnames[3].__eq__('chunksize')==True (len=9: same as Pool.map co_varnames[3]='chunksize'=9; the chunk submission size; identical parameter structure reflects that starmap and map share the same chunking algorithm); co_varnames.__len__()==4 (tied with Pool.map=4 and Pool.apply=4); co_qualname=='Pool.starmap' (len=12: 'Pool.'=5+'starmap'=7=12; 4 more than Pool.map=8: 'starmap'=7 vs 'map'=3, diff=4; most chars of the three methods in this spec); 'starmap'=7 chars ('star'=4+'map'=3=7: starmap applies func to unpacked tuples from iterable); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: mppool119a

  columns: [id, function, args, expected, description]
  rows:
    - [smap_vlen,   "pool.Pool.starmap.__code__.co_varnames.__len__",    [],            4,    "Pool.starmap co_varnames.__len__() == 4 (identical structure to Pool.map; all params, no locals); verified with Python 3.14.3"]
    - [smap_v1_eq,  "pool.Pool.starmap.__code__.co_varnames[1].__eq__",  ["func"],      true, "Pool.starmap co_varnames[1] == 'func' (len=4; tied with Pool.map co_varnames[1]='func'); verified with Python 3.14.3"]
    - [smap_v1_len, "pool.Pool.starmap.__code__.co_varnames[1].__len__", [],            4,    "Pool.starmap co_varnames[1].__len__() == 4 ('func'=4; same as Pool.map); verified with Python 3.14.3"]
    - [smap_v2_eq,  "pool.Pool.starmap.__code__.co_varnames[2].__eq__",  ["iterable"],  true, "Pool.starmap co_varnames[2] == 'iterable' (len=8; same as Pool.map; elements are tuples unpacked as args); verified with Python 3.14.3"]
    - [smap_v3_eq,  "pool.Pool.starmap.__code__.co_varnames[3].__eq__",  ["chunksize"], true, "Pool.starmap co_varnames[3] == 'chunksize' (len=9; same as Pool.map; longest element); verified with Python 3.14.3"]
    - [smap_qn_eq,  "pool.Pool.starmap.__code__.co_qualname.__eq__",     ["Pool.starmap"], true, "Pool.starmap.__code__.co_qualname == 'Pool.starmap' (len=12); verified with Python 3.14.3"]
    - [smap_qn_len, "pool.Pool.starmap.__code__.co_qualname.__len__",    [],            12,   "Pool.starmap.__code__.co_qualname.__len__() == 12 ('Pool.'=5+'starmap'=7=12; longest qualname in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool.apply co_varnames element equality — extra119
#
# Wave 260 theme: Pool.apply co_varnames[2]='args', [3]='kwds' (different from map).
#
# Pool.apply.__code__.co_varnames[0] == 'self' (len=4)
# Pool.apply.__code__.co_varnames[1] == 'func' (len=4, tied with map/starmap)
# Pool.apply.__code__.co_varnames[2] == 'args' (len=4, distinct from 'iterable')
# Pool.apply.__code__.co_varnames[3] == 'kwds' (len=4, all four params tied at len=4)
# Pool.apply.__code__.co_qualname    == 'Pool.apply' (len=10)
# ---------------------------------------------------------------------------

table multiprocessing_extra119.pool_apply_co_varnames:
  description: "multiprocessing.pool.Pool.apply co_varnames element equality checks in mppool119b namespace — wave 260 theme: Pool.apply co_varnames differ from map/starmap in the last two positions; co_varnames==('self','func','args','kwds') len=4; Pool.apply(func, args=(), kwds={}) calls func(*args, **kwds) in a single worker process and blocks until the result is ready (unlike apply_async which is non-blocking); co_varnames[1].__eq__('func')==True (len=4: tied with Pool.map co_varnames[1]='func' and Pool.starmap co_varnames[1]='func'; all three pool methods use 'func' at index 1); co_varnames[2].__eq__('args')==True (len=4: args is the tuple of positional arguments for func; 'args'=4 is shorter than Pool.map co_varnames[2]='iterable'=8; note 'args'=4 is tied in length with 'func'=4, 'kwds'=4, and 'self'=4 — all four co_varnames have length 4, making apply the only Pool method in this spec with all params the same length); co_varnames[3].__eq__('kwds')==True (len=4: kwds is the dict of keyword arguments for func; 'kwds'=4 is an abbreviation for 'kwargs'; 'kwds'=4 is shorter than 'chunksize'=9 at Pool.map index 3; all four pool.apply co_varnames elements have len=4: self==func==args==kwds=4); co_varnames.__len__()==4 (tied with Pool.map=4 and Pool.starmap=4; all three Pool methods have 4 co_varnames); co_qualname=='Pool.apply' (len=10: 'Pool.'=5+'apply'=5=10; between map=8 and starmap=12); element length ordering: all equal=4 (unique: all four elements of apply co_varnames have the same length); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: mppool119b

  columns: [id, function, args, expected, description]
  rows:
    - [app_vlen,   "pool.Pool.apply.__code__.co_varnames.__len__",    [],          4,    "Pool.apply co_varnames.__len__() == 4 (('self','func','args','kwds'); all params=4; tied with map=4 and starmap=4); verified with Python 3.14.3"]
    - [app_v1_eq,  "pool.Pool.apply.__code__.co_varnames[1].__eq__",  ["func"],    true, "Pool.apply co_varnames[1] == 'func' (len=4; tied with map/starmap co_varnames[1]='func'); verified with Python 3.14.3"]
    - [app_v1_len, "pool.Pool.apply.__code__.co_varnames[1].__len__", [],          4,    "Pool.apply co_varnames[1].__len__() == 4 ('func'=4; same across all three Pool methods); verified with Python 3.14.3"]
    - [app_v2_eq,  "pool.Pool.apply.__code__.co_varnames[2].__eq__",  ["args"],    true, "Pool.apply co_varnames[2] == 'args' (len=4; positional args for func; vs map co_varnames[2]='iterable'=8); verified with Python 3.14.3"]
    - [app_v2_len, "pool.Pool.apply.__code__.co_varnames[2].__len__", [],          4,    "Pool.apply co_varnames[2].__len__() == 4 ('args'=4; shorter than map 'iterable'=8); verified with Python 3.14.3"]
    - [app_v3_eq,  "pool.Pool.apply.__code__.co_varnames[3].__eq__",  ["kwds"],    true, "Pool.apply co_varnames[3] == 'kwds' (len=4; keyword args dict for func; vs map 'chunksize'=9); verified with Python 3.14.3"]
    - [app_v3_len, "pool.Pool.apply.__code__.co_varnames[3].__len__", [],          4,    "Pool.apply co_varnames[3].__len__() == 4 ('kwds'=4; all 4 apply co_varnames have len=4); verified with Python 3.14.3"]
    - [app_qn_eq,  "pool.Pool.apply.__code__.co_qualname.__eq__",     ["Pool.apply"], true, "Pool.apply.__code__.co_qualname == 'Pool.apply' (len=10); verified with Python 3.14.3"]
    - [app_qn_len, "pool.Pool.apply.__code__.co_qualname.__len__",    [],          10,   "Pool.apply.__code__.co_qualname.__len__() == 10 ('Pool.'=5+'apply'=5=10; between map=8 and starmap=12); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra119
# ---------------------------------------------------------------------------

invariant multiprocessing_extra119.pool_map_v1_func:
  description: "multiprocessing.pool.Pool.map.__code__.co_varnames[1].__eq__('func') returns True — Pool.map co_varnames[1]='func' (len=4); Pool.map(func, iterable, chunksize=None) applies func to every element of iterable using worker processes and returns a list of results in the same order; 'func'=4 is tied with 'self'=4 at the same length; co_argcount==4 (all 4 co_varnames are parameters: no local-only variables in map); compare: Pool.starmap co_varnames[1]='func' (same name, same index, same length — symmetric design between map and starmap); Pool.apply co_varnames[1]='func' (also 'func' at index 1 — all three Pool methods use 'func' as the first non-self parameter); compare to concurrent.futures: ProcessPoolExecutor.submit uses 'fn'=2 (not 'func'=4; shorter abbreviation); pool.Pool uses 'func' consistently; Pool.map.__code__.co_qualname=='Pool.map' (len=8: shortest qualname in this spec: 'Pool.'=5+'map'=3=8); co_varnames[3]='chunksize'=9 is the longest element (5 more than 'func'=4); first standalone Pool.map co_varnames[1] equality invariant in mppool119 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "pool.Pool.map.__code__.co_varnames[1].__eq__"
  args: ["func"]
  expected: true

invariant multiprocessing_extra119.pool_map_v3_chunksize:
  description: "multiprocessing.pool.Pool.map.__code__.co_varnames[3].__eq__('chunksize') returns True — Pool.map co_varnames[3]='chunksize' (len=9; the longest element in map/starmap co_varnames and in this spec); chunksize controls how the iterable is split into chunks when submitting tasks to worker processes; a larger chunksize reduces inter-process communication overhead but may cause load imbalance; when None (default) Pool.map chooses a chunksize automatically; 'chunksize'=9: 'chunk'=5+'size'=4=9; Pool.starmap co_varnames[3]='chunksize' (same name, same index, same length — map and starmap are identical in co_varnames structure); compare: Pool.apply co_varnames[3]='kwds'=4 (5 shorter than 'chunksize'=9; apply uses keyword args dict instead of chunk size); Pool.map.__code__.co_varnames.__len__()==4; Pool.map.__code__.co_qualname=='Pool.map' (len=8); first standalone Pool.map co_varnames[3] equality invariant in mppool119 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "pool.Pool.map.__code__.co_varnames[3].__eq__"
  args: ["chunksize"]
  expected: true

invariant multiprocessing_extra119.pool_starmap_v1_func:
  description: "multiprocessing.pool.Pool.starmap.__code__.co_varnames[1].__eq__('func') returns True — Pool.starmap co_varnames[1]='func' (len=4); Pool.starmap(func, iterable, chunksize=None) applies func to each element of iterable by unpacking it as positional arguments: func(*item) for each item in iterable; this is the star-apply analog of Pool.map (which uses func(item)); co_varnames==('self','func','iterable','chunksize') is identical to Pool.map co_varnames — the only difference is how iterable items are passed to func; Pool.starmap.__code__.co_qualname=='Pool.starmap' (len=12: 'Pool.'=5+'starmap'=7=12; longest qualname in spec: 4 more than Pool.map=8 because 'starmap'=7 vs 'map'=3, diff=4); co_varnames.__len__()==4 (tied with Pool.map=4 and Pool.apply=4); compare to Pool.apply_async.__code__.co_varnames which has 7 elements (('self','func','args','kwds','callback','error_callback','result')); first standalone Pool.starmap co_varnames[1] equality invariant in mppool119a namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "pool.Pool.starmap.__code__.co_varnames[1].__eq__"
  args: ["func"]
  expected: true

invariant multiprocessing_extra119.pool_apply_v2_args:
  description: "multiprocessing.pool.Pool.apply.__code__.co_varnames[2].__eq__('args') returns True — Pool.apply co_varnames[2]='args' (len=4); Pool.apply(func, args=(), kwds={}) calls func(*args, **kwds) in a worker process and blocks until the result is available; 'args'=4 is the tuple of positional arguments; compare: Pool.map co_varnames[2]='iterable'=8 (4 longer: map iterates over all elements, apply calls func once); Pool.apply uses 'args' (explicit positional args tuple) instead of 'iterable' (a sequence to iterate) because apply is a single-call interface not a bulk-mapping interface; co_varnames[2].__len__()==4 is tied with co_varnames[0]='self'=4, co_varnames[1]='func'=4, and co_varnames[3]='kwds'=4 — all four apply co_varnames elements have the same length=4; Pool.apply.__code__.co_qualname=='Pool.apply' (len=10: 'Pool.'=5+'apply'=5=10; between Pool.map=8 and Pool.starmap=12); co_varnames.__len__()==4 (tied with map=4 and starmap=4); first standalone Pool.apply co_varnames[2] equality invariant in mppool119b namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "pool.Pool.apply.__code__.co_varnames[2].__eq__"
  args: ["args"]
  expected: true

invariant multiprocessing_extra119.pool_apply_v3_kwds:
  description: "multiprocessing.pool.Pool.apply.__code__.co_varnames[3].__eq__('kwds') returns True — Pool.apply co_varnames[3]='kwds' (len=4); 'kwds' is the dict of keyword arguments passed to func in the worker process; 'kwds'=4 is an abbreviation for 'kwargs' (5 chars: one shorter than the more common 'kwargs' spelling); Pool uses 'kwds' consistently for keyword arguments (compare: multiprocessing.process.BaseProcess uses 'kwargs'=6 at __init__ co_varnames[5]); 'kwds'=4 is tied with all other apply co_varnames elements ('self'=4, 'func'=4, 'args'=4) — making Pool.apply the only Pool method in this spec where all co_varnames elements have the same length=4; compare: Pool.map co_varnames[3]='chunksize'=9 (5 longer than 'kwds'=4 — map uses chunksize for performance tuning while apply uses kwds for keyword arguments); Pool.apply.__code__.co_qualname=='Pool.apply' (len=10); co_varnames.__len__()==4; first standalone Pool.apply co_varnames[3] equality invariant in mppool119b namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "pool.Pool.apply.__code__.co_varnames[3].__eq__"
  args: ["kwds"]
  expected: true

