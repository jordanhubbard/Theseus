spec: textwrap_extra15
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl and prior extras through textwrap_extra14.zspec.zsdl."
    - "textwrap_extra14 covers: TextWrapper().tabsize==8; TextWrapper.__qualname__; wrap('hello world', 100); wrap('a b', 1); fill('a b c', 3); dedent('\\thello\\n\\tworld'); indent('foo\\nbar', '-- '); shorten('the quick brown fox', 10)."
    - "textwrap_extra13 covers: TextWrapper().expand_tabs==True; TextWrapper().max_lines==None; TextWrapper(width=20).width==20; wrap/fill two-words at width=5; dedent three-line two-space; indent double-angle prefix; shorten default placeholder width=8."
    - "textwrap_extra12 covers: TextWrapper().replace_whitespace==True; dedent single-line four-space; indent '!' prefix; shorten lowercase/space-dot."
    - "textwrap_extra11 covers: fill('', width=20)=='' — empty fill; wrap('hello', width=10)==['hello'] — single word."
    - "textwrap_extra7 covers: shorten('The quick brown fox', 10, placeholder='…') == 'The quick…' — Unicode placeholder."
    - "textwrap_extra.zspec covers: indent('hello\\nworld', '  ') == '  hello\\n  world' — two-space prefix."
    - "NOT yet covered (now covered here): textwrap.wrap('', 70) == [] — empty string produces empty list."
    - "NOT yet covered (now covered here): textwrap.wrap('word', 70) == ['word'] — single word at wide width."
    - "NOT yet covered (now covered here): textwrap.wrap('   leading spaces', 70) == ['leading spaces'] — leading spaces stripped."
    - "NOT yet covered (now covered here): textwrap.fill('a b c', 2) == 'a\\nb\\nc' — width=2, one-char words each on own line."
    - "NOT yet covered (now covered here): textwrap.fill('hello', 70) == 'hello' — single word returned unchanged."
    - "NOT yet covered (now covered here): textwrap.dedent('') == '' — empty string dedent."
    - "NOT yet covered (now covered here): textwrap.dedent('no indent') == 'no indent' — no common indent to strip."
    - "NOT yet covered (now covered here): textwrap.indent('hello\\nworld', '\\t') == '\\thello\\n\\tworld' — tab prefix."
    - "NOT yet covered (now covered here): textwrap.shorten('The quick brown fox', 10) == 'The [...]' — default placeholder, width=10, capital T."
    - "textwrap.wrap('', 70) == [] — empty input produces empty list, not ['']."
    - "textwrap.wrap('word', 70) == ['word'] — single word shorter than width returned as one-element list."
    - "textwrap.wrap('   leading spaces', 70) == ['leading spaces'] — drop_whitespace=True strips leading spaces."
    - "textwrap.fill('a b c', 2) == 'a\\nb\\nc' — three one-char words each own line at width=2."
    - "textwrap.fill('hello', 70) == 'hello' — single word shorter than width returned verbatim."
    - "textwrap.dedent('') == '' — empty string has no common indent, returns empty string unchanged."
    - "textwrap.dedent('no indent') == 'no indent' — no leading whitespace, string returned unchanged."
    - "textwrap.indent('hello\\nworld', '\\t') == '\\thello\\n\\tworld' — tab character as indent prefix."
    - "textwrap.shorten('The quick brown fox', 10) == 'The [...]' — 'The' (3) + ' [...]' (6) = 9 chars, fits in width=10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# textwrap.wrap — edge cases: empty string, single word, leading spaces
#
# textwrap_extra11 covers wrap('hello', width=10) == ['hello'].
# textwrap_extra14 covers wrap('hello world', 100) and wrap('a b', 1).
# No prior spec tests wrap('', 70) (empty list), wrap('word', 70) (single word
# at default-like width=70), or wrap('   leading spaces', 70) (leading spaces
# stripped by drop_whitespace=True default).
# ---------------------------------------------------------------------------

invariant textwrap_extra15.wrap.empty_string:
  description: "textwrap.wrap('', 70) == [] — empty input produces empty list"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["", 70]
  expected: []

invariant textwrap_extra15.wrap.single_word_width70:
  description: "textwrap.wrap('word', 70) == ['word'] — single word at wide width"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["word", 70]
  expected: ["word"]

invariant textwrap_extra15.wrap.leading_spaces_stripped:
  description: "textwrap.wrap('   leading spaces', 70) == ['leading spaces'] — leading spaces stripped"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["   leading spaces", 70]
  expected: ["leading spaces"]

# ---------------------------------------------------------------------------
# textwrap.fill — width=2 and single word at wide width
#
# textwrap_extra14 covers fill('a b c', 3) == 'a\nb\nc'.
# textwrap_extra11 covers fill('', width=20) == ''.
# No prior spec tests fill('a b c', 2) (width=2) or fill('hello', 70).
# At width=2: one-char words 'a', 'b', 'c' each fit on their own line.
# At width=70: 'hello' fits entirely; fill returns it verbatim.
# ---------------------------------------------------------------------------

invariant textwrap_extra15.fill.three_words_width2:
  description: "textwrap.fill('a b c', 2) == 'a\\nb\\nc' — width=2, one-char words each on own line"
  category: fill
  kind: python_call_eq
  function: fill
  args: ["a b c", 2]
  expected: "a\nb\nc"

invariant textwrap_extra15.fill.single_word_wide:
  description: "textwrap.fill('hello', 70) == 'hello' — single word shorter than width returned verbatim"
  category: fill
  kind: python_call_eq
  function: fill
  args: ["hello", 70]
  expected: "hello"

# ---------------------------------------------------------------------------
# textwrap.dedent — empty string and string with no common indent
#
# Prior dedent vectors cover strings with leading spaces or tabs.
# No prior spec tests dedent with an empty string ('' -> '') or with a
# string that has no indent at all ('no indent' -> 'no indent').
# ---------------------------------------------------------------------------

invariant textwrap_extra15.dedent.empty_string:
  description: "textwrap.dedent('') == '' — empty string has no common indent, returned unchanged"
  category: dedent
  kind: python_call_eq
  function: dedent
  args: [""]
  expected: ""

invariant textwrap_extra15.dedent.no_indent:
  description: "textwrap.dedent('no indent') == 'no indent' — no leading whitespace, string unchanged"
  category: dedent
  kind: python_call_eq
  function: dedent
  args: ["no indent"]
  expected: "no indent"

# ---------------------------------------------------------------------------
# textwrap.indent — tab prefix
#
# textwrap_extra covers indent('hello\nworld', '  ') with two-space prefix.
# textwrap_extra11 covers '* ' prefix; textwrap_extra12 covers '! ' and '+ '.
# textwrap_extra14 covers '-- ' (dash-space) prefix.
# No prior spec tests a tab character ('\t') as the indent prefix.
# indent('hello\nworld', '\t') == '\thello\n\tworld'.
# ---------------------------------------------------------------------------

invariant textwrap_extra15.indent.tab_prefix:
  description: "textwrap.indent('hello\\nworld', '\\t') == '\\thello\\n\\tworld' — tab character prefix"
  category: indent
  kind: python_call_eq
  function: indent
  args: ["hello\nworld", "\t"]
  expected: "\thello\n\tworld"

# ---------------------------------------------------------------------------
# textwrap.shorten — 'The quick brown fox' at width=10 with default placeholder
#
# textwrap.zspec covers shorten('The quick brown fox', 15) == 'The quick [...]'.
# textwrap_extra9 covers shorten('The quick brown fox', width=15) similarly.
# textwrap_extra7 covers shorten('The quick brown fox', 10, placeholder='…').
# textwrap_extra14 covers shorten('the quick brown fox', 10) (lowercase 't').
# No prior spec covers shorten('The quick brown fox', 10) with capital T and
# default placeholder ' [...]'. 'The' (3) + ' [...]' (6) = 9 chars ≤ width=10.
# ---------------------------------------------------------------------------

invariant textwrap_extra15.shorten.capital_t_width10:
  description: "textwrap.shorten('The quick brown fox', 10) == 'The [...]' — default placeholder, width=10"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["The quick brown fox", 10]
  expected: "The [...]"

# ---------------------------------------------------------------------------
# Table: wrap edge cases — empty, single word, leading spaces
#
# Groups the three wrap edge-case vectors in one indexed table.
# ---------------------------------------------------------------------------

table textwrap_extra15.wrap_edge_cases:
  description: "textwrap.wrap edge cases — empty input, single word, leading spaces"
  kind: python_call_eq
  category: wrap
  id_prefix: wec

  columns: [id, function, args, expected]
  rows:
    - [empty_string,     wrap, ["",                  70], []]
    - [single_word,      wrap, ["word",              70], ["word"]]
    - [leading_spaces,   wrap, ["   leading spaces", 70], ["leading spaces"]]

# ---------------------------------------------------------------------------
# Table: fill and dedent edge cases
#
# Groups fill and dedent edge-case vectors in one indexed table.
# ---------------------------------------------------------------------------

table textwrap_extra15.fill_dedent_edges:
  description: "textwrap.fill and textwrap.dedent edge cases — empty and no-indent inputs"
  kind: python_call_eq
  category: fill
  id_prefix: fde

  columns: [id, function, args, expected]
  rows:
    - [fill_width2,    fill,   ["a b c",    2],  "a\nb\nc"]
    - [fill_wide,      fill,   ["hello",    70],  "hello"]
    - [dedent_empty,   dedent, [""],              ""]
    - [dedent_no_ws,   dedent, ["no indent"],     "no indent"]
