spec: re_extra1786
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers re.compile, re.match, re.search, re.sub"
    - "re_extra554.zspec.zsdl — covers re.RegexFlag enum member class identity, values, and .name strings"
  notes:
    - "Wave 566, theme: __class_getitem__ and __init_subclass__ class creation hooks."
    - "re.Pattern and re.Match are C extension types that DO define __class_getitem__ in their own __dict__, enabling re.Pattern[str] and re.Match[str] generic subscript syntax."
    - "re.error and re.RegexFlag do NOT define __class_getitem__ — exceptions and enums do not support this pattern."
    - "None of the re types define __init_subclass__ in their own __dict__ — C types do not customise subclassing."
    - "Complementary rows: Pattern defines match, search, findall, sub, split, fullmatch, finditer; Match defines group, groups, groupdict, span, start, end."
    - "All expected values verified by running Python 3.14 re module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Wave 566 theme: __class_getitem__ — Pattern and Match define it; error and RegexFlag do not
# Pattern[str] and Match[str] are valid; re.error[str] and re.RegexFlag[int] are not
# ---------------------------------------------------------------------------

table re_extra1786.class_getitem:
  description: "__class_getitem__ in re type __dict__ — True for Pattern and Match (C generics), False for error and RegexFlag"
  kind: python_call_eq
  category: class_creation_hooks
  id_prefix: re1786

  columns: [id, function, args, expected]
  rows:
    - ["re1786001", re.Pattern.__dict__.__contains__,   ["__class_getitem__"], true]
    - ["re1786002", re.Match.__dict__.__contains__,     ["__class_getitem__"], true]
    - ["re1786003", re.error.__dict__.__contains__,     ["__class_getitem__"], false]
    - ["re1786004", re.RegexFlag.__dict__.__contains__, ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Wave 566 theme: __init_subclass__ — absent from all re types
# C extension types do not customise subclassing via __init_subclass__
# ---------------------------------------------------------------------------

table re_extra1786.init_subclass:
  description: "__init_subclass__ absent from all re type __dict__ — C types do not override it"
  kind: python_call_eq
  category: class_creation_hooks
  id_prefix: re1786

  columns: [id, function, args, expected]
  rows:
    - ["re1786005", re.Pattern.__dict__.__contains__,   ["__init_subclass__"], false]
    - ["re1786006", re.Match.__dict__.__contains__,     ["__init_subclass__"], false]
    - ["re1786007", re.error.__dict__.__contains__,     ["__init_subclass__"], false]
    - ["re1786008", re.RegexFlag.__dict__.__contains__, ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Complementary: Pattern defines search methods directly in its own __dict__
# match, search, findall, sub, split, fullmatch, finditer are all on Pattern
# ---------------------------------------------------------------------------

table re_extra1786.pattern_dict_methods:
  description: "re.Pattern defines match, search, findall, sub, split, fullmatch, finditer in its own __dict__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: re1786

  columns: [id, function, args, expected]
  rows:
    - ["re1786009",  re.Pattern.__dict__.__contains__, ["match"],    true]
    - ["re1786010",  re.Pattern.__dict__.__contains__, ["search"],   true]
    - ["re1786011",  re.Pattern.__dict__.__contains__, ["findall"],  true]
    - ["re1786012",  re.Pattern.__dict__.__contains__, ["sub"],      true]
    - ["re1786013",  re.Pattern.__dict__.__contains__, ["split"],    true]
    - ["re1786014",  re.Pattern.__dict__.__contains__, ["fullmatch"], true]
    - ["re1786015",  re.Pattern.__dict__.__contains__, ["finditer"], true]

# ---------------------------------------------------------------------------
# Complementary: Match defines capture-access methods directly in its own __dict__
# group, groups, groupdict, span, start, end are all on Match
# Pattern does NOT define group/groupdict/span/start/end
# ---------------------------------------------------------------------------

table re_extra1786.match_dict_methods:
  description: "re.Match defines group, groups, groupdict, span, start, end in its own __dict__; Pattern does NOT define group/groupdict/span/start/end"
  kind: python_call_eq
  category: dict_membership
  id_prefix: re1786

  columns: [id, function, args, expected]
  rows:
    - ["re1786016", re.Match.__dict__.__contains__,   ["group"],     true]
    - ["re1786017", re.Match.__dict__.__contains__,   ["groups"],    true]
    - ["re1786018", re.Match.__dict__.__contains__,   ["groupdict"], true]
    - ["re1786019", re.Match.__dict__.__contains__,   ["span"],      true]
    - ["re1786020", re.Match.__dict__.__contains__,   ["start"],     true]
    - ["re1786021", re.Match.__dict__.__contains__,   ["end"],       true]
    - ["re1786022", re.Pattern.__dict__.__contains__, ["group"],     false]
    - ["re1786023", re.Pattern.__dict__.__contains__, ["groupdict"], false]
    - ["re1786024", re.Pattern.__dict__.__contains__, ["span"],      false]
