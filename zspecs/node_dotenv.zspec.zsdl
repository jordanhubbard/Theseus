spec: node_dotenv
version: ">=16.0.0"
backend: node(dotenv)

docs: https://github.com/motdotla/dotenv#readme

provenance:
  derived_from:
    - "dotenv README — https://github.com/motdotla/dotenv#readme"
    - "Test vectors verified with dotenv via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "dotenv source"
  notes:
    - "dotenv (npm) is the JavaScript port of the same .env loader idea as python-dotenv."
    - "Spec name is prefixed 'node_' to disambiguate from the python-dotenv spec (zspecs/dotenv.zspec.zsdl)."
    - "Install: npm install dotenv"
    - "dotenv.parse(buffer_or_string) returns an object mapping KEY -> string-value."
    - "All values are strings, even when the source looks numeric or boolean."
    - "Comments (lines starting with #) and blank lines are ignored."
    - "Quoted values strip the quotes. Trailing whitespace on unquoted values is trimmed."
    - "Empty input returns {}."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "parse() never throws on malformed input — invalid lines are skipped silently."
  stderr: "null"
  stickiness: "N/A — each parse call is independent."
  codes: {}

table node_dotenv.parse:
  kind: node_module_call_eq
  category: parse
  function: parse
  id_prefix: parse

  columns: [id, args, expected]
  rows:
    - [single_pair,            ["FOO=bar"],                       {FOO: "bar"}]
    - [two_pairs,              ["A=1\nB=2"],                       {A: "1", B: "2"}]
    - [empty_value,            ["EMPTY="],                         {EMPTY: ""}]
    - [comment_line_skipped,   ["# a comment\nFOO=bar"],           {FOO: "bar"}]
    - [double_quoted,          ["QUOTED=\"hello world\""],         {QUOTED: "hello world"}]
    - [single_quoted,          ["SINGLE='val'"],                   {SINGLE: "val"}]
    - [trailing_whitespace,    ["SPACES=  trimmed  "],             {SPACES: "trimmed"}]
    - [equals_in_value,        ["EQUALS=a=b=c"],                   {EQUALS: "a=b=c"}]
    - [empty_input,            [""],                                {}]
    - [numeric_stays_string,   ["PORT=8080"],                      {PORT: "8080"}]
    - [boolean_stays_string,   ["DEBUG=true"],                     {DEBUG: "true"}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:51:02Z
  iterations: 1
  pass_count: 11
  fail_count: 0
  total_invariants: 11
  notes: Synthesis succeeded in 1 iteration(s). 11 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
