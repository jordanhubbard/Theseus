# ---------------------------------------------------------------------------

table inspect_extra131.getsourcefile_code_attrs:
  description: "inspect.getsourcefile code object: co_varnames[0]=='object', co_argcount==1, len(co_varnames)==3, __qualname__=='getsourcefile' len 13; wave 261; new to extra131"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgetsrc131

  columns: [id, function, args, expected, description]
  rows:
    - [getsourcefile_co_varnames_0_eq_object,
       "getsourcefile.__code__.co_varnames[0].__eq__",
       ["object"],
       true,
       "inspect.getsourcefile.__code__.co_varnames[0].__eq__('object') == True — getsourcefile is defined as 'def getsourcefile(object):' in Lib/inspect.py; the single positional parameter is 'object'; co_varnames[0] is 'object'; str.__eq__('object') returns True; new to extra131"]
    - [getsourcefile_co_argcount_eq_1,
       "getsourcefile.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getsourcefile.__code__.co_argcount.__eq__(1) == True — getsourcefile takes a single positional argument 'object'; co_argcount is 1; int.__eq__(1) returns True; new to extra131"]
    - [getsourcefile_co_varnames_len_3,
       "getsourcefile.__code__.co_varnames.__len__",
       [],
       3,
       "inspect.getsourcefile.__code__.co_varnames.__len__() == 3 — co_varnames lists all local variable names: object, all_bytecode_suffixes, module; tuple.__len__() returns 3; new to extra131"]
    - [getsourcefile_qualname_eq,
       "getsourcefile.__qualname__.__eq__",
       ["getsourcefile"],
       true,
       "inspect.getsourcefile.__qualname__.__eq__('getsourcefile') == True — getsourcefile is defined at module scope in Lib/inspect.py; its __qualname__ is 'getsourcefile'; str.__eq__('getsourcefile') returns True; new to extra131"]
    - [getsourcefile_qualname_len_13,
       "getsourcefile.__qualname__.__len__",
       [],
       13,
       "inspect.getsourcefile.__qualname__.__len__() == 13 — 'getsourcefile' has 13 characters; str.__len__() returns 13; new to extra131"]
    - [getsourcefile_module_eq_inspect,
       "getsourcefile.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getsourcefile.__module__.__eq__('inspect') == True — getsourcefile is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra131"]

