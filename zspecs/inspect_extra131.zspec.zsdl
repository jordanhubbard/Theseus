# ---------------------------------------------------------------------------
# Standalone invariants — extra131
# ---------------------------------------------------------------------------

invariant inspect_extra131.getmodule_co_varnames_0:
  description: "inspect.getmodule.__code__.co_varnames[0] == 'object' — first positional parameter; wave 261; new to extra131"
  kind: python_call_eq
  function: "getmodule.__code__.co_varnames[0].__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra131.getmodule_co_argcount:
  description: "inspect.getmodule.__code__.co_argcount == 2 — positional params: object, _filename; wave 261; new to extra131"
  kind: python_call_eq
  function: getmodule.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra131.getsourcefile_co_varnames_0:
  description: "inspect.getsourcefile.__code__.co_varnames[0] == 'object' — single positional parameter; wave 261; new to extra131"
  kind: python_call_eq
  function: "getsourcefile.__code__.co_varnames[0].__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra131.getsourcefile_co_argcount:
  description: "inspect.getsourcefile.__code__.co_argcount == 1 — single positional parameter 'object'; wave 261; new to extra131"
  kind: python_call_eq
  function: getsourcefile.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra131.getsourcelines_co_varnames_len:
  description: "len(inspect.getsourcelines.__code__.co_varnames) == 3 — local vars: object, lines, lnum; wave 261; new to extra131"
  kind: python_call_eq
  function: getsourcelines.__code__.co_varnames.__len__
  args: []
  expected: 3
