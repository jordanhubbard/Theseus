spec: inspect_extra131
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getmodule and inspect.getsourcefile and inspect.getsourcelines code object attributes (Wave 261)."
    - "inspect.getmodule.__code__.co_varnames[0] == 'object' — first positional param. Verified with Python 3.14.3."
    - "inspect.getmodule.__code__.co_argcount == 2 — two positional args: object, _filename. Verified with Python 3.14.3."
    - "len(inspect.getmodule.__code__.co_varnames) == 10 — variables: object, _filename, file, modname, module, f, main, mainobject, builtin, builtinobject. Verified with Python 3.14.3."
    - "inspect.getmodule.__code__.co_varnames[1] == '_filename'. Verified with Python 3.14.3."
    - "inspect.getsourcefile.__code__.co_varnames[0] == 'object' — first positional param. Verified with Python 3.14.3."
    - "inspect.getsourcefile.__code__.co_argcount == 1 — one positional argument (object). Verified with Python 3.14.3."
    - "len(inspect.getsourcefile.__code__.co_varnames) == 3 — variables: object, all_bytecode_suffixes, module. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__code__.co_varnames[0] == 'object' — first positional param. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__code__.co_argcount == 1 — one positional argument (object). Verified with Python 3.14.3."
    - "len(inspect.getsourcelines.__code__.co_varnames) == 3 — variables: object, lines, lnum. Verified with Python 3.14.3."
    - "inspect.getmodule.__qualname__ == 'getmodule' (len 9). Verified with Python 3.14.3."
    - "inspect.getsourcefile.__qualname__ == 'getsourcefile' (len 13). Verified with Python 3.14.3."
    - "inspect.getsourcelines.__qualname__ == 'getsourcelines' (len 14). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getmodule code object attributes
#
# Wave 261 theme: inspect.getmodule co_varnames, co_argcount, co_varnames length.
#
# inspect.getmodule.__code__.co_varnames[0] == 'object'
# inspect.getmodule.__code__.co_varnames[1] == '_filename'
# inspect.getmodule.__code__.co_argcount == 2
# len(inspect.getmodule.__code__.co_varnames) == 10
#
# getmodule(object, _filename=None) has co_argcount==2 (both object and _filename
# are positional-or-keyword). co_varnames contains all 10 local names.
# New to extra131.
# ---------------------------------------------------------------------------

table inspect_extra131.getmodule_code_attrs:
  description: "inspect.getmodule code object: co_varnames[0]=='object', co_varnames[1]=='_filename', co_argcount==2, len(co_varnames)==10; wave 261; new to extra131"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgetmod131

  columns: [id, function, args, expected, description]
  rows:
    - [getmodule_co_varnames_0_eq_object,
       "getmodule.__code__.co_varnames[0].__eq__",
       ["object"],
       true,
       "inspect.getmodule.__code__.co_varnames[0].__eq__('object') == True — getmodule is defined as 'def getmodule(object, _filename=None):' in Lib/inspect.py; the first positional parameter is 'object'; co_varnames[0] is 'object'; str.__eq__('object') returns True; new to extra131"]
    - [getmodule_co_varnames_1_eq__filename,
       "getmodule.__code__.co_varnames[1].__eq__",
       ["_filename"],
       true,
       "inspect.getmodule.__code__.co_varnames[1].__eq__('_filename') == True — the second positional parameter of getmodule is '_filename' (optional, used to specify a known filename for the object); co_varnames[1] is '_filename'; str.__eq__('_filename') returns True; new to extra131"]
    - [getmodule_co_argcount_eq_2,
       "getmodule.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmodule.__code__.co_argcount.__eq__(2) == True — co_argcount counts positional-or-keyword parameters; getmodule has two: object and _filename; int.__eq__(2) returns True; new to extra131"]
    - [getmodule_co_varnames_len_10,
       "getmodule.__code__.co_varnames.__len__",
       [],
       10,
       "inspect.getmodule.__code__.co_varnames.__len__() == 10 — co_varnames lists all local variable names: object, _filename, file, modname, module, f, main, mainobject, builtin, builtinobject; tuple.__len__() returns 10; new to extra131"]
    - [getmodule_qualname_eq,
       "getmodule.__qualname__.__eq__",
       ["getmodule"],
       true,
       "inspect.getmodule.__qualname__.__eq__('getmodule') == True — getmodule is defined at module scope in Lib/inspect.py; its __qualname__ is the simple function name 'getmodule'; str.__eq__('getmodule') returns True; new to extra131"]
    - [getmodule_qualname_len_9,
       "getmodule.__qualname__.__len__",
       [],
       9,
       "inspect.getmodule.__qualname__.__len__() == 9 — 'getmodule' has 9 characters; str.__len__() returns 9; new to extra131"]

# ---------------------------------------------------------------------------
