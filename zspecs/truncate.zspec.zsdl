spec: truncate
version: ">=2.0.0"
backend: node(truncate)

docs: https://www.npmjs.com/package/truncate

provenance:
  derived_from:
    - "truncate README — https://www.npmjs.com/package/truncate"
    - "Test vectors verified with truncate via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "truncate source"
  notes:
    - "truncate is an npm package. Install: npm install truncate"
    - "truncate(str, length) keeps the first `length` characters and appends the Unicode ellipsis '…' (U+2026)."
    - "If the string fits within `length`, it is returned unchanged."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns truncated string with ellipsis, or original if short enough."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table truncate.truncate:
  kind: node_module_call_eq
  function: ~
  category: truncate
  id_prefix: trunc

  columns: [id, args, expected]
  rows:
    - [long,    ["This is a long sentence.", 10],  "This is a …"]
    - [words,   ["Hello World", 5],                "Hello…"]
    - [short,   ["Short", 10],                     "Short"]
    - [exact,   ["Hello", 5],                      "Hello"]
