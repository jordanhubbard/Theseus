spec: truncate
version: ">=3.0.0"
backend: node(truncate)

docs: https://www.npmjs.com/package/truncate

provenance:
  derived_from:
    - "truncate README — https://www.npmjs.com/package/truncate"
    - "Test vectors verified with truncate via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "truncate source"
  notes:
    - "truncate is an npm package. Install: npm install truncate"
    - "truncate(str, maxLen) shortens a string to maxLen chars and appends '…' (U+2026) if truncated."
    - "Strings at or below maxLen are returned unchanged."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns truncated string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table truncate.truncate:
  kind: node_module_call_eq
  function: ~
  category: truncate
  id_prefix: trunc

  columns: [id, args, expected]
  rows:
    - [truncated,  ["Hello World", 5],  "Hello…"]
    - [long,       ["Hello World this is a long string", 10], "Hello Worl…"]
    - [no_change,  ["Hello", 10],       "Hello"]
