spec: uuid_extra102
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra101.zspec.zsdl — covers SafeUUID enum class identity (__name__/__module__/__qualname__/__bases__[0]/__mro__/__class__ EnumType/member class/member count) (table + invariants)."
    - "uuid_extra100.zspec.zsdl — covers UUID class-level descriptor types for hex/bytes/bytes_le/int/variant / UUID.int member_descriptor qualname and __objclass__ / UUID.__slots__ element names and UUID.__setattr__ qualname (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__ code attributes (co_name, co_argcount) / UUID.__str__/__repr__ qualname equality and length / UUID.__eq__/__hash__/__lt__ qualname equality and length (table + invariants)."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants class names and hex/str values (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality / RFC field property qualname lengths / type(UUID.hex).__name__=='property' (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__/__class__/__qualname__ equality and length (table + invariants)."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__/__bases__[0].__name__/'Enum' (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra101; it does NOT duplicate invariants present in those files."
    - "Wave 271 theme: UUID.variant is a property; UUID.is_safe is a member_descriptor; UUID.__reduce__ is a method_descriptor (from object); UUID.__hash__/__str__ are plain functions; UUID comparison operators (__lt__/__le__/__gt__/__ge__) are plain functions with co_argcount==2."
    - "type(uuid.UUID.variant).__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.is_safe).__name__ == 'member_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__qualname__ == 'UUID.variant'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.is_safe.__qualname__ == 'UUID.is_safe'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.is_safe.__objclass__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.__reduce__).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__reduce__.__qualname__ == 'object.__reduce__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.__hash__).__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(uuid.UUID.__str__).__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__qualname__ == 'UUID.__str__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__qualname__ == 'UUID.__le__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__gt__.__qualname__ == 'UUID.__gt__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ge__.__qualname__ == 'UUID.__ge__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('UUID.__lt__') == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__gt__.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ge__.__code__.co_argcount == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('UUID.__hash__') == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('UUID.__str__') == 12. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: UUID.variant is a property (Python-level with fget) because UUID.variant involves conditional logic based on UUID bit fields; UUID.is_safe is a member_descriptor (C-level struct field) because is_safe is stored as a __slots__ field. uuid_extra100 covers hex/bytes/int/variant descriptors; this spec anchors the variant/is_safe type distinction and comparison operator details."
    - "Note: UUID.__reduce__ has type method_descriptor with qualname 'object.__reduce__' — UUID inherits __reduce__ from object. UUID.__hash__ and UUID.__str__ are Python-defined functions (not inherited from object), so they have type 'function' with qualnames 'UUID.__hash__' and 'UUID.__str__'. uuid_extra99 anchors UUID.__str__ qualname length; this spec anchors the full equality and the variant/is_safe type distinction."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# type(uuid.UUID.variant).__name__.__eq__('property')
# type(uuid.UUID.is_safe).__name__.__eq__('member_descriptor')
# uuid.UUID.variant.fget.__qualname__.__eq__('UUID.variant')
# uuid.UUID.is_safe.__qualname__.__eq__('UUID.is_safe')
# uuid.UUID.is_safe.__objclass__.__name__.__eq__('UUID')
#
# Wave 271 theme: UUID.variant is a property; UUID.is_safe is a member_descriptor.
#
# UUID.variant is a Python property with fget.__qualname__ == 'UUID.variant'.
# It involves conditional logic to determine the UUID variant from bits 62-63
# of the integer field — hence it is a property (Python-level getter), not a
# C-level descriptor. UUID.is_safe is a member_descriptor (C-level field) because
# is_safe is stored directly in the UUID __slots__ struct without getter logic.
# uuid_extra100 covers UUID hex/bytes/int/variant descriptor types; this spec
# anchors the variant/is_safe type distinction more precisely.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra102.UUID_variant_and_is_safe_descriptor_types:
  description: "type(UUID.variant).__name__.__eq__('property')==True / type(UUID.is_safe).__name__.__eq__('member_descriptor')==True / UUID.variant.fget.__qualname__.__eq__('UUID.variant')==True / UUID.is_safe.__qualname__.__eq__('UUID.is_safe')==True / UUID.is_safe.__objclass__.__name__.__eq__('UUID')==True — variant is a Python property (conditional bit logic); is_safe is a member_descriptor (C-level slot field); fget qualname confirms Python-level getter for variant; __objclass__ for is_safe is UUID; extra100 covers descriptor types; first uuidprop102 anchor"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: uuidprop102

  columns: [id, function, args, expected, description]
  rows:
    - [variant_type_eq,      "UUID.variant.__class__.__name__.__eq__",           ["property"],          true, "type(UUID.variant) is 'property' (Python-level property; conditional bit logic for variant determination)"]
    - [is_safe_type_eq,      "UUID.is_safe.__class__.__name__.__eq__",           ["member_descriptor"], true, "type(UUID.is_safe) is 'member_descriptor' (C-level slot field; stored in UUID __slots__ struct)"]
    - [variant_fget_qualname, "UUID.variant.fget.__qualname__.__eq__",           ["UUID.variant"],      true, "UUID.variant.fget.__qualname__ is 'UUID.variant' (fget is the Python getter function for the variant property)"]
    - [is_safe_qualname_eq,   "UUID.is_safe.__qualname__.__eq__",                ["UUID.is_safe"],      true, "UUID.is_safe.__qualname__ is 'UUID.is_safe' (member_descriptor qualname follows 'Class.attr' pattern)"]
    - [is_safe_objclass_eq,   "UUID.is_safe.__objclass__.__name__.__eq__",       ["UUID"],              true, "UUID.is_safe.__objclass__.__name__ is 'UUID' (__objclass__ is the class the member_descriptor is defined on)"]

# ---------------------------------------------------------------------------
# type(uuid.UUID.__reduce__).__name__.__eq__('method_descriptor')
# uuid.UUID.__reduce__.__qualname__.__eq__('object.__reduce__')
# type(uuid.UUID.__hash__).__name__.__eq__('function')
# uuid.UUID.__hash__.__qualname__.__eq__('UUID.__hash__')
# type(uuid.UUID.__str__).__name__.__eq__('function')
#
# Wave 271 theme: UUID.__reduce__ is from object; UUID.__hash__ and __str__ are Python functions.
#
# UUID.__reduce__ has type method_descriptor with qualname 'object.__reduce__' —
# UUID does not define its own __reduce__, so it inherits the C-level implementation
# from object. UUID.__hash__ and UUID.__str__ are Python-defined functions in
# Lib/uuid.py (type 'function'), not inherited from object. uuid_extra99 anchors
# UUID.__str__ qualname length and UUID.__hash__ qualname length; this spec anchors
# the full type names and qualname equality checks as a grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra102.UUID_reduce_hash_str_types_and_qualnames:
  description: "type(UUID.__reduce__).__name__.__eq__('method_descriptor')==True / UUID.__reduce__.__qualname__.__eq__('object.__reduce__')==True / type(UUID.__hash__).__name__.__eq__('function')==True / UUID.__hash__.__qualname__.__eq__('UUID.__hash__')==True / type(UUID.__str__).__name__.__eq__('function')==True — __reduce__ is inherited from object (method_descriptor); __hash__ and __str__ are Python-defined functions; qualname 'object.__reduce__' shows inheritance from object; extra99 anchors qualname lengths; first uuidprop102 anchor"
  kind: python_call_eq
  category: method_identity
  id_prefix: uuidprop102

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_type_eq,       "UUID.__reduce__.__class__.__name__.__eq__",    ["method_descriptor"],   true, "type(UUID.__reduce__) is 'method_descriptor' (inherited from object; UUID has no custom __reduce__)"]
    - [reduce_qualname_eq,   "UUID.__reduce__.__qualname__.__eq__",          ["object.__reduce__"],   true, "UUID.__reduce__.__qualname__ is 'object.__reduce__' (17 chars; inherited from object via MRO)"]
    - [hash_type_eq,         "UUID.__hash__.__class__.__name__.__eq__",      ["function"],            true, "type(UUID.__hash__) is 'function' (Python-defined in Lib/uuid.py; UUID defines its own __hash__)"]
    - [hash_qualname_eq,     "UUID.__hash__.__qualname__.__eq__",            ["UUID.__hash__"],       true, "UUID.__hash__.__qualname__ is 'UUID.__hash__' (13 chars; 'UUID.'=5 + '__hash__'=8)"]
    - [str_type_eq,          "UUID.__str__.__class__.__name__.__eq__",       ["function"],            true, "type(UUID.__str__) is 'function' (Python-defined in Lib/uuid.py; UUID defines its own __str__)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__lt__.__qualname__.__eq__('UUID.__lt__')
# uuid.UUID.__le__.__qualname__.__eq__('UUID.__le__')
# uuid.UUID.__lt__.__code__.co_argcount.__eq__(2)
# uuid.UUID.__gt__.__qualname__.__eq__('UUID.__gt__')
# uuid.UUID.__lt__.__qualname__.__len__()==11
#
# Wave 271 theme: UUID comparison operators (__lt__/__le__/__gt__/__ge__) are Python functions.
#
# UUID.__lt__, UUID.__le__, UUID.__gt__, UUID.__ge__ are Python-defined functions
# in Lib/uuid.py that implement UUID ordering by comparing the integer representations.
# All four have qualnames following the 'UUID.__op__' pattern with length 11
# ('UUID.'=5 + '__lt__'=6 etc., all length 6 for the dunder name). All have
# co_argcount==2 (self, other). uuid_extra99 anchors UUID.__lt__ qualname length;
# this spec anchors the full qualname equality and co_argcount for all four.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra102.UUID_comparison_operators_qualnames_and_argcount:
  description: "UUID.__lt__.__qualname__.__eq__('UUID.__lt__')==True / UUID.__le__.__qualname__.__eq__('UUID.__le__')==True / UUID.__lt__.__code__.co_argcount.__eq__(2)==True / UUID.__gt__.__qualname__.__eq__('UUID.__gt__')==True / UUID.__lt__.__qualname__.__len__()==11 — all four comparison operators are Python-defined functions; qualnames follow 'UUID.__op__' pattern (11 chars each); co_argcount==2 (self, other) for all; compare UUID integer representations; extra99 anchors __lt__ qualname length; first uuidprop102 anchor"
  kind: python_call_eq
  category: method_identity
  id_prefix: uuidprop102

  columns: [id, function, args, expected, description]
  rows:
    - [lt_qualname_eq,       "UUID.__lt__.__qualname__.__eq__",          ["UUID.__lt__"],  true, "UUID.__lt__.__qualname__ is 'UUID.__lt__' (11 chars; 'UUID.'=5 + '__lt__'=6; compares UUID ints for less-than)"]
    - [le_qualname_eq,       "UUID.__le__.__qualname__.__eq__",          ["UUID.__le__"],  true, "UUID.__le__.__qualname__ is 'UUID.__le__' (11 chars; 'UUID.'=5 + '__le__'=6; less-than-or-equal comparison)"]
    - [lt_co_argcount,       "UUID.__lt__.__code__.co_argcount.__eq__",  [2],              true, "UUID.__lt__.__code__.co_argcount is 2 (self, other; compares self.int vs other.int)"]
    - [gt_qualname_eq,       "UUID.__gt__.__qualname__.__eq__",          ["UUID.__gt__"],  true, "UUID.__gt__.__qualname__ is 'UUID.__gt__' (11 chars; 'UUID.'=5 + '__gt__'=6; greater-than comparison)"]
    - [lt_qualname_len,      "UUID.__lt__.__qualname__.__len__",         [],               11,   "UUID.__lt__.__qualname__.__len__() is 11 ('UUID.__lt__': 'UUID.'=5 + '__lt__'=6)"]

# ---------------------------------------------------------------------------
# type(uuid.UUID.variant).__name__.__eq__('property') — standalone
#
# type(uuid.UUID.variant).__name__ is 'property'. UUID.variant is a Python-level
# property because determining the UUID variant requires conditional bit inspection:
# bits 62-63 of the UUID integer determine the variant (RFC 4122, Microsoft, NCS,
# or future). This cannot be expressed as a simple C-level field access — it
# requires branching logic. Contrast with UUID.int, UUID.time, UUID.clock_seq,
# etc. which are also Python properties accessing computed integer sub-fields.
# uuid_extra100 covers UUID descriptor type checks at class level; this spec
# anchors UUID.variant type as 'property' as a standalone under uuidprop102.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra102.UUID_variant_is_property:
  description: "type(uuid.UUID.variant).__name__.__eq__('property') == True — UUID.variant is a Python property (conditional bit logic for RFC 4122/Microsoft/NCS variant determination from bits 62-63); contrast with UUID.is_safe which is a member_descriptor; extra100 covers descriptor types; first standalone under uuidprop102"
  category: descriptor_identity
  kind: python_call_eq
  function: "UUID.variant.__class__.__name__.__eq__"
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# type(uuid.UUID.is_safe).__name__.__eq__('member_descriptor') — standalone
#
# type(uuid.UUID.is_safe).__name__ is 'member_descriptor'. UUID.is_safe is stored
# as a __slots__ field in the UUID class. When a class defines __slots__, Python
# creates member_descriptor objects for each slot to provide direct access to the
# C-level slot. UUID.is_safe holds a SafeUUID enum value (safe, unsafe, or unknown)
# indicating whether uuid1() used multiprocessing-safe generation. Unlike UUID.variant
# which requires conditional logic, UUID.is_safe is a direct slot field access.
# uuid_extra100 anchors UUID.int as a member_descriptor; this spec anchors
# UUID.is_safe as member_descriptor as a standalone under uuidprop102.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra102.UUID_is_safe_is_member_descriptor:
  description: "type(uuid.UUID.is_safe).__name__.__eq__('member_descriptor') == True — UUID.is_safe is a __slots__-based member_descriptor (direct C-level slot access; stores SafeUUID enum value); contrast with UUID.variant which is a property (conditional logic); uuid_extra100 anchors UUID.int as member_descriptor; first standalone for is_safe under uuidprop102"
  category: descriptor_identity
  kind: python_call_eq
  function: "UUID.is_safe.__class__.__name__.__eq__"
  args: ["member_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__reduce__.__qualname__.__eq__('object.__reduce__') — standalone
#
# uuid.UUID.__reduce__.__qualname__ is 'object.__reduce__'. UUID inherits
# __reduce__ from object — it does not define its own __reduce__. __reduce__
# is used by pickle to determine how to serialize an object. The fact that
# UUID uses object.__reduce__ means pickle will use the default serialization
# strategy (calling __reduce_ex__ which may use __getnewargs__ or __getstate__).
# The qualname 'object.__reduce__' (17 chars: 'object.'=7 + '__reduce__'=10)
# confirms that the descriptor is defined on object, not UUID. No prior uuid
# spec anchors UUID.__reduce__ qualname equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra102.UUID_reduce_qualname_is_object_reduce:
  description: "uuid.UUID.__reduce__.__qualname__.__eq__('object.__reduce__') == True — qualname is 'object.__reduce__' (17 chars; 'object.'=7 + '__reduce__'=10); UUID inherits __reduce__ from object (no custom implementation); pickle uses default serialization; type is method_descriptor; confirms MRO lookup reaches object; no prior spec anchors as standalone; first standalone under uuidprop102"
  category: method_identity
  kind: python_call_eq
  function: "UUID.__reduce__.__qualname__.__eq__"
  args: ["object.__reduce__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__hash__.__qualname__.__eq__('UUID.__hash__') — standalone
#
# uuid.UUID.__hash__.__qualname__ is 'UUID.__hash__' (13 chars: 'UUID.'=5 +
# '__hash__'=8). UUID defines its own __hash__ in Lib/uuid.py, implementing
# hash(uuid) as hash(uuid.int) — hashing the underlying 128-bit integer. This
# makes UUIDs hashable and usable as dictionary keys. The fact that UUID.__hash__
# is a Python function (type 'function') rather than a method_descriptor or
# wrapper_descriptor confirms it is defined at the Python level in Lib/uuid.py,
# not inherited from object. uuid_extra99 anchors UUID.__hash__ qualname length;
# this spec anchors the full qualname equality as a standalone under uuidprop102.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra102.UUID_hash_qualname_eq:
  description: "uuid.UUID.__hash__.__qualname__.__eq__('UUID.__hash__') == True — qualname is 'UUID.__hash__' (13 chars; 'UUID.'=5 + '__hash__'=8); UUID defines own __hash__ as hash(uuid.int) in Lib/uuid.py; type is 'function' (Python-defined); makes UUIDs hashable/usable as dict keys; extra99 anchors qualname length; first standalone under uuidprop102"
  category: method_identity
  kind: python_call_eq
  function: "UUID.__hash__.__qualname__.__eq__"
  args: ["UUID.__hash__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__le__.__qualname__.__eq__('UUID.__le__') — standalone
#
# uuid.UUID.__le__.__qualname__ is 'UUID.__le__' (11 chars: 'UUID.'=5 +
# '__le__'=6). UUID defines __le__ as a Python function in Lib/uuid.py for
# less-than-or-equal comparison. Like __lt__, __gt__, and __ge__, it has
# co_argcount==2 (self, other) and compares the integer representations of the
# two UUIDs. All four comparison dunder names (__lt__, __le__, __gt__, __ge__)
# have the same length (6 chars each), so all four qualnames have length 11.
# No prior uuid spec anchors UUID.__le__ qualname equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra102.UUID_le_qualname_eq:
  description: "uuid.UUID.__le__.__qualname__.__eq__('UUID.__le__') == True — qualname is 'UUID.__le__' (11 chars; 'UUID.'=5 + '__le__'=6); Python-defined comparison function; co_argcount==2 (self, other); all four comparison ops have same qualname length 11 (__lt__/__le__/__gt__/__ge__ all have 6-char dunder names); no prior spec anchors as standalone; first standalone under uuidprop102"
  category: method_identity
  kind: python_call_eq
  function: "UUID.__le__.__qualname__.__eq__"
  args: ["UUID.__le__"]
  expected: true

