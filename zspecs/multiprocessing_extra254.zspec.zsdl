spec: multiprocessing_extra254
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "multiprocessing is a package: __name__ == 'multiprocessing', __package__ == 'multiprocessing'."
    - "multiprocessing.__spec__.name == 'multiprocessing'; __loader__ is SourceFileLoader."
    - "multiprocessing.__all__ is a list (not a tuple) of 37 names on Python 3.14."
    - "Key members in __all__: 'Process', 'Pool', 'Queue', 'Pipe', 'Lock', 'cpu_count'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module identity — __name__, __package__, __spec__, __loader__
#
# multiprocessing is a package. __name__ and __package__ are both
# 'multiprocessing'. __spec__ is a ModuleSpec; __loader__ is SourceFileLoader.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra254.identity.module_name:
  description: "multiprocessing.__name__ == 'multiprocessing'"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["multiprocessing"]
  expected: true

invariant multiprocessing_extra254.identity.package:
  description: "multiprocessing.__package__ == 'multiprocessing' — package-level module"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["multiprocessing"]
  expected: true

invariant multiprocessing_extra254.identity.spec_class:
  description: "multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant multiprocessing_extra254.identity.spec_name:
  description: "multiprocessing.__spec__.name == 'multiprocessing'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["multiprocessing"]
  expected: true

invariant multiprocessing_extra254.identity.loader_class:
  description: "multiprocessing.__loader__.__class__.__name__ == 'SourceFileLoader'"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing.__all__ — type and key member checks
#
# On Python 3.14, __all__ is a list of 37 names covering process management,
# synchronization primitives, shared memory, and utility functions.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra254.all.type_is_list:
  description: "type(multiprocessing.__all__).__name__ == 'list'"
  category: all
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant multiprocessing_extra254.all.contains_Process:
  description: "'Process' in multiprocessing.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra254.all.contains_Pool:
  description: "'Pool' in multiprocessing.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Pool"]
  expected: true

invariant multiprocessing_extra254.all.contains_Queue:
  description: "'Queue' in multiprocessing.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Queue"]
  expected: true

invariant multiprocessing_extra254.all.contains_Pipe:
  description: "'Pipe' in multiprocessing.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Pipe"]
  expected: true

invariant multiprocessing_extra254.all.contains_Lock:
  description: "'Lock' in multiprocessing.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Lock"]
  expected: true

invariant multiprocessing_extra254.all.contains_cpu_count:
  description: "'cpu_count' in multiprocessing.__all__"
  category: all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["cpu_count"]
  expected: true
