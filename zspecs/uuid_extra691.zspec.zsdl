spec: uuid_extra691
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid.UUID method documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid.UUID dunder method __name__ identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra691.uuid_method_names:
  description: "uuid.UUID dunder method __name__ identity"
  kind: python_call_eq
  category: uuid_method_names
  id_prefix: uu691mn
  columns: [id, function, args, expected]
  rows:
    - [uu691mn001, uuid.UUID.__init__.__name__.__eq__,      ["__init__"],     true]
    - [uu691mn002, uuid.UUID.__str__.__name__.__eq__,       ["__str__"],      true]
    - [uu691mn003, uuid.UUID.__repr__.__name__.__eq__,      ["__repr__"],     true]
    - [uu691mn004, uuid.UUID.__int__.__name__.__eq__,       ["__int__"],      true]
    - [uu691mn005, uuid.UUID.__bytes__.__name__.__eq__,     ["__bytes__"],    true]
    - [uu691mn006, uuid.UUID.__eq__.__name__.__eq__,        ["__eq__"],       true]
    - [uu691mn007, uuid.UUID.__lt__.__name__.__eq__,        ["__lt__"],       true]
    - [uu691mn008, uuid.UUID.__le__.__name__.__eq__,        ["__le__"],       true]
    - [uu691mn009, uuid.UUID.__gt__.__name__.__eq__,        ["__gt__"],       true]
    - [uu691mn010, uuid.UUID.__ge__.__name__.__eq__,        ["__ge__"],       true]
    - [uu691mn011, uuid.UUID.__hash__.__name__.__eq__,      ["__hash__"],     true]
    - [uu691mn012, uuid.UUID.__setattr__.__name__.__eq__,   ["__setattr__"],  true]
