spec: just_tail
version: ">=3.2.0"
backend: node(just-tail)

docs: https://www.npmjs.com/package/just-tail

provenance:
  derived_from:
    - "just-tail README — https://www.npmjs.com/package/just-tail"
    - "Test vectors verified with just-tail via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-tail source"
  notes:
    - "just-tail is an npm package. Install: npm install just-tail"
    - "The module exports a single function that returns all elements except the first."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new array without the first element."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_tail.tail:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: jtail

  columns: [id, args, expected]
  rows:
    - [three_elems, [[1, 2, 3]], [2, 3]]
    - [two_elems,   [[1, 2]],   [2]]
    - [empty,       [[]],       []]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:10:39Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
