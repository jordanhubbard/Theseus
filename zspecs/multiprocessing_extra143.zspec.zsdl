table multiprocessing_extra143.queue_put_get:
  description: "multiprocessing.queues.Queue.put and get qualname and code checks — put.__qualname__.__eq__('Queue.put')==True (len=9: 'Queue'=5+'.'=1+'put'=3=9; tied with get for shortest method qualname in this spec); put.__code__.co_argcount.__eq__(4)==True ('self','obj','block','timeout' — 4 parameters: the obj to put, and blocking/timeout controls); put.__code__.co_varnames.__len__()==4 ('self','obj','block','timeout' — all are parameters, no additional locals); get.__qualname__.__eq__('Queue.get')==True (len=9: tied with put); get.__code__.co_argcount.__eq__(3)==True ('self','block','timeout' — 3 parameters; no obj parameter since get returns a value rather than receiving one); get.__code__.co_varnames.__len__()==5 ('self','block','timeout','res','deadline' — 3 params + 2 locals: res holds the received item, deadline tracks the blocking cutoff time); all Queue methods have __doc__==None (no docstrings); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpqputget143

  columns: [id, function, args, expected, description]
  rows:
