table multiprocessing_extra143.queue_identity:
  description: "multiprocessing.queues.Queue class identity checks — Queue.__name__.__eq__('Queue')==True (len=5: 'Queue'=5; the same name as asyncio.Queue but in the multiprocessing.queues module); Queue.__module__.__eq__('multiprocessing.queues')==True (len=22: 'multiprocessing'=15+'.'=1+'queues'=6=22; note: this differs from multiprocessing.Queue.__module__ which is 'multiprocessing.context' at len=23, because the direct class lives in multiprocessing.queues); Queue.__doc__ is None (no class-level docstring on multiprocessing.queues.Queue; none of the Queue methods have docstrings either — all doc attributes are None); Queue.__init__.__qualname__.__eq__('Queue.__init__')==True (len=14: 'Queue'=5+'.'=1+'__init__'=8=14); Queue.__init__ co_argcount==2 ('self','maxsize'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpqident143

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,      multiprocessing.queues.Queue.__name__.__eq__,    ["Queue"],                    true,  "multiprocessing.queues.Queue.__name__ == 'Queue' (len=5); verified with Python 3.14.3"]
    - [name_len,     multiprocessing.queues.Queue.__name__.__len__,    [],                           5,     "multiprocessing.queues.Queue.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [mod_eq,       multiprocessing.queues.Queue.__module__.__eq__,  ["multiprocessing.queues"],   true,  "multiprocessing.queues.Queue.__module__ == 'multiprocessing.queues' (len=22); verified with Python 3.14.3"]
    - [mod_len,      multiprocessing.queues.Queue.__module__.__len__,  [],                           22,    "multiprocessing.queues.Queue.__module__.__len__() == 22; verified with Python 3.14.3"]
    - [init_qn_eq,   multiprocessing.queues.Queue.__init__.__qualname__.__eq__, ["Queue.__init__"],  true,  "multiprocessing.queues.Queue.__init__.__qualname__ == 'Queue.__init__' (len=14); verified with Python 3.14.3"]
    - [init_qn_len,  multiprocessing.queues.Queue.__init__.__qualname__.__len__, [],                 14,    "multiprocessing.queues.Queue.__init__.__qualname__.__len__() == 14; verified with Python 3.14.3"]
