    - [put_qn_len,   multiprocessing.queues.Queue.put.__qualname__.__len__,          [],             9,     "multiprocessing.queues.Queue.put.__qualname__.__len__() == 9; verified with Python 3.14.3"]
    - [put_argc,     multiprocessing.queues.Queue.put.__code__.co_argcount.__eq__,  [4],             true,  "multiprocessing.queues.Queue.put.__code__.co_argcount == 4 ('self','obj','block','timeout'); verified with Python 3.14.3"]
