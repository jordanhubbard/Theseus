    - [get_qn_eq,    multiprocessing.queues.Queue.get.__qualname__.__eq__,          ["Queue.get"],  true,  "multiprocessing.queues.Queue.get.__qualname__ == 'Queue.get' (len=9); verified with Python 3.14.3"]
