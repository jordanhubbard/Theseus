spec: multiprocessing_extra143
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Queue — Queue documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/queues.py"
  notes:
    - "This spec covers: multiprocessing.queues.Queue — __name__=='Queue' (len=5); __module__=='multiprocessing.queues' (len=22); __doc__==None (no class-level docstring). Queue.put — __qualname__=='Queue.put' (len=9); co_argcount==4 ('self','obj','block','timeout'); co_varnames.__len__()==4. Queue.get — __qualname__=='Queue.get' (len=9); co_argcount==3 ('self','block','timeout'); co_varnames.__len__()==5 ('self','block','timeout','res','deadline'). Queue.empty — __qualname__=='Queue.empty' (len=11); co_argcount==1. Queue.full — __qualname__=='Queue.full' (len=10); co_argcount==1. Queue.qsize — __qualname__=='Queue.qsize' (len=11); co_argcount==1. Queue.close — __qualname__=='Queue.close' (len=11); co_argcount==1; co_varnames.__len__()==2 ('self','close'). Queue.join_thread — __qualname__=='Queue.join_thread' (len=17); co_argcount==1. Queue.cancel_join_thread — __qualname__=='Queue.cancel_join_thread' (len=24); co_argcount==1. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All Queue methods have __doc__==None (no docstrings on multiprocessing.queues.Queue methods). Queue.__module__=='multiprocessing.queues' (len=22: 'multiprocessing'=15+'.'=1+'queues'=6=22). Queue.put and Queue.get both have qualname len==9 (the shortest). Queue.empty, Queue.full, and Queue.qsize all have co_argcount==1; Queue.empty and Queue.qsize tie at qualname len==11; Queue.full has qualname len==10. Queue.cancel_join_thread has the longest qualname (len=24). Queue.get has more co_varnames than put (5 vs 4) due to 'res' and 'deadline' locals used in blocking receive. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

