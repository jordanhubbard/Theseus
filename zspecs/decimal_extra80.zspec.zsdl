spec: decimal_extra80
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra79."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy __bases__ and MRO; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity; Decimal.__dict__.__contains__ for various dunders; Decimal comparison/equality/hash wrapper_descriptor identity; Context/__dict__ class and membership; getcontext/setcontext __class__.__name__ and __module__; Decimal division/power operator wrapper_descriptor identity and __dict__ membership; Context.__init__/__class__.__name__; Context arithmetic method __class__.__name__; Context/__dict__/__class__/__name__ and membership; Context.__bases__[0].__name__; Context.__mro__.__len__(); Decimal arithmetic/string/conversion dunder __qualname__ values and lengths; Decimal comparison operator __qualname__ lengths; Decimal to_*/normalize/quantize/sqrt/compare __qualname__ lengths; Decimal.__dict__.__contains__ for arithmetic/comparison/math operators; Decimal.__dict__.__class__.__name__; Decimal.__name__; Decimal.__module__; Decimal.__qualname__; Decimal.__qualname__.__len__(); Decimal.__module__.__len__(); Decimal.__bases__[0].__name__; Decimal.__mro__.__len__(); Context/__name__/__module__/__qualname__; getcontext/setcontext/localcontext __class__.__name__."
    - "This spec covers: decimal.ROUND_UP/__class__.__name__ == 'str'; decimal.ROUND_DOWN/__class__.__name__ == 'str'; decimal.ROUND_CEILING/__class__.__name__ == 'str'; decimal.ROUND_FLOOR/__class__.__name__ == 'str'; decimal.ROUND_HALF_UP/__class__.__name__ == 'str'; decimal.ROUND_HALF_DOWN/__class__.__name__ == 'str'; decimal.ROUND_HALF_EVEN/__class__.__name__ == 'str'; decimal.ROUND_05UP/__class__.__name__ == 'str'; ROUND_UP.__eq__('ROUND_UP') == True; ROUND_DOWN.__eq__('ROUND_DOWN') == True; ROUND_CEILING.__eq__('ROUND_CEILING') == True; ROUND_FLOOR.__eq__('ROUND_FLOOR') == True; ROUND_HALF_UP.__eq__('ROUND_HALF_UP') == True; ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN') == True; ROUND_UP.__len__() == 8; ROUND_HALF_EVEN.__len__() == 15."
    - "decimal.ROUND_UP is a plain str with value 'ROUND_UP' (length 8)."
    - "decimal.ROUND_DOWN is a plain str with value 'ROUND_DOWN' (length 10)."
    - "decimal.ROUND_CEILING is a plain str with value 'ROUND_CEILING' (length 13)."
    - "decimal.ROUND_FLOOR is a plain str with value 'ROUND_FLOOR' (length 11)."
    - "decimal.ROUND_HALF_UP is a plain str with value 'ROUND_HALF_UP' (length 13)."
    - "decimal.ROUND_HALF_DOWN is a plain str with value 'ROUND_HALF_DOWN' (length 15)."
    - "decimal.ROUND_HALF_EVEN is a plain str with value 'ROUND_HALF_EVEN' (length 15)."
    - "decimal.ROUND_05UP is a plain str with value 'ROUND_05UP' (length 10)."
    - "All ROUND_* constants are plain Python str objects — not enums or subclasses."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.ROUND_* __class__.__name__ — all are plain str
# ROUND_UP, ROUND_DOWN, ROUND_CEILING, ROUND_FLOOR are plain str constants.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra80.round_constants_class_name_1:
  description: "decimal.ROUND_UP/DOWN/CEILING/FLOOR __class__.__name__ == 'str'"
  kind: python_call_eq
  category: constant_identity
  id_prefix: decimalextra80

  columns: [id, function, args, expected]
  rows:
    - [rup_cls,   ROUND_UP.__class__.__name__.__eq__,      ["str"], true]
    - [rdn_cls,   ROUND_DOWN.__class__.__name__.__eq__,    ["str"], true]
    - [rce_cls,   ROUND_CEILING.__class__.__name__.__eq__, ["str"], true]
    - [rfl_cls,   ROUND_FLOOR.__class__.__name__.__eq__,   ["str"], true]

# ---------------------------------------------------------------------------
# decimal.ROUND_* __class__.__name__ — HALF_UP, HALF_DOWN, HALF_EVEN, 05UP
# All are plain str constants; no enum subclassing.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra80.round_constants_class_name_2:
  description: "decimal.ROUND_HALF_UP/HALF_DOWN/HALF_EVEN/05UP __class__.__name__ == 'str'"
  kind: python_call_eq
  category: constant_identity
  id_prefix: decimalextra80

  columns: [id, function, args, expected]
  rows:
    - [rhu_cls,   ROUND_HALF_UP.__class__.__name__.__eq__,   ["str"], true]
    - [rhd_cls,   ROUND_HALF_DOWN.__class__.__name__.__eq__, ["str"], true]
    - [rhe_cls,   ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"], true]
    - [r05_cls,   ROUND_05UP.__class__.__name__.__eq__,      ["str"], true]

# ---------------------------------------------------------------------------
# decimal.ROUND_* string equality — ROUND_UP, ROUND_DOWN, ROUND_CEILING, ROUND_FLOOR
# Each constant equals its own name as a string.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra80.round_constants_eq_1:
  description: "decimal.ROUND_UP/DOWN/CEILING/FLOOR string equality to their own names"
  kind: python_call_eq
  category: constant_identity
  id_prefix: decimalextra80

  columns: [id, function, args, expected]
  rows:
    - [rup_eq,   ROUND_UP.__eq__,      ["ROUND_UP"],      true]
    - [rdn_eq,   ROUND_DOWN.__eq__,    ["ROUND_DOWN"],    true]
    - [rce_eq,   ROUND_CEILING.__eq__, ["ROUND_CEILING"], true]
    - [rfl_eq,   ROUND_FLOOR.__eq__,   ["ROUND_FLOOR"],   true]

# ---------------------------------------------------------------------------
# decimal.ROUND_* string equality — ROUND_HALF_UP, ROUND_HALF_EVEN; and lengths
# ROUND_HALF_UP.__eq__('ROUND_HALF_UP') == True;
# ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN') == True.
# ROUND_UP.__len__() == 8; ROUND_HALF_EVEN.__len__() == 15.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra80.round_constants_eq_2_and_lens:
  description: "decimal.ROUND_HALF_UP/HALF_EVEN equality; ROUND_UP/__len__(), ROUND_HALF_EVEN/__len__()"
  kind: python_call_eq
  category: constant_identity
  id_prefix: decimalextra80

  columns: [id, function, args, expected]
  rows:
    - [rhu_eq,     ROUND_HALF_UP.__eq__,     ["ROUND_HALF_UP"],   true]
    - [rhe_eq,     ROUND_HALF_EVEN.__eq__,   ["ROUND_HALF_EVEN"], true]
    - [rup_len,    ROUND_UP.__len__,          [],                  8]
    - [rhe_len,    ROUND_HALF_EVEN.__len__,   [],                  15]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra80.ROUND_UP.class_name:
  description: "decimal.ROUND_UP.__class__.__name__ == 'str' (ROUND_UP is a plain str constant)"
  category: constant_identity
  kind: python_call_eq
  function: ROUND_UP.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra80.ROUND_UP.eq:
  description: "decimal.ROUND_UP.__eq__('ROUND_UP') == True"
  category: constant_identity
  kind: python_call_eq
  function: ROUND_UP.__eq__
  args: ["ROUND_UP"]
  expected: true

invariant decimal_extra80.ROUND_HALF_EVEN.eq:
  description: "decimal.ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN') == True"
  category: constant_identity
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true

invariant decimal_extra80.ROUND_UP.len:
  description: "decimal.ROUND_UP.__len__() == 8 (len('ROUND_UP') == 8)"
  category: constant_identity
  kind: python_call_eq
  function: ROUND_UP.__len__
  args: []
  expected: 8

invariant decimal_extra80.ROUND_HALF_EVEN.len:
  description: "decimal.ROUND_HALF_EVEN.__len__() == 15 (len('ROUND_HALF_EVEN') == 15)"
  category: constant_identity
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__len__
  args: []
  expected: 15
