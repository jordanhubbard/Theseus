spec: klona
version: ">=2.0.0"
backend: node(klona)

docs: https://github.com/lukeed/klona#readme

provenance:
  derived_from:
    - "klona README — https://github.com/lukeed/klona#readme"
    - "Test vectors verified with klona@2.0.6 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "klona source"
  notes:
    - "klona exports { klona } as a named export (module.exports.klona = fn)."
    - "klona(value) creates a deep clone of the value with no shared references."
    - "The returned value is structurally equal to the input."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a deep clone. No errors for plain object/array inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table klona.clone:
  kind: node_module_call_eq
  function: klona
  category: clone
  id_prefix: kl

  columns: [id, args, expected]
  rows:
    - [object,  [{"a": 1}],        {"a": 1}]
    - [array,   [[1, 2, 3]],       [1, 2, 3]]
    - [nested,  [{"a": {"b": 2}}], {"a": {"b": 2}}]
