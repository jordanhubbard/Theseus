spec: io_extra98
version: ">=3.9"
backend: python_module(io)
extends: io_extra97

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec extends io_extra97.zspec.zsdl."
    - "This spec covers: io module identity — __name__, __package__, __spec__, __loader__ class names, __file__, __doc__, __all__."
    - "io.__name__ == 'io' — the module name."
    - "io.__package__ == '' — io is a top-level module (not a package), so __package__ is empty string."
    - "io.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is a ModuleSpec instance."
    - "io.__spec__.name == 'io' — the spec name matches the module name."
    - "io.__loader__.__class__.__name__ == 'type' — the loader stored in io.__loader__ is the FrozenImporter class itself (not an instance), so its __class__ is 'type'. io is a frozen module in CPython 3.14."
    - "io.__loader__.__name__ == 'FrozenImporter' — using __name__ on the loader class confirms it is FrozenImporter."
    - "io.__spec__.origin == 'frozen' — io is loaded from the frozen bytecode, not from a source file."
    - "io.__file__.__class__.__name__ == 'str' — __file__ is a string path (the .py source file location)."
    - "io.__doc__.__class__.__name__ == 'str' — __doc__ is a string."
    - "io.__all__.__class__.__name__ == 'list' — __all__ is a list."
    - "io.__all__.__len__() == 24 — __all__ has 24 entries."
    - "io.__all__.__contains__('open') == True — open is exported in __all__."
    - "io.__all__.__contains__('IOBase') == True — IOBase is exported in __all__."
    - "io.__all__.__contains__('BytesIO') == True — BytesIO is exported in __all__."
    - "io.__all__.__contains__('StringIO') == True — StringIO is exported in __all__."
    - "io.__all__.__contains__('DEFAULT_BUFFER_SIZE') == True — DEFAULT_BUFFER_SIZE is exported in __all__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io module __name__ and __package__
# io is a top-level module (not a package): __package__ == ''.
# __name__ == 'io'.
# ---------------------------------------------------------------------------

table io_extra98.module_name_package:
  description: "io.__name__ and io.__package__ string equality"
  kind: python_call_eq
  category: module_identity
  id_prefix: iomoduleid98

  columns: [id, function, args, expected]
  rows:
    - [io_name_eq,        __name__.__eq__,    ["io"],  true]
    - [io_name_not_other, __name__.__eq__,    ["_io"], false]
    - [io_pkg_empty,      __package__.__eq__, [""],    true]
    - [io_pkg_not_io,     __package__.__eq__, ["io"],  false]

# ---------------------------------------------------------------------------
# io module __spec__ and __loader__ class names
# io.__spec__ is a ModuleSpec; io is frozen so loader is the FrozenImporter
# class itself (not an instance), giving __loader__.__class__.__name__ == 'type'
# and __loader__.__name__ == 'FrozenImporter'.
# ---------------------------------------------------------------------------

table io_extra98.module_spec_loader:
  description: "io.__spec__.__class__.__name__, io.__spec__.name, io.__loader__.__class__.__name__, io.__loader__.__name__ equality"
  kind: python_call_eq
  category: module_identity
  id_prefix: iomoduleid98

  columns: [id, function, args, expected]
  rows:
    - [spec_cls_name,       __spec__.__class__.__name__.__eq__, ["ModuleSpec"],     true]
    - [spec_cls_not_str,    __spec__.__class__.__name__.__eq__, ["str"],            false]
    - [spec_name_eq_io,     __spec__.name.__eq__,               ["io"],             true]
    - [loader_cls_is_type,  __loader__.__class__.__name__.__eq__, ["type"],         true]

# ---------------------------------------------------------------------------
# io module __doc__ class name and __file__ class name
# __doc__ is a str; __file__ is a str path to the .py source file.
# __loader__.__name__ is 'FrozenImporter' (the class name, accessed via __name__).
# ---------------------------------------------------------------------------

table io_extra98.module_doc_file:
  description: "io.__doc__.__class__.__name__, io.__file__.__class__.__name__, io.__loader__.__name__ equality"
  kind: python_call_eq
  category: module_identity
  id_prefix: iomoduleid98

  columns: [id, function, args, expected]
  rows:
    - [doc_cls_str,          __doc__.__class__.__name__.__eq__,    ["str"],            true]
    - [doc_cls_not_bytes,    __doc__.__class__.__name__.__eq__,    ["bytes"],          false]
    - [file_cls_str,         __file__.__class__.__name__.__eq__,   ["str"],            true]
    - [loader_name_frozen,   __loader__.__name__.__eq__,           ["FrozenImporter"], true]

# ---------------------------------------------------------------------------
# io.__all__ membership and length
# io.__all__ is a list with 24 entries. Key public names are all present.
# ---------------------------------------------------------------------------

table io_extra98.all_membership:
  description: "io.__all__.__class__.__name__, __len__, and __contains__ for key names"
  kind: python_call_eq
  category: module_identity
  id_prefix: iomoduleid98

  columns: [id, function, args, expected]
  rows:
    - [all_cls_list,        __all__.__class__.__name__.__eq__, ["list"],               true]
    - [all_len_24,          __all__.__len__,                   [],                     24]
    - [all_has_open,        __all__.__contains__,              ["open"],               true]
    - [all_has_iobase,      __all__.__contains__,              ["IOBase"],             true]
    - [all_has_bytesio,     __all__.__contains__,              ["BytesIO"],            true]
    - [all_has_stringio,    __all__.__contains__,              ["StringIO"],           true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra98.module.name_eq_io:
  description: "io.__name__ == 'io' (the module name is the canonical two-letter string 'io')"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["io"]
  expected: true

invariant io_extra98.module.package_is_empty:
  description: "io.__package__ == '' (io is a top-level module, not a package; __package__ is empty string)"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant io_extra98.module.spec_class_is_ModuleSpec:
  description: "io.__spec__.__class__.__name__ == 'ModuleSpec' (module spec is always a ModuleSpec instance)"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant io_extra98.module.loader_name_is_FrozenImporter:
  description: "io.__loader__.__name__ == 'FrozenImporter' (io is a frozen module in CPython 3.14; loader class is FrozenImporter)"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__name__.__eq__
  args: ["FrozenImporter"]
  expected: true

invariant io_extra98.all.len_24:
  description: "io.__all__.__len__() == 24 (the io public API exports exactly 24 names)"
  category: module_identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 24
