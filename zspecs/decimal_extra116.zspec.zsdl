spec: decimal_extra116
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra115.zspec.zsdl."
    - "This spec covers: decimal.Decimal logical/bitwise method __qualname__ equality assertions not yet covered."
    - "decimal_extra11 covered Decimal.shift and Decimal.rotate VALUE VECTORS only (not qualnames)."
    - "No prior decimal_extra spec has asserted qualname equality for logical_and, logical_or, logical_xor, logical_invert, shift, or rotate."
    - "Decimal.logical_and.__qualname__ == 'Decimal.logical_and' (len 19); type 'method_descriptor'."
    - "Decimal.logical_or.__qualname__ == 'Decimal.logical_or' (len 18); type 'method_descriptor'."
    - "Decimal.logical_xor.__qualname__ == 'Decimal.logical_xor' (len 19); type 'method_descriptor'."
    - "Decimal.logical_invert.__qualname__ == 'Decimal.logical_invert' (len 22); type 'method_descriptor'."
    - "Decimal.shift.__qualname__ == 'Decimal.shift' (len 13); type 'method_descriptor'."
    - "Decimal.rotate.__qualname__ == 'Decimal.rotate' (len 14); type 'method_descriptor'."
    - "Length ordering: logical_invert(22) > logical_and(19)==logical_xor(19) > logical_or(18) > rotate(14) > shift(13)."
    - "All six methods are method_descriptor (C extension methods via PyMethodDef in Modules/_decimal/_decimal.c)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.logical_and and logical_or qualname equality assertions
# Decimal.logical_and.__qualname__ == 'Decimal.logical_and' (19 chars).
# Decimal.logical_or.__qualname__ == 'Decimal.logical_or' (18 chars).
# No prior decimal_extra spec has asserted qualname equality for either.
# decimal_extra11 covered logical_and/logical_or via value vectors (shift/rotate).
# logical_and(19) > logical_or(18): 'logical_and' is 1 char longer than 'logical_or'.
# Both implement IEEE 754 bitwise logical operations on decimal digit strings.
# Both take a context argument and operate digit-by-digit on coefficient digits.
# ---------------------------------------------------------------------------

table decimal_extra116.Decimal_logical_and_or_qualnames:
  description: "decimal.Decimal.logical_and.__qualname__='Decimal.logical_and'(19); logical_or.__qualname__='Decimal.logical_or'(18); type 'method_descriptor'; equality assertions novel; logical_and(19) is 1 char longer than logical_or(18)"
  kind: python_call_eq
  category: method_identity
  id_prefix: declogar116a

  columns: [id, function, args, expected, description]
  rows:
    - [land_qn_eq,    "Decimal.logical_and.__qualname__.__eq__",          ["Decimal.logical_and"],  true,  "decimal.Decimal.logical_and.__qualname__ == 'Decimal.logical_and' (19 chars; logical AND of decimal digit-by-digit coefficients)"]
    - [land_qn_len,   "Decimal.logical_and.__qualname__.__len__",         [],                       19,    "decimal.Decimal.logical_and.__qualname__.__len__() == 19 ('Decimal.logical_and': 'Decimal.'(8)+'logical_and'(11)==19)"]
    - [lor_qn_eq,     "Decimal.logical_or.__qualname__.__eq__",           ["Decimal.logical_or"],   true,  "decimal.Decimal.logical_or.__qualname__ == 'Decimal.logical_or' (18 chars; logical OR of decimal digit-by-digit coefficients)"]
    - [lor_qn_len,    "Decimal.logical_or.__qualname__.__len__",          [],                       18,    "decimal.Decimal.logical_or.__qualname__.__len__() == 18 ('Decimal.logical_or': 'Decimal.'(8)+'logical_or'(10)==18)"]
    - [land_gt_lor,   "Decimal.logical_and.__qualname__.__len__.__gt__",  [18],                     true,  "len('Decimal.logical_and') > len('Decimal.logical_or') (19 > 18; 'logical_and'(11) is 1 char longer than 'logical_or'(10))"]
    - [land_type,     "Decimal.logical_and.__class__.__name__.__eq__",    ["method_descriptor"],    true,  "type(decimal.Decimal.logical_and).__name__ == 'method_descriptor' (C extension method via PyMethodDef in Modules/_decimal/_decimal.c)"]
    - [lor_type,      "Decimal.logical_or.__class__.__name__.__eq__",     ["method_descriptor"],    true,  "type(decimal.Decimal.logical_or).__name__ == 'method_descriptor' (C extension method; same type as all other Decimal logical methods)"]
    - [land_ne_lor,   "Decimal.logical_and.__qualname__.__eq__",          ["Decimal.logical_or"],   false, "decimal.Decimal.logical_and.__qualname__ != 'Decimal.logical_or' (distinct methods: AND sets a digit to 1 if both input digits are 1; OR sets a digit to 1 if either input digit is 1)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.logical_xor and logical_invert qualname equality assertions
# Decimal.logical_xor.__qualname__ == 'Decimal.logical_xor' (19 chars).
# Decimal.logical_invert.__qualname__ == 'Decimal.logical_invert' (22 chars).
# No prior decimal_extra spec has asserted qualname equality for either.
# logical_invert(22) is the longest qualname among the six logical/shift methods.
# logical_xor(19) == logical_and(19) in length.
# logical_invert takes only one operand (self + context), unlike the binary operations.
# ---------------------------------------------------------------------------

table decimal_extra116.Decimal_logical_xor_invert_qualnames:
  description: "decimal.Decimal.logical_xor.__qualname__='Decimal.logical_xor'(19); logical_invert.__qualname__='Decimal.logical_invert'(22); logical_invert is longest in this group; logical_xor(19)==logical_and(19); all novel qualname eq assertions"
  kind: python_call_eq
  category: method_identity
  id_prefix: declogxi116b

  columns: [id, function, args, expected, description]
  rows:
    - [lxor_qn_eq,    "Decimal.logical_xor.__qualname__.__eq__",          ["Decimal.logical_xor"],    true,  "decimal.Decimal.logical_xor.__qualname__ == 'Decimal.logical_xor' (19 chars; logical XOR of decimal digit-by-digit coefficients)"]
    - [lxor_qn_len,   "Decimal.logical_xor.__qualname__.__len__",         [],                         19,    "decimal.Decimal.logical_xor.__qualname__.__len__() == 19 ('Decimal.logical_xor': 'Decimal.'(8)+'logical_xor'(11)==19; same as logical_and)"]
    - [linv_qn_eq,    "Decimal.logical_invert.__qualname__.__eq__",       ["Decimal.logical_invert"], true,  "decimal.Decimal.logical_invert.__qualname__ == 'Decimal.logical_invert' (22 chars; logical invert (NOT) of each digit; unary operation)"]
    - [linv_qn_len,   "Decimal.logical_invert.__qualname__.__len__",      [],                         22,    "decimal.Decimal.logical_invert.__qualname__.__len__() == 22 ('Decimal.logical_invert': 'Decimal.'(8)+'logical_invert'(14)==22; longest in group)"]
    - [linv_gt_lxor,  "Decimal.logical_invert.__qualname__.__len__.__gt__", [19],                     true,  "len('Decimal.logical_invert') > len('Decimal.logical_xor') (22 > 19; 'logical_invert'(14) is 3 chars longer than 'logical_xor'(11))"]
    - [lxor_eq_land,  "Decimal.logical_xor.__qualname__.__len__.__eq__",  [19],                       true,  "len('Decimal.logical_xor') == len('Decimal.logical_and') == 19 (xor and and share identical qualname lengths)"]
    - [lxor_type,     "Decimal.logical_xor.__class__.__name__.__eq__",    ["method_descriptor"],      true,  "type(decimal.Decimal.logical_xor).__name__ == 'method_descriptor' (C extension method in Modules/_decimal/_decimal.c)"]
    - [linv_type,     "Decimal.logical_invert.__class__.__name__.__eq__", ["method_descriptor"],      true,  "type(decimal.Decimal.logical_invert).__name__ == 'method_descriptor' (C extension method; unary unlike the binary and/or/xor)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.shift and rotate qualname equality assertions
# Decimal.shift.__qualname__ == 'Decimal.shift' (13 chars).
# Decimal.rotate.__qualname__ == 'Decimal.rotate' (14 chars).
# No prior decimal_extra spec has asserted qualname equality for shift or rotate.
# decimal_extra11 covered VALUE VECTORS for shift/rotate (not qualnames).
# shift(13) < rotate(14): 'rotate' is 1 char longer than 'shift'.
# Both are shorter than any of the logical_* methods.
# shift drops digits that fall off the end; rotate wraps them around.
# ---------------------------------------------------------------------------

table decimal_extra116.Decimal_shift_rotate_qualnames:
  description: "decimal.Decimal.shift.__qualname__='Decimal.shift'(13); rotate.__qualname__='Decimal.rotate'(14); type 'method_descriptor'; shift(13) < rotate(14) < logical_or(18) < logical_and(19)==logical_xor(19) < logical_invert(22); qualname eq assertions novel"
  kind: python_call_eq
  category: method_identity
  id_prefix: decshrot116c

  columns: [id, function, args, expected, description]
  rows:
    - [shift_qn_eq,    "Decimal.shift.__qualname__.__eq__",         ["Decimal.shift"],   true,  "decimal.Decimal.shift.__qualname__ == 'Decimal.shift' (13 chars; shifts the coefficient digits left or right by n positions)"]
    - [shift_qn_len,   "Decimal.shift.__qualname__.__len__",        [],                  13,    "decimal.Decimal.shift.__qualname__.__len__() == 13 ('Decimal.shift': 'Decimal.'(8)+'shift'(5)==13; shortest in this group)"]
    - [rotate_qn_eq,   "Decimal.rotate.__qualname__.__eq__",        ["Decimal.rotate"],  true,  "decimal.Decimal.rotate.__qualname__ == 'Decimal.rotate' (14 chars; rotates the coefficient digits left or right, wrapping around)"]
    - [rotate_qn_len,  "Decimal.rotate.__qualname__.__len__",       [],                  14,    "decimal.Decimal.rotate.__qualname__.__len__() == 14 ('Decimal.rotate': 'Decimal.'(8)+'rotate'(6)==14; one more than shift)"]
    - [rotate_gt_shift, "Decimal.rotate.__qualname__.__len__.__gt__", [13],               true,  "len('Decimal.rotate') > len('Decimal.shift') (14 > 13; 'rotate'(6) is 1 char longer than 'shift'(5))"]
    - [shift_lt_lor,   "Decimal.shift.__qualname__.__len__.__lt__", [18],                 true,  "len('Decimal.shift') < len('Decimal.logical_or') (13 < 18; shift is the shortest qualname in the group of six logical/shift methods)"]
    - [shift_type,     "Decimal.shift.__class__.__name__.__eq__",   ["method_descriptor"], true, "type(decimal.Decimal.shift).__name__ == 'method_descriptor' (C extension method; shift drops digits off the end unlike rotate which wraps)"]
    - [rotate_type,    "Decimal.rotate.__class__.__name__.__eq__",  ["method_descriptor"], true, "type(decimal.Decimal.rotate).__name__ == 'method_descriptor' (C extension method; rotate is the circular variant of shift)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra116.Decimal.logical_and_qualname_eq:
  description: "decimal.Decimal.logical_and.__qualname__ == 'Decimal.logical_and' (length 19; logical_and(other, context=None) performs a digit-by-digit AND of the two Decimal operands treated as strings of decimal digits — each digit pair is ANDed: 1 AND 1 = 1, all other combinations = 0; both operands must be logical (non-negative integer-coefficient Decimals with exponent zero); Decimal.logical_and is a method_descriptor defined via PyMethodDef in Modules/_decimal/_decimal.c; 'Decimal.'(8)+'logical_and'(11)==19; decimal_extra11 covered logical_and in value-vector context for shift/rotate but never asserted logical_and.__qualname__.__eq__('Decimal.logical_and'); no prior decimal_extra spec has covered logical_and.__qualname__ in any form)"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.logical_and.__qualname__.__eq__"
  args: ["Decimal.logical_and"]
  expected: true

invariant decimal_extra116.Decimal.logical_invert_qualname_eq:
  description: "decimal.Decimal.logical_invert.__qualname__ == 'Decimal.logical_invert' (length 22; logical_invert(context=None) is the unary logical NOT operation — it inverts each decimal digit of the coefficient: 0 becomes 1 and 1 becomes 0; unlike logical_and/or/xor it takes only one operand (plus optional context); 'Decimal.logical_invert' (22 chars) is the longest qualname among the six logical/shift methods covered in this spec; 'Decimal.'(8)+'logical_invert'(14)==22; 'logical_invert'(14) is the longest bare method name in this group — 3 chars longer than 'logical_and'/'logical_xor' (11 each) and 4 chars longer than 'logical_or' (10); no prior decimal_extra spec has asserted Decimal.logical_invert.__qualname__.__eq__('Decimal.logical_invert'))"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.logical_invert.__qualname__.__eq__"
  args: ["Decimal.logical_invert"]
  expected: true

invariant decimal_extra116.Decimal.logical_xor_qualname_eq:
  description: "decimal.Decimal.logical_xor.__qualname__ == 'Decimal.logical_xor' (length 19; logical_xor(other, context=None) performs a digit-by-digit XOR of two logical Decimals: 1 XOR 0 = 1, 0 XOR 1 = 1, 0 XOR 0 = 0, 1 XOR 1 = 0; both operands must be logical (non-negative integer-coefficient Decimals with exponent zero); 'Decimal.'(8)+'logical_xor'(11)==19; logical_xor shares its qualname length 19 with logical_and — both have 11-char bare names ('logical_and' and 'logical_xor' differ only in the last character: 'd' vs 'r'); no prior decimal_extra spec has asserted Decimal.logical_xor.__qualname__.__eq__('Decimal.logical_xor'))"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.logical_xor.__qualname__.__eq__"
  args: ["Decimal.logical_xor"]
  expected: true

invariant decimal_extra116.Decimal.shift_qualname_eq:
  description: "decimal.Decimal.shift.__qualname__ == 'Decimal.shift' (length 13; shift(n, context=None) shifts the coefficient digits left (positive n) or right (negative n) by n positions; digits that shift off the end are discarded (not wrapped); 'Decimal.'(8)+'shift'(5)==13; shift(13) is the shortest qualname among the six logical/shift methods in this spec — shorter than rotate(14), logical_or(18), logical_and(19), logical_xor(19), and logical_invert(22); decimal_extra11 covered Decimal('12345').shift(2).__str__()=='1234500' and shift(-2).__str__()=='123' (value vectors) but never asserted shift.__qualname__.__eq__('Decimal.shift'); no prior decimal_extra spec has covered shift qualname)"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.shift.__qualname__.__eq__"
  args: ["Decimal.shift"]
  expected: true

invariant decimal_extra116.Decimal.rotate_qualname_eq:
  description: "decimal.Decimal.rotate.__qualname__ == 'Decimal.rotate' (length 14; rotate(n, context=None) rotates the coefficient digits left (positive n) or right (negative n) by n positions; unlike shift, digits that rotate off one end reappear at the other end (circular shift); 'Decimal.'(8)+'rotate'(6)==14; rotate(14) is the second shortest qualname in this group — shorter than all four logical_* methods but longer than shift(13); rotate differs from shift in that no digits are lost: the precision of the context determines how many digits participate in the rotation; decimal_extra11 covered no rotate value vectors; no prior decimal_extra spec has asserted Decimal.rotate.__qualname__.__eq__('Decimal.rotate'))"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.rotate.__qualname__.__eq__"
  args: ["Decimal.rotate"]
  expected: true
