spec: flask_rust
version: ">=3.9"
backend: rust_module(flask_rust)

docs: https://flask.palletsprojects.com/en/latest/api/

provenance:
  derived_from:
    - "https://flask.palletsprojects.com/en/latest/api/ — Flask API"
  not_derived_from:
    - "flask source: src/flask/app.py"
  notes:
    - "Flask is a lightweight web framework for Python."
    - "Flask(__name__).name == '__main__' or module name."
    - "Flask('myapp').name == 'myapp'."
    - "Flask('myapp').debug == False — default."
    - "Flask('myapp').testing == False — default."
    - "Expose flask_app_name(name) -> str: Flask(name).name."
    - "Expose flask_default_debug() -> bool: Flask('app').debug."
    - "Expose flask_default_testing() -> bool: Flask('app').testing."
    - "All test vectors verified against flask 3.1.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# flask_app_name — app name roundtrip
table flask_rust.app.name:
  kind: python_call_eq
  category: app_name
  id_prefix: fl_name
  function: flask_app_name

  columns: [id, args, expected]
  rows:
    - [myapp, ["myapp"], "myapp"]
    - [api,   ["api"],   "api"]

# flask_default_debug — debug is False by default
invariant flask_rust.app.debug_false:
  description: "Flask default debug == False"
  category: defaults
  kind: python_call_eq
  function: flask_default_debug
  args: []
  expected: false

# flask_default_testing — testing is False by default
invariant flask_rust.app.testing_false:
  description: "Flask default testing == False"
  category: defaults
  kind: python_call_eq
  function: flask_default_testing
  args: []
  expected: false

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:17:47Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
