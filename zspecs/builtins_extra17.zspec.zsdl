spec: builtins_extra17
version: ">=3.9"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/exceptions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/exceptions.html — Python exceptions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Objects/exceptions.c"
  notes:
    - "This spec extends prior builtins specs."
    - "RuntimeError.__bases__[0].__name__ == 'Exception' — base for miscellaneous runtime errors."
    - "NotImplementedError.__bases__[0].__name__ == 'RuntimeError' — raised for unimplemented abstract methods."
    - "RecursionError.__bases__[0].__name__ == 'RuntimeError' — raised when max recursion depth is exceeded."
    - "OverflowError.__bases__[0].__name__ == 'ArithmeticError' — raised when a numeric result is too large."
    - "ZeroDivisionError.__bases__[0].__name__ == 'ArithmeticError' — raised on division by zero."
    - "FloatingPointError.__bases__[0].__name__ == 'ArithmeticError' — raised on floating-point operation failure."
    - "ArithmeticError.__bases__[0].__name__ == 'Exception' — base for numeric arithmetic errors."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ArithmeticError — base class
#
# ArithmeticError is the common base for numeric arithmetic exceptions.
# It derives directly from Exception.
# ---------------------------------------------------------------------------

invariant builtins_extra17.ArithmeticError.base:
  description: "ArithmeticError.__bases__[0].__name__ == 'Exception'"
  category: exception_hierarchy
  kind: python_call_eq
  function: ArithmeticError.__bases__.__getitem__(0).__name__.__eq__
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# RuntimeError — base class and subclasses
#
# RuntimeError derives from Exception. NotImplementedError and RecursionError
# both derive from RuntimeError.
# ---------------------------------------------------------------------------

invariant builtins_extra17.RuntimeError.base:
  description: "RuntimeError.__bases__[0].__name__ == 'Exception'"
  category: exception_hierarchy
  kind: python_call_eq
  function: RuntimeError.__bases__.__getitem__(0).__name__.__eq__
  args: ["Exception"]
  expected: true

invariant builtins_extra17.NotImplementedError.base:
  description: "NotImplementedError.__bases__[0].__name__ == 'RuntimeError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: NotImplementedError.__bases__.__getitem__(0).__name__.__eq__
  args: ["RuntimeError"]
  expected: true

invariant builtins_extra17.RecursionError.base:
  description: "RecursionError.__bases__[0].__name__ == 'RuntimeError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: RecursionError.__bases__.__getitem__(0).__name__.__eq__
  args: ["RuntimeError"]
  expected: true

# ---------------------------------------------------------------------------
# ArithmeticError subclasses
#
# OverflowError, ZeroDivisionError, and FloatingPointError all derive
# directly from ArithmeticError.
# ---------------------------------------------------------------------------

invariant builtins_extra17.OverflowError.base:
  description: "OverflowError.__bases__[0].__name__ == 'ArithmeticError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: OverflowError.__bases__.__getitem__(0).__name__.__eq__
  args: ["ArithmeticError"]
  expected: true

invariant builtins_extra17.ZeroDivisionError.base:
  description: "ZeroDivisionError.__bases__[0].__name__ == 'ArithmeticError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: ZeroDivisionError.__bases__.__getitem__(0).__name__.__eq__
  args: ["ArithmeticError"]
  expected: true

invariant builtins_extra17.FloatingPointError.base:
  description: "FloatingPointError.__bases__[0].__name__ == 'ArithmeticError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: FloatingPointError.__bases__.__getitem__(0).__name__.__eq__
  args: ["ArithmeticError"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table for RuntimeError/NotImplementedError/RecursionError/
# OverflowError/ZeroDivisionError/ArithmeticError
#
# All are simple non-nested exception classes so __qualname__ equals __name__.
# ---------------------------------------------------------------------------

table builtins_extra17.runtime_arithmetic_qualnames:
  description: "__qualname__ attributes for RuntimeError/NotImplementedError/RecursionError/OverflowError/ZeroDivisionError/ArithmeticError"
  kind: python_call_eq
  category: exception_classes

  columns: [id, function, args, expected]
  rows:
    - [RuntimeError,         RuntimeError.__qualname__.__eq__,         ["RuntimeError"],         true]
    - [NotImplementedError,  NotImplementedError.__qualname__.__eq__,  ["NotImplementedError"],  true]
    - [RecursionError,       RecursionError.__qualname__.__eq__,       ["RecursionError"],       true]
    - [OverflowError,        OverflowError.__qualname__.__eq__,        ["OverflowError"],        true]
    - [ZeroDivisionError,    ZeroDivisionError.__qualname__.__eq__,    ["ZeroDivisionError"],    true]
    - [ArithmeticError,      ArithmeticError.__qualname__.__eq__,      ["ArithmeticError"],      true]
