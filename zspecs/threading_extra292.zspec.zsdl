spec: threading_extra292
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module identity, spec, loader, and C extension function modules"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py, Modules/_threadmodule.c"
  notes:
    - "threading is a pure Python module; __loader__ is SourceFileLoader and __file__ is a str path"
    - "threading.__package__ is the empty string (top-level module)"
    - "get_ident, get_native_id, and stack_size are C functions exposed from the _thread extension"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table threading_extra292.module_identity:
  description: "threading module identity attributes"
  kind: python_call_eq
  category: identity
  id_prefix: thr292m

  columns: [id, function, args, expected, description]
  rows:
    - [thr292m_001, threading.__name__.__eq__, ["threading"], true, "threading.__name__ is 'threading'"]
    - [thr292m_002, threading.__package__.__eq__, [""], true, "threading.__package__ is empty string"]
    - [thr292m_003, threading.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "threading.__spec__ is a ModuleSpec"]
    - [thr292m_004, threading.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "threading.__loader__ is SourceFileLoader (pure Python)"]
    - [thr292m_005, threading.__file__.__class__.__name__.__eq__, ["str"], true, "threading.__file__ is a str path"]

table threading_extra292.c_function_modules:
  description: "threading C extension functions exposed via _thread have __module__ == '_thread'"
  kind: python_call_eq
  category: identity
  id_prefix: thr292c

  columns: [id, function, args, expected, description]
  rows:
    - [thr292c_001, threading.get_ident.__module__.__eq__, ["_thread"], true, "get_ident.__module__ is '_thread'"]
    - [thr292c_002, threading.get_native_id.__module__.__eq__, ["_thread"], true, "get_native_id.__module__ is '_thread'"]
    - [thr292c_003, threading.stack_size.__module__.__eq__, ["_thread"], true, "stack_size.__module__ is '_thread'"]

invariant threading_extra292.inv_spec_name:
  description: "threading.__spec__.name equals 'threading'"
  category: identity
  kind: python_call_eq
  function: threading.__spec__.name.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra292.inv_loader_class:
  description: "threading.__loader__ is a SourceFileLoader"
  category: identity
  kind: python_call_eq
  function: threading.__loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant threading_extra292.inv_get_ident_module:
  description: "threading.get_ident.__module__ is '_thread'"
  category: identity
  kind: python_call_eq
  function: threading.get_ident.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra292.inv_stack_size_module:
  description: "threading.stack_size.__module__ is '_thread'"
  category: identity
  kind: python_call_eq
  function: threading.stack_size.__module__.__eq__
  args: ["_thread"]
  expected: true
