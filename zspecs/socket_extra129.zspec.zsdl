# ---------------------------------------------------------------------------
# socket.__all__.__contains__('socket')
# socket.__all__.__contains__('AF_INET')
# socket.__all__.__contains__('AF_INET6')
# socket.__all__.__contains__('SOCK_STREAM')
# socket.__all__.__contains__('SOCK_DGRAM')
#
# Wave 274 theme: socket.__all__ list membership for core class and address family names.
#
# socket.__all__ is a 238-entry list (anchored in extra95). This table anchors
# membership of the socket class itself and four fundamental constants: AF_INET,
# AF_INET6, SOCK_STREAM, SOCK_DGRAM. extra95 first anchors __all__ class name
# and length; no prior socket spec anchors any individual __all__ membership
# checks under sockall129. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra129.all_membership_core:
  description: "socket.__all__/__contains__('socket')==True / __contains__('AF_INET')==True / __contains__('AF_INET6')==True / __contains__('SOCK_STREAM')==True / __contains__('SOCK_DGRAM')==True — extra95 anchors __all__ class name ('list') and length (238); this table anchors core socket class and address family constant membership; first sockall129 anchor"
  kind: python_call_eq
  category: module_all
  id_prefix: sockall129

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_socket,      __all__.__contains__, ["socket"],      true, "socket.__all__ contains 'socket' (the main socket class for creating network sockets)"]
    - [all_contains_AF_INET,     __all__.__contains__, ["AF_INET"],     true, "socket.__all__ contains 'AF_INET' (IPv4 address family constant)"]
    - [all_contains_AF_INET6,    __all__.__contains__, ["AF_INET6"],    true, "socket.__all__ contains 'AF_INET6' (IPv6 address family constant)"]
    - [all_contains_SOCK_STREAM, __all__.__contains__, ["SOCK_STREAM"], true, "socket.__all__ contains 'SOCK_STREAM' (TCP stream socket type)"]
    - [all_contains_SOCK_DGRAM,  __all__.__contains__, ["SOCK_DGRAM"],  true, "socket.__all__ contains 'SOCK_DGRAM' (UDP datagram socket type)"]

# ---------------------------------------------------------------------------
# socket.__all__.__contains__('gethostname')
# socket.__all__.__contains__('getaddrinfo')
# socket.__all__.__contains__('create_connection')
# socket.__all__.__contains__('error')
# socket.__all__.__contains__('timeout')
# socket.__all__.__contains__('getfqdn')
# socket.__all__.__contains__('create_server')
# socket.__all__.__contains__('IPPROTO_TCP')
#
# Wave 274 theme: socket.__all__ membership for functions, exceptions, protocol constants.
#
# gethostname/getaddrinfo are core name resolution functions (C builtin and Python
# wrapper, respectively). create_connection/create_server are Python helpers for
# client/server socket setup. error/timeout are the primary exception classes.
# getfqdn is the fully-qualified domain name lookup (pure Python). IPPROTO_TCP
# is the TCP protocol constant. All eight are in the 238-entry __all__ list.
# No prior socket spec anchors any of these membership checks under sockall129.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra129.all_membership_functions_and_exceptions:
  description: "socket.__all__/__contains__('gethostname')==True / __contains__('getaddrinfo')==True / __contains__('create_connection')==True / __contains__('error')==True / __contains__('timeout')==True / __contains__('getfqdn')==True / __contains__('create_server')==True / __contains__('IPPROTO_TCP')==True — all eight are in the 238-entry __all__ list; covers name resolution functions, connection helpers, exceptions, and TCP protocol constant; no prior socket spec anchors these; first sockall129 anchor"
  kind: python_call_eq
  category: module_all
  id_prefix: sockall129

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_gethostname,       __all__.__contains__, ["gethostname"],       true, "socket.__all__ contains 'gethostname' (returns machine hostname, C builtin)"]
    - [all_contains_getaddrinfo,       __all__.__contains__, ["getaddrinfo"],       true, "socket.__all__ contains 'getaddrinfo' (address lookup, Python wrapper over C)"]
    - [all_contains_create_connection, __all__.__contains__, ["create_connection"], true, "socket.__all__ contains 'create_connection' (Python helper for client socket setup)"]
    - [all_contains_error,             __all__.__contains__, ["error"],             true, "socket.__all__ contains 'error' (base socket exception, alias for OSError)"]
    - [all_contains_timeout,           __all__.__contains__, ["timeout"],           true, "socket.__all__ contains 'timeout' (raised on socket operation timeout)"]
    - [all_contains_getfqdn,           __all__.__contains__, ["getfqdn"],           true, "socket.__all__ contains 'getfqdn' (fully-qualified domain name lookup, pure Python)"]
    - [all_contains_create_server,     __all__.__contains__, ["create_server"],     true, "socket.__all__ contains 'create_server' (Python helper for server socket setup)"]
    - [all_contains_IPPROTO_TCP,       __all__.__contains__, ["IPPROTO_TCP"],       true, "socket.__all__ contains 'IPPROTO_TCP' (TCP protocol constant for setsockopt)"]

# ---------------------------------------------------------------------------
# socket.socket.connect.__objclass__.__name__.__eq__('socket')
# socket.socket.bind.__objclass__.__name__.__eq__('socket')
# socket.socket.listen.__objclass__.__name__.__eq__('socket')
# socket.socket.recv.__objclass__.__name__.__eq__('socket')
# socket.socket.send.__objclass__.__name__.__eq__('socket')
# socket.socket.setsockopt.__objclass__.__name__.__eq__('socket')
#
# Wave 274 theme: socket.socket method_descriptor __objclass__.__name__ identity.
#
# socket.socket.connect/bind/listen/recv/send/setsockopt are C-level
# method_descriptors from socketmodule.c. Each has an __objclass__ pointing to
# the underlying socket class from the _socket C extension. The __objclass__.__name__
# is 'socket' (the C-extension class, not the Python-level socket.socket alias).
# socket_extra93 anchors their __class__.__name__=='method_descriptor'; no prior
# socket spec anchors any socket.socket method's __objclass__.__name__ under sockall129.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra129.socket_method_objclass_names:
  description: "socket.socket.connect/__objclass__/__name__.__eq__('socket')==True / bind/__objclass__/__name__.__eq__('socket')==True / listen/__objclass__/__name__.__eq__('socket')==True / recv/__objclass__/__name__.__eq__('socket')==True / send/__objclass__/__name__.__eq__('socket')==True / setsockopt/__objclass__/__name__.__eq__('socket')==True — all six are C method_descriptors from socketmodule.c; __objclass__ is the _socket C extension class named 'socket'; extra93 anchors method_descriptor class names; first sockall129 anchor for __objclass__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockall129

  columns: [id, function, args, expected, description]
  rows:
    - [connect_objclass,    "socket.connect.__objclass__.__name__.__eq__",    ["socket"], true, "socket.socket.connect.__objclass__.__name__ is 'socket' (_socket C extension class)"]
    - [bind_objclass,       "socket.bind.__objclass__.__name__.__eq__",       ["socket"], true, "socket.socket.bind.__objclass__.__name__ is 'socket' (_socket C extension class)"]
    - [listen_objclass,     "socket.listen.__objclass__.__name__.__eq__",     ["socket"], true, "socket.socket.listen.__objclass__.__name__ is 'socket' (_socket C extension class)"]
    - [recv_objclass,       "socket.recv.__objclass__.__name__.__eq__",       ["socket"], true, "socket.socket.recv.__objclass__.__name__ is 'socket' (_socket C extension class)"]
    - [send_objclass,       "socket.send.__objclass__.__name__.__eq__",       ["socket"], true, "socket.socket.send.__objclass__.__name__ is 'socket' (_socket C extension class)"]
    - [setsockopt_objclass, "socket.setsockopt.__objclass__.__name__.__eq__", ["socket"], true, "socket.socket.setsockopt.__objclass__.__name__ is 'socket' (_socket C extension class)"]

# ---------------------------------------------------------------------------
# socket.__all__.__contains__('socket') — standalone
#
# socket.__all__ contains 'socket'. The socket class is the central object of
# the module — it represents a network socket and provides methods for connect,
# bind, listen, accept, send, recv, etc. Its presence in __all__ confirms it is
# the primary public API entry point. extra95 anchors __all__ class name and length;
# no prior socket spec anchors __all__.__contains__('socket') as a standalone
# under sockall129. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra129.all_contains_socket:
  description: "socket.__all__.__contains__('socket') == True — 'socket' (the main socket class) is in the 238-entry __all__ list; it is the central public API object providing connect/bind/listen/send/recv methods; extra95 anchors __all__ class name and length; first standalone for __all__.__contains__('socket') under sockall129"
  category: module_all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__all__.__contains__('error') — standalone
#
# socket.__all__ contains 'error'. socket.error is an alias for OSError in
# Python 3.x (since Python 3.3). It is the base exception for all socket
# errors. Its presence in __all__ confirms it is part of the public API and
# can be imported directly (e.g., 'from socket import error'). extra95 anchors
# __all__ class name and length; no prior socket spec anchors
# __all__.__contains__('error') as a standalone under sockall129.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra129.all_contains_error:
  description: "socket.__all__.__contains__('error') == True — socket.error is an alias for OSError (since Python 3.3); in the 238-entry __all__ list; base exception for all socket errors; extra95 anchors __all__ class name and length; first standalone for __all__.__contains__('error') under sockall129"
  category: module_all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.connect.__objclass__.__name__.__eq__('socket') — standalone
#
# socket.socket.connect.__objclass__.__name__ is 'socket'. connect is a
# C-level method_descriptor from socketmodule.c. Its __objclass__ is the socket
# class from the _socket C extension (not the Python-level socket.socket wrapper).
# The C class is named 'socket' (same as the module name), which is why
# __objclass__.__name__ is 'socket'. extra93 anchors connect's
# __class__.__name__=='method_descriptor'; no prior socket spec anchors
# connect.__objclass__.__name__ as a standalone under sockall129.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra129.connect_objclass_socket:
  description: "socket.socket.connect.__objclass__.__name__.__eq__('socket') == True — connect is a C method_descriptor from socketmodule.c; __objclass__ is the _socket C extension class named 'socket'; extra93 anchors __class__.__name__=='method_descriptor'; first standalone for connect.__objclass__.__name__ under sockall129"
  category: type_identity
  kind: python_call_eq
  function: "socket.connect.__objclass__.__name__.__eq__"
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.connect.__objclass__.__module__.__eq__('_socket') — standalone
#
# socket.socket.connect.__objclass__.__module__ is '_socket'. The __objclass__
# of connect is the socket class from the _socket C extension module, not the
# pure-Python 'socket' module (Lib/socket.py). The _socket extension wraps the
# OS socket API; the Python-level socket module re-exports it. This means the
# underlying C type lives in _socket, not socket. extra93 anchors method class
# names; no prior socket spec anchors connect.__objclass__.__module__ as a
# standalone under sockall129. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra129.connect_objclass_module_socket:
  description: "socket.socket.connect.__objclass__.__module__.__eq__('_socket') == True — __objclass__ of connect is the socket class from _socket (C extension module wrapping OS socket API), not the Python-level 'socket' module; extra93 anchors method class names; first standalone for connect.__objclass__.__module__ under sockall129"
  category: type_identity
  kind: python_call_eq
  function: "socket.connect.__objclass__.__module__.__eq__"
  args: ["_socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__all__.__contains__('IPPROTO_TCP') — standalone
#
# socket.__all__ contains 'IPPROTO_TCP'. IPPROTO_TCP is the integer constant
# for the TCP protocol, used as the protocol-level argument to setsockopt
# (e.g., socket.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)).
# It is one of the many protocol and constant names in the 238-entry __all__
# list. Its presence confirms that numeric protocol constants are part of the
# socket module's public API. No prior socket spec anchors
# __all__.__contains__('IPPROTO_TCP') as a standalone under sockall129.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra129.all_contains_IPPROTO_TCP:
  description: "socket.__all__.__contains__('IPPROTO_TCP') == True — IPPROTO_TCP is the TCP protocol constant in the 238-entry __all__ list; used as level arg to setsockopt; confirms numeric protocol constants are in public API; no prior socket spec anchors this as standalone; first standalone for __all__.__contains__('IPPROTO_TCP') under sockall129"
  category: module_all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["IPPROTO_TCP"]
  expected: true

