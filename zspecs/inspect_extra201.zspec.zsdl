spec: inspect_extra201
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers __code__.co_name identity for public inspect functions: isfunction, isbuiltin, isclass, getmembers, signature, getsource, getfile, getdoc."
    - "inspect.isfunction.__code__.co_name == 'isfunction' — Python predicate function; co_name matches def name. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__code__.co_name == 'isbuiltin' — Python predicate function; co_name matches def name. Verified with Python 3.14.3."
    - "inspect.isclass.__code__.co_name == 'isclass' — Python predicate function; co_name matches def name. Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_name == 'getmembers' — Python introspection function; co_name matches def name. Verified with Python 3.14.3."
    - "inspect.signature.__code__.co_name == 'signature' — Python function returning Signature; co_name matches def name. Verified with Python 3.14.3."
    - "inspect.getsource.__code__.co_name == 'getsource' — Python function returning source code; co_name matches def name. Verified with Python 3.14.3."
    - "inspect.getfile.__code__.co_name == 'getfile' — Python function returning source file path; co_name matches def name. Verified with Python 3.14.3."
    - "inspect.getdoc.__code__.co_name == 'getdoc' — Python function returning docstring; co_name matches def name. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __code__.co_name for inspect predicate functions
#
# isfunction, isbuiltin, isclass: Python predicate functions in inspect.
# co_name matches the function's def name exactly.
# ---------------------------------------------------------------------------

