  rows:
    - [isfunction_co_name,
       isfunction.__code__.co_name.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__code__.co_name.__eq__('isfunction') == True — isfunction is a Python predicate; __code__.co_name == 'isfunction'; new to extra201"]
    - [isbuiltin_co_name,
       isbuiltin.__code__.co_name.__eq__,
