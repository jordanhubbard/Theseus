spec: levenshtein_edit_distance
version: ">=3.0.0"
backend: node(levenshtein-edit-distance)

docs: https://github.com/wooorm/levenshtein-edit-distance#readme

provenance:
  derived_from:
    - "levenshtein-edit-distance README — https://github.com/wooorm/levenshtein-edit-distance#readme"
    - "Vladimir Levenshtein, 'Binary codes capable of correcting deletions, insertions and reversals', 1966"
    - "Test vectors verified with levenshtein-edit-distance via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "levenshtein-edit-distance source"
  notes:
    - "Computes minimum edit distance (Levenshtein) between two strings."
    - "Install: npm install levenshtein-edit-distance"
    - "Named export 'levenshteinEditDistance' is the function. v3 is ESM with a CJS shim."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table levenshtein_edit_distance.distance:
  kind: node_module_call_eq
  category: distance
  function: levenshteinEditDistance
  id_prefix: dist

  columns: [id, args, expected]
  rows:
    - [classic_kitten_sitting,  ["kitten", "sitting"],   3]
    - [identical,               ["hello", "hello"],       0]
    - [empty_to_text,           ["", "abc"],              3]
    - [text_to_empty,           ["abc", ""],              3]
    - [empty_to_empty,          ["", ""],                  0]
    - [single_substitution,     ["a", "b"],                1]
    - [single_insertion,        ["a", "ab"],               1]
    - [single_deletion,         ["ab", "a"],               1]
    - [completely_different,    ["cat", "dog"],            3]
    - [transposition,           ["abc", "acb"],            2]
    - [common_typo,             ["receive", "recieve"],    2]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:12:54Z
  iterations: 1
  pass_count: 11
  fail_count: 0
  total_invariants: 11
  notes: Synthesis succeeded in 1 iteration(s). 11 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
