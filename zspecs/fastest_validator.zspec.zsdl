spec: fastest_validator
version: ">=1.0.0"
backend: node(fastest-validator)

docs: https://github.com/icebob/fastest-validator#readme

provenance:
  derived_from:
    - "fastest-validator README — https://github.com/icebob/fastest-validator#readme"
    - "Test vectors verified with fastest-validator via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "fastest-validator source"
  notes:
    - "Very fast schema validator — pre-compiles schemas to plain JS functions."
    - "Install: npm install fastest-validator"
    - "v1 CJS; module export IS the Validator constructor; instance has .compile / .validate methods."
    - "Schema strings use shorthand: 'string|min:3' = required string with min length 3."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Compiled validators return true on success or an array of error objects on failure."
  stderr: "null"
  stickiness: "N/A — each compilation independent."
  codes: {}

invariant fastest_validator.compile_string_validate_pass:
  description: "compile({name:'string'}) accepts a valid string"
  category: validate
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: compile, args: [{name: "string"}]}
    - {call: [{name: "alice"}]}
  expected: true

invariant fastest_validator.compile_string_validate_fail:
  description: "compile({name:'string'}) rejects a non-string with an array of errors"
  category: validate
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: compile, args: [{name: "string"}]}
    - {call: [{name: 5}]}
    - {get: "constructor.name"}
  expected: "Array"

invariant fastest_validator.string_min_length_pass:
  description: "compile({s:'string|min:3'}) accepts string of length 3"
  category: validate
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: compile, args: [{s: "string|min:3"}]}
    - {call: [{s: "abc"}]}
  expected: true

invariant fastest_validator.string_min_length_fail:
  description: "compile({s:'string|min:3'}) rejects shorter string"
  category: validate
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: compile, args: [{s: "string|min:3"}]}
    - {call: [{s: "ab"}]}
    - {method: at, args: [0]}
    - {get: type}
  expected: "stringMin"

invariant fastest_validator.number_positive_fail:
  description: "compile({n:'number|positive'}) rejects -1"
  category: validate
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: compile, args: [{n: "number|positive"}]}
    - {call: [{n: -1}]}
    - {method: at, args: [0]}
    - {get: type}
  expected: "numberPositive"

invariant fastest_validator.number_positive_pass:
  description: "compile({n:'number|positive'}) accepts 5"
  category: validate
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: compile, args: [{n: "number|positive"}]}
    - {call: [{n: 5}]}
  expected: true

invariant fastest_validator.email_pass:
  description: "compile({e:'email'}) accepts a valid email"
  category: validate
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: compile, args: [{e: "email"}]}
    - {call: [{e: "alice@example.com"}]}
  expected: true

invariant fastest_validator.email_fail:
  description: "compile({e:'email'}) rejects a malformed email"
  category: validate
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: compile, args: [{e: "email"}]}
    - {call: [{e: "not-an-email"}]}
    - {get: "constructor.name"}
  expected: "Array"
