spec: inspect_extra271
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect re-exports CO_* compile flag constants from the code module; values are powers of 2."
    - "CO_OPTIMIZED=1, CO_NEWLOCALS=2, CO_VARARGS=4, CO_VARKEYWORDS=8, CO_NESTED=16, CO_GENERATOR=32."
    - "CO_NOFREE=64, CO_COROUTINE=128, CO_ITERABLE_COROUTINE=256, CO_ASYNC_GENERATOR=512."
    - "All CO_* constants are of type int; each is a distinct power of 2 (bit flag)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect CO_* compile flag constant integer values
#
# Powers of 2 bit flags: CO_OPTIMIZED(1) < CO_NEWLOCALS(2) < CO_VARARGS(4) <
#   CO_VARKEYWORDS(8) < CO_NESTED(16) < CO_GENERATOR(32) < CO_NOFREE(64) <
#   CO_COROUTINE(128) < CO_ITERABLE_COROUTINE(256) < CO_ASYNC_GENERATOR(512).
# ---------------------------------------------------------------------------

table inspect_extra271.co_flag_values:
  description: "inspect CO_* compile flag constants — integer bit-flag values: CO_OPTIMIZED=1, CO_NEWLOCALS=2, CO_VARARGS=4, CO_VARKEYWORDS=8, CO_NESTED=16, CO_GENERATOR=32, CO_NOFREE=64, CO_COROUTINE=128, CO_ITERABLE_COROUTINE=256, CO_ASYNC_GENERATOR=512; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex271cf

  columns: [id, function, args, expected, description]
  rows:
    - [co_opt_eq,              CO_OPTIMIZED.__eq__,                         [1],                            true, "inspect.CO_OPTIMIZED == 1 (bit 0); verified with Python 3.14.3"]
    - [co_nl_eq,               CO_NEWLOCALS.__eq__,                         [2],                            true, "inspect.CO_NEWLOCALS == 2 (bit 1); verified with Python 3.14.3"]
    - [co_va_eq,               CO_VARARGS.__eq__,                           [4],                            true, "inspect.CO_VARARGS == 4 (bit 2); verified with Python 3.14.3"]
    - [co_vk_eq,               CO_VARKEYWORDS.__eq__,                       [8],                            true, "inspect.CO_VARKEYWORDS == 8 (bit 3); verified with Python 3.14.3"]
    - [co_ne_eq,               CO_NESTED.__eq__,                            [16],                           true, "inspect.CO_NESTED == 16 (bit 4); verified with Python 3.14.3"]
    - [co_ge_eq,               CO_GENERATOR.__eq__,                         [32],                           true, "inspect.CO_GENERATOR == 32 (bit 5); verified with Python 3.14.3"]
    - [co_nf_eq,               CO_NOFREE.__eq__,                            [64],                           true, "inspect.CO_NOFREE == 64 (bit 6); verified with Python 3.14.3"]
    - [co_co_eq,               CO_COROUTINE.__eq__,                         [128],                          true, "inspect.CO_COROUTINE == 128 (bit 7); verified with Python 3.14.3"]
    - [co_ic_eq,               CO_ITERABLE_COROUTINE.__eq__,                [256],                          true, "inspect.CO_ITERABLE_COROUTINE == 256 (bit 8); verified with Python 3.14.3"]
    - [co_ag_eq,               CO_ASYNC_GENERATOR.__eq__,                   [512],                          true, "inspect.CO_ASYNC_GENERATOR == 512 (bit 9 — largest flag in this spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# inspect CO_* compile flag constant types
#
# All CO_* constants are plain int instances.
# type(CO_OPTIMIZED).__name__ == 'int'; same for all others.
# ---------------------------------------------------------------------------

table inspect_extra271.co_flag_types:
  description: "inspect CO_* compile flag constant types — all are plain int; type(CO_X).__name__ == 'int' for all CO_* constants; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex271ct

  columns: [id, function, args, expected, description]
  rows:
    - [co_opt_cls_eq,          CO_OPTIMIZED.__class__.__name__.__eq__,      ["int"],                        true, "type(inspect.CO_OPTIMIZED).__name__ == 'int'; verified with Python 3.14.3"]
    - [co_nl_cls_eq,           CO_NEWLOCALS.__class__.__name__.__eq__,      ["int"],                        true, "type(inspect.CO_NEWLOCALS).__name__ == 'int'; verified with Python 3.14.3"]
    - [co_va_cls_eq,           CO_VARARGS.__class__.__name__.__eq__,        ["int"],                        true, "type(inspect.CO_VARARGS).__name__ == 'int'; verified with Python 3.14.3"]
    - [co_vk_cls_eq,           CO_VARKEYWORDS.__class__.__name__.__eq__,    ["int"],                        true, "type(inspect.CO_VARKEYWORDS).__name__ == 'int'; verified with Python 3.14.3"]
    - [co_ne_cls_eq,           CO_NESTED.__class__.__name__.__eq__,         ["int"],                        true, "type(inspect.CO_NESTED).__name__ == 'int'; verified with Python 3.14.3"]
    - [co_ge_cls_eq,           CO_GENERATOR.__class__.__name__.__eq__,      ["int"],                        true, "type(inspect.CO_GENERATOR).__name__ == 'int'; verified with Python 3.14.3"]
    - [co_nf_cls_eq,           CO_NOFREE.__class__.__name__.__eq__,         ["int"],                        true, "type(inspect.CO_NOFREE).__name__ == 'int'; verified with Python 3.14.3"]
    - [co_co_cls_eq,           CO_COROUTINE.__class__.__name__.__eq__,      ["int"],                        true, "type(inspect.CO_COROUTINE).__name__ == 'int'; verified with Python 3.14.3"]
    - [co_ic_cls_eq,           CO_ITERABLE_COROUTINE.__class__.__name__.__eq__, ["int"],                   true, "type(inspect.CO_ITERABLE_COROUTINE).__name__ == 'int'; verified with Python 3.14.3"]
    - [co_ag_cls_eq,           CO_ASYNC_GENERATOR.__class__.__name__.__eq__, ["int"],                      true, "type(inspect.CO_ASYNC_GENERATOR).__name__ == 'int'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra271
# ---------------------------------------------------------------------------

invariant inspect_extra271.co_optimized_is_one:
  description: "inspect.CO_OPTIMIZED == 1 — smallest compile flag, bit 0"
  category: identity
  kind: python_call_eq
  function: CO_OPTIMIZED.__eq__
  args: [1]
  expected: true

invariant inspect_extra271.co_async_generator_is_512:
  description: "inspect.CO_ASYNC_GENERATOR == 512 — largest compile flag constant in this spec, bit 9"
  category: identity
  kind: python_call_eq
  function: CO_ASYNC_GENERATOR.__eq__
  args: [512]
  expected: true

invariant inspect_extra271.co_coroutine_is_128:
  description: "inspect.CO_COROUTINE == 128 — bit 7 compile flag; less than CO_ITERABLE_COROUTINE(256) and CO_ASYNC_GENERATOR(512)"
  category: identity
  kind: python_call_eq
  function: CO_COROUTINE.__eq__
  args: [128]
  expected: true

invariant inspect_extra271.co_optimized_type_is_int:
  description: "type(inspect.CO_OPTIMIZED).__name__ == 'int' — all CO_* constants are plain int instances"
  category: identity
  kind: python_call_eq
  function: CO_OPTIMIZED.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant inspect_extra271.co_generator_is_32:
  description: "inspect.CO_GENERATOR == 32 — bit 5 compile flag; marks generator functions"
  category: identity
  kind: python_call_eq
  function: CO_GENERATOR.__eq__
  args: [32]
  expected: true

invariant inspect_extra271.co_nofree_is_64:
  description: "inspect.CO_NOFREE == 64 — bit 6 compile flag; indicates no free variables in code object"
  category: identity
  kind: python_call_eq
  function: CO_NOFREE.__eq__
  args: [64]
  expected: true
