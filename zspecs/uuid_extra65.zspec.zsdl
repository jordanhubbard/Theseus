spec: uuid_extra65
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra64.zspec.zsdl — covers UUID/__dict__/__contains__ __eq__/__lt__/__hash__/hex/int/version / RESERVED_NCS/RFC_4122/RESERVED_MICROSOFT/RESERVED_FUTURE/__class__/__name__=='str' (table + invariants)."
    - "uuid_extra63.zspec.zsdl — covers UUID.__eq__/__lt__ __code__.co_name/co_argcount / uuid3/uuid5 __code__.co_name/co_argcount / NAMESPACE_DNS/URL/OID/X500/__class__/__name__=='UUID' (table + invariants)."
    - "uuid_extra62.zspec.zsdl — covers UUID.__init__/__str__/__hash__ __code__.co_name/co_argcount / uuid4/uuid1 __code__.co_name/co_argcount (table + invariants)."
    - "uuid_extra61.zspec.zsdl — covers uuid.__name__/__spec__.name/__spec__.__class__.__name__/__loader__.__class__.__name__ / UUID.__dict__.__class__.__name__=='mappingproxy' / UUID.__dict__.__contains__ __init__/__repr__/__str__/__hash__/__eq__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra64; it does NOT duplicate invariants present in those files."
    - "Wave 240 theme: UUID class __dict__ — remaining property attributes."
    - "uuid.UUID.__dict__.__contains__('bytes') == True — UUID.bytes is a property in __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('bytes_le') == True — UUID.bytes_le is a property in __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('fields') == True — UUID.fields is a property in __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('urn') == True — UUID.urn is a property in __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('variant') == True — UUID.variant is a property in __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('time_low') == True — UUID.time_low is a property in __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__qualname__ == 'uuid1' — uuid1 is a module-level function with simple qualname. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__qualname__ == 'uuid4' — uuid4 is a module-level function with simple qualname. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__qualname__ == 'UUID' — the UUID class has simple qualname 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.__dict__.__contains__ for bytes / bytes_le / fields
#
# Wave 240 theme: UUID class __dict__ content — bytes and fields properties.
#
# uuid.UUID defines bytes, bytes_le, and fields as properties in its class
# __dict__. uuid_extra64 covers hex/int/version. No prior uuid spec checks
# UUID.__dict__.__contains__ for bytes, bytes_le, or fields.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra65.UUID_dict_bytes_fields:
  description: "uuid.UUID/__dict__.__contains__('bytes')==True / UUID/__dict__.__contains__('bytes_le')==True / UUID/__dict__.__contains__('fields')==True — UUID.bytes, UUID.bytes_le, and UUID.fields are properties stored in UUID.__dict__; uuid_extra64 covers hex/int/version; no prior uuid spec checks __contains__ for bytes/bytes_le/fields; first combined bytes and fields __dict__ contains table for UUID"
  kind: python_call_eq
  category: class_dict
  id_prefix: uuidmore65

  columns: [id, function, args, expected]
  rows:
    - [UUID_dict_contains_bytes,    UUID.__dict__.__contains__, ["bytes"],    true]
    - [UUID_dict_contains_bytes_le, UUID.__dict__.__contains__, ["bytes_le"], true]
    - [UUID_dict_contains_fields,   UUID.__dict__.__contains__, ["fields"],   true]

# ---------------------------------------------------------------------------
# UUID.__dict__.__contains__ for urn / variant / time_low
#
# Wave 240 theme: UUID class __dict__ content — urn, variant, and time_low properties.
#
# uuid.UUID defines urn, variant, and time_low as properties in its class
# __dict__. No prior uuid spec checks UUID.__dict__.__contains__ for urn,
# variant, or time_low.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra65.UUID_dict_urn_variant_time_low:
  description: "uuid.UUID/__dict__.__contains__('urn')==True / UUID/__dict__.__contains__('variant')==True / UUID/__dict__.__contains__('time_low')==True — UUID.urn, UUID.variant, and UUID.time_low are properties stored in UUID.__dict__; no prior uuid spec checks __contains__ for urn/variant/time_low; first combined urn/variant/time_low __dict__ contains table for UUID"
  kind: python_call_eq
  category: class_dict
  id_prefix: uuidmore65

  columns: [id, function, args, expected]
  rows:
    - [UUID_dict_contains_urn,      UUID.__dict__.__contains__, ["urn"],      true]
    - [UUID_dict_contains_variant,  UUID.__dict__.__contains__, ["variant"],  true]
    - [UUID_dict_contains_time_low, UUID.__dict__.__contains__, ["time_low"], true]

# ---------------------------------------------------------------------------
# uuid.uuid1 / uuid4 __qualname__
#
# Wave 240 theme: uuid module function qualnames.
#
# uuid.uuid1 and uuid.uuid4 are module-level Python functions with simple
# qualnames. No prior uuid spec checks uuid1.__qualname__ or uuid4.__qualname__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra65.uuid1_uuid4_qualnames:
  description: "uuid.uuid1/__qualname__.__eq__('uuid1')==True / uuid4/__qualname__.__eq__('uuid4')==True — uuid1 and uuid4 are module-level Python functions with simple qualnames; no prior uuid spec checks uuid1.__qualname__ or uuid4.__qualname__; first qualname anchor for uuid1 and uuid4"
  kind: python_call_eq
  category: qualnames
  id_prefix: uuidmore65

  columns: [id, function, args, expected]
  rows:
    - [uuid1_qualname_uuid1, uuid1.__qualname__.__eq__, ["uuid1"], true]
    - [uuid4_qualname_uuid4, uuid4.__qualname__.__eq__, ["uuid4"], true]

# ---------------------------------------------------------------------------
# uuid.UUID __qualname__
#
# Wave 240 theme: UUID class qualname.
#
# uuid.UUID is a Python class with simple qualname 'UUID'. No prior uuid spec
# checks UUID.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra65.UUID_class_qualname:
  description: "uuid.UUID/__qualname__.__eq__('UUID')==True — UUID is a Python class with simple qualname 'UUID'; no prior uuid spec checks UUID.__qualname__; first qualname anchor for UUID class"
  kind: python_call_eq
  category: qualnames
  id_prefix: uuidmore65

  columns: [id, function, args, expected]
  rows:
    - [UUID_qualname_UUID, UUID.__qualname__.__eq__, ["UUID"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('bytes') — standalone
#
# uuid.UUID defines bytes as a property in its class __dict__. No prior uuid
# spec checks UUID.__dict__.__contains__('bytes'). First bytes __dict__
# contains standalone for UUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra65.UUID_dict_contains_bytes:
  description: "uuid.UUID.__dict__.__contains__('bytes') == True — UUID.bytes is a property stored in UUID.__dict__; no prior uuid spec checks UUID.__dict__.__contains__('bytes'); first bytes __dict__ contains standalone for UUID"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('urn') — standalone
#
# uuid.UUID defines urn as a property in its class __dict__. No prior uuid
# spec checks UUID.__dict__.__contains__('urn'). First urn __dict__
# contains standalone for UUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra65.UUID_dict_contains_urn:
  description: "uuid.UUID.__dict__.__contains__('urn') == True — UUID.urn is a property stored in UUID.__dict__; no prior uuid spec checks UUID.__dict__.__contains__('urn'); first urn __dict__ contains standalone for UUID"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["urn"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('time_low') — standalone
#
# uuid.UUID defines time_low as a property in its class __dict__. No prior uuid
# spec checks UUID.__dict__.__contains__('time_low'). First time_low __dict__
# contains standalone for UUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra65.UUID_dict_contains_time_low:
  description: "uuid.UUID.__dict__.__contains__('time_low') == True — UUID.time_low is a property stored in UUID.__dict__; no prior uuid spec checks UUID.__dict__.__contains__('time_low'); first time_low __dict__ contains standalone for UUID"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["time_low"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid1.__qualname__.__eq__('uuid1') — standalone
#
# uuid.uuid1 is a module-level Python function with simple qualname 'uuid1'.
# No prior uuid spec checks uuid1.__qualname__. First qualname standalone
# for uuid1.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra65.uuid1_qualname_uuid1:
  description: "uuid.uuid1.__qualname__.__eq__('uuid1') == True — uuid1 is a module-level Python function with simple qualname; no prior uuid spec checks uuid1.__qualname__; first qualname standalone for uuid1"
  category: qualnames
  kind: python_call_eq
  function: uuid1.__qualname__.__eq__
  args: ["uuid1"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__qualname__.__eq__('UUID') — standalone
#
# uuid.UUID is a Python class with simple qualname 'UUID'. No prior uuid spec
# checks UUID.__qualname__. First qualname standalone for UUID class.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra65.UUID_qualname_UUID:
  description: "uuid.UUID.__qualname__.__eq__('UUID') == True — UUID is a Python class with simple qualname 'UUID'; no prior uuid spec checks UUID.__qualname__; first qualname standalone for UUID class"
  category: qualnames
  kind: python_call_eq
  function: UUID.__qualname__.__eq__
  args: ["UUID"]
  expected: true
