spec: asyncio_extra100
version: ">=3.9"
backend: python_module(asyncio)
extends: asyncio_extra99

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra99.zspec.zsdl."
    - "This spec covers: wave 254 theme — asyncio Lock, Event, and Semaphore method __qualname__ lengths and class names. NEW in extra100: asyncio.Lock.acquire.__qualname__=='Lock.acquire' (len=12); asyncio.Lock.release.__qualname__=='Lock.release' (len=12); asyncio.Lock.locked.__qualname__=='Lock.locked' (len=11); all Lock methods have class='function' (pure-Python, unlike asyncio.Task methods which are C-level method_descriptors); asyncio.Event.set.__qualname__=='Event.set' (len=9); asyncio.Event.clear.__qualname__=='Event.clear' (len=11); asyncio.Event.wait.__qualname__=='Event.wait' (len=10); asyncio.Event.is_set.__qualname__=='Event.is_set' (len=12); asyncio.Semaphore.acquire.__qualname__=='Semaphore.acquire' (len=17); asyncio.Semaphore.release.__qualname__=='Semaphore.release' (len=17); asyncio.Semaphore.locked.__qualname__=='Semaphore.locked' (len=16); all methods __module__=='asyncio.locks'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.acquire.__class__.__name__ == 'function'. Lock, Event, and Semaphore are pure-Python classes defined in Lib/asyncio/locks.py; their methods are Python functions (class='function'), unlike asyncio.Task and asyncio.Future whose methods are C-level method_descriptors. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__module__ == 'asyncio.locks'. Lock is defined in Lib/asyncio/locks.py alongside Event and Semaphore. Lock.__mro__ has length 4: [Lock, _ContextManagerMixin, _LoopBoundMixin, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__mro__.__len__() == 3. Event's MRO is [Event, _LoopBoundMixin, object], length 3. Semaphore's MRO is [Semaphore, _ContextManagerMixin, _LoopBoundMixin, object], length 4. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Lock method qualnames — extra100
#
# Wave 254 theme: asyncio Lock, Event, and Semaphore method qualname lengths.
#
# Lock.acquire.__qualname__ == 'Lock.acquire'    (len=12)
# Lock.release.__qualname__ == 'Lock.release'    (len=12)
# Lock.locked.__qualname__  == 'Lock.locked'     (len=11)
# All Lock methods have __class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table asyncio_extra100.asyncio_lock_method_qualnames:
  description: "asyncio.Lock method __qualname__ and class name checks in asynciolockqn100 namespace — wave 254 theme: asyncio Lock, Event, and Semaphore method qualname lengths; asyncio.Lock is a pure-Python class defined in Lib/asyncio/locks.py (Lock.__module__=='asyncio.locks'); unlike asyncio.Task and asyncio.Future (which are C extension classes with method_descriptor methods), Lock methods are Python coroutine functions (class='function'); Lock.acquire.__qualname__.__eq__('Lock.acquire')==True (len=12: 'Lock.'=5 + 'acquire'=7); Lock.acquire.__qualname__.__len__()==12; Lock.release.__qualname__.__eq__('Lock.release')==True (len=12: 'Lock.'=5 + 'release'=7, same length as acquire); Lock.release.__qualname__.__len__()==12; Lock.locked.__qualname__.__eq__('Lock.locked')==True (len=11: 'Lock.'=5 + 'locked'=6, one char shorter than acquire/release); Lock.locked.__qualname__.__len__()==11; all three methods have __class__.__name__=='function'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolockqn100

  columns: [id, function, args, expected, description]
  rows:
    - [lock_acq_qeq,   asyncio.Lock.acquire.__qualname__.__eq__,         ["Lock.acquire"], true, "asyncio.Lock.acquire.__qualname__ == 'Lock.acquire' (len=12); verified with Python 3.14.3"]
    - [lock_acq_qlen,  asyncio.Lock.acquire.__qualname__.__len__,         [],               12,   "asyncio.Lock.acquire.__qualname__.__len__() == 12 ('Lock.'=5 + 'acquire'=7); verified with Python 3.14.3"]
    - [lock_rel_qeq,   asyncio.Lock.release.__qualname__.__eq__,         ["Lock.release"], true, "asyncio.Lock.release.__qualname__ == 'Lock.release' (len=12, same as acquire); verified with Python 3.14.3"]
    - [lock_rel_qlen,  asyncio.Lock.release.__qualname__.__len__,         [],               12,   "asyncio.Lock.release.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [lock_lkd_qeq,   asyncio.Lock.locked.__qualname__.__eq__,          ["Lock.locked"],  true, "asyncio.Lock.locked.__qualname__ == 'Lock.locked' (len=11, one less than acquire/release); verified with Python 3.14.3"]
    - [lock_lkd_qlen,  asyncio.Lock.locked.__qualname__.__len__,          [],               11,   "asyncio.Lock.locked.__qualname__.__len__() == 11; verified with Python 3.14.3"]
    - [lock_acq_cls,   asyncio.Lock.acquire.__class__.__name__.__eq__,   ["function"],     true, "asyncio.Lock.acquire.__class__.__name__ == 'function' — Python coroutine function, not C-level; verified with Python 3.14.3"]
    - [lock_rel_cls,   asyncio.Lock.release.__class__.__name__.__eq__,   ["function"],     true, "asyncio.Lock.release.__class__.__name__ == 'function' — Python coroutine function; verified with Python 3.14.3"]
    - [lock_lkd_cls,   asyncio.Lock.locked.__class__.__name__.__eq__,    ["function"],     true, "asyncio.Lock.locked.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Event method qualnames — extra100
#
# Event.set.__qualname__    == 'Event.set'    (len=9)
# Event.clear.__qualname__  == 'Event.clear'  (len=11)
# Event.wait.__qualname__   == 'Event.wait'   (len=10)
# Event.is_set.__qualname__ == 'Event.is_set' (len=12)
# All Event methods have __class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table asyncio_extra100.asyncio_event_method_qualnames:
  description: "asyncio.Event method __qualname__ length checks in asynciolockqn100 namespace — wave 254 theme: asyncio.Event methods are pure-Python functions with qualnames using 'Event.' prefix; asyncio.Event is defined in Lib/asyncio/locks.py (module='asyncio.locks'); Event.__mro__ is [Event, _LoopBoundMixin, object] (length=3); Event.set.__qualname__.__eq__('Event.set')==True (len=9: 'Event.'=6 + 'set'=3, the shortest Event method qualname); Event.set.__qualname__.__len__()==9; Event.clear.__qualname__.__eq__('Event.clear')==True (len=11: 'Event.'=6 + 'clear'=5); Event.wait.__qualname__.__eq__('Event.wait')==True (len=10: 'Event.'=6 + 'wait'=4); Event.is_set.__qualname__.__eq__('Event.is_set')==True (len=12: 'Event.'=6 + 'is_set'=6, the longest Event method qualname); all four methods have class='function' (pure-Python); Event.set is a synchronous function while Event.wait is a coroutine; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolockqn100a

  columns: [id, function, args, expected, description]
  rows:
    - [evt_set_qeq,    asyncio.Event.set.__qualname__.__eq__,             ["Event.set"],    true, "asyncio.Event.set.__qualname__ == 'Event.set' (len=9, shortest Event method qualname); verified with Python 3.14.3"]
    - [evt_set_qlen,   asyncio.Event.set.__qualname__.__len__,             [],               9,    "asyncio.Event.set.__qualname__.__len__() == 9; verified with Python 3.14.3"]
    - [evt_clr_qeq,    asyncio.Event.clear.__qualname__.__eq__,           ["Event.clear"],  true, "asyncio.Event.clear.__qualname__ == 'Event.clear' (len=11); verified with Python 3.14.3"]
    - [evt_clr_qlen,   asyncio.Event.clear.__qualname__.__len__,           [],               11,   "asyncio.Event.clear.__qualname__.__len__() == 11; verified with Python 3.14.3"]
    - [evt_wt_qeq,     asyncio.Event.wait.__qualname__.__eq__,            ["Event.wait"],   true, "asyncio.Event.wait.__qualname__ == 'Event.wait' (len=10); verified with Python 3.14.3"]
    - [evt_wt_qlen,    asyncio.Event.wait.__qualname__.__len__,            [],               10,   "asyncio.Event.wait.__qualname__.__len__() == 10; verified with Python 3.14.3"]
    - [evt_isset_qeq,  asyncio.Event.is_set.__qualname__.__eq__,          ["Event.is_set"], true, "asyncio.Event.is_set.__qualname__ == 'Event.is_set' (len=12, longest Event method qualname); verified with Python 3.14.3"]
    - [evt_isset_qlen, asyncio.Event.is_set.__qualname__.__len__,          [],               12,   "asyncio.Event.is_set.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [evt_set_cls,    asyncio.Event.set.__class__.__name__.__eq__,       ["function"],     true, "asyncio.Event.set.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]
    - [evt_wt_cls,     asyncio.Event.wait.__class__.__name__.__eq__,      ["function"],     true, "asyncio.Event.wait.__class__.__name__ == 'function' — Python coroutine function; verified with Python 3.14.3"]

