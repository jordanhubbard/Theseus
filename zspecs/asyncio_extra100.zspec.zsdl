table asyncio_extra100.asyncio_semaphore_method_qualnames:
  description: "asyncio.Semaphore method __qualname__ length checks in asynciolockqn100 namespace — wave 254 theme: asyncio.Semaphore method qualnames parallel Lock method qualnames but with longer 'Semaphore.' prefix; Semaphore is defined in Lib/asyncio/locks.py (module='asyncio.locks'); Semaphore.__mro__ is [Semaphore, _ContextManagerMixin, _LoopBoundMixin, object] (length=4, one more than Event's length-3 MRO); Semaphore.acquire.__qualname__.__eq__('Semaphore.acquire')==True (len=17: 'Semaphore.'=10 + 'acquire'=7); Semaphore.acquire.__qualname__.__len__()==17 (5 more than Lock.acquire.__qualname__.__len__()==12, because 'Semaphore.' is 5 chars longer than 'Lock.'); Semaphore.release.__qualname__.__eq__('Semaphore.release')==True (len=17: same as acquire — 'Semaphore.'=10 + 'release'=7); Semaphore.locked.__qualname__.__eq__('Semaphore.locked')==True (len=16: 'Semaphore.'=10 + 'locked'=6); Semaphore.locked.__qualname__.__len__()==16 (one less than acquire/release at 17, same pattern as Lock.locked vs Lock.acquire); all methods have class='function' (pure-Python); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolockqn100b

  columns: [id, function, args, expected, description]
  rows:
    - [sem_acq_qeq,   asyncio.Semaphore.acquire.__qualname__.__eq__,     ["Semaphore.acquire"], true, "asyncio.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (len=17); verified with Python 3.14.3"]
    - [sem_acq_qlen,  asyncio.Semaphore.acquire.__qualname__.__len__,     [],                    17,   "asyncio.Semaphore.acquire.__qualname__.__len__() == 17 (5 more than Lock.acquire.__qualname__.__len__()==12); verified with Python 3.14.3"]
    - [sem_rel_qeq,   asyncio.Semaphore.release.__qualname__.__eq__,     ["Semaphore.release"], true, "asyncio.Semaphore.release.__qualname__ == 'Semaphore.release' (len=17, same as acquire); verified with Python 3.14.3"]
    - [sem_rel_qlen,  asyncio.Semaphore.release.__qualname__.__len__,     [],                    17,   "asyncio.Semaphore.release.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [sem_lkd_qeq,   asyncio.Semaphore.locked.__qualname__.__eq__,      ["Semaphore.locked"],  true, "asyncio.Semaphore.locked.__qualname__ == 'Semaphore.locked' (len=16, one less than acquire/release); verified with Python 3.14.3"]
    - [sem_lkd_qlen,  asyncio.Semaphore.locked.__qualname__.__len__,      [],                    16,   "asyncio.Semaphore.locked.__qualname__.__len__() == 16; verified with Python 3.14.3"]
    - [sem_acq_cls,   asyncio.Semaphore.acquire.__class__.__name__.__eq__, ["function"],         true, "asyncio.Semaphore.acquire.__class__.__name__ == 'function' — Python coroutine function; verified with Python 3.14.3"]
    - [sem_rel_cls,   asyncio.Semaphore.release.__class__.__name__.__eq__, ["function"],         true, "asyncio.Semaphore.release.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra100
# ---------------------------------------------------------------------------

invariant asyncio_extra100.Lock_acquire_qualname_len_12:
  description: "asyncio.Lock.acquire.__qualname__.__len__() == 12 — asyncio.Lock.acquire.__qualname__ is 'Lock.acquire' (12 characters: 'Lock.'=5 + 'acquire'=7); Lock is a pure-Python class defined in Lib/asyncio/locks.py (Lock.__module__=='asyncio.locks'); Lock methods have class='function' (pure-Python coroutine functions), contrasting with asyncio.Task methods which are C-level method_descriptors (class='method_descriptor'); Lock.__mro__ has length 4 ([Lock, _ContextManagerMixin, _LoopBoundMixin, object]), more complex than Event's MRO (length=3) or Future's MRO (length=2); Lock.acquire and Lock.release have equal qualname lengths (both 12), while Lock.locked is one shorter (11); NEW in extra100: first standalone Lock.acquire qualname length invariant in asynciolockqn100 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Lock.acquire.__qualname__.__len__
  args: []
  expected: 12

invariant asyncio_extra100.Event_set_qualname_len_9:
  description: "asyncio.Event.set.__qualname__.__len__() == 9 — asyncio.Event.set.__qualname__ is 'Event.set' (9 characters: 'Event.'=6 + 'set'=3); this is the shortest qualname among the four Event methods: Event.set=9, Event.wait=10, Event.clear=11, Event.is_set=12; Event is defined in Lib/asyncio/locks.py (module='asyncio.locks'); Event.__mro__ is [Event, _LoopBoundMixin, object] (length=3); Event.set is a synchronous (non-coroutine) method that sets the internal flag and notifies all waiters; Event.wait is the corresponding coroutine that blocks until the flag is set; Event.set.__class__.__name__ is 'function' (pure-Python); NEW in extra100: first standalone Event.set qualname length invariant in asynciolockqn100 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Event.set.__qualname__.__len__
  args: []
  expected: 9

invariant asyncio_extra100.Semaphore_acquire_qualname_len_17:
  description: "asyncio.Semaphore.acquire.__qualname__.__len__() == 17 — asyncio.Semaphore.acquire.__qualname__ is 'Semaphore.acquire' (17 characters: 'Semaphore.'=10 + 'acquire'=7); this is 5 chars longer than Lock.acquire.__qualname__.__len__()==12 because 'Semaphore.' is 5 chars longer than 'Lock.'; Semaphore.release also has qualname length 17 (same as acquire); Semaphore.locked has length 16 (one shorter); Semaphore is defined in Lib/asyncio/locks.py (module='asyncio.locks'); Semaphore.__mro__ is [Semaphore, _ContextManagerMixin, _LoopBoundMixin, object] (length=4); Semaphore.acquire is a coroutine that decrements the counter (blocking when zero); Semaphore.release is synchronous and increments the counter; Semaphore.acquire.__class__.__name__ is 'function'; NEW in extra100: first standalone Semaphore.acquire qualname length invariant in asynciolockqn100 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.acquire.__qualname__.__len__
  args: []
  expected: 17

invariant asyncio_extra100.Lock_acquire_is_function:
  description: "asyncio.Lock.acquire.__class__.__name__.__eq__('function') returns True — asyncio.Lock.acquire is a Python coroutine function (class='function'), unlike asyncio.Task.acquire which would be a method_descriptor (C-level); this confirms that asyncio synchronization primitives (Lock, Event, Semaphore) are implemented in pure Python in Lib/asyncio/locks.py, while asyncio.Task and asyncio.Future are C extension classes from _asyncio; Lock.acquire.__qualname__ is 'Lock.acquire' (len=12); Lock.release and Lock.locked are also Python functions; Lock.acquire.__module__ is 'asyncio.locks' (the locks submodule, distinct from the '_asyncio' C extension module used by Task and Future); NEW in extra100: first standalone Lock.acquire class name invariant in asynciolockqn100 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Lock.acquire.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant asyncio_extra100.Event_is_set_qualname_len_12:
  description: "asyncio.Event.is_set.__qualname__.__len__() == 12 — asyncio.Event.is_set.__qualname__ is 'Event.is_set' (12 characters: 'Event.'=6 + 'is_set'=6); Event.is_set has the longest qualname among the four Event methods (set=9, wait=10, clear=11, is_set=12); this matches Lock.acquire.__qualname__.__len__()==12 and Lock.release.__qualname__.__len__()==12 (same length but different prefixes and suffixes); Event.is_set is a synchronous (non-coroutine) method that returns the current flag value; Event.is_set.__class__.__name__ is 'function'; NEW in extra100: first standalone Event.is_set qualname length invariant in asynciolockqn100 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Event.is_set.__qualname__.__len__
  args: []
  expected: 12

