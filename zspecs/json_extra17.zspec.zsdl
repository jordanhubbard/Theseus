spec: json_extra17
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json.zspec.zsdl and prior extras through json_extra16.zspec.zsdl."
    - "json_extra16 covers: JSONEncoder/__qualname__; JSONDecoder/__qualname__; JSONDecodeError/__qualname__; class __qualname__.__class__.__name__ table."
    - "json_extra15 covers: JSONDecodeError/__module__; JSONEncoder/__module__ standalone; JSONDecoder/__module__ standalone; load/__qualname__; dump/__qualname__."
    - "json_extra14 covers: loads/__qualname__; dumps/__qualname__; loads/__module__; dumps/__module__."
    - "Focus: __qualname__ for JSONEncoder and JSONDecoder instance methods — encode, iterencode, default, decode, raw_decode."
    - "No prior json spec checks JSONEncoder.encode.__qualname__."
    - "No prior json spec checks JSONEncoder.iterencode.__qualname__."
    - "No prior json spec checks JSONEncoder.default.__qualname__."
    - "No prior json spec checks JSONDecoder.decode.__qualname__."
    - "No prior json spec checks JSONDecoder.raw_decode.__qualname__."
    - "json.JSONEncoder.encode.__qualname__ == 'JSONEncoder.encode' — compound qualname for nested method."
    - "json.JSONEncoder.iterencode.__qualname__ == 'JSONEncoder.iterencode' — compound qualname."
    - "json.JSONEncoder.default.__qualname__ == 'JSONEncoder.default' — compound qualname."
    - "json.JSONDecoder.decode.__qualname__ == 'JSONDecoder.decode' — compound qualname."
    - "json.JSONDecoder.raw_decode.__qualname__ == 'JSONDecoder.raw_decode' — compound qualname."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# JSONEncoder method __qualname__ values
#
# json_extra16 checks JSONEncoder.__qualname__ == 'JSONEncoder' for the class.
# No prior json spec checks __qualname__ for any bound or unbound methods of
# JSONEncoder. For a method defined in class Foo, __qualname__ == 'Foo.method'.
# ---------------------------------------------------------------------------

invariant json_extra17.JSONEncoder.encode.qualname:
  description: "json.JSONEncoder.encode.__qualname__ == 'JSONEncoder.encode' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: "JSONEncoder.encode.__qualname__.__eq__"
  args: ["JSONEncoder.encode"]
  expected: true

invariant json_extra17.JSONEncoder.iterencode.qualname:
  description: "json.JSONEncoder.iterencode.__qualname__ == 'JSONEncoder.iterencode' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: "JSONEncoder.iterencode.__qualname__.__eq__"
  args: ["JSONEncoder.iterencode"]
  expected: true

invariant json_extra17.JSONEncoder.default.qualname:
  description: "json.JSONEncoder.default.__qualname__ == 'JSONEncoder.default' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: "JSONEncoder.default.__qualname__.__eq__"
  args: ["JSONEncoder.default"]
  expected: true

# ---------------------------------------------------------------------------
# JSONDecoder method __qualname__ values
#
# json_extra16 checks JSONDecoder.__qualname__ == 'JSONDecoder' for the class.
# No prior json spec checks __qualname__ for any methods of JSONDecoder.
# ---------------------------------------------------------------------------

invariant json_extra17.JSONDecoder.decode.qualname:
  description: "json.JSONDecoder.decode.__qualname__ == 'JSONDecoder.decode' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: "JSONDecoder.decode.__qualname__.__eq__"
  args: ["JSONDecoder.decode"]
  expected: true

invariant json_extra17.JSONDecoder.raw_decode.qualname:
  description: "json.JSONDecoder.raw_decode.__qualname__ == 'JSONDecoder.raw_decode' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: "JSONDecoder.raw_decode.__qualname__.__eq__"
  args: ["JSONDecoder.raw_decode"]
  expected: true

# ---------------------------------------------------------------------------
# JSONEncoder and JSONDecoder method __qualname__ table
#
# Consolidates all five method qualname checks into a single table for
# coverage completeness. All five are first covered in this spec.
# ---------------------------------------------------------------------------

table json_extra17.method_qualnames:
  description: "json encoder/decoder method __qualname__ values — compound dotted names"
  kind: python_call_eq
  category: method_attrs
  id_prefix: jmq17

  columns: [id, function, args, expected]
  rows:
    - [encode_qn,      "JSONEncoder.encode.__qualname__.__eq__",      ["JSONEncoder.encode"],      true]
    - [iterencode_qn,  "JSONEncoder.iterencode.__qualname__.__eq__",  ["JSONEncoder.iterencode"],  true]
    - [default_qn,     "JSONEncoder.default.__qualname__.__eq__",     ["JSONEncoder.default"],     true]
    - [decode_qn,      "JSONDecoder.decode.__qualname__.__eq__",      ["JSONDecoder.decode"],      true]
    - [raw_decode_qn,  "JSONDecoder.raw_decode.__qualname__.__eq__",  ["JSONDecoder.raw_decode"],  true]
