spec: linecache_extra4
version: ">=3.9"
backend: python_module(linecache)

docs: https://docs.python.org/3/library/linecache.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/linecache.html — Python linecache module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/linecache.py (internal implementation)"
  notes:
    - "This spec extends linecache.zspec.zsdl, linecache_extra.zspec.zsdl, linecache_extra2.zspec.zsdl, and linecache_extra3.zspec.zsdl."
    - "linecache.zspec.zsdl covers: function_names table (getline/getlines/clearcache/checkcache/updatecache/lazycache __name__); getline_module; getline for /nonexistent_path_xyz/file.py lines 0/1/2/-1; getlines nonexistent; clearcache/checkcache return None."
    - "linecache_extra.zspec.zsdl covers: getline/__name__/__module__; getlines/__name__; clearcache/__name__; checkcache/__name__; cache.__class__.__name__=='dict'; getline(''  ,1)==''."
    - "linecache_extra2.zspec.zsdl covers: getline/__name__/__module__; clearcache/__name__/__module__; checkcache/__name__/__module__; getlines/__name__/__module__; lazycache/__name__/__module__; updatecache/__name__/__module__; cache.__class__.__name__=='dict'."
    - "linecache_extra3.zspec.zsdl covers: function_names table (getline/getlines/clearcache/checkcache); getline.__module__ standalone; updatecache.__name__ standalone; checkcache.__class__.__name__=='function'; getlines('/dev/null',{}) return type; getline('nonexistent_file_xyz.py',1)==''."
    - "This spec adds: __qualname__ checks for getline, getlines, clearcache, checkcache, updatecache (not covered by any prior spec); getline('/dev/null', 1) == '' (readable empty device — always readable on POSIX, line 1 does not exist, returns ''); getlines('/dev/null') == [] (empty device returns empty list; prior spec only checks return type, not value)."
    - "linecache.getline(filename, lineno) returns '' when the requested line number exceeds the number of lines in the file. /dev/null contains zero lines, so any lineno returns ''."
    - "linecache.getlines('/dev/null') returns [] because /dev/null has no lines. linecache_extra3 verified the return type; this spec asserts the exact value."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ checks
# Module-level functions defined in linecache have __qualname__ == __name__.
# No prior spec covers __qualname__ for any linecache callable.
# ---------------------------------------------------------------------------

table linecache_extra4.function_qualnames:
  description: "linecache functions have __qualname__ equal to their unqualified name"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [getline,     getline.__qualname__.__eq__,     ["getline"],     true]
    - [getlines,    getlines.__qualname__.__eq__,    ["getlines"],    true]
    - [clearcache,  clearcache.__qualname__.__eq__,  ["clearcache"],  true]
    - [checkcache,  checkcache.__qualname__.__eq__,  ["checkcache"],  true]
    - [updatecache, updatecache.__qualname__.__eq__, ["updatecache"], true]

# ---------------------------------------------------------------------------
# getline('/dev/null', 1) == ''
# /dev/null is always readable on POSIX but contains zero bytes, so there is
# no line 1. linecache.getline returns '' when the requested line does not exist.
# Existing specs use /nonexistent_path_xyz/file.py (unreadable) or bare
# filenames. This is the first vector using /dev/null as the filename.
# ---------------------------------------------------------------------------

invariant linecache_extra4.getline.dev_null_line1:
  description: "linecache.getline('/dev/null', 1) == '' — /dev/null has no lines"
  category: behavior
  kind: python_call_eq
  function: getline
  args: ["/dev/null", 1]
  expected: ""

# ---------------------------------------------------------------------------
# getlines('/dev/null') == []
# /dev/null always reads as zero bytes, so getlines returns an empty list.
# linecache_extra3 checked that getlines('/dev/null', {}).__class__.__name__
# == 'list'; this spec asserts the exact return value == [].
# ---------------------------------------------------------------------------

invariant linecache_extra4.getlines.dev_null_value:
  description: "linecache.getlines('/dev/null') == [] — /dev/null contains no lines"
  category: behavior
  kind: python_call_eq
  function: getlines
  args: ["/dev/null"]
  expected: []
