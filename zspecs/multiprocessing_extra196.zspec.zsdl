  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra196.mp_SpawnContext_base_name_eq:
  description: "multiprocessing.context.SpawnContext.__bases__[0].__name__.__eq__('BaseContext') returns True — SpawnContext.__bases__[0].__name__=='BaseContext' (len=11); SpawnContext inherits from BaseContext, which provides the shared multiprocessing API; SpawnContext.__bases__[0].__name__ (11: 'BaseContext') == BaseContext.__name__ (11: 'BaseContext') — the base class name matches the base class's own __name__; SpawnContext.__bases__[0].__name__ (11) < SpawnContext.__module__ (23) by 12; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
