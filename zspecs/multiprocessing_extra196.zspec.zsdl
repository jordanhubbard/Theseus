invariant multiprocessing_extra196.mp_BaseContext_name_eq:
  description: "multiprocessing.context.BaseContext.__name__.__eq__('BaseContext') returns True — BaseContext.__name__=='BaseContext' (len=11); BaseContext is the abstract superclass for all three multiprocessing start-method contexts: SpawnContext (spawn), ForkContext (fork), and ForkServerContext (forkserver); it provides the shared API for creating processes and synchronization primitives; BaseContext.__name__ (11) > BaseContext.__bases__[0].__name__ (6: 'object') by 5; NEW in mpcontext196: first standalone BaseContext.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.context.BaseContext.__name__.__eq__
  args: ["BaseContext"]
  expected: true

invariant multiprocessing_extra196.mp_BaseContext_module_eq:
  description: "multiprocessing.context.BaseContext.__module__.__eq__('multiprocessing.context') returns True — BaseContext.__module__=='multiprocessing.context' (len=23: 'multiprocessing.context'=23); the context submodule isolates process-creation logic from the top-level multiprocessing package; BaseContext.__module__ (23) > BaseContext.__name__ (11) by 12; BaseContext.__module__ (23) == SpawnContext.__module__ (23) — all context classes share the same submodule; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.context.BaseContext.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra196.mp_BaseContext_base_name_eq:
  description: "multiprocessing.context.BaseContext.__bases__[0].__name__.__eq__('object') returns True — BaseContext.__bases__[0].__name__=='object' (len=6); BaseContext inherits directly from object — it is a standalone abstract class not derived from any framework-specific base; BaseContext.__bases__[0].__name__ (6: 'object') < BaseContext.__name__ (11: 'BaseContext') by 5; comparing base classes: SpawnContext.__bases__[0].__name__ == 'BaseContext' (11) while BaseContext.__bases__[0].__name__ == 'object' (6); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.context.BaseContext.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra196.mp_SpawnContext_name_eq:
  description: "multiprocessing.context.SpawnContext.__name__.__eq__('SpawnContext') returns True — SpawnContext.__name__=='SpawnContext' (len=12); SpawnContext implements the 'spawn' start method which is the default on macOS and Windows; spawning starts a fresh Python interpreter, making it the safest but slowest start method; SpawnContext.__name__ (12) > BaseContext.__name__ (11) by 1; SpawnContext.__name__ (12) < SpawnContext.__module__ (23) by 11; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.context.SpawnContext.__name__.__eq__
  args: ["SpawnContext"]
  expected: true

invariant multiprocessing_extra196.mp_SpawnContext_module_eq:
  description: "multiprocessing.context.SpawnContext.__module__.__eq__('multiprocessing.context') returns True — SpawnContext.__module__=='multiprocessing.context' (len=23); SpawnContext is co-located with BaseContext in the same multiprocessing.context submodule; SpawnContext.__module__ (23) == BaseContext.__module__ (23) — confirming both are defined in the same file; SpawnContext.__module__ (23) > SpawnContext.__name__ (12) by 11; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
