spec: abc_extra826
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython abc module source"
    - "Python docs: abc.ABCMeta"
    - "Python docs: abc.ABC"
    - "Python docs: abc.abstractmethod"
  not_derived_from:
    - "any third-party ABC framework"
  notes:
    - "Covers ABCMeta and ABC qualnames and module identity"
    - "Covers abstractmethod __isabstractmethod__ type and module"
    - "Covers get_cache_token qualname"
  created_at: "2026-04-12"

table abc_extra826.abcmeta_qualnames:
  description: "abc.ABCMeta method and attribute identity checks"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: ab826am
  columns: [id, function, args, expected]
  rows:
    - [ab826am001, abc.ABCMeta.__prepare__.__qualname__.__eq__, ["ABCMeta.__prepare__"], true]
    - [ab826am002, abc.ABCMeta.__init_subclass__.__qualname__.__eq__, ["ABCMeta.__init_subclass__"], true]
    - [ab826am003, abc.ABCMeta.__module__.__eq__, ["abc"], true]
    - [ab826am004, abc.ABCMeta.__qualname__.__eq__, ["ABCMeta"], true]
    - [ab826am005, abc.ABCMeta.__doc__.__class__.__name__.__eq__, ["str"], true]

table abc_extra826.abc_qualnames:
  description: "abc.ABC method and attribute identity checks"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: ab826ac
  columns: [id, function, args, expected]
  rows:
    - [ab826ac001, abc.ABC.__init__.__qualname__.__eq__, ["ABC.__init__"], true]
    - [ab826ac002, abc.ABC.__init_subclass__.__qualname__.__eq__, ["ABC.__init_subclass__"], true]
    - [ab826ac003, abc.ABC.__qualname__.__eq__, ["ABC"], true]

table abc_extra826.abstractmethod_qualnames:
  description: "abc.abstractmethod attribute and module identity checks"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: ab826ab
  columns: [id, function, args, expected]
  rows:
    - [ab826ab001, abc.abstractmethod.__isabstractmethod__.__class__.__name__.__eq__, ["bool"], true]
    - [ab826ab002, abc.abstractmethod.__qualname__.__eq__, ["abstractmethod"], true]
    - [ab826ab003, abc.abstractmethod.__module__.__eq__, ["abc"], true]

table abc_extra826.module_functions:
  description: "abc module-level function qualname checks"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: ab826mf
  columns: [id, function, args, expected]
  rows:
    - [ab826mf001, abc.get_cache_token.__qualname__.__eq__, ["get_cache_token"], true]
