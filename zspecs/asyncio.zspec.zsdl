spec: asyncio
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/asyncio.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "asyncio source: internal event loop implementation"
  notes:
    - "asyncio.FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED are string sentinel constants used with asyncio.wait()."
    - "asyncio.Queue is the async-safe queue (not the queue stdlib module); new Queue is always empty."
    - "asyncio.iscoroutinefunction is deprecated as of Python 3.12; use inspect.iscoroutinefunction instead."
    - "AbstractEventLoopPolicy.__name__ resolves to '_AbstractEventLoopPolicy' internally."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — core asyncio classes
# ---------------------------------------------------------------------------

table asyncio.class_names:
  kind: python_call_eq
  category: classes
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [future,          Future.__name__.__eq__,          ["Future"],          true]
    - [task,            Task.__name__.__eq__,            ["Task"],            true]
    - [lock,            Lock.__name__.__eq__,            ["Lock"],            true]
    - [event,           Event.__name__.__eq__,           ["Event"],           true]
    - [condition,       Condition.__name__.__eq__,       ["Condition"],       true]
    - [semaphore,       Semaphore.__name__.__eq__,       ["Semaphore"],       true]
    - [queue,           Queue.__name__.__eq__,           ["Queue"],           true]
    - [priority_queue,  PriorityQueue.__name__.__eq__,   ["PriorityQueue"],   true]
    - [lifo_queue,      LifoQueue.__name__.__eq__,       ["LifoQueue"],       true]
    - [queue_empty,     QueueEmpty.__name__.__eq__,      ["QueueEmpty"],      true]
    - [queue_full,      QueueFull.__name__.__eq__,       ["QueueFull"],       true]
    - [cancelled_error, CancelledError.__name__.__eq__,  ["CancelledError"],  true]
    - [timeout_error,   TimeoutError.__name__.__eq__,    ["TimeoutError"],    true]
    - [invalid_state,   InvalidStateError.__name__.__eq__,["InvalidStateError"],true]
    - [stream_reader,   StreamReader.__name__.__eq__,    ["StreamReader"],    true]
    - [stream_writer,   StreamWriter.__name__.__eq__,    ["StreamWriter"],    true]

# ---------------------------------------------------------------------------
# Function name checks — top-level asyncio functions
# ---------------------------------------------------------------------------

table asyncio.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [get_event_loop,       get_event_loop.__name__.__eq__,       ["get_event_loop"],       true]
    - [new_event_loop,       new_event_loop.__name__.__eq__,       ["new_event_loop"],       true]
    - [run,                  run.__name__.__eq__,                  ["run"],                  true]
    - [gather,               gather.__name__.__eq__,               ["gather"],               true]
    - [sleep,                sleep.__name__.__eq__,                ["sleep"],                true]
    - [iscoroutine,          iscoroutine.__name__.__eq__,          ["iscoroutine"],          true]
    - [iscoroutinefunction,  iscoroutinefunction.__name__.__eq__,  ["iscoroutinefunction"],  true]
    - [isfuture,             isfuture.__name__.__eq__,             ["isfuture"],             true]

# ---------------------------------------------------------------------------
# iscoroutine / iscoroutinefunction / isfuture — non-coroutine inputs
# ---------------------------------------------------------------------------

invariant asyncio.iscoroutine.non_coroutine:
  description: "asyncio.iscoroutine(1) == False — integers are not coroutines"
  category: introspection
  kind: python_call_eq
  function: iscoroutine
  args: [1]
  expected: false

invariant asyncio.iscoroutinefunction.builtin:
  description: "asyncio.iscoroutinefunction(len) == False — builtins are not coroutine functions"
  category: introspection
  kind: python_call_eq
  function: iscoroutinefunction
  args: ["len"]
  expected: false

invariant asyncio.isfuture.non_future:
  description: "asyncio.isfuture(1) == False — integers are not futures"
  category: introspection
  kind: python_call_eq
  function: isfuture
  args: [1]
  expected: false

# ---------------------------------------------------------------------------
# String sentinel constants — asyncio.wait() completion modes
# ---------------------------------------------------------------------------

invariant asyncio.constants.first_completed:
  description: "asyncio.FIRST_COMPLETED == 'FIRST_COMPLETED'"
  category: constants
  kind: python_call_eq
  function: FIRST_COMPLETED.__eq__
  args: ["FIRST_COMPLETED"]
  expected: true

invariant asyncio.constants.first_exception:
  description: "asyncio.FIRST_EXCEPTION == 'FIRST_EXCEPTION'"
  category: constants
  kind: python_call_eq
  function: FIRST_EXCEPTION.__eq__
  args: ["FIRST_EXCEPTION"]
  expected: true

invariant asyncio.constants.all_completed:
  description: "asyncio.ALL_COMPLETED == 'ALL_COMPLETED'"
  category: constants
  kind: python_call_eq
  function: ALL_COMPLETED.__eq__
  args: ["ALL_COMPLETED"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.Queue — new queue is always empty
# ---------------------------------------------------------------------------

invariant asyncio.queue_empty:
  description: "asyncio.Queue().empty() == True — a newly created Queue has no items"
  category: queue
  kind: python_call_eq
  function: Queue
  args: []
  method: empty
  method_args: []
  expected: true

invariant asyncio.queue_qsize:
  description: "asyncio.Queue().qsize() == 0 — a newly created Queue has size 0"
  category: queue
  kind: python_call_eq
  function: Queue
  args: []
  method: qsize
  method_args: []
  expected: 0

