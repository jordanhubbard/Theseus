spec: io_extra2206
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2206 (io_extra2206): rich comparison operator protocol dict-presence checks — __lt__, __le__, __gt__, __ge__, __eq__, __ne__."
    - "io.IOBase does NOT define any of the six comparison dunders in its own __dict__ — identity/equality is handled by the default object protocol inherited from object."
    - "io.RawIOBase does NOT define any of the six comparison dunders in its own __dict__ — it extends IOBase without adding comparison support."
    - "io.BufferedIOBase does NOT define any of the six comparison dunders in its own __dict__ — same pattern as RawIOBase."
    - "io.TextIOBase does NOT define any of the six comparison dunders in its own __dict__ — same pattern as RawIOBase."
    - "io.StringIO does NOT define any of the six comparison dunders in its own __dict__ — the concrete text-stream class relies on inherited object identity semantics."
    - "io.BytesIO does NOT define any of the six comparison dunders in its own __dict__ — the concrete binary-stream class relies on inherited object identity semantics."
    - "io.FileIO does NOT define any of the six comparison dunders in its own __dict__ — file streams are not ordered or value-compared."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table io_extra2206.iobase_comparison_protocol:
  description: "io.IOBase rich comparison operator dict-presence checks — all six operators absent from class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2206

  columns: [id, function, args, expected]
  rows:
    - ["io2206001", "io.IOBase.__dict__.__contains__", ["__lt__"], false]
    - ["io2206002", "io.IOBase.__dict__.__contains__", ["__le__"], false]
    - ["io2206003", "io.IOBase.__dict__.__contains__", ["__gt__"], false]
    - ["io2206004", "io.IOBase.__dict__.__contains__", ["__ge__"], false]
    - ["io2206005", "io.IOBase.__dict__.__contains__", ["__eq__"], false]
    - ["io2206006", "io.IOBase.__dict__.__contains__", ["__ne__"], false]

