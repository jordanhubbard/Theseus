spec: compute_min
version: ">=1.0.1"
backend: node(compute-min)

docs: https://www.npmjs.com/package/compute-min

provenance:
  derived_from:
    - "compute-min README — https://www.npmjs.com/package/compute-min"
    - "Test vectors verified with compute-min via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "compute-min source"
  notes:
    - "compute-min is an npm package. Install: npm install compute-min"
    - "Returns the minimum value of an array of numbers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table compute_min.min:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: cmin

  columns: [id, args, expected]
  rows:
    - [three,  [[3, 1, 2]],       1]
    - [one,    [[5]],             5]
    - [four,   [[10, 20, 5, 15]], 5]
