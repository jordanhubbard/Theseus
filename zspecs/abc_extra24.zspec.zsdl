spec: abc_extra24
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra23.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__.__len__() and __name__.__len__() and __qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token, abstractproperty __module__/__name__/__qualname__ lengths, ABCMeta.register __name__/__qualname__ lengths."
    - "This spec covers: __qualname__.__len__() for ABCMeta.__new__/ABCMeta.__instancecheck__; __mro__.__len__() for ABCMeta/ABC; ABC.__slots__ existence and type; ABC.__abstractmethods__.__len__(); abstractmethod.__qualname__.__len__() and get_cache_token.__qualname__.__len__() as standalones."
    - "abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (length 15)."
    - "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (length 25)."
    - "abc.ABCMeta.__mro__ == (ABCMeta, type, object) — length 3; ABCMeta inherits from type."
    - "abc.ABC.__mro__ == (ABC, object) — length 2; ABC is a simple helper class."
    - "abc.ABC.__slots__ == () — ABC defines empty __slots__."
    - "abc.ABC.__abstractmethods__ == frozenset() — length 0; ABC has no abstract methods."
    - "abc.abstractmethod.__qualname__ == 'abstractmethod' (length 14)."
    - "abc.get_cache_token.__qualname__ == 'get_cache_token' (length 15)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for ABCMeta.__new__ and ABCMeta.__instancecheck__
#
# ABCMeta defines __new__ and __instancecheck__ as metaclass methods.
# 'ABCMeta.__new__' has 15 characters (7 + 1 + 7); 'ABCMeta.__instancecheck__'
# has 25 characters (7 + 1 + 17). No prior abc spec records
# __qualname__.__len__() for these two methods.
# ---------------------------------------------------------------------------

table abc_extra24.abcmeta_method_qualname_lens:
  description: "__qualname__.__len__() for ABCMeta methods — __new__ (15) and __instancecheck__ (25)"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [__new__,           "ABCMeta.__new__.__qualname__.__len__",           [], 15]
    - [__instancecheck__, "ABCMeta.__instancecheck__.__qualname__.__len__", [], 25]

# ---------------------------------------------------------------------------
# __mro__.__len__() for ABCMeta and ABC
#
# ABCMeta's MRO is (ABCMeta, type, object), length 3 — it inherits from the
# built-in type metaclass. ABC's MRO is (ABC, object), length 2 — ABC is a
# minimal helper class that uses ABCMeta as its metaclass. No prior abc spec
# records __mro__.__len__() for either class.
# ---------------------------------------------------------------------------

table abc_extra24.class_mro_lens:
  description: "__mro__.__len__() for ABCMeta/ABC — ABCMeta depth 3 (metaclass chain), ABC depth 2 (direct object subclass)"
  kind: python_call_eq
  category: mro_lengths
  id_prefix: mro_len

  columns: [id, function, args, expected]
  rows:
    - [ABCMeta, ABCMeta.__mro__.__len__, [], 3]
    - [ABC,     ABC.__mro__.__len__,     [], 2]

# ---------------------------------------------------------------------------
# ABC.__slots__ and ABC.__abstractmethods__
#
# ABC.__slots__ == () — ABC explicitly defines empty __slots__ to suppress
# per-instance __dict__. ABC.__abstractmethods__ == frozenset() (length 0) —
# ABC itself is not abstract; it is a convenience base class. No prior abc
# spec records either of these attributes for ABC.
# ---------------------------------------------------------------------------

table abc_extra24.abc_slots_and_abstractmethods:
  description: "ABC.__slots__ class name length and ABC.__abstractmethods__ length — empty slot tuple (5) and empty frozenset (0)"
  kind: python_call_eq
  category: slot_and_abstractmethods_checks
  id_prefix: abc

  columns: [id, function, args, expected]
  rows:
    - [slots_class_name_len,    ABC.__slots__.__class__.__name__.__len__,    [], 5]
    - [abstractmethods_len,     ABC.__abstractmethods__.__len__,              [], 0]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — standalone
#
# 'ABCMeta.__instancecheck__' has 25 characters: the 7-character class name
# 'ABCMeta', a dot, and the 17-character method name '__instancecheck__'.
# This is the longest method qualname among all abc methods measured in the
# extra series.
# ---------------------------------------------------------------------------

invariant abc_extra24.ABCMeta.instancecheck.qualname_len:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — 'ABCMeta.__instancecheck__' is 7 + 1 + 17 = 25 characters; longest method qualname in abc extra series"
  category: method_qualname_lengths
  kind: python_call_eq
  function: "ABCMeta.__instancecheck__.__qualname__.__len__"
  args: []
  expected: 25

# ---------------------------------------------------------------------------
# abc.abstractmethod.__qualname__.__len__() == 14 — standalone
#
# abc.abstractmethod.__qualname__ == 'abstractmethod' (length 14). extra22
# recorded abstractmethod.__qualname__ equality with __name__ but not the
# length as a standalone. This invariant anchors it at 14 for cross-module
# comparison with related decorator names.
# ---------------------------------------------------------------------------

invariant abc_extra24.abstractmethod.qualname_len:
  description: "abc.abstractmethod.__qualname__.__len__() == 14 — 'abstractmethod' has length 14; top-level class so qualname equals name"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: abstractmethod.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# abc.get_cache_token.__qualname__.__len__() == 15 — standalone
#
# abc.get_cache_token.__qualname__ == 'get_cache_token' (length 15). extra22
# recorded get_cache_token.__qualname__ equality with __name__ but not the
# length as a standalone. This invariant anchors it at 15, confirming
# get_cache_token's qualname is one character longer than abstractmethod's.
# ---------------------------------------------------------------------------

invariant abc_extra24.get_cache_token.qualname_len:
  description: "abc.get_cache_token.__qualname__.__len__() == 15 — 'get_cache_token' has length 15; one character longer than abstractmethod (14)"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: get_cache_token.__qualname__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# abc.ABCMeta.__mro__.__len__() == 3 — standalone
#
# ABCMeta's MRO is (ABCMeta, type, object), depth 3. ABCMeta is a metaclass
# (subclass of type), so it has one more level in its MRO than ABC (depth 2).
# This invariant anchors the metaclass chain depth for cross-module comparison.
# ---------------------------------------------------------------------------

invariant abc_extra24.ABCMeta.mro_len:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — MRO is (ABCMeta, type, object); metaclass depth 3 vs ABC's depth 2"
  category: mro_lengths
  kind: python_call_eq
  function: ABCMeta.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# abc.ABC.__bases__[0].__name__.__len__() == 6 — standalone
#
# abc.ABC.__bases__[0].__name__ == 'object' (length 6). ABC has a single
# direct base class (object). No prior abc spec records this attribute length
# as a standalone; it complements the __mro__.__len__() == 2 invariant above.
# ---------------------------------------------------------------------------

invariant abc_extra24.ABC.bases0_name_len:
  description: "abc.ABC.__bases__[0].__name__.__len__() == 6 — ABC's sole base class is 'object' (length 6)"
  category: base_class_names
  kind: python_call_eq
  function: "ABC.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# abc.ABCMeta.__bases__[0].__name__.__len__() == 4 — standalone
#
# abc.ABCMeta.__bases__[0].__name__ == 'type' (length 4). ABCMeta inherits
# from the built-in type metaclass. This confirms ABCMeta's metaclass chain:
# its base is 'type' (4 chars), shorter than ABC's base 'object' (6 chars).
# ---------------------------------------------------------------------------

invariant abc_extra24.ABCMeta.bases0_name_len:
  description: "abc.ABCMeta.__bases__[0].__name__.__len__() == 4 — ABCMeta's base class is 'type' (length 4); ABCMeta is a subclass of the built-in type metaclass"
  category: base_class_names
  kind: python_call_eq
  function: "ABCMeta.__bases__[0].__name__.__len__"
  args: []
  expected: 4
