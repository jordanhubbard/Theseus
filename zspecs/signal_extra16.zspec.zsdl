spec: signal_extra16
version: ">=3.9"
backend: python_module(signal)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/signal.html — Python signal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
  notes:
    - "This spec extends signal_extra15.zspec.zsdl."
    - "Prior specs covered: signal numbers (SIGINT=2, SIGTERM=15, etc.), SIG_DFL/SIG_IGN values and as Handlers members, signal/__name__, Signals/__name__/__qualname__, Handlers/__name__/__qualname__, getsignal/__name__, raise_signal/__name__, strsignal for various signals, valid_signals() return type, SIG_DFL/SIG_IGN.__eq__ values, Signals/Handlers __name__.__len__(), signal/getsignal/raise_signal __qualname__/__module__ (extra12/extra13), signal.signal/__qualname__/getsignal/__qualname__/raise_signal/__qualname__/strsignal/__name__/__qualname__/valid_signals/__name__/__qualname__ (extra14), signal/getsignal/raise_signal/strsignal __module__.__len__() (extra14), function __name__.__len__() for signal/getsignal/raise_signal/strsignal/valid_signals, Signals/Handlers __module__.__len__(), alarm/__name__/__module__.__len__(), pause/__module__.__len__(), set_wakeup_fd/__module__/__name__.__len__() (extra15)."
    - "This spec covers: signal.Signals.__mro__.__len__(), signal.Handlers.__mro__.__len__(), signal.Signals.__bases__[0].__name__, signal.Handlers.__bases__[0].__name__, signal.SIGTERM.__class__.__name__, signal.SIG_DFL.__class__.__name__, signal.SIGINT.__class__.__name__, signal.Signals._member_names_.__len__(), signal.SIGINT value, signal.SIGTERM value."
    - "signal.Signals.__mro__.__len__() == 6 — Signals MRO: Signals -> IntEnum -> int -> ReprEnum -> Enum -> object (6 entries); no prior signal spec checks Signals.__mro__.__len__()."
    - "signal.Handlers.__mro__.__len__() == 6 — same depth as Signals; Handlers also inherits through IntEnum; no prior signal spec checks Handlers.__mro__.__len__()."
    - "signal.Signals.__bases__[0].__name__ == 'IntEnum' — Signals is a direct subclass of IntEnum; no prior signal spec checks Signals.__bases__[0].__name__."
    - "signal.Handlers.__bases__[0].__name__ == 'IntEnum' — Handlers is also a direct subclass of IntEnum; no prior signal spec checks Handlers.__bases__[0].__name__."
    - "signal.SIGTERM.__class__.__name__ == 'Signals' — SIGTERM is an instance of the Signals enum; no prior signal spec checks SIGTERM.__class__.__name__."
    - "signal.SIG_DFL.__class__.__name__ == 'Handlers' — SIG_DFL is an instance of the Handlers enum; no prior signal spec checks SIG_DFL.__class__.__name__."
    - "signal.SIGINT.__class__.__name__ == 'Signals' — SIGINT is an instance of the Signals enum like SIGTERM; no prior signal spec checks SIGINT.__class__.__name__."
    - "signal.Signals._member_names_.__len__() == 31 — 31 named signal constants in the Signals enum on macOS/Darwin; no prior signal spec checks _member_names_.__len__()."
    - "signal.SIGINT value == 2 — SIGINT is interrupt signal, standardized as 2 by POSIX; verifiable as signal.SIGINT.value.__eq__(2)."
    - "signal.SIGTERM value == 15 — SIGTERM is terminate signal, standardized as 15 by POSIX; verifiable as signal.SIGTERM.value.__eq__(15)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# signal.Signals and signal.Handlers __mro__ depth
#
# The MRO for both Signals and Handlers is 6 entries deep:
#   Signals -> IntEnum -> int -> ReprEnum -> Enum -> object
# No prior signal spec checks __mro__.__len__() on Signals or Handlers.
# Both classes have identical MRO depth due to the same inheritance chain
# through IntEnum.
# ---------------------------------------------------------------------------

invariant signal_extra16.Signals.mro_len:
  description: "signal.Signals.__mro__.__len__() == 6 — MRO: Signals->IntEnum->int->ReprEnum->Enum->object; no prior signal spec checks Signals.__mro__.__len__()"
  category: class_hierarchy
  kind: python_call_eq
  function: Signals.__mro__.__len__
  args: []
  expected: 6

invariant signal_extra16.Handlers.mro_len:
  description: "signal.Handlers.__mro__.__len__() == 6 — same MRO depth as Signals via IntEnum inheritance; no prior signal spec checks Handlers.__mro__.__len__()"
  category: class_hierarchy
  kind: python_call_eq
  function: Handlers.__mro__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# signal.Signals and signal.Handlers __bases__[0].__name__
#
# Both Signals and Handlers are direct subclasses of IntEnum. The __bases__
# tuple has exactly one entry for each (since Python's enum metaclass handles
# multiple bases internally). No prior signal spec checks __bases__[0].__name__
# on Signals or Handlers. The function paths contain '[' and must be quoted.
# ---------------------------------------------------------------------------

table signal_extra16.enum_bases:
  description: "Signals/Handlers __bases__[0].__name__ — both are direct IntEnum subclasses; no prior signal spec checks __bases__[0].__name__ on either"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: bases16

  columns: [id, function, args, expected]
  rows:
    - [Signals,  "Signals.__bases__[0].__name__.__eq__",  [IntEnum], true]
    - [Handlers, "Handlers.__bases__[0].__name__.__eq__", [IntEnum], true]

# ---------------------------------------------------------------------------
# signal.SIGTERM, signal.SIGINT, signal.SIG_DFL instance class names
#
# SIGTERM and SIGINT are members of the Signals enum; SIG_DFL is a member of
# the Handlers enum. No prior signal spec checks __class__.__name__ on any of
# these three signal constants. These invariants confirm the enum membership
# of the most commonly referenced signal constants.
# ---------------------------------------------------------------------------

table signal_extra16.constant_class_names:
  description: "SIGTERM/SIGINT/SIG_DFL __class__.__name__ — confirm enum membership; no prior signal spec checks __class__.__name__ on these constants"
  kind: python_call_eq
  category: enum_membership
  id_prefix: clsname16

  columns: [id, function, args, expected]
  rows:
    - [SIGTERM,  SIGTERM.__class__.__name__.__eq__,  [Signals],  true]
    - [SIGINT,   SIGINT.__class__.__name__.__eq__,   [Signals],  true]
    - [SIG_DFL,  SIG_DFL.__class__.__name__.__eq__,  [Handlers], true]

# ---------------------------------------------------------------------------
# signal.Signals._member_names_ length and SIGINT/SIGTERM values
#
# The _member_names_ list tracks all named members of the Signals enum. On
# macOS/Darwin it contains 31 entries. SIGINT==2 and SIGTERM==15 are POSIX
# constants. No prior signal spec checks _member_names_.__len__(). SIGINT and
# SIGTERM values were checked as enum members in early specs but the value
# attribute comparison via __eq__ provides an orthogonal regression check.
# ---------------------------------------------------------------------------

invariant signal_extra16.Signals.member_names_len:
  description: "signal.Signals._member_names_.__len__() == 31 — 31 named signal constants on macOS/Darwin; no prior signal spec checks _member_names_.__len__()"
  category: enum_membership
  kind: python_call_eq
  function: Signals._member_names_.__len__
  args: []
  expected: 31

invariant signal_extra16.SIGINT.value:
  description: "signal.SIGINT.value.__eq__(2) — SIGINT is interrupt signal, POSIX value 2; verifies .value attribute access on Signals member"
  category: signal_values
  kind: python_call_eq
  function: SIGINT.value.__eq__
  args: [2]
  expected: true

invariant signal_extra16.SIGTERM.value:
  description: "signal.SIGTERM.value.__eq__(15) — SIGTERM is terminate signal, POSIX value 15; verifies .value attribute access on Signals member"
  category: signal_values
  kind: python_call_eq
  function: SIGTERM.value.__eq__
  args: [15]
  expected: true
