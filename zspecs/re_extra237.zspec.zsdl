spec: re_extra237
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.fullmatch behavioral contracts — match/no-match results, Match object group/start/end/span."
    - "re.fullmatch(r'\\d+', '123') is not None — matches entire string of digits; verified Python 3.14.3 macOS."
    - "re.fullmatch(r'\\d+', '12x') is None — partial digit match fails fullmatch; verified Python 3.14.3 macOS."
    - "re.fullmatch(r'\\w+', 'hello').__class__.__name__ == 'Match' — successful fullmatch returns a Match object; verified Python 3.14.3 macOS."
    - "re.fullmatch(r'[a-z]+', 'abc').group() == 'abc' — group() returns the entire matched string; verified Python 3.14.3 macOS."
    - "re.fullmatch(r'[a-z]+', 'abc').start() == 0 — fullmatch always starts at position 0; verified Python 3.14.3 macOS."
    - "re.fullmatch(r'[a-z]+', 'abc').end() == 3 — end position equals length of the string; verified Python 3.14.3 macOS."
    - "re.fullmatch(r'\\d{3}', '123').group() == '123' — exact-length digit pattern matches; verified Python 3.14.3 macOS."
    - "re.fullmatch.__qualname__ == 'fullmatch' — function qualname; covered in re_extra136; novel behavioral anchors here."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.fullmatch match/no-match boolean contracts
# fullmatch requires the entire string to match the pattern.
# A partial match that does not cover the full string returns None.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra237.fullmatch.digits_match_not_none:
  description: "re.fullmatch(r'\\d+', '123') is not None — entire digit string matches \\d+; verified Python 3.14.3 macOS"
  category: match_result
  kind: python_call_eq
  function: fullmatch
  args: ["\\d+", "123"]
  method: __class__.__name__.__eq__
  method_args: ["Match"]
  expected: true

invariant re_extra237.fullmatch.partial_is_none:
  description: "re.fullmatch(r'\\d+', '12x') is None — '12x' does not fully match \\d+; fullmatch fails when pattern does not cover entire string; verified Python 3.14.3 macOS"
  category: match_result
  kind: python_call_eq
  function: fullmatch
  args: ["\\d+", "12x"]
  method: __class__.__name__.__eq__
  method_args: ["NoneType"]
  expected: true

invariant re_extra237.fullmatch.word_match_class:
  description: "re.fullmatch(r'\\w+', 'hello').__class__.__name__ == 'Match' — successful fullmatch returns a Match object; verified Python 3.14.3 macOS"
  category: match_result
  kind: python_call_eq
  function: fullmatch
  args: ["\\w+", "hello"]
  method: __class__.__name__.__eq__
  method_args: ["Match"]
  expected: true

# ---------------------------------------------------------------------------
# re.fullmatch Match.group() contracts
# group() with no arguments returns the entire matched string.
# For fullmatch, group(0) == the input string (entire string matched).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra237.fullmatch.group_abc:
  description: "re.fullmatch(r'[a-z]+', 'abc').group() == 'abc' — group() returns the entire matched string; verified Python 3.14.3 macOS"
  category: match_group
  kind: python_call_eq
  function: fullmatch
  args: ["[a-z]+", "abc"]
  method: group
  method_args: []
  expected: "abc"

invariant re_extra237.fullmatch.group_digits:
  description: "re.fullmatch(r'\\d{3}', '123').group() == '123' — exact-length digit pattern group equals input; verified Python 3.14.3 macOS"
  category: match_group
  kind: python_call_eq
  function: fullmatch
  args: ["\\d{3}", "123"]
  method: group
  method_args: []
  expected: "123"

# ---------------------------------------------------------------------------
# re.fullmatch Match.start() and .end() contracts
# For fullmatch, start() is always 0 (match begins at string start).
# end() equals the length of the matched string.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra237.fullmatch.start_zero:
  description: "re.fullmatch(r'[a-z]+', 'abc').start() == 0 — fullmatch always starts at position 0; verified Python 3.14.3 macOS"
  category: match_span
  kind: python_call_eq
  function: fullmatch
  args: ["[a-z]+", "abc"]
  method: start
  method_args: []
  expected: 0

invariant re_extra237.fullmatch.end_three:
  description: "re.fullmatch(r'[a-z]+', 'abc').end() == 3 — end position equals string length 3; verified Python 3.14.3 macOS"
  category: match_span
  kind: python_call_eq
  function: fullmatch
  args: ["[a-z]+", "abc"]
  method: end
  method_args: []
  expected: 3

# ---------------------------------------------------------------------------
# re.fullmatch function identity spot-checks
# fullmatch.__qualname__ and __module__ covered in re_extra136.
# These are additional namespace anchors.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra237.fullmatch_identity:
  description: "re.fullmatch function __qualname__ and __module__ identity; verified Python 3.14.3"
  kind: python_call_eq
  category: function_identity
  id_prefix: refullmatch237

  columns: [id, function, args, expected]
  rows:
    - [qualname_eq,   fullmatch.__qualname__.__eq__,   ["fullmatch"], true]
    - [module_eq,     fullmatch.__module__.__eq__,     ["re"],        true]
    - [qualname_len,  fullmatch.__qualname__.__len__,  [],            9]
    - [class_eq,      fullmatch.__class__.__name__.__eq__, ["function"], true]
