spec: itertools_extra1666
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "Python itertools documentation — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools.zspec.zsdl — covers classnames and first_element checks"
    - "itertools_extra.zspec.zsdl — covers filterfalse classname, chain/repeat/islice length hints"
  notes:
    - "Theme: __new__ — object construction protocol."
    - "Every public itertools type is a C extension type (tp_new in C → __new__ in Python)."
    - "All 19 public itertools types define __new__ in their own __dict__."
    - "None of the itertools C types define __init__ in their own __dict__; C types that implement tp_new typically do not also implement tp_init."
    - "This is the canonical C type pattern: construction goes entirely through __new__; no __init__ slot is needed."
    - "batched was added in Python 3.12; pairwise was added in Python 3.10."
    - "All expected values verified by running Python 3.14 on macOS Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: c_types_new_present
#
# Confirms that every public itertools C type defines __new__ in its own
# __dict__.  This is the canonical fingerprint of a C extension type that
# handles object construction entirely through tp_new.
# ---------------------------------------------------------------------------

table itertools_extra1666.c_types_new_present:
  kind: python_call_eq
  category: c_types_new_present
  id_prefix: it1666

  columns: [id, function, args, expected]
  rows:
    - ["accumulate_has_new",                  accumulate.__dict__.__contains__,                  ["__new__"], true]
    - ["batched_has_new",                     batched.__dict__.__contains__,                     ["__new__"], true]
    - ["chain_has_new",                       chain.__dict__.__contains__,                       ["__new__"], true]
    - ["combinations_has_new",                combinations.__dict__.__contains__,                ["__new__"], true]
    - ["combinations_with_replacement_new",   combinations_with_replacement.__dict__.__contains__, ["__new__"], true]
    - ["compress_has_new",                    compress.__dict__.__contains__,                    ["__new__"], true]
    - ["count_has_new",                       count.__dict__.__contains__,                       ["__new__"], true]
    - ["cycle_has_new",                       cycle.__dict__.__contains__,                       ["__new__"], true]
    - ["dropwhile_has_new",                   dropwhile.__dict__.__contains__,                   ["__new__"], true]
    - ["filterfalse_has_new",                 filterfalse.__dict__.__contains__,                 ["__new__"], true]
    - ["groupby_has_new",                     groupby.__dict__.__contains__,                     ["__new__"], true]
    - ["islice_has_new",                      islice.__dict__.__contains__,                      ["__new__"], true]
    - ["pairwise_has_new",                    pairwise.__dict__.__contains__,                    ["__new__"], true]
    - ["permutations_has_new",                permutations.__dict__.__contains__,                ["__new__"], true]
    - ["product_has_new",                     product.__dict__.__contains__,                     ["__new__"], true]
    - ["repeat_has_new",                      repeat.__dict__.__contains__,                      ["__new__"], true]
    - ["starmap_has_new",                     starmap.__dict__.__contains__,                     ["__new__"], true]
    - ["takewhile_has_new",                   takewhile.__dict__.__contains__,                   ["__new__"], true]
    - ["zip_longest_has_new",                 zip_longest.__dict__.__contains__,                 ["__new__"], true]

# ---------------------------------------------------------------------------
# Table 2: c_types_init_absent
#
# Confirms that none of the public itertools C types define __init__ in their
# own __dict__.  C types that use tp_new exclusively do not also define
# tp_init, so __init__ is absent from the class __dict__.
# ---------------------------------------------------------------------------

table itertools_extra1666.c_types_init_absent:
  kind: python_call_eq
  category: c_types_init_absent
  id_prefix: it1666

  columns: [id, function, args, expected]
  rows:
    - ["accumulate_no_init",                  accumulate.__dict__.__contains__,                  ["__init__"], false]
    - ["batched_no_init",                     batched.__dict__.__contains__,                     ["__init__"], false]
    - ["chain_no_init",                       chain.__dict__.__contains__,                       ["__init__"], false]
    - ["combinations_no_init",                combinations.__dict__.__contains__,                ["__init__"], false]
    - ["combinations_with_replacement_no_init", combinations_with_replacement.__dict__.__contains__, ["__init__"], false]
    - ["compress_no_init",                    compress.__dict__.__contains__,                    ["__init__"], false]
    - ["count_no_init",                       count.__dict__.__contains__,                       ["__init__"], false]
    - ["cycle_no_init",                       cycle.__dict__.__contains__,                       ["__init__"], false]
    - ["dropwhile_no_init",                   dropwhile.__dict__.__contains__,                   ["__init__"], false]
    - ["filterfalse_no_init",                 filterfalse.__dict__.__contains__,                 ["__init__"], false]
    - ["groupby_no_init",                     groupby.__dict__.__contains__,                     ["__init__"], false]
    - ["islice_no_init",                      islice.__dict__.__contains__,                      ["__init__"], false]
    - ["pairwise_no_init",                    pairwise.__dict__.__contains__,                    ["__init__"], false]
    - ["permutations_no_init",                permutations.__dict__.__contains__,                ["__init__"], false]
    - ["product_no_init",                     product.__dict__.__contains__,                     ["__init__"], false]
    - ["repeat_no_init",                      repeat.__dict__.__contains__,                      ["__init__"], false]
    - ["starmap_no_init",                     starmap.__dict__.__contains__,                     ["__init__"], false]
    - ["takewhile_no_init",                   takewhile.__dict__.__contains__,                   ["__init__"], false]
    - ["zip_longest_no_init",                 zip_longest.__dict__.__contains__,                 ["__init__"], false]
