spec: uuid_extra1741
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 563 (_extra1741): descriptor protocol dict-presence checks."
    - "uuid.UUID is not a descriptor — it defines no __get__, __set__, __delete__, or __set_name__ in its own __dict__."
    - "uuid.UUID.__dict__.__contains__('__get__') is False — UUID is a value-object class, not a descriptor."
    - "uuid.UUID.__dict__.__contains__('__set__') is False — UUID defines no __set__."
    - "uuid.UUID.__dict__.__contains__('__delete__') is False — UUID defines no __delete__."
    - "uuid.UUID.__dict__.__contains__('__set_name__') is False — UUID does not participate in class creation hooks."
    - "uuid.SafeUUID is an IntEnum subclass — also not a descriptor; all four checks are False."
    - "Complementary checks: uuid.UUID.__dict__ contains many @property attributes ('int', 'fields', 'bytes', 'bytes_le', 'hex', 'urn', 'variant', 'version', 'is_safe')."
    - "uuid.UUID.__dict__.__contains__('fields') is True — UUID exposes a fields property."
    - "uuid.UUID.__dict__.__contains__('bytes_le') is True — UUID exposes a bytes_le property."
    - "uuid.UUID.__dict__.__contains__('int') is True — UUID exposes an int property for the 128-bit integer value."
    - "uuid.UUID.__dict__.__contains__('hex') is True — UUID exposes a hex property."
    - "uuid.UUID.__dict__.__contains__('urn') is True — UUID exposes a urn property."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: descriptor protocol dict-presence checks for uuid types
#
# Wave 563 theme: which uuid types define __get__, __set__, __delete__,
# __set_name__ in their own __dict__.
#
# uuid.UUID: pure-Python value object — no descriptor protocol.
#   __get__: False, __set__: False, __delete__: False, __set_name__: False.
# uuid.SafeUUID: IntEnum subclass — also no descriptor protocol.
#   __get__: False, __set__: False, __delete__: False, __set_name__: False.
# ---------------------------------------------------------------------------

table uuid_extra1741.descriptor_protocol:
  description: "uuid types descriptor protocol dict-presence checks — wave 563 _extra1741"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1741

  columns: [id, function, args, expected]
  rows:
    - ["uu1741001", "uuid.UUID.__dict__.__contains__", ["__get__"], false]
    - ["uu1741002", "uuid.UUID.__dict__.__contains__", ["__set__"], false]
    - ["uu1741003", "uuid.UUID.__dict__.__contains__", ["__delete__"], false]
    - ["uu1741004", "uuid.UUID.__dict__.__contains__", ["__set_name__"], false]
    - ["uu1741005", "uuid.SafeUUID.__dict__.__contains__", ["__get__"], false]
    - ["uu1741006", "uuid.SafeUUID.__dict__.__contains__", ["__set__"], false]
    - ["uu1741007", "uuid.SafeUUID.__dict__.__contains__", ["__delete__"], false]
    - ["uu1741008", "uuid.SafeUUID.__dict__.__contains__", ["__set_name__"], false]

# ---------------------------------------------------------------------------
# Table 2: uuid.UUID __dict__ property attribute presence
#
# uuid.UUID is a rich pure-Python class with many @property attributes.
# These are stored as property objects in uuid.UUID.__dict__.
#
# uuid.UUID.__dict__.__contains__('int') is True — 128-bit integer value.
# uuid.UUID.__dict__.__contains__('fields') is True — (time_low, ...) tuple.
# uuid.UUID.__dict__.__contains__('bytes') is True — big-endian bytes.
# uuid.UUID.__dict__.__contains__('bytes_le') is True — mixed-endian bytes.
# uuid.UUID.__dict__.__contains__('hex') is True — 32-char hex string.
# uuid.UUID.__dict__.__contains__('urn') is True — urn:uuid: prefixed string.
# uuid.UUID.__dict__.__contains__('variant') is True — RFC 4122 variant.
# uuid.UUID.__dict__.__contains__('version') is True — UUID version number.
# uuid.UUID.__dict__.__contains__('is_safe') is True — SafeUUID attribute.
# uuid.UUID.__dict__.__contains__('node') is True — 48-bit hardware address.
# ---------------------------------------------------------------------------

table uuid_extra1741.uuid_dict_property_presence:
  description: "uuid.UUID __dict__ property attribute presence checks — wave 563 _extra1741"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1741

  columns: [id, function, args, expected]
  rows:
    - ["uu1741009",  "uuid.UUID.__dict__.__contains__", ["int"],      true]
    - ["uu1741010",  "uuid.UUID.__dict__.__contains__", ["fields"],   true]
    - ["uu1741011",  "uuid.UUID.__dict__.__contains__", ["bytes"],    true]
    - ["uu1741012",  "uuid.UUID.__dict__.__contains__", ["bytes_le"], true]
    - ["uu1741013",  "uuid.UUID.__dict__.__contains__", ["hex"],      true]
    - ["uu1741014",  "uuid.UUID.__dict__.__contains__", ["urn"],      true]
    - ["uu1741015",  "uuid.UUID.__dict__.__contains__", ["variant"],  true]
    - ["uu1741016",  "uuid.UUID.__dict__.__contains__", ["version"],  true]
    - ["uu1741017",  "uuid.UUID.__dict__.__contains__", ["is_safe"],  true]
    - ["uu1741018",  "uuid.UUID.__dict__.__contains__", ["node"],     true]

# ---------------------------------------------------------------------------
# Table 3: uuid.UUID __dict__ method and dunder presence
#
# uuid.UUID also exposes __init__, __str__, __repr__, __int__ in __dict__.
# These contrast with the descriptor dunders (__get__, __set__, etc.) which
# are absent.
#
# uuid.UUID.__dict__.__contains__('__init__') is True.
# uuid.UUID.__dict__.__contains__('__str__') is True.
# uuid.UUID.__dict__.__contains__('__repr__') is True.
# uuid.UUID.__dict__.__contains__('__int__') is True.
# ---------------------------------------------------------------------------

table uuid_extra1741.uuid_dict_dunder_presence:
  description: "uuid.UUID __dict__ dunder method presence — contrast with absent descriptor dunders — wave 563 _extra1741"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1741

  columns: [id, function, args, expected]
  rows:
    - ["uu1741019", "uuid.UUID.__dict__.__contains__", ["__init__"],  true]
    - ["uu1741020", "uuid.UUID.__dict__.__contains__", ["__str__"],   true]
    - ["uu1741021", "uuid.UUID.__dict__.__contains__", ["__repr__"],  true]
    - ["uu1741022", "uuid.UUID.__dict__.__contains__", ["__int__"],   true]
    - ["uu1741023", "uuid.UUID.__dict__.__contains__", ["__slots__"], true]
