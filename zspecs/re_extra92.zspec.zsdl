spec: re_extra92
version: ">=3.9"
backend: python_module(re)
extends: re_extra91

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra91."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; method qualnames; re.error/__name__; module-level function qualnames; re.RegexFlag hierarchy; re module constants; Pattern/Match __dict__.__class__.__name__; Pattern/Match __qualname__ and length; PatternError attributes; re.NOFLAG value; Pattern/Match method __doc__.__len__(); re.Pattern/__dict__.__contains__; re module-level function __qualname__ for all functions; Pattern/Match __name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__(); RegexFlag class identity; re.Pattern/Match method __qualname__ string equality."
    - "This spec covers: re.Pattern and re.Match method __qualname__ string lengths (complementing the string equality checks in re_extra91)."
    - "re.Pattern.match.__qualname__.__len__() == 13 — 'Pattern.match' has 13 characters."
    - "re.Pattern.search.__qualname__.__len__() == 14 — 'Pattern.search' has 14 characters."
    - "re.Pattern.findall.__qualname__.__len__() == 15 — 'Pattern.findall' has 15 characters."
    - "re.Pattern.finditer.__qualname__.__len__() == 16 — 'Pattern.finditer' has 16 characters."
    - "re.Pattern.sub.__qualname__.__len__() == 11 — 'Pattern.sub' has 11 characters."
    - "re.Pattern.subn.__qualname__.__len__() == 12 — 'Pattern.subn' has 12 characters."
    - "re.Pattern.split.__qualname__.__len__() == 13 — 'Pattern.split' has 13 characters."
    - "re.Pattern.fullmatch.__qualname__.__len__() == 17 — 'Pattern.fullmatch' has 17 characters."
    - "re.Match.group.__qualname__.__len__() == 11 — 'Match.group' has 11 characters."
    - "re.Match.groups.__qualname__.__len__() == 12 — 'Match.groups' has 12 characters."
    - "re.Match.start.__qualname__.__len__() == 11 — 'Match.start' has 11 characters."
    - "re.Match.end.__qualname__.__len__() == 9 — 'Match.end' has 9 characters."
    - "re.Match.span.__qualname__.__len__() == 10 — 'Match.span' has 10 characters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern match/search/findall/finditer __qualname__ lengths
# Pattern is a C type from _sre; method qualnames follow 'Pattern.<method>' format.
# Lengths: match=13, search=14, findall=15, finditer=16.
# ---------------------------------------------------------------------------

table re_extra92.Pattern_match_search_qualname_lengths:
  description: "re.Pattern.match/search/findall/finditer __qualname__ string lengths"
  kind: python_call_eq
  category: qualname
  id_prefix: remathmethodlen92

  columns: [id, function, args, expected]
  rows:
    - [pattern_match_len,    Pattern.match.__qualname__.__len__,    [], 13]
    - [pattern_search_len,   Pattern.search.__qualname__.__len__,   [], 14]
    - [pattern_findall_len,  Pattern.findall.__qualname__.__len__,  [], 15]
    - [pattern_finditer_len, Pattern.finditer.__qualname__.__len__, [], 16]

# ---------------------------------------------------------------------------
# re.Pattern sub/subn/split/fullmatch __qualname__ lengths
# Lengths: sub=11, subn=12, split=13, fullmatch=17.
# Note: match and split share length 13.
# ---------------------------------------------------------------------------

table re_extra92.Pattern_sub_split_qualname_lengths:
  description: "re.Pattern.sub/subn/split/fullmatch __qualname__ string lengths"
  kind: python_call_eq
  category: qualname
  id_prefix: remathmethodlen92

  columns: [id, function, args, expected]
  rows:
    - [pattern_sub_len,       Pattern.sub.__qualname__.__len__,       [], 11]
    - [pattern_subn_len,      Pattern.subn.__qualname__.__len__,      [], 12]
    - [pattern_split_len,     Pattern.split.__qualname__.__len__,     [], 13]
    - [pattern_fullmatch_len, Pattern.fullmatch.__qualname__.__len__, [], 17]

# ---------------------------------------------------------------------------
# re.Match group/groups __qualname__ lengths
# Match method qualnames follow 'Match.<method>' format.
# group=11, groups=12.
# ---------------------------------------------------------------------------

table re_extra92.Match_group_groups_qualname_lengths:
  description: "re.Match.group/groups __qualname__ string lengths"
  kind: python_call_eq
  category: qualname
  id_prefix: remathmethodlen92

  columns: [id, function, args, expected]
  rows:
    - [match_group_len,   Match.group.__qualname__.__len__,   [], 11]
    - [match_groups_len,  Match.groups.__qualname__.__len__,  [], 12]
    - [match_start_len,   Match.start.__qualname__.__len__,   [], 11]
    - [match_end_len,     Match.end.__qualname__.__len__,     [], 9]

# ---------------------------------------------------------------------------
# re.Match span + cross-checks
# span=10; cross-checks: Pattern.sub (11) == Match.group (11);
# Pattern.finditer (16) > Pattern.fullmatch (17) is false.
# ---------------------------------------------------------------------------

table re_extra92.Match_span_cross_checks:
  description: "re.Match.span __qualname__ length; cross-checks between Pattern and Match method lengths"
  kind: python_call_eq
  category: qualname
  id_prefix: remathmethodlen92

  columns: [id, function, args, expected]
  rows:
    - [match_span_len,           Match.span.__qualname__.__len__,       [], 10]
    - [pattern_sub_eq_match_grp, Pattern.sub.__qualname__.__len__,      [], 11]
    - [match_grp_eq_pattern_sub, Match.group.__qualname__.__len__,      [], 11]
    - [pattern_findall_len_xchk, Pattern.findall.__qualname__.__len__,  [], 15]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra92.Pattern.match_qualname_len:
  description: "re.Pattern.match.__qualname__.__len__() == 13 ('Pattern.match' has 13 characters)"
  category: qualname
  kind: python_call_eq
  function: Pattern.match.__qualname__.__len__
  args: []
  expected: 13

invariant re_extra92.Pattern.fullmatch_qualname_len:
  description: "re.Pattern.fullmatch.__qualname__.__len__() == 17 ('Pattern.fullmatch' has 17 characters)"
  category: qualname
  kind: python_call_eq
  function: Pattern.fullmatch.__qualname__.__len__
  args: []
  expected: 17

invariant re_extra92.Pattern.sub_qualname_len:
  description: "re.Pattern.sub.__qualname__.__len__() == 11 ('Pattern.sub' has 11 characters)"
  category: qualname
  kind: python_call_eq
  function: Pattern.sub.__qualname__.__len__
  args: []
  expected: 11

invariant re_extra92.Match.group_qualname_len:
  description: "re.Match.group.__qualname__.__len__() == 11 ('Match.group' has 11 characters)"
  category: qualname
  kind: python_call_eq
  function: Match.group.__qualname__.__len__
  args: []
  expected: 11

invariant re_extra92.Match.span_qualname_len:
  description: "re.Match.span.__qualname__.__len__() == 10 ('Match.span' has 10 characters)"
  category: qualname
  kind: python_call_eq
  function: Match.span.__qualname__.__len__
  args: []
  expected: 10
