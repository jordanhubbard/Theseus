spec: concurrent_futures_extra1996
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 580 (_extra1996): __index__, __complex__, __float__, __round__, __abs__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures executor and Future types are concurrency primitives, not numeric types."
    - "Covers concurrent.futures.Future, ThreadPoolExecutor, ProcessPoolExecutor, Executor."
    - "None of these define __index__, __complex__, __float__, __round__, or __abs__ in their own __dict__."
  created_at: "2026-04-12"
error_model: python_exceptions

table concurrent_futures_extra1996.index_protocol:
  description: "concurrent.futures types __index__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1996

  columns: [id, function, args, expected]
  rows:
    - ["cf1996001", "concurrent.futures.Future.__dict__.__contains__",              ["__index__"],   false]
    - ["cf1996002", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__index__"],   false]
    - ["cf1996003", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__index__"],   false]
    - ["cf1996004", "concurrent.futures.Executor.__dict__.__contains__",            ["__index__"],   false]

