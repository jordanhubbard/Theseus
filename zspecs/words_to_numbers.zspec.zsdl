spec: words_to_numbers
version: ">=1.0.0"
backend: node(words-to-numbers)

docs: https://www.npmjs.com/package/words-to-numbers

provenance:
  derived_from:
    - "words-to-numbers README — https://www.npmjs.com/package/words-to-numbers"
    - "Test vectors verified with words-to-numbers via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "words-to-numbers source"
  notes:
    - "words-to-numbers is an npm package. Install: npm install words-to-numbers"
    - "wordsToNumbers(str) converts English number words to their numeric value."
    - "Module exports a named export: require('words-to-numbers').wordsToNumbers"
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns numeric value or original string if not a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table words_to_numbers.wordsToNumbers:
  kind: node_module_call_eq
  function: wordsToNumbers
  category: convert
  id_prefix: wtn

  columns: [id, args, expected]
  rows:
    - [twenty_one,  ["twenty one"],  21]
    - [one_hundred, ["one hundred"], 100]
    - [forty_two,   ["forty two"],   42]
