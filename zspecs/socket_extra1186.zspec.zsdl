provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket.socket.__dict__/__mro__/__bases__ class names (mappingproxy/tuple/tuple), socket.error.__dict__/__mro__ class names (mappingproxy/tuple), socket.AddressFamily/__dict__/__mro__/__bases__ and socket.SocketKind.__dict__/__mro__/__bases__ class names (mappingproxy/tuple/tuple), and MRO/bases lengths"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1186.socket_class_dict_mro_bases:
  description: "socket.socket __dict__/__mro__/__bases__ class names confirming mappingproxy and tuple types"
  kind: python_call_eq
  category: socket_class_dict_mro_bases
  id_prefix: sk1186dm
  columns: [id, function, args, expected]
  rows:
    - [sk1186dm001, socket.socket.__dict__.__class__.__name__.__eq__,             ["mappingproxy"],  true]
    - [sk1186dm002, socket.socket.__dict__.__class__.__qualname__.__eq__,         ["mappingproxy"],  true]
    - [sk1186dm003, socket.socket.__dict__.__class__.__module__.__eq__,           ["builtins"],      true]
    - [sk1186dm004, socket.socket.__mro__.__class__.__name__.__eq__,              ["tuple"],         true]
    - [sk1186dm005, socket.socket.__mro__.__class__.__qualname__.__eq__,          ["tuple"],         true]
    - [sk1186dm006, socket.socket.__mro__.__class__.__module__.__eq__,            ["builtins"],      true]
    - [sk1186dm007, socket.socket.__bases__.__class__.__name__.__eq__,            ["tuple"],         true]
    - [sk1186dm008, socket.socket.__bases__.__class__.__module__.__eq__,          ["builtins"],      true]
    - [sk1186dm009, socket.socket.__mro__.__len__,                                [],                3]
    - [sk1186dm010, socket.socket.__bases__.__len__,                              [],                1]

