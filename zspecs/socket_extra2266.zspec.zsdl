spec: socket_extra2266
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "Wave 598 (_extra2266): pickling/serialization protocol dict-presence checks."
    - "Checks __reduce__, __reduce_ex__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__, __copy__, __deepcopy__, __sizeof__, __class_getitem__, __init_subclass__ presence in __dict__ of socket types."
    - "socket.socket is a Python class defining __getstate__ (True) to suppress default pickling; all other protocol keys absent."
    - "socket.error is an alias for OSError; OSError defines __reduce__ (True); all other pickling/copy keys absent."
    - "socket.herror and socket.gaierror are OSError subclasses with no additional protocol keys in their own __dict__."
    - "socket.timeout is an alias for TimeoutError; TimeoutError.__dict__ has no pickling/copy protocol keys."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; no pickling/copy protocol keys in their __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra2266.socket_pickle:
  description: "socket.socket pickle/copy protocol dict-presence — __getstate__ present (raises to block pickling); all other protocol keys absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2266

  columns: [id, function, args, expected]
  rows:
    - ["sk2266001", "socket.socket.__dict__.__contains__", ["__reduce__"], false]
    - ["sk2266002", "socket.socket.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["sk2266003", "socket.socket.__dict__.__contains__", ["__getstate__"], true]
    - ["sk2266004", "socket.socket.__dict__.__contains__", ["__setstate__"], false]
    - ["sk2266005", "socket.socket.__dict__.__contains__", ["__getnewargs__"], false]
    - ["sk2266006", "socket.socket.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["sk2266007", "socket.socket.__dict__.__contains__", ["__copy__"], false]
    - ["sk2266008", "socket.socket.__dict__.__contains__", ["__deepcopy__"], false]
    - ["sk2266009", "socket.socket.__dict__.__contains__", ["__sizeof__"], false]
    - ["sk2266010", "socket.socket.__dict__.__contains__", ["__class_getitem__"], false]
    - ["sk2266011", "socket.socket.__dict__.__contains__", ["__init_subclass__"], false]

