spec: threading_extra50
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra49.zspec.zsdl."
    - "Prior specs covered: Thread/__name__/__qualname__/__module__; Thread/__qualname__.__len__()==6; Thread/__mro__.__len__()==2; Thread/__bases__[0].__name__=='object'; Thread/__bases__[0].__qualname__=='object'; Event/__qualname__=='Event'; Event/__qualname__.__len__()==5; Event/__mro__.__len__()==2; Event/__bases__[0].__name__=='object'; Event/__bases__[0].__qualname__=='object'; Semaphore/__name__/__qualname__/__module__; Semaphore/__qualname__.__len__()==9; Semaphore/__mro__.__len__()==2; Semaphore/__bases__[0].__qualname__=='object'; BoundedSemaphore/__name__/__qualname__/__module__; BoundedSemaphore/__qualname__.__len__()==16; BoundedSemaphore/__mro__.__len__()==3; BoundedSemaphore/__bases__[0].__name__=='Semaphore'; BoundedSemaphore/__bases__[0].__qualname__=='Semaphore'; Condition/__name__/__module__; Condition/__qualname__=='Condition'; Condition/__qualname__.__len__()==9; Condition/__mro__.__len__()==2; Condition/__bases__[0].__name__=='object'; Condition/__bases__[0].__qualname__=='object'; Barrier/__name__/__qualname__/__module__; Barrier/__mro__.__len__()==2; Barrier/__bases__[0].__name__=='object'; Barrier/__bases__[0].__qualname__=='object'; Timer/__name__/__qualname__/__module__; Timer/__mro__.__len__()==3; Timer/__bases__[0].__name__=='Thread'; Timer/__bases__[0].__qualname__=='Thread'; Lock/__name__=='lock'; Lock/__qualname__=='lock'; Lock/__qualname__.__len__()==4; Lock/__module__=='_thread'; Lock/__module__.__len__()==7; local/__name__=='_local'; TIMEOUT_MAX; threading.__all__.__len__()==28; current_thread/__name__/__qualname__/__module__; main_thread/__name__/__qualname__/__module__; active_count/__name__/__qualname__/__module__; enumerate/__name__/__qualname__/__module__; settrace/__name__/__qualname__; setprofile/__name__/__qualname__; stack_size/__name__/__qualname__; RLock/__name__/__qualname__/__module__; Thread/__class__.__name__=='type'; Event/__class__.__name__=='type'; Semaphore/__class__.__name__=='type'; BoundedSemaphore/__class__.__name__=='type'; Condition/__class__.__name__=='type'; Barrier/__class__.__name__=='type'; Timer/__class__.__name__=='type'; main_thread/__class__.__name__=='function'; current_thread/__class__.__name__=='function'; Thread/__class__.__qualname__=='type'; Event/__class__.__qualname__=='type'; Semaphore/__class__.__qualname__=='type'; BoundedSemaphore/__class__.__qualname__=='type'; Condition/__class__.__qualname__=='type'; Barrier/__class__.__qualname__=='type'; Timer/__class__.__qualname__=='type'; Lock/__class__.__qualname__=='type'; RLock/__class__.__qualname__=='type'; main_thread/__class__.__qualname__=='function'; current_thread/__class__.__qualname__=='function'."
    - "This spec covers: threading.TIMEOUT_MAX/__class__.__name__=='float'; threading.active_count/__class__.__name__=='function'; threading.enumerate/__class__.__name__=='function'; threading.settrace/__class__.__name__=='function'; threading.setprofile/__class__.__name__=='function'; threading.stack_size/__class__.__name__=='builtin_function_or_method'; threading.TIMEOUT_MAX/__class__.__qualname__=='float'; threading.active_count/__class__.__qualname__=='function'; threading.Thread.daemon/__class__.__name__=='property'."
    - "Key findings: threading.TIMEOUT_MAX is a float constant (value ~9.22e9 seconds on 64-bit systems, derived from the maximum value representable in a system timespec); its __class__.__name__ == 'float' and __class__.__qualname__ == 'float' (both 5 chars — the 'float' built-in type is a top-level type with __qualname__ == __name__). threading.active_count, enumerate, settrace, and setprofile are all pure-Python functions defined with def statements in Lib/threading.py; their __class__.__name__ == __class__.__qualname__ == 'function'. threading.stack_size is imported from the _thread C extension module (Modules/_threadmodule.c); it is a C-extension built-in function, so __class__.__name__ == 'builtin_function_or_method' (26 chars). threading.Thread.daemon is a Python property descriptor (defined using @property in Lib/threading.py); Thread.daemon.__class__.__name__ == 'property'. No prior spec recorded __class__.__name__ for TIMEOUT_MAX, active_count, enumerate, settrace, setprofile, stack_size, or Thread.daemon. All nine invariants are new to extra50."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.TIMEOUT_MAX constant type — extra50 namespace
#
# threading.TIMEOUT_MAX is a float constant equal to the maximum timeout
# value accepted by threading synchronization primitives. On 64-bit systems
# this is approximately 9223372036.0 seconds (derived from the system
# timespec maximum). Its __class__.__name__ == 'float' and
# __class__.__qualname__ == 'float'. No prior spec recorded __class__.__name__
# or __class__.__qualname__ for TIMEOUT_MAX. Both are new to extra50.
# ---------------------------------------------------------------------------

invariant threading_extra50.TIMEOUT_MAX_class_name:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — float constant equal to the maximum timeout in seconds accepted by threading synchronization primitives; value ~9.22e9 on 64-bit systems; __class__.__name__ == 'float' (5 chars)"
  category: identity
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra50.TIMEOUT_MAX_class_qualname:
  description: "threading.TIMEOUT_MAX.__class__.__qualname__ == 'float' — float constant; the 'float' built-in type is a top-level built-in with __qualname__ == __name__ == 'float'; __class__.__qualname__ == 'float' (5 chars)"
  category: identity
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__qualname__.__eq__
  args: ["float"]
  expected: true

# ---------------------------------------------------------------------------
# threading pure-Python module-level functions __class__.__name__ — extra50
#
# threading.active_count, enumerate, settrace, and setprofile are pure-Python
# functions defined with def statements in Lib/threading.py. Their __class__
# is the built-in function type, so __class__.__name__ == 'function' (8 chars).
# Prior specs recorded __name__/__qualname__/__module__ for all four, but no
# prior spec recorded __class__.__name__ for any of them. All four new to extra50.
# ---------------------------------------------------------------------------

table threading_extra50.pure_python_functions_class_names:
  description: "threading pure-Python module-level functions __class__.__name__ == 'function' — active_count/enumerate/settrace/setprofile are def-statement functions in Lib/threading.py; __class__ is the built-in function type; __class__.__name__ == 'function' (8 chars)"
  kind: python_call_eq
  category: identity
  id_prefix: thrdconst50

  columns: [id, function, args, expected, description]
  rows:
    - [active_count_class_name,
       active_count.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.active_count.__class__.__name__ == 'function' — pure-Python function in Lib/threading.py; returns the number of Thread objects currently alive; __class__ is the built-in function type; __class__.__name__ == 'function' (8 chars)"]
    - [enumerate_class_name,
       enumerate.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.enumerate.__class__.__name__ == 'function' — pure-Python function in Lib/threading.py; returns a list of all Thread objects currently alive including daemon threads and the main thread; __class__ is the built-in function type; __class__.__name__ == 'function' (8 chars)"]
    - [settrace_class_name,
       settrace.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.settrace.__class__.__name__ == 'function' — pure-Python function in Lib/threading.py; sets a trace function to be called for every new thread; delegates to sys.settrace for each thread; __class__ is the built-in function type; __class__.__name__ == 'function' (8 chars)"]
    - [setprofile_class_name,
       setprofile.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.setprofile.__class__.__name__ == 'function' — pure-Python function in Lib/threading.py; sets a profile function to be called for every new thread; delegates to sys.setprofile for each thread; __class__ is the built-in function type; __class__.__name__ == 'function' (8 chars)"]

# ---------------------------------------------------------------------------
# threading.active_count __class__.__qualname__ — extra50 namespace
#
# threading.active_count is a pure-Python function. The built-in 'function'
# type is a top-level built-in, so __class__.__qualname__ == __class__.__name__
# == 'function' (8 chars). Prior spec extra49 did not record __class__.__qualname__
# for active_count (it recorded main_thread and current_thread only). New to extra50.
# ---------------------------------------------------------------------------

invariant threading_extra50.active_count_class_qualname:
  description: "threading.active_count.__class__.__qualname__ == 'function' — pure-Python function in Lib/threading.py; __class__ is the built-in function type; the function type is a top-level built-in with __qualname__ == __name__ == 'function' (8 chars)"
  category: identity
  kind: python_call_eq
  function: active_count.__class__.__qualname__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# threading.stack_size __class__.__name__ — extra50 namespace
#
# threading.stack_size is imported from the _thread C extension module
# (Modules/_threadmodule.c). It is a C-extension built-in function, not a
# pure-Python function, so its __class__.__name__ is
# 'builtin_function_or_method' (26 chars). This is distinct from the
# pure-Python functions above which have __class__.__name__ == 'function'.
# Prior spec recorded stack_size/__name__/__qualname__ but not __class__.__name__.
# New to extra50.
# ---------------------------------------------------------------------------

invariant threading_extra50.stack_size_class_name:
  description: "threading.stack_size.__class__.__name__ == 'builtin_function_or_method' — C-extension function imported from _thread module (Modules/_threadmodule.c); __class__.__name__ == 'builtin_function_or_method' (26 chars); contrasts with pure-Python threading functions whose __class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: stack_size.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# threading.Thread.daemon property type — extra50 namespace
#
# threading.Thread.daemon is a Python property descriptor defined using the
# @property decorator in Lib/threading.py. When accessed on the class (not
# an instance), it returns the property object itself. The 'property' type
# is a built-in type, so Thread.daemon.__class__.__name__ == 'property' (8 chars).
# No prior spec recorded __class__.__name__ for threading.Thread.daemon.
# New to extra50.
# ---------------------------------------------------------------------------

invariant threading_extra50.Thread_daemon_class_name:
  description: "threading.Thread.daemon.__class__.__name__ == 'property' — Thread.daemon is a @property descriptor in Lib/threading.py; when accessed on the class (not an instance) it returns the property object; the built-in 'property' type has __name__ == 'property' (8 chars)"
  category: identity
  kind: python_call_eq
  function: Thread.daemon.__class__.__name__.__eq__
  args: ["property"]
  expected: true
