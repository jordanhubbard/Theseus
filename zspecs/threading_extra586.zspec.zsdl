spec: threading_extra586
version: ">=3.9"
backend: python_module(threading)
docs: "Identity invariants for threading.Lock, threading.Condition, and threading.Semaphore"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.Lock is a factory function (allocate_lock alias), not a class; covered via __class__.__name__ and __name__"
    - "Covers Condition and Semaphore method qualname identity"
  created_at: "2026-04-12T00:00:00Z"

table th586lk:
  description: "threading.Lock factory function identity"
  columns: [id, function, args, expected]
  rows:
    - [th586lk01, threading.Lock.__class__.__name__.__eq__, ["function"], true]
    - [th586lk02, threading.Lock.__name__.__eq__, ["allocate_lock"], true]

table th586cv:
  description: "threading.Condition class and method qualname/module identity"
  columns: [id, function, args, expected]
  rows:
    - [th586cv01, threading.Condition.__qualname__.__eq__, ["Condition"], true]
    - [th586cv02, threading.Condition.__module__.__eq__, ["threading"], true]
    - [th586cv03, threading.Condition.acquire.__qualname__.__eq__, ["Condition.acquire"], true]
    - [th586cv04, threading.Condition.release.__qualname__.__eq__, ["Condition.release"], true]
    - [th586cv05, threading.Condition.wait.__qualname__.__eq__, ["Condition.wait"], true]
    - [th586cv06, threading.Condition.notify.__qualname__.__eq__, ["Condition.notify"], true]
    - [th586cv07, threading.Condition.notify_all.__qualname__.__eq__, ["Condition.notify_all"], true]

table th586ev:
  description: "threading.Semaphore class and method qualname identity"
  columns: [id, function, args, expected]
  rows:
    - [th586ev01, threading.Semaphore.__qualname__.__eq__, ["Semaphore"], true]
    - [th586ev02, threading.Semaphore.acquire.__qualname__.__eq__, ["Semaphore.acquire"], true]
    - [th586ev03, threading.Semaphore.release.__qualname__.__eq__, ["Semaphore.release"], true]
