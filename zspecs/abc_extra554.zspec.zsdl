spec: abc_extra554
backend: python_module(abc)
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module: Abstract Base Classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers attribute type identity and qualname checks for abc.ABC, abc.ABCMeta, and abc.abstractmethod"
    - "abc.ABC.__abstractmethods__ is a frozenset on the class itself (empty frozenset for ABC base)"
    - "abc.abstractmethod.__isabstractmethod__ is True by definition of the decorator"
    - "__subclasscheck__ and __instancecheck__ are methods on ABCMeta accessed via abc.ABC's metaclass"
  created_at: "2026-04-12T00:00:00Z"

invariant abc_extra554.abc_abstractmethods_class_name:
  kind: python_call_eq
  function: abc.ABC.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

invariant abc_extra554.abcmeta_abstractmethods_class_name:
  kind: python_call_eq
  function: abc.ABCMeta.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

invariant abc_extra554.abstractmethod_isabstractmethod:
  kind: python_call_eq
  function: abc.abstractmethod.__isabstractmethod__.__eq__
  args: [true]
  expected: true

invariant abc_extra554.abc_subclasscheck_name:
  kind: python_call_eq
  function: abc.ABC.__subclasscheck__.__name__.__eq__
  args: ["__subclasscheck__"]
  expected: true

invariant abc_extra554.abc_instancecheck_name:
  kind: python_call_eq
  function: abc.ABC.__instancecheck__.__name__.__eq__
  args: ["__instancecheck__"]
  expected: true

invariant abc_extra554.abcmeta_register_qualname:
  kind: python_call_eq
  function: abc.ABCMeta.register.__qualname__.__eq__
  args: ["ABCMeta.register"]
  expected: true

invariant abc_extra554.abcmeta_instancecheck_qualname:
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__qualname__.__eq__
  args: ["ABCMeta.__instancecheck__"]
  expected: true

invariant abc_extra554.abcmeta_subclasscheck_qualname:
  kind: python_call_eq
  function: abc.ABCMeta.__subclasscheck__.__qualname__.__eq__
  args: ["ABCMeta.__subclasscheck__"]
  expected: true

table abc_extra554.attribute_identity_checks:
  columns: [id, function, args, expected]
  rows:
    - ["abc_abstractmethods_class", abc.ABC.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true]
    - ["abcmeta_abstractmethods_class", abc.ABCMeta.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true]
    - ["abstractmethod_isabstractmethod", abc.abstractmethod.__isabstractmethod__.__eq__, [true], true]
    - ["abc_subclasscheck_name", abc.ABC.__subclasscheck__.__name__.__eq__, ["__subclasscheck__"], true]
    - ["abc_instancecheck_name", abc.ABC.__instancecheck__.__name__.__eq__, ["__instancecheck__"], true]
    - ["abcmeta_register_qualname", abc.ABCMeta.register.__qualname__.__eq__, ["ABCMeta.register"], true]
    - ["abcmeta_instancecheck_qualname", abc.ABCMeta.__instancecheck__.__qualname__.__eq__, ["ABCMeta.__instancecheck__"], true]
    - ["abcmeta_subclasscheck_qualname", abc.ABCMeta.__subclasscheck__.__qualname__.__eq__, ["ABCMeta.__subclasscheck__"], true]
