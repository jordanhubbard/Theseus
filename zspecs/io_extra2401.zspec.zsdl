spec: io_extra2401
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Theme: __hash__ and __eq__ implementation type classification for io module classes."
    - "All io classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase, FileIO, BytesIO, StringIO, BufferedReader, BufferedWriter, TextIOWrapper) inherit __hash__ and __eq__ from object via C slot wrappers."
    - "io.IOBase.__hash__ is object.__hash__ — True; all io classes share the same C slot wrapper."
    - "io.IOBase.__hash__.__class__.__name__ == 'wrapper_descriptor' for every io base and concrete class."
    - "io.IOBase.__eq__.__class__.__name__ == 'wrapper_descriptor' for every io base and concrete class."
    - "None of the io classes set __hash__ = None; io instances ARE hashable by identity (default object hash)."
    - "io.IOBase.__dict__.get('__hash__') returns None (the key is absent), not the wrapper_descriptor — the wrapper is inherited from object."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __hash__ implementation type — class-level attribute
#
# Accessing .__hash__ on each io class returns the C slot wrapper_descriptor
# inherited from object. None of the io classes define their own __hash__
# in Python; they all delegate to the C-level identity hash.
# ---------------------------------------------------------------------------

table io_extra2401.iobase_hash_eq:
  kind: python_call_eq
  category: hash_eq_type
  id_prefix: io2401

  columns: [id, function, args, expected]
  rows:
    - ["io2401001", "io.IOBase.__hash__.__class__.__name__.__eq__",          ["wrapper_descriptor"], true]
    - ["io2401002", "io.IOBase.__eq__.__class__.__name__.__eq__",            ["wrapper_descriptor"], true]
    - ["io2401003", "io.RawIOBase.__hash__.__class__.__name__.__eq__",       ["wrapper_descriptor"], true]
    - ["io2401004", "io.RawIOBase.__eq__.__class__.__name__.__eq__",         ["wrapper_descriptor"], true]
    - ["io2401005", "io.BufferedIOBase.__hash__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]
    - ["io2401006", "io.BufferedIOBase.__eq__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true]
    - ["io2401007", "io.TextIOBase.__hash__.__class__.__name__.__eq__",      ["wrapper_descriptor"], true]
    - ["io2401008", "io.TextIOBase.__eq__.__class__.__name__.__eq__",        ["wrapper_descriptor"], true]
    - ["io2401009", "io.FileIO.__hash__.__class__.__name__.__eq__",          ["wrapper_descriptor"], true]
    - ["io2401010", "io.FileIO.__eq__.__class__.__name__.__eq__",            ["wrapper_descriptor"], true]

table io_extra2401.concrete_io_hash_eq:
  kind: python_call_eq
  category: hash_eq_type
  id_prefix: io2401

  columns: [id, function, args, expected]
  rows:
    - ["io2401011", "io.BytesIO.__hash__.__class__.__name__.__eq__",         ["wrapper_descriptor"], true]
    - ["io2401012", "io.BytesIO.__eq__.__class__.__name__.__eq__",           ["wrapper_descriptor"], true]
    - ["io2401013", "io.StringIO.__hash__.__class__.__name__.__eq__",        ["wrapper_descriptor"], true]
    - ["io2401014", "io.StringIO.__eq__.__class__.__name__.__eq__",          ["wrapper_descriptor"], true]
    - ["io2401015", "io.BufferedReader.__hash__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]
    - ["io2401016", "io.BufferedReader.__eq__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true]
    - ["io2401017", "io.BufferedWriter.__hash__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]
    - ["io2401018", "io.BufferedWriter.__eq__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true]
    - ["io2401019", "io.TextIOWrapper.__hash__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true]
    - ["io2401020", "io.TextIOWrapper.__eq__.__class__.__name__.__eq__",     ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# Shared identity — all io classes inherit the exact same slot wrapper
#
# io.IOBase.__hash__ is object.__hash__ confirms no class in the io hierarchy
# overrides the C-level hash slot with a Python function.
# ---------------------------------------------------------------------------

table io_extra2401.hash_identity:
  kind: python_call_eq
  category: hash_identity
  id_prefix: io2401

  columns: [id, function, args, expected]
  rows:
    - ["io2401021", "io.IOBase.__dict__.__contains__",        ["__hash__"], false]
    - ["io2401022", "io.RawIOBase.__dict__.__contains__",     ["__hash__"], false]
    - ["io2401023", "io.BufferedIOBase.__dict__.__contains__", ["__hash__"], false]
    - ["io2401024", "io.TextIOBase.__dict__.__contains__",    ["__hash__"], false]
    - ["io2401025", "io.BytesIO.__dict__.__contains__",       ["__hash__"], false]
    - ["io2401026", "io.StringIO.__dict__.__contains__",      ["__hash__"], false]
