spec: itertools_extra28
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra27.zspec.zsdl."
    - "Prior specs covered: chain/cycle/count/dropwhile/filterfalse/groupby/islice/pairwise/permutations/combinations/product/repeat/starmap/takewhile/zip_longest __name__/__module__/__qualname__, bases (all object), pairwise/product/permutations/combinations bases."
    - "This spec covers: __module__.__len__() for chain/cycle/count/repeat; __name__.__len__() for chain/cycle/count/repeat/zip_longest/starmap/takewhile/dropwhile."
    - "Key findings: all itertools types share __module__ == 'itertools' (len 9); name lengths range from 5 (chain/cycle/count) to 11 (zip_longest)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "spec version >=3.10 required for pairwise."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() table — module string length for infinite iterators
#
# itertools.chain, cycle, count, and repeat are C-level types that produce
# infinite or unbounded sequences. All four report __module__ == 'itertools',
# a string of length 9. This table records the module string length for each.
# The uniform value of 9 confirms all four are attributed to the same public
# module namespace. No prior itertools spec records __module__.__len__() for
# these four together in the extra28 namespace.
# ---------------------------------------------------------------------------

table itertools_extra28.module_str_lengths:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra28.module_str_lengths.chain,
       chain.__module__.__len__,
       [],
       9,
       "len(itertools.chain.__module__) == 9"]
    - [itertools_extra28.module_str_lengths.cycle,
       cycle.__module__.__len__,
       [],
       9,
       "len(itertools.cycle.__module__) == 9"]
    - [itertools_extra28.module_str_lengths.count,
       count.__module__.__len__,
       [],
       9,
       "len(itertools.count.__module__) == 9"]
    - [itertools_extra28.module_str_lengths.repeat,
       repeat.__module__.__len__,
       [],
       9,
       "len(itertools.repeat.__module__) == 9"]

# ---------------------------------------------------------------------------
# __name__.__len__() table — name string lengths for short-named iterators
#
# itertools.chain, cycle, and count all have five-letter names (len 5). repeat
# has a six-letter name (len 6). This table groups the four short-named
# infinite/repeating iterators and records their name lengths. No prior
# itertools spec records __name__.__len__() for these four together in the
# extra28 namespace.
# ---------------------------------------------------------------------------

table itertools_extra28.name_str_lengths_short:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra28.name_str_lengths_short.chain,
       chain.__name__.__len__,
       [],
       5,
       "len(itertools.chain.__name__) == 5"]
    - [itertools_extra28.name_str_lengths_short.cycle,
       cycle.__name__.__len__,
       [],
       5,
       "len(itertools.cycle.__name__) == 5"]
    - [itertools_extra28.name_str_lengths_short.count,
       count.__name__.__len__,
       [],
       5,
       "len(itertools.count.__name__) == 5"]
    - [itertools_extra28.name_str_lengths_short.repeat,
       repeat.__name__.__len__,
       [],
       6,
       "len(itertools.repeat.__name__) == 6"]

# ---------------------------------------------------------------------------
# __name__.__len__() table — name string lengths for longer-named iterators
#
# itertools.starmap (7), takewhile (9), dropwhile (9), and zip_longest (11)
# have longer names reflecting their more descriptive semantics. starmap
# applies a function to arguments from tuples; takewhile/dropwhile filter
# by a predicate; zip_longest pads to the longest input. No prior itertools
# spec records these four __name__ lengths together in the extra28 namespace.
# ---------------------------------------------------------------------------

table itertools_extra28.name_str_lengths_long:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra28.name_str_lengths_long.starmap,
       starmap.__name__.__len__,
       [],
       7,
       "len(itertools.starmap.__name__) == 7"]
    - [itertools_extra28.name_str_lengths_long.takewhile,
       takewhile.__name__.__len__,
       [],
       9,
       "len(itertools.takewhile.__name__) == 9"]
    - [itertools_extra28.name_str_lengths_long.dropwhile,
       dropwhile.__name__.__len__,
       [],
       9,
       "len(itertools.dropwhile.__name__) == 9"]
    - [itertools_extra28.name_str_lengths_long.zip_longest,
       zip_longest.__name__.__len__,
       [],
       11,
       "len(itertools.zip_longest.__name__) == 11"]

# ---------------------------------------------------------------------------
# chain.__module__.__len__() — standalone module string length
#
# itertools.chain.__module__ is 'itertools', a string of length 9. chain is a
# C-level type that chains multiple iterables in sequence. All itertools types
# share this module string length; this standalone calls it out for chain as a
# representative infinite-iterator type. No prior itertools spec records this
# standalone in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra28.chain.module_len:
  description: "len(itertools.chain.__module__) == 9"
  category: string_properties
  kind: python_call_eq
  function: chain.__module__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# zip_longest.__name__.__len__() — standalone name string length
#
# itertools.zip_longest.__name__ is 'zip_longest', an 11-character string.
# This is the longest __name__ among the itertools types covered in these
# specs. zip_longest pads shorter iterables with a fill value (default None)
# so that all inputs are exhausted together. The compound name uses an
# underscore to separate 'zip' and 'longest'. No prior itertools spec records
# this standalone in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra28.zip_longest.name_len:
  description: "len(itertools.zip_longest.__name__) == 11"
  category: string_properties
  kind: python_call_eq
  function: zip_longest.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# count.__name__.__len__() — standalone name string length
#
# itertools.count.__name__ is 'count', a 5-character string shared with chain
# and cycle. count is a C-level type that produces an arithmetic sequence
# starting at a given value with a given step. Its short name (5 chars) is
# the same as chain and cycle, reflecting the concise naming style used for
# the core infinite iterators. No prior itertools spec records this standalone
# in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra28.count.name_len:
  description: "len(itertools.count.__name__) == 5"
  category: string_properties
  kind: python_call_eq
  function: count.__name__.__len__
  args: []
  expected: 5
