spec: itertools_extra1636
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __subclasshook__/__instancecheck__/__subclasscheck__"
    - "All itertools types are C extension types implemented in Modules/itertoolsmodule.c"
    - "C extension types do not define __subclasshook__, __instancecheck__, or __subclasscheck__ in their type __dict__"
    - "ABCMeta.__instancecheck__ and __subclasscheck__ are defined on the ABCMeta metaclass, not on itertools C types"
    - "itertools C types use the standard type.__instancecheck__ (inherited from type) — no virtual subclassing hook"
    - "isinstance(itertools.chain(), collections.abc.Iterator) is True because collections.abc.Iterator.__subclasshook__ checks for __next__ and __iter__, which all itertools types implement"
    - "isinstance(itertools.chain(), collections.abc.Iterable) is True via the same __subclasshook__ mechanism checking for __iter__"
    - "isinstance(list(range(3)), collections.abc.Iterable) is True — list defines __iter__ so ABCMeta.__instancecheck__ returns True via __subclasshook__"
    - "itertools C types have no __subclasshook__ in their own __dict__; virtual subclassing is entirely on the ABC side"
    - "None of the itertools C types set up ABCMeta as their metaclass; their metaclass is the plain C-level 'type'"
    - "itertools.chain uniquely has from_iterable as a classmethod descriptor; still no virtual subclassing hook"
  created_at: "2026-04-12"
error_model: python_exceptions

table itertools_extra1636.c_types_no_virtual_subclassing:
  description: "itertools C extension types do not define __subclasshook__, __instancecheck__, or __subclasscheck__ in their type __dict__; they use the standard type metaclass with no virtual subclassing protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1636nv

  columns: [id, function, args, expected]
  rows:
    - ["it1636nv001", "itertools.chain.__dict__.__contains__",                         ["__subclasshook__"],   false]
    - ["it1636nv002", "itertools.chain.__dict__.__contains__",                         ["__instancecheck__"],  false]
    - ["it1636nv003", "itertools.chain.__dict__.__contains__",                         ["__subclasscheck__"],  false]
    - ["it1636nv004", "itertools.islice.__dict__.__contains__",                        ["__subclasshook__"],   false]
    - ["it1636nv005", "itertools.islice.__dict__.__contains__",                        ["__instancecheck__"],  false]
    - ["it1636nv006", "itertools.islice.__dict__.__contains__",                        ["__subclasscheck__"],  false]
    - ["it1636nv007", "itertools.product.__dict__.__contains__",                       ["__subclasshook__"],   false]
    - ["it1636nv008", "itertools.product.__dict__.__contains__",                       ["__instancecheck__"],  false]
    - ["it1636nv009", "itertools.product.__dict__.__contains__",                       ["__subclasscheck__"],  false]
    - ["it1636nv010", "itertools.combinations.__dict__.__contains__",                  ["__subclasshook__"],   false]
    - ["it1636nv011", "itertools.permutations.__dict__.__contains__",                  ["__subclasshook__"],   false]
    - ["it1636nv012", "itertools.groupby.__dict__.__contains__",                       ["__subclasshook__"],   false]
    - ["it1636nv013", "itertools.cycle.__dict__.__contains__",                         ["__subclasshook__"],   false]
    - ["it1636nv014", "itertools.repeat.__dict__.__contains__",                        ["__subclasshook__"],   false]
    - ["it1636nv015", "itertools.count.__dict__.__contains__",                         ["__subclasshook__"],   false]
    - ["it1636nv016", "itertools.zip_longest.__dict__.__contains__",                   ["__subclasshook__"],   false]
    - ["it1636nv017", "itertools.starmap.__dict__.__contains__",                       ["__subclasshook__"],   false]
    - ["it1636nv018", "itertools.takewhile.__dict__.__contains__",                     ["__subclasshook__"],   false]
    - ["it1636nv019", "itertools.dropwhile.__dict__.__contains__",                     ["__subclasshook__"],   false]
    - ["it1636nv020", "itertools.filterfalse.__dict__.__contains__",                   ["__subclasshook__"],   false]
    - ["it1636nv021", "itertools.accumulate.__dict__.__contains__",                    ["__subclasshook__"],   false]
    - ["it1636nv022", "itertools.combinations_with_replacement.__dict__.__contains__", ["__subclasshook__"],   false]
    - ["it1636nv023", "itertools.compress.__dict__.__contains__",                      ["__subclasshook__"],   false]
    - ["it1636nv024", "itertools.chain.__class__.__name__.__eq__",                     ["type"],               true]
    - ["it1636nv025", "itertools.islice.__class__.__name__.__eq__",                    ["type"],               true]
    - ["it1636nv026", "itertools.product.__class__.__name__.__eq__",                   ["type"],               true]
    - ["it1636nv027", "itertools.combinations.__class__.__name__.__eq__",              ["type"],               true]
    - ["it1636nv028", "itertools.repeat.__class__.__name__.__eq__",                    ["type"],               true]
    - ["it1636nv029", "itertools.chain.__class__.__name__.__eq__",                     ["ABCMeta"],            false]
    - ["it1636nv030", "itertools.islice.__class__.__name__.__eq__",                    ["ABCMeta"],            false]

table itertools_extra1636.itertools_abc_isinstance:
  description: "itertools objects satisfy collections.abc ABC isinstance checks via ABCMeta.__instancecheck__ + Iterator/Iterable __subclasshook__; the hook is on the ABC side, not the itertools side"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1636ai

  columns: [id, function, args, expected]
