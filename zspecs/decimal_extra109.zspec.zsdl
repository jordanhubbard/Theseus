spec: decimal_extra109
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra108.zspec.zsdl."
    - "This spec covers: decimal.Decimal.is_infinite, is_normal, is_subnormal, is_qnan, is_snan, and is_canonical method qualnames."
    - "decimal_extra108 covered: is_nan(14), is_finite(17), is_zero(15), is_signed(17)."
    - "decimal.Decimal.is_infinite.__qualname__ == 'Decimal.is_infinite' (len 19); type 'method_descriptor'."
    - "decimal.Decimal.is_normal.__qualname__ == 'Decimal.is_normal' (len 17); type 'method_descriptor'."
    - "decimal.Decimal.is_subnormal.__qualname__ == 'Decimal.is_subnormal' (len 20); type 'method_descriptor'."
    - "decimal.Decimal.is_qnan.__qualname__ == 'Decimal.is_qnan' (len 15); type 'method_descriptor'."
    - "decimal.Decimal.is_snan.__qualname__ == 'Decimal.is_snan' (len 15); type 'method_descriptor'."
    - "decimal.Decimal.is_canonical.__qualname__ == 'Decimal.is_canonical' (len 20); type 'method_descriptor'."
    - "is_qnan and is_snan share qualname length 15; is_subnormal and is_canonical share length 20."
    - "is_subnormal(20) and is_canonical(20) are the longest among all six is_* methods covered in this spec."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.is_infinite and decimal.Decimal.is_normal qualnames
# Both are 'method_descriptor' (C extension tp_methods entries).
# is_infinite: 'Decimal.is_infinite' (19 chars); returns True for +/-Infinity.
# is_normal: 'Decimal.is_normal' (17 chars); returns True for finite non-zero
#   numbers not in subnormal range; same length as is_finite(17) from spec 108.
# ---------------------------------------------------------------------------

table decimal_extra109.Decimal_is_infinite_is_normal_qualnames:
  description: "decimal.Decimal.is_infinite qualname='Decimal.is_infinite'(19), is_normal qualname='Decimal.is_normal'(17); both type 'method_descriptor'; is_normal shares len 17 with is_finite and is_signed from spec 108"
  kind: python_call_eq
  category: qualnames
  id_prefix: decisnf109a

  columns: [id, function, args, expected, description]
  rows:
    - [is_inf_type,      "Decimal.is_infinite.__class__.__name__.__eq__",    ["method_descriptor"],    true,  "type(decimal.Decimal.is_infinite).__name__ == 'method_descriptor' (C extension tp_methods entry for is_infinite)"]
    - [is_inf_qn_eq,     "Decimal.is_infinite.__qualname__.__eq__",          ["Decimal.is_infinite"],  true,  "decimal.Decimal.is_infinite.__qualname__ == 'Decimal.is_infinite' (returns True if value is positive or negative Infinity)"]
    - [is_inf_qn_len,    "Decimal.is_infinite.__qualname__.__len__",         [],                       19,    "decimal.Decimal.is_infinite.__qualname__.__len__() == 19 ('Decimal.is_infinite' has 19 chars; 'Decimal.'(8)+'is_infinite'(11)==19)"]
    - [is_nrm_type,      "Decimal.is_normal.__class__.__name__.__eq__",      ["method_descriptor"],    true,  "type(decimal.Decimal.is_normal).__name__ == 'method_descriptor' (C extension tp_methods entry for is_normal)"]
    - [is_nrm_qn_eq,     "Decimal.is_normal.__qualname__.__eq__",            ["Decimal.is_normal"],    true,  "decimal.Decimal.is_normal.__qualname__ == 'Decimal.is_normal' (returns True for finite non-zero numbers outside the subnormal range)"]
    - [is_nrm_qn_len,    "Decimal.is_normal.__qualname__.__len__",           [],                       17,    "decimal.Decimal.is_normal.__qualname__.__len__() == 17 ('Decimal.is_normal' has 17 chars; same length as is_finite and is_signed)"]
    - [is_inf_gt_nrm,    "Decimal.is_infinite.__qualname__.__len__.__gt__",  [17],                     true,  "len('Decimal.is_infinite') > len('Decimal.is_normal') (19 > 17; is_infinite is 2 chars longer than is_normal)"]
    - [is_nrm_ne_is_inf, "Decimal.is_normal.__qualname__.__eq__",            ["Decimal.is_infinite"],  false, "decimal.Decimal.is_normal.__qualname__ != 'Decimal.is_infinite' (distinct qualname strings; is_normal tests normality, is_infinite tests for Infinity)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.is_subnormal and decimal.Decimal.is_canonical qualnames
# Both are 'method_descriptor' (C extension tp_methods entries).
# is_subnormal: 'Decimal.is_subnormal' (20 chars); subnormal numbers have
#   fewer significant digits than allowed by the current precision.
# is_canonical: 'Decimal.is_canonical' (20 chars); always True in the C
#   implementation (all Decimal values are canonical in _decimal).
# Both share the same qualname length of 20 chars; this is the longest
# qualname length among all six is_* methods covered in this spec.
# ---------------------------------------------------------------------------

table decimal_extra109.Decimal_is_subnormal_is_canonical_qualnames:
  description: "decimal.Decimal.is_subnormal qualname='Decimal.is_subnormal'(20), is_canonical qualname='Decimal.is_canonical'(20); both type 'method_descriptor'; share qualname length 20 (longest in this spec)"
  kind: python_call_eq
  category: qualnames
  id_prefix: decisnf109b

  columns: [id, function, args, expected, description]
  rows:
    - [is_sub_type,      "Decimal.is_subnormal.__class__.__name__.__eq__",   ["method_descriptor"],     true,  "type(decimal.Decimal.is_subnormal).__name__ == 'method_descriptor' (C extension tp_methods entry for is_subnormal)"]
    - [is_sub_qn_eq,     "Decimal.is_subnormal.__qualname__.__eq__",         ["Decimal.is_subnormal"],  true,  "decimal.Decimal.is_subnormal.__qualname__ == 'Decimal.is_subnormal' (returns True for subnormal numbers with fewer significant digits)"]
    - [is_sub_qn_len,    "Decimal.is_subnormal.__qualname__.__len__",        [],                        20,    "decimal.Decimal.is_subnormal.__qualname__.__len__() == 20 ('Decimal.is_subnormal' has 20 chars; 'Decimal.'(8)+'is_subnormal'(12)==20)"]
    - [is_can_type,      "Decimal.is_canonical.__class__.__name__.__eq__",   ["method_descriptor"],     true,  "type(decimal.Decimal.is_canonical).__name__ == 'method_descriptor' (C extension tp_methods entry for is_canonical)"]
    - [is_can_qn_eq,     "Decimal.is_canonical.__qualname__.__eq__",         ["Decimal.is_canonical"],  true,  "decimal.Decimal.is_canonical.__qualname__ == 'Decimal.is_canonical' (always True in the C implementation; all _decimal values are canonical)"]
    - [is_can_qn_len,    "Decimal.is_canonical.__qualname__.__len__",        [],                        20,    "decimal.Decimal.is_canonical.__qualname__.__len__() == 20 ('Decimal.is_canonical' has 20 chars; same length as is_subnormal)"]
    - [sub_eq_can_len,   "Decimal.is_subnormal.__qualname__.__len__.__eq__", [20],                      true,  "len('Decimal.is_subnormal') == len('Decimal.is_canonical') == 20 (both share the same qualname length of 20 chars)"]
    - [sub_ne_can,       "Decimal.is_subnormal.__qualname__.__eq__",         ["Decimal.is_canonical"],  false, "decimal.Decimal.is_subnormal.__qualname__ != 'Decimal.is_canonical' (distinct qualname strings despite same length; subnormal tests range, canonical tests form)"]
    - [sub_gt_inf,       "Decimal.is_subnormal.__qualname__.__len__.__gt__", [19],                      true,  "len('Decimal.is_subnormal') > len('Decimal.is_infinite') (20 > 19; is_subnormal is one char longer than is_infinite)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.is_qnan and decimal.Decimal.is_snan qualnames
# Both are 'method_descriptor' (C extension tp_methods entries).
# is_qnan: 'Decimal.is_qnan' (15 chars); returns True for quiet NaN.
# is_snan: 'Decimal.is_snan' (15 chars); returns True for signaling NaN.
# Both share qualname length 15; same as is_zero(15) from spec 108 and
# is_qnan/is_snan from spec 108's __new__ qualname.
# qNaN vs sNaN: quiet NaN propagates silently; signaling NaN raises exception.
# ---------------------------------------------------------------------------

table decimal_extra109.Decimal_is_qnan_is_snan_qualnames:
  description: "decimal.Decimal.is_qnan qualname='Decimal.is_qnan'(15), is_snan qualname='Decimal.is_snan'(15); both type 'method_descriptor'; share qualname length 15 (same as is_zero from spec 108)"
  kind: python_call_eq
  category: qualnames
  id_prefix: decisnf109c

  columns: [id, function, args, expected, description]
  rows:
    - [is_qnan_type,     "Decimal.is_qnan.__class__.__name__.__eq__",   ["method_descriptor"],  true,  "type(decimal.Decimal.is_qnan).__name__ == 'method_descriptor' (C extension tp_methods entry for is_qnan)"]
    - [is_qnan_qn_eq,    "Decimal.is_qnan.__qualname__.__eq__",         ["Decimal.is_qnan"],    true,  "decimal.Decimal.is_qnan.__qualname__ == 'Decimal.is_qnan' (returns True for quiet NaN; quiet NaN propagates silently through arithmetic)"]
    - [is_qnan_qn_len,   "Decimal.is_qnan.__qualname__.__len__",        [],                     15,    "decimal.Decimal.is_qnan.__qualname__.__len__() == 15 ('Decimal.is_qnan' has 15 chars; 'Decimal.'(8)+'is_qnan'(7)==15)"]
    - [is_snan_type,     "Decimal.is_snan.__class__.__name__.__eq__",   ["method_descriptor"],  true,  "type(decimal.Decimal.is_snan).__name__ == 'method_descriptor' (C extension tp_methods entry for is_snan)"]
    - [is_snan_qn_eq,    "Decimal.is_snan.__qualname__.__eq__",         ["Decimal.is_snan"],    true,  "decimal.Decimal.is_snan.__qualname__ == 'Decimal.is_snan' (returns True for signaling NaN; raises exception when used in arithmetic)"]
    - [is_snan_qn_len,   "Decimal.is_snan.__qualname__.__len__",        [],                     15,    "decimal.Decimal.is_snan.__qualname__.__len__() == 15 ('Decimal.is_snan' has 15 chars; same length as is_qnan)"]
    - [qnan_eq_snan_len, "Decimal.is_qnan.__qualname__.__len__.__eq__", [15],                   true,  "len('Decimal.is_qnan') == len('Decimal.is_snan') == 15 (qnan and snan share identical qualname length; differ only by 'q' vs 's' prefix)"]
    - [qnan_ne_snan,     "Decimal.is_qnan.__qualname__.__eq__",         ["Decimal.is_snan"],    false, "decimal.Decimal.is_qnan.__qualname__ != 'Decimal.is_snan' (distinct qualnames despite same length; differ by one char: 'q' vs 's')"]
    - [qnan_lt_infinite, "Decimal.is_qnan.__qualname__.__len__.__lt__", [19],                   true,  "len('Decimal.is_qnan') < len('Decimal.is_infinite') (15 < 19; is_qnan is 4 chars shorter than is_infinite)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra109.Decimal.is_infinite_qualname:
  description: "decimal.Decimal.is_infinite.__qualname__ == 'Decimal.is_infinite' (length 19; type is 'method_descriptor'; is_infinite returns True if the Decimal is positive or negative Infinity, and False for finite values and NaN; 'Decimal.'(8) + 'is_infinite'(11) == 19; this is 2 chars longer than is_normal(17) and 2 chars shorter than is_subnormal(20))"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.is_infinite.__qualname__.__eq__"
  args: ["Decimal.is_infinite"]
  expected: true

invariant decimal_extra109.Decimal.is_subnormal_qualname_len:
  description: "decimal.Decimal.is_subnormal.__qualname__.__len__() == 20 ('Decimal.is_subnormal' has 20 characters; 'Decimal.'(8) + 'is_subnormal'(12) == 20; type is 'method_descriptor'; is_subnormal returns True when the exponent is less than Emin and the adjusted exponent of the coefficient differs from Emin, producing a subnormal number with fewer than precision significant digits; this shares qualname length 20 with is_canonical)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.is_subnormal.__qualname__.__len__"
  args: []
  expected: 20

invariant decimal_extra109.Decimal.is_canonical_qualname:
  description: "decimal.Decimal.is_canonical.__qualname__ == 'Decimal.is_canonical' (length 20; type is 'method_descriptor'; the IEEE 754-2008 standard defines multiple bit patterns for some values (e.g. different encodings for the same NaN or infinity); is_canonical returns True if the Decimal is in its canonical encoding; in the C implementation (_decimal.c) all Decimal values are always canonical so is_canonical always returns True; shares qualname length 20 with is_subnormal)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.is_canonical.__qualname__.__eq__"
  args: ["Decimal.is_canonical"]
  expected: true

invariant decimal_extra109.Decimal.is_qnan_qualname_len:
  description: "decimal.Decimal.is_qnan.__qualname__.__len__() == 15 ('Decimal.is_qnan' has 15 characters; 'Decimal.'(8) + 'is_qnan'(7) == 15; type is 'method_descriptor'; a quiet NaN (qNaN) propagates through arithmetic operations without raising exceptions, unlike a signaling NaN (sNaN) which raises InvalidOperation; is_qnan shares qualname length 15 with is_snan and with is_zero from decimal_extra108)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.is_qnan.__qualname__.__len__"
  args: []
  expected: 15

invariant decimal_extra109.Decimal.is_snan_qualname_eq:
  description: "decimal.Decimal.is_snan.__qualname__ == 'Decimal.is_snan' (length 15; type is 'method_descriptor'; a signaling NaN (sNaN) raises an InvalidOperation exception when used in any arithmetic operation; it differs from a quiet NaN (qNaN) which propagates silently; is_snan.__qualname__ differs from is_qnan.__qualname__ by exactly one character: 's' vs 'q'; both have length 15 and use the same 'method_descriptor' type)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.is_snan.__qualname__.__eq__"
  args: ["Decimal.is_snan"]
  expected: true
