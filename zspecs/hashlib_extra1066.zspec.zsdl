spec: hashlib_extra1066
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks algorithms_available and algorithms_guaranteed class names, HASH object method qualnames, and python_call_raises for invalid algorithm"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1066.algorithms_set_classnames:
  description: "hashlib algorithms_available and algorithms_guaranteed set class name identity"
  kind: python_call_eq
  category: algorithms_classnames
  id_prefix: hl1066ac
  columns: [id, function, args, expected]
  rows:
    - [hl1066ac001, hashlib.algorithms_available.__class__.__name__.__eq__,                ["set"],  true]
    - [hl1066ac002, hashlib.algorithms_guaranteed.__class__.__name__.__eq__,               ["set"],  true]
    - [hl1066ac003, hashlib.algorithms_available.__class__.__name__.__class__.__name__.__eq__, ["str"],  true]
    - [hl1066ac004, hashlib.algorithms_guaranteed.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
    - [hl1066ac005, hashlib.algorithms_available.__class__.__module__.__eq__,              ["builtins"], true]
    - [hl1066ac006, hashlib.algorithms_guaranteed.__class__.__module__.__eq__,             ["builtins"], true]
    - [hl1066ac007, hashlib.algorithms_guaranteed.__class__.__qualname__.__eq__,           ["set"],  true]

table hashlib_extra1066.hash_object_method_qualnames:
  description: "HASH object method __qualname__ identity via md5 instance methods"
  kind: python_call_eq
  category: hash_method_qualnames
  id_prefix: hl1066hm
  columns: [id, function, args, expected]
  rows:
    - [hl1066hm001, hashlib.md5.update.__qualname__.__eq__,    ["HASH.update"],    true]
    - [hl1066hm002, hashlib.md5.digest.__qualname__.__eq__,    ["HASH.digest"],    true]
    - [hl1066hm003, hashlib.md5.hexdigest.__qualname__.__eq__, ["HASH.hexdigest"], true]
    - [hl1066hm004, hashlib.md5.copy.__qualname__.__eq__,      ["HASH.copy"],      true]
    - [hl1066hm005, hashlib.sha256.update.__qualname__.__eq__,    ["HASH.update"],    true]
    - [hl1066hm006, hashlib.sha256.digest.__qualname__.__eq__,    ["HASH.digest"],    true]
    - [hl1066hm007, hashlib.sha256.hexdigest.__qualname__.__eq__, ["HASH.hexdigest"], true]
    - [hl1066hm008, hashlib.sha256.copy.__qualname__.__eq__,      ["HASH.copy"],      true]
    - [hl1066hm009, hashlib.sha512.update.__qualname__.__eq__,    ["HASH.update"],    true]
    - [hl1066hm010, hashlib.sha512.digest.__qualname__.__eq__,    ["HASH.digest"],    true]
    - [hl1066hm011, hashlib.sha512.hexdigest.__qualname__.__eq__, ["HASH.hexdigest"], true]

table hashlib_extra1066.new_raises_invalid_algorithm:
  description: "hashlib.new raises ValueError for unknown algorithm names"
  kind: python_call_raises
  category: invalid_algorithm
  id_prefix: hl1066nr
  columns: [id, function, args, exception]
  rows:
    - [hl1066nr001, hashlib.new, ["notanalgorithm"],  "ValueError"]
    - [hl1066nr002, hashlib.new, [""],                "ValueError"]
    - [hl1066nr003, hashlib.new, ["SHA-256-FAKE"],    "ValueError"]
    - [hl1066nr004, hashlib.new, ["md5sha256combo"],  "ValueError"]
    - [hl1066nr005, hashlib.new, ["ripemd999"],       "ValueError"]
    - [hl1066nr006, hashlib.new, ["xxhash128"],       "ValueError"]
