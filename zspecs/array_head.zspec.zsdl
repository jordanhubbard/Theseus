spec: array_head
version: ">=0.1.0"
backend: node(array-head)

docs: https://www.npmjs.com/package/array-head

provenance:
  derived_from:
    - "array-head README — https://www.npmjs.com/package/array-head"
    - "Test vectors verified with array-head via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "array-head source"
  notes:
    - "array-head is an npm package. Install: npm install array-head"
    - "Returns the first element of an array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the first element."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_head.head:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: ahead

  columns: [id, args, expected]
  rows:
    - [numbers,  [[1, 2, 3]],         1]
    - [strings,  [["a", "b", "c"]],   "a"]
    - [single,   [[42]],              42]
