spec: lodash_meanby
version: ">=4.0.0"
backend: node(lodash.meanby)

docs: https://lodash.com/docs/#meanBy

provenance:
  derived_from:
    - "lodash.meanby README — https://www.npmjs.com/package/lodash.meanby"
    - "Test vectors verified with lodash.meanby@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.meanby exports the _.meanBy function directly as module.exports."
    - "meanBy(array, iteratee) computes the arithmetic mean of iteratee results."
    - "String iteratee plucks the named property."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the mean as a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_meanby.meanby:
  kind: node_module_call_eq
  function: ~
  category: meanby
  id_prefix: lmeanb

  columns: [id, args, expected]
  rows:
    - [by_n,  [[{"n": 1}, {"n": 2}, {"n": 3}], "n"],  2]
    - [by_v,  [[{"v": 10}, {"v": 20}], "v"],           15]
