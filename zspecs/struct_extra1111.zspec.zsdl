spec: struct_extra1111
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.__name__ class attrs, struct.error class attrs (type/qualname/module), struct.Struct method_descriptor class name for pack/unpack/pack_into/unpack_from/iter_unpack, pack_into/unpack_from/iter_unpack module-level qualname and module"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1111.module_name_attrs:
  description: "struct.__name__ identity and class attributes"
  kind: python_call_eq
  category: module_name_attrs
  id_prefix: st1111mn
  columns: [id, function, args, expected]
  rows:
    - [st1111mn001, struct.__name__.__eq__,                              ["struct"],   true]
    - [st1111mn002, struct.__name__.__class__.__name__.__eq__,           ["str"],      true]
    - [st1111mn003, struct.__name__.__class__.__qualname__.__eq__,       ["str"],      true]
    - [st1111mn004, struct.__name__.__class__.__module__.__eq__,         ["builtins"], true]
    - [st1111mn005, struct.__spec__.name.__eq__,                         ["struct"],   true]
    - [st1111mn006, struct.__spec__.name.__class__.__name__.__eq__,      ["str"],      true]
    - [st1111mn007, struct.Struct.__doc__.__class__.__module__.__eq__,   ["builtins"], true]
    - [st1111mn008, struct.Struct.__doc__.__class__.__qualname__.__eq__, ["str"],      true]

table struct_extra1111.error_class_type_attrs:
  description: "struct.error __class__.__name__, __qualname__, __module__ identity"
  kind: python_call_eq
  category: error_class_type_attrs
  id_prefix: st1111et
  columns: [id, function, args, expected]
  rows:
    - [st1111et001, struct.error.__class__.__name__.__eq__,              ["type"],     true]
    - [st1111et002, struct.error.__class__.__qualname__.__eq__,          ["type"],     true]
    - [st1111et003, struct.error.__class__.__module__.__eq__,            ["builtins"], true]
    - [st1111et004, struct.error.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
    - [st1111et005, struct.error.__doc__.__class__.__name__.__eq__,      ["NoneType"], true]
    - [st1111et006, struct.error.__doc__.__class__.__qualname__.__eq__,  ["NoneType"], true]
    - [st1111et007, struct.error.__doc__.__class__.__module__.__eq__,    ["builtins"], true]

table struct_extra1111.struct_method_descriptor_class_names:
  description: "struct.Struct method __class__.__name__ identity and module-level pack_into/unpack_from/iter_unpack qualname and module"
  kind: python_call_eq
  category: struct_method_descriptor_classnames
  id_prefix: st1111md
  columns: [id, function, args, expected]
  rows:
    - [st1111md001, struct.Struct.pack.__class__.__name__.__eq__,              ["method_descriptor"],     true]
    - [st1111md002, struct.Struct.unpack.__class__.__name__.__eq__,            ["method_descriptor"],     true]
    - [st1111md003, struct.Struct.pack_into.__class__.__name__.__eq__,         ["method_descriptor"],     true]
    - [st1111md004, struct.Struct.unpack_from.__class__.__name__.__eq__,       ["method_descriptor"],     true]
    - [st1111md005, struct.Struct.iter_unpack.__class__.__name__.__eq__,       ["method_descriptor"],     true]
    - [st1111md006, struct.pack_into.__qualname__.__eq__,                       ["pack_into"],             true]
    - [st1111md007, struct.unpack_from.__qualname__.__eq__,                     ["unpack_from"],           true]
    - [st1111md008, struct.iter_unpack.__qualname__.__eq__,                     ["iter_unpack"],           true]
    - [st1111md009, struct.pack_into.__module__.__eq__,                         ["_struct"],               true]
    - [st1111md010, struct.unpack_from.__module__.__eq__,                       ["_struct"],               true]
    - [st1111md011, struct.iter_unpack.__module__.__eq__,                       ["_struct"],               true]
    - [st1111md012, struct.pack_into.__class__.__name__.__eq__,                 ["builtin_function_or_method"], true]
    - [st1111md013, struct.unpack_from.__class__.__name__.__eq__,               ["builtin_function_or_method"], true]
    - [st1111md014, struct.iter_unpack.__class__.__name__.__eq__,               ["builtin_function_or_method"], true]
