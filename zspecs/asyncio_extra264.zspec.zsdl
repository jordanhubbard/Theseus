spec: asyncio_extra264
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-protocol.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-protocol.html — asyncio protocol documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/protocols.py"
  notes:
    - "BaseProtocol, Protocol, DatagramProtocol, and SubprocessProtocol are all defined in asyncio.protocols."
    - "BaseProtocol inherits from object (single base)."
    - "Protocol, DatagramProtocol, and SubprocessProtocol each inherit directly from BaseProtocol."
    - "All four classes have __module__ == 'asyncio.protocols'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.BaseProtocol — class identity
#
# asyncio.BaseProtocol is defined in asyncio.protocols and inherits from
# object. It is the common root for all protocol classes.
# ---------------------------------------------------------------------------

invariant asyncio_extra264.base_protocol.name:
  description: "asyncio.BaseProtocol.__name__ == 'BaseProtocol'"
  category: identity
  kind: python_call_eq
  function: BaseProtocol.__name__.__eq__
  args: ["BaseProtocol"]
  expected: true

invariant asyncio_extra264.base_protocol.module:
  description: "asyncio.BaseProtocol.__module__ == 'asyncio.protocols'"
  category: identity
  kind: python_call_eq
  function: BaseProtocol.__module__.__eq__
  args: ["asyncio.protocols"]
  expected: true

invariant asyncio_extra264.base_protocol.base:
  description: "asyncio.BaseProtocol.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: BaseProtocol.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# asyncio.Protocol — class identity
#
# asyncio.Protocol is defined in asyncio.protocols and inherits from
# BaseProtocol.
# ---------------------------------------------------------------------------

invariant asyncio_extra264.protocol.name:
  description: "asyncio.Protocol.__name__ == 'Protocol'"
  category: identity
  kind: python_call_eq
  function: Protocol.__name__.__eq__
  args: ["Protocol"]
  expected: true

invariant asyncio_extra264.protocol.module:
  description: "asyncio.Protocol.__module__ == 'asyncio.protocols'"
  category: identity
  kind: python_call_eq
  function: Protocol.__module__.__eq__
  args: ["asyncio.protocols"]
  expected: true

invariant asyncio_extra264.protocol.base:
  description: "asyncio.Protocol.__bases__[0].__name__ == 'BaseProtocol'"
  category: identity
  kind: python_call_eq
  function: Protocol.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseProtocol"

# ---------------------------------------------------------------------------
# asyncio.DatagramProtocol — class identity
#
# asyncio.DatagramProtocol is defined in asyncio.protocols and inherits from
# BaseProtocol.
# ---------------------------------------------------------------------------

invariant asyncio_extra264.datagram_protocol.name:
  description: "asyncio.DatagramProtocol.__name__ == 'DatagramProtocol'"
  category: identity
  kind: python_call_eq
  function: DatagramProtocol.__name__.__eq__
  args: ["DatagramProtocol"]
  expected: true

invariant asyncio_extra264.datagram_protocol.module:
  description: "asyncio.DatagramProtocol.__module__ == 'asyncio.protocols'"
  category: identity
  kind: python_call_eq
  function: DatagramProtocol.__module__.__eq__
  args: ["asyncio.protocols"]
  expected: true

invariant asyncio_extra264.datagram_protocol.base:
  description: "asyncio.DatagramProtocol.__bases__[0].__name__ == 'BaseProtocol'"
  category: identity
  kind: python_call_eq
  function: DatagramProtocol.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseProtocol"

# ---------------------------------------------------------------------------
# asyncio.SubprocessProtocol — class identity
#
# asyncio.SubprocessProtocol is defined in asyncio.protocols and inherits
# from BaseProtocol.
# ---------------------------------------------------------------------------

invariant asyncio_extra264.subprocess_protocol.name:
  description: "asyncio.SubprocessProtocol.__name__ == 'SubprocessProtocol'"
  category: identity
  kind: python_call_eq
  function: SubprocessProtocol.__name__.__eq__
  args: ["SubprocessProtocol"]
  expected: true

invariant asyncio_extra264.subprocess_protocol.module:
  description: "asyncio.SubprocessProtocol.__module__ == 'asyncio.protocols'"
  category: identity
  kind: python_call_eq
  function: SubprocessProtocol.__module__.__eq__
  args: ["asyncio.protocols"]
  expected: true

invariant asyncio_extra264.subprocess_protocol.base:
  description: "asyncio.SubprocessProtocol.__bases__[0].__name__ == 'BaseProtocol'"
  category: identity
  kind: python_call_eq
  function: SubprocessProtocol.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseProtocol"
