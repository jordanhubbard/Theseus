spec: hashlib_extra916
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __qualname__ attributes of hashlib hash constructors and utility functions"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra916.hash_constructor_qualnames:
  description: "hashlib hash constructor __qualname__ identity"
  kind: python_call_eq
  category: constructor_qualnames
  id_prefix: hl916hc
  columns: [id, function, args, expected]
  rows:
    - [hl916hc001, hashlib.md5.__qualname__.__eq__,    ["md5"],    true]
    - [hl916hc002, hashlib.sha1.__qualname__.__eq__,   ["sha1"],   true]
    - [hl916hc003, hashlib.sha256.__qualname__.__eq__, ["sha256"], true]
    - [hl916hc004, hashlib.sha512.__qualname__.__eq__, ["sha512"], true]

table hashlib_extra916.factory_qualnames:
  description: "hashlib factory and utility function __qualname__ identity"
  kind: python_call_eq
  category: factory_qualnames
  id_prefix: hl916fq
  columns: [id, function, args, expected]
  rows:
    - [hl916fq001, hashlib.new.__qualname__,          ["new"],         true]
    - [hl916fq002, hashlib.new.__qualname__.__eq__,   ["new"],         true]
    - [hl916fq003, hashlib.pbkdf2_hmac.__qualname__.__eq__, ["pbkdf2_hmac"], true]
    - [hl916fq004, hashlib.algorithms_available.__class__.__name__.__eq__, ["set"], true]
    - [hl916fq005, hashlib.algorithms_guaranteed.__class__.__name__.__eq__, ["frozenset"], true]

table hashlib_extra916.module_identity:
  description: "hashlib module-level identity checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: hl916mi
  columns: [id, function, args, expected]
  rows:
    - [hl916mi001, hashlib.md5.__module__.__eq__,    ["hashlib"], true]
    - [hl916mi002, hashlib.sha1.__module__.__eq__,   ["hashlib"], true]
    - [hl916mi003, hashlib.sha256.__module__.__eq__, ["hashlib"], true]
    - [hl916mi004, hashlib.sha512.__module__.__eq__, ["hashlib"], true]
    - [hl916mi005, hashlib.new.__module__.__eq__,    ["hashlib"], true]
    - [hl916mi006, hashlib.pbkdf2_hmac.__module__.__eq__, ["hashlib"], true]
