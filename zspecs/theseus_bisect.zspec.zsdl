spec: theseus_bisect
version: ">=3.9"
backend: python_cleanroom(theseus_bisect)
blocks: bisect

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html"
  notes:
    - "Clean-room binary search on sorted sequences. Do NOT import bisect."
    - "bisect_left(a, x): insertion point for x in sorted list a (left of equal elements)."
    - "bisect_right(a, x): insertion point for x in sorted list a (right of equal elements)."
    - "insort_left(a, x): inserts x into a maintaining sorted order."
    - "bisect_left([1,2,3,4,5], 3) == 2."
    - "bisect_right([1,2,3,3,5], 3) == 4."
    - "Export: bisect_left, bisect_right, insort_left, insort_right."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_bisect.bisect_left:
  description: "bisect_left([1,2,3,4,5], 3) == 2"
  category: search
  kind: python_call_eq
  function: bisect_left_result
  args: []
  expected: 2

invariant theseus_bisect.bisect_right:
  description: "bisect_right([1,2,3,3,5], 3) == 4"
  category: search
  kind: python_call_eq
  function: bisect_right_result
  args: []
  expected: 4

invariant theseus_bisect.insort:
  description: "insort_left([1,3,5], 4) results in [1,3,4,5]"
  category: insert
  kind: python_call_eq
  function: bisect_insort_result
  args: []
  expected: [1, 3, 4, 5]
