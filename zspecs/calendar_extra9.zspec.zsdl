spec: calendar_extra9
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
  notes:
    - "This spec extends calendar.zspec.zsdl and calendar_extra through calendar_extra8.zspec.zsdl."
    - "calendar_extra7 covers: month_name[1/6/12]; month_abbr[1/6/12]; day_name[0/4/6]; day_abbr[0/4/6]; isleap; leapdays; monthrange; firstweekday; isleap/__module__; timegm/__module__."
    - "calendar_extra8 covers: day_name/abbr[1/2/3/5]; monthrange(2026,1/2/12); weekday(2026,1,1/12,31); leapdays(2025,2030); monthcalendar.__name__."
    - "Prior specs covering Calendar: __name__, __module__ (Calendar.__module__), __qualname__ (Calendar.__qualname__), __bases__[0].__name__ (object); same for TextCalendar/__name__/__bases__; HTMLCalendar/__name__/__bases__."
    - "Prior specs covering month_name: index 1 (Jan), 2 (Feb), 4 (Apr), 6 (June), 12 (Dec); month_abbr: 1 (Jan), 9 (Sep), 12 (Dec)."
    - "NEW in extra9 — Axis 1: TextCalendar.__module__ and HTMLCalendar.__module__ (both == 'calendar') — not covered in any prior spec."
    - "NEW in extra9 — Axis 2: TextCalendar.__qualname__ and HTMLCalendar.__qualname__ — not covered in any prior spec."
    - "NEW in extra9 — Axis 3: setfirstweekday.__name__ and firstweekday.__name__ — not covered; note firstweekday.__name__ == 'getfirstweekday' (bound method discrepancy)."
    - "NEW in extra9 — Axis 4: MRO lengths — TextCalendar and HTMLCalendar each have MRO length 3 (TextCalendar/HTMLCalendar -> Calendar -> object)."
    - "NEW in extra9 — Axis 5: month_name[3/5/7/8] and month_abbr[3/5/7/8] — uncovered indices."
    - "calendar.firstweekday.__name__ == 'getfirstweekday' — the module-level name 'firstweekday' is an alias for the bound method whose __name__ is 'getfirstweekday'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TextCalendar and HTMLCalendar __module__ attributes
#
# No prior spec checks __module__ on TextCalendar or HTMLCalendar. Only
# Calendar.__module__ was covered (calendar_extra7). Both should be 'calendar'.
# ---------------------------------------------------------------------------

invariant calendar_extra9.TextCalendar.module:
  description: "calendar.TextCalendar.__module__ == 'calendar'"
  category: class_modules
  kind: python_call_eq
  function: TextCalendar.__module__.__eq__
  args: ["calendar"]
  expected: true

invariant calendar_extra9.HTMLCalendar.module:
  description: "calendar.HTMLCalendar.__module__ == 'calendar'"
  category: class_modules
  kind: python_call_eq
  function: HTMLCalendar.__module__.__eq__
  args: ["calendar"]
  expected: true

# ---------------------------------------------------------------------------
# TextCalendar and HTMLCalendar __qualname__ attributes
#
# calendar_extra7 covers Calendar.__qualname__. No prior spec covers
# TextCalendar.__qualname__ or HTMLCalendar.__qualname__.
# ---------------------------------------------------------------------------

invariant calendar_extra9.TextCalendar.qualname:
  description: "calendar.TextCalendar.__qualname__ == 'TextCalendar' — flat qualname for module-level class"
  category: class_qualnames
  kind: python_call_eq
  function: TextCalendar.__qualname__.__eq__
  args: ["TextCalendar"]
  expected: true

invariant calendar_extra9.HTMLCalendar.qualname:
  description: "calendar.HTMLCalendar.__qualname__ == 'HTMLCalendar' — flat qualname for module-level class"
  category: class_qualnames
  kind: python_call_eq
  function: HTMLCalendar.__qualname__.__eq__
  args: ["HTMLCalendar"]
  expected: true

# ---------------------------------------------------------------------------
# setfirstweekday and firstweekday __name__ attributes
#
# No prior spec checks __name__ on either function. Note the discrepancy:
# calendar.setfirstweekday.__name__ == 'setfirstweekday' (matches the alias),
# but calendar.firstweekday.__name__ == 'getfirstweekday' (bound method name
# differs from the module-level alias).
# ---------------------------------------------------------------------------

invariant calendar_extra9.setfirstweekday.name:
  description: "calendar.setfirstweekday.__name__ == 'setfirstweekday'"
  category: function_names
  kind: python_call_eq
  function: setfirstweekday.__name__.__eq__
  args: ["setfirstweekday"]
  expected: true

invariant calendar_extra9.firstweekday.name:
  description: "calendar.firstweekday.__name__ == 'getfirstweekday' — bound method name differs from alias"
  category: function_names
  kind: python_call_eq
  function: firstweekday.__name__.__eq__
  args: ["getfirstweekday"]
  expected: true

# ---------------------------------------------------------------------------
# MRO lengths for TextCalendar and HTMLCalendar
#
# TextCalendar and HTMLCalendar both inherit from Calendar then object, giving
# MRO length 3. No prior spec checks __mro__ length for any calendar class.
# ---------------------------------------------------------------------------

invariant calendar_extra9.TextCalendar.mro_length:
  description: "len(calendar.TextCalendar.__mro__) == 3 — TextCalendar -> Calendar -> object"
  category: class_hierarchy
  kind: python_call_eq
  function: TextCalendar.__mro__.__len__
  args: []
  expected: 3

invariant calendar_extra9.HTMLCalendar.mro_length:
  description: "len(calendar.HTMLCalendar.__mro__) == 3 — HTMLCalendar -> Calendar -> object"
  category: class_hierarchy
  kind: python_call_eq
  function: HTMLCalendar.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# month_name at indices 3, 5, 7, 8 — uncovered months
#
# Prior specs cover month_name[1/2/4/6/12]. The remaining uncovered indices
# targeted here are: 3 (March), 5 (May), 7 (July), 8 (August).
# ---------------------------------------------------------------------------

table calendar_extra9.month_names_new:
  kind: python_call_eq
  category: month_names
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [march,  month_name.__getitem__, [3],  "March"]
    - [may,    month_name.__getitem__, [5],  "May"]
    - [july,   month_name.__getitem__, [7],  "July"]
    - [august, month_name.__getitem__, [8],  "August"]

# ---------------------------------------------------------------------------
# month_abbr at indices 3, 5, 7, 8 — uncovered abbreviations
#
# Prior specs cover month_abbr[1/9/12]. Indices 3/5/7/8 are new.
# ---------------------------------------------------------------------------

table calendar_extra9.month_abbrs_new:
  kind: python_call_eq
  category: month_abbrs
  id_prefix: mabbr

  columns: [id, function, args, expected]
  rows:
    - [march,  month_abbr.__getitem__, [3],  "Mar"]
    - [may,    month_abbr.__getitem__, [5],  "May"]
    - [july,   month_abbr.__getitem__, [7],  "Jul"]
    - [august, month_abbr.__getitem__, [8],  "Aug"]
