spec: to_words
version: ">=4.0.0"
backend: node(to-words)

docs: https://github.com/yashpal-cs/to-words#readme

provenance:
  derived_from:
    - "to-words README — https://github.com/yashpal-cs/to-words#readme"
    - "Test vectors verified with to-words via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "to-words source"
  notes:
    - "Converts integers and decimals to written-out English words ('Forty Two', 'One Thousand Two Hundred Thirty Four')."
    - "Install: npm install to-words"
    - "Module exposes both a class (ToWords) and a top-level toWords() helper. Tests use the simpler top-level form."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on numeric input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table to_words.toWords:
  kind: node_module_call_eq
  category: toWords
  function: toWords
  id_prefix: words

  columns: [id, args, expected]
  rows:
    - [zero,        [0],         "Zero"]
    - [one,         [1],         "One"]
    - [forty_two,   [42],        "Forty Two"]
    - [hundred,     [100],       "One Hundred"]
    - [k1234,       [1234],      "One Thousand Two Hundred Thirty Four"]
    - [m1m,         [1000000],   "One Million"]
    - [eleven,      [11],        "Eleven"]
    - [twenty,      [20],        "Twenty"]
    - [ninety_nine, [99],        "Ninety Nine"]
