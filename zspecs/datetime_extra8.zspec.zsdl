spec: datetime_extra8
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
  notes:
    - "This spec extends datetime.zspec.zsdl and prior extras through datetime_extra7.zspec.zsdl."
    - "datetime.zspec.zsdl covers date.fromisoformat('2024-03-15').weekday() == 4 (Friday); strftime('%Y/%m/%d')."
    - "No prior spec covers date.isoweekday() — returns 1 (Monday) through 7 (Sunday), unlike weekday() (0-6)."
    - "No prior spec covers time() constructor with a microsecond argument and the resulting microsecond attribute."
    - "No prior spec covers time(23,59,59,999999).isoformat() — the latest representable microsecond-precision time via constructor."
    - "No prior spec covers timedelta(weeks=2).days == 14 — two-week normalization (timedelta_timedelta.zspec.zsdl only covers weeks=1)."
    - "No prior spec covers timedelta(days=3, hours=12).seconds == 43200 — multi-unit seconds component."
    - "date(2024, 4, 9).isoweekday() == 2 — 2024-04-09 is a Tuesday; isoweekday returns 2 for Tuesday."
    - "date(2024, 1, 1).isoweekday() == 1 — 2024-01-01 is a Monday; isoweekday returns 1 for Monday."
    - "date(2024, 12, 29).isoweekday() == 7 — 2024-12-29 is a Sunday; isoweekday returns 7 for Sunday."
    - "time(12, 0, 0, 500000).microsecond == 500000 — microsecond argument stored correctly."
    - "time(23, 59, 59, 999999).isoformat() == '23:59:59.999999' — six-digit microsecond suffix."
    - "timedelta(weeks=2).days == 14 — two weeks normalizes to 14 days."
    - "timedelta(days=3, hours=12).seconds == 43200 — 12 hours == 43200 sub-day seconds."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# date.isoweekday() — ISO weekday number (1=Monday, 7=Sunday)
#
# datetime.zspec.zsdl covers weekday() (0=Monday, 6=Sunday) for 2024-03-15.
# No prior spec covers isoweekday(), which uses the ISO 8601 convention where
# Monday==1 and Sunday==7. Three calendar positions are tested: Monday,
# Tuesday, and Sunday to exercise the boundary values of the 1-7 range.
# ---------------------------------------------------------------------------

invariant datetime_extra8.date.isoweekday_tuesday:
  description: "date(2024, 4, 9).isoweekday() == 2 — 2024-04-09 is a Tuesday"
  category: date_weekday
  kind: python_call_eq
  function: date
  args: [2024, 4, 9]
  method: isoweekday
  method_args: []
  expected: 2

invariant datetime_extra8.date.isoweekday_monday:
  description: "date(2024, 1, 1).isoweekday() == 1 — 2024-01-01 is a Monday (ISO lower bound)"
  category: date_weekday
  kind: python_call_eq
  function: date
  args: [2024, 1, 1]
  method: isoweekday
  method_args: []
  expected: 1

invariant datetime_extra8.date.isoweekday_sunday:
  description: "date(2024, 12, 29).isoweekday() == 7 — 2024-12-29 is a Sunday (ISO upper bound)"
  category: date_weekday
  kind: python_call_eq
  function: date
  args: [2024, 12, 29]
  method: isoweekday
  method_args: []
  expected: 7

# ---------------------------------------------------------------------------
# time() constructor — microsecond argument and isoformat
#
# datetime_extra7 covers datetime(2024,3,15,12,30,45,999999).microsecond for
# a datetime instance, but no prior spec constructs a time object with a
# microsecond argument and checks the resulting attribute or isoformat string.
# time(h, m, s, us) stores the microsecond in the fourth positional argument.
# ---------------------------------------------------------------------------

invariant datetime_extra8.time.microsecond_attr:
  description: "time(12, 0, 0, 500000).microsecond == 500000 — microsecond argument stored in time object"
  category: time_construction
  kind: python_call_eq
  function: time
  args: [12, 0, 0, 500000]
  method: microsecond
  expected: 500000

invariant datetime_extra8.time.microsecond_isoformat:
  description: "time(23, 59, 59, 999999).isoformat() == '23:59:59.999999' — six-digit microsecond suffix"
  category: time_construction
  kind: python_call_eq
  function: time
  args: [23, 59, 59, 999999]
  method: isoformat
  method_args: []
  expected: "23:59:59.999999"

# ---------------------------------------------------------------------------
# timedelta — additional normalization vectors
#
# datetime_timedelta.zspec.zsdl covers timedelta(weeks=1).days == 7 and
# timedelta(hours=1).seconds == 3600.
# No prior spec covers timedelta(weeks=2).days == 14 (two-week normalization)
# or timedelta(days=3, hours=12).seconds == 43200 (hours component of a
# multi-day timedelta is stored as sub-day seconds, not total seconds).
# ---------------------------------------------------------------------------

invariant datetime_extra8.timedelta.two_weeks_to_days:
  description: "timedelta(weeks=2).days == 14 — two weeks normalizes to 14 days"
  category: timedelta_normalize
  kind: python_call_eq
  function: timedelta
  kwargs: {weeks: 2}
  method: days
  expected: 14

invariant datetime_extra8.timedelta.days_hours_seconds:
  description: "timedelta(days=3, hours=12).seconds == 43200 — 12 hours stored as 43200 sub-day seconds"
  category: timedelta_normalize
  kind: python_call_eq
  function: timedelta
  kwargs: {days: 3, hours: 12}
  method: seconds
  expected: 43200
