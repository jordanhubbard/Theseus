spec: deep_object_assign
version: ">=0.0.1"
backend: node(deep-object-assign)

docs: https://www.npmjs.com/package/deep-object-assign

provenance:
  derived_from:
    - "deep-object-assign README — https://www.npmjs.com/package/deep-object-assign"
    - "Test vectors verified with deep-object-assign via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "deep-object-assign source"
  notes:
    - "deep-object-assign is an npm package. Install: npm install deep-object-assign"
    - "Recursively merges two objects, combining nested properties."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table deep_object_assign.merge:
  kind: node_module_call_eq
  function: ~
  category: objects
  id_prefix: doa

  columns: [id, args, expected]
  rows:
    - [flat,   [{"a": 1}, {"b": 2}],               {"a": 1, "b": 2}]
    - [deep,   [{"a": {"x": 1}}, {"a": {"y": 2}}], {"a": {"x": 1, "y": 2}}]
    - [override,[{"a": 1}, {"a": 2}],               {"a": 2}]
