spec: poplib_extra3
version: ">=3.9"
backend: python_module(poplib)

docs: https://docs.python.org/3/library/poplib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/poplib.html — Python poplib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/poplib.py"
  notes:
    - "This spec extends poplib.zspec.zsdl and prior extras."
    - "poplib.zspec.zsdl covers: POP3/POP3_SSL/error_proto __name__, POP3.__module__, POP3.port==110, POP3_SSL.port==995, error_proto hierarchy, method names."
    - "poplib_extra.zspec.zsdl covers: class names/types/modules/qualnames, error_proto hierarchy, POP3_SSL hierarchy."
    - "poplib_extra2.zspec.zsdl covers: POP3/POP3_SSL port type checks (int), port value table, error_proto base name, POP3_SSL base name."
    - "This spec adds: POP3.__bases__[0].__name__=='object' (not covered), POP3 method qualnames (table), error_proto.__qualname__ cross-check via standalone invariant."
    - "POP3 inherits directly from object (no intermediate base class)."
    - "POP3 method __qualname__ values match their __name__ values for top-level methods."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# POP3.__bases__[0].__name__ == 'object'
# POP3 has no intermediate base class; it inherits directly from object.
# Not covered in any prior poplib spec.
# ---------------------------------------------------------------------------

invariant poplib_extra3.hierarchy.POP3_base_is_object:
  description: "poplib.POP3.__bases__[0].__name__ == 'object' — POP3 inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: POP3.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# POP3 method qualnames
# For top-level (non-nested) methods, __qualname__ == 'ClassName.method_name'.
# Not covered in any prior poplib spec.
# ---------------------------------------------------------------------------

table poplib_extra3.method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mqualname

  columns: [id, function, args, expected]
  rows:
    - [user,  POP3.user.__qualname__.__eq__,  ["POP3.user"],  true]
    - [pass_, POP3.pass_.__qualname__.__eq__, ["POP3.pass_"], true]
    - [stat,  POP3.stat.__qualname__.__eq__,  ["POP3.stat"],  true]
    - [list,  POP3.list.__qualname__.__eq__,  ["POP3.list"],  true]
    - [retr,  POP3.retr.__qualname__.__eq__,  ["POP3.retr"],  true]
    - [dele,  POP3.dele.__qualname__.__eq__,  ["POP3.dele"],  true]
    - [quit,  POP3.quit.__qualname__.__eq__,  ["POP3.quit"],  true]

# ---------------------------------------------------------------------------
# error_proto.__name__ standalone invariant
# poplib.zspec and poplib_extra both cover error_proto.__name__ (table/invariant).
# This adds a focused cross-namespace check: the name value is 'error_proto'.
# poplib_extra2 does not add a standalone error_proto.__name__ invariant.
# ---------------------------------------------------------------------------

invariant poplib_extra3.error_proto.name:
  description: "poplib.error_proto.__name__ == 'error_proto' — exception class name check"
  category: class_names
  kind: python_call_eq
  function: error_proto.__name__.__eq__
  args: ["error_proto"]
  expected: true

# ---------------------------------------------------------------------------
# POP3_SSL.__bases__[0].__name__ == 'POP3' — value-returning standalone invariant
# poplib_extra2 covers this as a value-returning invariant; this is omitted.
# New: POP3_SSL.__module__ cross-check (covered in poplib_extra, not extra2 standalone).
# We add the POP3 class-type check (metaclass is 'type') as a standalone invariant.
# poplib_extra covers this in a table; here we add a focused standalone form.
# ---------------------------------------------------------------------------

invariant poplib_extra3.POP3.metaclass_is_type:
  description: "poplib.POP3.__class__.__name__ == 'type' — POP3 is a regular Python class"
  category: class_types
  kind: python_call_eq
  function: POP3.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant poplib_extra3.POP3_SSL.metaclass_is_type:
  description: "poplib.POP3_SSL.__class__.__name__ == 'type' — POP3_SSL is a regular Python class"
  category: class_types
  kind: python_call_eq
  function: POP3_SSL.__class__.__name__.__eq__
  args: ["type"]
  expected: true
