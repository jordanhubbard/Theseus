spec: socket_extra1291
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra129.zspec.zsdl — covers socket.socket/__init__/__new__ qualname and class checks / socket.error/__timeout__ dict membership / herror/gaierror init identity (table + invariants)."
    - "socket_extra128.zspec.zsdl — covers socket.socket/__init__/__qualname__/__name__/co_argcount / socket.socket/__new__ identity / AF_* constants class checks (table + invariants)."
    - "socket_extra2.zspec.zsdl — covers create_connection/create_server/setdefaulttimeout function names / inet_aton/inet_ntoa vectors / htons/ntohs/ntohl byte-order checks (table + invariants)."
    - "socket_extra.zspec.zsdl — covers create_connection/create_server/setdefaulttimeout/htons/ntohs function names / inet_aton broadcast / inet_ntoa / htonl little-endian (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in earlier socket spec files."
    - "Wave 533 theme: __init__ and __new__ method presence and qualname checks for socket."
    - "socket.socket.__init__.__qualname__ == 'socket.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__init__.__class__.__name__ == 'function'. socket.socket is defined in Lib/socket.py; its __init__ is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('__init__') == True. socket.socket explicitly defines __init__ in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__new__.__qualname__ == 'socket.__new__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__new__.__class__.__name__ == 'builtin_function_or_method'. socket.socket overrides __new__ at the C level. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('__new__') == False. __new__ is inherited / not present in socket.socket's own __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__init__.__qualname__ == 'OSError.__init__'. socket.error IS OSError (socket.error is OSError evaluates True). OSError.__init__ is a C-level wrapper_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__init__.__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__dict__.__contains__('__init__') == True. socket.error is OSError which has __init__ in its __dict__ as a wrapper_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__init__.__qualname__ == 'OSError.__init__'. socket.timeout is a subclass of OSError and does not override __init__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__init__.__class__.__name__ == 'wrapper_descriptor'. Inherited from OSError. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__dict__.__contains__('__init__') == False. socket.timeout does not define __init__ in its own __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket is a Python class defined in Lib/socket.py (wrapping the C-level _socket.socket). Its __init__ is a pure-Python function ('function'), unlike C extension types where __init__ would be a wrapper_descriptor."
    - "Note: socket.error is socket.error is OSError — they are the same object. OSError does define __init__ explicitly (as a wrapper_descriptor in its own __dict__), which is why socket.error.__dict__.__contains__('__init__') is True."
    - "Note: socket.timeout is a subclass of OSError (via TimeoutError). It does NOT override __init__, so socket.timeout.__dict__.__contains__('__init__') is False, and __init__ resolves to OSError.__init__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__init__.__qualname__.__eq__('socket.__init__')
# socket.socket.__init__.__class__.__name__.__eq__('function')
# socket.socket.__dict__.__contains__('__init__') == True
# socket.socket.__new__.__qualname__.__eq__('socket.__new__')
# socket.socket.__new__.__class__.__name__.__eq__('builtin_function_or_method')
# socket.socket.__dict__.__contains__('__new__') == False
#
# Wave 533 theme: socket.socket __init__ and __new__ identity.
#
# socket.socket (the Python-level class in Lib/socket.py) is unusual:
# its __init__ is a pure-Python function ('function') because the class
# is a Python wrapper around the lower-level _socket.socket. The __qualname__
# of socket.socket.__init__ is 'socket.__init__' — the class name within
# the module is 'socket' (same as the module name, which is intentional).
# socket.socket does NOT have __new__ in its own __dict__; __new__ resolves
# to a builtin_function_or_method inherited from the C-level _socket.socket.
# No prior socket spec anchors __init__.__qualname__.__eq__ or
# __dict__.__contains__ checks under skinit1291. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table socket_extra1291.socket_init_and_new_identity:
  description: "socket.socket/__init__/__qualname__.__eq__('socket.__init__')==True / __init__/__class__/__name__.__eq__('function')==True / __dict__/__contains__('__init__')==True / __new__/__qualname__.__eq__('socket.__new__')==True / __new__/__class__/__name__.__eq__('builtin_function_or_method')==True / __dict__/__contains__('__new__')==False — socket.socket is a Python-level class; __init__ is pure-Python ('function'); __new__ is C-level (builtin); first skinit1291 anchor"
  kind: python_call_eq
  category: init_new_identity
  id_prefix: skinit1291

  columns: [id, function, args, expected, description]
  rows:
    - [sk1291in001, socket.__init__.__qualname__.__eq__,           ["socket.__init__"],             true,  "socket.socket.__init__.__qualname__ is 'socket.__init__' (class named 'socket' in Lib/socket.py)"]
    - [sk1291in002, socket.__init__.__class__.__name__.__eq__,     ["function"],                    true,  "socket.socket.__init__.__class__.__name__ is 'function' (pure-Python method in Lib/socket.py)"]
    - [sk1291in003, socket.__dict__.__contains__,                  ["__init__"],                    true,  "socket.socket.__dict__.__contains__('__init__') is True — explicitly defined in Lib/socket.py class body"]
    - [sk1291in004, socket.__new__.__qualname__.__eq__,            ["socket.__new__"],              true,  "socket.socket.__new__.__qualname__ is 'socket.__new__' (inherits C-level __new__ from _socket.socket)"]
    - [sk1291in005, socket.__new__.__class__.__name__.__eq__,      ["builtin_function_or_method"],  true,  "socket.socket.__new__.__class__.__name__ is 'builtin_function_or_method' (C-level tp_new from _socket)"]
    - [sk1291in006, socket.__dict__.__contains__,                  ["__new__"],                     false, "socket.socket.__dict__.__contains__('__new__') is False — __new__ not overridden in Python class body"]

# ---------------------------------------------------------------------------
# socket.error.__init__.__qualname__.__eq__('OSError.__init__')
# socket.error.__init__.__class__.__name__.__eq__('wrapper_descriptor')
# socket.error.__dict__.__contains__('__init__') == True
# socket.timeout.__init__.__qualname__.__eq__('OSError.__init__')
# socket.timeout.__init__.__class__.__name__.__eq__('wrapper_descriptor')
# socket.timeout.__dict__.__contains__('__init__') == False
#
# Wave 533 theme: socket.error and socket.timeout __init__ checks.
#
# socket.error IS OSError — they are the same object (socket.error is OSError
# evaluates to True). Because socket.error IS OSError, it has OSError.__init__
# in its __dict__ as a wrapper_descriptor. By contrast, socket.timeout is a
# subclass of OSError but does NOT override __init__; its __dict__ does not
# contain '__init__', and __init__ resolves to OSError.__init__ via MRO.
# This difference (True vs False for __dict__.__contains__('__init__')) is
# notable and has not been anchored in prior socket specs.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra1291.error_and_timeout_init:
  description: "socket.error/__init__/__qualname__.__eq__('OSError.__init__')==True / __init__/__class__/__name__.__eq__('wrapper_descriptor')==True / __dict__/__contains__('__init__')==True / socket.timeout/__init__/__qualname__.__eq__('OSError.__init__')==True / __init__/__class__/__name__.__eq__('wrapper_descriptor')==True / __dict__/__contains__('__init__')==False — socket.error IS OSError (has __init__ in dict); timeout is a subclass (no __init__ in dict); first skerr1291 anchor"
  kind: python_call_eq
  category: error_timeout_init
  id_prefix: skerr1291

  columns: [id, function, args, expected, description]
  rows:
    - [sk1291er001, error.__init__.__qualname__.__eq__,            ["OSError.__init__"],   true,  "socket.error.__init__.__qualname__ is 'OSError.__init__' — socket.error IS OSError"]
    - [sk1291er002, error.__init__.__class__.__name__.__eq__,      ["wrapper_descriptor"],  true,  "socket.error.__init__.__class__.__name__ is 'wrapper_descriptor' (C-level OSError.__init__ slot)"]
    - [sk1291er003, error.__dict__.__contains__,                   ["__init__"],            true,  "socket.error.__dict__.__contains__('__init__') is True — socket.error IS OSError which has __init__ in dict"]
    - [sk1291er004, timeout.__init__.__qualname__.__eq__,          ["OSError.__init__"],   true,  "socket.timeout.__init__.__qualname__ is 'OSError.__init__' — timeout is a subclass, inherits __init__"]
    - [sk1291er005, timeout.__init__.__class__.__name__.__eq__,    ["wrapper_descriptor"],  true,  "socket.timeout.__init__.__class__.__name__ is 'wrapper_descriptor' (inherited OSError.__init__)"]
    - [sk1291er006, timeout.__dict__.__contains__,                 ["__init__"],            false, "socket.timeout.__dict__.__contains__('__init__') is False — timeout does not override __init__"]

# ---------------------------------------------------------------------------
# socket.socket.__init__.__qualname__.__eq__('socket.__init__') — standalone
# socket.socket.__dict__.__contains__('__init__') == True — standalone
# socket.socket.__new__.__qualname__.__eq__('socket.__new__') — standalone
# socket.error.__init__.__qualname__.__eq__('OSError.__init__') — standalone
# socket.error.__dict__.__contains__('__init__') == True — standalone
# socket.timeout.__dict__.__contains__('__init__') == False — standalone
#
# Wave 533 theme: standalone confirmations for socket init/new invariants.
#
# These standalones provide dedicated anchors for the most important
# wave 533 invariants for the socket module. The key distinction captured:
# socket.socket.__init__ is a pure-Python 'function' (rare for socket-like
# objects — it wraps the C-level _socket.socket). socket.error IS OSError and
# has __init__ in its __dict__, while socket.timeout inherits without override.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra1291.socket_wave533_standalones:
  description: "socket.socket/__init__/__qualname__.__eq__('socket.__init__')==True / __dict__/__contains__('__init__')==True / __new__/__qualname__.__eq__('socket.__new__')==True / error/__init__/__qualname__.__eq__('OSError.__init__')==True / error/__dict__/__contains__('__init__')==True / timeout/__dict__/__contains__('__init__')==False — standalone wave-533 confirmations for socket; first sksc1291 anchor"
  kind: python_call_eq
  category: wave533_standalones
  id_prefix: sksc1291

  columns: [id, function, args, expected, description]
  rows:
    - [sk1291sc001, socket.__init__.__qualname__.__eq__,           ["socket.__init__"],   true,  "socket.socket.__init__.__qualname__ primary wave 533 invariant for socket"]
    - [sk1291sc002, socket.__dict__.__contains__,                  ["__init__"],          true,  "socket.socket.__dict__ explicitly contains '__init__' (pure-Python method)"]
    - [sk1291sc003, socket.__new__.__qualname__.__eq__,            ["socket.__new__"],    true,  "socket.socket.__new__.__qualname__ is 'socket.__new__' (C-level builtin inherited)"]
    - [sk1291sc004, error.__init__.__qualname__.__eq__,            ["OSError.__init__"],  true,  "socket.error.__init__ resolves to OSError.__init__ (socket.error IS OSError)"]
    - [sk1291sc005, error.__dict__.__contains__,                   ["__init__"],          true,  "socket.error.__dict__ contains '__init__' because socket.error IS OSError (same object)"]
    - [sk1291sc006, timeout.__dict__.__contains__,                 ["__init__"],          false, "socket.timeout.__dict__ does NOT contain '__init__' (subclass of OSError; no override)"]
