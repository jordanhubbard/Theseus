spec: has_symbols
version: ">=1.0.0"
backend: node(has-symbols)

docs: https://github.com/inspect-js/has-symbols#readme

provenance:
  derived_from:
    - "has-symbols README — https://github.com/inspect-js/has-symbols#readme"
    - "ECMA-262 §19.4 — Symbol objects"
    - "Test vectors verified with has-symbols via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "has-symbols source"
  notes:
    - "Detects native ES6 Symbol support — used by polyfill packages to skip Symbol-aware code paths."
    - "Install: npm install has-symbols"
    - "v1 CJS; module export IS the predicate. Returns true on any modern engine; false where Symbol is missing or shimmed."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "Result depends on engine, not arguments — invariant within a host."
  codes: {}

invariant has_symbols.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant has_symbols.module_arity:
  description: "Module function declared length is 0 (no args)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 0

invariant has_symbols.returns_true_on_modern_node:
  description: "Returns true on a Symbol-supporting host (Node 22)"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain: []
  expected: true

invariant has_symbols.result_is_boolean:
  description: "Return value is of Boolean type"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "Boolean"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:50:01Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
