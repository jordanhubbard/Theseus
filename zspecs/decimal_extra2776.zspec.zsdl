spec: decimal_extra2776
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers existing decimal invariants"
    - "decimal_extra2761.zspec.zsdl — covers __matmul__/__truediv__/__iadd__ dict-presence"
    - "decimal_extra2746.zspec.zsdl — covers __round__/__divmod__/__pow__ dict-presence"
    - "decimal_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
    - "decimal_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 632 (decimal_extra2776) theme: __isub__, __imul__, and __itruediv__ dict-presence checks."
    - "decimal.Decimal does NOT define __isub__, __imul__, or __itruediv__ in its own __dict__."
    - "Although decimal.Decimal defines __sub__, __mul__, and __truediv__, it is an immutable type and does not implement the corresponding in-place operator hooks."
    - "decimal.Context and decimal.DecimalException also do NOT define __isub__, __imul__, or __itruediv__ in their own __dict__."
    - "__isub__ supports the -= operator; Decimal is immutable and rebinds the name rather than mutating in place."
    - "__imul__ supports the *= operator; Decimal is immutable and does not implement in-place multiplication."
    - "__itruediv__ supports the /= operator; Decimal is immutable and does not implement in-place true-division."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __isub__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2776.no_isub_in_decimal_classes:
  description: "__isub__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal is immutable and does not implement -= in-place subtraction"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2776

  columns: [id, function, args, expected]
  rows:
    - ["dc2776001", "decimal.Decimal.__dict__.__contains__",          ["__isub__"], false]
    - ["dc2776002", "decimal.Context.__dict__.__contains__",          ["__isub__"], false]
    - ["dc2776003", "decimal.DecimalException.__dict__.__contains__", ["__isub__"], false]

# ---------------------------------------------------------------------------
# __imul__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2776.no_imul_in_decimal_classes:
  description: "__imul__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal is immutable and does not implement *= in-place multiplication"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2776

  columns: [id, function, args, expected]
  rows:
    - ["dc2776004", "decimal.Decimal.__dict__.__contains__",          ["__imul__"], false]
    - ["dc2776005", "decimal.Context.__dict__.__contains__",          ["__imul__"], false]
    - ["dc2776006", "decimal.DecimalException.__dict__.__contains__", ["__imul__"], false]

# ---------------------------------------------------------------------------
# __itruediv__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2776.no_itruediv_in_decimal_classes:
  description: "__itruediv__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal is immutable and does not implement /= in-place true-division"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2776

  columns: [id, function, args, expected]
  rows:
    - ["dc2776007", "decimal.Decimal.__dict__.__contains__",          ["__itruediv__"], false]
    - ["dc2776008", "decimal.Context.__dict__.__contains__",          ["__itruediv__"], false]
    - ["dc2776009", "decimal.DecimalException.__dict__.__contains__", ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Complementary: decimal.Decimal defines binary arithmetic hooks but none of the in-place variants
# Contrasts Decimal's __sub__/__mul__/__truediv__ presence with absent __isub__/__imul__/__itruediv__
# ---------------------------------------------------------------------------

table decimal_extra2776.decimal_has_binary_ops_but_not_inplace_variants:
  description: "decimal.Decimal defines __sub__/__mul__/__truediv__ but NOT __isub__/__imul__/__itruediv__; decimal.Context has sqrt/exp/ln but none of the in-place arithmetic hooks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2776

  columns: [id, function, args, expected]
  rows:
    - ["dc2776010", "decimal.Decimal.__dict__.__contains__", ["__sub__"],      true]
    - ["dc2776011", "decimal.Decimal.__dict__.__contains__", ["__mul__"],      true]
    - ["dc2776012", "decimal.Decimal.__dict__.__contains__", ["__truediv__"],  true]
    - ["dc2776013", "decimal.Decimal.__dict__.__contains__", ["__isub__"],     false]
    - ["dc2776014", "decimal.Decimal.__dict__.__contains__", ["__imul__"],     false]
    - ["dc2776015", "decimal.Decimal.__dict__.__contains__", ["__itruediv__"], false]
    - ["dc2776016", "decimal.Context.__dict__.__contains__", ["sqrt"],         true]
    - ["dc2776017", "decimal.Context.__dict__.__contains__", ["exp"],          true]
    - ["dc2776018", "decimal.Context.__dict__.__contains__", ["ln"],           true]
    - ["dc2776019", "decimal.Context.__dict__.__contains__", ["__isub__"],     false]
    - ["dc2776020", "decimal.Context.__dict__.__contains__", ["__imul__"],     false]
    - ["dc2776021", "decimal.Context.__dict__.__contains__", ["__itruediv__"], false]
