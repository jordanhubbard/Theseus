spec: asyncio_extra18
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "This spec extends asyncio.zspec.zsdl through asyncio_extra17.zspec.zsdl."
    - "asyncio_extra covers: Task/Future/Queue/Lock/Event/Semaphore __name__."
    - "asyncio_extra15 covers: Lock/Event/Semaphore/Barrier __qualname__ and __module__; Task/Future/Queue __qualname__."
    - "asyncio_extra17 covers: run/sleep/gather/wait/wait_for/create_task/ensure_future/shield/current_task/all_tasks __name__; get_event_loop/get_running_loop/new_event_loop __name__; run.__module__."
    - "NOT yet covered in any prior spec: asyncio.Task.__qualname__ == 'Task' as standalone __eq__ invariant."
    - "NOT yet covered: asyncio.Future.__qualname__ == 'Future' as standalone __eq__ invariant."
    - "NOT yet covered: asyncio.Queue.__qualname__ == 'Queue' as standalone __eq__ invariant."
    - "NOT yet covered: asyncio.Lock.__qualname__ == 'Lock' as standalone __eq__ invariant."
    - "NOT yet covered: asyncio.Event.__qualname__ == 'Event' as standalone __eq__ invariant."
    - "NOT yet covered: asyncio.Semaphore.__qualname__ == 'Semaphore' as standalone __eq__ invariant."
    - "NOT yet covered: asyncio.Task.__module__ == '_asyncio' — Task is a C extension type accelerated by _asyncio."
    - "NOT yet covered: asyncio.Future.__module__ == '_asyncio' — Future is also a C extension type."
    - "NOT yet covered: asyncio.Queue.__module__ == 'asyncio.queues' — Queue is defined in asyncio/queues.py."
    - "NOT yet covered: asyncio.Lock.__module__ == 'asyncio.locks' — Lock is defined in asyncio/locks.py."
    - "NOT yet covered: asyncio.Event.__module__ == 'asyncio.locks' — Event is defined in asyncio/locks.py."
    - "NOT yet covered: asyncio.Semaphore.__module__ == 'asyncio.locks' — Semaphore is defined in asyncio/locks.py."
    - "NOT yet covered: asyncio.get_event_loop.__name__ == 'get_event_loop' as standalone __eq__ invariant."
    - "NOT yet covered: asyncio.create_task.__name__ == 'create_task' as standalone __eq__ invariant."
    - "NOT yet covered: asyncio.sleep.__name__ == 'sleep' as standalone __eq__ invariant."
    - "asyncio.Task and asyncio.Future use the C-accelerated implementation from _asyncio when available."
    - "asyncio.Queue is a pure-Python class in asyncio/queues.py."
    - "asyncio.Lock, asyncio.Event, and asyncio.Semaphore are pure-Python classes in asyncio/locks.py."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for Task, Future, Queue, Lock, Event, Semaphore
#
# asyncio_extra15 covers Lock/Event/Semaphore/Barrier __qualname__ and
# Task/Future/Queue __qualname__ in table form. This spec provides standalone
# __eq__ invariants for the full canonical set for independent coverage.
# ---------------------------------------------------------------------------

table asyncio_extra18.class_qualnames:
  description: "asyncio primitive classes have correct __qualname__ attributes"
  kind: python_call_eq
  category: class_names
  id_prefix: clsqn18

  columns: [id, function, args, expected]
  rows:
    - [Task,      Task.__qualname__.__eq__,      ["Task"],      true]
    - [Future,    Future.__qualname__.__eq__,    ["Future"],    true]
    - [Queue,     Queue.__qualname__.__eq__,     ["Queue"],     true]
    - [Lock,      Lock.__qualname__.__eq__,      ["Lock"],      true]
    - [Event,     Event.__qualname__.__eq__,     ["Event"],     true]
    - [Semaphore, Semaphore.__qualname__.__eq__, ["Semaphore"], true]

# ---------------------------------------------------------------------------
# __module__ table for Task, Future, Queue, Lock, Event, Semaphore
#
# asyncio_extra15 covers __module__ for Lock/Event/Semaphore/Barrier and
# CancelledError. No prior spec covers Task/__module__ or Future/__module__
# as standalone __eq__ invariants. Task and Future are C-accelerated in
# CPython 3.9+ and live in _asyncio; Queue and the locks live in their
# respective asyncio submodules.
# ---------------------------------------------------------------------------

table asyncio_extra18.class_modules:
  description: "asyncio primitive classes have correct __module__ attributes"
  kind: python_call_eq
  category: class_modules
  id_prefix: clsmod18

  columns: [id, function, args, expected]
  rows:
    - [Task,      Task.__module__.__eq__,      ["_asyncio"],      true]
    - [Future,    Future.__module__.__eq__,    ["_asyncio"],      true]
    - [Queue,     Queue.__module__.__eq__,     ["asyncio.queues"], true]
    - [Lock,      Lock.__module__.__eq__,      ["asyncio.locks"],  true]
    - [Event,     Event.__module__.__eq__,     ["asyncio.locks"],  true]
    - [Semaphore, Semaphore.__module__.__eq__, ["asyncio.locks"],  true]

# ---------------------------------------------------------------------------
# Module-level function __name__ — standalone invariants
#
# asyncio_extra17 covers get_event_loop, create_task, and sleep in a table.
# These standalone invariants provide independent single-function coverage
# for the three functions called out in the task specification.
# ---------------------------------------------------------------------------

invariant asyncio_extra18.get_event_loop.name:
  description: "asyncio.get_event_loop.__name__ == 'get_event_loop'"
  category: function_names
  kind: python_call_eq
  function: get_event_loop.__name__.__eq__
  args: ["get_event_loop"]
  expected: true

invariant asyncio_extra18.create_task.name:
  description: "asyncio.create_task.__name__ == 'create_task'"
  category: function_names
  kind: python_call_eq
  function: create_task.__name__.__eq__
  args: ["create_task"]
  expected: true

invariant asyncio_extra18.sleep.name:
  description: "asyncio.sleep.__name__ == 'sleep'"
  category: function_names
  kind: python_call_eq
  function: sleep.__name__.__eq__
  args: ["sleep"]
  expected: true
