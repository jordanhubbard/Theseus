spec: socket_extra245
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 791 — Internet Protocol (network byte order)"
  - "RFC 1700 — Assigned Numbers"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "RFC 791 — Internet Protocol, DARPA, September 1981"
    - "RFC 1700 — Assigned Numbers, October 1994"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec extends socket.zspec.zsdl, socket_extra.zspec.zsdl, socket_extra2.zspec.zsdl, and socket_extra3.zspec.zsdl; it does NOT duplicate invariants present in those files."
    - "socket.zspec.zsdl covers: htonl/ntohl function names; htonl(0)==0."
    - "socket_extra.zspec.zsdl covers: htons/ntohs function names; htons(0)/ntohs(0)/ntohl(0)==0; htonl(1)==16777216 (little-endian)."
    - "socket_extra2.zspec.zsdl covers: AF/SocketKind enum class names; gethostname/getfqdn return type; socket.error/timeout aliases."
    - "socket_extra3.zspec.zsdl covers: AddressFamily/SocketKind __name__; herror/gaierror bases; IPPROTO class names; socket.__module__."
    - "ntohs, ntohl, htons, htonl are built-in functions in the _socket C extension module."
    - "On little-endian hosts (x86_64, arm64 macOS): ntohs(256) == 1 because 0x0100 byte-swapped is 0x0001."
    - "On little-endian hosts: ntohs(1) == 256 because 0x0001 byte-swapped is 0x0100."
    - "On little-endian hosts: ntohl(256) == 65536 because 0x00000100 byte-swapped is 0x00010000."
    - "On little-endian hosts: htons(256) == 1 (same as ntohs — host-to-network and network-to-host are symmetric byte swaps)."
    - "On little-endian hosts: htonl(256) == 65536 (same as ntohl for the same reason)."
    - "ntohs and htons operate on 16-bit unsigned integers; ntohl and htonl operate on 32-bit unsigned integers."
    - "ntohs.__module__ == '_socket' and ntohl.__module__ == '_socket' (C extension)."
    - "htons.__module__ == '_socket' and htonl.__module__ == '_socket' (C extension)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0 (little-endian arm64), 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "socket raises OverflowError when values exceed the range of the underlying unsigned integer type."
  stderr: "null"
  stickiness: "N/A — all tested invariants are pure-computation functions or name checks."
  codes: {}

# ---------------------------------------------------------------------------
# ntohs, ntohl, htons, htonl — function __name__ and __module__
# socket_extra already covers __name__ for htons/ntohs via table;
# this spec adds __name__ for ntohl, and __module__ for all four.
# ---------------------------------------------------------------------------

table socket245byteorder.function_modules:
  description: "ntohs, ntohl, htons, htonl are all in the _socket C extension module"
  kind: python_call_eq
  category: function_identity
  id_prefix: socket245byteorder

  columns: [id, function, args, expected]
  rows:
    - [ntohs_module, ntohs.__module__.__eq__, ["_socket"], true]
    - [ntohl_module, ntohl.__module__.__eq__, ["_socket"], true]
    - [htons_module, htons.__module__.__eq__, ["_socket"], true]
    - [htonl_module, htonl.__module__.__eq__, ["_socket"], true]
    - [ntohs_name,   ntohs.__name__.__eq__,   ["ntohs"],   true]
    - [ntohl_name,   ntohl.__name__.__eq__,   ["ntohl"],   true]
    - [htons_name,   htons.__name__.__eq__,   ["htons"],   true]
    - [htonl_name,   htonl.__name__.__eq__,   ["htonl"],   true]

# ---------------------------------------------------------------------------
# Byte order swap values on little-endian (macOS/Linux x86_64/arm64)
# ntohs(256) == 1: network byte order 0x0100 -> host 0x0001
# ntohs(1) == 256: network byte order 0x0001 -> host 0x0100
# ---------------------------------------------------------------------------

invariant socket245byteorder.ntohs.256_swaps_to_1:
  description: "socket.ntohs(256) == 1 on little-endian (0x0100 network -> 0x0001 host)"
  category: byte_order
  kind: python_call_eq
  function: ntohs
  args: [256]
  expected: 1

invariant socket245byteorder.ntohs.1_swaps_to_256:
  description: "socket.ntohs(1) == 256 on little-endian (0x0001 network -> 0x0100 host)"
  category: byte_order
  kind: python_call_eq
  function: ntohs
  args: [1]
  expected: 256

invariant socket245byteorder.htons.256_swaps_to_1:
  description: "socket.htons(256) == 1 on little-endian (host 0x0100 -> network 0x0001)"
  category: byte_order
  kind: python_call_eq
  function: htons
  args: [256]
  expected: 1

invariant socket245byteorder.htons.1_swaps_to_256:
  description: "socket.htons(1) == 256 on little-endian (host 0x0001 -> network 0x0100)"
  category: byte_order
  kind: python_call_eq
  function: htons
  args: [1]
  expected: 256

invariant socket245byteorder.ntohl.256_swaps_to_65536:
  description: "socket.ntohl(256) == 65536 on little-endian (0x00000100 -> 0x00010000)"
  category: byte_order
  kind: python_call_eq
  function: ntohl
  args: [256]
  expected: 65536

invariant socket245byteorder.htonl.256_swaps_to_65536:
  description: "socket.htonl(256) == 65536 on little-endian (0x00000100 -> 0x00010000)"
  category: byte_order
  kind: python_call_eq
  function: htonl
  args: [256]
  expected: 65536

# ---------------------------------------------------------------------------
# ntohl and htonl symmetry — ntohl(0x01000000) == 1 on little-endian
# Verifies that ntohl and htonl are mutual inverses.
# ---------------------------------------------------------------------------

invariant socket245byteorder.ntohl.0x01000000_swaps_to_1:
  description: "socket.ntohl(0x01000000) == 1 on little-endian (0x01000000 -> 0x00000001)"
  category: byte_order
  kind: python_call_eq
  function: ntohl
  args: [16777216]
  expected: 1

invariant socket245byteorder.htonl.0x01000000_swaps_to_1:
  description: "socket.htonl(0x01000000) == 1 on little-endian (0x01000000 -> 0x00000001)"
  category: byte_order
  kind: python_call_eq
  function: htonl
  args: [16777216]
  expected: 1
