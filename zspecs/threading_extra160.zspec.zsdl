  function: current_thread.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra160.current_thread_module_threading:
  description: "threading.current_thread.__module__ == 'threading' — current_thread is defined in Lib/threading.py; wave 288; new to extra160"
  kind: python_call_eq
