spec: threading_extra160
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Timer.__bases__[0].__name__ 'Thread'; threading.Timer.__module__ 'threading'; threading.Timer.__name__ 'Timer'; threading.current_thread.__class__.__name__ 'function'; threading.current_thread.__module__ 'threading'; threading.main_thread.__class__.__name__ 'function'; threading.main_thread.__module__ 'threading' (Wave 288)."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer inherits directly from Thread; __bases__[0].__name__ is 'Thread'. Verified with Python 3.14.3."
    - "threading.Timer.__module__ == 'threading' — Timer is defined in Lib/threading.py; its __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.Timer.__name__ == 'Timer' — the class name is 'Timer'. Verified with Python 3.14.3."
    - "threading.current_thread.__class__.__name__ == 'function' — current_thread is a Python function in Lib/threading.py; its __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "threading.current_thread.__module__ == 'threading' — current_thread is defined in Lib/threading.py; its __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.main_thread.__class__.__name__ == 'function' — main_thread is a Python function in Lib/threading.py; its __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "threading.main_thread.__module__ == 'threading' — main_thread is defined in Lib/threading.py; its __module__ is 'threading'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Timer class identity
#
# Wave 288 theme: threading.Timer class identity — base class, module, and name.
#
# threading.Timer.__bases__[0].__name__ == 'Thread'
# threading.Timer.__module__ == 'threading'
# threading.Timer.__name__ == 'Timer'
# threading.Timer.__bases__.__len__() == 1
#
# threading.Timer is a Python class in Lib/threading.py that represents an
# action that should be run only after a certain amount of time has passed.
# It is a subclass of Thread — its single base class is Thread, so
# __bases__[0].__name__ is 'Thread' and __bases__.__len__() is 1. Timer is
# defined in the threading module, so its __module__ is 'threading'. Its
# simple class name is 'Timer'. New to extra160.
# ---------------------------------------------------------------------------

table threading_extra160.timer_class_identity:
  description: "threading.Timer: __bases__[0].__name__ 'Thread', __module__ 'threading', __name__ 'Timer', __bases__.__len__() 1; wave 288; new to extra160"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtimerci160

  columns: [id, function, args, expected, description]
  rows:
    - ["timer_bases_0_name_eq_thread",
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer is a Python class in Lib/threading.py that subclasses Thread; its single direct base class is Thread; __bases__[0].__name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra160"]
    - [timer_module_eq_threading,
       "Timer.__module__.__eq__",
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — Timer is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra160"]
    - [timer_name_eq_timer,
       "Timer.__name__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — the Timer class name is 'Timer'; it represents an action scheduled to run after a time delay in a separate thread; str.__eq__('Timer') returns True; new to extra160"]
    - [timer_bases_len_eq_1,
       "Timer.__bases__.__len__",
       [],
       1,
       "threading.Timer.__bases__.__len__() == 1 — Timer inherits from exactly one base class (Thread); __bases__ is a tuple with one element; tuple.__len__() returns 1; new to extra160"]

# ---------------------------------------------------------------------------
# Table 2: threading.current_thread and threading.main_thread function identity
#
# Wave 288 theme: threading.current_thread and threading.main_thread function
# identity — __class__.__name__ and __module__.
#
# threading.current_thread.__class__.__name__ == 'function'
# threading.current_thread.__module__ == 'threading'
# threading.main_thread.__class__.__name__ == 'function'
# threading.main_thread.__module__ == 'threading'
#
# current_thread() returns the Thread object corresponding to the caller's
# thread of control. main_thread() returns the Thread object corresponding to
# the main thread. Both are Python functions defined in Lib/threading.py.
# As Python function objects their __class__.__name__ is 'function' and
# their __module__ is 'threading'. New to extra160.
# ---------------------------------------------------------------------------

table threading_extra160.current_and_main_thread_identity:
  description: "threading.current_thread: __class__.__name__ 'function', __module__ 'threading'; threading.main_thread: __class__.__name__ 'function', __module__ 'threading'; wave 288; new to extra160"
  kind: python_call_eq
  category: identity
  id_prefix: threadingcmti160

  columns: [id, function, args, expected, description]
  rows:
    - [current_thread_cls_name_eq_function,
       "current_thread.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.current_thread.__class__.__name__.__eq__('function') == True — current_thread is a Python function defined in Lib/threading.py that returns the Thread object for the caller's thread of control; as a Python function object its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra160"]
    - [current_thread_module_eq_threading,
       "current_thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.current_thread.__module__.__eq__('threading') == True — current_thread is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra160"]
    - [main_thread_cls_name_eq_function,
       "main_thread.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.main_thread.__class__.__name__.__eq__('function') == True — main_thread is a Python function defined in Lib/threading.py that returns the Thread object corresponding to the main thread of the process; as a Python function object its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra160"]
    - [main_thread_module_eq_threading,
       "main_thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.main_thread.__module__.__eq__('threading') == True — main_thread is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra160"]

