spec: antigravity
version: ">=3.0"
backend: python_module(antigravity)

docs: https://docs.python.org/3/library/antigravity.html

provenance:
  derived_from:
    - "CPython source — Lib/antigravity.py (PSF; source inspection permitted)"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "antigravity: xkcd comic at https://xkcd.com/353/"
  notes:
    - "antigravity is a Python easter egg module: importing it opens https://xkcd.com/353/ in a browser."
    - "Beyond the side effect, the module exposes one public function: geohash(latitude, longitude, datedow)."
    - "geohash implements the Geohashing algorithm from xkcd comic #426."
    - "geohash accepts 3 positional arguments: latitude (float), longitude (float), datedow (bytes)."
    - "geohash.__code__.co_argcount == 3 confirms the three-parameter signature."
    - "antigravity.__doc__ is a str (the module docstring, which may be None or a string depending on version)."
    - "All expected values verified by running Python 3.12 antigravity module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "geohash raises no documented exceptions for valid inputs. Import side-effect opens a browser tab."
  stderr: "null"
  stickiness: "N/A — function attribute checks are stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Function name and module checks — geohash
# ---------------------------------------------------------------------------

invariant antigravity.geohash_name:
  description: "geohash.__name__ == 'geohash'"
  category: functions
  kind: python_call_eq
  function: geohash.__name__.__eq__
  args: ["geohash"]
  expected: true

invariant antigravity.geohash_module:
  description: "geohash.__module__ == 'antigravity'"
  category: functions
  kind: python_call_eq
  function: geohash.__module__.__eq__
  args: ["antigravity"]
  expected: true

# ---------------------------------------------------------------------------
# Signature check — geohash takes 3 arguments
# ---------------------------------------------------------------------------

invariant antigravity.geohash_argcount:
  description: "geohash.__code__.co_argcount == 3"
  category: signature
  kind: python_call_eq
  function: geohash.__code__.co_argcount.__eq__
  args: [3]
  expected: true

# ---------------------------------------------------------------------------
# Module attribute type checks
# ---------------------------------------------------------------------------

invariant antigravity.geohash_qualname:
  description: "geohash.__qualname__ == 'geohash'"
  category: attributes
  kind: python_call_eq
  function: geohash.__qualname__.__eq__
  args: ["geohash"]
  expected: true

invariant antigravity.geohash_class_name:
  description: "geohash.__class__.__name__ == 'function'"
  category: attributes
  kind: python_call_eq
  function: geohash.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# geohash code object attribute checks
# ---------------------------------------------------------------------------

invariant antigravity.geohash_code_name:
  description: "geohash.__code__.co_name == 'geohash'"
  category: code_object
  kind: python_call_eq
  function: geohash.__code__.co_name.__eq__
  args: ["geohash"]
  expected: true

invariant antigravity.geohash_code_varcount:
  description: "geohash.__code__.co_nlocals >= 3 (at least 3 local variables covering the parameters)"
  category: code_object
  kind: python_call_eq
  function: geohash.__code__.co_nlocals.__ge__
  args: [3]
  expected: true

invariant antigravity.geohash_defaults_none:
  description: "geohash has no default arguments — __defaults__ is None"
  category: signature
  kind: python_call_eq
  function: geohash.__defaults__.__eq__
  args: [null]
  expected: true
