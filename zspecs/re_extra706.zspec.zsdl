spec: re_extra706
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers re module top-level function qualnames: compile, search, match, fullmatch, findall, finditer, sub, subn, split"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra706.function_identity:
  description: "Identity checks for re module top-level function qualnames and module attributes"
  kind: python_call_eq
  category: function_identity
  id_prefix: re706fi
  columns: [id, function, args, expected]
  rows:
    - [re706fi001, re.compile.__qualname__.__eq__, ["compile"], true]
    - [re706fi002, re.compile.__module__.__eq__, ["re"], true]
    - [re706fi003, re.search.__qualname__.__eq__, ["search"], true]
    - [re706fi004, re.search.__module__.__eq__, ["re"], true]
    - [re706fi005, re.match.__qualname__.__eq__, ["match"], true]
    - [re706fi006, re.match.__module__.__eq__, ["re"], true]
    - [re706fi007, re.fullmatch.__qualname__.__eq__, ["fullmatch"], true]
    - [re706fi008, re.findall.__qualname__.__eq__, ["findall"], true]
    - [re706fi009, re.finditer.__qualname__.__eq__, ["finditer"], true]
    - [re706fi010, re.sub.__qualname__.__eq__, ["sub"], true]
    - [re706fi011, re.subn.__qualname__.__eq__, ["subn"], true]
    - [re706fi012, re.split.__qualname__.__eq__, ["split"], true]
