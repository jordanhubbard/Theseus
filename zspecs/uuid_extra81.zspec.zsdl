spec: uuid_extra81
version: ">=3.9"
extends: uuid_extra80
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra80.zspec.zsdl — covers UUID property __class__.__name__ identity for hex/bytes/bytes_le/fields/time_low/time_mid/variant/version / SafeUUID class identity (__name__/__module__/__qualname__/__bases__[0].__name__) / SafeUUID.__mro__.__len__()==3 (table + invariants)."
    - "uuid_extra79.zspec.zsdl — covers UUID dunder method __qualname__.__eq__ for __init__/__str__/__repr__/__eq__/__hash__/__int__/__lt__/__setattr__ / uuid1/uuid3/uuid4/uuid5 __qualname__.__eq__ / UUID.__name__/__module__.__eq__ (table + invariants)."
    - "uuid_extra78.zspec.zsdl — covers UUID.__dict__.__contains__ for __init__/__str__/__repr__/__eq__/__hash__/int/hex/bytes/variant/version (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra80; it does NOT duplicate invariants present in those files."
    - "Wave 255 theme: uuid.UUID.__dict__ additional membership — comparison methods and field properties."
    - "uuid.UUID.__dict__.__contains__('__lt__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__gt__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__le__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__ge__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('time_low') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('time_mid') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('clock_seq_hi_variant') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('clock_seq_low') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('node') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('urn') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('bytes_le') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('fields') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__lt__') == True
# uuid.UUID.__dict__.__contains__('__gt__') == True
# uuid.UUID.__dict__.__contains__('__le__') == True
# uuid.UUID.__dict__.__contains__('__ge__') == True
#
# Wave 255 theme: UUID.__dict__ comparison method membership.
#
# UUID defines __lt__, __gt__, __le__, __ge__ as Python functions in uuid.py
# for ordering support. These are all present in UUID.__dict__. uuid_extra78
# anchors __eq__ and __hash__ membership; this table anchors the inequality
# comparison methods under the new id_prefix uuiddictextra81.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra81.uuid_dict_comparison_methods:
  description: "uuid.UUID.__dict__.__contains__('__lt__')==True / UUID.__dict__.__contains__('__gt__')==True / UUID.__dict__.__contains__('__le__')==True / UUID.__dict__.__contains__('__ge__')==True — UUID defines all four ordering comparison methods (__lt__/__gt__/__le__/__ge__) as Python functions in uuid.py; uuid_extra78 anchors __eq__ and __hash__; this table anchors the four ordering methods under uuiddictextra81; first uuiddictextra81 anchor for UUID comparison method dict membership"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuiddictextra81

  columns: [id, function, args, expected]
  rows:
    - [uuid_dict_lt,  "UUID.__dict__.__contains__", ["__lt__"], true]
    - [uuid_dict_gt,  "UUID.__dict__.__contains__", ["__gt__"], true]
    - [uuid_dict_le,  "UUID.__dict__.__contains__", ["__le__"], true]
    - [uuid_dict_ge,  "UUID.__dict__.__contains__", ["__ge__"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('time_low') == True
# uuid.UUID.__dict__.__contains__('time_mid') == True
# uuid.UUID.__dict__.__contains__('clock_seq_hi_variant') == True
# uuid.UUID.__dict__.__contains__('clock_seq_low') == True
#
# Wave 255 theme: UUID.__dict__ field property membership (group 1).
#
# time_low, time_mid, clock_seq_hi_variant, and clock_seq_low are Python property
# descriptors on UUID corresponding to RFC 4122 UUID field decomposition.
# uuid_extra80 anchors their __class__.__name__=='property'; this table anchors
# their __dict__ membership under uuiddictextra81.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra81.uuid_dict_field_props_group1:
  description: "uuid.UUID.__dict__.__contains__('time_low')==True / UUID.__dict__.__contains__('time_mid')==True / UUID.__dict__.__contains__('clock_seq_hi_variant')==True / UUID.__dict__.__contains__('clock_seq_low')==True — time_low/time_mid/clock_seq_hi_variant/clock_seq_low are property descriptors on UUID representing RFC 4122 timestamp and clock-sequence fields; uuid_extra80 anchors their __class__.__name__=='property'; this table anchors their dict membership under uuiddictextra81; first uuiddictextra81 anchor for UUID field property dict membership"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuiddictextra81

  columns: [id, function, args, expected]
  rows:
    - [uuid_dict_time_low,            "UUID.__dict__.__contains__", ["time_low"],            true]
    - [uuid_dict_time_mid,            "UUID.__dict__.__contains__", ["time_mid"],            true]
    - [uuid_dict_clock_seq_hi_var,    "UUID.__dict__.__contains__", ["clock_seq_hi_variant"], true]
    - [uuid_dict_clock_seq_low,       "UUID.__dict__.__contains__", ["clock_seq_low"],       true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('node') == True
# uuid.UUID.__dict__.__contains__('urn') == True
# uuid.UUID.__dict__.__contains__('bytes_le') == True
# uuid.UUID.__dict__.__contains__('fields') == True
#
# Wave 255 theme: UUID.__dict__ field property membership (group 2).
#
# node, urn, bytes_le, and fields are Python property descriptors on UUID.
# node provides the 48-bit hardware address; urn provides the URN string form;
# bytes_le provides the little-endian byte layout; fields returns the 6-tuple
# of RFC 4122 fields. uuid_extra80 anchors their __class__.__name__=='property';
# this table anchors their dict membership.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra81.uuid_dict_field_props_group2:
  description: "uuid.UUID.__dict__.__contains__('node')==True / UUID.__dict__.__contains__('urn')==True / UUID.__dict__.__contains__('bytes_le')==True / UUID.__dict__.__contains__('fields')==True — node/urn/bytes_le/fields are property descriptors on UUID; uuid_extra80 anchors their __class__.__name__=='property'; this table anchors their dict membership under uuiddictextra81; first uuiddictextra81 anchor for node/urn/bytes_le/fields dict membership"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuiddictextra81

  columns: [id, function, args, expected]
  rows:
    - [uuid_dict_node,      "UUID.__dict__.__contains__", ["node"],     true]
    - [uuid_dict_urn,       "UUID.__dict__.__contains__", ["urn"],      true]
    - [uuid_dict_bytes_le,  "UUID.__dict__.__contains__", ["bytes_le"], true]
    - [uuid_dict_fields,    "UUID.__dict__.__contains__", ["fields"],   true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__lt__') (cross-check)
# uuid.UUID.__dict__.__contains__('time_low') (cross-check)
# uuid.UUID.__dict__.__contains__('node') (cross-check)
# uuid.UUID.__dict__.__contains__('fields') (cross-check)
#
# Wave 255 theme: UUID dict membership cross-check table.
#
# Cross-checks anchor one row from each of the three primary tables above
# in a single table to confirm consistency. All are True.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra81.uuid_dict_cross_check:
  description: "uuid.UUID.__dict__.__contains__('__lt__')==True / UUID.__dict__.__contains__('time_low')==True / UUID.__dict__.__contains__('node')==True / UUID.__dict__.__contains__('fields')==True — cross-check table anchoring one representative from each of the comparison-method, field-property-group1, and field-property-group2 tables; confirms all three categories of UUID.__dict__ membership are consistent; first uuiddictextra81 cross-check anchor"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuiddictextra81

  columns: [id, function, args, expected]
  rows:
    - [uuid_dict_lt2,       "UUID.__dict__.__contains__", ["__lt__"],   true]
    - [uuid_dict_time_low2, "UUID.__dict__.__contains__", ["time_low"], true]
    - [uuid_dict_node2,     "UUID.__dict__.__contains__", ["node"],     true]
    - [uuid_dict_fields2,   "UUID.__dict__.__contains__", ["fields"],   true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__lt__') == True — standalone
#
# UUID.__dict__ contains '__lt__'. UUID implements rich comparison for ordering.
# uuid_extra78 anchors __eq__ and __hash__ membership but not the ordering
# methods. First __dict__.__contains__('__lt__') standalone for uuid.UUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra81.uuid_dict_lt:
  description: "uuid.UUID.__dict__.__contains__('__lt__') == True — UUID defines __lt__ as a Python function in uuid.py to support ordering (UUIDs sort by integer value); uuid_extra78 anchors __eq__/__hash__ but not the ordering methods; first __dict__.__contains__('__lt__') standalone for uuid.UUID under uuiddictextra81"
  category: class_attrs
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["__lt__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__ge__') == True — standalone
#
# UUID.__dict__ contains '__ge__'. UUID implements all four ordering comparisons.
# No prior uuid spec anchors __ge__ dict membership. First '__ge__' standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra81.uuid_dict_ge:
  description: "uuid.UUID.__dict__.__contains__('__ge__') == True — UUID defines __ge__ as a Python function for ordering support; uuid_extra78 anchors __eq__/__hash__; this standalone anchors __ge__ membership; first __dict__.__contains__('__ge__') standalone for uuid.UUID under uuiddictextra81"
  category: class_attrs
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["__ge__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('clock_seq_hi_variant') == True — standalone
#
# UUID.__dict__ contains 'clock_seq_hi_variant'. This property provides
# the clock_seq_hi_variant field of the UUID as defined in RFC 4122.
# No prior uuid spec anchors clock_seq_hi_variant dict membership.
# First standalone for clock_seq_hi_variant.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra81.uuid_dict_clock_seq_hi_variant:
  description: "uuid.UUID.__dict__.__contains__('clock_seq_hi_variant') == True — clock_seq_hi_variant is a property descriptor on UUID exposing the RFC 4122 clock_seq_hi_and_reserved field; no prior uuid spec anchors this dict membership; first standalone for uuid.UUID clock_seq_hi_variant under uuiddictextra81"
  category: class_attrs
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["clock_seq_hi_variant"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('urn') == True — standalone
#
# UUID.__dict__ contains 'urn'. The urn property returns the UUID in URN
# format ('urn:uuid:...'). No prior uuid spec anchors urn dict membership.
# First standalone for urn.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra81.uuid_dict_urn:
  description: "uuid.UUID.__dict__.__contains__('urn') == True — urn is a property descriptor on UUID that returns the URN string form 'urn:uuid:<hex>'; uuid_extra80 anchors urn.__class__.__name__=='property'; this standalone anchors the dict membership; first __dict__.__contains__('urn') standalone for uuid.UUID under uuiddictextra81"
  category: class_attrs
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["urn"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('bytes_le') == True — standalone
#
# UUID.__dict__ contains 'bytes_le'. The bytes_le property returns the UUID
# as 16 bytes in little-endian format. No prior uuid spec anchors bytes_le
# dict membership. First standalone for bytes_le.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra81.uuid_dict_bytes_le:
  description: "uuid.UUID.__dict__.__contains__('bytes_le') == True — bytes_le is a property descriptor on UUID returning the 16-byte little-endian representation; uuid_extra80 anchors bytes_le.__class__.__name__=='property'; this standalone anchors the dict membership; first __dict__.__contains__('bytes_le') standalone for uuid.UUID under uuiddictextra81"
  category: class_attrs
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["bytes_le"]
  expected: true
