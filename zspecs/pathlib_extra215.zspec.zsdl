spec: pathlib_extra215
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath construction, components, joining, manipulation"
    - "pathlib_extra.zspec.zsdl — covers PurePosixPath predicates and string representations"
  notes:
    - "pathlib.PurePath.__dict__ contains the property descriptors: parent, parents, parts, stem, suffix, suffixes, name."
    - "pathlib.PurePath is the abstract base for all pure path classes; its __dict__ holds property objects, not bound methods."
    - "pathlib.PurePosixPath.__dict__ has exactly 6 keys: __module__, __firstlineno__, __doc__, parser, __slots__, __static_attributes__."
    - "pathlib.PurePosixPath.__dict__.__len__() == 6; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__dict__.__contains__('parent') == True; parent is a property defined on PurePath; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__dict__.__contains__('parents') == True; parents is a property defined on PurePath; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__dict__.__contains__('parts') == True; parts is a property defined on PurePath; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__dict__.__contains__('stem') == True; stem is a property defined on PurePath; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__dict__.__contains__('suffix') == True; suffix is a property defined on PurePath; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__dict__.__contains__('suffixes') == True; suffixes is a property defined on PurePath; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.PurePath.__dict__ membership — path component properties
# parent, parents, parts, stem, suffix are property descriptors on PurePath
# ---------------------------------------------------------------------------

table pathlib_extra215.purepath_dict_components:
  description: "pathlib.PurePath.__dict__ contains path-component property descriptors"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibpure215

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_has_parent,   "pathlib.PurePath.__dict__.__contains__",  ["parent"],   true,  "pathlib.PurePath.__dict__.__contains__('parent') == True; parent is a property descriptor on PurePath; confirmed Python 3.14.3 macOS"]
    - [purepath_has_parents,  "pathlib.PurePath.__dict__.__contains__",  ["parents"],  true,  "pathlib.PurePath.__dict__.__contains__('parents') == True; parents is a property descriptor on PurePath; confirmed Python 3.14.3 macOS"]
    - [purepath_has_parts,    "pathlib.PurePath.__dict__.__contains__",  ["parts"],    true,  "pathlib.PurePath.__dict__.__contains__('parts') == True; parts is a property descriptor on PurePath; confirmed Python 3.14.3 macOS"]
    - [purepath_has_stem,     "pathlib.PurePath.__dict__.__contains__",  ["stem"],     true,  "pathlib.PurePath.__dict__.__contains__('stem') == True; stem is a property descriptor on PurePath; confirmed Python 3.14.3 macOS"]
    - [purepath_has_suffix,   "pathlib.PurePath.__dict__.__contains__",  ["suffix"],   true,  "pathlib.PurePath.__dict__.__contains__('suffix') == True; suffix is a property descriptor on PurePath; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.PurePath.__dict__ membership — more path properties
# suffixes and name are also property descriptors on PurePath
# ---------------------------------------------------------------------------

table pathlib_extra215.purepath_dict_more_properties:
  description: "pathlib.PurePath.__dict__ contains suffixes and name property descriptors"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibpure215

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_has_suffixes,  "pathlib.PurePath.__dict__.__contains__",  ["suffixes"],  true,  "pathlib.PurePath.__dict__.__contains__('suffixes') == True; suffixes is a property descriptor on PurePath; confirmed Python 3.14.3 macOS"]
    - [purepath_has_name,      "pathlib.PurePath.__dict__.__contains__",  ["name"],      true,  "pathlib.PurePath.__dict__.__contains__('name') == True; name is a property descriptor on PurePath; confirmed Python 3.14.3 macOS"]
    - [purepath_no_read,       "pathlib.PurePath.__dict__.__contains__",  ["read"],      false, "pathlib.PurePath.__dict__.__contains__('read') == False; read is not a PurePath attribute; confirmed Python 3.14.3 macOS"]
    - [purepath_no_write,      "pathlib.PurePath.__dict__.__contains__",  ["write"],     false, "pathlib.PurePath.__dict__.__contains__('write') == False; write is not a PurePath attribute; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.PurePosixPath.__dict__ — lightweight subclass dict
# PurePosixPath adds only minimal subclass-specific keys to __dict__
# Its __dict__ has exactly 6 entries: __module__, __firstlineno__, __doc__,
# parser, __slots__, __static_attributes__
# ---------------------------------------------------------------------------

table pathlib_extra215.pureposixpath_dict_keys:
  description: "pathlib.PurePosixPath.__dict__ key membership for subclass-specific keys"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibpure215

  columns: [id, function, args, expected, description]
  rows:
    - [pureposix_has_module,   "pathlib.PurePosixPath.__dict__.__contains__",  ["__module__"],  true,  "pathlib.PurePosixPath.__dict__.__contains__('__module__') == True; __module__ is present in PurePosixPath.__dict__; confirmed Python 3.14.3 macOS"]
    - [pureposix_has_doc,      "pathlib.PurePosixPath.__dict__.__contains__",  ["__doc__"],     true,  "pathlib.PurePosixPath.__dict__.__contains__('__doc__') == True; __doc__ is present in PurePosixPath.__dict__; confirmed Python 3.14.3 macOS"]
    - [pureposix_has_slots,    "pathlib.PurePosixPath.__dict__.__contains__",  ["__slots__"],   true,  "pathlib.PurePosixPath.__dict__.__contains__('__slots__') == True; __slots__ is present in PurePosixPath.__dict__; confirmed Python 3.14.3 macOS"]
    - [pureposix_dict_len,     "pathlib.PurePosixPath.__dict__.__len__",        [],              6,     "pathlib.PurePosixPath.__dict__.__len__() == 6; PurePosixPath adds exactly 6 keys to its __dict__; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra215.purepath_has_parent:
  description: "pathlib.PurePath.__dict__.__contains__('parent') == True — parent is a property descriptor on PurePath; confirmed Python 3.14.3 macOS"
  category: dict_membership
  kind: python_call_eq
  function: "pathlib.PurePath.__dict__.__contains__"
  args: ["parent"]
  expected: true

