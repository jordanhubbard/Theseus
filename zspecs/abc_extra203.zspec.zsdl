spec: abc_extra203
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py (frozen as <frozen abc>)"
  notes:
    - "abc.abstractmethod.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple; abstractmethod co_varnames is ('funcobj',) on Python 3.14.3 (length 1)."
    - "abc.abstractmethod.__code__.co_varnames.__contains__('funcobj') returns True — 'funcobj' is the sole parameter of abstractmethod(funcobj); the parameter was renamed from 'func' in earlier Python versions."
    - "abc.ABCMeta.__dict__.__contains__('register') returns True — ABCMeta.register() is defined directly on the metaclass; it registers a virtual subclass."
    - "abc.ABCMeta.__dict__.__contains__('__instancecheck__') returns True — ABCMeta overrides __instancecheck__ to support isinstance() delegation to virtual subclasses."
    - "abc.ABC.__dict__.__contains__('__doc__') returns True — ABC.__doc__ is set in the class body; it is present in ABC.__dict__."
    - "abc.ABCMeta.__dict__ keys: __module__, __firstlineno__, __doc__, __new__, register, __instancecheck__, __subclasscheck__, _dump_registry, _abc_registry_clear, _abc_caches_clear, __static_attributes__."
    - "abc.ABC.__dict__ keys: __module__, __firstlineno__, __doc__, __slots__, __static_attributes__, __abstractmethods__, _abc_impl."
    - "abc.ABC.__dict__ does NOT contain '__subclasshook__' — __subclasshook__ is defined on ABCMeta-created classes via the metaclass machinery, not stored directly in ABC.__dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.abstractmethod co_varnames type and membership checks
#
# abc.abstractmethod.__code__.co_varnames.__class__.__name__  == 'tuple'
# abc.abstractmethod.__code__.co_varnames.__contains__('funcobj') == True
# abc.abstractmethod.__code__.co_varnames.__len__()           == 1
# ---------------------------------------------------------------------------

table abc_extra203.abstractmethod_covarnames:
  description: "abc.abstractmethod __code__.co_varnames type and membership checks in abccovarnames203 namespace — abstractmethod.__code__.co_varnames.__class__.__name__=='tuple' (co_varnames is always a tuple of parameter and local variable name strings); co_varnames.__contains__('funcobj')==True ('funcobj' is the sole parameter of abc.abstractmethod(funcobj); the parameter name was 'func' in earlier versions); co_varnames.__len__()==1 (abstractmethod takes exactly one parameter and defines no local variables — it simply sets __isabstractmethod__=True and returns the function); full co_varnames on 3.14.3 is ('funcobj',); verified with Python 3.14.3"
  kind: python_call_eq
  category: covarnames
  id_prefix: abccovarnames203

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_covarnames_class_name, abc.abstractmethod.__code__.co_varnames.__class__.__name__.__eq__,   ["tuple"],   true, "abc.abstractmethod.__code__.co_varnames.__class__.__name__ == 'tuple'; verified Python 3.14.3"]
    - [abstractmethod_covarnames_has_funcobj, abc.abstractmethod.__code__.co_varnames.__contains__,               ["funcobj"], true, "abc.abstractmethod.__code__.co_varnames.__contains__('funcobj') — sole parameter; verified Python 3.14.3"]
    - [abstractmethod_covarnames_len,         abc.abstractmethod.__code__.co_varnames.__len__,                    [],          1,    "abc.abstractmethod.__code__.co_varnames.__len__() == 1 (only 'funcobj'); verified Python 3.14.3"]
    - [abcmeta_dict_has_register,             abc.ABCMeta.__dict__.__contains__,                                  ["register"], true, "abc.ABCMeta.__dict__.__contains__('register') == True; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABCMeta.__dict__ membership checks
#
# abc.ABCMeta.__dict__.__contains__('register')          == True
# abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True
# abc.ABCMeta.__dict__.__contains__('__subclasscheck__') == True
# abc.ABCMeta.__dict__.__contains__('__new__')           == True
# ---------------------------------------------------------------------------

table abc_extra203.abcmeta_dict_membership:
  description: "abc.ABCMeta.__dict__ membership checks in abccovarnames203 namespace — ABCMeta.__dict__.__contains__('register')==True (ABCMeta.register(cls, subclass) registers a virtual subclass; allows isinstance(obj, cls) to return True for subclass even without inheritance); ABCMeta.__dict__.__contains__('__instancecheck__')==True (ABCMeta overrides __instancecheck__ to consult the virtual subclass registry when isinstance() is called); ABCMeta.__dict__.__contains__('__subclasscheck__')==True (ABCMeta overrides __subclasscheck__ to consult the registry for issubclass()); ABCMeta.__dict__.__contains__('__new__')==True (ABCMeta.__new__ initialises the abstract method machinery); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: abccovarnames203a

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_dict_has_register,          abc.ABCMeta.__dict__.__contains__,   ["register"],          true, "abc.ABCMeta.__dict__.__contains__('register') == True; verified Python 3.14.3"]
    - [abcmeta_dict_has_instancecheck,     abc.ABCMeta.__dict__.__contains__,   ["__instancecheck__"], true, "abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True; verified Python 3.14.3"]
    - [abcmeta_dict_has_subclasscheck,     abc.ABCMeta.__dict__.__contains__,   ["__subclasscheck__"], true, "abc.ABCMeta.__dict__.__contains__('__subclasscheck__') == True; verified Python 3.14.3"]
    - [abcmeta_dict_has_new,               abc.ABCMeta.__dict__.__contains__,   ["__new__"],           true, "abc.ABCMeta.__dict__.__contains__('__new__') == True; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: abc.ABC.__dict__ membership checks
#
# abc.ABC.__dict__.__contains__('__doc__')              == True
# abc.ABC.__dict__.__contains__('__abstractmethods__')  == True
# abc.ABC.__dict__.__contains__('__slots__')            == True
# abc.ABC.__dict__.__contains__('_abc_impl')            == True
# ---------------------------------------------------------------------------

table abc_extra203.abc_dict_membership:
  description: "abc.ABC.__dict__ membership checks in abccovarnames203 namespace — ABC.__dict__.__contains__('__doc__')==True (ABC.__doc__ is set in the class body and stored in ABC.__dict__); ABC.__dict__.__contains__('__abstractmethods__')==True (ABC.__abstractmethods__ is an empty frozenset stored directly in ABC.__dict__; it represents the set of abstract methods that must be implemented by concrete subclasses); ABC.__dict__.__contains__('__slots__')==True (ABC defines __slots__=() to prevent a __dict__ instance attribute on ABC instances); ABC.__dict__.__contains__('_abc_impl')==True (_abc_impl is the C-level ABCData object installed by ABCMeta.__new__ to store the virtual subclass registry); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: abccovarnames203b

  columns: [id, function, args, expected, description]
  rows:
    - [abc_dict_has_doc,               abc.ABC.__dict__.__contains__,   ["__doc__"],             true, "abc.ABC.__dict__.__contains__('__doc__') == True; verified Python 3.14.3"]
    - [abc_dict_has_abstractmethods,   abc.ABC.__dict__.__contains__,   ["__abstractmethods__"], true, "abc.ABC.__dict__.__contains__('__abstractmethods__') == True; verified Python 3.14.3"]
    - [abc_dict_has_slots,             abc.ABC.__dict__.__contains__,   ["__slots__"],           true, "abc.ABC.__dict__.__contains__('__slots__') == True; verified Python 3.14.3"]
    - [abc_dict_has_abc_impl,          abc.ABC.__dict__.__contains__,   ["_abc_impl"],           true, "abc.ABC.__dict__.__contains__('_abc_impl') == True; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra203
# ---------------------------------------------------------------------------

invariant abc_extra203.abstractmethod_covarnames_class_name_tuple:
  description: "abc.abstractmethod.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — abc.abstractmethod.__code__.co_varnames is always a tuple of parameter and local variable name strings; abstractmethod co_varnames on Python 3.14.3 is ('funcobj',) (length 1); co_varnames.__class__.__name__ is 'tuple' (len=5: t-u-p-l-e); the tuple has exactly one entry because abstractmethod takes one parameter and uses no local variables; NEW in extra203: first standalone abc.abstractmethod co_varnames class name invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: covarnames
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant abc_extra203.abstractmethod_covarnames_contains_funcobj:
  description: "abc.abstractmethod.__code__.co_varnames.__contains__('funcobj') returns True — 'funcobj' is the sole parameter of abc.abstractmethod(funcobj); abstractmethod sets funcobj.__isabstractmethod__ = True and returns funcobj; the parameter was renamed from 'func' to 'funcobj' at some point in Python's history; co_varnames is ('funcobj',) on Python 3.14.3 — it has exactly one entry; NEW in extra203; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: covarnames
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_varnames.__contains__
  args: ["funcobj"]
  expected: true

invariant abc_extra203.abcmeta_dict_contains_register:
  description: "abc.ABCMeta.__dict__.__contains__('register') returns True — abc.ABCMeta defines register() directly in its class body in the frozen abc module; ABCMeta.register(cls, subclass) registers subclass as a virtual subclass of cls, making isinstance(obj, cls) return True for instances of subclass even without inheritance; 'register' is in ABCMeta.__dict__ (not inherited); NEW in extra203; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["register"]
  expected: true

invariant abc_extra203.abcmeta_dict_contains_instancecheck:
  description: "abc.ABCMeta.__dict__.__contains__('__instancecheck__') returns True — abc.ABCMeta overrides __instancecheck__ to support isinstance() delegation; when isinstance(obj, cls) is called and cls uses ABCMeta, Python calls cls.__class__.__instancecheck__(cls, obj) which consults the virtual subclass registry registered via ABCMeta.register(); 'register' and '__instancecheck__' are both in ABCMeta.__dict__; NEW in extra203; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__instancecheck__"]
  expected: true

invariant abc_extra203.abc_dict_contains_doc:
  description: "abc.ABC.__dict__.__contains__('__doc__') returns True — abc.ABC.__doc__ is set in the class body and stored directly in ABC.__dict__; __doc__ is present in ABC.__dict__ as a plain str (or None); it is distinct from __abstractmethods__ and _abc_impl which are also in ABC.__dict__; abc.ABC is a helper class providing a concise way to define abstract classes using inheritance; 'abc.ABC.__dict__' contains exactly: __module__, __firstlineno__, __doc__, __slots__, __static_attributes__, __abstractmethods__, _abc_impl; NEW in extra203; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: abc.ABC.__dict__.__contains__
  args: ["__doc__"]
  expected: true

invariant abc_extra203.abstractmethod_covarnames_len_one:
  description: "abc.abstractmethod.__code__.co_varnames.__len__() returns 1 — abstractmethod co_varnames has exactly 1 entry on Python 3.14.3: ('funcobj',); abstractmethod takes one parameter and defines no local variables (it simply sets __isabstractmethod__=True on funcobj and returns it); len==1 makes abstractmethod the minimal non-trivial Python function in the abc module by co_varnames length; compare: abc.ABCMeta.__new__ has more parameters; NEW in extra203; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: covarnames
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_varnames.__len__
  args: []
  expected: 1

invariant abc_extra203.abc_dict_contains_abstractmethods:
  description: "abc.ABC.__dict__.__contains__('__abstractmethods__') returns True — abc.ABC.__abstractmethods__ is an empty frozenset stored directly in ABC.__dict__; it records the set of unimplemented abstract methods; for ABC itself the set is empty (frozenset()) because ABC has no abstract methods declared in its body; ABCMeta.__new__ installs __abstractmethods__ on every class created with ABCMeta as its metaclass; '__abstractmethods__' is in ABC.__dict__; NEW in extra203; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: abc.ABC.__dict__.__contains__
  args: ["__abstractmethods__"]
  expected: true

invariant abc_extra203.abcmeta_dict_contains_subclasscheck:
  description: "abc.ABCMeta.__dict__.__contains__('__subclasscheck__') returns True — abc.ABCMeta overrides __subclasscheck__ to support issubclass() delegation; when issubclass(sub, cls) is called and cls uses ABCMeta, Python calls cls.__class__.__subclasscheck__(cls, sub) which consults the virtual subclass registry; '__subclasscheck__' is in ABCMeta.__dict__ alongside '__instancecheck__' and 'register'; NEW in extra203; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__subclasscheck__"]
  expected: true

