spec: cmath_extra11
version: ">=3.9"
backend: python_module(cmath)

docs: https://docs.python.org/3/library/cmath.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cmath.html — Python cmath module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/cmathmodule.c"
  notes:
    - "This spec extends cmath.zspec.zsdl and prior extras through cmath_extra10.zspec.zsdl."
    - "cmath_extra3 covers __qualname__.__eq__ for sqrt/exp/log/sin/cos/tan/phase/polar/rect/isnan/isinf/isfinite/isclose."
    - "cmath_extra10 covers __qualname__.__eq__ for asin/acos/atan/sinh/cosh/tanh."
    - "No prior cmath spec checks __qualname__.__len__() for any function."
    - "cmath.sin.__qualname__.__len__() == 3 — len('sin')."
    - "cmath.cos.__qualname__.__len__() == 3 — len('cos')."
    - "cmath.exp.__qualname__.__len__() == 3 — len('exp')."
    - "cmath.log.__qualname__.__len__() == 3 — len('log')."
    - "cmath.sqrt.__qualname__.__len__() == 4 — len('sqrt')."
    - "cmath.phase.__qualname__.__len__() == 5 — len('phase')."
    - "cmath.polar.__qualname__.__len__() == 5 — len('polar')."
    - "cmath.rect.__qualname__.__len__() == 4 — len('rect')."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# cmath function __qualname__.__len__() table
#
# cmath_extra3 and cmath_extra10 cover __qualname__.__eq__ for all major cmath
# functions. No prior cmath spec checks __qualname__.__len__() for any function.
# For C builtins at module level, __qualname__ == __name__, so the qualname
# length equals the function name length. This table anchors qualname lengths
# for the core cmath functions: the 3-letter functions (sin/cos/exp/log) have
# length 3; sqrt and rect have length 4; phase and polar have length 5.
# ---------------------------------------------------------------------------

table cmath_extra11.function_qualname_lengths:
  description: "__qualname__.__len__() for core cmath builtin functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: cqlen11

  columns: [id, function, args, expected]
  rows:
    - [sin,   sin.__qualname__.__len__,   [], 3]
    - [cos,   cos.__qualname__.__len__,   [], 3]
    - [exp,   exp.__qualname__.__len__,   [], 3]
    - [log,   log.__qualname__.__len__,   [], 3]
    - [sqrt,  sqrt.__qualname__.__len__,  [], 4]
    - [rect,  rect.__qualname__.__len__,  [], 4]
    - [phase, phase.__qualname__.__len__, [], 5]
    - [polar, polar.__qualname__.__len__, [], 5]
