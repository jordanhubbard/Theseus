spec: itertools_extra213
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools_extra212.zspec.zsdl — covers itertools __qualname__ equality and length checks"
    - "itertools.zspec.zsdl — covers core itertools function behavior"
  notes:
    - "itertools.chain.__doc__.__contains__('chain') == True — the chain docstring says 'Return a chain object'; the word 'chain' appears in the text. Verified with Python 3.14.3."
    - "itertools.cycle.__doc__.__contains__('cycle') == False — the cycle docstring says 'Return elements from the iterable until it is exhausted. Then repeat the sequence indefinitely.' — the word 'cycle' does NOT appear. Verified with Python 3.14.3."
    - "itertools.cycle.__doc__.__contains__('exhausted') == True — the cycle docstring says 'until it is exhausted'. Verified with Python 3.14.3."
    - "itertools.product.__doc__.__contains__('product') == True — the product docstring says 'product(A, B)' in the example text. Verified with Python 3.14.3."
    - "itertools.combinations.__doc__.__contains__('combinations') == True — the combinations docstring says 'combinations(range(4), 3)' in the example. Verified with Python 3.14.3."
    - "itertools.groupby.__doc__.__contains__('groupby') == False — the groupby docstring describes making an iterator for consecutive keys and groups but does not mention 'groupby' by name. Verified with Python 3.14.3."
    - "itertools.groupby.__doc__.__contains__('key') == True — the groupby docstring mentions the key argument. Verified with Python 3.14.3."
    - "itertools.islice.__doc__.__contains__('islice') == True — the islice docstring opens with 'islice(iterable, stop)'. Verified with Python 3.14.3."
    - "itertools.accumulate.__doc__.__contains__('accumulate') == True — the accumulate docstring says 'Return series of accumulated sums'. Verified with Python 3.14.3."
    - "itertools.permutations.__doc__.__contains__('permutations') == True — the permutations docstring says 'permutations(range(3), 2)' in the example. Verified with Python 3.14.3."
    - "itertools.chain.__doc__.__len__() == 190 — the chain docstring has exactly 190 characters. Verified with Python 3.14.3."
    - "itertools.product.__doc__.__len__() == 681 — the product docstring has exactly 681 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools __doc__.__contains__ checks — chain, cycle, product, combinations
#
# chain.__doc__.__contains__('chain')         == True
# cycle.__doc__.__contains__('cycle')         == False  (not mentioned in doc text)
# cycle.__doc__.__contains__('exhausted')     == True
# product.__doc__.__contains__('product')     == True
# ---------------------------------------------------------------------------

table itertools_extra213.doc_contains_group1:
  description: "itertools __doc__.__contains__ checks for chain, cycle, and product in iterdoccontains213g1 namespace — chain.__doc__ contains 'chain' (True), cycle.__doc__ does NOT contain 'cycle' (False, the word is absent from the C docstring), cycle.__doc__ contains 'exhausted' (True), product.__doc__ contains 'product' (True); all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iterdoccontains213g1

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_contains_chain,
       chain.__doc__.__contains__,
       ["chain"],
       true,
       "itertools.chain.__doc__.__contains__('chain') == True — the chain docstring says 'Return a chain object whose .__next__() method returns elements'; the word 'chain' appears; __contains__('chain') returns True; verified with Python 3.14.3"]
    - [cycle_doc_not_contains_cycle,
       cycle.__doc__.__contains__,
       ["cycle"],
       false,
       "itertools.cycle.__doc__.__contains__('cycle') == False — the cycle C docstring reads 'Return elements from the iterable until it is exhausted. Then repeat the sequence indefinitely.' and does not include the word 'cycle'; __contains__('cycle') returns False; verified with Python 3.14.3"]
    - [cycle_doc_contains_exhausted,
       cycle.__doc__.__contains__,
       ["exhausted"],
       true,
       "itertools.cycle.__doc__.__contains__('exhausted') == True — the cycle docstring says 'until it is exhausted'; __contains__('exhausted') returns True; verified with Python 3.14.3"]
    - [product_doc_contains_product,
       product.__doc__.__contains__,
       ["product"],
       true,
       "itertools.product.__doc__.__contains__('product') == True — the product docstring uses 'product(A, B)' in its example; __contains__('product') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: itertools __doc__.__contains__ checks — combinations, groupby, islice, accumulate
#
# combinations.__doc__.__contains__('combinations') == True
# groupby.__doc__.__contains__('groupby')           == False  (not in C docstring)
# groupby.__doc__.__contains__('key')               == True
# islice.__doc__.__contains__('islice')             == True
# ---------------------------------------------------------------------------

table itertools_extra213.doc_contains_group2:
  description: "itertools __doc__.__contains__ checks for combinations, groupby, and islice in iterdoccontains213g2 namespace — combinations.__doc__ contains 'combinations' (True), groupby.__doc__ does NOT contain 'groupby' (False, the C docstring omits the function name), groupby.__doc__ contains 'key' (True), islice.__doc__ contains 'islice' (True); all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iterdoccontains213g2

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_doc_contains_combinations,
       combinations.__doc__.__contains__,
       ["combinations"],
       true,
       "itertools.combinations.__doc__.__contains__('combinations') == True — the combinations docstring uses 'combinations(range(4), 3)' in its example; __contains__('combinations') returns True; verified with Python 3.14.3"]
    - [groupby_doc_not_contains_groupby,
       groupby.__doc__.__contains__,
       ["groupby"],
       false,
       "itertools.groupby.__doc__.__contains__('groupby') == False — the groupby C docstring says 'make an iterator that returns consecutive keys and groups from the iterable' and does not include the word 'groupby'; __contains__('groupby') returns False; verified with Python 3.14.3"]
    - [groupby_doc_contains_key,
       groupby.__doc__.__contains__,
       ["key"],
       true,
       "itertools.groupby.__doc__.__contains__('key') == True — the groupby docstring describes returning consecutive keys and mentions the key argument; __contains__('key') returns True; verified with Python 3.14.3"]
    - [islice_doc_contains_islice,
       islice.__doc__.__contains__,
       ["islice"],
       true,
       "itertools.islice.__doc__.__contains__('islice') == True — the islice docstring opens with 'islice(iterable, stop) --> islice object'; __contains__('islice') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
