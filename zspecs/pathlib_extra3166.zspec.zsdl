spec: pp3166
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 658 (pp3166): __add__, __sub__, __mul__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "No pathlib class defines __add__ in its own __dict__: path joining uses __truediv__ (the / operator), not __add__."
    - "No pathlib class defines __sub__ in its own __dict__: path objects do not support arithmetic subtraction."
    - "No pathlib class defines __mul__ in its own __dict__: path objects do not support arithmetic multiplication."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __add__ dict-presence — operator.contains(Cls.__dict__, '__add__')
#
# No pathlib class defines __add__ in its own __dict__; all false.
# pathlib uses __truediv__ for path joining (p / 'child'); __add__ is not defined.
# ---------------------------------------------------------------------------

table pp3166.add:
  description: "pathlib types __add__ dict-presence checks; wave 658"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3166

  columns: [id, function, args, expected]
  rows:
    - ["pp3166001", operator.contains, [pathlib.PurePath.__dict__,        "__add__"], false]
    - ["pp3166002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__add__"], false]
    - ["pp3166003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__add__"], false]
    - ["pp3166004", operator.contains, [pathlib.Path.__dict__,             "__add__"], false]
    - ["pp3166005", operator.contains, [pathlib.PosixPath.__dict__,        "__add__"], false]

