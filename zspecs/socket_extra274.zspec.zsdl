spec: socket_extra274
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "socket_extra273.zspec.zsdl — covers AddressFamily IntEnum identity and SOCK_STREAM/SOCK_DGRAM/SOCK_RAW/AF_UNIX/AF_INET6 values."
    - "socket_extra272.zspec.zsdl — covers AF_INET/SOCK_STREAM/SOCK_DGRAM/IPPROTO_TCP/IPPROTO_UDP constant values and SocketKind IntEnum identity."
    - "socket_extra271.zspec.zsdl — covers socket module __spec__/__loader__ identity and AddressFamily enum identity."
    - "socket_extra270.zspec.zsdl — covers socket.socket __init__/__repr__/__str__ method identity and socket.timeout/error exception identity."
  notes:
    - "socket.IPPROTO_TCP == 6 — the TCP protocol number per IANA; universally 6 across all POSIX platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.IPPROTO_UDP == 17 — the UDP protocol number per IANA; universally 17 across all POSIX platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.IPPROTO_IP == 0 — the dummy/wildcard IP protocol number; value 0 on all platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.IPPROTO_ICMP == 1 — the ICMP protocol number per IANA; universally 1 across all POSIX platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SOL_SOCKET == 65535 — the socket-level option level on macOS/Darwin; value is platform-specific (Linux uses 1). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SO_REUSEADDR == 4 — the SO_REUSEADDR socket option value on macOS/Darwin; platform-specific (Linux uses 2). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SO_KEEPALIVE == 8 — the SO_KEEPALIVE socket option value on macOS/Darwin. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.getprotobyname('tcp') == 6 — getprotobyname resolves 'tcp' to IANA protocol number 6. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.getprotobyname('udp') == 17 — getprotobyname resolves 'udp' to IANA protocol number 17. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.IPPROTO_* protocol number constants
# These are IANA-assigned IP protocol numbers, universal across all platforms.
# IPPROTO_IP==0 (dummy/wildcard), IPPROTO_ICMP==1, IPPROTO_TCP==6, IPPROTO_UDP==17.
# getprotobyname() performs a /etc/protocols lookup and returns the same values.
# ---------------------------------------------------------------------------

table socket_extra274.IPPROTO_constants:
  description: "socket.IPPROTO_* protocol number constants — IPPROTO_IP==0; IPPROTO_ICMP==1; IPPROTO_TCP==6; IPPROTO_UDP==17; IANA-assigned, universal across POSIX; verified with Python 3.14.3 macOS/Darwin"
  kind: python_call_eq
  category: behavior
  id_prefix: ipproto274

  columns: [id, function, args, expected, description]
  rows:
    - [ipproto_ip,    IPPROTO_IP.__eq__,    [0],  true, "socket.IPPROTO_IP == 0 — dummy/wildcard IP protocol number; universally 0 on POSIX"]
    - [ipproto_icmp,  IPPROTO_ICMP.__eq__,  [1],  true, "socket.IPPROTO_ICMP == 1 — ICMP protocol number per IANA; universally 1 on POSIX"]
    - [ipproto_tcp,   IPPROTO_TCP.__eq__,   [6],  true, "socket.IPPROTO_TCP == 6 — TCP protocol number per IANA; universally 6 on POSIX"]
    - [ipproto_udp,   IPPROTO_UDP.__eq__,   [17], true, "socket.IPPROTO_UDP == 17 — UDP protocol number per IANA; universally 17 on POSIX"]
    - [proto_tcp,     getprotobyname_tcp.__eq__, [6], true, "socket.getprotobyname('tcp') == 6 — /etc/protocols lookup returns IANA TCP protocol number"]

# ---------------------------------------------------------------------------
# socket.SOL_SOCKET and SO_* socket option constants on macOS/Darwin
# SOL_SOCKET is the socket option level passed to getsockopt/setsockopt.
# On macOS/Darwin, SOL_SOCKET==0xffff==65535 (Linux uses 1).
# SO_REUSEADDR==4 on macOS/Darwin (Linux uses 2); SO_KEEPALIVE==8 on macOS.
# These are from <sys/socket.h> and are platform-specific.
# ---------------------------------------------------------------------------

table socket_extra274.SOL_SOCKET_and_SO_options:
  description: "socket.SOL_SOCKET and SO_* option values on macOS/Darwin — SOL_SOCKET==65535; SO_REUSEADDR==4; SO_KEEPALIVE==8; platform-specific macOS/Darwin values from sys/socket.h; verified with Python 3.14.3 macOS/Darwin"
  kind: python_call_eq
  category: behavior
  id_prefix: solsock274

  columns: [id, function, args, expected, description]
  rows:
    - [sol_socket,     SOL_SOCKET.__eq__,    [65535], true, "socket.SOL_SOCKET == 65535 (0xffff) — socket option level on macOS/Darwin; Linux uses 1"]
    - [so_reuseaddr,   SO_REUSEADDR.__eq__,  [4],     true, "socket.SO_REUSEADDR == 4 — SO_REUSEADDR option value on macOS/Darwin; Linux uses 2"]
    - [so_keepalive,   SO_KEEPALIVE.__eq__,  [8],     true, "socket.SO_KEEPALIVE == 8 — SO_KEEPALIVE option value on macOS/Darwin"]
    - [proto_udp,      getprotobyname_udp.__eq__, [17], true, "socket.getprotobyname('udp') == 17 — /etc/protocols lookup returns IANA UDP protocol number"]

# ---------------------------------------------------------------------------
# Standalone invariants — IPPROTO_* constants and SOL_SOCKET/SO_* options
# ---------------------------------------------------------------------------

invariant socket_extra274.IPPROTO_TCP_eq:
  description: "socket.IPPROTO_TCP == 6 — the TCP protocol number as assigned by IANA; this value is universal across all POSIX platforms; passed to socket() as the protocol argument for raw TCP sockets; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: IPPROTO_TCP.__eq__
  args: [6]
  expected: true

invariant socket_extra274.IPPROTO_UDP_eq:
  description: "socket.IPPROTO_UDP == 17 — the UDP protocol number as assigned by IANA; this value is universal across all POSIX platforms; passed to socket() as the protocol argument for raw UDP sockets; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: IPPROTO_UDP.__eq__
  args: [17]
  expected: true

invariant socket_extra274.IPPROTO_IP_eq:
  description: "socket.IPPROTO_IP == 0 — the dummy/wildcard IP protocol number; value 0 selects the default protocol for the given socket type; universal across POSIX platforms; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: IPPROTO_IP.__eq__
  args: [0]
  expected: true

invariant socket_extra274.IPPROTO_ICMP_eq:
  description: "socket.IPPROTO_ICMP == 1 — the ICMP protocol number as assigned by IANA; used with SOCK_RAW to create raw ICMP sockets; universal across POSIX platforms; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: IPPROTO_ICMP.__eq__
  args: [1]
  expected: true

invariant socket_extra274.SOL_SOCKET_eq:
  description: "socket.SOL_SOCKET == 65535 — the socket-level option level constant on macOS/Darwin; value is 0xffff (65535) on macOS, but 1 on Linux; used as the first argument to getsockopt/setsockopt for socket-level options; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: SOL_SOCKET.__eq__
  args: [65535]
  expected: true

invariant socket_extra274.SO_REUSEADDR_eq:
  description: "socket.SO_REUSEADDR == 4 — the SO_REUSEADDR socket option constant on macOS/Darwin; value is 4 on macOS (Linux uses 2); allows binding to a recently-used local address; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: SO_REUSEADDR.__eq__
  args: [4]
  expected: true

invariant socket_extra274.SO_KEEPALIVE_eq:
  description: "socket.SO_KEEPALIVE == 8 — the SO_KEEPALIVE socket option constant on macOS/Darwin; enables TCP keepalive probes on connected sockets; value is macOS/Darwin-specific; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: SO_KEEPALIVE.__eq__
  args: [8]
  expected: true

invariant socket_extra274.getprotobyname_tcp_eq:
  description: "socket.getprotobyname('tcp') == 6 — looks up 'tcp' in /etc/protocols and returns the IANA-assigned protocol number 6; the result matches IPPROTO_TCP; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: getprotobyname_tcp.__eq__
  args: [6]
  expected: true
