spec: mp2941
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.html"
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.shared_ctypes.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 643 — theme: __neg__, __pos__, __abs__ dict-presence (unary operator slots)."
    - "Tests operator.contains(SomeClass.__dict__, '__neg__') etc. for multiprocessing classes."
    - "Classes covered: Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.ListProxy, managers.SetProxy, managers.DictProxy."
    - "None of these classes define __neg__, __pos__, or __abs__ in their own __dict__."
    - "pool.Pool.__module__ == 'multiprocessing.pool'; managers.*.__module__ == 'multiprocessing.managers'."
    - "Process.__module__ == 'multiprocessing.context' on Python 3.12+."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __neg__ dict-presence — operator.contains(Cls.__dict__, '__neg__')
#
# None of the multiprocessing classes define __neg__; all results are false.
# ---------------------------------------------------------------------------

table mp2941.neg:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_neg
  id_prefix: neg

  columns: [id, function, args, expected]
  rows:
    - ["neg_Process",         operator.contains, [Process.__dict__,                          "__neg__"], false]
    - ["neg_Pool",            operator.contains, [multiprocessing.pool.Pool.__dict__,        "__neg__"], false]
    - ["neg_AsyncResult",     operator.contains, [multiprocessing.pool.AsyncResult.__dict__, "__neg__"], false]
    - ["neg_MapResult",       operator.contains, [multiprocessing.pool.MapResult.__dict__,   "__neg__"], false]
    - ["neg_SyncManager",     operator.contains, [multiprocessing.managers.SyncManager.__dict__,  "__neg__"], false]
    - ["neg_ListProxy",       operator.contains, [multiprocessing.managers.ListProxy.__dict__,    "__neg__"], false]
    - ["neg_SetProxy",        operator.contains, [multiprocessing.managers.SetProxy.__dict__,     "__neg__"], false]
    - ["neg_DictProxy",       operator.contains, [multiprocessing.managers.DictProxy.__dict__,    "__neg__"], false]

