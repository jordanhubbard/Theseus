spec: datetime_extra19
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
  notes:
    - "This spec extends datetime.zspec.zsdl and prior extras through datetime_extra18.zspec.zsdl."
    - "datetime_extra18 covers: timedelta.total_seconds/__qualname__; timezone.utc/__class__/__qualname__; MINYEAR/MAXYEAR/__class__/__module__; timedelta/__qualname__/__class__/__name__ and timezone/__module__/__class__/__name__ type axes."
    - "datetime_extra17 covers: date/datetime/timedelta dunder operator method __qualname__ (__add__/__sub__/__eq__/__hash__/__mul__); timezone.__qualname__ standalone."
    - "datetime_extra16 covers: __qualname__ for date/datetime method descriptors (today, fromisoformat, strftime, isoformat, now, strptime); time.isoformat; timedelta.__qualname__."
    - "datetime_extra12 covers: __qualname__ and __module__ for date/time/datetime/timedelta/timezone/tzinfo (all six classes)."
    - "Focus: __bases__[0].__name__ for date, datetime, time, timedelta, and timezone; __bases__[0].__qualname__ for those same five classes; tzinfo/__qualname__/__class__.__name__ and tzinfo/__module__/__class__.__name__ type axes; date.__init__.__qualname__."
    - "No prior datetime spec checks date.__bases__[0].__name__."
    - "No prior datetime spec checks datetime.__bases__[0].__name__."
    - "No prior datetime spec checks time.__bases__[0].__name__."
    - "No prior datetime spec checks timedelta.__bases__[0].__name__."
    - "No prior datetime spec checks timezone.__bases__[0].__name__."
    - "No prior datetime spec checks date.__bases__[0].__qualname__."
    - "No prior datetime spec checks datetime.__bases__[0].__qualname__."
    - "No prior datetime spec checks time.__bases__[0].__qualname__."
    - "No prior datetime spec checks timedelta.__bases__[0].__qualname__."
    - "No prior datetime spec checks timezone.__bases__[0].__qualname__."
    - "No prior datetime spec checks tzinfo.__qualname__.__class__.__name__ (type axis)."
    - "No prior datetime spec checks tzinfo.__module__.__class__.__name__ (type axis)."
    - "No prior datetime spec checks date.__init__.__qualname__."
    - "datetime.date.__bases__[0].__name__ == 'object' — date inherits directly from object."
    - "datetime.datetime.__bases__[0].__name__ == 'date' — datetime subclasses date."
    - "datetime.time.__bases__[0].__name__ == 'object' — time inherits directly from object."
    - "datetime.timedelta.__bases__[0].__name__ == 'object' — timedelta inherits directly from object."
    - "datetime.timezone.__bases__[0].__name__ == 'tzinfo' — timezone inherits from tzinfo."
    - "datetime.date.__bases__[0].__qualname__ == 'object' — top-level class, qualname equals name."
    - "datetime.datetime.__bases__[0].__qualname__ == 'date' — top-level class, qualname equals name."
    - "datetime.time.__bases__[0].__qualname__ == 'object' — top-level class, qualname equals name."
    - "datetime.timedelta.__bases__[0].__qualname__ == 'object' — top-level class, qualname equals name."
    - "datetime.timezone.__bases__[0].__qualname__ == 'tzinfo' — top-level class, qualname equals name."
    - "datetime.tzinfo.__qualname__.__class__.__name__ == 'str' — qualname attribute is a plain string."
    - "datetime.tzinfo.__module__.__class__.__name__ == 'str' — module attribute is a plain string."
    - "datetime.date.__init__.__qualname__ == 'object.__init__' — date has no Python-level __init__; inherits from object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__name__ for date, datetime, time, timedelta, timezone
#
# No prior datetime spec checks __bases__[0].__name__ for any of the five main
# classes.  date, time, and timedelta inherit from object.  datetime subclasses
# date, making its base name 'date'.  timezone inherits from tzinfo.
# ---------------------------------------------------------------------------

invariant datetime_extra19.date.base_name:
  description: "datetime.date.__bases__[0].__name__ == 'object' — date inherits directly from object"
  category: class_attrs
  kind: python_call_eq
  function: "date.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant datetime_extra19.datetime.base_name:
  description: "datetime.datetime.__bases__[0].__name__ == 'date' — datetime subclasses date"
  category: class_attrs
  kind: python_call_eq
  function: "datetime.__bases__[0].__name__.__eq__"
  args: ["date"]
  expected: true

invariant datetime_extra19.time.base_name:
  description: "datetime.time.__bases__[0].__name__ == 'object' — time inherits directly from object"
  category: class_attrs
  kind: python_call_eq
  function: "time.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant datetime_extra19.timedelta.base_name:
  description: "datetime.timedelta.__bases__[0].__name__ == 'object' — timedelta inherits directly from object"
  category: class_attrs
  kind: python_call_eq
  function: "timedelta.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant datetime_extra19.timezone.base_name:
  description: "datetime.timezone.__bases__[0].__name__ == 'tzinfo' — timezone inherits from tzinfo"
  category: class_attrs
  kind: python_call_eq
  function: "timezone.__bases__[0].__name__.__eq__"
  args: ["tzinfo"]
  expected: true

# ---------------------------------------------------------------------------
# __bases__[0].__qualname__ for date, datetime, time, timedelta, timezone
#
# No prior datetime spec checks __bases__[0].__qualname__ for any of these
# classes.  For top-level built-in types (object, date, tzinfo), __qualname__
# equals __name__, so the values mirror the __name__ checks above.
# ---------------------------------------------------------------------------

invariant datetime_extra19.date.base_qualname:
  description: "datetime.date.__bases__[0].__qualname__ == 'object' — base class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: "date.__bases__[0].__qualname__.__eq__"
  args: ["object"]
  expected: true

invariant datetime_extra19.datetime.base_qualname:
  description: "datetime.datetime.__bases__[0].__qualname__ == 'date' — base class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: "datetime.__bases__[0].__qualname__.__eq__"
  args: ["date"]
  expected: true

invariant datetime_extra19.time.base_qualname:
  description: "datetime.time.__bases__[0].__qualname__ == 'object' — base class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: "time.__bases__[0].__qualname__.__eq__"
  args: ["object"]
  expected: true

invariant datetime_extra19.timedelta.base_qualname:
  description: "datetime.timedelta.__bases__[0].__qualname__ == 'object' — base class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: "timedelta.__bases__[0].__qualname__.__eq__"
  args: ["object"]
  expected: true

invariant datetime_extra19.timezone.base_qualname:
  description: "datetime.timezone.__bases__[0].__qualname__ == 'tzinfo' — base class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: "timezone.__bases__[0].__qualname__.__eq__"
  args: ["tzinfo"]
  expected: true

# ---------------------------------------------------------------------------
# tzinfo — __qualname__ and __module__ type axes
#
# datetime_extra12 checks tzinfo.__qualname__ == 'tzinfo' (value).
# datetime_extra12 checks tzinfo.__module__ == 'datetime' (value).
# datetime_extra18 checks timedelta.__qualname__.__class__.__name__ and
# timezone.__module__.__class__.__name__ (type axes for timedelta and timezone).
# No prior datetime spec checks the type (__class__.__name__) of the __qualname__
# or __module__ attributes on tzinfo specifically.  Both are plain str instances.
# ---------------------------------------------------------------------------

invariant datetime_extra19.tzinfo.qualname.class_name:
  description: "datetime.tzinfo.__qualname__.__class__.__name__ == 'str' — qualname attribute is a plain string"
  category: type_attrs
  kind: python_call_eq
  function: tzinfo.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant datetime_extra19.tzinfo.module.class_name:
  description: "datetime.tzinfo.__module__.__class__.__name__ == 'str' — module attribute is a plain string"
  category: type_attrs
  kind: python_call_eq
  function: tzinfo.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# date.__init__.__qualname__
#
# datetime_extra16 checks __qualname__ for date.today, date.fromisoformat,
# date.strftime, and date.isoformat.  datetime_extra17 checks dunder operator
# methods like date.__add__.  No prior datetime spec checks date.__init__.__qualname__.
# The C implementation of date has no Python-level __init__, so it inherits
# object.__init__; its __qualname__ is the compound string 'object.__init__'.
# ---------------------------------------------------------------------------

invariant datetime_extra19.date.__init__.qualname:
  description: "datetime.date.__init__.__qualname__ == 'object.__init__' — date inherits __init__ from object"
  category: method_qualnames
  kind: python_call_eq
  function: "date.__init__.__qualname__.__eq__"
  args: ["object.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all thirteen new invariants
#
# All thirteen are first covered in this spec (datetime_extra19).
# ---------------------------------------------------------------------------

table datetime_extra19.base_names_qualnames_and_type_axes:
  description: "datetime five-class base __name__ and __qualname__, tzinfo type axes, date.__init__ qualname"
  kind: python_call_eq
  category: class_attrs
  id_prefix: dte19

  columns: [id, function, args, expected]
  rows:
    - [date_base_name,       "date.__bases__[0].__name__.__eq__",         ["object"],          true]
    - [datetime_base_name,   "datetime.__bases__[0].__name__.__eq__",     ["date"],            true]
    - [time_base_name,       "time.__bases__[0].__name__.__eq__",         ["object"],          true]
    - [timedelta_base_name,  "timedelta.__bases__[0].__name__.__eq__",    ["object"],          true]
    - [timezone_base_name,   "timezone.__bases__[0].__name__.__eq__",     ["tzinfo"],          true]
    - [date_base_qn,         "date.__bases__[0].__qualname__.__eq__",     ["object"],          true]
    - [datetime_base_qn,     "datetime.__bases__[0].__qualname__.__eq__", ["date"],            true]
    - [time_base_qn,         "time.__bases__[0].__qualname__.__eq__",     ["object"],          true]
    - [timedelta_base_qn,    "timedelta.__bases__[0].__qualname__.__eq__", ["object"],         true]
    - [timezone_base_qn,     "timezone.__bases__[0].__qualname__.__eq__", ["tzinfo"],          true]
    - [tzinfo_qn_type,       tzinfo.__qualname__.__class__.__name__.__eq__, ["str"],           true]
    - [tzinfo_mod_type,      tzinfo.__module__.__class__.__name__.__eq__,  ["str"],            true]
    - [date_init_qn,         "date.__init__.__qualname__.__eq__",          ["object.__init__"], true]
