# ---------------------------------------------------------------------------
# first element tests — call NAME(args).__next__() to get the first value
#
# chain([10,20],[30]) first → 10
# islice([5,6,7,8], 2) first → 5   (islice(iterable, stop))
# count(7) first → 7
# cycle([3,1,4]) first → 3
# repeat(99) first → 99
# accumulate([5,10,15]) first → 5  (running total starts at 5)
# compress([1,2,3],[1,0,1]) first → 1  (first True selector)
# product([1,2],[3,4]) first → (1,3) — harness normalizes to [1, 3]
# combinations([1,2,3], 2) first → (1,2) — harness normalizes to [1, 2]
# zip_longest([1,2],[3]) first → (1,3) — harness normalizes to [1, 3]
# ---------------------------------------------------------------------------

invariant itertools.first_element.chain:
  description: "chain([10,20],[30]).__next__() == 10"
  category: first_element
  kind: python_call_eq
  function: chain
  args: [[10, 20], [30]]
  method: __next__
  expected: 10

invariant itertools.first_element.islice:
  description: "islice([5,6,7,8], 2).__next__() == 5"
  category: first_element
  kind: python_call_eq
  function: islice
  args: [[5, 6, 7, 8], 2]
  method: __next__
  expected: 5

invariant itertools.first_element.count:
  description: "count(7).__next__() == 7"
  category: first_element
  kind: python_call_eq
  function: count
  args: [7]
  method: __next__
  expected: 7

invariant itertools.first_element.cycle:
  description: "cycle([3,1,4]).__next__() == 3"
  category: first_element
  kind: python_call_eq
  function: cycle
  args: [[3, 1, 4]]
  method: __next__
  expected: 3

invariant itertools.first_element.repeat:
  description: "repeat(99).__next__() == 99"
  category: first_element
  kind: python_call_eq
  function: repeat
  args: [99]
  method: __next__
  expected: 99

invariant itertools.first_element.accumulate:
  description: "accumulate([5,10,15]).__next__() == 5 (running sum starts at first element)"
  category: first_element
  kind: python_call_eq
  function: accumulate
  args: [[5, 10, 15]]
  method: __next__
  expected: 5

invariant itertools.first_element.compress:
  description: "compress([1,2,3],[1,0,1]).__next__() == 1 (first selector is True)"
  category: first_element
  kind: python_call_eq
  function: compress
  args: [[1, 2, 3], [1, 0, 1]]
  method: __next__
  expected: 1

invariant itertools.first_element.product:
  description: "product([1,2],[3,4]).__next__() == (1,3) — first Cartesian pair; tuple normalized to list"
  category: first_element
  kind: python_call_eq
  function: product
  args: [[1, 2], [3, 4]]
  method: __next__
  expected: [1, 3]

invariant itertools.first_element.combinations:
  description: "combinations([1,2,3], 2).__next__() == (1,2) — first 2-combination; tuple normalized to list"
  category: first_element
  kind: python_call_eq
  function: combinations
  args: [[1, 2, 3], 2]
  method: __next__
  expected: [1, 2]

invariant itertools.first_element.zip_longest:
  description: "zip_longest([1,2],[3]).__next__() == (1,3) — harness normalizes tuple to list"
  category: first_element
  kind: python_call_eq
  function: zip_longest
  args: [[1, 2], [3]]
  method: __next__
  expected: [1, 3]

