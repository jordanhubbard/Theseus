spec: itertools
version: ">=3.0"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "Python itertools documentation — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS Darwin 25.4.0, 2026-04-08"
  not_derived_from:
    - "CPython source: Lib/itertools.py"
  notes:
    - "All itertools functions return iterator objects (C-level types)."
    - "Class names are accessed via NAME.__name__.__eq__(NAME) pattern."
    - "First-element tests call NAME(args).__next__() via method: __next__."
    - "zip_longest, product, combinations, permutations return tuples; harness normalizes tuple→list when expected is a list."
    - "starmap requires a callable as first arg — not directly testable via first_element (callable not resolvable from module namespace); covered via classname only."
    - "All expected values verified by running Python 3.14 on macOS Darwin 25.4.0, 2026-04-08."
  created_at: "2026-04-08T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# class names — each itertools object is a C-level type; verify via __name__
#
# Pattern: function: NAME.__name__.__eq__, args: ["NAME"] → true
# ---------------------------------------------------------------------------

invariant itertools.classnames.chain:
  description: "itertools.chain.__name__ == 'chain'"
  category: classnames
  kind: python_call_eq
  function: chain.__name__.__eq__
  args: ["chain"]
  expected: true

invariant itertools.classnames.islice:
  description: "itertools.islice.__name__ == 'islice'"
  category: classnames
  kind: python_call_eq
  function: islice.__name__.__eq__
  args: ["islice"]
  expected: true

invariant itertools.classnames.count:
  description: "itertools.count.__name__ == 'count'"
