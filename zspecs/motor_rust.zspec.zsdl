spec: motor_rust
version: ">=3.9"
backend: rust_module(motor_rust)

docs: https://motor.readthedocs.io/

provenance:
  derived_from:
    - "https://motor.readthedocs.io/ — motor async MongoDB driver"
  notes:
    - "motor provides async MongoDB driver."
    - "motor.motor_asyncio.AsyncIOMotorClient is a class."
    - "motor.version_tuple is a tuple."
    - "motor.version is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant motor_rust.has_async_client:
  description: "motor.motor_asyncio.AsyncIOMotorClient is a class"
  category: presence
  kind: python_call_eq
  function: motor_has_async_client
  args: []
  expected: true

invariant motor_rust.version_tuple_len:
  description: "motor.version_tuple has length >= 3"
  category: version
  kind: python_call_eq
  function: motor_version_tuple_len
  args: []
  expected: true

invariant motor_rust.version_nonempty:
  description: "motor.version is non-empty"
  category: version
  kind: python_call_eq
  function: motor_version_nonempty
  args: []
  expected: true

