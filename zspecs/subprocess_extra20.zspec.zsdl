spec: subprocess_extra20
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
    - "subprocess_extra6.zspec.zsdl — covers __qualname__ for Popen/CompletedProcess/CalledProcessError class-level; NOT run/call/check_call/check_output __qualname__."
    - "subprocess_extra17.zspec.zsdl — covers Popen.__init__.__qualname__ and Popen.__repr__.__qualname__; NOT run/call/check_call/check_output __qualname__."
    - "subprocess_extra18.zspec.zsdl — covers __module__ for subprocess classes and functions; exception __bases__[0].__name__."
    - "subprocess_extra19.zspec.zsdl — covers __init__.__qualname__ for CompletedProcess/CalledProcessError/TimeoutExpired; PIPE/STDOUT/DEVNULL integer values."
  notes:
    - "This spec extends subprocess.zspec.zsdl and all prior subprocess_extra specs through subprocess_extra19.zspec.zsdl."
    - "Prior specs covered: subprocess.__name__/__package__, Popen.__name__/__module__/__qualname__, CompletedProcess.__name__/__module__, CalledProcessError.__name__/__module__, TimeoutExpired.__name__/__module__, run/__name__/__module__, call/__name__, check_call/__name__, check_output/__name__, PIPE==-1, STDOUT==-2, DEVNULL==-3, Popen.__bases__[0].__name__, CompletedProcess.__bases__[0].__name__, CalledProcessError.__bases__[0].__name__, TimeoutExpired.__bases__[0].__name__, various __qualname__ checks."
    - "This spec covers: subprocess.Popen.__init__.__name__, subprocess.run.__qualname__, subprocess.call.__qualname__, subprocess.check_call.__qualname__, subprocess.check_output.__qualname__, subprocess.run.__module__.__len__(), subprocess.Popen.__module__.__len__(), subprocess.CompletedProcess.__qualname__, subprocess.CalledProcessError.__qualname__, subprocess.TimeoutExpired.__qualname__, subprocess.SubprocessError.__name__, subprocess.SubprocessError.__bases__[0].__name__."
    - "subprocess.Popen.__init__.__name__ == '__init__' — dunder name for the initializer method; prior specs cover __qualname__ for Popen.__init__ but not __name__."
    - "subprocess.run.__qualname__ == 'run' — top-level function, qualname equals bare name; prior specs cover __name__ and __module__ but not __qualname__."
    - "subprocess.SubprocessError.__name__ == 'SubprocessError' — base exception class; not covered in any prior subprocess spec."
    - "subprocess.SubprocessError.__bases__[0].__name__ == 'Exception' — SubprocessError inherits from Exception; not covered in any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# subprocess top-level function __qualname__ attributes
#
# subprocess_extra18 covers __module__ for run/call/check_call/check_output.
# No prior subprocess spec covers __qualname__ for these four functions.
# As top-level module-level functions, their __qualname__ equals their
# bare function name.
# ---------------------------------------------------------------------------

table subprocess_extra20.toplevel_function_qualnames:
  description: "__qualname__ for subprocess top-level functions equals the bare function name"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fnqn20

  columns: [id, function, args, expected]
  rows:
    - [run,          run.__qualname__.__eq__,          ["run"],          true]
    - [call,         call.__qualname__.__eq__,         ["call"],         true]
    - [check_call,   check_call.__qualname__.__eq__,   ["check_call"],   true]
    - [check_output, check_output.__qualname__.__eq__, ["check_output"], true]

# ---------------------------------------------------------------------------
# subprocess class __qualname__ attributes — CompletedProcess, CalledProcessError,
# TimeoutExpired
#
# subprocess_extra6 covers Popen.__qualname__. No prior subprocess spec covers
# __qualname__ for CompletedProcess, CalledProcessError, or TimeoutExpired
# as class-level attributes (extra6 covers class-level Popen only; extra19
# covers __init__.__qualname__ for the latter three). These are top-level
# classes so their __qualname__ equals their bare __name__.
# ---------------------------------------------------------------------------

table subprocess_extra20.class_qualnames:
  description: "__qualname__ for subprocess classes equals the bare class name"
  kind: python_call_eq
  category: type_attrs
  id_prefix: clsqn20

  columns: [id, function, args, expected]
  rows:
    - [CompletedProcess,   CompletedProcess.__qualname__.__eq__,   ["CompletedProcess"],   true]
    - [CalledProcessError, CalledProcessError.__qualname__.__eq__, ["CalledProcessError"], true]
    - [TimeoutExpired,     TimeoutExpired.__qualname__.__eq__,     ["TimeoutExpired"],     true]

# ---------------------------------------------------------------------------
# subprocess __module__ string lengths
#
# subprocess.run.__module__ == 'subprocess' (len 10).
# subprocess.Popen.__module__ == 'subprocess' (len 10).
# Prior specs confirm the __module__ values; no prior spec checks __len__().
# ---------------------------------------------------------------------------

table subprocess_extra20.module_lengths:
  description: "__module__.__len__() == 10 for subprocess functions and classes (all 'subprocess')"
  kind: python_call_eq
  category: function_attrs
  id_prefix: modlen20

  columns: [id, function, args, expected]
  rows:
    - [run,   run.__module__.__len__,   [], 10]
    - [Popen, Popen.__module__.__len__, [], 10]

# ---------------------------------------------------------------------------
# subprocess.SubprocessError — __name__ and __bases__[0].__name__
#
# SubprocessError is the base exception for the subprocess module. No prior
# subprocess spec covers SubprocessError.__name__ or its inheritance chain.
# SubprocessError inherits directly from Exception.
# ---------------------------------------------------------------------------

invariant subprocess_extra20.SubprocessError.name:
  description: "subprocess.SubprocessError.__name__ == 'SubprocessError' — base exception class name"
  category: type_attrs
  kind: python_call_eq
  function: SubprocessError.__name__.__eq__
  args: ["SubprocessError"]
  expected: true

invariant subprocess_extra20.SubprocessError.base_name:
  description: "subprocess.SubprocessError.__bases__[0].__name__ == 'Exception' — SubprocessError inherits from Exception"
  category: type_attrs
  kind: python_call_eq
  function: "SubprocessError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — Popen.__init__.__name__
# ---------------------------------------------------------------------------

invariant subprocess_extra20.Popen.init_name:
  description: "subprocess.Popen.__init__.__name__ == '__init__' — dunder name for the initializer method"
  category: function_attrs
  kind: python_call_eq
  function: Popen.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — top-level function __qualname__
# ---------------------------------------------------------------------------

invariant subprocess_extra20.run.qualname:
  description: "subprocess.run.__qualname__ == 'run' — top-level function qualname equals bare name"
  category: function_attrs
  kind: python_call_eq
  function: run.__qualname__.__eq__
  args: ["run"]
  expected: true

invariant subprocess_extra20.call.qualname:
  description: "subprocess.call.__qualname__ == 'call' — top-level function qualname equals bare name"
  category: function_attrs
  kind: python_call_eq
  function: call.__qualname__.__eq__
  args: ["call"]
  expected: true

invariant subprocess_extra20.check_call.qualname:
  description: "subprocess.check_call.__qualname__ == 'check_call' — top-level function qualname equals bare name"
  category: function_attrs
  kind: python_call_eq
  function: check_call.__qualname__.__eq__
  args: ["check_call"]
  expected: true

invariant subprocess_extra20.check_output.qualname:
  description: "subprocess.check_output.__qualname__ == 'check_output' — top-level function qualname equals bare name"
  category: function_attrs
  kind: python_call_eq
  function: check_output.__qualname__.__eq__
  args: ["check_output"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — class __qualname__
# ---------------------------------------------------------------------------

invariant subprocess_extra20.CompletedProcess.qualname:
  description: "subprocess.CompletedProcess.__qualname__ == 'CompletedProcess' — class qualname equals bare class name"
  category: type_attrs
  kind: python_call_eq
  function: CompletedProcess.__qualname__.__eq__
  args: ["CompletedProcess"]
  expected: true

invariant subprocess_extra20.CalledProcessError.qualname:
  description: "subprocess.CalledProcessError.__qualname__ == 'CalledProcessError' — class qualname equals bare class name"
  category: type_attrs
  kind: python_call_eq
  function: CalledProcessError.__qualname__.__eq__
  args: ["CalledProcessError"]
  expected: true

invariant subprocess_extra20.TimeoutExpired.qualname:
  description: "subprocess.TimeoutExpired.__qualname__ == 'TimeoutExpired' — class qualname equals bare class name"
  category: type_attrs
  kind: python_call_eq
  function: TimeoutExpired.__qualname__.__eq__
  args: ["TimeoutExpired"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — __module__ string lengths
# ---------------------------------------------------------------------------

invariant subprocess_extra20.run.module_len:
  description: "subprocess.run.__module__.__len__() == 10 — 'subprocess' has 10 characters"
  category: function_attrs
  kind: python_call_eq
  function: run.__module__.__len__
  args: []
  expected: 10

invariant subprocess_extra20.Popen.module_len:
  description: "subprocess.Popen.__module__.__len__() == 10 — 'subprocess' has 10 characters"
  category: function_attrs
  kind: python_call_eq
  function: Popen.__module__.__len__
  args: []
  expected: 10
