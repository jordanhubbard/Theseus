spec: multiprocessing_extra218
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "multiprocessing.pool.Pool.__name__ == 'Pool' — 4 characters; module is multiprocessing.pool; verified with Python 3.14.3."
    - "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool' — Pool lives in multiprocessing.pool submodule; verified with Python 3.14.3."
    - "multiprocessing.pool.Pool.__qualname__ == 'Pool' — simple class name, not nested; verified with Python 3.14.3."
    - "multiprocessing.Semaphore.__name__ == 'Semaphore' — 9 characters; module is multiprocessing.context; verified with Python 3.14.3."
    - "multiprocessing.Lock.__name__ == 'Lock' — 4 characters; module is multiprocessing.context; verified with Python 3.14.3."
    - "multiprocessing.Event.__name__ == 'Event' — 5 characters; module is multiprocessing.context; verified with Python 3.14.3."
    - "multiprocessing.Condition.__name__ == 'Condition' — 9 characters; module is multiprocessing.context; verified with Python 3.14.3."
    - "multiprocessing.Semaphore.__qualname__ == 'BaseContext.Semaphore' — nested under BaseContext; verified with Python 3.14.3."
    - "multiprocessing.Lock.__qualname__ == 'BaseContext.Lock' — nested under BaseContext; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Pool class name and module contracts — extra218 namespace
#
# Pool.__name__ == 'Pool' (4 chars); __module__ == 'multiprocessing.pool'.
# ---------------------------------------------------------------------------

table multiprocessing_extra218.pool_name_module:
  description: "multiprocessing.pool.Pool class __name__, __module__, and __qualname__ contracts in mp218pool namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp218pool

  columns: [id, function, args, expected, description]
  rows:
    - [pool_name_eq,      pool.Pool.__name__.__eq__,     ["Pool"],                  true, "multiprocessing.pool.Pool.__name__ == 'Pool'; verified with Python 3.14.3"]
    - [pool_name_len_4,   pool.Pool.__name__.__len__,    [],                        4,    "multiprocessing.pool.Pool.__name__.__len__() == 4 — 'Pool' has 4 characters; verified with Python 3.14.3"]
    - [pool_module_eq,    pool.Pool.__module__.__eq__,   ["multiprocessing.pool"],  true, "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool'; verified with Python 3.14.3"]
    - [pool_qualname_eq,  pool.Pool.__qualname__.__eq__, ["Pool"],                  true, "multiprocessing.pool.Pool.__qualname__ == 'Pool'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing sync primitive class name contracts — extra218 namespace
#
# Semaphore/Lock/Event/Condition live in multiprocessing.context; qualnames
# are nested under BaseContext.
# ---------------------------------------------------------------------------

table multiprocessing_extra218.sync_name_contracts:
  description: "multiprocessing sync primitive __name__ and __module__ contracts in mp218sync namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp218sync

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_name_eq,      Semaphore.__name__.__eq__,     ["Semaphore"],               true, "multiprocessing.Semaphore.__name__ == 'Semaphore'; verified with Python 3.14.3"]
    - [semaphore_name_len_9,   Semaphore.__name__.__len__,    [],                          9,    "multiprocessing.Semaphore.__name__.__len__() == 9 — 'Semaphore' has 9 characters; verified with Python 3.14.3"]
    - [semaphore_module_eq,    Semaphore.__module__.__eq__,   ["multiprocessing.context"], true, "multiprocessing.Semaphore.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [lock_name_eq,           Lock.__name__.__eq__,          ["Lock"],                    true, "multiprocessing.Lock.__name__ == 'Lock'; verified with Python 3.14.3"]
    - [lock_module_eq,         Lock.__module__.__eq__,        ["multiprocessing.context"], true, "multiprocessing.Lock.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [event_name_eq,          Event.__name__.__eq__,         ["Event"],                   true, "multiprocessing.Event.__name__ == 'Event'; verified with Python 3.14.3"]
    - [event_module_eq,        Event.__module__.__eq__,       ["multiprocessing.context"], true, "multiprocessing.Event.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [condition_name_eq,      Condition.__name__.__eq__,     ["Condition"],               true, "multiprocessing.Condition.__name__ == 'Condition'; verified with Python 3.14.3"]
    - [condition_module_eq,    Condition.__module__.__eq__,   ["multiprocessing.context"], true, "multiprocessing.Condition.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing sync primitive __qualname__ contracts — extra218 namespace
#
# Semaphore and Lock qualnames are nested: 'BaseContext.Semaphore', 'BaseContext.Lock'.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra218.semaphore_qualname_eq:
  description: "multiprocessing.Semaphore.__qualname__ == 'BaseContext.Semaphore' — nested under BaseContext; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: Semaphore.__qualname__.__eq__
  args: ["BaseContext.Semaphore"]
  expected: true

invariant multiprocessing_extra218.lock_qualname_eq:
  description: "multiprocessing.Lock.__qualname__ == 'BaseContext.Lock' — nested under BaseContext; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: Lock.__qualname__.__eq__
  args: ["BaseContext.Lock"]
  expected: true
