spec: node_cron
version: ">=3.0.0"
backend: node(node-cron)

docs: https://www.npmjs.com/package/node-cron

provenance:
  derived_from:
    - "node-cron README — https://www.npmjs.com/package/node-cron"
    - "Test vectors verified with node-cron via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "node-cron source"
  notes:
    - "node-cron is an npm package. Install: npm install node-cron"
    - "cron.validate(expression) checks if a cron expression is syntactically valid."
    - "Supports 5-field cron syntax: minute hour day-of-month month day-of-week."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table node_cron.validate:
  kind: node_module_call_eq
  function: validate
  category: validate
  id_prefix: cron

  columns: [id, args, expected]
  rows:
    - [every_5min,  ["*/5 * * * *"],   true]
    - [mon_9am,     ["0 9 * * MON"],   true]
    - [every_2hr,   ["0 */2 * * *"],   true]
    - [invalid,     ["invalid"],        false]
    - [out_of_range,["60 * * * *"],     false]
