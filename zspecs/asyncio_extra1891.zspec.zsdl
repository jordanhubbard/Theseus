spec: asyncio_extra1891
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "asyncio module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party asyncio extensions"
  notes:
    - "Tests unary arithmetic protocol and async iteration protocol membership in asyncio types"
    - "None of the asyncio synchronization/future types implement unary arithmetic dunder methods"
    - "asyncio.Future and asyncio.Task are awaitable but not async-iterable"
    - "Streams API (StreamReader, StreamWriter) and timeout API added progressively through 3.x versions"
  created_at: "2026-04-12"

table asyncio_extra1891.unary_arithmetic:
  columns: [id, function, args, expected]
  rows:
    - ["as1891-ua-001", "asyncio.Future.__dict__.__contains__", ["__abs__"], false]
    - ["as1891-ua-002", "asyncio.Future.__dict__.__contains__", ["__neg__"], false]
    - ["as1891-ua-003", "asyncio.Task.__dict__.__contains__", ["__abs__"], false]
    - ["as1891-ua-004", "asyncio.Queue.__dict__.__contains__", ["__abs__"], false]
    - ["as1891-ua-005", "asyncio.Lock.__dict__.__contains__", ["__abs__"], false]
    - ["as1891-ua-006", "asyncio.Event.__dict__.__contains__", ["__abs__"], false]
    - ["as1891-ua-007", "asyncio.Semaphore.__dict__.__contains__", ["__abs__"], false]
    - ["as1891-ua-008", "asyncio.Condition.__dict__.__contains__", ["__abs__"], false]

table asyncio_extra1891.async_iteration_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["as1891-ai-001", "asyncio.Future.__dict__.__contains__", ["__aiter__"], false]
    - ["as1891-ai-002", "asyncio.Task.__dict__.__contains__", ["__aiter__"], false]
    - ["as1891-ai-003", "asyncio.Queue.__dict__.__contains__", ["__aiter__"], false]
    - ["as1891-ai-004", "asyncio.Lock.__dict__.__contains__", ["__aiter__"], false]
    - ["as1891-ai-005", "asyncio.Event.__dict__.__contains__", ["__aiter__"], false]
    - ["as1891-ai-006", "asyncio.Semaphore.__dict__.__contains__", ["__aiter__"], false]
    - ["as1891-ai-007", "asyncio.Condition.__dict__.__contains__", ["__aiter__"], false]
    - ["as1891-ai-008", "asyncio.Queue.__dict__.__contains__", ["__anext__"], false]

table asyncio_extra1891.asyncio_streams_attrs:
  columns: [id, function, args, expected]
  rows:
    - ["as1891-sa-001", "asyncio.__dict__.__contains__", ["StreamReader"], true]
    - ["as1891-sa-002", "asyncio.__dict__.__contains__", ["StreamWriter"], true]
    - ["as1891-sa-003", "asyncio.__dict__.__contains__", ["open_connection"], true]
    - ["as1891-sa-004", "asyncio.__dict__.__contains__", ["start_server"], true]
    - ["as1891-sa-005", "asyncio.__dict__.__contains__", ["open_unix_connection"], true]
    - ["as1891-sa-006", "asyncio.__dict__.__contains__", ["start_unix_server"], true]
    - ["as1891-sa-007", "asyncio.__dict__.__contains__", ["StreamReaderProtocol"], false]
    - ["as1891-sa-008", "asyncio.__dict__.__contains__", ["Timeout"], true]
    - ["as1891-sa-009", "asyncio.__dict__.__contains__", ["timeout"], true]
    - ["as1891-sa-010", "asyncio.__dict__.__contains__", ["timeout_at"], true]
