spec: decimal_extra141
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Context method __qualname__ values and lengths — new territory covering the arithmetic, transcendental, and utility methods of Context. Previous specs (decimal_extra140) covered Decimal method qualnames; this spec focuses on Context."
    - "All decimal.Context method qualnames follow the 'Context.<method>' pattern."
    - "Context method qualname lengths by group: ln/exp=11 (shortest alongside add/fma/abs), ln=10 (shortest of all), sqrt/log10/power=12-13, divide=14, max_mag/min_mag=15, multiply/subtract/quantize/copy_abs/copy_sign=16-17, next_toward=19, remainder_near/create_decimal=22 (longest)."
    - "decimal.Context.ln.__qualname__ == 'Context.ln' (len=10; the shortest Context method qualname — 'ln' is only 2 characters)."
    - "decimal.Context.add.__qualname__ == 'Context.add' (len=11); Context.fma, Context.abs, Context.exp all also have len=11."
    - "decimal.Context.remainder_near.__qualname__ == 'Context.remainder_near' (len=22; tied with Context.create_decimal for the longest Context method qualname)."
    - "decimal.Context.create_decimal.__qualname__ == 'Context.create_decimal' (len=22; tied with remainder_near)."
    - "decimal.Context.next_toward.__qualname__ == 'Context.next_toward' (len=19)."
    - "decimal.Context.__name__ == 'Context' (len=7); __module__ == 'decimal'; __bases__[0].__name__ == 'object'; MRO length == 2."
    - "decimal.Context.__doc__ is a str of length 406."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context class identity
# Context.__name__ == 'Context' (len=7); __module__ == 'decimal'.
# __class__.__name__ == 'type'; __bases__[0].__name__ == 'object'.
# MRO length == 2; __doc__ len == 406.
# ---------------------------------------------------------------------------

table decimal_extra141.Context_class_identity:
  description: "decimal.Context class identity: __name__='Context' (7), __module__='decimal', __class__.__name__='type', __bases__[0]='object', MRO length=2, __doc__ len=406"
  kind: python_call_eq
  category: class_identity
  id_prefix: decctx141

  columns: [id, function, args, expected, description]
  rows:
    - [ctx_name_eq,    Context.__name__.__eq__,                    ["Context"], true, "decimal.Context.__name__ == 'Context'"]
    - [ctx_name_len,   Context.__name__.__len__,                   [],          7,    "decimal.Context.__name__.__len__() == 7 ('Context' has 7 characters)"]
    - [ctx_module_eq,  Context.__module__.__eq__,                  ["decimal"], true, "decimal.Context.__module__ == 'decimal'"]
    - [ctx_cls_eq,     Context.__class__.__name__.__eq__,          ["type"],    true, "decimal.Context.__class__.__name__ == 'type' (a regular class, not an enum or ABC)"]
    - [ctx_base0_eq,   "Context.__bases__[0].__name__.__eq__",     ["object"],  true, "decimal.Context.__bases__[0].__name__ == 'object' (Context directly subclasses object)"]
    - [ctx_mro_len,    "Context.__mro__.__len__",                  [],          2,    "decimal.Context.__mro__.__len__() == 2 ([Context, object]; a flat MRO with only two entries)"]
    - [ctx_doc_cls,    Context.__doc__.__class__.__name__.__eq__,  ["str"],     true, "decimal.Context.__doc__ is a str (non-None; describes rounding, traps, and flags controlled by the context)"]
    - [ctx_doc_len,    Context.__doc__.__len__,                    [],          406,  "decimal.Context.__doc__.__len__() == 406 (406 characters; opens with 'The context affects almost all operations and controls rounding, Over/Underflow,')"]

# ---------------------------------------------------------------------------
# decimal.Context short method qualnames (len <= 13)
# ln=10 (shortest), add/exp/fma/abs=11, sqrt=12, power/log10=13.
# ---------------------------------------------------------------------------

table decimal_extra141.Context_short_method_qualnames:
  description: "decimal.Context short method qualnames: ln=10, add/exp/fma/abs=11, sqrt=12, power/log10=13"
  kind: python_call_eq
  category: qualname
  id_prefix: decctx141

  columns: [id, function, args, expected, description]
  rows:
    - [ln_qeq,     Context.ln.__qualname__.__eq__,    ["Context.ln"],    true, "decimal.Context.ln.__qualname__ == 'Context.ln' (natural logarithm; len=10; the shortest Context method qualname — 'ln' is only 2 characters)"]
    - [ln_qlen,    Context.ln.__qualname__.__len__,   [],                10,   "decimal.Context.ln.__qualname__.__len__() == 10 ('Context.ln' has 10 characters; shortest of all Context method qualnames)"]
    - [add_qeq,    Context.add.__qualname__.__eq__,   ["Context.add"],   true, "decimal.Context.add.__qualname__ == 'Context.add' (addition; len=11)"]
    - [add_qlen,   Context.add.__qualname__.__len__,  [],                11,   "decimal.Context.add.__qualname__.__len__() == 11 ('Context.add' has 11 characters; tied with exp, fma, and abs)"]
    - [exp_qeq,    Context.exp.__qualname__.__eq__,   ["Context.exp"],   true, "decimal.Context.exp.__qualname__ == 'Context.exp' (exponential function e**x; len=11)"]
    - [exp_qlen,   Context.exp.__qualname__.__len__,  [],                11,   "decimal.Context.exp.__qualname__.__len__() == 11 (tied with add, fma, abs at 11)"]
    - [fma_qeq,    Context.fma.__qualname__.__eq__,   ["Context.fma"],   true, "decimal.Context.fma.__qualname__ == 'Context.fma' (fused multiply-add: a*b+c; len=11)"]
    - [fma_qlen,   Context.fma.__qualname__.__len__,  [],                11,   "decimal.Context.fma.__qualname__.__len__() == 11 (tied with add and exp at 11)"]
    - [abs_qeq,    Context.abs.__qualname__.__eq__,   ["Context.abs"],   true, "decimal.Context.abs.__qualname__ == 'Context.abs' (absolute value; len=11)"]
    - [sqrt_qeq,   Context.sqrt.__qualname__.__eq__,  ["Context.sqrt"],  true, "decimal.Context.sqrt.__qualname__ == 'Context.sqrt' (square root; len=12)"]
    - [sqrt_qlen,  Context.sqrt.__qualname__.__len__, [],                12,   "decimal.Context.sqrt.__qualname__.__len__() == 12 ('Context.sqrt' has 12 characters)"]
    - [power_qeq,  Context.power.__qualname__.__eq__, ["Context.power"], true, "decimal.Context.power.__qualname__ == 'Context.power' (base**exponent with context; len=13)"]
    - [power_qlen, Context.power.__qualname__.__len__,[],                13,   "decimal.Context.power.__qualname__.__len__() == 13 ('Context.power' has 13 characters; tied with log10)"]
    - [log10_qeq,  Context.log10.__qualname__.__eq__, ["Context.log10"], true, "decimal.Context.log10.__qualname__ == 'Context.log10' (base-10 logarithm; len=13; tied with power)"]
    - [log10_qlen, Context.log10.__qualname__.__len__,[],                13,   "decimal.Context.log10.__qualname__.__len__() == 13 (tied with power at 13)"]

# ---------------------------------------------------------------------------
# decimal.Context medium and long method qualnames (len 14-22)
# divide=14, max_mag/min_mag=15, multiply/subtract/quantize/copy_abs=16,
# normalize/copy_sign=17, next_toward=19, remainder_near/create_decimal=22.
# ---------------------------------------------------------------------------

table decimal_extra141.Context_long_method_qualnames:
  description: "decimal.Context longer method qualnames: divide=14, max_mag/min_mag=15, multiply/subtract/quantize/copy_abs=16, normalize/copy_sign=17, next_toward=19, remainder_near/create_decimal=22"
  kind: python_call_eq
  category: qualname
  id_prefix: decctx141

  columns: [id, function, args, expected, description]
  rows:
    - [divide_qeq,       Context.divide.__qualname__.__eq__,         ["Context.divide"],         true, "decimal.Context.divide.__qualname__ == 'Context.divide' (division; len=14)"]
    - [divide_qlen,      Context.divide.__qualname__.__len__,        [],                          14,   "decimal.Context.divide.__qualname__.__len__() == 14 ('Context.divide' has 14 characters)"]
    - [maxmag_qeq,       Context.max_mag.__qualname__.__eq__,        ["Context.max_mag"],        true, "decimal.Context.max_mag.__qualname__ == 'Context.max_mag' (max by magnitude; len=15)"]
    - [maxmag_qlen,      Context.max_mag.__qualname__.__len__,       [],                          15,   "decimal.Context.max_mag.__qualname__.__len__() == 15 ('Context.max_mag' has 15 characters; tied with min_mag)"]
    - [minmag_qeq,       Context.min_mag.__qualname__.__eq__,        ["Context.min_mag"],        true, "decimal.Context.min_mag.__qualname__ == 'Context.min_mag' (min by magnitude; len=15; tied with max_mag)"]
    - [multiply_qeq,     Context.multiply.__qualname__.__eq__,       ["Context.multiply"],       true, "decimal.Context.multiply.__qualname__ == 'Context.multiply' (multiplication; len=16)"]
    - [multiply_qlen,    Context.multiply.__qualname__.__len__,      [],                          16,   "decimal.Context.multiply.__qualname__.__len__() == 16 ('Context.multiply' has 16 characters; tied with subtract, quantize, copy_abs)"]
    - [subtract_qeq,     Context.subtract.__qualname__.__eq__,       ["Context.subtract"],       true, "decimal.Context.subtract.__qualname__ == 'Context.subtract' (subtraction; len=16; tied with multiply)"]
    - [quantize_qeq,     Context.quantize.__qualname__.__eq__,       ["Context.quantize"],       true, "decimal.Context.quantize.__qualname__ == 'Context.quantize' (set exponent of result; len=16)"]
    - [copy_abs_qeq,     Context.copy_abs.__qualname__.__eq__,       ["Context.copy_abs"],       true, "decimal.Context.copy_abs.__qualname__ == 'Context.copy_abs' (copy of value with positive sign; len=16)"]
    - [normalize_qeq,    Context.normalize.__qualname__.__eq__,      ["Context.normalize"],      true, "decimal.Context.normalize.__qualname__ == 'Context.normalize' (reduce trailing zeros; len=17)"]
    - [normalize_qlen,   Context.normalize.__qualname__.__len__,     [],                          17,   "decimal.Context.normalize.__qualname__.__len__() == 17 ('Context.normalize' has 17 characters; tied with copy_sign)"]
    - [copy_sign_qeq,    Context.copy_sign.__qualname__.__eq__,      ["Context.copy_sign"],      true, "decimal.Context.copy_sign.__qualname__ == 'Context.copy_sign' (copy sign from second to first; len=17; tied with normalize)"]
    - [next_toward_qeq,  Context.next_toward.__qualname__.__eq__,    ["Context.next_toward"],    true, "decimal.Context.next_toward.__qualname__ == 'Context.next_toward' (next representable value toward second; len=19)"]
    - [next_toward_qlen, Context.next_toward.__qualname__.__len__,   [],                          19,   "decimal.Context.next_toward.__qualname__.__len__() == 19 ('Context.next_toward' has 19 characters)"]
    - [rem_near_qeq,     Context.remainder_near.__qualname__.__eq__, ["Context.remainder_near"], true, "decimal.Context.remainder_near.__qualname__ == 'Context.remainder_near' (IEEE 754 remainder; len=22; tied for longest)"]
    - [rem_near_qlen,    Context.remainder_near.__qualname__.__len__,[],                          22,   "decimal.Context.remainder_near.__qualname__.__len__() == 22 ('Context.remainder_near' has 22 characters; tied with create_decimal for the longest Context method qualname)"]
    - [create_dec_qeq,   Context.create_decimal.__qualname__.__eq__, ["Context.create_decimal"], true, "decimal.Context.create_decimal.__qualname__ == 'Context.create_decimal' (create a Decimal from a value; len=22; tied with remainder_near for longest)"]
    - [create_dec_qlen,  Context.create_decimal.__qualname__.__len__,[],                          22,   "decimal.Context.create_decimal.__qualname__.__len__() == 22 (tied with remainder_near at 22; both are the longest Context method qualnames)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra141.Context.ln_qualname_len_10:
  description: "decimal.Context.ln.__qualname__.__len__() == 10 ('Context.ln' has 10 characters; the shortest Context method qualname; 'ln' is only 2 characters — the natural logarithm function abbreviated from the Latin 'logarithmus naturalis')"
  category: qualname
  kind: python_call_eq
  function: Context.ln.__qualname__.__len__
  args: []
  expected: 10

invariant decimal_extra141.Context.add_qualname_eq:
  description: "decimal.Context.add.__qualname__ == 'Context.add' (len=11) — all decimal.Context method qualnames use the public class name 'Context' in the 'Context.<method>' pattern, analogous to how Decimal methods use 'Decimal.<method>' (decimal_extra140)"
  category: qualname
  kind: python_call_eq
  function: Context.add.__qualname__.__eq__
  args: ["Context.add"]
  expected: true

invariant decimal_extra141.Context.remainder_near_qualname_len_22:
  description: "decimal.Context.remainder_near.__qualname__.__len__() == 22 ('Context.remainder_near' has 22 characters; tied with create_decimal (22) for the longest Context method qualname; 'Context.' prefix (8) + 'remainder_near' (14) = 22)"
  category: qualname
  kind: python_call_eq
  function: Context.remainder_near.__qualname__.__len__
  args: []
  expected: 22

invariant decimal_extra141.Context.create_decimal_qualname_eq:
  description: "decimal.Context.create_decimal.__qualname__ == 'Context.create_decimal' (len=22; tied with remainder_near for the longest Context method qualname; create_decimal creates a new Decimal object from a value, applying the rounding and precision of the calling context)"
  category: qualname
  kind: python_call_eq
  function: Context.create_decimal.__qualname__.__eq__
  args: ["Context.create_decimal"]
  expected: true

invariant decimal_extra141.Context.normalize_qualname_eq:
  description: "decimal.Context.normalize.__qualname__ == 'Context.normalize' (len=17) — Context.normalize reduces trailing zeros in the coefficient of a Decimal to produce the simplest equivalent form; this parallels Decimal.normalize.__qualname__ == 'Decimal.normalize' (also len=17) from decimal_extra140"
  category: qualname
  kind: python_call_eq
  function: Context.normalize.__qualname__.__eq__
  args: ["Context.normalize"]
  expected: true

invariant decimal_extra141.Context.sqrt_qualname_eq:
  description: "decimal.Context.sqrt.__qualname__ == 'Context.sqrt' (len=12) — the Context version of square root respects the Context's precision and rounding mode; Context.sqrt.__qualname__ (12 chars) is 1 character longer than Decimal.sqrt.__qualname__ == 'Decimal.sqrt' (also 12 chars — 'Decimal.' is 8 chars vs 'Context.' also 8 chars, so both prefix + 'sqrt' = 12)"
  category: qualname
  kind: python_call_eq
  function: Context.sqrt.__qualname__.__eq__
  args: ["Context.sqrt"]
  expected: true

invariant decimal_extra141.Context.name_len_7:
  description: "decimal.Context.__name__.__len__() == 7 ('Context' has 7 characters; the same length as 'Decimal' (7) — both the Decimal number type and its arithmetic context have 7-character class names)"
  category: class_identity
  kind: python_call_eq
  function: Context.__name__.__len__
  args: []
  expected: 7

invariant decimal_extra141.Context.mro_len_2:
  description: "decimal.Context.__mro__.__len__() == 2 (MRO is [Context, object]; Context directly subclasses object with no intermediate types; this is a simpler MRO than the decimal exception classes like Underflow (MRO length 9) covered in decimal_extra139)"
  category: class_identity
  kind: python_call_eq
  function: "Context.__mro__.__len__"
  args: []
  expected: 2
