spec: theseus_optparse_cr
version: ">=3.0"
backend: python_cleanroom(theseus_optparse_cr)
blocks: optparse

docs: https://docs.python.org/3/library/optparse.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/optparse.html"
  not_derived_from:
    - "CPython source: Lib/optparse.py"
  notes:
    - "Clean-room optparse module. Do NOT import optparse."

error_model: python_exceptions

invariant theseus_optparse_cr.optparse2_parse:
  description: "OptionParser can parse simple options"
  category: behavior
  kind: python_call_eq
  function: optparse2_parse
  args: []
  expected: true

invariant theseus_optparse_cr.optparse2_defaults:
  description: "Option defaults are set correctly"
  category: behavior
  kind: python_call_eq
  function: optparse2_defaults
  args: []
  expected: true

invariant theseus_optparse_cr.optparse2_error:
  description: "OptionValueError exists as Exception subclass"
  category: behavior
  kind: python_call_eq
  function: optparse2_error
  args: []
  expected: true
