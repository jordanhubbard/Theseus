# ---------------------------------------------------------------------------
# Standalone invariants — extra140
# ---------------------------------------------------------------------------

invariant asyncio_extra140.run_qualname_len_3:
  description: "asyncio.run.__qualname__.__len__() == 3 — asyncio.run.__qualname__ is 'run' (3 chars: the shortest qualname of all top-level asyncio task functions — compare: 'sleep'=5, 'gather'=6, 'shield'=6, 'wait_for'=8, 'create_task'=11, 'ensure_future'=13); run.__module__=='asyncio.runners' (len=15, distinct from asyncio.tasks where sleep/gather/wait_for live); run.__code__.co_argcount==1; run.__code__.co_kwonlyargcount==2; NEW in extra140: first standalone run qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.run.__qualname__.__len__
  args: []
  expected: 3

invariant asyncio_extra140.run_module_len_15:
  description: "asyncio.run.__module__.__len__() == 15 — asyncio.run.__module__ is 'asyncio.runners' (15 chars: 'asyncio'=7+'.'=1+'runners'=7=15); this is distinct from 'asyncio.tasks' (len=13) where sleep, gather, wait_for, ensure_future, create_task, shield all live; asyncio.run is the only top-level task function in asyncio.runners; NEW in extra140: first standalone run module length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.run.__module__.__len__
  args: []
  expected: 15

invariant asyncio_extra140.run_co_kwonlyargcount_2:
  description: "asyncio.run.__code__.co_kwonlyargcount == 2 — asyncio.run takes 'debug' and 'loop_factory' as keyword-only parameters (co_kwonlyargcount==2); co_argcount==1 (only 'main' is positional); co_varnames.__len__()==4; NEW in extra140: first standalone run co_kwonlyargcount invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.run.__code__.co_kwonlyargcount
  args: []
  expected: 2

invariant asyncio_extra140.run_co_varnames_len_4:
  description: "asyncio.run.__code__.co_varnames.__len__() == 4 — asyncio.run.__code__.co_varnames is ('main','debug','loop_factory','runner') (len=4); co_argcount==1 ('main'), co_kwonlyargcount==2 ('debug','loop_factory'), and 'runner' is a local variable; NEW in extra140: first standalone run co_varnames length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.run.__code__.co_varnames.__len__
  args: []
  expected: 4

invariant asyncio_extra140.wait_for_co_varnames_len_3:
  description: "asyncio.wait_for.__code__.co_varnames.__len__() == 3 — asyncio.wait_for.__code__.co_varnames is ('fut','timeout','exc') (len=3); co_argcount==2 ('fut','timeout' are positional); 'exc' is a local for the caught exception; wait_for is a coroutine function (iscoroutinefunction==True); NEW in extra140: first standalone wait_for co_varnames length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.wait_for.__code__.co_varnames.__len__
  args: []
  expected: 3

invariant asyncio_extra140.ensure_future_qualname_len_13:
  description: "asyncio.ensure_future.__qualname__.__len__() == 13 — asyncio.ensure_future.__qualname__ is 'ensure_future' (13 chars: 'ensure'=6+'_'=1+'future'=6=13); coincidentally same length as ensure_future.__module__ ('asyncio.tasks', also len=13); ensure_future.__code__.co_argcount==1; co_varnames.__len__()==4; NEW in extra140: first standalone ensure_future qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
