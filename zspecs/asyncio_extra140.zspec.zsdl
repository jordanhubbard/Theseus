table asyncio_extra140.wait_for_identity:
  description: "asyncio.wait_for qualname, module, and code attribute checks — wait_for.__qualname__.__eq__('wait_for')==True (len=8: 'wait'=4+'_'=1+'for'=3=8); wait_for.__module__.__eq__('asyncio.tasks')==True (len=13); wait_for.__code__.co_argcount==2 ('fut' and 'timeout' are both positional); wait_for.__code__.co_varnames.__len__()==3 ('fut','timeout','exc' — 'exc' is the local for the caught exception); 'fut' and 'timeout' are in co_varnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciowaitfor140

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,         asyncio.wait_for.__qualname__.__eq__,               ["wait_for"],        true, "asyncio.wait_for.__qualname__ == 'wait_for' (len=8); verified with Python 3.14.3"]
    - [qn_len,        asyncio.wait_for.__qualname__.__len__,               [],                 8,    "asyncio.wait_for.__qualname__.__len__() == 8; verified with Python 3.14.3"]
    - [mod_eq,        asyncio.wait_for.__module__.__eq__,                 ["asyncio.tasks"],   true, "asyncio.wait_for.__module__ == 'asyncio.tasks' (len=13); verified with Python 3.14.3"]
    - [mod_len,       asyncio.wait_for.__module__.__len__,                 [],                 13,   "asyncio.wait_for.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [argc,          asyncio.wait_for.__code__.co_argcount.__eq__,       [2],                 true, "asyncio.wait_for.__code__.co_argcount == 2 ('fut','timeout'); verified with Python 3.14.3"]
    - [varnames_len,  asyncio.wait_for.__code__.co_varnames.__len__,       [],                 3,    "asyncio.wait_for.__code__.co_varnames.__len__() == 3 ('fut','timeout','exc'); verified with Python 3.14.3"]
    - [fut_in,        asyncio.wait_for.__code__.co_varnames.__contains__,  ["fut"],            true, "asyncio.wait_for.__code__.co_varnames contains 'fut'; verified with Python 3.14.3"]
    - [timeout_in,    asyncio.wait_for.__code__.co_varnames.__contains__,  ["timeout"],        true, "asyncio.wait_for.__code__.co_varnames contains 'timeout'; verified with Python 3.14.3"]

