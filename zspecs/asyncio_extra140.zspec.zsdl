spec: asyncio_extra140
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio task functions documentation"
    - "https://docs.python.org/3/library/asyncio-runner.html — Python asyncio runner documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/runners.py, Lib/asyncio/tasks.py"
  notes:
    - "This spec covers: asyncio.run — module-level function in asyncio.runners. asyncio.run.__qualname__=='run' (len=3); asyncio.run.__module__=='asyncio.runners' (len=15); asyncio.run.__code__.co_argcount==1 ('main' is the only positional param; 'debug' and 'loop_factory' are keyword-only, co_kwonlyargcount==2); asyncio.run.__code__.co_varnames.__len__()==4 ('main','debug','loop_factory','runner'). Also asyncio.wait_for — coroutine function: __qualname__=='wait_for' (len=8); __module__=='asyncio.tasks' (len=13); co_argcount==2 ('fut','timeout'); co_varnames.__len__()==3 ('fut','timeout','exc'). Also asyncio.ensure_future: __qualname__=='ensure_future' (len=13); co_argcount==1; co_varnames.__len__()==4. Also asyncio.create_task: __qualname__=='create_task' (len=11); co_argcount==1; co_varnames.__len__()==3. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.run.__code__.co_kwonlyargcount==2 because 'debug' and 'loop_factory' are keyword-only parameters in the def run(main, *, debug=None, loop_factory=None) signature. co_argcount==1 counts only positional-or-keyword params. asyncio.wait_for is a coroutine function (iscoroutinefunction returns True); co_argcount==2 ('fut','timeout'); co_varnames==('fut','timeout','exc') (len=3 — 'exc' is a local for the caught exception). asyncio.ensure_future co_varnames==('coro_or_future','loop','should_close','_wrap_awaitable') (len=4). asyncio.create_task co_varnames==('coro','kwargs','loop') (len=3). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.run qualname, module, code — extra140
#
# asyncio.run.__qualname__                 == 'run'              (len=3)
# asyncio.run.__module__                   == 'asyncio.runners'  (len=15)
# asyncio.run.__code__.co_argcount         == 1
# asyncio.run.__code__.co_kwonlyargcount   == 2
# asyncio.run.__code__.co_varnames len     == 4
# ---------------------------------------------------------------------------

table asyncio_extra140.run_identity:
  description: "asyncio.run qualname, module, and code attribute checks — run.__qualname__.__eq__('run')==True (len=3: shortest qualname of all top-level asyncio task functions); run.__module__.__eq__('asyncio.runners')==True (len=15: 'asyncio'=7+'.'=1+'runners'=7=15, distinct from asyncio.tasks); run.__code__.co_argcount==1 ('main' is the only positional param); run.__code__.co_kwonlyargcount==2 ('debug' and 'loop_factory' are keyword-only); run.__code__.co_varnames.__len__()==4 ('main','debug','loop_factory','runner'); 'main' and 'runner' are in co_varnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciorun140

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,         asyncio.run.__qualname__.__eq__,                    ["run"],             true, "asyncio.run.__qualname__ == 'run' (len=3); verified with Python 3.14.3"]
    - [qn_len,        asyncio.run.__qualname__.__len__,                    [],                 3,    "asyncio.run.__qualname__.__len__() == 3; verified with Python 3.14.3"]
    - [mod_eq,        asyncio.run.__module__.__eq__,                      ["asyncio.runners"], true, "asyncio.run.__module__ == 'asyncio.runners' (len=15); verified with Python 3.14.3"]
    - [mod_len,       asyncio.run.__module__.__len__,                      [],                 15,   "asyncio.run.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [argc,          asyncio.run.__code__.co_argcount.__eq__,            [1],                 true, "asyncio.run.__code__.co_argcount == 1 ('main' is the only positional param); verified with Python 3.14.3"]
    - [kwonly,        asyncio.run.__code__.co_kwonlyargcount.__eq__,      [2],                 true, "asyncio.run.__code__.co_kwonlyargcount == 2 ('debug','loop_factory'); verified with Python 3.14.3"]
    - [varnames_len,  asyncio.run.__code__.co_varnames.__len__,            [],                 4,    "asyncio.run.__code__.co_varnames.__len__() == 4 ('main','debug','loop_factory','runner'); verified with Python 3.14.3"]
    - [main_in,       asyncio.run.__code__.co_varnames.__contains__,      ["main"],            true, "asyncio.run.__code__.co_varnames contains 'main'; verified with Python 3.14.3"]
    - [runner_in,     asyncio.run.__code__.co_varnames.__contains__,      ["runner"],          true, "asyncio.run.__code__.co_varnames contains 'runner'; verified with Python 3.14.3"]

