spec: socket_extra81
version: ">=3.9"
extends: socket_extra80
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra80.zspec.zsdl — covers AF_INET/AF_INET6/AF_UNIX/__class__/__name__=='AddressFamily' / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW/__class__/__name__=='SocketKind' / AF_INET/__eq__(2)/AF_INET6/__eq__(30)/SOCK_STREAM/__eq__(1)/SOCK_DGRAM/__eq__(2) / AddressFamily/SocketKind class identity (table + invariants)."
    - "socket_extra79.zspec.zsdl — covers socket.gethostname/gethostbyname/getaddrinfo/getnameinfo/setdefaulttimeout/getdefaulttimeout/inet_aton/inet_ntoa/htons __class__/__name__/__module__/__qualname__ (table + invariants)."
    - "socket_extra78.zspec.zsdl — covers socket.socket/__name__/__module__ / socket.error/__name__/__module__ / socket.gaierror/herror identity (table + invariants)."
    - "socket_extra35.zspec.zsdl — covers AddressFamily/SocketKind/__mro__.__len__()==6 (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra80; it does NOT duplicate invariants present in those files."
    - "Wave 248 theme: socket IPPROTO_* constants and SOL_SOCKET/SOMAXCONN/AF_UNSPEC constant identity (class names and integer values)."
    - "socket.IPPROTO_TCP.__class__.__name__ == 'int' — IPPROTO_TCP is a plain int constant (NOT an IntEnum). No prior socket spec checks IPPROTO_TCP.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_UDP.__class__.__name__ == 'int' — IPPROTO_UDP is a plain int constant. No prior socket spec checks IPPROTO_UDP.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_IP.__class__.__name__ == 'int' — IPPROTO_IP is a plain int constant. No prior socket spec checks IPPROTO_IP.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_IPV6.__class__.__name__ == 'int' — IPPROTO_IPV6 is a plain int constant. No prior socket spec checks IPPROTO_IPV6.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOL_SOCKET.__class__.__name__ == 'int' — SOL_SOCKET is a plain int constant. No prior socket spec checks SOL_SOCKET.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_TCP.__eq__(6) == True — IPPROTO_TCP == 6 on all platforms. No prior socket spec checks IPPROTO_TCP.__eq__(6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_UDP.__eq__(17) == True — IPPROTO_UDP == 17 on all platforms. No prior socket spec checks IPPROTO_UDP.__eq__(17). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_IP.__eq__(0) == True — IPPROTO_IP == 0 on all platforms. No prior socket spec checks IPPROTO_IP.__eq__(0). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOL_SOCKET.__eq__(65535) == True — SOL_SOCKET == 65535 on macOS/BSD (value is 1 on Linux). macOS-specific. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOMAXCONN.__class__.__name__ == 'int' — SOMAXCONN is a plain int constant. No prior socket spec checks SOMAXCONN.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOMAXCONN.__eq__(128) == True — SOMAXCONN == 128 on macOS. No prior socket spec checks SOMAXCONN.__eq__(128). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNSPEC.__class__.__name__ == 'AddressFamily' — AF_UNSPEC is an AddressFamily IntEnum member (NOT a plain int). No prior socket spec checks AF_UNSPEC.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNSPEC.__eq__(0) == True — AF_UNSPEC == 0 on all platforms. No prior socket spec checks AF_UNSPEC.__eq__(0). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP/__class__/__name__ / IPPROTO_UDP/__class__/__name__
# socket.IPPROTO_IP/__class__/__name__ / IPPROTO_IPV6/__class__/__name__
# socket.SOL_SOCKET/__class__/__name__
#
# Wave 248 theme: IPPROTO_* and SOL_* constant class name identity.
#
# IPPROTO_TCP, IPPROTO_UDP, IPPROTO_IP, IPPROTO_IPV6, and SOL_SOCKET are all
# plain int constants (not IntEnum members like AF_INET/SOCK_STREAM).
# Their __class__.__name__ is 'int'. No prior socket spec checks any of these
# __class__.__name__ values. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra81.ipproto_sol_class_names:
  description: "socket.IPPROTO_TCP/__class__/__name__.__eq__('int')==True / IPPROTO_UDP/__class__/__name__.__eq__('int')==True / IPPROTO_IP/__class__/__name__.__eq__('int')==True / IPPROTO_IPV6/__class__/__name__.__eq__('int')==True / SOL_SOCKET/__class__/__name__.__eq__('int')==True — IPPROTO_* and SOL_SOCKET are plain int constants (unlike AF_* which are AddressFamily IntEnum); no prior socket spec checks these __class__.__name__ values; first class name anchor for IPPROTO_TCP/UDP/IP/IPV6 and SOL_SOCKET"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra81

  columns: [id, function, args, expected]
  rows:
    - [ipproto_tcp_class_int,  IPPROTO_TCP.__class__.__name__.__eq__,  ["int"], true]
    - [ipproto_udp_class_int,  IPPROTO_UDP.__class__.__name__.__eq__,  ["int"], true]
    - [ipproto_ip_class_int,   IPPROTO_IP.__class__.__name__.__eq__,   ["int"], true]
    - [ipproto_ipv6_class_int, IPPROTO_IPV6.__class__.__name__.__eq__, ["int"], true]
    - [sol_socket_class_int,   SOL_SOCKET.__class__.__name__.__eq__,   ["int"], true]

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__eq__(6) / IPPROTO_UDP.__eq__(17) / IPPROTO_IP.__eq__(0)
# socket.SOL_SOCKET.__eq__(65535)
#
# Wave 248 theme: IPPROTO_* and SOL_SOCKET integer value identity.
#
# IPPROTO_TCP == 6, IPPROTO_UDP == 17, IPPROTO_IP == 0 on all platforms.
# SOL_SOCKET == 65535 on macOS/BSD (1 on Linux).
# No prior socket spec checks any of these __eq__ calls.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra81.ipproto_sol_values:
  description: "socket.IPPROTO_TCP/__eq__(6)==True / IPPROTO_UDP/__eq__(17)==True / IPPROTO_IP/__eq__(0)==True / SOL_SOCKET/__eq__(65535)==True — IPPROTO_TCP==6/IPPROTO_UDP==17/IPPROTO_IP==0 are universal; SOL_SOCKET==65535 is macOS/BSD-specific (Linux uses 1); no prior socket spec checks these integer equality values; first numeric value anchor for IPPROTO_TCP/UDP/IP and SOL_SOCKET"
  kind: python_call_eq
  category: const_values
  id_prefix: socketextra81

  columns: [id, function, args, expected]
  rows:
    - [ipproto_tcp_eq_6,      IPPROTO_TCP.__eq__,   [6],     true]
    - [ipproto_udp_eq_17,     IPPROTO_UDP.__eq__,   [17],    true]
    - [ipproto_ip_eq_0,       IPPROTO_IP.__eq__,    [0],     true]
    - [sol_socket_eq_65535,   SOL_SOCKET.__eq__,    [65535], true]

# ---------------------------------------------------------------------------
# socket.SOMAXCONN/__class__/__name__ / SOMAXCONN.__eq__(128)
# socket.AF_UNSPEC/__class__/__name__ / AF_UNSPEC.__eq__(0)
#
# Wave 248 theme: SOMAXCONN and AF_UNSPEC constant identity.
#
# SOMAXCONN is a plain int (128 on macOS). AF_UNSPEC is an AddressFamily
# IntEnum member with value 0. No prior socket spec checks any of these.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra81.somaxconn_af_unspec_identity:
  description: "socket.SOMAXCONN/__class__/__name__.__eq__('int')==True / SOMAXCONN/__eq__(128)==True / AF_UNSPEC/__class__/__name__.__eq__('AddressFamily')==True / AF_UNSPEC/__eq__(0)==True — SOMAXCONN is a plain int (128 on macOS); AF_UNSPEC is an AddressFamily IntEnum with value 0; no prior socket spec checks these attributes; first identity anchor for socket.SOMAXCONN and socket.AF_UNSPEC"
  kind: python_call_eq
  category: const_values
  id_prefix: socketextra81

  columns: [id, function, args, expected]
  rows:
    - [somaxconn_class_int,            SOMAXCONN.__class__.__name__.__eq__,  ["int"],           true]
    - [somaxconn_eq_128,               SOMAXCONN.__eq__,                     [128],             true]
    - [af_unspec_class_addressfamily,  AF_UNSPEC.__class__.__name__.__eq__,  ["AddressFamily"], true]
    - [af_unspec_eq_0,                 AF_UNSPEC.__eq__,                     [0],               true]

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP/__class__.__name__ / IPPROTO_UDP/__class__.__name__ — extended
#
# Wave 248 theme: IPPROTO contrast with AF_* enum class names.
#
# IPPROTO_TCP and IPPROTO_UDP are plain int (not AddressFamily/SocketKind).
# By contrast, AF_UNSPEC is AddressFamily. This table anchors the contrast.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra81.ipproto_vs_af_class_name_contrast:
  description: "socket.IPPROTO_TCP/__class__/__name__.__eq__('int')==True / IPPROTO_IP/__class__.__name__.__eq__('int')==True — IPPROTO constants are plain int (not wrapped in an IntEnum like AddressFamily or SocketKind); this table anchors the plain-int nature of IPPROTO constants as a cross-check complementing the SOMAXCONN and AF_UNSPEC anchors; first standalone cross-check for IPPROTO plain-int class name in wave 248"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra81

  columns: [id, function, args, expected]
  rows:
    - [ipproto_tcp_class_int_xchk,   IPPROTO_TCP.__class__.__name__.__eq__, ["int"], true]
    - [ipproto_ip_class_int_xchk,    IPPROTO_IP.__class__.__name__.__eq__,  ["int"], true]

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__class__.__name__.__eq__('int') — standalone
#
# IPPROTO_TCP is a plain int. No prior socket spec checks
# IPPROTO_TCP.__class__.__name__. First __class__.__name__ standalone for
# socket.IPPROTO_TCP. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra81.ipproto_tcp_class_int:
  description: "socket.IPPROTO_TCP.__class__.__name__.__eq__('int') == True — IPPROTO_TCP is a plain Python int (value 6) not an IntEnum; no prior socket spec checks IPPROTO_TCP.__class__.__name__; first __class__.__name__ standalone for socket.IPPROTO_TCP"
  category: class_attrs
  kind: python_call_eq
  function: IPPROTO_TCP.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__eq__(6) — standalone
#
# IPPROTO_TCP == 6 on all platforms. No prior socket spec checks
# IPPROTO_TCP.__eq__(6). First integer value standalone for socket.IPPROTO_TCP.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra81.ipproto_tcp_eq_6:
  description: "socket.IPPROTO_TCP.__eq__(6) == True — IPPROTO_TCP is the TCP protocol number (6) universally; no prior socket spec checks IPPROTO_TCP.__eq__(6); first integer value standalone for socket.IPPROTO_TCP"
  category: const_values
  kind: python_call_eq
  function: IPPROTO_TCP.__eq__
  args: [6]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_UNSPEC.__class__.__name__.__eq__('AddressFamily') — standalone
#
# AF_UNSPEC is an AddressFamily IntEnum member. No prior socket spec checks
# AF_UNSPEC.__class__.__name__. First __class__.__name__ standalone for
# socket.AF_UNSPEC. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra81.af_unspec_class_addressfamily:
  description: "socket.AF_UNSPEC.__class__.__name__.__eq__('AddressFamily') == True — AF_UNSPEC is an AddressFamily IntEnum member with value 0; unlike IPPROTO_* constants which are plain int; no prior socket spec checks AF_UNSPEC.__class__.__name__; first __class__.__name__ standalone for socket.AF_UNSPEC"
  category: class_attrs
  kind: python_call_eq
  function: AF_UNSPEC.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOL_SOCKET.__class__.__name__.__eq__('int') — standalone
#
# SOL_SOCKET is a plain int (not an IntEnum). No prior socket spec checks
# SOL_SOCKET.__class__.__name__. First __class__.__name__ standalone for
# socket.SOL_SOCKET. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra81.sol_socket_class_int:
  description: "socket.SOL_SOCKET.__class__.__name__.__eq__('int') == True — SOL_SOCKET is a plain int (value 65535 on macOS/BSD); no prior socket spec checks SOL_SOCKET.__class__.__name__; first __class__.__name__ standalone for socket.SOL_SOCKET"
  category: class_attrs
  kind: python_call_eq
  function: SOL_SOCKET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOMAXCONN.__eq__(128) — standalone
#
# SOMAXCONN == 128 on macOS. No prior socket spec checks SOMAXCONN.__eq__(128).
# First integer value standalone for socket.SOMAXCONN.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra81.somaxconn_eq_128:
  description: "socket.SOMAXCONN.__eq__(128) == True — SOMAXCONN is the maximum backlog for listen() (128 on macOS); no prior socket spec checks SOMAXCONN.__eq__(128); first integer value standalone for socket.SOMAXCONN"
  category: const_values
  kind: python_call_eq
  function: SOMAXCONN.__eq__
  args: [128]
  expected: true
