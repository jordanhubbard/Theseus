spec: pathlib_extra76
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra7."
    - "Prior specs covered: PurePath/PurePosixPath/PureWindowsPath/Path/PosixPath/WindowsPath __name__/__module__/__qualname__; Path instance attributes root/drive/suffix/stem/parts; Path method __name__ checks; Path MRO; Path.name value."
    - "pathlib_extra4.zspec.zsdl covers method __name__ for: iterdir, glob, rglob, open, stat, mkdir, exists, is_file, is_dir, is_symlink, read_text, write_text."
    - "This spec covers: Path method __qualname__ values and lengths for open, read_text, write_text, iterdir, mkdir, exists, unlink, rename, stat."
    - "Path methods are defined in pathlib.py; their __qualname__ is 'Path.<method>'."
    - "Path.open.__qualname__ == 'Path.open' — len 9."
    - "Path.read_text.__qualname__ == 'Path.read_text' — len 14."
    - "Path.write_text.__qualname__ == 'Path.write_text' — len 15."
    - "Path.iterdir.__qualname__ == 'Path.iterdir' — len 12."
    - "Path.mkdir.__qualname__ == 'Path.mkdir' — len 10."
    - "Path.exists.__qualname__ == 'Path.exists' — len 11."
    - "Path.unlink.__qualname__ == 'Path.unlink' — len 11."
    - "Path.rename.__qualname__ == 'Path.rename' — len 11."
    - "Path.stat.__qualname__ == 'Path.stat' — len 9."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path method __qualname__ equality — open, read_text, write_text, iterdir
# pathlib_extra4 checks method __name__; no prior spec checks __qualname__
# for Path methods.
# ---------------------------------------------------------------------------

table pathlib_extra76.Path_method_qualname_eq:
  description: "Path method __qualname__ values are 'Path.<method>'"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pathlibmeth76

  columns: [id, function, args, expected]
  rows:
    - [open,      Path.open.__qualname__.__eq__,      ["Path.open"],      true]
    - [read_text, Path.read_text.__qualname__.__eq__,  ["Path.read_text"],  true]
    - [write_text, Path.write_text.__qualname__.__eq__, ["Path.write_text"], true]
    - [iterdir,   Path.iterdir.__qualname__.__eq__,   ["Path.iterdir"],   true]

# ---------------------------------------------------------------------------
# Path method __qualname__ equality — mkdir, exists, unlink
# ---------------------------------------------------------------------------

table pathlib_extra76.Path_method_qualname_eq_2:
  description: "Path method __qualname__ values for mkdir, exists, unlink"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pathlibmeth76

  columns: [id, function, args, expected]
  rows:
    - [mkdir,  Path.mkdir.__qualname__.__eq__,  ["Path.mkdir"],  true]
    - [exists, Path.exists.__qualname__.__eq__, ["Path.exists"], true]
    - [unlink, Path.unlink.__qualname__.__eq__, ["Path.unlink"], true]

# ---------------------------------------------------------------------------
# Path method __qualname__ length checks — open, read_text, write_text, iterdir
# 'Path.open'       == 9  chars
# 'Path.read_text'  == 14 chars
# 'Path.write_text' == 15 chars
# 'Path.iterdir'    == 12 chars
# ---------------------------------------------------------------------------

table pathlib_extra76.Path_method_qualname_lengths:
  description: "Path method __qualname__ string lengths"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: pathlibmeth76

  columns: [id, function, args, expected]
  rows:
    - [open,      Path.open.__qualname__.__len__,      [], 9]
    - [read_text, Path.read_text.__qualname__.__len__,  [], 14]
    - [write_text, Path.write_text.__qualname__.__len__, [], 15]
    - [iterdir,   Path.iterdir.__qualname__.__len__,   [], 12]

# ---------------------------------------------------------------------------
# Path method __qualname__ length checks — mkdir, exists, stat
# 'Path.mkdir' == 10 chars
# 'Path.exists' == 11 chars
# 'Path.stat'   == 9  chars
# ---------------------------------------------------------------------------

table pathlib_extra76.Path_method_qualname_lengths_2:
  description: "Path method __qualname__ string lengths for mkdir, exists, stat"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: pathlibmeth76

  columns: [id, function, args, expected]
  rows:
    - [mkdir, Path.mkdir.__qualname__.__len__,  [], 10]
    - [exists, Path.exists.__qualname__.__len__, [], 11]
    - [stat,   Path.stat.__qualname__.__len__,   [], 9]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra76.Path_open.qualname_eq:
  description: "pathlib.Path.open.__qualname__ == 'Path.open'"
  category: method_qualnames
  kind: python_call_eq
  function: Path.open.__qualname__.__eq__
  args: ["Path.open"]
  expected: true

invariant pathlib_extra76.Path_read_text.qualname_eq:
  description: "pathlib.Path.read_text.__qualname__ == 'Path.read_text'"
  category: method_qualnames
  kind: python_call_eq
  function: Path.read_text.__qualname__.__eq__
  args: ["Path.read_text"]
  expected: true

invariant pathlib_extra76.Path_open.qualname_len_9:
  description: "len('Path.open') == 9 — verified via Path.open.__qualname__.__len__"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Path.open.__qualname__.__len__
  args: []
  expected: 9

invariant pathlib_extra76.Path_read_text.qualname_len_14:
  description: "len('Path.read_text') == 14 — verified via Path.read_text.__qualname__.__len__"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Path.read_text.__qualname__.__len__
  args: []
  expected: 14

invariant pathlib_extra76.Path_write_text.qualname_len_15:
  description: "len('Path.write_text') == 15 — verified via Path.write_text.__qualname__.__len__"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Path.write_text.__qualname__.__len__
  args: []
  expected: 15
