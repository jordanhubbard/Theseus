spec: shutil_extra7
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
  notes:
    - "This spec extends shutil.zspec.zsdl and prior extras."
    - "shutil.zspec.zsdl covers: function_names table (copy/copy2/copyfile/copyfileobj/copymode/copystat/copytree/rmtree/move/disk_usage/which/make_archive/unpack_archive/get_archive_formats/get_unpack_formats/get_terminal_size/chown); Error/SameFileError __name__; disk_usage/_fields/total/free; which nonexistent; archive_formats; unpack_formats; COPY_BUFSIZE."
    - "shutil_extra.zspec.zsdl covers: copy/copy2/copyfile/copyfileobj/copytree/rmtree/move/make_archive/unpack_archive/disk_usage/which __name__ standalone; copy.__module__; get_archive_formats/get_unpack_formats returns_list; Error.__name__/base OSError."
    - "shutil_extra2.zspec.zsdl covers: copy2/copyfileobj/which/disk_usage/make_archive/unpack_archive/get_archive_formats __name__; which/make_archive/unpack_archive __module__; disk_usage total/used/free type."
    - "shutil_extra3.zspec.zsdl covers: copy2/copyfile/copytree/rmtree/move/disk_usage/get_archive_formats/get_unpack_formats __module__; disk_usage result class name; SameFileError base; ExecError module/is_type; Error module; get_archive_formats/get_unpack_formats is_callable."
    - "shutil_extra4.zspec.zsdl covers: copy/copy2/copyfile/copyfileobj/copytree/rmtree/move/disk_usage/which/get_terminal_size/get_archive_formats/make_archive __name__ table; Error/SameFileError __name__ table; Error/SameFileError base; disk_usage named tuple class name; disk_usage total>0; get_archive_formats returns list."
    - "shutil_extra5.zspec.zsdl covers: copy/copy2/copyfile/copytree/rmtree/move/make_archive/unpack_archive/disk_usage/which/get_terminal_size __qualname__; Error/SameFileError __qualname__; copy/copy2/copyfile/rmtree/move/which/unpack_archive __module__ table; Error/SameFileError __module__ table."
    - "shutil_extra6.zspec.zsdl covers: Error/SameFileError/ReadError __name__ table; Error/SameFileError/ReadError __module__ table; Error/ReadError __qualname__; SameFileError base bool form; ReadError base both forms."
    - "This spec adds: __class__.__name__=='function' for copy/copy2/copyfile/rmtree/move/which functions (not in any prior spec); copymode/__name__/__module__/__qualname__/__class__.__name__ (copymode missing from extras); copystat/__name__ standalone/__module__/__qualname__/__class__.__name__ (copystat missing from extras); chown/__qualname__/__module__ (not in any prior extra); get_unpack_formats.__qualname__ (not in extra5); get_terminal_size.__module__ (not in extra5 modules table)."
    - "shutil.copymode and shutil.copystat appear only in shutil.zspec.zsdl function_names table; no extra spec covers their __module__, __qualname__, or __class__.__name__."
    - "shutil.chown.__qualname__ and shutil.chown.__module__ not covered in any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __class__.__name__ == 'function' for core copy functions
# No prior shutil spec checks __class__.__name__ for these functions.
# shutil_extra3 covers get_archive_formats and get_unpack_formats __class__.__name__.
# ---------------------------------------------------------------------------

table shutil_extra7.function_class_names:
  description: "shutil module-level functions report __class__.__name__ == 'function'"
  kind: python_call_eq
  category: function_identity
  id_prefix: fclass7

  columns: [id, function, args, expected]
  rows:
    - [copy,     copy.__class__.__name__.__eq__,     ["function"], true]
    - [rmtree,   rmtree.__class__.__name__.__eq__,   ["function"], true]
    - [move,     move.__class__.__name__.__eq__,     ["function"], true]
    - [which,    which.__class__.__name__.__eq__,    ["function"], true]

# ---------------------------------------------------------------------------
# copymode — __name__, __module__, __qualname__, __class__.__name__
# shutil.zspec.zsdl function_names table includes copymode.__name__.
# No extra spec covers copymode at all.
# ---------------------------------------------------------------------------

invariant shutil_extra7.copymode.name:
  description: "shutil.copymode.__name__ == 'copymode'"
  category: function_names
  kind: python_call_eq
  function: copymode.__name__.__eq__
  args: ["copymode"]
  expected: true

invariant shutil_extra7.copymode.module:
  description: "shutil.copymode.__module__ == 'shutil'"
  category: module_attrs
  kind: python_call_eq
  function: copymode.__module__.__eq__
  args: ["shutil"]
  expected: true

invariant shutil_extra7.copymode.qualname:
  description: "shutil.copymode.__qualname__ == 'copymode'"
  category: qualname_attrs
  kind: python_call_eq
  function: copymode.__qualname__.__eq__
  args: ["copymode"]
  expected: true

invariant shutil_extra7.copymode.class_is_function:
  description: "shutil.copymode.__class__.__name__ == 'function'"
  category: function_identity
  kind: python_call_eq
  function: copymode.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# copystat — __module__, __qualname__, __class__.__name__
# shutil.zspec.zsdl function_names table includes copystat.__name__.
# No extra spec covers copystat __module__, __qualname__, or __class__.__name__.
# ---------------------------------------------------------------------------

invariant shutil_extra7.copystat.module:
  description: "shutil.copystat.__module__ == 'shutil'"
  category: module_attrs
  kind: python_call_eq
  function: copystat.__module__.__eq__
  args: ["shutil"]
  expected: true

invariant shutil_extra7.copystat.class_is_function:
  description: "shutil.copystat.__class__.__name__ == 'function'"
  category: function_identity
  kind: python_call_eq
  function: copystat.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# chown — __qualname__ and __module__
# shutil.zspec.zsdl covers chown.__name__ in the table.
# No extra spec covers chown __qualname__ or __module__.
# ---------------------------------------------------------------------------

invariant shutil_extra7.chown.qualname:
  description: "shutil.chown.__qualname__ == 'chown' — module-level function qualname equals name"
  category: qualname_attrs
  kind: python_call_eq
  function: chown.__qualname__.__eq__
  args: ["chown"]
  expected: true

invariant shutil_extra7.chown.module:
  description: "shutil.chown.__module__ == 'shutil'"
  category: module_attrs
  kind: python_call_eq
  function: chown.__module__.__eq__
  args: ["shutil"]
  expected: true

# ---------------------------------------------------------------------------
# get_unpack_formats — __qualname__
# shutil_extra5 covers get_terminal_size.__qualname__ and all function qualnames
# except get_unpack_formats.
# ---------------------------------------------------------------------------

invariant shutil_extra7.get_unpack_formats.qualname:
  description: "shutil.get_unpack_formats.__qualname__ == 'get_unpack_formats'"
  category: qualname_attrs
  kind: python_call_eq
  function: get_unpack_formats.__qualname__.__eq__
  args: ["get_unpack_formats"]
  expected: true

# ---------------------------------------------------------------------------
# get_terminal_size — __module__
# shutil_extra5 function_modules table does NOT include get_terminal_size.
# ---------------------------------------------------------------------------

invariant shutil_extra7.get_terminal_size.module:
  description: "shutil.get_terminal_size.__module__ == 'shutil'"
  category: module_attrs
  kind: python_call_eq
  function: get_terminal_size.__module__.__eq__
  args: ["shutil"]
  expected: true
