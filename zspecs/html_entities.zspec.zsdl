spec: html_entities
version: ">=3.9"
backend: python_module(html.entities)

docs: https://docs.python.org/3/library/html.entities.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/html.entities.html — Python html.entities module documentation"
    - "https://html.spec.whatwg.org/multipage/named-character-references.html — HTML5 named character references"
    - "Test vectors verified by running Python 3.14.3 html.entities module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/html/entities.py"
  notes:
    - "html.entities.name2codepoint maps HTML 4 entity names (without & and ;) to Unicode codepoints."
    - "html.entities.codepoint2name is the inverse mapping: codepoint int to entity name."
    - "html.entities.entitydefs maps HTML 4 entity names to single-character strings."
    - "html.entities.html5 maps HTML5 named character references (with trailing semicolon) to characters."
    - "All four exports are plain dicts."
    - "codepoint 38 = '&' (AMPERSAND), 60 = '<' (LESS-THAN SIGN), 62 = '>' (GREATER-THAN SIGN), 34 = '\"' (QUOTATION MARK)."
    - "html5 keys retain the trailing semicolon, e.g. 'amp;' not 'amp'."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# module identity
# ---------------------------------------------------------------------------

invariant html_entities.module.name:
  description: "html.entities module __name__ == 'html.entities'"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["html.entities"]
  expected: true

# ---------------------------------------------------------------------------
# name2codepoint — entity name to codepoint integer
# ---------------------------------------------------------------------------

table html_entities.name2codepoint.vectors:
  kind: python_call_eq
  category: name2codepoint
  id_prefix: name2cp
  function: name2codepoint.__getitem__

  columns: [id, args, expected]
  rows:
    - [amp,  ["amp"],  38]
    - [lt,   ["lt"],   60]
    - [gt,   ["gt"],   62]
    - [quot, ["quot"], 34]
    - [nbsp, ["nbsp"], 160]

# ---------------------------------------------------------------------------
# codepoint2name — codepoint integer to entity name
# ---------------------------------------------------------------------------

table html_entities.codepoint2name.vectors:
  kind: python_call_eq
  category: codepoint2name
  id_prefix: cp2name

  columns: [id, function, args, expected]
  rows:
    - [cp38,  codepoint2name.__getitem__, [38],  "amp"]
    - [cp60,  codepoint2name.__getitem__, [60],  "lt"]
    - [cp62,  codepoint2name.__getitem__, [62],  "gt"]
    - [cp34,  codepoint2name.__getitem__, [34],  "quot"]

# ---------------------------------------------------------------------------
# entitydefs — entity name to single-character string
# ---------------------------------------------------------------------------

table html_entities.entitydefs.vectors:
  kind: python_call_eq
  category: entitydefs
  id_prefix: entitydefs
  function: entitydefs.__getitem__

  columns: [id, args, expected]
  rows:
    - [amp, ["amp"], "&"]
    - [lt,  ["lt"],  "<"]
    - [gt,  ["gt"],  ">"]

# ---------------------------------------------------------------------------
# type checks — all four exports are dicts
# ---------------------------------------------------------------------------

invariant html_entities.name2codepoint.is_dict:
  description: "name2codepoint.__class__.__name__ == 'dict'"
  category: types
  kind: python_call_eq
  function: name2codepoint.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant html_entities.html5.is_dict:
  description: "html5.__class__.__name__ == 'dict'"
  category: types
  kind: python_call_eq
  function: html5.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# html5 — HTML5 named character references (keys include trailing semicolon)
# ---------------------------------------------------------------------------

invariant html_entities.html5.amp_semicolon:
  description: "html5['amp;'] == '&' — HTML5 uses trailing semicolon in keys"
  category: html5
  kind: python_call_eq
  function: html5.__getitem__
  args: ["amp;"]
  expected: "&"

invariant html_entities.html5.lt_semicolon:
  description: "html5['lt;'] == '<'"
  category: html5
  kind: python_call_eq
  function: html5.__getitem__
  args: ["lt;"]
  expected: "<"

invariant html_entities.html5.gt_semicolon:
  description: "html5['gt;'] == '>'"
  category: html5
  kind: python_call_eq
  function: html5.__getitem__
  args: ["gt;"]
  expected: ">"
