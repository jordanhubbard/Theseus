spec: theseus_opcode_cr
version: ">=3.8"
backend: python_cleanroom(theseus_opcode_cr)
blocks: opcode

docs: https://docs.python.org/3/library/dis.html#opcode-collections

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/dis.html"
  not_derived_from:
    - "CPython source: Lib/opcode.py"
  notes:
    - "Clean-room opcode module. Do NOT import opcode."

error_model: python_exceptions

invariant theseus_opcode_cr.opcode2_opmap:
  description: "opmap is a non-empty dict mapping opcode names to numbers"
  category: behavior
  kind: python_call_eq
  function: opcode2_opmap
  args: []
  expected: true

invariant theseus_opcode_cr.opcode2_opname:
  description: "opname is a non-empty list of opcode names"
  category: behavior
  kind: python_call_eq
  function: opcode2_opname
  args: []
  expected: true

invariant theseus_opcode_cr.opcode2_load_const:
  description: "LOAD_CONST is in opmap and opname round-trips"
  category: behavior
  kind: python_call_eq
  function: opcode2_load_const
  args: []
  expected: true
