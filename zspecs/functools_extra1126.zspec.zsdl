  columns: [id, function, args, exception]
  rows:
    - [fn1126lr001, functools.lru_cache.__getattribute__,                         ["__wrapped__"],                  "AttributeError"]
    - [fn1126lr002, functools.partial.__getattribute__,                           ["__wrapped__"],                  "AttributeError"]
    - [fn1126lr003, functools.cached_property.__getattribute__,                   ["__wrapped__"],                  "AttributeError"]
    - [fn1126lr004, functools.update_wrapper.__getattribute__,                    ["__wrapped__"],                  "AttributeError"]
    - [fn1126lr005, functools.cmp_to_key.__getattribute__,                        ["__wrapped__"],                  "AttributeError"]
    - [fn1126lr006, functools.total_ordering.__getattribute__,                    ["__wrapped__"],                  "AttributeError"]
    - [fn1126lr007, functools.singledispatch.__getattribute__,                    ["__wrapped__"],                  "AttributeError"]
