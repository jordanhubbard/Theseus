provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks functools.__name__, functools.__spec__.name, functools.__doc__.__class__.__name__, cached_property.__doc__.__class__.__name__, partial.__doc__.__class__.__name__, update_wrapper.__module__, lru_cache.__wrapped__ raises AttributeError, reduce.__module__ — not covered in _extra1096/_extra1111"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1126.module_name_spec_doc:
  description: "functools module-level __name__, __spec__.name, and __doc__ class identity"
  kind: python_call_eq
  category: module_name_spec_doc
  id_prefix: fn1126mn
  columns: [id, function, args, expected]
  rows:
    - [fn1126mn001, functools.__name__.__eq__,                                    ["functools"],                    true]
    - [fn1126mn002, functools.__spec__.name.__eq__,                               ["functools"],                    true]
    - [fn1126mn003, functools.__doc__.__class__.__name__.__eq__,                  ["str"],                          true]
    - [fn1126mn004, functools.cached_property.__doc__.__class__.__name__.__eq__,  ["str"],                          true]
    - [fn1126mn005, functools.partial.__doc__.__class__.__name__.__eq__,          ["str"],                          true]
    - [fn1126mn006, functools.update_wrapper.__module__.__eq__,                   ["functools"],                    true]
    - [fn1126mn007, functools.reduce.__module__.__eq__,                           ["_functools"],                   true]
    - [fn1126mn008, functools.cmp_to_key.__module__.__eq__,                       ["functools"],                    true]

table functools_extra1126.cached_property_doc_and_partial_init:
  description: "functools.cached_property __doc__ string identity, partial.__init__ qualname, lru_cache kwarg forms"
  kind: python_call_eq
  category: cached_property_doc_partial_init
  id_prefix: fn1126ci
  columns: [id, function, args, expected]
  rows:
    - [fn1126ci001, functools.cached_property.__init__.__module__.__eq__,         ["functools"],                    true]
    - [fn1126ci002, functools.cached_property.__init__.__class__.__name__.__eq__, ["function"],                     true]
    - [fn1126ci003, functools.partial.__init__.__qualname__.__eq__,               ["partial.__init__"],             true]
    - [fn1126ci004, functools.partial.__init__.__class__.__name__.__eq__,         ["slot_wrapper"],                 true]
    - [fn1126ci005, functools.lru_cache.__qualname__.__eq__,                      ["lru_cache"],                    true]
    - [fn1126ci006, functools.lru_cache.__doc__.__class__.__name__.__eq__,        ["str"],                          true]
    - [fn1126ci007, functools.wraps.__qualname__.__eq__,                          ["wraps"],                        true]
    - [fn1126ci008, functools.singledispatch.__doc__.__class__.__name__.__eq__,   ["str"],                          true]

table functools_extra1126.lru_cache_wrapped_raises_and_reduce_module:
  description: "functools.lru_cache.__wrapped__ raises AttributeError (not a decorated function) and reduce module"
  kind: python_call_raises
