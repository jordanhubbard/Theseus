spec: functools_extra2701
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 627 theme: __lshift__, __rshift__, and __invert__ dict-presence checks (bit-shift left/right and bitwise NOT)."
    - "functools.partial is a callable wrapper; it does not implement bit-shift or bitwise NOT protocols."
    - "functools.partialmethod is a descriptor; it similarly defines none of __lshift__, __rshift__, or __invert__."
    - "functools.cached_property is a data descriptor (defines __get__, __set__, __delete__) but not __lshift__, __rshift__, or __invert__."
    - "functools.singledispatchmethod is a descriptor wrapper; it does not define __lshift__, __rshift__, or __invert__."
    - "None of the functools public classes define __lshift__, __rshift__, or __invert__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __lshift__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2701.lshift_protocol:
  description: "__lshift__ is absent from all functools class __dict__s — none implement bit-shift left"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2701

  columns: [id, function, args, expected]
  rows:
    - ["ft2701001", "functools.partial.__dict__.__contains__",              ["__lshift__"], false]
    - ["ft2701002", "functools.partialmethod.__dict__.__contains__",        ["__lshift__"], false]
    - ["ft2701003", "functools.cached_property.__dict__.__contains__",      ["__lshift__"], false]
    - ["ft2701004", "functools.singledispatchmethod.__dict__.__contains__",  ["__lshift__"], false]

# ---------------------------------------------------------------------------
# __rshift__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2701.rshift_protocol:
  description: "__rshift__ is absent from all functools class __dict__s — none implement bit-shift right"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2701

  columns: [id, function, args, expected]
  rows:
    - ["ft2701005", "functools.partial.__dict__.__contains__",              ["__rshift__"], false]
    - ["ft2701006", "functools.partialmethod.__dict__.__contains__",        ["__rshift__"], false]
    - ["ft2701007", "functools.cached_property.__dict__.__contains__",      ["__rshift__"], false]
    - ["ft2701008", "functools.singledispatchmethod.__dict__.__contains__",  ["__rshift__"], false]

# ---------------------------------------------------------------------------
# __invert__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2701.invert_protocol:
  description: "__invert__ is absent from all functools class __dict__s — none implement bitwise NOT"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2701

  columns: [id, function, args, expected]
  rows:
    - ["ft2701009", "functools.partial.__dict__.__contains__",              ["__invert__"], false]
    - ["ft2701010", "functools.partialmethod.__dict__.__contains__",        ["__invert__"], false]
    - ["ft2701011", "functools.cached_property.__dict__.__contains__",      ["__invert__"], false]
    - ["ft2701012", "functools.singledispatchmethod.__dict__.__contains__",  ["__invert__"], false]

# ---------------------------------------------------------------------------
# Combined view — partial and partialmethod vs. all three protocols
# ---------------------------------------------------------------------------

table functools_extra2701.partial_bitshift_combined:
  description: "functools.partial and functools.partialmethod define none of __lshift__, __rshift__, __invert__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2701

  columns: [id, function, args, expected]
  rows:
    - ["ft2701013", "functools.partial.__dict__.__contains__",       ["__lshift__"],  false]
    - ["ft2701014", "functools.partial.__dict__.__contains__",       ["__rshift__"],  false]
    - ["ft2701015", "functools.partial.__dict__.__contains__",       ["__invert__"],  false]
    - ["ft2701016", "functools.partialmethod.__dict__.__contains__", ["__lshift__"],  false]
    - ["ft2701017", "functools.partialmethod.__dict__.__contains__", ["__rshift__"],  false]
    - ["ft2701018", "functools.partialmethod.__dict__.__contains__", ["__invert__"],  false]
