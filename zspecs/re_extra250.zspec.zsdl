spec: re_extra250
version: ">=3.6"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module flag integer values and compiled pattern attributes."
    - "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — flags are RegexFlag enum members, not plain ints; verified Python 3.14.3 macOS."
    - "int(re.IGNORECASE) == 2, int(re.MULTILINE) == 8, int(re.DOTALL) == 16, int(re.VERBOSE) == 64; verified Python 3.14.3 macOS."
    - "int(re.UNICODE) == 32, int(re.ASCII) == 256; verified Python 3.14.3 macOS."
    - "re.compile('hello').pattern == 'hello' — compiled pattern stores the source pattern string; verified Python 3.14.3 macOS."
    - "re.compile('hello').flags == 32 — default flags include re.UNICODE (32) even without explicit flags; verified Python 3.14.3 macOS."
    - "re.compile('hello', re.IGNORECASE).flags == 34 — 32 (UNICODE default) + 2 (IGNORECASE); verified Python 3.14.3 macOS."
    - "re.compile('hello').groups == 0 — pattern with no capturing groups; verified Python 3.14.3 macOS."
    - "re.compile('(a)(b)').groups == 2 — pattern with two capturing groups; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# RegexFlag integer values — 5-column table
# re.IGNORECASE etc. are RegexFlag enum members; __int__() returns the int value.
# ---------------------------------------------------------------------------

table re_extra250.flag_values:
  description: "re flag integer values via __int__().__eq__; verified Python 3.14.3"
  kind: python_call_eq
  category: flags
  id_prefix: reflags250

  columns: [id, function, args, expected, description]
  rows:
    - [ignorecase, "re.IGNORECASE.__int__().__eq__", [2],   true, "int(re.IGNORECASE) == 2"]
    - [multiline,  "re.MULTILINE.__int__().__eq__",  [8],   true, "int(re.MULTILINE) == 8"]
    - [dotall,     "re.DOTALL.__int__().__eq__",     [16],  true, "int(re.DOTALL) == 16"]
    - [verbose,    "re.VERBOSE.__int__().__eq__",    [64],  true, "int(re.VERBOSE) == 64"]
    - [unicode,    "re.UNICODE.__int__().__eq__",    [32],  true, "int(re.UNICODE) == 32"]
    - [ascii,      "re.ASCII.__int__().__eq__",      [256], true, "int(re.ASCII) == 256"]

# ---------------------------------------------------------------------------
# Compiled pattern attributes — 5-column table
# re.compile() returns a compiled pattern object with .pattern, .flags, .groups.
# ---------------------------------------------------------------------------

table re_extra250.compiled_pattern:
  description: "re.compile() pattern object attribute values; verified Python 3.14.3"
  kind: python_call_eq
  category: compiled
  id_prefix: recomp250

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_str,    "re.compile('hello').pattern.__eq__",               ["hello"], true, "re.compile('hello').pattern == 'hello'"]
    - [flags_default,  "re.compile('hello').flags.__eq__",                 [32],      true, "re.compile('hello').flags == 32 (re.UNICODE default)"]
    - [flags_igncase,  "re.compile('hello', re.IGNORECASE).flags.__eq__",  [34],      true, "re.compile('hello', re.IGNORECASE).flags == 34 (32+2)"]
    - [groups_zero,    "re.compile('hello').groups.__eq__",                [0],       true, "re.compile('hello').groups == 0 (no capturing groups)"]
    - [groups_two,     "re.compile('(a)(b)').groups.__eq__",               [2],       true, "re.compile('(a)(b)').groups == 2"]

# ---------------------------------------------------------------------------
# Standalone invariants — RegexFlag class membership
# ---------------------------------------------------------------------------

invariant re_extra250.IGNORECASE.classname:
  description: "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — flags are RegexFlag enum members, not plain ints; verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.IGNORECASE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra250.MULTILINE.classname:
  description: "re.MULTILINE.__class__.__name__ == 'RegexFlag' — verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.MULTILINE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — flag int values
# ---------------------------------------------------------------------------

invariant re_extra250.IGNORECASE.int_value:
  description: "int(re.IGNORECASE) == 2 — IGNORECASE flag integer value is 2; verified Python 3.14.3 macOS"
  category: flags
  kind: python_call_eq
  function: re.IGNORECASE.__int__().__eq__
  args: [2]
  expected: true

invariant re_extra250.MULTILINE.int_value:
  description: "int(re.MULTILINE) == 8 — MULTILINE flag integer value is 8; verified Python 3.14.3 macOS"
  category: flags
  kind: python_call_eq
  function: re.MULTILINE.__int__().__eq__
  args: [8]
  expected: true

invariant re_extra250.DOTALL.int_value:
  description: "int(re.DOTALL) == 16 — DOTALL flag integer value is 16; verified Python 3.14.3 macOS"
  category: flags
  kind: python_call_eq
  function: re.DOTALL.__int__().__eq__
  args: [16]
  expected: true

invariant re_extra250.VERBOSE.int_value:
  description: "int(re.VERBOSE) == 64 — VERBOSE flag integer value is 64; verified Python 3.14.3 macOS"
  category: flags
  kind: python_call_eq
  function: re.VERBOSE.__int__().__eq__
  args: [64]
  expected: true

invariant re_extra250.UNICODE.int_value:
  description: "int(re.UNICODE) == 32 — UNICODE flag integer value is 32; also the default flag for compiled patterns; verified Python 3.14.3 macOS"
  category: flags
  kind: python_call_eq
  function: re.UNICODE.__int__().__eq__
  args: [32]
  expected: true

invariant re_extra250.ASCII.int_value:
  description: "int(re.ASCII) == 256 — ASCII flag integer value is 256; verified Python 3.14.3 macOS"
  category: flags
  kind: python_call_eq
  function: re.ASCII.__int__().__eq__
  args: [256]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — compiled pattern attributes
# ---------------------------------------------------------------------------

invariant re_extra250.compile.pattern:
  description: "re.compile('hello').pattern == 'hello' — compiled pattern stores its source string; verified Python 3.14.3 macOS"
  category: compiled
  kind: python_call_eq
  function: re.compile('hello').pattern.__eq__
  args: ["hello"]
  expected: true

invariant re_extra250.compile.flags_default:
  description: "re.compile('hello').flags == 32 — default compilation includes re.UNICODE (32); verified Python 3.14.3 macOS"
  category: compiled
  kind: python_call_eq
  function: re.compile('hello').flags.__eq__
  args: [32]
  expected: true

invariant re_extra250.compile.flags_ignorecase:
  description: "re.compile('hello', re.IGNORECASE).flags == 34 — UNICODE (32) + IGNORECASE (2) = 34; verified Python 3.14.3 macOS"
  category: compiled
  kind: python_call_eq
  function: re.compile('hello', re.IGNORECASE).flags.__eq__
  args: [34]
  expected: true

invariant re_extra250.compile.groups_zero:
  description: "re.compile('hello').groups == 0 — pattern with no capturing groups has groups == 0; verified Python 3.14.3 macOS"
  category: compiled
  kind: python_call_eq
  function: re.compile('hello').groups.__eq__
  args: [0]
  expected: true

invariant re_extra250.compile.groups_two:
  description: "re.compile('(a)(b)').groups == 2 — pattern with two capturing groups has groups == 2; verified Python 3.14.3 macOS"
  category: compiled
  kind: python_call_eq
  function: re.compile('(a)(b)').groups.__eq__
  args: [2]
  expected: true
