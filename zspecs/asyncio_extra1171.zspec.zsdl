spec: asyncio_extra1171
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio.__all__.__contains__ membership checks for Queue/Task/Future/Lock/Event/run/sleep/gather, asyncio.exceptions.__name__ identity, asyncio.locks.__name__ identity, asyncio.tasks.__name__ identity, asyncio.queues.__name__ identity, asyncio.Queue/Task/Future class module identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio.__all__.__contains__ membership for key public names, asyncio.exceptions/locks/tasks/queues submodule __name__ identity, asyncio.Queue/Task/Future class __module__ identity — behaviors not covered by extra1141 or extra1156"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra1171.all_membership_checks:
  description: "asyncio.__all__.__contains__ checks for key public names in the asyncio namespace"
  kind: python_call_eq
  category: module_membership
  id_prefix: as1171am
  columns: [id, function, args, expected]
  rows:
    - [as1171am001, asyncio.__all__.__contains__, ["Queue"],       true]
    - [as1171am002, asyncio.__all__.__contains__, ["Task"],        true]
    - [as1171am003, asyncio.__all__.__contains__, ["Future"],      true]
    - [as1171am004, asyncio.__all__.__contains__, ["Lock"],        true]
    - [as1171am005, asyncio.__all__.__contains__, ["Event"],       true]
    - [as1171am006, asyncio.__all__.__contains__, ["run"],         true]
    - [as1171am007, asyncio.__all__.__contains__, ["sleep"],       true]
    - [as1171am008, asyncio.__all__.__contains__, ["gather"],      true]
    - [as1171am009, asyncio.__all__.__contains__, ["Semaphore"],   true]
    - [as1171am010, asyncio.__all__.__contains__, ["Condition"],   true]
    - [as1171am011, asyncio.__all__.__contains__, ["wait"],        true]
    - [as1171am012, asyncio.__all__.__contains__, ["create_task"], true]

table asyncio_extra1171.submodule_name_identity:
  description: "asyncio.exceptions, asyncio.locks, asyncio.tasks, and asyncio.queues submodule __name__ identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: as1171sn
  columns: [id, function, args, expected]
  rows:
    - [as1171sn001, asyncio.exceptions.__name__.__eq__,             ["asyncio.exceptions"],  true]
    - [as1171sn002, asyncio.exceptions.__name__.__class__.__name__.__eq__, ["str"],          true]
    - [as1171sn003, asyncio.locks.__name__.__eq__,                  ["asyncio.locks"],       true]
    - [as1171sn004, asyncio.locks.__name__.__class__.__name__.__eq__, ["str"],               true]
    - [as1171sn005, asyncio.tasks.__name__.__eq__,                  ["asyncio.tasks"],       true]
    - [as1171sn006, asyncio.tasks.__name__.__class__.__name__.__eq__, ["str"],               true]
    - [as1171sn007, asyncio.queues.__name__.__eq__,                 ["asyncio.queues"],      true]
    - [as1171sn008, asyncio.queues.__name__.__class__.__name__.__eq__, ["str"],              true]

table asyncio_extra1171.queue_task_future_module_identity:
  description: "asyncio.Queue, asyncio.Task, and asyncio.Future class __module__ and __name__ identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: as1171qt
  columns: [id, function, args, expected]
  rows:
    - [as1171qt001, asyncio.Queue.__module__.__eq__,         ["asyncio.queues"],  true]
    - [as1171qt002, asyncio.Queue.__name__.__eq__,           ["Queue"],           true]
    - [as1171qt003, asyncio.Queue.__qualname__.__eq__,       ["Queue"],           true]
    - [as1171qt004, asyncio.Queue.__class__.__name__.__eq__, ["type"],            true]
    - [as1171qt005, asyncio.Task.__module__.__eq__,          ["asyncio.tasks"],   true]
    - [as1171qt006, asyncio.Task.__name__.__eq__,            ["Task"],            true]
    - [as1171qt007, asyncio.Task.__qualname__.__eq__,        ["Task"],            true]
    - [as1171qt008, asyncio.Task.__class__.__name__.__eq__,  ["type"],            true]
    - [as1171qt009, asyncio.Future.__module__.__eq__,        ["asyncio.futures"], true]
    - [as1171qt010, asyncio.Future.__name__.__eq__,          ["Future"],          true]
    - [as1171qt011, asyncio.Future.__qualname__.__eq__,      ["Future"],          true]
    - [as1171qt012, asyncio.Future.__class__.__name__.__eq__, ["type"],           true]
