spec: concurrent_futures_extra2371
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "All expected values verified interactively with Python 3.14.4 on macOS/Darwin 25.4.0."
    - "concurrent.futures.Future, ThreadPoolExecutor, ProcessPoolExecutor, Executor are classes — __class__.__name__ == 'type'."
    - "concurrent.futures.wait and as_completed are plain Python functions — __class__.__name__ == 'function'."
    - "concurrent.futures.FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED are string constants — __class__.__name__ == 'str'."
    - "concurrent.futures.CancelledError, TimeoutError, BrokenExecutor are exception/error classes — __class__.__name__ == 'type'."
    - "The pattern function: Name.__class__.__name__.__eq__ with args: ['expected'] and expected: true is the canonical ZSDL idiom for attribute equality checks."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level classes: __class__.__name__ == "type"
# ---------------------------------------------------------------------------

table concurrent_futures_extra2371.object_types:
  kind: python_call_eq
  category: object_types

  columns: [id, function, args, expected]
  rows:
    - ["cf2371001", "Future.__class__.__name__.__eq__",              ["type"], true]
    - ["cf2371002", "ThreadPoolExecutor.__class__.__name__.__eq__",  ["type"], true]
    - ["cf2371003", "ProcessPoolExecutor.__class__.__name__.__eq__", ["type"], true]
    - ["cf2371004", "Executor.__class__.__name__.__eq__",            ["type"], true]
    - ["cf2371005", "CancelledError.__class__.__name__.__eq__",      ["type"], true]
    - ["cf2371006", "TimeoutError.__class__.__name__.__eq__",        ["type"], true]
    - ["cf2371007", "BrokenExecutor.__class__.__name__.__eq__",      ["type"], true]

# ---------------------------------------------------------------------------
# Module-level plain functions: __class__.__name__ == "function"
