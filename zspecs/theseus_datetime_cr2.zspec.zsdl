spec: theseus_datetime_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_datetime_cr2)
blocks: datetime

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html"
  notes:
    - "Clean-room extended datetime utilities. Do NOT import datetime."
    - "timedelta: duration expressed in days, seconds, microseconds."
    - "timezone: fixed-offset timezone (UTC and others)."
    - "timezone.utc: UTC timezone constant."
    - "timedelta(days=0, seconds=0, microseconds=0): duration object."
    - "timedelta.total_seconds(): total duration in seconds as float."
    - "datetime2_timedelta_seconds(): timedelta(days=1).total_seconds() == 86400.0."
    - "datetime2_timedelta_add(): (timedelta(days=1) + timedelta(hours=12)).total_seconds() == 129600.0."
    - "datetime2_timezone_utc(): timezone.utc.utcoffset(None).total_seconds() == 0.0."
    - "timedelta stores days, seconds, microseconds; normalizes to 0 <= microseconds < 1e6, 0 <= seconds < 86400."
    - "total_seconds = days * 86400 + seconds + microseconds / 1e6."
    - "Export: timedelta, timezone."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_datetime_cr2.timedelta_seconds:
  description: "timedelta(days=1).total_seconds() == 86400.0"
  category: timedelta
  kind: python_call_eq
  function: datetime2_timedelta_seconds
  args: []
  expected: 86400.0

invariant theseus_datetime_cr2.timedelta_add:
  description: "(timedelta(days=1) + timedelta(hours=12)).total_seconds() == 129600.0"
  category: timedelta
  kind: python_call_eq
  function: datetime2_timedelta_add
  args: []
  expected: 129600.0

invariant theseus_datetime_cr2.timezone_utc:
  description: "timezone.utc.utcoffset(None).total_seconds() == 0.0"
  category: timezone
  kind: python_call_eq
  function: datetime2_timezone_utc
  args: []
  expected: 0.0
