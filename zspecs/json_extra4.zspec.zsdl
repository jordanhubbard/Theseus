spec: json_extra4
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/decoder.py"
  notes:
    - "This spec extends json.zspec.zsdl, json_extra.zspec.zsdl, json_extra2.zspec.zsdl, json_extra3.zspec.zsdl, json_decoder.zspec.zsdl, and json_encoder.zspec.zsdl."
    - "json_extra.zspec.zsdl covers: JSONDecodeError __name__/__module__/__bases__[0]; JSONEncodeError/JSONDecoder __name__/__module__; loads raises JSONDecodeError for invalid inputs."
    - "json_extra3.zspec.zsdl covers: JSONDecodeError/__name__, JSONEncoder/__name__, JSONDecoder/__name__ in a table; JSONDecodeError.__base__.__name__; JSONEncoder/__module__, JSONDecoder/__module__ in a table; tool.__name__."
    - "json_decoder.zspec.zsdl covers: JSONDecoder/__name__, JSONDecodeError/__name__ in a table; JSONDecodeError.__bases__[0].__name__ == 'ValueError'; JSONDecodeError.__module__."
    - "This spec adds: JSONDecodeError __name__ and __module__ as standalone named invariants (for unambiguous traceability); JSONDecodeError hierarchy via __mro__; JSONDecodeError instance attribute types (lineno/colno/pos are int); json.detect_encoding/__name__ (Python >= 3.9); json.tool module __name__ as a standalone invariant."
    - "json.JSONDecodeError.__name__ == 'JSONDecodeError' — confirmed on CPython 3.12."
    - "json.JSONDecodeError.__module__ == 'json.decoder' — defined in the decoder submodule."
    - "json.JSONDecodeError.__bases__[0].__name__ == 'ValueError' — direct ValueError subclass."
    - "JSONDecodeError instance attributes: lineno (int), colno (int), pos (int) — set when a parse error is raised."
    - "json.detect_encoding.__name__ == 'detect_encoding' — internal helper exposed since Python 3.9."
    - "json.tool.__name__ == 'json.tool' — the submodule's fully qualified module name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# JSONDecodeError — __name__ and __module__ as standalone invariants
#
# Multiple existing specs cover these in tables. This spec adds them as
# named standalone invariants for clear per-invariant traceability.
# ---------------------------------------------------------------------------

invariant json_extra4.JSONDecodeError.name:
  description: "json.JSONDecodeError.__name__ == 'JSONDecodeError'"
  category: class_names
  kind: python_call_eq
  function: JSONDecodeError.__name__.__eq__
  args: ["JSONDecodeError"]
  expected: true

invariant json_extra4.JSONDecodeError.module:
  description: "json.JSONDecodeError.__module__ == 'json.decoder'"
  category: class_modules
  kind: python_call_eq
  function: JSONDecodeError.__module__.__eq__
  args: ["json.decoder"]
  expected: true

# ---------------------------------------------------------------------------
# JSONDecodeError — class hierarchy
#
# JSONDecodeError is a direct subclass of ValueError. Verified via both
# __bases__[0] and __mro__[1] for orthogonal coverage.
# json_extra and json_decoder use __bases__.__getitem__(0) or __base__.__name__;
# this spec uses the attribute chain form for __bases__ and MRO form.
# ---------------------------------------------------------------------------

invariant json_extra4.JSONDecodeError.bases0_name:
  description: "json.JSONDecodeError.__bases__[0].__name__ == 'ValueError'"
  category: class_hierarchy
  kind: python_call_eq
  function: JSONDecodeError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ValueError"

invariant json_extra4.JSONDecodeError.mro_index1:
  description: "json.JSONDecodeError.__mro__[1].__name__ == 'ValueError'"
  category: class_hierarchy
  kind: python_call_eq
  function: JSONDecodeError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "ValueError"

# ---------------------------------------------------------------------------
# JSONDecodeError — instance attribute types (lineno, colno, pos)
#
# When json.loads() raises JSONDecodeError, the exception object carries three
# integer attributes:
#   .lineno — the line number (1-based) where the parse error occurred
#   .colno  — the column number (1-based) within that line
#   .pos    — the character position in the original string
#
# We provoke a parse error with a minimal invalid input and verify the types.
# Note: the exact values depend on the input; we only verify the type is int.
# ---------------------------------------------------------------------------

invariant json_extra4.JSONDecodeError.lineno_type:
  description: "JSONDecodeError raised by loads raises with .lineno of type int"
  category: exception_attributes
  kind: python_call_raises
  function: loads
  args: ["{"]
  expected_exception: json.JSONDecodeError
  exception_attr: lineno
  exception_attr_class: int

invariant json_extra4.JSONDecodeError.colno_type:
  description: "JSONDecodeError raised by loads raises with .colno of type int"
  category: exception_attributes
  kind: python_call_raises
  function: loads
  args: ["{"]
  expected_exception: json.JSONDecodeError
  exception_attr: colno
  exception_attr_class: int

invariant json_extra4.JSONDecodeError.pos_type:
  description: "JSONDecodeError raised by loads raises with .pos of type int"
  category: exception_attributes
  kind: python_call_raises
  function: loads
  args: ["{"]
  expected_exception: json.JSONDecodeError
  exception_attr: pos
  exception_attr_class: int

# ---------------------------------------------------------------------------
# JSONDecodeError — instance attribute values for a known parse error
#
# json.loads('') raises JSONDecodeError at pos=0, lineno=1, colno=1.
# This is a well-defined error: empty string is not valid JSON.
# ---------------------------------------------------------------------------

invariant json_extra4.JSONDecodeError.empty_string_lineno:
  description: "loads('') raises JSONDecodeError with lineno == 1"
  category: exception_attributes
  kind: python_call_raises
  function: loads
  args: [""]
  expected_exception: json.JSONDecodeError
  exception_attr: lineno
  exception_attr_value: 1

invariant json_extra4.JSONDecodeError.empty_string_pos:
  description: "loads('') raises JSONDecodeError with pos == 0"
  category: exception_attributes
  kind: python_call_raises
  function: loads
  args: [""]
  expected_exception: json.JSONDecodeError
  exception_attr: pos
  exception_attr_value: 0

# ---------------------------------------------------------------------------
# json.detect_encoding — __name__ (Python >= 3.9)
#
# json.detect_encoding is an internal helper that determines the text encoding
# of a bytes or bytearray JSON input. It has been accessible since Python 3.9.
# We only verify the function's __name__; we do not invoke it because the
# input type (bytes) must be handled carefully and is covered in json_decoder.
# ---------------------------------------------------------------------------

invariant json_extra4.detect_encoding.name:
  description: "json.detect_encoding.__name__ == 'detect_encoding' (Python >= 3.9)"
  category: function_names
  kind: python_call_eq
  function: detect_encoding.__name__.__eq__
  args: ["detect_encoding"]
  expected: true

invariant json_extra4.detect_encoding.is_callable:
  description: "callable(json.detect_encoding) == True — detect_encoding is a function"
  category: function_names
  kind: python_call_eq
  function: detect_encoding.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# json.tool — submodule __name__
#
# json.tool is a submodule providing a command-line JSON formatter. Its
# __name__ attribute equals the fully qualified module name 'json.tool'.
# json_extra3 covers this; this spec adds it as a standalone invariant.
# ---------------------------------------------------------------------------

invariant json_extra4.tool.module_name:
  description: "json.tool.__name__ == 'json.tool' — submodule's __name__ is its fully qualified name"
  category: submodules
  kind: python_call_eq
  function: tool.__name__.__eq__
  args: ["json.tool"]
  expected: true

# ---------------------------------------------------------------------------
# JSONDecodeError — class type identity
#
# Verify that JSONDecodeError is itself a class (type), not a function or
# other object.
# ---------------------------------------------------------------------------

invariant json_extra4.JSONDecodeError.is_type:
  description: "json.JSONDecodeError.__class__.__name__ == 'type' — it is a class object"
  category: class_names
  kind: python_call_eq
  function: JSONDecodeError.__class__.__name__.__eq__
  args: ["type"]
  expected: true
