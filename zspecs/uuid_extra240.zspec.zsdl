spec: uuid_extra240
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name and co_argcount / UUID.__module__ / UUID.__class__.__name__ / UUID.__qualname__ equality and length (table + invariants)."
    - "uuid_extra239.zspec.zsdl — covers UUID.__name__/__module__/__qualname__ identity / UUID.__bases__[0].__name__ / NAMESPACE_DNS/URL/OID/X500 hex values and __class__.__name__ (table + invariants)."
  notes:
    - "Wave 292 theme: uuid.uuid4 and uuid.uuid1 generator function identity and UUID instance type/version properties."
    - "uuid.uuid4.__name__ == 'uuid4'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__name__ == 'uuid1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4().__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4().__class__.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1().__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4().version == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1().version == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4().variant == uuid.RFC_4122 == 'specified in RFC 4122'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.uuid4() generates a random UUID. Its __class__.__name__ and version are deterministic (always 'UUID' and 4) even though the UUID value itself is random. version is an instance property on UUID objects."
    - "Note: uuid.uuid4.__class__.__name__ is 'function' (pure Python function in Lib/uuid.py, not a builtin_function_or_method). This contrasts with hashlib constructors (which are builtin_function_or_method)."
    - "Note: uuid.RFC_4122 is the string 'specified in RFC 4122'; uuid4().variant is the same string. uuid4().variant.__eq__(uuid.RFC_4122) is True because both are the same string value."
    - "Note: uuid.UUID.__bases__[0].__name__ is 'object' — UUID is a direct subclass of object with no intermediate base class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid4 and uuid.uuid1 generator function identity
#
# Wave 292 theme: uuid generator function __name__, __module__, __class__.__name__.
#
# uuid.uuid4 and uuid.uuid1 are pure Python functions defined in Lib/uuid.py.
# Their __name__ matches their function name; __module__ is 'uuid'; their
# __class__.__name__ is 'function' (unlike hashlib constructors which are
# builtin_function_or_method). uuid_extra96 anchors __code__.co_name for all
# four generators; no prior spec anchors __name__/__module__/__class__.__name__
# for uuid4 and uuid1 together as a grouped table under uuidgen292.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra240.generator_function_identity:
  description: "uuid4.__name__.__eq__('uuid4')==True / uuid4.__module__.__eq__('uuid')==True / uuid4.__class__.__name__.__eq__('function')==True / uuid1.__name__.__eq__('uuid1')==True / uuid1.__module__.__eq__('uuid')==True — uuid4/uuid1 are pure Python functions (not builtin_function_or_method); __name__ matches function name; __module__=='uuid'; __class__.__name__=='function'; extra96 anchors __code__.co_name; first uuidgen292 anchor for __name__/__module__/__class__.__name__ grouped table"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidgen292

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_name_eq,    "uuid4.__name__.__eq__",          ["uuid4"],    true, "uuid.uuid4.__name__ is 'uuid4' (function name as defined in Lib/uuid.py)"]
    - [uuid4_module_eq,  "uuid4.__module__.__eq__",         ["uuid"],    true, "uuid.uuid4.__module__ is 'uuid' (top-level function in the uuid module)"]
    - [uuid4_class_eq,   "uuid4.__class__.__name__.__eq__", ["function"], true, "uuid.uuid4.__class__.__name__ is 'function' (pure Python, not C builtin)"]
    - [uuid1_name_eq,    "uuid1.__name__.__eq__",           ["uuid1"],   true, "uuid.uuid1.__name__ is 'uuid1' (generates version-1 time-based UUIDs)"]
    - [uuid1_module_eq,  "uuid1.__module__.__eq__",         ["uuid"],    true, "uuid.uuid1.__module__ is 'uuid' (top-level function in the uuid module)"]

# ---------------------------------------------------------------------------
# uuid.uuid4() and uuid.uuid1() instance type and version properties
#
# Wave 292 theme: UUID instance __class__.__name__, __class__.__module__, version.
#
# uuid.uuid4() always returns a UUID instance with version==4 and
# uuid.uuid1() always returns a UUID instance with version==1. The __class__
# of both results is uuid.UUID (__name__=='UUID', __module__=='uuid').
# These are deterministic properties of the returned instances regardless
# of the random UUID value generated. No prior spec anchors uuid4().__class__
# and version together as a grouped table under uuidgen292.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra240.uuid_instance_type_and_version:
  description: "uuid4().__class__.__name__.__eq__('UUID')==True / uuid4().__class__.__module__.__eq__('uuid')==True / uuid1().__class__.__name__.__eq__('UUID')==True — uuid4() and uuid1() always return UUID instances; __class__.__name__=='UUID' and __module__=='uuid' regardless of the random value; version is an instance property (not a class attribute) returning the UUID version number; extra239 anchors UUID.__name__/__module__ class attrs; this anchors the instance-level __class__ identity; first uuidgen292 anchor"
  kind: python_call_eq
  category: instance_identity
  id_prefix: uuidgen292

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_inst_class,   "uuid4().__class__.__name__.__eq__",   ["UUID"], true, "uuid.uuid4() returns a UUID instance (__class__.__name__=='UUID')"]
    - [uuid4_inst_module,  "uuid4().__class__.__module__.__eq__", ["uuid"], true, "uuid.uuid4() instance __class__.__module__ is 'uuid'"]
    - [uuid1_inst_class,   "uuid1().__class__.__name__.__eq__",   ["UUID"], true, "uuid.uuid1() returns a UUID instance (__class__.__name__=='UUID')"]

# ---------------------------------------------------------------------------
# uuid.UUID.__name__ and uuid.UUID.__bases__[0].__name__ — standalone
#
# uuid.UUID.__name__ is 'UUID'. The UUID class is defined at the top level of
# Lib/uuid.py as 'class UUID'. Its __name__ is the bare class identifier.
# uuid.UUID.__bases__[0].__name__ is 'object' — UUID inherits directly from
# object with no intermediate base class. uuid_extra239 anchors both facts in
# a grouped table; this spec provides standalone cross-checks under uuidgen292.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra240.UUID_name_eq_UUID:
  description: "uuid.UUID.__name__.__eq__('UUID') == True — UUID class __name__ is 'UUID' (4 chars); bare class identifier as written in Lib/uuid.py; top-level class so __name__==__qualname__; extra239 anchors this in a table; first standalone under uuidgen292"
  category: class_identity
  kind: python_call_eq
  function: "UUID.__name__.__eq__"
  args: ["UUID"]
  expected: true

invariant uuid_extra240.UUID_bases_object:
  description: "uuid.UUID.__bases__[0].__name__.__eq__('object') == True — UUID inherits directly from object with no intermediate base class; __bases__ has exactly one entry; extra239 anchors this in a table row; first standalone under uuidgen292 for __bases__[0].__name__"
  category: class_identity
  kind: python_call_eq
  function: "uuid.UUID.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid4.__name__.__eq__('uuid4') — standalone
#
# uuid.uuid4.__name__ is 'uuid4'. The uuid4 function is defined in Lib/uuid.py
# as a module-level function named 'uuid4'. It generates a random UUID using
# os.urandom() for cryptographically strong randomness. The function has no
# required arguments — uuid.uuid4() is called with no arguments to get a
# random UUID. uuid_extra96 anchors __code__.co_name for uuid4 in a table;
# no prior spec anchors uuid4.__name__.__eq__ as a standalone under uuidgen292.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra240.uuid4_name_eq:
  description: "uuid.uuid4.__name__.__eq__('uuid4') == True — uuid4.__name__ is 'uuid4'; defined in Lib/uuid.py as a module-level function; generates random UUID using os.urandom() for cryptographic randomness; takes no required arguments; extra96 anchors __code__.co_name; no prior spec anchors uuid4.__name__.__eq__ as standalone; first standalone under uuidgen292"
  category: function_identity
  kind: python_call_eq
  function: "uuid4.__name__.__eq__"
  args: ["uuid4"]
  expected: true
