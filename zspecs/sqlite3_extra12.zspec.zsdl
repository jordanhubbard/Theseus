spec: sqlite3_extra12
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl and prior extras through sqlite3_extra11.zspec.zsdl."
    - "sqlite3_extra11 covers: sqlite_version class_name; apilevel value/class_name; threadsafety class_name/ge1; exception __name__ table (Error/DatabaseError/IntegrityError/OperationalError/NotSupportedError); sqlite_version_info class_name/len."
    - "sqlite3_extra10 covers: Connection/Cursor/Row __class__.__name__ == 'type'; connect __class__.__name__ == 'builtin_function_or_method'."
    - "sqlite3_extra9 covers: SQLITE_ABORT/SQLITE_CONSTRAINT/SQLITE_RANGE; complete_statement __name__/__module__; DatabaseError/Error MRO[1]; PARSE_DECLTYPES/PARSE_COLNAMES type; version/__len__."
    - "sqlite3_extra8 covers: SQLITE_BUSY/SQLITE_LOCKED/SQLITE_MISUSE/SQLITE_NOTADB; connect/__name__/__module__; Warning/__name__/__module__."
    - "sqlite3_extra7 covers: SQLITE_OK/SQLITE_ERROR/SQLITE_INTERNAL; Connection/Row/Cursor __module__; exception __bases__[0]/__name__ table."
    - "sqlite3_extra5 covers: __qualname__ for Connection/Cursor/Row/Error/Warning/IntegrityError/OperationalError/connect/complete_statement."
    - "Focus: new axes — exception __module__, paramstyle, version type checks, connect/__qualname__."
    - "sqlite3.paramstyle == 'qmark' — DB-API 2.0 mandatory constant; no prior spec checks paramstyle."
    - "sqlite3.version.__class__.__name__ == 'str' — Python sqlite3 wrapper version string type; distinct from sqlite_version (extra11)."
    - "sqlite3.Warning.__name__ == 'Warning' — extra8 checks Warning __name__/__module__ but via a table row; re-anchored as standalone in extra12 namespace."
    - "sqlite3.InterfaceError.__name__ == 'InterfaceError' — not covered in extra11 exception_names table."
    - "sqlite3.ProgrammingError.__name__ == 'ProgrammingError' — not covered in extra11 exception_names table."
    - "sqlite3.Error.__module__ == 'sqlite3' — exception module attribute; no prior spec checks __module__ for Error."
    - "sqlite3.DatabaseError.__module__ == 'sqlite3' — exception module; no prior spec checks __module__ for DatabaseError."
    - "sqlite3.connect.__qualname__ == 'connect' — top-level function qualname; extra5 checks qualname via table but under a different id_prefix."
    - "sqlite3.Row.__name__ == 'Row' — no prior spec checks Row.__name__ directly via __eq__ chain."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sqlite3.paramstyle — DB-API 2.0 mandatory constant
#
# DB-API 2.0 requires paramstyle to be one of: 'qmark', 'numeric', 'named',
# 'format', 'pyformat'. CPython sqlite3 uses 'qmark' (? placeholders).
# No prior sqlite3 spec checks paramstyle.
# ---------------------------------------------------------------------------

invariant sqlite3_extra12.paramstyle.value:
  description: "sqlite3.paramstyle == 'qmark' — DB-API 2.0 parameter style for SQLite"
  category: module_attrs
  kind: python_call_eq
  function: paramstyle.__eq__
  args: ["qmark"]
  expected: true

invariant sqlite3_extra12.paramstyle.class_name:
  description: "sqlite3.paramstyle.__class__.__name__ == 'str' — paramstyle is a string"
  category: module_attrs
  kind: python_call_eq
  function: paramstyle.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.version — Python wrapper version string type check
#
# sqlite3_extra9 checks version.__len__ (length of the version string).
# sqlite3_extra11 checks sqlite_version (the C library version) class_name.
# sqlite3.version (the Python wrapper version, e.g. '2.6.0') is a str; the
# type check for version (not sqlite_version) is new in extra12.
# ---------------------------------------------------------------------------

invariant sqlite3_extra12.version.class_name:
  description: "sqlite3.version.__class__.__name__ == 'str' — Python wrapper version is a string"
  category: module_attrs
  kind: python_call_eq
  function: version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class __name__ — exceptions not covered in extra11 table
#
# sqlite3_extra11 covers Error/DatabaseError/IntegrityError/OperationalError/NotSupportedError.
# Warning, InterfaceError, and ProgrammingError __name__ are not in any prior table.
# sqlite3_extra8 checks Warning.__name__ and Warning.__module__ in a table row;
# this spec re-anchors Warning as a standalone invariant and adds InterfaceError
# and ProgrammingError as new vectors.
# ---------------------------------------------------------------------------

invariant sqlite3_extra12.exception_names.Warning:
  description: "sqlite3.Warning.__name__ == 'Warning' — Warning exception class name"
  category: class_names
  kind: python_call_eq
  function: Warning.__name__.__eq__
  args: ["Warning"]
  expected: true

invariant sqlite3_extra12.exception_names.InterfaceError:
  description: "sqlite3.InterfaceError.__name__ == 'InterfaceError' — InterfaceError class name"
  category: class_names
  kind: python_call_eq
  function: InterfaceError.__name__.__eq__
  args: ["InterfaceError"]
  expected: true

invariant sqlite3_extra12.exception_names.ProgrammingError:
  description: "sqlite3.ProgrammingError.__name__ == 'ProgrammingError' — ProgrammingError class name"
  category: class_names
  kind: python_call_eq
  function: ProgrammingError.__name__.__eq__
  args: ["ProgrammingError"]
  expected: true

# ---------------------------------------------------------------------------
# Exception __module__ — no prior spec checks __module__ for exception classes
#
# sqlite3_extra7 checks Connection/Row/Cursor __module__ == 'sqlite3'.
# sqlite3_extra8 checks Warning.__module__ == 'sqlite3' in a table row.
# Error and DatabaseError __module__ as standalone invariants are new.
# ---------------------------------------------------------------------------

invariant sqlite3_extra12.exception_module.Error:
  description: "sqlite3.Error.__module__ == 'sqlite3' — Error exception lives in sqlite3"
  category: class_attrs
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["sqlite3"]
  expected: true

invariant sqlite3_extra12.exception_module.DatabaseError:
  description: "sqlite3.DatabaseError.__module__ == 'sqlite3' — DatabaseError lives in sqlite3"
  category: class_attrs
  kind: python_call_eq
  function: DatabaseError.__module__.__eq__
  args: ["sqlite3"]
  expected: true

# ---------------------------------------------------------------------------
# connect function attributes — __qualname__ and Row.__name__
#
# sqlite3_extra5 checks connect.__qualname__ via a table; re-anchored in extra12.
# sqlite3.Row.__name__ == 'Row' confirmed via __eq__ chain; no prior spec
# checks Row.__name__ directly (extra7 checks Row.__module__).
# ---------------------------------------------------------------------------

invariant sqlite3_extra12.connect.qualname:
  description: "sqlite3.connect.__qualname__ == 'connect' — top-level function qualname"
  category: function_identity
  kind: python_call_eq
  function: connect.__qualname__.__eq__
  args: ["connect"]
  expected: true

invariant sqlite3_extra12.Row.name:
  description: "sqlite3.Row.__name__ == 'Row' — Row class __name__ attribute"
  category: class_names
  kind: python_call_eq
  function: Row.__name__.__eq__
  args: ["Row"]
  expected: true
