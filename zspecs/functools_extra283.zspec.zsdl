spec: functools_extra283
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.cmp_to_key is a C-level builtin_function_or_method: __module__ == '_functools', not 'functools'."
    - "cmp_to_key.__name__ == 'cmp_to_key' (10 chars); __qualname__ == 'cmp_to_key'."
    - "cmp_to_key.__module__ == '_functools' (10 chars) — defined in the C extension module _functools."
    - "functools.total_ordering is a pure-Python decorator function: __module__ == 'functools', __class__.__name__ == 'function'."
    - "total_ordering.__name__ == 'total_ordering' (14 chars); __qualname__ == 'total_ordering' (top-level)."
    - "total_ordering.__doc__ is not None — the decorator ships with a docstring."
    - "functools._lru_cache_wrapper is a C-level type: __class__.__name__ == 'type', __module__ == 'functools'."
    - "_lru_cache_wrapper.__name__ == '_lru_cache_wrapper' (18 chars); __qualname__ == '_lru_cache_wrapper'."
    - "_lru_cache_wrapper.__bases__[0].__name__ == 'object' — its sole base class is object."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.cmp_to_key — C builtin identity
#
# cmp_to_key is a C-level builtin_function_or_method from the _functools
# extension module. __name__ == 'cmp_to_key' (10 chars);
# __module__ == '_functools' (not 'functools').
# __qualname__ == 'cmp_to_key'.
# ---------------------------------------------------------------------------

table functools_extra283.cmp_to_key_identity:
  description: "functools.cmp_to_key builtin identity — __name__, __module__, __qualname__, __class__.__name__; name and module lengths; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex283ck

  columns: [id, function, args, expected, description]
  rows:
    - [ck_name_eq,  cmp_to_key.__name__.__eq__,          ["cmp_to_key"],  true, "functools.cmp_to_key.__name__ == 'cmp_to_key'; verified with Python 3.14.3"]
    - [ck_name_len, cmp_to_key.__name__.__len__,          [],             10,   "functools.cmp_to_key.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [ck_mod_eq,   cmp_to_key.__module__.__eq__,         ["_functools"],  true, "functools.cmp_to_key.__module__ == '_functools' (C extension, not 'functools'); verified with Python 3.14.3"]
    - [ck_mod_len,  cmp_to_key.__module__.__len__,         [],             10,   "functools.cmp_to_key.__module__.__len__() == 10; verified with Python 3.14.3"]
    - [ck_qn_eq,    cmp_to_key.__qualname__.__eq__,       ["cmp_to_key"],  true, "functools.cmp_to_key.__qualname__ == 'cmp_to_key'; verified with Python 3.14.3"]
    - [ck_cls_eq,   cmp_to_key.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' (C builtin); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools.total_ordering — pure-Python decorator identity
#
# total_ordering is a pure-Python function.
# __name__ == 'total_ordering' (14 chars); __module__ == 'functools'.
# __qualname__ == 'total_ordering' (top-level function).
# __doc__ is not None.
# ---------------------------------------------------------------------------

table functools_extra283.total_ordering_identity:
  description: "functools.total_ordering decorator identity — __name__, __module__, __qualname__, __class__.__name__, doc presence; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex283to

  columns: [id, function, args, expected, description]
  rows:
    - [to_name_eq,  total_ordering.__name__.__eq__,           ["total_ordering"], true,  "functools.total_ordering.__name__ == 'total_ordering'; verified with Python 3.14.3"]
    - [to_name_len, total_ordering.__name__.__len__,           [],                14,    "functools.total_ordering.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [to_mod_eq,   total_ordering.__module__.__eq__,          ["functools"],      true,  "functools.total_ordering.__module__ == 'functools'; verified with Python 3.14.3"]
    - [to_qn_eq,    total_ordering.__qualname__.__eq__,        ["total_ordering"], true,  "functools.total_ordering.__qualname__ == 'total_ordering' (top-level function); verified with Python 3.14.3"]
    - [to_cls_eq,   total_ordering.__class__.__name__.__eq__,  ["function"],       true,  "functools.total_ordering.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [to_doc_none, total_ordering.__doc__.__eq__,             [null],             false, "functools.total_ordering.__doc__ is not None — decorator ships with a docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools._lru_cache_wrapper — C-level type identity
#
# _lru_cache_wrapper is the C-level type wrapping lru_cache-decorated functions.
# __name__ == '_lru_cache_wrapper' (18 chars); __module__ == 'functools'.
# __class__.__name__ == 'type'; __bases__[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

table functools_extra283.lru_cache_wrapper_identity:
  description: "functools._lru_cache_wrapper type identity — __name__, __module__, __qualname__, __class__.__name__, base class; name length; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex283lcw

  columns: [id, function, args, expected, description]
  rows:
    - [lcw_name_eq,  _lru_cache_wrapper.__name__.__eq__,              ["_lru_cache_wrapper"], true, "functools._lru_cache_wrapper.__name__ == '_lru_cache_wrapper'; verified with Python 3.14.3"]
    - [lcw_name_len, _lru_cache_wrapper.__name__.__len__,              [],                    18,   "functools._lru_cache_wrapper.__name__.__len__() == 18; verified with Python 3.14.3"]
    - [lcw_mod_eq,   _lru_cache_wrapper.__module__.__eq__,             ["functools"],          true, "functools._lru_cache_wrapper.__module__ == 'functools'; verified with Python 3.14.3"]
    - [lcw_qn_eq,    _lru_cache_wrapper.__qualname__.__eq__,           ["_lru_cache_wrapper"], true, "functools._lru_cache_wrapper.__qualname__ == '_lru_cache_wrapper'; verified with Python 3.14.3"]
    - [lcw_cls_eq,   _lru_cache_wrapper.__class__.__name__.__eq__,     ["type"],               true, "functools._lru_cache_wrapper.__class__.__name__ == 'type' (C-level class); verified with Python 3.14.3"]
    - [lcw_base_eq,  "_lru_cache_wrapper.__bases__[0].__name__.__eq__", ["object"],             true, "functools._lru_cache_wrapper.__bases__[0].__name__ == 'object'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra283
# ---------------------------------------------------------------------------

invariant functools_extra283.cmp_to_key_module_is_c_extension:
  description: "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is implemented in the C extension _functools, not the pure-Python functools module"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra283.cmp_to_key_is_builtin:
  description: "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is a C builtin, not a pure-Python function"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra283.cmp_to_key_name_length_is_10:
  description: "functools.cmp_to_key.__name__.__len__() == 10 — 'cmp_to_key' has 10 characters"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__name__.__len__
  args: []
  expected: 10

invariant functools_extra283.total_ordering_is_function:
  description: "functools.total_ordering.__class__.__name__ == 'function' — total_ordering is a pure-Python function, not a C builtin or class"
  category: identity
  kind: python_call_eq
  function: total_ordering.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra283.total_ordering_name_length_is_14:
  description: "functools.total_ordering.__name__.__len__() == 14 — 'total_ordering' has 14 characters"
  category: identity
  kind: python_call_eq
  function: total_ordering.__name__.__len__
  args: []
  expected: 14

invariant functools_extra283.total_ordering_has_docstring:
  description: "functools.total_ordering.__doc__.__eq__(None) == False — total_ordering ships with a non-None docstring"
  category: behavior
  kind: python_call_eq
  function: total_ordering.__doc__.__eq__
  args: [null]
  expected: false

invariant functools_extra283.lru_cache_wrapper_is_type:
  description: "functools._lru_cache_wrapper.__class__.__name__ == 'type' — _lru_cache_wrapper is a C-level type object"
  category: identity
  kind: python_call_eq
  function: _lru_cache_wrapper.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra283.lru_cache_wrapper_name_length_is_18:
  description: "functools._lru_cache_wrapper.__name__.__len__() == 18 — '_lru_cache_wrapper' has 18 characters"
  category: identity
  kind: python_call_eq
  function: _lru_cache_wrapper.__name__.__len__
  args: []
  expected: 18
