spec: theseus_collections_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_collections_cr3)
blocks: collections

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html"
  notes:
    - "Clean-room extended collections. Do NOT import collections."
    - "ChainMap(*maps): groups multiple dicts as a single unit; lookups check maps in order."
    - "UserDict(initialdata=None): wrapper around dict with full dict interface."
    - "UserList(initlist=None): wrapper around list with full list interface."
    - "UserString(seq=''): wrapper around str with full str interface."
    - "collections3_chainmap(): ChainMap({'a':1},{'b':2})['b'] == 2."
    - "collections3_chainmap_precedence(): ChainMap({'x':1},{'x':2})['x'] == 1 (first map wins)."
    - "collections3_userdict(): d=UserDict({'k':42}); d['k'] == 42."
    - "Export: ChainMap, UserDict, UserList, UserString."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_collections_cr3.chainmap:
  description: "ChainMap({'a':1},{'b':2})['b'] == 2"
  category: chainmap
  kind: python_call_eq
  function: collections3_chainmap
  args: []
  expected: 2

invariant theseus_collections_cr3.chainmap_precedence:
  description: "ChainMap({'x':1},{'x':2})['x'] == 1 (first map wins)"
  category: chainmap
  kind: python_call_eq
  function: collections3_chainmap_precedence
  args: []
  expected: 1

invariant theseus_collections_cr3.userdict:
  description: "UserDict({'k':42})['k'] == 42"
  category: userdict
  kind: python_call_eq
  function: collections3_userdict
  args: []
  expected: 42
