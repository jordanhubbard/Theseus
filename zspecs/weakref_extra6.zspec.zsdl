spec: weakref_extra6
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
  notes:
    - "This spec extends weakref.zspec.zsdl and prior extras through weakref_extra5.zspec.zsdl."
    - "Focus: __qualname__ and __module__ for ProxyType and CallableProxyType; __qualname__ for getweakrefcount and getweakrefs; WeakMethod module."
    - "weakref.ProxyType.__qualname__ == 'ProxyType' — C-level type for non-callable proxies."
    - "weakref.ProxyType.__module__ == 'weakref' — ProxyType is re-exported from the weakref module."
    - "weakref.CallableProxyType.__name__ == 'CallableProxyType' — C-level type for callable proxies."
    - "weakref.CallableProxyType.__qualname__ == 'CallableProxyType'."
    - "weakref.CallableProxyType.__module__ == 'weakref' — re-exported at the weakref module level."
    - "weakref.WeakMethod.__qualname__ == 'WeakMethod' — pure-Python class in Lib/weakref.py."
    - "weakref.WeakMethod.__module__ == 'weakref' — defined in Lib/weakref.py."
    - "weakref.getweakrefcount.__qualname__ == 'getweakrefcount' — C-level function, qualname == name."
    - "weakref.getweakrefs.__qualname__ == 'getweakrefs' — C-level function, qualname == name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ProxyType — __qualname__ and __module__
#
# weakref.ProxyType is the C-level type for non-callable proxy objects.
# weakref.zspec.zsdl covers ProxyType.__name__ == 'ProxyType'.
# weakref_extra5 covers ref.__qualname__ and proxy.__qualname__.
# This spec adds the __qualname__ and __module__ checks for ProxyType.
# ---------------------------------------------------------------------------

invariant weakref_extra6.ProxyType.qualname:
  description: "weakref.ProxyType.__qualname__ == 'ProxyType'"
  category: qualnames
  kind: python_call_eq
  function: ProxyType.__qualname__.__eq__
  args: ["ProxyType"]
  expected: true

invariant weakref_extra6.ProxyType.module:
  description: "weakref.ProxyType.__module__ == 'weakref'"
  category: module
  kind: python_call_eq
  function: ProxyType.__module__.__eq__
  args: ["weakref"]
  expected: true

# ---------------------------------------------------------------------------
# CallableProxyType — __name__, __qualname__, __module__
#
# weakref.CallableProxyType is the C-level type for callable proxy objects.
# weakref.zspec.zsdl covers CallableProxyType.__name__ == 'CallableProxyType'.
# No prior spec covers __qualname__ or __module__ for CallableProxyType.
# ---------------------------------------------------------------------------

invariant weakref_extra6.CallableProxyType.name:
  description: "weakref.CallableProxyType.__name__ == 'CallableProxyType'"
  category: class_names
  kind: python_call_eq
  function: CallableProxyType.__name__.__eq__
  args: ["CallableProxyType"]
  expected: true

invariant weakref_extra6.CallableProxyType.qualname:
  description: "weakref.CallableProxyType.__qualname__ == 'CallableProxyType'"
  category: qualnames
  kind: python_call_eq
  function: CallableProxyType.__qualname__.__eq__
  args: ["CallableProxyType"]
  expected: true

invariant weakref_extra6.CallableProxyType.module:
  description: "weakref.CallableProxyType.__module__ == 'weakref'"
  category: module
  kind: python_call_eq
  function: CallableProxyType.__module__.__eq__
  args: ["weakref"]
  expected: true

# ---------------------------------------------------------------------------
# WeakMethod — __qualname__ and __module__
#
# weakref_extra2 covers WeakMethod.__name__ == 'WeakMethod'.
# No prior spec covers __qualname__ or __module__ for WeakMethod as individual
# invariants (only weakref_extra2 mentions __module__ in notes, not as invariants).
# ---------------------------------------------------------------------------

invariant weakref_extra6.WeakMethod.qualname:
  description: "weakref.WeakMethod.__qualname__ == 'WeakMethod'"
  category: qualnames
  kind: python_call_eq
  function: WeakMethod.__qualname__.__eq__
  args: ["WeakMethod"]
  expected: true

invariant weakref_extra6.WeakMethod.module:
  description: "weakref.WeakMethod.__module__ == 'weakref'"
  category: module
  kind: python_call_eq
  function: WeakMethod.__module__.__eq__
  args: ["weakref"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__ checks — getweakrefcount, getweakrefs
#
# weakref.zspec.zsdl and weakref_extra cover __name__ for getweakrefcount and
# getweakrefs; weakref_extra2 covers __module__. No prior spec checks
# __qualname__ for these C-level functions (qualname == name for C builtins).
# ---------------------------------------------------------------------------

table weakref_extra6.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [getweakrefcount, getweakrefcount.__qualname__.__eq__, ["getweakrefcount"], true]
    - [getweakrefs,     getweakrefs.__qualname__.__eq__,     ["getweakrefs"],     true]
