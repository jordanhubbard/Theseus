spec: socket_extra14
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "This spec extends socket.zspec.zsdl and prior extras through socket_extra13.zspec.zsdl."
    - "socket_extra13 covers: timeout.__mro__[0/1/2].__name__; has_ipv6 value and class name; SO_REUSEADDR value (4 on macOS) and class name."
    - "socket_extra12 covers: SocketType/__name__/__module__; herror/__mro__[0/1/2/3]; gaierror/__mro__[0/2]; AddressFamily/__qualname__; SocketKind/__qualname__; AF_INET6/__class__.__name__; SOCK_RAW/__class__.__name__."
    - "socket_extra11 covers: socket.socket __name__/__module__/__bases__[0].__name__; SOCK_SEQPACKET.value/name; AF_APPLETALK.value/name; setdefaulttimeout/__module__; getdefaulttimeout/__module__; create_server/__module__; create_connection/__module__; timeout.__bases__[0].__name__; gaierror.__bases__[0].__name__."
    - "socket.zspec.zsdl covers: AF_INET == 2; SOCK_STREAM == 1; SOCK_DGRAM == 2; SOCK_RAW == 3; IPPROTO_IP/TCP/UDP; SOL_SOCKET == 65535; SHUT_RD/WR/RDWR; socket/herror/gaierror class names; inet_aton; htonl; getdefaulttimeout."
    - "No prior spec covers: IPPROTO_TCP == 6 (the integer constant value, not just the name)."
    - "No prior spec covers: IPPROTO_UDP == 17 (the integer constant value)."
    - "No prior spec covers: IPPROTO_IP == 0 (the integer constant value)."
    - "No prior spec covers: IPPROTO_TCP.__class__.__name__ == 'int' — protocol constants are plain ints on macOS."
    - "No prior spec covers: IPPROTO_UDP.__class__.__name__ == 'int'."
    - "No prior spec covers: SO_KEEPALIVE == 8 on macOS/Darwin — socket keepalive option."
    - "No prior spec covers: SO_KEEPALIVE.__class__.__name__ == 'int'."
    - "No prior spec covers: SO_BROADCAST == 32 on macOS/Darwin — socket broadcast option."
    - "No prior spec covers: socket.AF_INET6 == 30 is already in base spec; but AF_INET.__class__.__name__ is already in socket_extra2; SOCK_STREAM.__class__.__name__ is in socket_extra2."
    - "IPPROTO_TCP == 6 is universal (IANA assigned); IPPROTO_UDP == 17 is universal."
    - "IPPROTO_IP == 0 is the IP protocol number (used as a socket option level for IP-level options)."
    - "SO_KEEPALIVE == 8 on macOS/Darwin; Linux uses 9."
    - "SO_BROADCAST == 32 on macOS/Darwin; Linux uses 6."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IPPROTO_* constant values — universal IANA-assigned protocol numbers
#
# socket.zspec.zsdl covers IPPROTO_IP/TCP/UDP __name__; no prior spec checks
# the actual integer values. IPPROTO_TCP == 6 and IPPROTO_UDP == 17 are
# universal across all POSIX platforms. IPPROTO_IP == 0 is also universal.
# ---------------------------------------------------------------------------

invariant socket_extra14.IPPROTO_TCP.value:
  description: "socket.IPPROTO_TCP == 6 — TCP protocol number (IANA assigned)"
  category: constants
  kind: python_call_eq
  function: IPPROTO_TCP.__eq__
  args: [6]
  expected: true

invariant socket_extra14.IPPROTO_UDP.value:
  description: "socket.IPPROTO_UDP == 17 — UDP protocol number (IANA assigned)"
  category: constants
  kind: python_call_eq
  function: IPPROTO_UDP.__eq__
  args: [17]
  expected: true

invariant socket_extra14.IPPROTO_IP.value:
  description: "socket.IPPROTO_IP == 0 — IP protocol number (used as socket option level)"
  category: constants
  kind: python_call_eq
  function: IPPROTO_IP.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# IPPROTO_* class names — protocol constants are plain ints on macOS/Darwin
#
# socket_extra4 checks SOL_SOCKET and SHUT_* __class__.__name__ == 'int'.
# socket_extra13 checks SO_REUSEADDR.__class__.__name__ == 'int'.
# No prior spec checks IPPROTO_TCP or IPPROTO_UDP class names.
# ---------------------------------------------------------------------------

invariant socket_extra14.IPPROTO_TCP.class_name:
  description: "socket.IPPROTO_TCP.__class__.__name__ == 'int' — TCP protocol constant is a plain int"
  category: constants
  kind: python_call_eq
  function: IPPROTO_TCP.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra14.IPPROTO_UDP.class_name:
  description: "socket.IPPROTO_UDP.__class__.__name__ == 'int' — UDP protocol constant is a plain int"
  category: constants
  kind: python_call_eq
  function: IPPROTO_UDP.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# SO_KEEPALIVE and SO_BROADCAST — additional socket-level option constants
#
# socket_extra13 covers SO_REUSEADDR == 4 (macOS) and its class name.
# No prior spec covers SO_KEEPALIVE or SO_BROADCAST values.
# SO_KEEPALIVE == 8 on macOS/Darwin; SO_BROADCAST == 32 on macOS/Darwin.
# Both are plain int constants (not enum members) on all platforms.
# ---------------------------------------------------------------------------

invariant socket_extra14.SO_KEEPALIVE.value:
  description: "socket.SO_KEEPALIVE == 8 on macOS/Darwin — socket keepalive option"
  category: constants
  kind: python_call_eq
  function: SO_KEEPALIVE.__eq__
  args: [8]
  expected: true

invariant socket_extra14.SO_KEEPALIVE.class_name:
  description: "socket.SO_KEEPALIVE.__class__.__name__ == 'int' — SO_KEEPALIVE is a plain int constant"
  category: constants
  kind: python_call_eq
  function: SO_KEEPALIVE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra14.SO_BROADCAST.value:
  description: "socket.SO_BROADCAST == 32 on macOS/Darwin — socket broadcast option"
  category: constants
  kind: python_call_eq
  function: SO_BROADCAST.__eq__
  args: [32]
  expected: true

invariant socket_extra14.SO_BROADCAST.class_name:
  description: "socket.SO_BROADCAST.__class__.__name__ == 'int' — SO_BROADCAST is a plain int constant"
  category: constants
  kind: python_call_eq
  function: SO_BROADCAST.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# gaierror MRO index 0 — self-check at index 0
#
# socket_extra12 checks gaierror.__mro__[0].__name__ == 'gaierror' (see notes in
# that spec). However, the notes say gaierror.__mro__[0/2] are covered; let us
# verify what is NOT covered by checking gaierror.__mro__[1].__name__ == 'OSError'.
# socket_extra12 covers mro[0] and mro[2]; no prior spec covers mro[1] for gaierror.
# gaierror.__mro__: [gaierror, OSError, Exception, BaseException, object]
# Index 1 is OSError; index 2 is Exception (confirmed covered in socket_extra12).
# ---------------------------------------------------------------------------

invariant socket_extra14.gaierror.mro_index1:
  description: "socket.gaierror.__mro__[1].__name__ == 'OSError' — gaierror MRO index 1"
  category: class_hierarchy
  kind: python_call_eq
  function: gaierror.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "OSError"

invariant socket_extra14.gaierror.mro_index3:
  description: "socket.gaierror.__mro__[3].__name__ == 'BaseException' — gaierror MRO index 3"
  category: class_hierarchy
  kind: python_call_eq
  function: gaierror.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "BaseException"
