spec: xml_extra4
version: ">=3.9"
backend: python_module(xml.etree.ElementTree)

docs: https://docs.python.org/3/library/xml.etree.elementtree.html

provenance:
  derived_from:
    - "Python xml.etree.ElementTree documentation — https://docs.python.org/3/library/xml.etree.elementtree.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xml/etree/ElementTree.py"
    - "xml_extra.zspec.zsdl — covers Element/ElementTree/SubElement/ParseError __name__, parse/fromstring/tostring __name__, ParseError base"
    - "xml_extra2.zspec.zsdl — covers fromstring tag/attrib, Element tag/attrib, tostring result class, ParseError name/base, VERSION/XML_VERSION class names, SubElement __name__"
    - "xml_extra3.zspec.zsdl — covers Element/__qualname__/ElementTree/__qualname__/XMLParser/__qualname__/ParseError/__qualname__, function __qualname__ (tostring/indent/iterparse/parse), Element/__module__/XMLParser/__module__, bases, function type checks, ParseError/Element is_type"
    - "xml_etree_extra.zspec.zsdl — covers Element/SubElement __name__, function names, Comment/ProcessingInstruction __name__, ParseError name/base, fromstring result class, Element.__module__ is str"
    - "xml_etree_extra2.zspec.zsdl — covers SubElement/__qualname__, fromstring/__qualname__, function __module__ (SubElement/fromstring/tostring/parse/indent/iterparse), ParseError.__module__"
    - "xml_parse.zspec.zsdl — covers ElementTree/XMLParser/ParseError __module__ exact values, ParseError base/issubclass, XMLParser feed/close, ElementTree base/name, ParseError args length"
  notes:
    - "This spec extends all prior xml.etree.ElementTree specs with new axes."
    - "Comment.__qualname__ == 'Comment' — top-level factory function (Python 3.14 uses a plain function, not a C builtin)."
    - "ProcessingInstruction.__qualname__ == 'ProcessingInstruction' — same."
    - "register_namespace.__qualname__ == 'register_namespace' — top-level function."
    - "Comment.__module__ == 'xml.etree.ElementTree' — not in any prior spec."
    - "ProcessingInstruction.__module__ == 'xml.etree.ElementTree' — not in any prior spec."
    - "register_namespace.__module__ == 'xml.etree.ElementTree' — not in any prior spec."
    - "Comment.__class__.__name__ == 'function' — on Python 3.14 it is a plain function."
    - "ProcessingInstruction.__class__.__name__ == 'function'."
    - "register_namespace.__class__.__name__ == 'function'."
    - "Element('root').text is None — text attribute defaults to None on a fresh Element."
    - "Element('root').tail is None — tail attribute defaults to None on a fresh Element."
    - "fromstring('<msg>hello</msg>').text == 'hello' — text content is captured."
    - "tostring(Element('item'), encoding='unicode') == '<item />' — unicode encoding returns str."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Comment, ProcessingInstruction, register_namespace — __qualname__
# (xml_etree_extra.zspec.zsdl covers __name__ for Comment/ProcessingInstruction;
#  __qualname__ is not in any prior spec)
# ---------------------------------------------------------------------------

table xml_extra4.factory_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [Comment,                Comment.__qualname__.__eq__,                ["Comment"],                true]
    - [ProcessingInstruction,  ProcessingInstruction.__qualname__.__eq__,  ["ProcessingInstruction"],  true]
    - [register_namespace,     register_namespace.__qualname__.__eq__,     ["register_namespace"],     true]

# ---------------------------------------------------------------------------
# Comment, ProcessingInstruction, register_namespace — __module__
# (xml_etree_extra2 covers SubElement/fromstring/tostring/parse/indent/iterparse;
#  Comment/ProcessingInstruction/register_namespace are not covered)
# ---------------------------------------------------------------------------

table xml_extra4.factory_modules:
  kind: python_call_eq
  category: modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [Comment,               Comment.__module__.__eq__,               ["xml.etree.ElementTree"], true]
    - [ProcessingInstruction, ProcessingInstruction.__module__.__eq__,  ["xml.etree.ElementTree"], true]
    - [register_namespace,    register_namespace.__module__.__eq__,     ["xml.etree.ElementTree"], true]

# ---------------------------------------------------------------------------
# Comment, ProcessingInstruction, register_namespace — __class__.__name__
# (not in any prior spec; verifies that these are plain Python functions)
# ---------------------------------------------------------------------------

table xml_extra4.factory_class_names:
  kind: python_call_eq
  category: types
  id_prefix: fclass

  columns: [id, function, args, expected]
  rows:
    - [Comment,               Comment.__class__.__name__.__eq__,               ["function"], true]
    - [ProcessingInstruction, ProcessingInstruction.__class__.__name__.__eq__,  ["function"], true]
    - [register_namespace,    register_namespace.__class__.__name__.__eq__,     ["function"], true]

# ---------------------------------------------------------------------------
# Element.text and Element.tail — default to None on a fresh Element
# (prior specs check tag and attrib; text and tail are new axes)
# ---------------------------------------------------------------------------

invariant xml_extra4.Element.text_is_none:
  description: "Element('root').text is None — text attribute defaults to None"
  category: Element
  kind: python_call_eq
  function: Element
  args: ["root"]
  method: text
  method_args: []
  expected: null

invariant xml_extra4.Element.tail_is_none:
  description: "Element('root').tail is None — tail attribute defaults to None"
  category: Element
  kind: python_call_eq
  function: Element
  args: ["root"]
  method: tail
  method_args: []
  expected: null

# ---------------------------------------------------------------------------
# fromstring — text content of a text-bearing element
# (prior specs check tag and attrib; text content is a new axis)
# ---------------------------------------------------------------------------

invariant xml_extra4.fromstring.text_content:
  description: "fromstring('<msg>hello</msg>').text == 'hello'"
  category: fromstring
  kind: python_call_eq
  function: fromstring
  args: ["<msg>hello</msg>"]
  method: text
  expected: "hello"

# ---------------------------------------------------------------------------
# tostring — encoding='unicode' returns a str
# (xml_extra2 checks tostring returns bytes by default; unicode encoding is new)
# ---------------------------------------------------------------------------

invariant xml_extra4.tostring.unicode_encoding:
  description: "tostring(Element('item'), encoding='unicode') == '<item />'"
  category: tostring
  kind: python_call_eq
  function: tostring
  args: [{type: python_call, function: Element, args: ["item"]}, "unicode"]
  expected: "<item />"
