spec: decimal_extra1711
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "IBM General Decimal Arithmetic Specification 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal.zspec.zsdl — covers Decimal str_repr, predicates, as_tuple, class_name, context prec, InvalidOperation"
    - "decimal_extra.zspec.zsdl — covers Decimal predicates, to_eng_string, Context/BasicContext/ExtendedContext names, DefaultContext, rounding modes"
  notes:
    - "Wave 561 (_extra1711): __init__ protocol — which decimal types define __init__ in their own __dict__."
    - "decimal.Decimal is a C extension type that uses __new__ for construction (it is effectively immutable once created). It does NOT define __init__ in its own __dict__."
    - "decimal.Context is a C extension type that DOES define __init__ in its own __dict__. Context.__init__ accepts all context parameters: prec, rounding, Emin, Emax, capitals, clamp, flags, traps."
    - "decimal.DecimalException is a pure-Python exception base class. It does NOT define __init__ in its own __dict__ — it inherits from ArithmeticError and uses the default exception __init__."
    - "decimal.InvalidOperation, Overflow, Underflow, Inexact, Rounded, Subnormal, DivisionByZero, FloatOperation do NOT define __init__ in their own __dict__ — they inherit from DecimalException."
    - "Key insight: Decimal is immutable (like int/float) and uses __new__; Context is mutable and configurable so it uses __init__. This is the clearest __new__ vs __init__ contrast in the decimal module."
    - "decimal.BasicContext and decimal.ExtendedContext are classes (not instances); they do NOT define __init__ in their own __dict__ — they inherit Context construction."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal — C type, uses __new__, NO __init__ in own __dict__
# Decimal is immutable once created; its C implementation uses tp_new (exposed
# as __new__) and has no tp_init slot, so __init__ is absent from its __dict__.
# ---------------------------------------------------------------------------

table decimal_extra1711.Decimal_no_init:
  description: "decimal.Decimal does NOT define __init__ in its own __dict__ — it is an immutable C extension type constructed via __new__; __init__ is absent; wave 561"
  kind: python_call_eq
  category: init_protocol
  id_prefix: dc1711
  columns: [id, function, args, expected]
  rows:
    - ["dc1711001", decimal.Decimal.__dict__.__contains__, ["__init__"], false]
    - ["dc1711002", decimal.Decimal.__dict__.__contains__, ["__new__"],  true]

# ---------------------------------------------------------------------------
# decimal.Context — C type with __init__ in own __dict__
# Context is mutable; its C implementation registers tp_init which is exposed
# as __init__ in the Python class dict.  Context.__init__ accepts the full
# set of precision/rounding/flag parameters.
# ---------------------------------------------------------------------------

table decimal_extra1711.Context_has_init:
  description: "decimal.Context DOES define __init__ in its own __dict__ — Context is mutable and configurable, so its C implementation exposes tp_init as __init__; contrast with the immutable Decimal which uses __new__ only; wave 561"
  kind: python_call_eq
  category: init_protocol
  id_prefix: dc1711
  columns: [id, function, args, expected]
  rows:
    - ["dc1711003", decimal.Context.__dict__.__contains__, ["__init__"], true]
    - ["dc1711004", decimal.Context.__dict__.__contains__, ["__new__"],  false]

# ---------------------------------------------------------------------------
# Exception hierarchy — DecimalException and subclasses do NOT define __init__
# DecimalException inherits from ArithmeticError. None of the decimal exception
# classes define __init__ in their own __dict__.
# ---------------------------------------------------------------------------

table decimal_extra1711.exceptions_no_init:
  description: "decimal exception classes (DecimalException, InvalidOperation, Overflow, DivisionByZero) do NOT define __init__ in their own __dict__ — they inherit default exception construction from ArithmeticError / DecimalException; wave 561"
  kind: python_call_eq
  category: init_protocol
  id_prefix: dc1711
  columns: [id, function, args, expected]
  rows:
    - ["dc1711005", decimal.DecimalException.__dict__.__contains__,  ["__init__"], false]
    - ["dc1711006", decimal.InvalidOperation.__dict__.__contains__,  ["__init__"], false]
    - ["dc1711007", decimal.Overflow.__dict__.__contains__,          ["__init__"], false]
    - ["dc1711008", decimal.DivisionByZero.__dict__.__contains__,    ["__init__"], false]
    - ["dc1711009", decimal.Inexact.__dict__.__contains__,           ["__init__"], false]
    - ["dc1711010", decimal.Rounded.__dict__.__contains__,           ["__init__"], false]

# ---------------------------------------------------------------------------
# BasicContext and ExtendedContext — no __init__ in own __dict__
# Both are subclasses of Context but define no __init__ themselves.
# ---------------------------------------------------------------------------

table decimal_extra1711.context_subclasses_no_init:
  description: "decimal.BasicContext and decimal.ExtendedContext do NOT define __init__ in their own __dict__ — they are thin subclasses of Context that inherit Context.__init__; wave 561"
  kind: python_call_eq
  category: init_protocol
  id_prefix: dc1711
  columns: [id, function, args, expected]
  rows:
    - ["dc1711011", decimal.BasicContext.__dict__.__contains__,    ["__init__"], false]
    - ["dc1711012", decimal.ExtendedContext.__dict__.__contains__,  ["__init__"], false]

# ---------------------------------------------------------------------------
# Positive anchors — members that ARE in each class's own __dict__
# Confirms __dict__.__contains__ is functioning correctly.
# ---------------------------------------------------------------------------

table decimal_extra1711.positive_anchors:
  description: "Positive anchor checks: known members of each decimal class own __dict__ — confirms __dict__.__contains__ queries operate correctly; wave 561"
  kind: python_call_eq
  category: init_protocol
  id_prefix: dc1711
  columns: [id, function, args, expected]
  rows:
    - ["dc1711013", decimal.Decimal.__dict__.__contains__, ["is_finite"],   true]
    - ["dc1711014", decimal.Decimal.__dict__.__contains__, ["is_nan"],      true]
    - ["dc1711015", decimal.Decimal.__dict__.__contains__, ["is_infinite"],  true]
    - ["dc1711016", decimal.Decimal.__dict__.__contains__, ["as_tuple"],    true]
    - ["dc1711017", decimal.Context.__dict__.__contains__, ["prec"],        true]
    - ["dc1711018", decimal.Context.__dict__.__contains__, ["create_decimal"], true]

# ---------------------------------------------------------------------------
# Class-name spot-checks
# ---------------------------------------------------------------------------

table decimal_extra1711.class_names:
  description: "Class __name__ identity spot-checks for the decimal types examined in the __init__ protocol tables; wave 561"
  kind: python_call_eq
  category: class_metadata
  id_prefix: dc1711
  columns: [id, function, args, expected]
  rows:
    - ["dc1711019", decimal.Decimal.__name__.__eq__,         ["Decimal"],          true]
    - ["dc1711020", decimal.Context.__name__.__eq__,         ["Context"],          true]
    - ["dc1711021", decimal.DecimalException.__name__.__eq__, ["DecimalException"], true]
    - ["dc1711022", decimal.InvalidOperation.__name__.__eq__, ["InvalidOperation"], true]
    - ["dc1711023", decimal.BasicContext.__name__.__eq__,    ["BasicContext"],     true]
    - ["dc1711024", decimal.ExtendedContext.__name__.__eq__,  ["ExtendedContext"],  true]
