spec: functools_extra1786
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module reference"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES, callable type checks"
    - "functools_extra.zspec.zsdl — covers __name__, __module__, partial instance class name"
  notes:
    - "Wave 566 theme: __class_getitem__ and __init_subclass__ class creation hooks (PEP 487/585)."
    - "functools.partial.__dict__.__contains__('__class_getitem__') == True — partial is a C extension type; PEP 585 generic support added in Python 3.9 means partial explicitly defines __class_getitem__ in its own __dict__. Confirmed in wave 563."
    - "functools.cached_property.__dict__.__contains__('__class_getitem__') == False — cached_property is a pure Python class; it is not a parameterizable generic container type and does not define __class_getitem__ in its own __dict__."
    - "functools.partialmethod.__dict__.__contains__('__class_getitem__') == False — partialmethod is a pure Python class; not a generic type; no __class_getitem__ in its own __dict__."
    - "functools.partial.__dict__.__contains__('__init_subclass__') == False — C extension types expose __init_subclass__ via inheritance from object, not in their own __dict__."
    - "functools.cached_property.__dict__.__contains__('__init_subclass__') == False — pure Python class; inherits __init_subclass__ from object; not in own __dict__."
    - "Complementary table covers __dict__ membership for __repr__, __reduce__, __hash__ and related dunder names in functools types."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __class_getitem__ and __init_subclass__ presence in functools types
#
# PEP 585 (Python 3.9+) added __class_getitem__ to C extension types that
# support generic alias syntax (e.g. functools.partial[int]).
# functools.partial explicitly defines __class_getitem__ in its own __dict__.
# Pure Python classes (cached_property, partialmethod) do not.
# No functools type defines __init_subclass__ in its own __dict__.
# ---------------------------------------------------------------------------

table functools_extra1786.class_creation_hooks:
  description: "Which functools types define __class_getitem__ or __init_subclass__ in their own __dict__ (PEP 487/585)"
  kind: python_call_eq
  category: class_creation_hooks
  id_prefix: fu1786

  columns: [id, function, args, expected]
  rows:
    - ["fu1786001", functools.partial.__dict__.__contains__,           ["__class_getitem__"],  true]
    - ["fu1786002", functools.cached_property.__dict__.__contains__,   ["__class_getitem__"],  false]
    - ["fu1786003", functools.partialmethod.__dict__.__contains__,     ["__class_getitem__"],  false]
    - ["fu1786004", functools.partial.__dict__.__contains__,           ["__init_subclass__"],  false]
    - ["fu1786005", functools.cached_property.__dict__.__contains__,   ["__init_subclass__"],  false]
    - ["fu1786006", functools.partialmethod.__dict__.__contains__,     ["__init_subclass__"],  false]
    - ["fu1786007", functools.partial.__dict__.__contains__,           ["__subclasshook__"],   false]
    - ["fu1786008", functools.cached_property.__dict__.__contains__,   ["__subclasshook__"],   false]
    - ["fu1786009", functools.partial.__dict__.__contains__,           ["__init__"],           true]
    - ["fu1786010", functools.cached_property.__dict__.__contains__,   ["__init__"],           true]
    - ["fu1786011", functools.partialmethod.__dict__.__contains__,     ["__init__"],           true]

# ---------------------------------------------------------------------------
# Table 2: complementary __dict__ membership checks for functools types
#
# Verifies other dunder names in the own __dict__ of functools types.
# partial (C type) owns __new__, __call__, __repr__, __reduce__,
# __setstate__, __doc__, __class_getitem__.
# cached_property (Python class) owns __init__, __set_name__, __get__,
# __set__, __doc__, but NOT __class_getitem__ or __init_subclass__.
# ---------------------------------------------------------------------------

table functools_extra1786.dict_membership_complement:
  description: "Complementary __dict__ membership checks for functools.partial and functools.cached_property"
  kind: python_call_eq
  category: dict_membership
  id_prefix: fu1786

  columns: [id, function, args, expected]
  rows:
    - ["fu1786012", functools.partial.__dict__.__contains__,           ["__new__"],            true]
    - ["fu1786013", functools.partial.__dict__.__contains__,           ["__call__"],           true]
    - ["fu1786014", functools.partial.__dict__.__contains__,           ["__repr__"],           true]
    - ["fu1786015", functools.partial.__dict__.__contains__,           ["__reduce__"],         true]
    - ["fu1786016", functools.partial.__dict__.__contains__,           ["__setstate__"],       true]
    - ["fu1786017", functools.cached_property.__dict__.__contains__,   ["__get__"],            true]
    - ["fu1786018", functools.cached_property.__dict__.__contains__,   ["__set__"],            true]
    - ["fu1786019", functools.cached_property.__dict__.__contains__,   ["__set_name__"],       true]
    - ["fu1786020", functools.cached_property.__dict__.__contains__,   ["__new__"],            false]
    - ["fu1786021", functools.partialmethod.__dict__.__contains__,     ["__get__"],            true]
    - ["fu1786022", functools.partialmethod.__dict__.__contains__,     ["__new__"],            false]
    - ["fu1786023", functools.partial.__dict__.__contains__,           ["__set_name__"],       false]
    - ["fu1786024", functools.cached_property.__dict__.__contains__,   ["__call__"],           false]
