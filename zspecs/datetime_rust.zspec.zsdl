spec: datetime_rust
version: ">=3.9"
backend: rust_module(datetime_rust)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime documentation (API surface)"
    - "ISO 8601:2019 — Date and time — Representations for information interchange"
    - "ISO/IEC 9899:2018 — Proleptic Gregorian calendar definitions"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
  notes:
    - "Clean-room Rust reimplementation of date/datetime arithmetic, exposed via PyO3."
    - "Exposes functional API: date_isoformat(y,m,d) -> str, date_weekday(y,m,d) -> int, etc."
    - "date_isoformat(year, month, day) -> str — 'YYYY-MM-DD' (ISO 8601)."
    - "date_weekday(year, month, day) -> int — Monday=0, Sunday=6 (ISO weekday - 1)."
    - "date_toordinal(year, month, day) -> int — days since year 1, Jan 1 (ordinal 1)."
    - "date_add_days(year, month, day, n) -> str — ISO 8601 string for date + n days."
    - "date_days_between(y1,m1,d1, y2,m2,d2) -> int — signed day count (d2 - d1)."
    - "datetime_isoformat(y,m,d,H,M,S) -> str — 'YYYY-MM-DDTHH:MM:SS'."
    - "Proleptic Gregorian calendar (same as Python datetime.date)."
    - "Leap year rule: divisible by 4, except centuries unless divisible by 400."
    - "date(1,1,1).toordinal() = 1 (Python convention)."
    - "date(2024,1,1).toordinal() = 738886 (verified against Python 3.14.3)."
    - "date(2024,4,18) is Thursday (weekday=3)."
    - "All test vectors verified against Python 3.14.3."
  created_at: "2026-04-18T00:00:00Z"

error_model: python_exceptions

table datetime_rust.date_isoformat:
  kind: python_call_eq
  category: isoformat
  id_prefix: date_isoformat
  function: date_isoformat

  columns: [id, args, expected]
  rows:
    - [epoch,        [1, 1, 1],          "0001-01-01"]
    - [y2k,          [2000, 1, 1],       "2000-01-01"]
    - [today,        [2024, 4, 18],      "2024-04-18"]
    - [end_of_year,  [2023, 12, 31],     "2023-12-31"]
    - [leap_day,     [2000, 2, 29],      "2000-02-29"]

table datetime_rust.date_weekday:
  kind: python_call_eq
  category: weekday
  id_prefix: date_weekday
  function: date_weekday

  columns: [id, args, expected]
  rows:
    - [monday_jan1_2024,   [2024, 1, 1],   0]
    - [thursday_apr18,     [2024, 4, 18],  3]
    - [sunday,             [2024, 1, 7],   6]
    - [saturday,           [2024, 1, 6],   5]
    - [wednesday,          [2024, 1, 3],   2]

table datetime_rust.date_toordinal:
  kind: python_call_eq
  category: ordinal
  id_prefix: date_toordinal
  function: date_toordinal

  columns: [id, args, expected]
  rows:
    - [day_one,      [1, 1, 1],     1     ]
    - [y2k,          [2000, 1, 1],  730120]
    - [jan2024,      [2024, 1, 1],  738886]
    - [apr2024,      [2024, 4, 18], 738994]

table datetime_rust.date_add_days:
  kind: python_call_eq
  category: arithmetic
  id_prefix: date_add_days
  function: date_add_days

  columns: [id, args, expected]
  rows:
    - [plus_ten,        [2024, 1, 1, 10],    "2024-01-11"]
    - [month_boundary,  [2024, 1, 25, 7],    "2024-02-01"]
    - [year_boundary,   [2023, 12, 25, 10],  "2024-01-04"]
    - [leap_day_cross,  [2024, 2, 28, 1],    "2024-02-29"]
    - [negative,        [2024, 1, 10, -5],   "2024-01-05"]
    - [plus_zero,       [2024, 6, 15, 0],    "2024-06-15"]

table datetime_rust.date_days_between:
  kind: python_call_eq
  category: arithmetic
  id_prefix: date_days_between
  function: date_days_between

  columns: [id, args, expected]
  rows:
    - [same_day,      [2024, 1, 1, 2024, 1, 1],    0  ]
    - [one_day,       [2024, 1, 1, 2024, 1, 2],    1  ]
    - [one_year,      [2024, 1, 1, 2025, 1, 1],    366]
    - [negative,      [2024, 3, 1, 2024, 1, 1],   -60 ]

table datetime_rust.datetime_isoformat:
  kind: python_call_eq
  category: datetime
  id_prefix: datetime_isoformat
  function: datetime_isoformat

  columns: [id, args, expected]
  rows:
    - [midnight,      [2024, 1, 1, 0, 0, 0],    "2024-01-01T00:00:00"]
    - [noon,          [2024, 4, 18, 12, 0, 0],  "2024-04-18T12:00:00"]
    - [end_of_day,    [2024, 12, 31, 23, 59, 59], "2024-12-31T23:59:59"]

invariant datetime_rust.error.invalid_month:
  description: "date with month=13 raises ValueError"
  category: error
  kind: python_call_raises
  function: date_isoformat
  args: [2024, 13, 1]
  expected_exception: ValueError

invariant datetime_rust.error.invalid_day:
  description: "date with day=31 in April raises ValueError"
  category: error
  kind: python_call_raises
  function: date_isoformat
  args: [2024, 4, 31]
  expected_exception: ValueError

invariant datetime_rust.error.non_leap_day:
  description: "Feb 29 in non-leap year raises ValueError"
  category: error
  kind: python_call_raises
  function: date_isoformat
  args: [2023, 2, 29]
  expected_exception: ValueError

