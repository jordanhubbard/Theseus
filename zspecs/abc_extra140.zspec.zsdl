invariant abc_extra140.update_abstractmethods_doc_len_627:
  description: "abc.update_abstractmethods.__doc__.__len__() == 627 — abc.update_abstractmethods.__doc__ is a 627-char multi-paragraph doc beginning 'Recalculate the set of abstract methods of an abstract class.' and describing when to use the function (when a method is implemented after class creation, or when a new abstract method is added); this is the longest __doc__ in this spec (compare: ABCMeta=576, ABCMeta.register=99, get_cache_token=230, __instancecheck__=__subclasscheck__=39); update_abstractmethods.__qualname__=='update_abstractmethods' (len=22); co_argcount==1 ('cls'); co_varnames.__len__()==5; NEW in extra140: first standalone update_abstractmethods doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.update_abstractmethods.__doc__.__len__
  args: []
  expected: 627

invariant abc_extra140.update_abstractmethods_varnames_len_5:
  description: "abc.update_abstractmethods.__code__.co_varnames.__len__() == 5 — abc.update_abstractmethods.__code__.co_varnames is ('cls','abstracts','scls','name','value') (5 elements: 1 param 'cls' + 4 locals 'abstracts','scls','name','value'); the 4 locals iterate over the class hierarchy collecting abstract method names ('abstracts' set, 'scls' subclass iteration, 'name' and 'value' for each attribute); update_abstractmethods co_argcount==1 ('cls' only); update_abstractmethods.__qualname__=='update_abstractmethods' (len=22); NEW in extra140: first standalone update_abstractmethods co_varnames length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.update_abstractmethods.__code__.co_varnames.__len__
  args: []
  expected: 5

invariant abc_extra140.get_cache_token_module_abc_c_extension:
  description: "abc.get_cache_token.__module__.__len__() == 4 — abc.get_cache_token.__module__ is '_abc' (4 chars: the C extension module; note the leading underscore indicating an internal C module); this is different from abc.update_abstractmethods.__module__=='abc' (len=3: pure Python); get_cache_token.__qualname__=='get_cache_token' (len=15); get_cache_token is a C builtin function (no __code__ attribute); __doc__.__len__()==230; NEW in extra140: first standalone get_cache_token module length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
