spec: abc_extra140
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers: abc.ABCMeta.register — __qualname__=='ABCMeta.register' (len=16); __doc__.__len__()==99 (doc is 'Register a virtual subclass of an ABC.\\n\\nReturns the subclass, to allow usage as a class decorator.\\n'); co_argcount==2 ('cls','subclass'). abc.ABCMeta.__instancecheck__ — __qualname__=='ABCMeta.__instancecheck__' (len=25); __doc__.__eq__('Override for isinstance(instance, cls).')==True (len=39); co_argcount==2 ('cls','instance'); co_varnames.__len__()==2. abc.ABCMeta.__subclasscheck__ — __qualname__=='ABCMeta.__subclasscheck__' (len=25); __doc__.__eq__('Override for issubclass(subclass, cls).')==True (len=39); co_argcount==2 ('cls','subclass'); co_varnames.__len__()==2. abc.update_abstractmethods — __qualname__=='update_abstractmethods' (len=22); __module__=='abc' (len=3); __doc__.__len__()==627; co_argcount==1 ('cls'); co_varnames.__len__()==5. abc.get_cache_token — __qualname__=='get_cache_token' (len=15); __module__=='_abc' (len=4); __doc__.__len__()==230; a C builtin (no __code__). abc.ABCMeta.__name__=='ABCMeta' (len=7); abc.ABCMeta.__doc__.__len__()==576. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__instancecheck__ and abc.ABCMeta.__subclasscheck__ both have qualname len==25 and doc len==39 — symmetric methods for isinstance() and issubclass() override. abc.abstractmethod does not have __wrapped__ (hasattr returns False). abc.update_abstractmethods is a pure-Python function in 'abc' (len=3) while abc.get_cache_token is a C builtin from '_abc' (len=4). ABCMeta.__doc__.__len__()==576 (a detailed multi-paragraph doc with example). register.__doc__.__len__()==99: the two-sentence doc describes virtual subclass registration and the class decorator usage. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

