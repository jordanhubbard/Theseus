  args: []
  expected: 4

invariant abc_extra140.get_cache_token_doc_len_230:
  description: "abc.get_cache_token.__doc__.__len__() == 230 — abc.get_cache_token.__doc__ is a 230-char multi-sentence doc beginning 'Returns the current ABC cache token.' and describing the token as an opaque object identifying the version of the ABC cache for virtual subclasses, changing with every call to register() on any ABC; get_cache_token.__qualname__=='get_cache_token' (len=15); get_cache_token.__module__=='_abc' (len=4: C extension); this is a C builtin (no __code__); compare: update_abstractmethods.__doc__.__len__()==627 (more than twice as long); NEW in extra140: first standalone get_cache_token doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__doc__.__len__
  args: []
  expected: 230

invariant abc_extra140.abcmeta_doc_len_576:
  description: "abc.ABCMeta.__doc__.__len__() == 576 — abc.ABCMeta.__doc__ is a 576-char detailed multi-paragraph doc with a class example showing how to create an Abstract Base Class with ABCMeta as its metaclass; ABCMeta.__name__=='ABCMeta' (len=7); ABCMeta.__module__=='abc' (len=3); ABCMeta.__bases__[0].__name__=='type' (len=4: ABCMeta inherits from type, making it a proper metaclass); this is the second-longest __doc__ in this spec after update_abstractmethods (627); NEW in extra140: first standalone ABCMeta.__doc__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
