# abc.ABCMeta.register.__qualname__    == 'ABCMeta.register' (len=16)
# abc.ABCMeta.register.__doc__.__len__() == 99
# abc.ABCMeta.register co_argcount     == 2
# abc.ABCMeta.__name__                 == 'ABCMeta'         (len=7)
# abc.ABCMeta.__doc__.__len__()        == 576
# ---------------------------------------------------------------------------

table abc_extra140.abcmeta_register_and_identity:
  description: "abc.ABCMeta.register doc and identity, and ABCMeta class doc checks — register.__qualname__.__eq__('ABCMeta.register')==True (len=16: 'ABCMeta'=7+'.'=1+'register'=8=16); register.__doc__.__len__()==99 (doc is 'Register a virtual subclass of an ABC.\\n\\nReturns the subclass, to allow usage as a class decorator.\\n' — 99 chars including newlines; a two-sentence description); register.__code__.co_argcount.__eq__(2)==True ('cls','subclass' — a classmethod taking the class to register as a virtual subclass); ABCMeta.__name__.__eq__('ABCMeta')==True (len=7: 'ABCMeta'=7); ABCMeta.__name__.__len__()==7; ABCMeta.__module__.__eq__('abc')==True (len=3: the pure-Python abc module); ABCMeta.__doc__.__len__()==576 (a detailed multi-paragraph doc with a class example showing how to create an ABC with ABCMeta as its metaclass — the longest __doc__ value in this spec); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcreg140

  columns: [id, function, args, expected, description]
  rows:
    - [reg_qn_eq,    abc.ABCMeta.register.__qualname__.__eq__,          ["ABCMeta.register"],  true,  "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' (len=16); verified with Python 3.14.3"]
    - [reg_qn_len,   abc.ABCMeta.register.__qualname__.__len__,          [],                    16,    "abc.ABCMeta.register.__qualname__.__len__() == 16; verified with Python 3.14.3"]
    - [reg_doc_len,  abc.ABCMeta.register.__doc__.__len__,               [],                    99,    "abc.ABCMeta.register.__doc__.__len__() == 99; verified with Python 3.14.3"]
    - [reg_argc,     abc.ABCMeta.register.__code__.co_argcount.__eq__,  [2],                    true,  "abc.ABCMeta.register.__code__.co_argcount == 2 ('cls','subclass'); verified with Python 3.14.3"]
    - [meta_name_eq, abc.ABCMeta.__name__.__eq__,                       ["ABCMeta"],            true,  "abc.ABCMeta.__name__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]
    - [meta_name_len,abc.ABCMeta.__name__.__len__,                       [],                    7,     "abc.ABCMeta.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [meta_mod_eq,  abc.ABCMeta.__module__.__eq__,                     ["abc"],                true,  "abc.ABCMeta.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [meta_mod_len, abc.ABCMeta.__module__.__len__,                     [],                    3,     "abc.ABCMeta.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [meta_doc_len, abc.ABCMeta.__doc__.__len__,                        [],                    576,   "abc.ABCMeta.__doc__.__len__() == 576; verified with Python 3.14.3"]

