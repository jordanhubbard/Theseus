invariant abc_extra140.abcmeta_register_doc_len_99:
  description: "abc.ABCMeta.register.__doc__.__len__() == 99 — abc.ABCMeta.register.__doc__ is 'Register a virtual subclass of an ABC.\\n\\nReturns the subclass, to allow usage as a class decorator.\\n' (99 chars including newlines: two sentences separated by a blank line); register.__qualname__=='ABCMeta.register' (len=16); register.__module__=='abc' (len=3); register co_argcount==2 ('cls','subclass'); compare: __instancecheck__.__doc__.__len__()==39 (shorter), update_abstractmethods.__doc__.__len__()==627 (longer), ABCMeta.__doc__.__len__()==576 (class-level doc); NEW in extra140: first standalone ABCMeta.register doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.register.__doc__.__len__
  args: []
  expected: 99

