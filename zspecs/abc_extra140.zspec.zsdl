table abc_extra140.update_abstractmethods_and_get_cache_token:
  description: "abc.update_abstractmethods and abc.get_cache_token qualname, module, doc, and code checks — update_abstractmethods.__qualname__.__eq__('update_abstractmethods')==True (len=22: 'update_abstractmethods'=22; top-level function, qualname equals name); update_abstractmethods.__module__.__eq__('abc')==True (len=3: pure-Python abc module, not the C _abc extension); update_abstractmethods.__doc__.__len__()==627 (a detailed multi-paragraph doc beginning 'Recalculate the set of abstract methods of an abstract class.' — the longest __doc__ in this spec); update_abstractmethods.__code__.co_argcount.__eq__(1)==True ('cls', the class to update); update_abstractmethods.__code__.co_varnames.__len__()==5 ('cls','abstracts','scls','name','value' — 1 param + 4 locals iterating over the class hierarchy and its method values); get_cache_token.__qualname__.__eq__('get_cache_token')==True (len=15: 'get_cache_token'=15); get_cache_token.__module__.__eq__('_abc')==True (len=4: the C extension _abc, unlike update_abstractmethods which is in pure-Python 'abc'; len=4 vs len=3); get_cache_token.__doc__.__len__()==230 (doc beginning 'Returns the current ABC cache token.' — a C builtin with no __code__); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcuam140

  columns: [id, function, args, expected, description]
