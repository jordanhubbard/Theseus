  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__qualname__.__len__
  args: []
  expected: 25

invariant abc_extra140.abcmeta_subclasscheck_doc_len_39:
  description: "abc.ABCMeta.__subclasscheck__.__doc__.__len__() == 39 — abc.ABCMeta.__subclasscheck__.__doc__ is 'Override for issubclass(subclass, cls).' (39 chars); this ties with __instancecheck__.__doc__.__len__()==39 (the symmetric isinstance/issubclass override pair has equal doc lengths); __subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25); __subclasscheck__ co_argcount==2 ('cls','subclass'); NEW in extra140: first standalone ABCMeta.__subclasscheck__ doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__subclasscheck__.__doc__.__len__
