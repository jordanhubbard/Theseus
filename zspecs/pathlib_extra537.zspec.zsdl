spec: pathlib_extra537
version: ">=3.9"
backend: python_module(pathlib)
docs: "Behavioral specs for pathlib.Path method name identity"
provenance:
  derived_from:
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"
error_model: strict

table pathlib_extra537.method_name_identity:
  description: "Verify __name__ for pathlib.Path dunder methods"
  kind: python_call_eq
  category: identity
  id_prefix: mn
  columns: [id, function, args, expected]
  rows:
    - [mn001, pathlib.Path.__init__.__name__.__eq__, ["__init__"], true]
    - [mn002, pathlib.Path.__new__.__name__.__eq__, ["__new__"], true]
    - [mn003, pathlib.Path.__repr__.__name__.__eq__, ["__repr__"], true]
    - [mn004, pathlib.Path.__str__.__name__.__eq__, ["__str__"], true]
    - [mn005, pathlib.Path.__bytes__.__name__.__eq__, ["__bytes__"], true]
    - [mn006, pathlib.Path.__hash__.__name__.__eq__, ["__hash__"], true]
    - [mn007, pathlib.Path.__eq__.__name__.__eq__, ["__eq__"], true]
    - [mn008, pathlib.Path.__lt__.__name__.__eq__, ["__lt__"], true]
    - [mn009, pathlib.Path.__le__.__name__.__eq__, ["__le__"], true]
    - [mn010, pathlib.Path.__gt__.__name__.__eq__, ["__gt__"], true]
    - [mn011, pathlib.Path.__ge__.__name__.__eq__, ["__ge__"], true]
    - [mn012, pathlib.Path.__truediv__.__name__.__eq__, ["__truediv__"], true]
    - [mn013, pathlib.Path.__rtruediv__.__name__.__eq__, ["__rtruediv__"], true]
