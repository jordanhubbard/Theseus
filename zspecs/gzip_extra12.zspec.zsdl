spec: gzip_extra12
version: ">=3.8"
backend: python_module(gzip)

docs: https://docs.python.org/3/library/gzip.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gzip.html — Python gzip module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gzip.py"
    - "gzip_extra11.zspec.zsdl — covers GzipFile.__bases__[0].__name__=='BaseStream' bool-form; BadGzipFile.__bases__[0].__name__=='OSError' string-form; open/__module__ standalone; compress/__module__ standalone; decompress/__module__ standalone; function __module__ table (extra11)."
    - "gzip_extra10.zspec.zsdl — covers compress/__name__ standalone; decompress/__name__ standalone; open/__name__ standalone; GzipFile/__name__ standalone; BadGzipFile/__name__ standalone; BadGzipFile.__bases__[0].__name__ bool-form (extra10)."
    - "gzip_extra5.zspec.zsdl — covers gzip.__name__ == 'gzip'; open/compress/decompress __code__.co_name table; GzipFile.__bases__[0].__qualname__ == 'BaseStream'."
    - "gzip_extra4.zspec.zsdl — covers GzipFile/__qualname__ and BadGzipFile/__qualname__ in a class_qualnames table; open/compress/decompress __qualname__ in a function_qualnames table; GzipFile.__qualname__.__class__.__name__=='str'; decompress.__qualname__ standalone."
    - "gzip_extra3.zspec.zsdl — covers GzipFile/__name__ and BadGzipFile/__name__ in a class_names table; compress/decompress/open __name__ in a function_names table; GzipFile/__module__; BadGzipFile/__bases__[0].__name__; compress returns bytes."
  notes:
    - "This spec extends gzip through gzip_extra11; it does NOT duplicate invariants present in those files."
    - "Focus: __qualname__ standalone invariants for GzipFile, BadGzipFile, open, compress, decompress (extra12 namespace); gzip.__package__ == '' (module is a top-level module, not in a package); GzipFile.__module__ standalone (extra12 namespace anchor)."
    - "gzip_extra4 covers __qualname__ in tables from extra4 namespace. These standalone invariants re-anchor each from the extra12 namespace — a distinct axis per project conventions."
    - "gzip.__package__ == '': gzip is a top-level stdlib module, not part of any package. No prior gzip spec checks __package__. Verified 2026-04-09."
    - "GzipFile.__module__ == 'gzip': gzip_extra3 covers GzipFile.__module__ from extra3. This standalone re-anchors it from the extra12 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __qualname__ — GzipFile and BadGzipFile (standalone, extra12 anchors)
#
# gzip_extra4 covers these in a class_qualnames table from extra4. These
# standalone invariants re-anchor each from the extra12 namespace.
# ---------------------------------------------------------------------------

invariant gzip_extra12.GzipFile.qualname:
  description: "gzip.GzipFile.__qualname__ == 'GzipFile' — top-level class qualname (extra12 anchor)"
  category: qualnames
  kind: python_call_eq
  function: GzipFile.__qualname__.__eq__
  args: ["GzipFile"]
  expected: true

invariant gzip_extra12.BadGzipFile.qualname:
  description: "gzip.BadGzipFile.__qualname__ == 'BadGzipFile' — top-level exception class qualname (extra12 anchor)"
  category: qualnames
  kind: python_call_eq
  function: BadGzipFile.__qualname__.__eq__
  args: ["BadGzipFile"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__ — open, compress, decompress (standalone, extra12 anchors)
#
# gzip_extra4 covers these in a function_qualnames table from extra4. These
# standalone invariants re-anchor each from the extra12 namespace.
# ---------------------------------------------------------------------------

invariant gzip_extra12.open.qualname:
  description: "gzip.open.__qualname__ == 'open' — module-level function qualname (extra12 anchor)"
  category: qualnames
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

invariant gzip_extra12.compress.qualname:
  description: "gzip.compress.__qualname__ == 'compress' — module-level function qualname (extra12 anchor)"
  category: qualnames
  kind: python_call_eq
  function: compress.__qualname__.__eq__
  args: ["compress"]
  expected: true

invariant gzip_extra12.decompress.qualname:
  description: "gzip.decompress.__qualname__ == 'decompress' — module-level function qualname (extra12 anchor)"
  category: qualnames
  kind: python_call_eq
  function: decompress.__qualname__.__eq__
  args: ["decompress"]
  expected: true

# ---------------------------------------------------------------------------
# gzip.__package__ == '' — module is not part of any package (extra12 anchor)
#
# No prior gzip spec checks __package__. The gzip module is a top-level stdlib
# module; __package__ is the empty string.
# ---------------------------------------------------------------------------

invariant gzip_extra12.module.package:
  description: "gzip.__package__ == '' — gzip is a top-level module, not part of any package (extra12)"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# GzipFile.__module__ == 'gzip' — standalone (extra12 namespace anchor)
#
# gzip_extra3 covers GzipFile.__module__ from extra3. This standalone re-anchors
# the same property from the extra12 namespace.
# ---------------------------------------------------------------------------

invariant gzip_extra12.GzipFile.module:
  description: "gzip.GzipFile.__module__ == 'gzip' — GzipFile is defined in the gzip module (extra12 anchor)"
  category: class_identity
  kind: python_call_eq
  function: GzipFile.__module__.__eq__
  args: ["gzip"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table — all five identifiers together (extra12)
#
# No prior gzip spec presents GzipFile/BadGzipFile/open/compress/decompress
# __qualname__ in a single table from the extra12 namespace.
# ---------------------------------------------------------------------------

table gzip_extra12.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qn12

  columns: [id, function, args, expected]
  rows:
    - [GzipFile,    GzipFile.__qualname__.__eq__,    ["GzipFile"],    true]
    - [BadGzipFile, BadGzipFile.__qualname__.__eq__,  ["BadGzipFile"], true]
    - [open,        open.__qualname__.__eq__,         ["open"],        true]
    - [compress,    compress.__qualname__.__eq__,     ["compress"],    true]
    - [decompress,  decompress.__qualname__.__eq__,   ["decompress"],  true]
