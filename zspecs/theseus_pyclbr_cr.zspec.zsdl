spec: theseus_pyclbr_cr
version: ">=3.0"
backend: python_cleanroom(theseus_pyclbr_cr)
blocks: pyclbr

docs: https://docs.python.org/3/library/pyclbr.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pyclbr.html"
  not_derived_from:
    - "CPython source: Lib/pyclbr.py"
  notes:
    - "Clean-room pyclbr module. Do NOT import pyclbr."

error_model: python_exceptions

invariant theseus_pyclbr_cr.pyclbr2_class:
  description: "Class object has name and module attributes"
  category: behavior
  kind: python_call_eq
  function: pyclbr2_class
  args: []
  expected: true

invariant theseus_pyclbr_cr.pyclbr2_function:
  description: "Function object has name and module attributes"
  category: behavior
  kind: python_call_eq
  function: pyclbr2_function
  args: []
  expected: true

invariant theseus_pyclbr_cr.pyclbr2_readmodule:
  description: "readmodule() returns a dict of class/function names"
  category: behavior
  kind: python_call_eq
  function: pyclbr2_readmodule
  args: []
  expected: true
