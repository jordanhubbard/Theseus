spec: itertools_extra185
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/itertools.py"
  notes:
    - "This spec covers: itertools.tee and itertools.zip_longest identity — itertools.tee.__name__=='tee' (len=3); itertools.tee.__module__=='itertools'; itertools.tee.__qualname__=='tee'; itertools.tee.__class__.__name__=='builtin_function_or_method'; itertools.zip_longest.__name__=='zip_longest' (len=11); itertools.zip_longest.__module__=='itertools'; itertools.zip_longest.__qualname__=='zip_longest'; itertools.zip_longest.__class__.__name__=='type' (zip_longest is a C type, not a function)."
    - "itertools.tee.__name__ == 'tee' — tee is a C builtin function in the itertools module that creates n independent iterators from a single iterable; its __name__ is 'tee' (3 chars). Verified with Python 3.14.3."
    - "itertools.tee.__module__ == 'itertools' — tee reports __module__=='itertools' (the public module), not a private C extension name. Verified with Python 3.14.3."
    - "itertools.tee.__qualname__ == 'tee' — as a module-level builtin, __qualname__ equals __name__ 'tee'. Verified with Python 3.14.3."
    - "itertools.tee.__class__.__name__ == 'builtin_function_or_method' — tee is a C builtin function (not a type), so type(tee).__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "itertools.zip_longest.__name__ == 'zip_longest' — zip_longest is a C type (class) in itertools that pairs up elements from multiple iterables, filling missing values; its __name__ is 'zip_longest' (11 chars). Verified with Python 3.14.3."
    - "itertools.zip_longest.__module__ == 'itertools' — zip_longest reports __module__=='itertools'. Verified with Python 3.14.3."
    - "itertools.zip_longest.__qualname__ == 'zip_longest' — module-level type has __qualname__ == __name__ == 'zip_longest'. Verified with Python 3.14.3."
    - "itertools.zip_longest.__class__.__name__ == 'type' — zip_longest is a C type (class), so type(zip_longest).__name__ is 'type' (unlike tee which is 'builtin_function_or_method'). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.tee __name__, __module__, __qualname__
#
# itertools.tee.__name__ == 'tee'
# itertools.tee.__name__.__len__() == 3
# itertools.tee.__module__ == 'itertools'
# itertools.tee.__qualname__ == 'tee'
#
# itertools.tee is a C builtin function that creates n independent iterators
# from a single iterable by caching elements internally. Its __name__ is 'tee'
# (3 chars) and its __module__ is 'itertools'. New to extra185.
# ---------------------------------------------------------------------------

table itertools_extra185.tee_identity:
  description: "itertools.tee.__name__=='tee' len 3; __module__=='itertools'; __qualname__=='tee'; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: itertee185

  columns: [id, function, args, expected, description]
  rows:
    - [tee_name_eq,
       tee.__name__.__eq__,
       ["tee"],
       true,
       "itertools.tee.__name__.__eq__('tee') == True — tee is a C builtin that creates n independent iterators from a single iterable by caching elements; its __name__ is 'tee' (3 chars); str.__eq__('tee') returns True; new to extra185"]
    - [tee_name_len_3,
       tee.__name__.__len__,
       [],
       3,
       "itertools.tee.__name__.__len__() == 3 — the name 'tee' has exactly 3 characters: t-e-e; str.__len__() returns 3; new to extra185"]
    - [tee_module_eq,
       tee.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.tee.__module__.__eq__('itertools') == True — tee is exposed through the itertools public module; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra185"]
    - [tee_qualname_eq,
       tee.__qualname__.__eq__,
       ["tee"],
       true,
       "itertools.tee.__qualname__.__eq__('tee') == True — as a module-level builtin, __qualname__ equals __name__ 'tee' (3 chars); str.__eq__('tee') returns True; new to extra185"]

# ---------------------------------------------------------------------------
# Table 2: itertools.tee __class__ and itertools.zip_longest __name__,
#          __module__
#
# itertools.tee.__class__.__name__ == 'builtin_function_or_method'
# itertools.zip_longest.__name__ == 'zip_longest'
# itertools.zip_longest.__name__.__len__() == 11
# itertools.zip_longest.__module__ == 'itertools'
#
# tee is a C builtin function so its __class__.__name__ is
# 'builtin_function_or_method'. zip_longest is a C type (class) that zips
# multiple iterables using a fillvalue for missing elements; it has __name__
# 'zip_longest' (11 chars). New to extra185.
# ---------------------------------------------------------------------------

table itertools_extra185.tee_class_and_zip_longest_name:
  description: "itertools.tee.__class__.__name__=='builtin_function_or_method'; itertools.zip_longest.__name__=='zip_longest' len 11; __module__=='itertools'; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: itertee185

  columns: [id, function, args, expected, description]
  rows:
    - [tee_class_eq,
       tee.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "itertools.tee.__class__.__name__.__eq__('builtin_function_or_method') == True — tee is a C builtin function (not a type), so type(tee).__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra185"]
    - [zip_longest_name_eq,
       zip_longest.__name__.__eq__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__name__.__eq__('zip_longest') == True — zip_longest is a C type that pairs elements from multiple iterables using a fillvalue for missing values; its __name__ is 'zip_longest' (11 chars); str.__eq__('zip_longest') returns True; new to extra185"]
    - [zip_longest_name_len_11,
       zip_longest.__name__.__len__,
       [],
       11,
       "itertools.zip_longest.__name__.__len__() == 11 — the name 'zip_longest' has exactly 11 characters: z-i-p-_-l-o-n-g-e-s-t; str.__len__() returns 11; new to extra185"]
    - [zip_longest_module_eq,
       zip_longest.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.zip_longest.__module__.__eq__('itertools') == True — zip_longest is exposed through the itertools public module; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra185"]

# ---------------------------------------------------------------------------
# Table 3: itertools.zip_longest __qualname__ and __class__
#
# itertools.zip_longest.__qualname__ == 'zip_longest'
# itertools.zip_longest.__class__.__name__ == 'type'
#
# zip_longest is a C type so __qualname__ == __name__ == 'zip_longest'. Its
# __class__.__name__ is 'type' (the metaclass), contrasting with tee whose
# __class__.__name__ is 'builtin_function_or_method'. New to extra185.
# ---------------------------------------------------------------------------

table itertools_extra185.zip_longest_qualname_and_class:
  description: "itertools.zip_longest.__qualname__=='zip_longest' equals __name__; __class__.__name__=='type' (C type, not builtin_function_or_method); new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: itertee185

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_qualname_eq,
       zip_longest.__qualname__.__eq__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__qualname__.__eq__('zip_longest') == True — as a module-level C type, __qualname__ equals __name__ 'zip_longest' (11 chars); str.__eq__('zip_longest') returns True; new to extra185"]
    - [zip_longest_qualname_len_11,
       zip_longest.__qualname__.__len__,
       [],
       11,
       "itertools.zip_longest.__qualname__.__len__() == 11 — the qualname 'zip_longest' has exactly 11 characters, equal to the __name__ length; str.__len__() returns 11; new to extra185"]
    - [zip_longest_class_eq,
       zip_longest.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.zip_longest.__class__.__name__.__eq__('type') == True — zip_longest is a C type (class), so type(zip_longest).__name__ is 'type' (the metaclass), contrasting with tee whose type is 'builtin_function_or_method'; str.__eq__('type') returns True; new to extra185"]
    - [tee_qualname_len_3,
       tee.__qualname__.__len__,
       [],
       3,
       "itertools.tee.__qualname__.__len__() == 3 — cross-check: 'tee' qualname is 3 chars (same as __name__) while 'zip_longest' qualname is 11 chars; confirmed by str.__len__(); new to extra185"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra185
# ---------------------------------------------------------------------------

invariant itertools_extra185.tee_name_is_tee:
  description: "itertools.tee.__name__ == 'tee' — C builtin that creates n independent iterators from a single iterable by caching elements internally; __name__ is 'tee' (3 chars); new to extra185"
  category: identity
  kind: python_call_eq
  function: tee.__name__.__eq__
  args: ["tee"]
  expected: true

invariant itertools_extra185.tee_module_is_itertools:
  description: "itertools.tee.__module__ == 'itertools' — tee is exposed through the public itertools module; its __module__ is 'itertools'; new to extra185"
  category: identity
  kind: python_call_eq
  function: tee.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra185.tee_qualname_equals_name:
  description: "itertools.tee.__qualname__ == 'tee' — module-level C builtin has __qualname__ == __name__ == 'tee' (3 chars); new to extra185"
  category: identity
  kind: python_call_eq
  function: tee.__qualname__.__eq__
  args: ["tee"]
  expected: true

invariant itertools_extra185.tee_class_is_builtin_function:
  description: "itertools.tee.__class__.__name__ == 'builtin_function_or_method' — tee is a C builtin function (not a type/class), so type(tee).__name__ is 'builtin_function_or_method'; new to extra185"
  category: identity
  kind: python_call_eq
  function: tee.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra185.zip_longest_name_is_zip_longest:
  description: "itertools.zip_longest.__name__ == 'zip_longest' — C type that zips multiple iterables padding with a fillvalue for missing elements; __name__ is 'zip_longest' (11 chars); new to extra185"
  category: identity
  kind: python_call_eq
  function: zip_longest.__name__.__eq__
  args: ["zip_longest"]
  expected: true

invariant itertools_extra185.zip_longest_module_is_itertools:
  description: "itertools.zip_longest.__module__ == 'itertools' — zip_longest is exposed through the public itertools module; its __module__ is 'itertools'; new to extra185"
  category: identity
  kind: python_call_eq
  function: zip_longest.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra185.zip_longest_qualname_equals_name:
  description: "itertools.zip_longest.__qualname__ == 'zip_longest' — module-level C type has __qualname__ == __name__ == 'zip_longest' (11 chars); new to extra185"
  category: identity
  kind: python_call_eq
  function: zip_longest.__qualname__.__eq__
  args: ["zip_longest"]
  expected: true

invariant itertools_extra185.zip_longest_class_is_type:
  description: "itertools.zip_longest.__class__.__name__ == 'type' — zip_longest is a C type (class), so type(zip_longest).__name__ is 'type'; this distinguishes it from tee whose type is 'builtin_function_or_method'; new to extra185"
  category: identity
  kind: python_call_eq
  function: zip_longest.__class__.__name__.__eq__
  args: ["type"]
  expected: true
