spec: hl3496
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 680 (hl3496): __aenter__, __aexit__, __await__ dict-presence checks for hashlib/uuid/struct/socket types."
    - "All values False — these types do not implement async protocols."
    - "type(hashlib.md5()), type(hashlib.sha1()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "None of the hashlib types define __aenter__, __aexit__, or __await__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3496.aenter:
  description: "hashlib types __aenter__ dict-presence checks; wave 680"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: hl3496
  columns: [id, function, args, expected]
  rows:
    - ["hl3496001", operator.contains, [type(hashlib.md5()).__dict__,        "__aenter__"], false]
    - ["hl3496002", operator.contains, [type(hashlib.sha1()).__dict__,       "__aenter__"], false]
    - ["hl3496003", operator.contains, [type(hashlib.sha256()).__dict__,     "__aenter__"], false]
    - ["hl3496004", operator.contains, [type(hashlib.sha512()).__dict__,     "__aenter__"], false]
    - ["hl3496005", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__aenter__"], false]

