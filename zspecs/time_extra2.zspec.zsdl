spec: time_extra2
version: ">=3.3"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "Python time documentation — https://docs.python.org/3/library/time.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "time.zspec.zsdl — covers gmtime epoch/year2024 attributes, strptime tables, function names (gmtime/strptime/strftime/mktime/sleep), struct_time.__name__, strptime error cases"
    - "time_extra.zspec.zsdl — covers struct_time.__module__, time()/monotonic()/perf_counter()/process_time() return types, gmtime()/localtime() return types, timezone/__class__.__name__, altzone/__class__.__name__"
  notes:
    - "This spec provides a self-contained reference for the __name__ attributes and module-level integer constant types of the time module."
    - "time.struct_time.__name__ == 'struct_time' — confirmed on CPython 3.12."
    - "time.timezone.__class__.__name__ == 'int' — UTC offset west of UTC in seconds."
    - "time.altzone.__class__.__name__ == 'int' — DST-adjusted UTC offset in seconds."
    - "time.daylight.__class__.__name__ == 'int' — non-zero when DST is used in the local timezone."
    - "time.gmtime.__name__ == 'gmtime' — confirmed on CPython 3.12."
    - "time.localtime.__name__ == 'localtime' — confirmed on CPython 3.12."
    - "time.mktime.__name__ == 'mktime' — confirmed on CPython 3.12."
    - "time.strftime.__name__ == 'strftime' — confirmed on CPython 3.12."
    - "time.strptime.__name__ == 'strptime' — confirmed on CPython 3.12."
    - "time.monotonic.__name__ == 'monotonic' — confirmed on CPython 3.12."
    - "time.perf_counter.__name__ == 'perf_counter' — confirmed on CPython 3.12."
    - "time.process_time.__name__ == 'process_time' — confirmed on CPython 3.12."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct_time class identity
# ---------------------------------------------------------------------------

invariant time_extra2.struct_time.class_name:
  description: "time.struct_time.__name__ == 'struct_time'"
  category: struct_time
  kind: python_call_eq
  function: struct_time.__name__.__eq__
  args: ["struct_time"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level integer constants — type checks
# ---------------------------------------------------------------------------

invariant time_extra2.timezone.class_name:
  description: "time.timezone.__class__.__name__ == 'int' — UTC offset is an integer"
  category: module_constants
  kind: python_call_eq
  function: timezone.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant time_extra2.altzone.class_name:
  description: "time.altzone.__class__.__name__ == 'int' — DST offset is an integer"
  category: module_constants
  kind: python_call_eq
  function: altzone.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant time_extra2.daylight.class_name:
  description: "time.daylight.__class__.__name__ == 'int' — DST-in-use flag is an integer"
  category: module_constants
  kind: python_call_eq
  function: daylight.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ checks
# ---------------------------------------------------------------------------

table time_extra2.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [gmtime,        gmtime.__name__.__eq__,        ["gmtime"],        true]
    - [localtime,     localtime.__name__.__eq__,      ["localtime"],     true]
    - [mktime,        mktime.__name__.__eq__,         ["mktime"],        true]
    - [strftime,      strftime.__name__.__eq__,       ["strftime"],      true]
    - [strptime,      strptime.__name__.__eq__,       ["strptime"],      true]
    - [monotonic,     monotonic.__name__.__eq__,      ["monotonic"],     true]
    - [perf_counter,  perf_counter.__name__.__eq__,   ["perf_counter"],  true]
    - [process_time,  process_time.__name__.__eq__,   ["process_time"],  true]
