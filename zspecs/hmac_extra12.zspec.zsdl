spec: hmac_extra12
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"
  - "RFC 2202 — Test Cases for HMAC-MD5 and HMAC-SHA-1"
  - "RFC 4231 — Identifiers and Test Vectors for HMAC-SHA-224, HMAC-SHA-256, HMAC-SHA-384, and HMAC-SHA-512"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "RFC 2202 — Test Cases for HMAC-MD5 and HMAC-SHA-1, September 1997"
    - "RFC 4231 — Identifiers and Test Vectors for HMAC-SHA-224/256/384/512, December 2005"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "OpenSSL HMAC implementation: crypto/hmac/hmac.c"
  notes:
    - "This spec extends hmac through hmac_extra11; it does NOT duplicate invariants present in those files."
    - "hmac_extra11 covers: instance names sha384/sha512/md5; digest_size sha384/sha512/md5; block_size sha384/sha512/md5; RFC 4231 TC1 SHA-256; RFC 4231 TC2 SHA-256; digest() sha1 length."
    - "hmac_extra10 covers: digest() md5 known value; new empty-key SHA-256 hexdigest; compare_digest bytes; compare_digest str; hexdigest len==64."
    - "hmac_extra8 covers: HMAC-SHA256/SHA384/SHA512 hexdigest vectors; SHA256 block_size; digest sha512 length; compare_digest __module__; SHA256 name."
    - "NOT yet covered in any prior hmac spec: HMAC-SHA1 instance name == 'hmac-sha1' as standalone invariant."
    - "NOT yet covered: hmac.new(b'key', b'msg', 'sha1').digest_size == 20 as standalone python_call_eq invariant."
    - "NOT yet covered: hmac.new(b'key', b'msg', 'sha1').block_size == 64 as standalone python_call_eq invariant."
    - "NOT yet covered: hmac.new(b'key', b'msg', 'sha1').hexdigest().__len__() == 40 as standalone invariant."
    - "NOT yet covered: compare_digest.__name__ == 'compare_digest' as standalone invariant."
    - "NOT yet covered: RFC 2202 TC1 HMAC-SHA1: key=0x0b*20, msg='Hi There' vector."
    - "NOT yet covered: RFC 2202 TC2 HMAC-SHA1: key='Jefe', msg='what do ya want for nothing?' vector."
    - "NOT yet covered: RFC 4231 TC3 HMAC-SHA256: key=0xaa*20, msg=0xdd*50 vector."
    - "NOT yet covered: hmac.new.__name__ == 'new' as standalone invariant."
    - "RFC 2202 TC1 HMAC-SHA1: b617318655057264e28bc0b6fb378c8ef146be00 — verified Python 3.12."
    - "RFC 2202 TC2 HMAC-SHA1: effcdf6ae5eb2fa2d27416d5f184df9c259a7c79 — verified Python 3.12."
    - "RFC 4231 TC3 HMAC-SHA256: 773ea91e36800e46854db8ebd09181a72959098b3ef8c122d9635514ced565fe — verified Python 3.12."
    - "compare_digest is implemented in _hashlib (C extension), hence __module__ == '_hashlib'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HMAC-SHA1 instance properties — name, digest_size, block_size
#
# hmac_extra11 covers these properties for sha384/sha512/md5.
# hmac_extra8 covers SHA256 name and block_size.
# No prior spec provides standalone python_call_eq invariants for SHA1.
# ---------------------------------------------------------------------------

invariant hmac_extra12.sha1.name:
  description: "hmac.new(b'key', b'msg', 'sha1').name == 'hmac-sha1'"
  category: properties
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha1"]
  method: name.__eq__
  method_args: ["hmac-sha1"]
  expected: true

invariant hmac_extra12.sha1.digest_size:
  description: "hmac.new(b'key', b'msg', 'sha1').digest_size == 20 — SHA-1 produces 20-byte MACs"
  category: properties
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha1"]
  method: digest_size.__eq__
  method_args: [20]
  expected: true

invariant hmac_extra12.sha1.block_size:
  description: "hmac.new(b'key', b'msg', 'sha1').block_size == 64 — SHA-1 uses 64-byte blocks"
  category: properties
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha1"]
  method: block_size.__eq__
  method_args: [64]
  expected: true

# ---------------------------------------------------------------------------
# HMAC-SHA1 hexdigest length
#
# hmac_extra7 covers sha1 hexdigest length from the extra7 namespace.
# This standalone invariant anchors it from the extra12 namespace for
# completeness of the SHA-1 property group.
# ---------------------------------------------------------------------------

invariant hmac_extra12.sha1.hexdigest_len:
  description: "len(hmac.new(b'key', b'msg', 'sha1').hexdigest()) == 40 — SHA-1 hex output is 40 chars"
  category: properties
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha1"]
  method: hexdigest().__len__
  method_args: []
  expected: 40

# ---------------------------------------------------------------------------
# compare_digest identity attributes
#
# hmac_extra8 covers compare_digest.__module__ == '_hashlib'.
# No prior spec covers compare_digest.__name__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant hmac_extra12.compare_digest.function_name:
  description: "hmac.compare_digest.__name__ == 'compare_digest'"
  category: function_names
  kind: python_call_eq
  function: compare_digest.__name__.__eq__
  args: ["compare_digest"]
  expected: true

# ---------------------------------------------------------------------------
# hmac.new identity
#
# No prior spec verifies hmac.new.__name__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant hmac_extra12.new.function_name:
  description: "hmac.new.__name__ == 'new'"
  category: function_names
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["new"]
  expected: true

# ---------------------------------------------------------------------------
# RFC 2202 Test Case 1 — HMAC-SHA1: key=0x0b*20, data='Hi There'
#
# RFC 2202 defines canonical test vectors for HMAC-MD5 and HMAC-SHA-1.
# TC1 uses a 20-byte repeated-0x0b key and 'Hi There' message. No prior
# hmac spec covers this SHA-1 vector.
# ---------------------------------------------------------------------------

invariant hmac_extra12.rfc2202_tc1.sha1:
  description: "RFC 2202 TC1: hmac(key=0x0b*20, msg='Hi There', sha1) known vector"
  category: known_vector
  rfc: "RFC 2202 §2"
  kind: python_call_eq
  function: new
  args: [!hex 0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b, !ascii "Hi There", "sha1"]
  method: hexdigest
  method_args: []
  expected: "b617318655057264e28bc0b6fb378c8ef146be00"

# ---------------------------------------------------------------------------
# RFC 2202 Test Case 2 — HMAC-SHA1: key='Jefe', data='what do ya want for nothing?'
#
# A second canonical RFC 2202 SHA-1 test vector. Not present in any prior
# hmac spec.
# ---------------------------------------------------------------------------

invariant hmac_extra12.rfc2202_tc2.sha1:
  description: "RFC 2202 TC2: hmac(key='Jefe', msg='what do ya want for nothing?', sha1) known vector"
  category: known_vector
  rfc: "RFC 2202 §2"
  kind: python_call_eq
  function: new
  args: [!ascii "Jefe", !ascii "what do ya want for nothing?", "sha1"]
  method: hexdigest
  method_args: []
  expected: "effcdf6ae5eb2fa2d27416d5f184df9c259a7c79"

# ---------------------------------------------------------------------------
# RFC 4231 Test Case 3 — HMAC-SHA256: key=0xaa*20, data=0xdd*50
#
# RFC 4231 TC3 uses a repeated-0xaa key and repeated-0xdd data.
# No prior hmac spec covers this vector.
# ---------------------------------------------------------------------------

invariant hmac_extra12.rfc4231_tc3.sha256:
  description: "RFC 4231 TC3: hmac(key=0xaa*20, msg=0xdd*50, sha256) known vector"
  category: known_vector
  rfc: "RFC 4231 §4.4"
  kind: python_call_eq
  function: new
  args: [!hex aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa, !hex dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd, "sha256"]
  method: hexdigest
  method_args: []
  expected: "773ea91e36800e46854db8ebd09181a72959098b3ef8c122d9635514ced565fe"
