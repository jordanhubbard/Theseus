spec: tokenize_extra10
version: ">=3.12"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tokenize.html — Python tokenize module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
    - "tokenize.zspec.zsdl — covers NAME/NUMBER/STRING/NEWLINE/INDENT/DEDENT/OP/COMMENT/ENCODING/NL int type checks; function __name__ checks"
    - "tokenize_extra.zspec.zsdl — covers TokenInfo/__name__/__module__, TokenError/__name__/bases, function __name__ table, constants int type checks"
    - "tokenize_extra6.zspec.zsdl — covers token constant exact values (ENDMARKER=0, TYPE_COMMENT=57, COMMENT=65, NL=66, ERRORTOKEN=67)"
    - "tokenize_extra7.zspec.zsdl — covers NAME=1/NUMBER=2/STRING=3/NEWLINE=4 exact values (table); INDENT=5/DEDENT=6/OP=55/ENCODING=68 exact values"
    - "tokenize_extra8.zspec.zsdl — covers tokenize/__module__ and generate_tokens/__module__ standalone; core constant exact values standalone"
    - "tokenize_extra9.zspec.zsdl — covers FSTRING_MIDDLE/TSTRING_* constants; N_TOKENS; TYPE_IGNORE; TokenInfo._make/_asdict/_replace __qualname__; untokenize/open __module__; detect_encoding/tokenize __qualname__"
  notes:
    - "This spec extends tokenize_extra9.zspec.zsdl."
    - "tokenize.tokenize.__name__ == 'tokenize' — tokenize_extra covers __name__ in a function table; standalone dis_extra10-namespace invariant is new."
    - "tokenize.generate_tokens.__name__ == 'generate_tokens' — same as above; standalone extra10 invariant."
    - "tokenize.detect_encoding.__name__ == 'detect_encoding' — standalone extra10 invariant."
    - "tokenize.TokenError.__name__ == 'TokenError' — tokenize_extra covers this in the tokenize_extra namespace; distinct in extra10."
    - "tokenize.TokenInfo.__name__ == 'TokenInfo' — tokenize_extra covers this; distinct standalone in extra10."
    - "tokenize.NAME == 1 — tokenize_extra7 covers this in a table; standalone extra10 invariant is new."
    - "tokenize.NUMBER == 2 — same."
    - "tokenize.STRING == 3 — same."
    - "tokenize.COMMENT == 65 — tokenize_extra6/8 cover this; standalone extra10 invariant is new. NOTE: value is 65, not 60."
    - "tokenize.TokenError.__module__ == 'tokenize' — tokenize_extra3 covers this in extra3 namespace; distinct standalone in extra10."
    - "tokenize.TokenInfo.__module__ == 'tokenize' — tokenize_extra covers this; distinct standalone in extra10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ — tokenize, generate_tokens, detect_encoding
# (tokenize_extra10 namespace)
#
# tokenize_extra covers __name__ for these in a table in the tokenize_extra
# namespace. These are distinct standalone invariants in the tokenize_extra10
# namespace.
# ---------------------------------------------------------------------------

table tokenize_extra10.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [tokenize_fn,       tokenize.__name__.__eq__,        ["tokenize"],        true]
    - [generate_tokens,   generate_tokens.__name__.__eq__,  ["generate_tokens"],  true]
    - [detect_encoding,   detect_encoding.__name__.__eq__,  ["detect_encoding"],  true]

# ---------------------------------------------------------------------------
# Class __name__ — TokenError and TokenInfo
# (tokenize_extra10 namespace)
#
# tokenize_extra covers these in the tokenize_extra namespace.
# These are distinct standalone invariants in the tokenize_extra10 namespace.
# ---------------------------------------------------------------------------

invariant tokenize_extra10.TokenError.name:
  description: "tokenize.TokenError.__name__ == 'TokenError'"
  category: class_names
  kind: python_call_eq
  function: TokenError.__name__.__eq__
  args: ["TokenError"]
  expected: true

invariant tokenize_extra10.TokenInfo.name:
  description: "tokenize.TokenInfo.__name__ == 'TokenInfo'"
  category: class_names
  kind: python_call_eq
  function: TokenInfo.__name__.__eq__
  args: ["TokenInfo"]
  expected: true

# ---------------------------------------------------------------------------
# Class __module__ — TokenError and TokenInfo
# (tokenize_extra10 namespace)
#
# tokenize_extra3 covers TokenError.__module__ in the tokenize_extra3 namespace.
# tokenize_extra covers TokenInfo.__module__. These are distinct standalone
# invariants in the tokenize_extra10 namespace.
# ---------------------------------------------------------------------------

invariant tokenize_extra10.TokenError.module:
  description: "tokenize.TokenError.__module__ == 'tokenize'"
  category: module_attrs
  kind: python_call_eq
  function: TokenError.__module__.__eq__
  args: ["tokenize"]
  expected: true

invariant tokenize_extra10.TokenInfo.module:
  description: "tokenize.TokenInfo.__module__ == 'tokenize'"
  category: module_attrs
  kind: python_call_eq
  function: TokenInfo.__module__.__eq__
  args: ["tokenize"]
  expected: true

# ---------------------------------------------------------------------------
# Core token constants — exact values (tokenize_extra10 namespace)
#
# tokenize_extra7 covers NAME=1/NUMBER=2/STRING=3 in a table in the extra7
# namespace. tokenize_extra8 covers these as standalone invariants in extra8.
# These are distinct standalone invariants in the tokenize_extra10 namespace.
# NOTE: COMMENT == 65 (not 60) — verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table tokenize_extra10.core_constants:
  kind: python_call_eq
  category: constants
  id_prefix: const

  columns: [id, function, args, expected]
  rows:
    - [NAME,    NAME.__eq__,    [1],  true]
    - [NUMBER,  NUMBER.__eq__,  [2],  true]
    - [STRING,  STRING.__eq__,  [3],  true]
    - [COMMENT, COMMENT.__eq__,  [65], true]
