spec: ab3496
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 680 (ab3496): __aenter__, __aexit__, __await__ dict-presence checks for abc module types."
    - "Theme: __aenter__/__aexit__/__await__ dict-presence (async protocols)."
    - "All values False — abc types are abstract base class machinery with no async protocol support defined in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: abc.ABC, abc.ABCMeta, and type(abc.abstractmethod(lambda: None)) — the built-in function type."
    - "Key finding (__aenter__): all 3 abc subjects return false for __aenter__. abc.ABC is a pure abstract base class convenience wrapper with no __aenter__ in its own __dict__. abc.ABCMeta is a metaclass focused on abstract method tracking and virtual subclass registration; async context manager usage is not part of ABCMeta's responsibility. The function type does not define __aenter__ in its own __dict__ — functions are callables and descriptors, not async context managers."
    - "Key finding (__aexit__): all 3 abc subjects return false for __aexit__. abc.ABC: no __aexit__ in its own __dict__. abc.ABCMeta: does not define __aexit__ in ABCMeta.__dict__. The function type: functions define no __aexit__ in their own __dict__."
    - "Key finding (__await__): all 3 abc subjects return false for __await__. abc.ABC: no __await__ in its own __dict__. abc.ABCMeta: a metaclass with no awaitable protocol defined. The function type: regular functions are not awaitable — only coroutine functions (defined with 'async def') return awaitables. A plain function (including abc.abstractmethod-decorated lambdas) does not define __await__ in its own __dict__."
    - "abc.ABCMeta has now returned false for every dunder tested across 29 consecutive waves (652–680). Its entire capability is expressed through class-hierarchy machinery — not operator overloading, comparison, display, iteration, sizing, context manager, callable, or async protocol overrides."
    - "Cross-wave summary for abc subjects:"
    - "  Wave 652 (ab3076): __get__ true for function type; __set__/__delete__ false."
    - "  Wave 653 (ab3091): __hash__/__eq__/__bool__ all false for all 3."
    - "  Wave 654 (ab3106): __lt__/__le__/__gt__ all false for all 3."
    - "  Wave 655 (ab3121): __ge__ false; __repr__ true for function type only; __str__ false."
    - "  Wave 656 (ab3136): __call__ true for function type only; __len__/__getitem__ false."
    - "  Wave 657 (ab3151): __setitem__/__delitem__/__contains__ — all false for all 3."
    - "  Wave 658 (ab3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (ab3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (ab3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (ab3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (ab3226): __radd__/__rsub__/__rmul__ — all false for all 3."
    - "  Wave 663 (ab3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 3."
    - "  Wave 664 (ab3256): __rpow__/__rlshift__/__rrshift__ — all false for all 3."
    - "  Wave 665 (ab3271): __rand__/__ror__/__rxor__ — all false for all 3."
    - "  Wave 666 (ab3286): __iadd__/__isub__/__imul__ — all false for all 3."
    - "  Wave 667 (ab3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 3."
    - "  Wave 668 (ab3316): __ipow__/__ilshift__/__irshift__ — all false for all 3."
    - "  Wave 669 (ab3331): __iand__/__ior__/__ixor__ — all false for all 3."
    - "  Wave 670 (ab3346): __neg__/__pos__/__abs__ — all false for all 3."
    - "  Wave 671 (ab3361): __invert__/__floor__/__ceil__ — all false for all 3."
    - "  Wave 672 (ab3376): __trunc__/__round__/__index__ — all false for all 3."
    - "  Wave 673 (ab3391): __int__/__float__/__complex__ — all false for all 3."
    - "  Wave 674 (ab3406): __bool__/__str__/__repr__ — all false for all 3."
    - "  Wave 675 (ab3421): __hash__/__eq__/__lt__ — all false for all 3."
    - "  Wave 676 (ab3436): __le__/__gt__/__ge__ — all false for all 3."
    - "  Wave 677 (ab3451): __getitem__/__setitem__/__delitem__ — all false for all 3."
    - "  Wave 678 (ab3466): __iter__/__next__/__len__ — all false for all 3."
    - "  Wave 679 (ab3481): __enter__/__exit__/__call__ — all false for all 3."
    - "  Wave 680 (ab3496): __aenter__/__aexit__/__await__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __aenter__ dict-presence — operator.contains(Cls.__dict__, '__aenter__')
#
# All 3 abc subjects return false for __aenter__.
# abc.ABC: a plain abstract base class convenience wrapper with no __aenter__
#   in its own __dict__. 'async with ABC():' raises AttributeError since neither
#   ABC nor object provides __aenter__.
# abc.ABCMeta: a metaclass for abstract method tracking and virtual subclass
#   registration. __aenter__ is absent from ABCMeta.__dict__ — the metaclass
#   API (__subclasshook__, register(), __abstractmethods__) has no async context
#   manager component.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   regular functions do not define __aenter__ in their own __dict__. Functions
#   are callables and descriptors; the async context manager protocol is not
#   defined for the function type.
# ---------------------------------------------------------------------------

table ab3496.aenter:
  description: "abc types __aenter__ dict-presence checks; wave 680"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3496

  columns: [id, function, args, expected]
  rows:
    - ["ab3496001", operator.contains, [abc.ABC.__dict__,                                 "__aenter__"], false]
    - ["ab3496002", operator.contains, [abc.ABCMeta.__dict__,                             "__aenter__"], false]
    - ["ab3496003", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__aenter__"], false]

# ---------------------------------------------------------------------------
# __aexit__ dict-presence — operator.contains(Cls.__dict__, '__aexit__')
#
# All 3 abc subjects return false for __aexit__.
# abc.ABC: no __aexit__ in its own __dict__; the async context manager exit
#   protocol is not defined for abc.ABC.
# abc.ABCMeta: does not define __aexit__ in ABCMeta.__dict__. The metaclass
#   is focused on abstract method registration and subclass checking, not
#   async lifecycle management.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   functions do not define __aexit__ in their own __dict__. Functions are
#   callables and descriptors; the async context manager protocol is not
#   defined for the function type.
# ---------------------------------------------------------------------------

table ab3496.aexit:
  description: "abc types __aexit__ dict-presence checks; wave 680"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3496

  columns: [id, function, args, expected]
  rows:
    - ["ab3496004", operator.contains, [abc.ABC.__dict__,                                 "__aexit__"], false]
    - ["ab3496005", operator.contains, [abc.ABCMeta.__dict__,                             "__aexit__"], false]
    - ["ab3496006", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__aexit__"], false]

# ---------------------------------------------------------------------------
# __await__ dict-presence — operator.contains(Cls.__dict__, '__await__')
#
# All 3 abc subjects return false for __await__.
# abc.ABC: no __await__ in its own __dict__. abc.ABC instances are not awaitable.
# abc.ABCMeta: does not define __await__ in ABCMeta.__dict__. Metaclasses are
#   not awaitable objects; ABCMeta has no coroutine-related functionality.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   regular functions (including abstractmethod-decorated ones) are not awaitable.
#   Only coroutine functions defined with 'async def' return awaitables.
#   The plain function type does not define __await__ in its own __dict__.
# ---------------------------------------------------------------------------

table ab3496.await:
  description: "abc types __await__ dict-presence checks; wave 680"
  kind: python_call_eq
  version: ">=3.9"
