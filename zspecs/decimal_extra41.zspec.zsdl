spec: decimal_extra41
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra40.zspec.zsdl — covers Context/Decimal/DecimalException/InvalidOperation/DivisionByZero/Overflow/Underflow/Inexact/Rounded __qualname__.__len__()."
    - "decimal_extra39.zspec.zsdl — covers Context/Decimal/DecimalException/InvalidOperation/DivisionByZero/Overflow/Underflow/Inexact/Rounded __qualname__.__eq__() (string equality)."
    - "decimal_extra38.zspec.zsdl — covers Rounded/Subnormal/Clamped/FloatOperation __module__=='decimal'; Decimal/__bases__[0].__name__=='object'; Decimal/__mro__.__len__()==2; Context/__name__/__module__/__bases__[0].__name__."
    - "decimal_extra37.zspec.zsdl — covers Rounded/Subnormal/Clamped/FloatOperation __name__."
    - "decimal_extra20.zspec.zsdl — covers ROUND_UP/ROUND_DOWN/ROUND_HALF_EVEN __len__() and all ROUND_* constants __len__()."
    - "decimal_extra.zspec.zsdl — covers ROUND_HALF_UP/ROUND_HALF_DOWN/ROUND_CEILING/ROUND_FLOOR string equality."
  notes:
    - "This spec extends decimal_extra40.zspec.zsdl."
    - "Prior specs collectively covered: all nine main decimal class __qualname__.__eq__() (decimal_extra39: Context/Decimal/DecimalException/InvalidOperation/DivisionByZero/Overflow/Underflow/Inexact/Rounded); all nine __qualname__.__len__() (decimal_extra40 — same nine classes); Rounded/Subnormal/Clamped/FloatOperation __name__ (decimal_extra37) and __module__ (decimal_extra38); all ROUND_* constant string equality and __len__() values; all ROUND_* __class__.__name__=='str'. The classes Subnormal, Clamped, and FloatOperation were NOT included in decimal_extra39 or decimal_extra40 — their __qualname__.__eq__() and __qualname__.__len__() are unchecked in those specs."
    - "This spec covers: decimal.Subnormal.__qualname__.__eq__('Subnormal') (NOVEL — decimal_extra39 covers nine classes but NOT Subnormal; decimal_extra37 covers Subnormal.__name__ but not __qualname__; novel equality anchor in decimal_extra41 namespace); decimal.Clamped.__qualname__.__eq__('Clamped') (NOVEL — decimal_extra39 omits Clamped; novel); decimal.FloatOperation.__qualname__.__eq__('FloatOperation') (NOVEL — decimal_extra39 omits FloatOperation; novel); decimal.Subnormal.__qualname__.__len__()==9 (NOVEL — decimal_extra40 covers nine classes but NOT Subnormal.__qualname__.__len__(); novel length anchor); decimal.Clamped.__qualname__.__len__()==7 (NOVEL); decimal.FloatOperation.__qualname__.__len__()==14 (NOVEL); decimal.FloatOperation.__bases__.__len__()==2 (NOVEL — FloatOperation uniquely inherits from both DecimalException and TypeError, giving 2 direct bases; no prior decimal spec checks FloatOperation.__bases__.__len__(); novel multiple-inheritance count); decimal.FloatOperation.__mro__.__len__()==7 (NOVEL — FloatOperation's MRO is [FloatOperation, DecimalException, ArithmeticError, TypeError, Exception, BaseException, object] — 7 entries due to TypeError merging; no prior decimal spec checks FloatOperation.__mro__.__len__())."
    - "decimal.Subnormal.__qualname__ == 'Subnormal'. Subnormal is a DecimalException subclass signaling that a subnormal result was produced. decimal_extra37 covers Subnormal.__name__; decimal_extra38 covers Subnormal.__module__; decimal_extra39 covers 9 classes but omits Subnormal.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Clamped.__qualname__ == 'Clamped'. Clamped is a DecimalException subclass signaling that an exponent was clamped to the context's emin/emax limits. decimal_extra39 omits Clamped.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.FloatOperation.__qualname__ == 'FloatOperation'. FloatOperation is a DecimalException/TypeError subclass signaling that a float was mixed with Decimal arithmetic. decimal_extra39 omits FloatOperation.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Subnormal.__qualname__.__len__() == 9. 'Subnormal' has 9 characters. decimal_extra40 covers nine classes but omits Subnormal. Novel length anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Clamped.__qualname__.__len__() == 7. 'Clamped' has 7 characters. decimal_extra40 omits Clamped. Novel length anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.FloatOperation.__qualname__.__len__() == 14. 'FloatOperation' has 14 characters. decimal_extra40 omits FloatOperation. Novel length anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.FloatOperation.__bases__.__len__() == 2. FloatOperation is unique in the decimal module: it inherits from both DecimalException AND TypeError. Its MRO merges the exception hierarchy with TypeError's hierarchy: [FloatOperation, DecimalException, ArithmeticError, TypeError, Exception, BaseException, object] (7 entries). No prior decimal spec checks FloatOperation.__bases__.__len__() or the 7-entry MRO length. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Subnormal, Clamped, FloatOperation __qualname__ attributes
#
# These three exception subclasses were covered in decimal_extra37 (__name__)
# and decimal_extra38 (__module__), but were OMITTED from the nine-class
# __qualname__ table in decimal_extra39. All three are defined at module scope
# in the decimal module, so their __qualname__ equals their bare class name.
#
#   Subnormal.__qualname__    == 'Subnormal'      (9 chars)
#   Clamped.__qualname__      == 'Clamped'        (7 chars)
#   FloatOperation.__qualname__== 'FloatOperation' (14 chars)
#
# All three __qualname__.__eq__() values are novel equality anchors in the
# decimal_extra41 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra41.remaining_class_qualnames:
  description: "decimal Subnormal/Clamped/FloatOperation __qualname__.__eq__() — these three classes were omitted from the nine-class table in decimal_extra39; decimal_extra37 covers their __name__; all three are novel __qualname__ equality anchors in decimal_extra41 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: drcq41

  columns: [id, function, args, expected]
  rows:
    - [Subnormal_qualname,      Subnormal.__qualname__.__eq__,      ["Subnormal"],      true]
    - [Clamped_qualname,        Clamped.__qualname__.__eq__,        ["Clamped"],        true]
    - [FloatOperation_qualname, FloatOperation.__qualname__.__eq__, ["FloatOperation"], true]

# ---------------------------------------------------------------------------
# decimal.Subnormal, Clamped, FloatOperation __qualname__.__len__() values
#
# The length of each class's __qualname__ string equals the length of its
# bare class name, since all three are defined at module scope.
#
#   Subnormal.__qualname__.__len__()    == 9   ('Subnormal')
#   Clamped.__qualname__.__len__()      == 7   ('Clamped')
#   FloatOperation.__qualname__.__len__()== 14  ('FloatOperation')
#
# decimal_extra40 covers nine classes but omits Subnormal/Clamped/FloatOperation.
# All three are novel length anchors in the decimal_extra41 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra41.remaining_class_qualname_lengths:
  description: "decimal Subnormal(9)/Clamped(7)/FloatOperation(14) __qualname__.__len__() — these three were omitted from the nine-class length table in decimal_extra40; all three novel length anchors in decimal_extra41 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: drcql41

  columns: [id, function, args, expected]
  rows:
    - [Subnormal_qualname_len,      Subnormal.__qualname__.__len__,      [], 9]
    - [Clamped_qualname_len,        Clamped.__qualname__.__len__,        [], 7]
    - [FloatOperation_qualname_len, FloatOperation.__qualname__.__len__, [], 14]

# ---------------------------------------------------------------------------
# decimal.FloatOperation multiple inheritance attributes
#
# FloatOperation is unique in the decimal module: it has TWO direct base
# classes (multiple inheritance). It is simultaneously a DecimalException
# and a TypeError, making it catchable by either handler.
#
#   FloatOperation.__bases__.__len__()  == 2
#     direct bases: [DecimalException, TypeError]
#
#   FloatOperation.__mro__.__len__()    == 7
#     MRO: [FloatOperation, DecimalException, ArithmeticError,
#           TypeError, Exception, BaseException, object]
#
# The 7-entry MRO is longer than the 6-entry MRO for Subnormal/Clamped
# because Python's C3 linearization must merge DecimalException's chain
# with TypeError's chain.
#
# No prior decimal spec checks FloatOperation.__bases__.__len__() or
# FloatOperation.__mro__.__len__(). Both are novel invariants in the
# decimal_extra41 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant decimal_extra41.FloatOperation_bases_len:
  description: "decimal.FloatOperation.__bases__.__len__() == 2 — FloatOperation uniquely inherits from both DecimalException and TypeError; no prior decimal spec checks FloatOperation.__bases__.__len__(); novel multiple-inheritance count in decimal_extra41 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_structure
  kind: python_call_eq
  function: "FloatOperation.__bases__.__len__"
  args: []
  expected: 2

invariant decimal_extra41.FloatOperation_mro_len:
  description: "decimal.FloatOperation.__mro__.__len__() == 7 — MRO is [FloatOperation, DecimalException, ArithmeticError, TypeError, Exception, BaseException, object]; 7 entries due to merging DecimalException and TypeError chains; no prior decimal spec checks FloatOperation.__mro__.__len__(); novel in decimal_extra41 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_structure
  kind: python_call_eq
  function: FloatOperation.__mro__.__len__
  args: []
  expected: 7
