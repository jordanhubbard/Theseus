spec: abc_extra204
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py (frozen as <frozen abc>)"
  notes:
    - "abc.abstractmethod.__annotations__.__class__.__name__ == 'dict' — annotations is always a plain dict; abc.abstractmethod has no type annotations on Python 3.14.3, so the dict is empty ({}) but its class is 'dict'."
    - "abc.ABCMeta.__dict__.__contains__('__subclasshook__') returns False — __subclasshook__ is NOT in ABCMeta.__dict__; it is typically defined as a classmethod on user-defined ABC subclasses, not on ABCMeta itself."
    - "abc.ABCMeta.__dict__.__contains__('_dump_registry') returns True — _dump_registry() is a debugging method defined directly on ABCMeta; it prints the virtual subclass registry for a class."
    - "abc.ABCMeta.__dict__.__contains__('_abc_registry') returns False — _abc_registry is NOT in ABCMeta.__dict__; the registry data is stored in the C-level _abc_impl object on each class instance, not as a class-level attribute on ABCMeta."
    - "abc.ABC.__dict__.__contains__('__subclasshook__') returns False — __subclasshook__ is NOT in ABC.__dict__; it is defined by user subclasses to customise issubclass behaviour, but ABC itself does not define it."
    - "abc.ABCMeta.__dict__ keys on Python 3.14.3: __module__, __firstlineno__, __doc__, __new__, register, __instancecheck__, __subclasscheck__, _dump_registry, _abc_registry_clear, _abc_caches_clear, __static_attributes__."
    - "abc.ABC.__dict__ keys on Python 3.14.3: __module__, __firstlineno__, __doc__, __slots__, __static_attributes__, __abstractmethods__, _abc_impl."
    - "abc.ABC.__dict__ contains exactly 7 entries; __dict__.__len__() == 7."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.abstractmethod __annotations__ class name and len checks
#
# abc.abstractmethod.__annotations__.__class__.__name__  == 'dict'
# abc.abstractmethod.__annotations__.__len__()           == 0
# abc.abstractmethod.__annotations__.__contains__('return') == False
# abc.abstractmethod.__annotations__.__contains__('funcobj') == False
# ---------------------------------------------------------------------------

table abc_extra204.abstractmethod_annotations:
  description: "abc.abstractmethod __annotations__ class name and membership checks in abcannotations204 namespace — abstractmethod.__annotations__.__class__.__name__=='dict' (annotations is always a plain dict; abc.abstractmethod has no type annotations on Python 3.14.3 so the dict is empty); __len__()==0 (no annotated parameters or return type); __contains__('return')==False (no return annotation); __contains__('funcobj')==False ('funcobj' is the sole parameter of abstractmethod(funcobj) but carries no annotation); abstractmethod sets funcobj.__isabstractmethod__ = True and returns funcobj; verified with Python 3.14.3"
  kind: python_call_eq
  category: annotations
  id_prefix: abcannotations204

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_annotations_class_name,     "abc.abstractmethod.__annotations__.__class__.__name__.__eq__",   ["dict"],      true,  "abc.abstractmethod.__annotations__.__class__.__name__ == 'dict'; verified Python 3.14.3"]
    - [abstractmethod_annotations_len,            "abc.abstractmethod.__annotations__.__len__",                     [],            0,     "abc.abstractmethod.__annotations__.__len__() == 0 (no annotations); verified Python 3.14.3"]
    - [abstractmethod_annotations_no_return,      "abc.abstractmethod.__annotations__.__contains__",                ["return"],    false, "abc.abstractmethod.__annotations__.__contains__('return') == False; verified Python 3.14.3"]
    - [abstractmethod_annotations_no_funcobj,     "abc.abstractmethod.__annotations__.__contains__",                ["funcobj"],   false, "abc.abstractmethod.__annotations__.__contains__('funcobj') == False; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABCMeta.__dict__ membership checks — present and absent
#
# abc.ABCMeta.__dict__.__contains__('__subclasshook__') == False
# abc.ABCMeta.__dict__.__contains__('_dump_registry')   == True
# abc.ABCMeta.__dict__.__contains__('_abc_registry')    == False
# abc.ABCMeta.__dict__.__contains__('_abc_registry_clear') == True
# ---------------------------------------------------------------------------

table abc_extra204.abcmeta_dict_membership:
  description: "abc.ABCMeta.__dict__ membership checks in abcannotations204 namespace — ABCMeta.__dict__.__contains__('__subclasshook__')==False (__subclasshook__ is NOT stored on ABCMeta; it is defined by user-written ABC subclasses to customise issubclass() behaviour; ABCMeta itself does not define it); ABCMeta.__dict__.__contains__('_dump_registry')==True (_dump_registry() is a debugging utility method defined directly on ABCMeta; it dumps the virtual subclass registry to stdout); ABCMeta.__dict__.__contains__('_abc_registry')==False (_abc_registry is not a class attribute on ABCMeta; registry data lives in _abc_impl on individual class objects); ABCMeta.__dict__.__contains__('_abc_registry_clear')==True (_abc_registry_clear() is a testing utility defined on ABCMeta to clear the virtual subclass registry); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: abcannotations204a

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_dict_no_subclasshook,      "abc.ABCMeta.__dict__.__contains__",   ["__subclasshook__"],    false, "abc.ABCMeta.__dict__.__contains__('__subclasshook__') == False; verified Python 3.14.3"]
    - [abcmeta_dict_has_dump_registry,    "abc.ABCMeta.__dict__.__contains__",   ["_dump_registry"],      true,  "abc.ABCMeta.__dict__.__contains__('_dump_registry') == True; verified Python 3.14.3"]
    - [abcmeta_dict_no_abc_registry,      "abc.ABCMeta.__dict__.__contains__",   ["_abc_registry"],       false, "abc.ABCMeta.__dict__.__contains__('_abc_registry') == False; verified Python 3.14.3"]
    - [abcmeta_dict_has_registry_clear,   "abc.ABCMeta.__dict__.__contains__",   ["_abc_registry_clear"], true,  "abc.ABCMeta.__dict__.__contains__('_abc_registry_clear') == True; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: abc.ABC.__dict__ membership checks
#
# abc.ABC.__dict__.__contains__('__subclasshook__')   == False
# abc.ABC.__dict__.__contains__('_abc_impl')          == True
# abc.ABC.__dict__.__contains__('__abstractmethods__') == True
# abc.ABC.__dict__.__len__()                           == 7
# ---------------------------------------------------------------------------

table abc_extra204.abc_dict_membership:
  description: "abc.ABC.__dict__ membership checks in abcannotations204 namespace — ABC.__dict__.__contains__('__subclasshook__')==False (__subclasshook__ is NOT stored in ABC.__dict__; user subclasses define it as a classmethod to customise issubclass() behaviour, but the base ABC class does not define it); ABC.__dict__.__contains__('_abc_impl')==True (_abc_impl is the C-level ABCData object installed by ABCMeta.__new__; it stores the virtual subclass registry and cache); ABC.__dict__.__contains__('__abstractmethods__')==True (__abstractmethods__ is an empty frozenset() stored in ABC.__dict__; ABCMeta installs it for every class created with ABCMeta); ABC.__dict__.__len__()==7 (exactly 7 entries: __module__, __firstlineno__, __doc__, __slots__, __static_attributes__, __abstractmethods__, _abc_impl); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: abcannotations204b

  columns: [id, function, args, expected, description]
  rows:
    - [abc_dict_no_subclasshook,        "abc.ABC.__dict__.__contains__",   ["__subclasshook__"],    false, "abc.ABC.__dict__.__contains__('__subclasshook__') == False; verified Python 3.14.3"]
    - [abc_dict_has_abc_impl,           "abc.ABC.__dict__.__contains__",   ["_abc_impl"],           true,  "abc.ABC.__dict__.__contains__('_abc_impl') == True; verified Python 3.14.3"]
    - [abc_dict_has_abstractmethods,    "abc.ABC.__dict__.__contains__",   ["__abstractmethods__"], true,  "abc.ABC.__dict__.__contains__('__abstractmethods__') == True; verified Python 3.14.3"]
    - [abc_dict_len,                    "abc.ABC.__dict__.__len__",        [],                      7,     "abc.ABC.__dict__.__len__() == 7 (exact count of ABC.__dict__ entries); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra204
# ---------------------------------------------------------------------------

invariant abc_extra204.abstractmethod_annotations_class_name_dict:
  description: "abc.abstractmethod.__annotations__.__class__.__name__.__eq__('dict') returns True — abc.abstractmethod.__annotations__ is a plain dict; on Python 3.14.3 abc.abstractmethod carries no PEP-3107 type annotations so the dict is empty ({}), but __annotations__.__class__.__name__ is 'dict' (len=4: d-i-c-t); __annotations__ is always a dict even when empty; NEW in extra204: first standalone abc.abstractmethod annotations class name invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: annotations
  kind: python_call_eq
  function: abc.abstractmethod.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant abc_extra204.abstractmethod_annotations_len_zero:
  description: "abc.abstractmethod.__annotations__.__len__() returns 0 — abc.abstractmethod has no type annotations on Python 3.14.3; __annotations__ is an empty dict with length 0; abstractmethod(funcobj) takes one parameter ('funcobj') but it carries no annotation; abstractmethod sets funcobj.__isabstractmethod__ = True and returns funcobj; len==0 confirms the annotations dict is empty; NEW in extra204; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: annotations
  kind: python_call_eq
  function: abc.abstractmethod.__annotations__.__len__
  args: []
  expected: 0

invariant abc_extra204.abcmeta_dict_no_subclasshook:
  description: "abc.ABCMeta.__dict__.__contains__('__subclasshook__') returns False — __subclasshook__ is NOT in ABCMeta.__dict__; __subclasshook__ is a classmethod that user-defined ABC subclasses can define to customise the issubclass() check; it is typically defined by the user as @classmethod def __subclasshook__(cls, C): ...; ABCMeta itself does not define __subclasshook__, so it is absent from ABCMeta.__dict__; similarly, abc.ABC.__dict__ also does not contain '__subclasshook__'; NEW in extra204; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__subclasshook__"]
  expected: false

invariant abc_extra204.abcmeta_dict_has_dump_registry:
  description: "abc.ABCMeta.__dict__.__contains__('_dump_registry') returns True — abc.ABCMeta defines _dump_registry() directly in its class body in the frozen abc module; ABCMeta._dump_registry(cls, file=None) is a debugging utility that dumps the virtual subclass registry for cls to file (default stdout); it prints the class, its subclasses, and registered virtual subclasses; '_dump_registry' is in ABCMeta.__dict__ (not inherited); NEW in extra204; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["_dump_registry"]
  expected: true

invariant abc_extra204.abcmeta_dict_no_abc_registry:
  description: "abc.ABCMeta.__dict__.__contains__('_abc_registry') returns False — _abc_registry is NOT an attribute defined on the ABCMeta class; the virtual subclass registry is stored in the C-level _abc_impl object (an ABCData struct) on each individual class created with ABCMeta; ABCMeta itself does not carry a _abc_registry class attribute; in Python 3.4+ the registry was moved from a WeakSet class attribute to the C-level _abc_impl; '_abc_registry' is absent from ABCMeta.__dict__; NEW in extra204; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["_abc_registry"]
  expected: false

invariant abc_extra204.abc_dict_no_subclasshook:
  description: "abc.ABC.__dict__.__contains__('__subclasshook__') returns False — __subclasshook__ is NOT in abc.ABC.__dict__; abc.ABC is a simple helper class (metaclass=ABCMeta) that does not define __subclasshook__; user subclasses that want to customise issubclass() define __subclasshook__ in their own class body; ABC.__dict__ on Python 3.14.3 contains exactly 7 entries: __module__, __firstlineno__, __doc__, __slots__, __static_attributes__, __abstractmethods__, _abc_impl — __subclasshook__ is not among them; NEW in extra204; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: abc.ABC.__dict__.__contains__
  args: ["__subclasshook__"]
  expected: false

invariant abc_extra204.abc_dict_has_abc_impl:
  description: "abc.ABC.__dict__.__contains__('_abc_impl') returns True — abc.ABC.__dict__ contains '_abc_impl'; _abc_impl is the C-level ABCData object installed by ABCMeta.__new__ when the ABC class is created; it stores the virtual subclass registry and the negative/positive lookup caches for isinstance() and issubclass() checks; '_abc_impl' is in ABC.__dict__ along with __abstractmethods__ (an empty frozenset) and __slots__ (an empty tuple); NEW in extra204; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: abc.ABC.__dict__.__contains__
  args: ["_abc_impl"]
  expected: true

invariant abc_extra204.abc_dict_len_seven:
  description: "abc.ABC.__dict__.__len__() returns 7 — abc.ABC.__dict__ contains exactly 7 entries on Python 3.14.3: __module__, __firstlineno__, __doc__, __slots__, __static_attributes__, __abstractmethods__, _abc_impl; this is a compact class with no user-visible methods or data attributes; __slots__=() prevents a per-instance __dict__; __abstractmethods__=frozenset() marks ABC as having no abstract methods; _abc_impl holds the C-level registry; len==7 is an exact count of these entries; NEW in extra204; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: abc.ABC.__dict__.__len__
  args: []
  expected: 7
