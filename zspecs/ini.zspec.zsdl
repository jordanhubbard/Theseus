spec: ini
version: ">=1.0.0"
backend: node(ini)

docs: https://github.com/npm/ini#readme

provenance:
  derived_from:
    - "ini README — https://github.com/npm/ini#readme"
    - "Test vectors verified with ini@6.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "ini source: lib/ini.js"
  notes:
    - "ini exports an object with parse() and stringify() methods."
    - "parse() converts an INI-formatted string to a nested JS object."
    - "stringify() converts a JS object to an INI-formatted string."
    - "Sections become nested objects in the parsed result."
    - "stringify() produces section headers followed by key=value lines with trailing newline."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "parse returns object; stringify returns string. No errors for valid inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table ini.parse:
  kind: node_module_call_eq
  function: parse
  category: parse
  id_prefix: ini_parse

  columns: [id, args, expected]
  rows:
    - [section,  ["[section]\nkey=value\n"],  {"section": {"key": "value"}}]
    - [flat,     ["foo=bar\n"],               {"foo": "bar"}]

table ini.stringify:
  kind: node_module_call_eq
  function: stringify
  category: stringify
  id_prefix: ini_str

  columns: [id, args, expected]
  rows:
    - [section,  [{"section": {"key": "value"}}],  "[section]\nkey=value\n"]
