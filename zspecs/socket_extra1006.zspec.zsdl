spec: socket_extra1006
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __doc__.__class__.__name__ == 'str' for socket class, networking functions, and exception types"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1006.socket_class_docs:
  description: "socket.socket class __doc__ class name checks"
  kind: python_call_eq
  category: socket_class_docs
  id_prefix: sk1006sc
  columns: [id, function, args, expected]
  rows:
    - [sk1006sc001, socket.socket.__doc__.__class__.__name__.__eq__,         ["str"], true]
    - [sk1006sc002, socket.socket.bind.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [sk1006sc003, socket.socket.connect.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sk1006sc004, socket.socket.listen.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [sk1006sc005, socket.socket.accept.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [sk1006sc006, socket.socket.close.__doc__.__class__.__name__.__eq__,   ["str"], true]

table socket_extra1006.network_function_docs:
  description: "socket networking utility function __doc__ class name checks"
  kind: python_call_eq
  category: network_function_docs
  id_prefix: sk1006nf
  columns: [id, function, args, expected]
  rows:
    - [sk1006nf001, socket.getfqdn.__doc__.__class__.__name__.__eq__,       ["str"], true]
    - [sk1006nf002, socket.gethostname.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [sk1006nf003, socket.gethostbyname.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sk1006nf004, socket.getaddrinfo.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [sk1006nf005, socket.getnameinfo.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [sk1006nf006, socket.create_connection.__doc__.__class__.__name__.__eq__, ["str"], true]

table socket_extra1006.exception_docs:
  description: "socket exception type __doc__ class name checks"
  kind: python_call_eq
  category: exception_docs
  id_prefix: sk1006ex
  columns: [id, function, args, expected]
  rows:
    - [sk1006ex001, socket.error.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [sk1006ex002, socket.timeout.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sk1006ex003, socket.herror.__doc__.__class__.__name__.__eq__,  ["str"], true]
