spec: math_extra7
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl and prior extras through math_extra6.zspec.zsdl."
    - "math_extra4 covers __module__ for comb/perm/prod/isqrt only."
    - "No prior spec covers __module__ for sqrt/floor/ceil/trunc/fabs/factorial/gcd/lcm/sin/cos/tan/log/log2/log10/exp/pow."
    - "No prior spec covers the exact IEEE 754 double value of math.e (only bounds)."
    - "math.e == 2.718281828459045 — this is the exact double representation of Euler's number."
    - "For all built-in C functions in the math module, __module__ == 'math'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks — rounding / arithmetic group
#
# math_extra4 covers __module__ for comb/perm/prod/isqrt.
# This table adds the remaining arithmetic/rounding functions.
# ---------------------------------------------------------------------------

table math_extra7.modules_arithmetic:
  kind: python_call_eq
  category: function_modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [sqrt,      sqrt.__module__.__eq__,      ["math"], true]
    - [floor,     floor.__module__.__eq__,     ["math"], true]
    - [ceil,      ceil.__module__.__eq__,      ["math"], true]
    - [trunc,     trunc.__module__.__eq__,     ["math"], true]
    - [fabs,      fabs.__module__.__eq__,      ["math"], true]
    - [factorial, factorial.__module__.__eq__, ["math"], true]
    - [gcd,       gcd.__module__.__eq__,       ["math"], true]
    - [lcm,       lcm.__module__.__eq__,       ["math"], true]

# ---------------------------------------------------------------------------
# __module__ checks — transcendental / trig group
# ---------------------------------------------------------------------------

table math_extra7.modules_transcendental:
  kind: python_call_eq
  category: function_modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [sin,   sin.__module__.__eq__,   ["math"], true]
    - [cos,   cos.__module__.__eq__,   ["math"], true]
    - [tan,   tan.__module__.__eq__,   ["math"], true]
    - [log,   log.__module__.__eq__,   ["math"], true]
    - [log2,  log2.__module__.__eq__,  ["math"], true]
    - [log10, log10.__module__.__eq__, ["math"], true]
    - [exp,   exp.__module__.__eq__,   ["math"], true]
    - [pow,   pow.__module__.__eq__,   ["math"], true]

# ---------------------------------------------------------------------------
# __module__ checks — predicate / utility group
# ---------------------------------------------------------------------------

table math_extra7.modules_predicates:
  kind: python_call_eq
  category: function_modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [isfinite, isfinite.__module__.__eq__, ["math"], true]
    - [isinf,    isinf.__module__.__eq__,    ["math"], true]
    - [isnan,    isnan.__module__.__eq__,    ["math"], true]
    - [isclose,  isclose.__module__.__eq__,  ["math"], true]
    - [hypot,    hypot.__module__.__eq__,    ["math"], true]
    - [degrees,  degrees.__module__.__eq__,  ["math"], true]
    - [radians,  radians.__module__.__eq__,  ["math"], true]

# ---------------------------------------------------------------------------
# math.e — exact IEEE 754 double value
#
# math.zspec.zsdl covers only bounds (e > 2.71 and e < 2.72).
# The exact double representation is 2.718281828459045, which is the value
# Python returns for math.e on all IEEE 754 platforms.
# ---------------------------------------------------------------------------

invariant math_extra7.e.exact_value:
  description: "math.e == 2.718281828459045 — exact IEEE 754 double representation of Euler's number"
  category: constants
  kind: python_call_eq
  function: e.__eq__
  args: [2.718281828459045]
  expected: true

# ---------------------------------------------------------------------------
# math.pi — exact IEEE 754 double value
#
# math.zspec.zsdl covers only bounds (pi > 3.14 and pi < 3.15).
# The exact double representation is 3.141592653589793.
# ---------------------------------------------------------------------------

invariant math_extra7.pi.exact_value:
  description: "math.pi == 3.141592653589793 — exact IEEE 754 double representation of pi"
  category: constants
  kind: python_call_eq
  function: pi.__eq__
  args: [3.141592653589793]
  expected: true
