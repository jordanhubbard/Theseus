spec: io_extra70
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/"
    - "io_extra69.zspec.zsdl — covers BytesIO.__doc__.__contains__('Buffered') and __contains__('I/O') and __len__()==60; StringIO.__doc__.__contains__('Text') and __contains__('I/O') and __len__()==174; FileIO.__doc__.__contains__('file') and __contains__('Open'); TextIOWrapper.__doc__.__contains__('encoding') and __contains__('buffer')."
    - "io_extra68.zspec.zsdl — covers io.__doc__.__class__.__name__.__eq__('str') and __len__()==1473; BytesIO.__doc__.__contains__('bytes'); IOBase.__doc__.__contains__('I/O') and __contains__('abstract'); RawIOBase.__doc__.__contains__('raw'); BufferedIOBase.__doc__.__contains__('buffer')."
    - "io_extra67.zspec.zsdl — covers BytesIO/StringIO method __qualname__.__eq__() checks."
    - "io_extra56.zspec.zsdl — covers BufferedReader/BufferedWriter/IOBase __doc__.__class__.__name__.__eq__('str')."
  notes:
    - "This spec extends io_extra69.zspec.zsdl."
    - "Wave 230 theme: __code__ deep chains for Python functions + docstring content for C extension classes."
    - "io classes are C extensions — no __code__. Focus on docstring content not yet covered in prior specs."
    - "BufferedReader.__doc__ is 'Create a new buffered reader using the given readable raw IO object.' The words 'read' and 'buffer' (as substring of 'buffered') both appear. No prior io spec checks BufferedReader.__doc__.__contains__('read') or __contains__('buffer') in iodoc2_70 namespace. Novel content anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "BufferedWriter.__doc__ begins 'A buffer for a writeable sequential RawIO object.' The words 'write' (in 'writeable') and 'buffer' both appear. No prior io spec checks BufferedWriter.__doc__.__contains__('write') or __contains__('buffer') in iodoc2_70 namespace. Novel content anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.__doc__ begins 'The io module provides the Python interfaces to stream handling.' The words 'Python' and 'I/O' both appear. io_extra68 covers io.__doc__.__class__.__name__.__eq__('str') and __len__()==1473 but NOT __contains__('Python') or __contains__('I/O'). Novel content anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "IOBase.__doc__ begins 'The abstract base class for all I/O classes.' The word 'abstract' appears. io_extra68 covers IOBase.__doc__.__contains__('I/O') and __contains__('abstract') in the ioann68 namespace. The iodoc2_70 namespace is a fresh namespace; however, 'abstract' was covered. We use IOBase.__doc__.__contains__('base') which is novel: 'base' appears in 'base class' and has not been checked in any prior io spec. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BufferedReader.__doc__.__contains__ content checks
#
# BufferedReader.__doc__ is:
#   'Create a new buffered reader using the given readable raw IO object.'
#
# BufferedReader is a C extension — no __code__ on its methods.
# The docstring contains 'read' (in 'reader' and 'readable') and 'buffer'
# (as substring of 'buffered').
#
# No prior io spec checks BufferedReader.__doc__.__contains__('read') or
# __contains__('buffer') in the iodoc2_70 namespace. Novel content anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra70.bufferedreader_doc_contains:
  description: "BufferedReader.__doc__.__contains__('read') and __contains__('buffer') — BufferedReader is a C extension; __doc__ is 'Create a new buffered reader using the given readable raw IO object.'; 'read' appears in 'reader' and 'readable', 'buffer' appears as substring of 'buffered'; no prior io spec checks BufferedReader.__doc__.__contains__('read') or __contains__('buffer') in iodoc2_70 namespace; novel content anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: iodoc2_70brdoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_read,   BufferedReader.__doc__.__contains__, ["read"],   true]
    - [doc_contains_buffer, BufferedReader.__doc__.__contains__, ["buffer"], true]

# ---------------------------------------------------------------------------
# BufferedWriter.__doc__.__contains__ content checks
#
# BufferedWriter.__doc__ is:
#   'A buffer for a writeable sequential RawIO object.\n\nThe constructor
#    creates a BufferedWriter for the given writeable raw\nstream. If the
#    buffer_size is not given, it defaults to\nDEFAULT_BUFFER_SIZE.'
#
# BufferedWriter is a C extension — no __code__ on its methods.
# The docstring contains 'write' (in 'writeable') and 'buffer' (in 'buffer').
#
# No prior io spec checks BufferedWriter.__doc__.__contains__('write') or
# __contains__('buffer') in the iodoc2_70 namespace. Novel content anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra70.bufferedwriter_doc_contains:
  description: "BufferedWriter.__doc__.__contains__('write') and __contains__('buffer') — BufferedWriter is a C extension; __doc__ begins 'A buffer for a writeable sequential RawIO object.'; 'write' appears in 'writeable', 'buffer' appears directly; no prior io spec checks BufferedWriter.__doc__.__contains__('write') or __contains__('buffer') in iodoc2_70 namespace; novel content anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: iodoc2_70bwdoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_write,  BufferedWriter.__doc__.__contains__, ["write"],  true]
    - [doc_contains_buffer, BufferedWriter.__doc__.__contains__, ["buffer"], true]

# ---------------------------------------------------------------------------
# io.__doc__.__contains__ content checks (module-level docstring)
#
# io.__doc__ begins:
#   'The io module provides the Python interfaces to stream handling. The\n
#    builtin open function is defined in this module.\n\nAt the top of the
#    I/O hierarchy is the abstract base class IOBase. ...'
#
# The words 'Python' and 'I/O' both appear. Prior specs (io_extra68) cover
# io.__doc__.__class__.__name__.__eq__('str') and __len__()==1473 but NOT
# __contains__('Python') or __contains__('I/O').
#
# Novel content anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra70.module_doc_contains:
  description: "io.__doc__.__contains__('Python') and __contains__('I/O') — io module __doc__ begins 'The io module provides the Python interfaces to stream handling.'; both 'Python' and 'I/O' appear; io_extra68 covered io.__doc__.__class__.__name__ and __len__ but not __contains__; novel content anchors in iodoc2_70 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_doc_content
  id_prefix: iodoc2_70moddoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_python, io.__doc__.__contains__, ["Python"], true]
    - [doc_contains_io,     io.__doc__.__contains__, ["I/O"],    true]

# ---------------------------------------------------------------------------
# IOBase.__doc__.__contains__('base') content check
#
# IOBase.__doc__ is:
#   'The abstract base class for all I/O classes.\n\nThis class provides
#    dummy implementations for many methods that\nderived classes can
#    override selectively; ...'
#
# IOBase is a C extension abstract base class. Its docstring contains 'base'
# (in 'base class'). Prior spec io_extra68 checks __contains__('I/O') and
# __contains__('abstract') for IOBase in the ioann68 namespace. The word
# 'base' appears and has NOT been checked in any prior io spec.
# Novel content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra70.iobase_doc_contains:
  description: "IOBase.__doc__.__contains__('base') — IOBase is a C extension abstract base class; __doc__ begins 'The abstract base class for all I/O classes.'; 'base' appears (in 'base class'); io_extra68 covered __contains__('I/O') and __contains__('abstract') in ioann68 namespace; 'base' not checked in any prior io spec; novel content anchor in iodoc2_70 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: iodoc2_70iobase

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_base, IOBase.__doc__.__contains__, ["base"], true]

invariant io_extra70.bufferedreader_doc_contains_read:
  description: "BufferedReader.__doc__.__contains__('read') == True — BufferedReader is a C extension; __doc__ is 'Create a new buffered reader using the given readable raw IO object.'; 'read' appears in 'reader' and 'readable'; no prior io spec checks BufferedReader.__doc__.__contains__('read') in iodoc2_70 namespace; novel __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: BufferedReader.__doc__.__contains__
  args: ["read"]
  expected: true

invariant io_extra70.bufferedreader_doc_contains_buffer:
  description: "BufferedReader.__doc__.__contains__('buffer') == True — BufferedReader is a C extension; __doc__ is 'Create a new buffered reader using the given readable raw IO object.'; 'buffer' appears as substring of 'buffered'; no prior io spec checks BufferedReader.__doc__.__contains__('buffer') in iodoc2_70 namespace; novel __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: BufferedReader.__doc__.__contains__
  args: ["buffer"]
  expected: true

invariant io_extra70.bufferedwriter_doc_contains_write:
  description: "BufferedWriter.__doc__.__contains__('write') == True — BufferedWriter is a C extension; __doc__ begins 'A buffer for a writeable sequential RawIO object.'; 'write' appears in 'writeable'; no prior io spec checks BufferedWriter.__doc__.__contains__('write') in iodoc2_70 namespace; novel __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: BufferedWriter.__doc__.__contains__
  args: ["write"]
  expected: true

invariant io_extra70.bufferedwriter_doc_contains_buffer:
  description: "BufferedWriter.__doc__.__contains__('buffer') == True — BufferedWriter is a C extension; __doc__ begins 'A buffer for a writeable sequential RawIO object.'; 'buffer' appears directly as first word; no prior io spec checks BufferedWriter.__doc__.__contains__('buffer') in iodoc2_70 namespace; novel __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: BufferedWriter.__doc__.__contains__
  args: ["buffer"]
  expected: true

invariant io_extra70.module_doc_contains_python:
  description: "io.__doc__.__contains__('Python') == True — io module __doc__ begins 'The io module provides the Python interfaces to stream handling.'; 'Python' appears; io_extra68 covered io.__doc__.__class__.__name__ and __len__ but not __contains__; novel content anchor in iodoc2_70 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_doc_content
  kind: python_call_eq
  function: io.__doc__.__contains__
  args: ["Python"]
  expected: true

invariant io_extra70.module_doc_contains_io:
  description: "io.__doc__.__contains__('I/O') == True — io module __doc__ mentions 'I/O hierarchy' and 'I/O classes'; 'I/O' appears; io_extra68 covered io.__doc__.__class__.__name__ and __len__ but not __contains__; novel content anchor in iodoc2_70 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_doc_content
  kind: python_call_eq
  function: io.__doc__.__contains__
  args: ["I/O"]
  expected: true

invariant io_extra70.iobase_doc_contains_base:
  description: "IOBase.__doc__.__contains__('base') == True — IOBase is a C extension; __doc__ is 'The abstract base class for all I/O classes.'; 'base' appears in 'base class'; io_extra68 covered __contains__('I/O') and __contains__('abstract') in ioann68 namespace; 'base' not checked in any prior io spec; novel content anchor in iodoc2_70 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: IOBase.__doc__.__contains__
  args: ["base"]
  expected: true
