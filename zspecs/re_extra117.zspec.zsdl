spec: re_extra117
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec extends re_extra116.zspec.zsdl."
    - "This spec covers: re.Pattern and re.Match class identity (MRO slot names, metaclass, module) not previously covered."
    - "re_extra111 covered all 8 Pattern method qualnames; re_extra112 covered Match methods group/groups/groupdict/start/end/span."
    - "re_extra115 covered Pattern descriptor qualnames (pattern, flags, groups, groupindex)."
    - "re_extra116 covered Match descriptor qualnames (string, re, pos, endpos, lastindex, lastgroup)."
    - "This spec covers: Pattern and Match class __name__, __module__, MRO slots; Match.expand and Match.regs (not covered in re_extra112)."
    - "re.Pattern.__name__ == 'Pattern' (len 7); re.Pattern.__module__ == 're' (len 2)."
    - "re.Match.__name__ == 'Match' (len 5); re.Match.__module__ == 're' (len 2)."
    - "Pattern.__mro__ has 2 entries: (Pattern, object); Match.__mro__ has 2 entries: (Match, object)."
    - "Both Pattern and Match use metaclass 'type' (plain C extension types in _sre)."
    - "re.Match.expand.__qualname__ == 'Match.expand' (len 12); type 'method_descriptor'."
    - "re.Match.regs.__qualname__ == 'Match.regs' (len 10); type 'getset_descriptor'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern class identity: __name__, __module__, MRO, metaclass
# re.Pattern.__name__ == 'Pattern' (7 chars); __module__ == 're' (2 chars).
# re.Pattern.__mro__ == (Pattern, object) — just 2 entries (the shortest possible MRO).
# Pattern is a C extension type from Modules/_sre.c; it uses the default 'type' metaclass.
# No prior re_extra spec has covered these class-level identity properties individually.
# re_extra111 focused on method qualnames; re_extra115 on descriptor attribute qualnames.
# ---------------------------------------------------------------------------

table re_extra117.Pattern_class_identity:
  description: "re.Pattern class identity: __name__='Pattern'(7), __module__='re'(2), __mro__ len=2 (Pattern,object), metaclass='type'; C extension type from Modules/_sre.c"
  kind: python_call_eq
  category: class_identity
  id_prefix: repatid117a

  columns: [id, function, args, expected, description]
  rows:
    - [pat_name_eq,    "Pattern.__name__.__eq__",           ["Pattern"],  true,  "re.Pattern.__name__ == 'Pattern' (7 chars; the public name of the compiled pattern type)"]
    - [pat_name_len,   "Pattern.__name__.__len__",          [],           7,     "re.Pattern.__name__.__len__() == 7 ('Pattern' has 7 characters)"]
    - [pat_module_eq,  "Pattern.__module__.__eq__",         ["re"],       true,  "re.Pattern.__module__ == 're' (2 chars; the compiled pattern C type is attributed to the 're' module)"]
    - [pat_module_len, "Pattern.__module__.__len__",        [],           2,     "re.Pattern.__module__.__len__() == 2 ('re' has 2 characters; the shortest module name in common use)"]
    - [pat_mro_len,    "Pattern.__mro__.__len__",           [],           2,     "re.Pattern.__mro__.__len__() == 2 (Pattern, object — the minimal 2-entry MRO for a direct object subtype)"]
    - [pat_mro0_name,  "Pattern.__mro__[0].__name__.__eq__", ["Pattern"], true,  "re.Pattern.__mro__[0].__name__ == 'Pattern' (the class itself is first in its own MRO)"]
    - [pat_mro1_name,  "Pattern.__mro__[1].__name__.__eq__", ["object"],  true,  "re.Pattern.__mro__[1].__name__ == 'object' (Pattern inherits directly from object with no intermediate base)"]
    - [pat_type_name,  "Pattern.__class__.__name__.__eq__", ["type"],     true,  "type(re.Pattern).__name__ == 'type' (Pattern is a plain C extension type using the default 'type' metaclass)"]

# ---------------------------------------------------------------------------
# re.Match class identity: __name__, __module__, MRO, metaclass
# re.Match.__name__ == 'Match' (5 chars); __module__ == 're' (2 chars).
# re.Match.__mro__ == (Match, object) — also 2 entries.
# Both Pattern and Match are C extension types from Modules/_sre.c sharing the same
# module string 're', but Pattern.__name__ (7) is 2 chars longer than Match.__name__ (5).
# re_extra112 focused on Match method qualnames; no prior spec covered Match class identity.
# ---------------------------------------------------------------------------

table re_extra117.Match_class_identity:
  description: "re.Match class identity: __name__='Match'(5), __module__='re'(2), __mro__ len=2 (Match,object), metaclass='type'; C extension type from Modules/_sre.c; name is 2 chars shorter than Pattern"
  kind: python_call_eq
  category: class_identity
  id_prefix: rematid117b

  columns: [id, function, args, expected, description]
  rows:
    - [mat_name_eq,    "Match.__name__.__eq__",              ["Match"],   true,  "re.Match.__name__ == 'Match' (5 chars; the public name of the match result type)"]
    - [mat_name_len,   "Match.__name__.__len__",             [],          5,     "re.Match.__name__.__len__() == 5 ('Match' has 5 characters; shorter than Pattern at 7)"]
    - [mat_module_eq,  "Match.__module__.__eq__",            ["re"],      true,  "re.Match.__module__ == 're' (2 chars; same module as Pattern — both C extension types are attributed to 're')"]
    - [mat_module_len, "Match.__module__.__len__",           [],          2,     "re.Match.__module__.__len__() == 2 ('re' has 2 characters; same length as Pattern.__module__)"]
    - [mat_mro_len,    "Match.__mro__.__len__",              [],          2,     "re.Match.__mro__.__len__() == 2 (Match, object — same minimal 2-entry MRO structure as Pattern)"]
    - [mat_mro0_name,  "Match.__mro__[0].__name__.__eq__",  ["Match"],   true,  "re.Match.__mro__[0].__name__ == 'Match' (the class itself is first in its own MRO)"]
    - [mat_mro1_name,  "Match.__mro__[1].__name__.__eq__",  ["object"],  true,  "re.Match.__mro__[1].__name__ == 'object' (Match inherits directly from object like Pattern)"]
    - [mat_type_name,  "Match.__class__.__name__.__eq__",   ["type"],    true,  "type(re.Match).__name__ == 'type' (Match is a plain C extension type using the default 'type' metaclass)"]
    - [mat_lt_pat_len, "Match.__name__.__len__.__lt__",     [7],         true,  "len('Match') < len('Pattern') (5 < 7; Match is 2 chars shorter than Pattern)"]

# ---------------------------------------------------------------------------
# re.Match.expand and re.Match.regs: qualnames not covered by re_extra112
# re_extra112 covered: group, groups, groupdict, start, end, span.
# Match.expand: 'Match.expand' (12 chars); type 'method_descriptor'.
#   Expands escape sequences in a template string using the match's captured groups.
# Match.regs: 'Match.regs' (10 chars); type 'getset_descriptor'.
#   A tuple of (start, end) integer pairs for each group in the match.
# Neither expand nor regs was covered in any prior re_extra spec.
# ---------------------------------------------------------------------------

table re_extra117.Match_expand_regs_qualnames:
  description: "re.Match.expand qualname='Match.expand'(12) type='method_descriptor'; Match.regs qualname='Match.regs'(10) type='getset_descriptor'; neither covered in re_extra112; expand substitutes group references in a template string"
  kind: python_call_eq
  category: qualnames
  id_prefix: rematex117c

  columns: [id, function, args, expected, description]
  rows:
    - [expand_type,    "Match.expand.__class__.__name__.__eq__",   ["method_descriptor"],  true,  "type(re.Match.expand).__name__ == 'method_descriptor' (C extension method; expands escape sequences using captured groups)"]
    - [expand_qn_eq,   "Match.expand.__qualname__.__eq__",         ["Match.expand"],       true,  "re.Match.expand.__qualname__ == 'Match.expand' (12 chars; 'Match.'(6)+'expand'(6)==12; not covered in re_extra112)"]
    - [expand_qn_len,  "Match.expand.__qualname__.__len__",        [],                     12,    "re.Match.expand.__qualname__.__len__() == 12 ('Match.expand' has 12 chars; same length as Match.string and Match.endpos)"]
    - [regs_type,      "Match.regs.__class__.__name__.__eq__",     ["getset_descriptor"],  true,  "type(re.Match.regs).__name__ == 'getset_descriptor' (tp_getset entry; regs provides (start,end) pairs for all captured groups)"]
    - [regs_qn_eq,     "Match.regs.__qualname__.__eq__",           ["Match.regs"],         true,  "re.Match.regs.__qualname__ == 'Match.regs' (10 chars; 'Match.'(6)+'regs'(4)==10; tuple of (start,end) pairs for every group)"]
    - [regs_qn_len,    "Match.regs.__qualname__.__len__",          [],                     10,    "re.Match.regs.__qualname__.__len__() == 10 ('Match.regs' has 10 chars; 4 chars longer than Match.re at 8)"]
    - [expand_gt_regs, "Match.expand.__qualname__.__len__.__gt__", [10],                   true,  "len('Match.expand') > len('Match.regs') (12 > 10; expand is 2 chars longer than regs)"]
    - [expand_ne_regs, "Match.expand.__qualname__.__eq__",         ["Match.regs"],         false, "re.Match.expand.__qualname__ != 'Match.regs' (distinct qualnames; expand(12) is a method, regs(10) is a getset_descriptor)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra117.Pattern.name_eq:
  description: "re.Pattern.__name__ == 'Pattern' (length 7; type is 'type' — a plain C extension type; Pattern is the compiled regular expression type returned by re.compile(); it is defined in Modules/_sre.c as the SRE_Pattern struct type; it has __module__ == 're' even though the C implementation lives in _sre; re_extra111 covered Pattern method qualnames and re_extra115 covered Pattern descriptor qualnames, but no prior spec covered Pattern.__name__ directly)"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra117.Match.name_eq:
  description: "re.Match.__name__ == 'Match' (length 5; type is 'type' — a plain C extension type; Match is the match object type returned by Pattern.match(), Pattern.search(), and Pattern.fullmatch(); it is defined in Modules/_sre.c alongside Pattern; Match.__name__(5) is 2 chars shorter than Pattern.__name__(7); both have __module__ == 're' and __mro__.__len__() == 2 (direct subtype of object); re_extra112 covered Match method qualnames but not Match class-level identity attributes)"
  category: class_identity
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra117.Pattern.mro_len_eq_2:
  description: "re.Pattern.__mro__.__len__() == 2 (Pattern, object; the minimal 2-entry MRO indicates Pattern is a direct subtype of object with no intermediate base class; this is the same MRO length as re.Match; both are C extension types that inherit directly from object; Python requires all types to have at least 2 entries in __mro__ — the type itself and object; Pattern has no ABC, no mixin, and no intermediate wrapper class in its MRO)"
  category: class_identity
  kind: python_call_eq
  function: "Pattern.__mro__.__len__"
  args: []
  expected: 2

invariant re_extra117.Match.expand_qualname_eq:
  description: "re.Match.expand.__qualname__ == 'Match.expand' (length 12; type is 'method_descriptor'; expand() takes a template string and returns it with escape sequences replaced by the corresponding captured groups from the match — it is the instance-level equivalent of re.template substitution; 'Match.'(6)+'expand'(6)==12; re_extra112 covered Match methods group/groups/groupdict/start/end/span but not expand; Match.expand.__qualname__(12) has the same length as Match.string.__qualname__(12) and Match.endpos.__qualname__(12))"
  category: qualnames
  kind: python_call_eq
  function: "Match.expand.__qualname__.__eq__"
  args: ["Match.expand"]
  expected: true

invariant re_extra117.Match.regs_qualname_eq:
  description: "re.Match.regs.__qualname__ == 'Match.regs' (length 10; type is 'getset_descriptor'; regs is a read-only attribute that returns a tuple of (start, end) integer pairs — one pair for the entire match at index 0, then one pair per capturing group; 'Match.'(6)+'regs'(4)==10; it is a getset_descriptor like Match.lastindex and Match.lastgroup, not a member_descriptor; no prior re_extra spec covers Match.regs in any qualname context)"
  category: qualnames
  kind: python_call_eq
  function: "Match.regs.__qualname__.__eq__"
  args: ["Match.regs"]
  expected: true

