spec: pickle_extra15
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl through pickle_extra14.zspec.zsdl."
    - "pickle_extra14 covers: Pickler/__qualname__; Unpickler/__qualname__; PickleBuffer/__qualname__; Pickler/Unpickler/PickleBuffer __bases__[0].__name__; loads/__qualname__; load/__qualname__; dump/__qualname__."
    - "pickle_extra13 covers: HIGHEST_PROTOCOL/__class__.__name__; HIGHEST_PROTOCOL>=5; DEFAULT_PROTOCOL/__class__.__name__; PickleError/__name__; PicklingError/__name__; UnpicklingError/__name__; PicklingError/__bases__[0].__name__; dumps/__qualname__."
    - "pickle_extra12 covers: Pickler/Unpickler __module__; exception __module__ table; dumps/loads __module__ standalone."
    - "pickle_extra11 covers: Pickler/Unpickler __name__; PickleError/PicklingError/UnpicklingError __name__ table; PickleError/__bases__[0].__name__; PicklingError/__bases__[0].__name__; UnpicklingError/__bases__[0].__name__."
    - "pickle_extra10 covers: dumps(42).__class__.__name__; HIGHEST_PROTOCOL/DEFAULT_PROTOCOL __class__.__name__; PickleError/PicklingError/UnpicklingError __qualname__; dumps/loads __name__; pickle.__name__."
    - "Focus: new axes — pickle.__package__; exception __qualname__.__class__.__name__ table; Pickler/__qualname__.__class__.__name__; Unpickler/__qualname__.__class__.__name__."
    - "pickle.__package__ == '' — pickle is a top-level module with no parent package; no prior spec checks pickle.__package__."
    - "pickle.PickleError.__qualname__.__class__.__name__ == 'str' — qualname value is always a string; no prior spec checks this axis."
    - "pickle.PicklingError.__qualname__.__class__.__name__ == 'str' — same string-type guarantee for PicklingError qualname."
    - "pickle.UnpicklingError.__qualname__.__class__.__name__ == 'str' — same string-type guarantee for UnpicklingError qualname."
    - "pickle.Pickler.__qualname__.__class__.__name__ == 'str' — qualname type check for Pickler."
    - "pickle.Unpickler.__qualname__.__class__.__name__ == 'str' — qualname type check for Unpickler."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pickle.__package__ — module package affiliation
#
# pickle is a top-level module; its __package__ is the empty string.
# No prior pickle spec checks __package__. pickle_extra10 checks pickle.__name__
# but not __package__.
# ---------------------------------------------------------------------------

invariant pickle_extra15.module.package:
  description: "pickle.__package__ == '' — top-level module has no parent package"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# Exception __qualname__.__class__.__name__ — type of the qualname string
#
# pickle_extra10 checks __qualname__ values for the three exception classes.
# No prior spec checks __qualname__.__class__.__name__ for any pickle symbol.
# All qualname attributes are plain str objects.
# ---------------------------------------------------------------------------

table pickle_extra15.exception_qualname_type:
  description: "pickle exception classes — __qualname__.__class__.__name__ == 'str'"
  kind: python_call_eq
  category: class_attrs
  id_prefix: peqt15

  columns: [id, function, args, expected]
  rows:
    - [PickleError_qn_type,     PickleError.__qualname__.__class__.__name__.__eq__,     ["str"], true]
    - [PicklingError_qn_type,   PicklingError.__qualname__.__class__.__name__.__eq__,   ["str"], true]
    - [UnpicklingError_qn_type, UnpicklingError.__qualname__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# Pickler and Unpickler — __qualname__.__class__.__name__
#
# pickle_extra14 checks __qualname__ values for Pickler/Unpickler.
# No prior spec checks the type of the qualname attribute for these classes.
# ---------------------------------------------------------------------------

invariant pickle_extra15.Pickler.qualname_type:
  description: "pickle.Pickler.__qualname__.__class__.__name__ == 'str' — qualname is a string"
  category: class_attrs
  kind: python_call_eq
  function: Pickler.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pickle_extra15.Unpickler.qualname_type:
  description: "pickle.Unpickler.__qualname__.__class__.__name__ == 'str' — qualname is a string"
  category: class_attrs
  kind: python_call_eq
  function: Unpickler.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
