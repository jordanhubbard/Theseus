spec: functools_extra2266
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "Wave 598 (_extra2266): pickling/serialization protocol dict-presence checks."
    - "Checks __reduce__, __reduce_ex__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__, __copy__, __deepcopy__, __sizeof__, __class_getitem__, __init_subclass__ presence in __dict__ of functools types."
    - "functools.partial: __reduce__ present (True), __setstate__ present (True), __class_getitem__ present (True); all others absent."
    - "functools.lru_cache: all pickling/copy/sizeof protocol keys absent from __dict__."
    - "functools._lru_cache_wrapper: __reduce__ present (True), __copy__ present (True), __deepcopy__ present (True); all others absent."
    - "functools.cached_property: only __class_getitem__ present (True); all pickling and copy protocol keys absent."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table functools_extra2266.partial_pickle:
  description: "functools.partial pickle/copy protocol dict-presence — __reduce__ present, __setstate__ present, __class_getitem__ present, others absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2266

  columns: [id, function, args, expected]
  rows:
    - ["ft2266001", "functools.partial.__dict__.__contains__", ["__reduce__"], true]
    - ["ft2266002", "functools.partial.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["ft2266003", "functools.partial.__dict__.__contains__", ["__getstate__"], false]
    - ["ft2266004", "functools.partial.__dict__.__contains__", ["__setstate__"], true]
    - ["ft2266005", "functools.partial.__dict__.__contains__", ["__getnewargs__"], false]
    - ["ft2266006", "functools.partial.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["ft2266007", "functools.partial.__dict__.__contains__", ["__copy__"], false]
    - ["ft2266008", "functools.partial.__dict__.__contains__", ["__deepcopy__"], false]
    - ["ft2266009", "functools.partial.__dict__.__contains__", ["__sizeof__"], false]
    - ["ft2266010", "functools.partial.__dict__.__contains__", ["__class_getitem__"], true]
    - ["ft2266011", "functools.partial.__dict__.__contains__", ["__init_subclass__"], false]

