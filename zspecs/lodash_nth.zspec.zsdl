spec: lodash_nth
version: ">=4.0.0"
backend: node(lodash.nth)

docs: https://lodash.com/docs/#nth

provenance:
  derived_from:
    - "lodash.nth README — https://www.npmjs.com/package/lodash.nth"
    - "Test vectors verified with lodash.nth@4.2.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.nth exports the _.nth function directly as module.exports."
    - "nth(array, n) returns the element at index n. Negative n counts from the end."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns element at index n. Returns undefined for out-of-bounds."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_nth.nth:
  kind: node_module_call_eq
  function: ~
  category: nth
  id_prefix: lnth

  columns: [id, args, expected]
  rows:
    - [first,    [[1, 2, 3, 4], 0],   1]
    - [second,   [[1, 2, 3, 4], 1],   2]
    - [last,     [[1, 2, 3, 4], -1],  4]
    - [second_r, [[1, 2, 3, 4], -2],  3]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:35:01Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
