spec: pathlib_extra1051
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module Path class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks pathlib.Path method __qualname__ identity for filesystem operation methods"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1051.path_file_ops_qualnames:
  description: "pathlib.Path file operation method __qualname__ checks"
  kind: python_call_eq
  category: path_file_ops_qualnames
  id_prefix: pl1051fo
  columns: [id, function, args, expected]
  rows:
    - [pl1051fo001, pathlib.Path.touch.__qualname__.__eq__,       ["Path.touch"],       true]
    - [pl1051fo002, pathlib.Path.rename.__qualname__.__eq__,      ["Path.rename"],      true]
    - [pl1051fo003, pathlib.Path.replace.__qualname__.__eq__,     ["Path.replace"],     true]
    - [pl1051fo004, pathlib.Path.samefile.__qualname__.__eq__,    ["Path.samefile"],    true]
    - [pl1051fo005, pathlib.Path.unlink.__qualname__.__eq__,      ["Path.unlink"],      true]
    - [pl1051fo006, pathlib.Path.mkdir.__qualname__.__eq__,       ["Path.mkdir"],       true]
    - [pl1051fo007, pathlib.Path.rmdir.__qualname__.__eq__,       ["Path.rmdir"],       true]

table pathlib_extra1051.path_stat_qualnames:
  description: "pathlib.Path stat and query method __qualname__ checks"
  kind: python_call_eq
  category: path_stat_qualnames
  id_prefix: pl1051sq
  columns: [id, function, args, expected]
  rows:
    - [pl1051sq001, pathlib.Path.is_mount.__qualname__.__eq__,        ["Path.is_mount"],        true]
    - [pl1051sq002, pathlib.Path.is_symlink.__qualname__.__eq__,      ["Path.is_symlink"],      true]
    - [pl1051sq003, pathlib.Path.is_block_device.__qualname__.__eq__, ["Path.is_block_device"], true]
    - [pl1051sq004, pathlib.Path.is_char_device.__qualname__.__eq__,  ["Path.is_char_device"],  true]
    - [pl1051sq005, pathlib.Path.is_fifo.__qualname__.__eq__,         ["Path.is_fifo"],         true]
    - [pl1051sq006, pathlib.Path.is_socket.__qualname__.__eq__,       ["Path.is_socket"],       true]
    - [pl1051sq007, pathlib.Path.is_file.__qualname__.__eq__,         ["Path.is_file"],         true]

table pathlib_extra1051.path_class_identity:
  description: "pathlib class and module identity checks"
  kind: python_call_eq
  category: path_class_identity
  id_prefix: pl1051ci
  columns: [id, function, args, expected]
  rows:
    - [pl1051ci001, pathlib.Path.__module__.__eq__,          ["pathlib"],     true]
    - [pl1051ci002, pathlib.PurePath.__module__.__eq__,      ["pathlib"],     true]
    - [pl1051ci003, pathlib.PosixPath.__module__.__eq__,     ["pathlib"],     true]
    - [pl1051ci004, pathlib.Path.__name__.__eq__,            ["Path"],        true]
    - [pl1051ci005, pathlib.PurePath.__name__.__eq__,        ["PurePath"],    true]
    - [pl1051ci006, pathlib.Path.stat.__qualname__.__eq__,   ["Path.stat"],   true]
    - [pl1051ci007, pathlib.Path.exists.__qualname__.__eq__, ["Path.exists"], true]
