spec: decimal_extra691
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal.Decimal method documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks decimal.Decimal logical, rotation, and special method __qualname__ identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra691.decimal_method_qualnames:
  description: "decimal.Decimal logical and rotation method __qualname__ identity"
  kind: python_call_eq
  category: decimal_qualnames
  id_prefix: dc691mq
  columns: [id, function, args, expected]
  rows:
    - [dc691mq001, decimal.Decimal.logical_xor.__qualname__.__eq__,      ["Decimal.logical_xor"],      true]
    - [dc691mq002, decimal.Decimal.logical_invert.__qualname__.__eq__,   ["Decimal.logical_invert"],   true]
    - [dc691mq003, decimal.Decimal.rotate.__qualname__.__eq__,           ["Decimal.rotate"],           true]
    - [dc691mq004, decimal.Decimal.shift.__qualname__.__eq__,            ["Decimal.shift"],            true]
    - [dc691mq005, decimal.Decimal.scaleb.__qualname__.__eq__,           ["Decimal.scaleb"],           true]
    - [dc691mq006, decimal.Decimal.to_integral_exact.__qualname__.__eq__, ["Decimal.to_integral_exact"], true]
    - [dc691mq007, decimal.Decimal.number_class.__qualname__.__eq__,     ["Decimal.number_class"],     true]
    - [dc691mq008, decimal.Decimal.radix.__qualname__.__eq__,            ["Decimal.radix"],            true]
    - [dc691mq009, decimal.Decimal.canonical.__qualname__.__eq__,        ["Decimal.canonical"],        true]
    - [dc691mq010, decimal.Decimal.same_quantum.__qualname__.__eq__,     ["Decimal.same_quantum"],     true]
    - [dc691mq011, decimal.Decimal.adjusted.__qualname__.__eq__,         ["Decimal.adjusted"],         true]
    - [dc691mq012, decimal.Decimal.conjugate.__qualname__.__eq__,        ["Decimal.conjugate"],        true]
    - [dc691mq013, decimal.Decimal.__floor__.__qualname__.__eq__,        ["Decimal.__floor__"],        true]
    - [dc691mq014, decimal.Decimal.__ceil__.__qualname__.__eq__,         ["Decimal.__ceil__"],         true]
