spec: io_extra1771
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "Python io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE, SEEK_* types, TextIOWrapper/BufferedRandom/UnsupportedOperation class names"
  notes:
    - "Wave 565, theme: async protocol. All five async dunder methods are absent from io stdlib types."
    - "io types use synchronous context manager (__enter__/__exit__), NOT async context manager."
    - "There is no aiofiles-style async IO in the stdlib io module."
    - "IOBase.__dict__ contains 'readable', 'writable', 'seekable', 'closed' — all defined directly on IOBase."
    - "SEEK_SET == 0, SEEK_CUR == 1, SEEK_END == 2 — verified with Python 3.14 on macOS/Darwin 25.4.0."
    - "DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — the constant is a plain Python int."
    - "All expected values verified by running Python 3.14 io module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Async protocol — io types do NOT define any async dunder in their own __dict__
# Wave 565 theme: __aenter__, __aexit__, __aiter__, __anext__, __await__
# ---------------------------------------------------------------------------

table io_extra1771.async_protocol:
  kind: python_call_eq
  category: async_protocol
  id_prefix: io1771

  columns: [id, function, args, expected]
  rows:
    - ["io1771001", IOBase.__dict__.__contains__,      ["__aenter__"], false]
    - ["io1771002", IOBase.__dict__.__contains__,      ["__aexit__"],  false]
    - ["io1771003", IOBase.__dict__.__contains__,      ["__aiter__"],  false]
    - ["io1771004", IOBase.__dict__.__contains__,      ["__anext__"],  false]
    - ["io1771005", IOBase.__dict__.__contains__,      ["__await__"],  false]
    - ["io1771006", RawIOBase.__dict__.__contains__,   ["__aenter__"], false]
    - ["io1771007", RawIOBase.__dict__.__contains__,   ["__aexit__"],  false]
    - ["io1771008", BufferedIOBase.__dict__.__contains__, ["__aenter__"], false]
    - ["io1771009", BufferedIOBase.__dict__.__contains__, ["__aexit__"],  false]
    - ["io1771010", TextIOBase.__dict__.__contains__,  ["__aenter__"], false]
    - ["io1771011", TextIOBase.__dict__.__contains__,  ["__aexit__"],  false]

# ---------------------------------------------------------------------------
# Complementary: IOBase defines synchronous I/O protocol methods
# readable, writable, seekable, closed are all defined on IOBase itself
# ---------------------------------------------------------------------------

table io_extra1771.iobase_sync_protocol:
  kind: python_call_eq
  category: sync_protocol
  id_prefix: io1771

  columns: [id, function, args, expected]
  rows:
    - ["io1771012", IOBase.__dict__.__contains__, ["readable"],  true]
    - ["io1771013", IOBase.__dict__.__contains__, ["writable"],  true]
    - ["io1771014", IOBase.__dict__.__contains__, ["seekable"],  true]
    - ["io1771015", IOBase.__dict__.__contains__, ["closed"],    true]

# ---------------------------------------------------------------------------
# SEEK_* constant values
# ---------------------------------------------------------------------------

table io_extra1771.seek_values:
  kind: python_call_eq
  category: constants
  id_prefix: io1771

  columns: [id, function, args, expected]
  rows:
    - ["io1771016", SEEK_SET.__eq__, [0], true]
    - ["io1771017", SEEK_CUR.__eq__, [1], true]
    - ["io1771018", SEEK_END.__eq__, [2], true]

# ---------------------------------------------------------------------------
# DEFAULT_BUFFER_SIZE — type check
# ---------------------------------------------------------------------------

invariant io_extra1771.DEFAULT_BUFFER_SIZE.class_name:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# IOBase class name
# ---------------------------------------------------------------------------

invariant io_extra1771.IOBase.class_name:
  description: "io.IOBase.__name__ == 'IOBase'"
  category: class_metadata
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true

invariant io_extra1771.RawIOBase.class_name:
  description: "io.RawIOBase.__name__ == 'RawIOBase'"
  category: class_metadata
  kind: python_call_eq
  function: RawIOBase.__name__.__eq__
  args: ["RawIOBase"]
  expected: true

invariant io_extra1771.BufferedIOBase.class_name:
  description: "io.BufferedIOBase.__name__ == 'BufferedIOBase'"
  category: class_metadata
  kind: python_call_eq
  function: BufferedIOBase.__name__.__eq__
  args: ["BufferedIOBase"]
  expected: true

invariant io_extra1771.TextIOBase.class_name:
  description: "io.TextIOBase.__name__ == 'TextIOBase'"
  category: class_metadata
  kind: python_call_eq
  function: TextIOBase.__name__.__eq__
  args: ["TextIOBase"]
  expected: true
