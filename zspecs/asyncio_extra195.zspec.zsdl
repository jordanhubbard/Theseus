    - [run_name_len,      asyncio.run.__name__.__len__,             [],                   3,    "asyncio.run.__name__.__len__() == 3 ('run'=3: r(1)u(2)n(3)); verified Python 3.14.3"]
    - [run_module_eq,     asyncio.run.__module__.__eq__,            ["asyncio.runners"],  true, "asyncio.run.__module__ == 'asyncio.runners' (len=15; pure Python in Lib/asyncio/runners.py); verified Python 3.14.3"]
