invariant asyncio_extra195.asyncio_get_event_loop_name_eq:
  description: "asyncio.get_event_loop.__name__.__eq__('get_event_loop') returns True — asyncio.get_event_loop.__name__=='get_event_loop' (len=14: 'get_event_loop'=14); get_event_loop() returns the running event loop in the current OS thread; if no event loop is running and none has been set, it creates a new one (deprecated behavior since Python 3.10); get_event_loop is implemented in the C extension _asyncio (not pure-Python), giving it __module__=='_asyncio' (len=8); get_event_loop.__name__ (14) == get_event_loop.__qualname__ (14) — module-level C function; NEW in asynciofuncs195: first standalone get_event_loop.__name__.__eq__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.get_event_loop.__name__.__eq__
  args: ["get_event_loop"]
  expected: true

invariant asyncio_extra195.asyncio_get_event_loop_module_eq:
  description: "asyncio.get_event_loop.__module__.__eq__('_asyncio') returns True — asyncio.get_event_loop.__module__=='_asyncio' (len=8: '_asyncio'=8: '_'=1+'asyncio'=7=8); get_event_loop is implemented in the C extension module _asyncio for performance; the leading underscore convention marks it as a private C implementation module; get_event_loop.__module__ (8) << asyncio.run.__module__ (15) — C extension name vs pure-Python runners module name; get_event_loop.__module__ (8) < sleep.__module__ (13) and create_task.__module__ (13) — C extension vs pure-Python tasks module; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.get_event_loop.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra195.asyncio_get_event_loop_qualname_eq:
  description: "asyncio.get_event_loop.__qualname__.__eq__('get_event_loop') returns True — asyncio.get_event_loop.__qualname__=='get_event_loop' (len=14); for a module-level function the qualname is identical to __name__; get_event_loop.__qualname__ (14) == get_event_loop.__name__ (14) — confirming module-level scope; compare a method qualname like 'Condition.wait' which includes the class prefix separated by '.'; get_event_loop.__qualname__ (14) is the longest qualname in this spec — all other functions have shorter names; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.get_event_loop.__qualname__.__eq__
  args: ["get_event_loop"]
  expected: true

invariant asyncio_extra195.asyncio_run_name_eq:
  description: "asyncio.run.__name__.__eq__('run') returns True — asyncio.run.__name__=='run' (len=3: r(1)u(2)n(3)); asyncio.run() is the main entry point for running a coroutine as the top-level asyncio program; it creates a new event loop, runs the coroutine until completion, closes the loop, and returns the result; asyncio.run.__name__ (3) is the shortest function name in this spec; asyncio.run.__module__ (15: 'asyncio.runners') — run is defined in the pure-Python Lib/asyncio/runners.py module; NEW in asynciofuncs195: first standalone asyncio.run.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.run.__name__.__eq__
  args: ["run"]
  expected: true

invariant asyncio_extra195.asyncio_run_module_eq:
  description: "asyncio.run.__module__.__eq__('asyncio.runners') returns True — asyncio.run.__module__=='asyncio.runners' (len=15: 'asyncio'=7+'.'=1+'runners'=7=15); run is defined in Lib/asyncio/runners.py, the module dedicated to high-level runner functions; asyncio.run.__module__ (15) > asyncio.sleep.__module__ (13) by 2 — 'runners' (7) is 2 characters longer than 'tasks' (5); asyncio.run.__module__ (15) > asyncio.get_event_loop.__module__ (8: '_asyncio') — pure-Python module name is longer than C extension name; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.run.__module__.__eq__
  args: ["asyncio.runners"]
  expected: true

invariant asyncio_extra195.asyncio_create_task_name_eq:
  description: "asyncio.create_task.__name__.__eq__('create_task') returns True — asyncio.create_task.__name__=='create_task' (len=11: 'create_task'=11: 'create'=6+'_'=1+'task'=4=11); create_task() submits a coroutine to the running event loop wrapped in a Task, enabling concurrent execution; unlike asyncio.run(), create_task() requires an already-running event loop; create_task.__name__ (11) > sleep.__name__ (5) by 6; create_task.__module__ (13: 'asyncio.tasks') == sleep.__module__ (13) — both defined in Lib/asyncio/tasks.py; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.create_task.__name__.__eq__
  args: ["create_task"]
  expected: true

invariant asyncio_extra195.asyncio_sleep_name_eq:
  description: "asyncio.sleep.__name__.__eq__('sleep') returns True — asyncio.sleep.__name__=='sleep' (len=5: s(1)l(2)e(3)e(4)p(5)); asyncio.sleep(delay) suspends the current coroutine for delay seconds, yielding control back to the event loop and allowing other tasks to run; asyncio.sleep(0) is a common pattern to yield to the event loop without blocking; sleep.__module__ (13: 'asyncio.tasks') == create_task.__module__ (13) — both defined in Lib/asyncio/tasks.py; sleep.__name__ (5) < create_task.__name__ (11) by 6; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.sleep.__name__.__eq__
  args: ["sleep"]
  expected: true

invariant asyncio_extra195.asyncio_create_task_module_eq:
  description: "asyncio.create_task.__module__.__eq__('asyncio.tasks') returns True — asyncio.create_task.__module__=='asyncio.tasks' (len=13: 'asyncio'=7+'.'=1+'tasks'=5=13); create_task is defined in Lib/asyncio/tasks.py alongside sleep, gather, and the Task class itself; create_task.__module__ (13) == sleep.__module__ (13) — both create_task and sleep share the same source module; create_task.__module__ (13) < run.__module__ (15) by 2 — asyncio.tasks vs asyncio.runners; NEW in asynciofuncs195: completing 8-invariant coverage for asyncio module-level function identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.create_task.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

