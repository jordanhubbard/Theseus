table asyncio_extra195.asyncio_sleep_identity:
  description: "asyncio.sleep function identity checks in asynciofuncs195 namespace — sleep.__name__=='sleep' (len=5: s(1)l(2)e(3)e(4)p(5); suspends the current coroutine for the given number of seconds, yielding control back to the event loop); sleep.__module__=='asyncio.tasks' (len=13: 'asyncio'=7+'.'=1+'tasks'=5=13; defined in Lib/asyncio/tasks.py alongside create_task); sleep.__module__ (13) == create_task.__module__ (13) — both sleep and create_task are defined in asyncio.tasks; sleep.__name__ (5) < create_task.__name__ (11) by 6 — sleep is a shorter name than create_task; sleep.__module__ (13) < run.__module__ (15) by 2 — asyncio.tasks vs asyncio.runners; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciofuncs195

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_name_eq,      asyncio.sleep.__name__.__eq__,      ["sleep"],           true, "asyncio.sleep.__name__ == 'sleep' (len=5; suspends the coroutine yielding control to the event loop); verified Python 3.14.3"]
    - [sleep_name_len,     asyncio.sleep.__name__.__len__,     [],                  5,    "asyncio.sleep.__name__.__len__() == 5 ('sleep'=5: s(1)l(2)e(3)e(4)p(5)); verified Python 3.14.3"]
    - [sleep_module_eq,    asyncio.sleep.__module__.__eq__,    ["asyncio.tasks"],   true, "asyncio.sleep.__module__ == 'asyncio.tasks' (len=13; same module as create_task); verified Python 3.14.3"]
    - [sleep_module_len,   asyncio.sleep.__module__.__len__,   [],                  13,   "asyncio.sleep.__module__.__len__() == 13 ('asyncio.tasks'=13: 'asyncio'=7+'.'=1+'tasks'=5=13); verified Python 3.14.3"]
    - [ctask_module_eq,    asyncio.create_task.__module__.__eq__, ["asyncio.tasks"], true, "asyncio.create_task.__module__ == 'asyncio.tasks' (len=13; sleep.__module__==create_task.__module__ both len 13); verified Python 3.14.3"]

