table asyncio_extra195.asyncio_get_event_loop_identity:
  description: "asyncio.get_event_loop function identity checks in asynciofuncs195 namespace — get_event_loop.__name__=='get_event_loop' (len=14: 'get_event_loop'=14; returns the running event loop in the current OS thread, or creates one if none is running); get_event_loop.__module__=='_asyncio' (len=8: '_asyncio'=8; implemented in the C extension, not pure-Python asyncio); get_event_loop.__qualname__=='get_event_loop' (len=14; qualname equals name for a module-level function); get_event_loop.__name__ (14) == get_event_loop.__qualname__ (14) — module-level function; get_event_loop.__module__ (8) << asyncio.run.__module__ (15) — C extension vs pure-Python runners; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciofuncs195

  columns: [id, function, args, expected, description]
  rows:
    - [gel_name_eq,      asyncio.get_event_loop.__name__.__eq__,      ["get_event_loop"],  true, "asyncio.get_event_loop.__name__ == 'get_event_loop' (len=14; returns/creates the event loop for the current thread); verified Python 3.14.3"]
    - [gel_name_len,     asyncio.get_event_loop.__name__.__len__,     [],                  14,   "asyncio.get_event_loop.__name__.__len__() == 14 ('get_event_loop'=14); verified Python 3.14.3"]
    - [gel_module_eq,    asyncio.get_event_loop.__module__.__eq__,    ["_asyncio"],        true, "asyncio.get_event_loop.__module__ == '_asyncio' (len=8; C extension, not pure-Python asyncio); verified Python 3.14.3"]
    - [gel_module_len,   asyncio.get_event_loop.__module__.__len__,   [],                  8,    "asyncio.get_event_loop.__module__.__len__() == 8 ('_asyncio'=8: '_'=1+'asyncio'=7=8); verified Python 3.14.3"]
    - [gel_qualname_eq,  asyncio.get_event_loop.__qualname__.__eq__,  ["get_event_loop"],  true, "asyncio.get_event_loop.__qualname__ == 'get_event_loop' (len=14; qualname equals name for module-level function); verified Python 3.14.3"]

