spec: asyncio_extra195
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio tasks and coroutines documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/runners.py"
  notes:
    - "asyncio.get_event_loop.__name__ == 'get_event_loop' (len=14: 'get_event_loop'=14); implemented in the C extension _asyncio."
    - "asyncio.get_event_loop.__module__ == '_asyncio' (len=8: '_asyncio'=8); C-level implementation, not pure Python."
    - "asyncio.get_event_loop.__qualname__ == 'get_event_loop' (len=14); qualname equals name for a module-level function."
    - "asyncio.run.__name__ == 'run' (len=3: r(1)u(2)n(3)); defined in asyncio.runners (pure Python)."
    - "asyncio.run.__module__ == 'asyncio.runners' (len=15: 'asyncio'=7+'.'=1+'runners'=7=15); pure Python in Lib/asyncio/runners.py."
    - "asyncio.create_task.__name__ == 'create_task' (len=11: 'create_task'=11); defined in asyncio.tasks."
    - "asyncio.create_task.__module__ == 'asyncio.tasks' (len=13: 'asyncio'=7+'.'=1+'tasks'=5=13); pure Python in Lib/asyncio/tasks.py."
    - "asyncio.sleep.__name__ == 'sleep' (len=5: s(1)l(2)e(3)e(4)p(5)); defined in asyncio.tasks."
    - "asyncio.sleep.__module__ == 'asyncio.tasks' (len=13); same module as create_task."
    - "Length ordering: run.__name__ (3) < sleep.__name__ (5) < create_task.__name__ (11) < get_event_loop.__name__ (14)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

