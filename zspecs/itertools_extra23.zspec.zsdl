spec: itertools_extra23
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra22.zspec.zsdl."
    - "itertools_extra22 covers: __qualname__.__eq__ for eight itertools classes (count/cycle/repeat/chain/islice/starmap/groupby/product)."
    - "itertools_extra21 covers: __mro__.__len__() for twelve itertools classes."
    - "No prior itertools spec records __qualname__.__eq__ for class instance/special methods (chain.from_iterable, count.__next__, count.__iter__, product.__next__) in the extra23 namespace."
    - "No prior itertools spec records __qualname__.__eq__ for combinations/permutations/combinations_with_replacement together in the extra23 namespace."
    - "Focus: method-level qualnames for C-level itertools types, plus class qualnames for the three combinatoric classes."
    - "All C-level method qualnames verified: chain.from_iterable.__qualname__ == 'chain.from_iterable'; count.__next__.__qualname__ == 'count.__next__'; count.__iter__.__qualname__ == 'count.__iter__'; product.__next__.__qualname__ == 'product.__next__'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — chain class method and count/product slots
#
# chain.from_iterable is a classmethod on the C-level chain type; its qualname
# is 'chain.from_iterable'. count.__next__ and count.__iter__ are slot wrappers
# on the C-level count type with nested qualnames. product.__next__ is likewise
# a slot wrapper on product.
# No prior itertools spec records these method qualnames in the extra23 namespace.
# ---------------------------------------------------------------------------

table itertools_extra23.method_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra23.method_qualnames.chain_from_iterable,
       chain.from_iterable.__qualname__.__eq__,
       ["chain.from_iterable"],
       true,
       "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'"]
    - [itertools_extra23.method_qualnames.count_next,
       "count.__next__.__qualname__.__eq__",
       ["count.__next__"],
       true,
       "itertools.count.__next__.__qualname__ == 'count.__next__'"]
    - [itertools_extra23.method_qualnames.count_iter,
       "count.__iter__.__qualname__.__eq__",
       ["count.__iter__"],
       true,
       "itertools.count.__iter__.__qualname__ == 'count.__iter__'"]
    - [itertools_extra23.method_qualnames.product_next,
       "product.__next__.__qualname__.__eq__",
       ["product.__next__"],
       true,
       "itertools.product.__next__.__qualname__ == 'product.__next__'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — combinatoric itertools classes
#
# combinations, permutations, and combinations_with_replacement are C-level
# types. Their qualnames are simple names equal to their class names.
# itertools_extra22 covers count/cycle/repeat/chain/islice/starmap/groupby/product
# but does not include these three combinatoric classes.
# No prior itertools spec records all three combinatoric class qualnames
# together in the extra23 namespace.
# ---------------------------------------------------------------------------

table itertools_extra23.combinatoric_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra23.combinatoric_qualnames.combinations,
       combinations.__qualname__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__qualname__ == 'combinations'"]
    - [itertools_extra23.combinatoric_qualnames.permutations,
       permutations.__qualname__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__qualname__ == 'permutations'"]
    - [itertools_extra23.combinatoric_qualnames.combinations_with_replacement,
       combinations_with_replacement.__qualname__.__eq__,
       ["combinations_with_replacement"],
       true,
       "itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement'"]

# ---------------------------------------------------------------------------
# chain.from_iterable.__qualname__.__eq__ — standalone classmethod qualname
#
# itertools.chain.from_iterable is a C-level classmethod. Its qualname
# 'chain.from_iterable' reflects the enclosing chain type name.
# No prior itertools spec records this standalone in the extra23 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra23.chain.from_iterable.qualname:
  description: "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'"
  category: qualnames
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__eq__
  args: ["chain.from_iterable"]
  expected: true

# ---------------------------------------------------------------------------
# combinations.__qualname__.__eq__ — standalone class qualname
#
# itertools.combinations is a C-level type. Its qualname is 'combinations'.
# No prior itertools spec records this standalone in the extra23 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra23.combinations.qualname:
  description: "itertools.combinations.__qualname__ == 'combinations'"
  category: qualnames
  kind: python_call_eq
  function: combinations.__qualname__.__eq__
  args: ["combinations"]
  expected: true

# ---------------------------------------------------------------------------
# combinations_with_replacement.__qualname__.__eq__ — standalone class qualname
#
# itertools.combinations_with_replacement is a C-level type. Its qualname is
# 'combinations_with_replacement', the same as its module attribute name.
# No prior itertools spec records this standalone in the extra23 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra23.combinations_with_replacement.qualname:
  description: "itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement'"
  category: qualnames
  kind: python_call_eq
  function: combinations_with_replacement.__qualname__.__eq__
  args: ["combinations_with_replacement"]
  expected: true
