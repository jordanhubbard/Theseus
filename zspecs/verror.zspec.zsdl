spec: verror
version: ">=1.10.0"
backend: node(verror)

docs: https://github.com/joyent/node-verror#readme

provenance:
  derived_from:
    - "node-verror README — https://github.com/joyent/node-verror#readme"
    - "Test vectors verified with verror via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "verror source"
  notes:
    - "Joyent's VError — chained errors with cause-tracking and printf-style formatting."
    - "Install: npm install verror"
    - "Module export IS the VError constructor (CJS); .cause() retrieves the wrapped error."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Constructor; pure formatting, never throws."
  stderr: "null"
  stickiness: "Each invariant constructs a fresh VError."
  codes: {}

# Bare construction
invariant verror.bare_message:
  description: "VError(msg).message preserves msg"
  category: basic
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: ["outer error"]
  chain:
    - {get: message}
  expected: "outer error"

invariant verror.bare_no_cause:
  description: "VError without cause arg returns undefined from .cause()"
  category: basic
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: ["outer error"]
  chain:
    - {method: cause, args: []}
  expected: ~

# printf formatting (no cause)
invariant verror.printf_string_substitution:
  description: "VError('error %s', 'foo').message is 'error foo'"
  category: formatting
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: ["error %s", "foo"]
  chain:
    - {get: message}
  expected: "error foo"

invariant verror.printf_int_substitution:
  description: "VError('rc=%d', 42).message is 'rc=42'"
  category: formatting
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: ["rc=%d", 42]
  chain:
    - {get: message}
  expected: "rc=42"

# Name
invariant verror.name_is_VError:
  description: ".name == 'VError'"
  category: basic
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: ["x"]
  chain:
    - {get: name}
  expected: "VError"

# Message with no format args
invariant verror.empty_construction_empty_message:
  description: "No-arg construction has empty .message"
  category: basic
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {get: message}
  expected: ""

# Static helper VError.cause(plainError) requires an actual Error instance —
# JSON-form arg fails ERR_ASSERTION; we cover .cause() via the bare-no-cause
# instance test above.
