  category: core_classes_doc_type
  id_prefix: dc931x
  columns: [id, function, args, expected]
  rows:
    - [dc931x001, decimal.Decimal.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [dc931x002, decimal.Context.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [dc931x003, decimal.Decimal.__module__.__eq__,                  ["decimal"], true]
    - [dc931x004, decimal.Context.__module__.__eq__,                  ["decimal"], true]
    - [dc931x005, decimal.Decimal.__class__.__name__.__eq__,          ["type"], true]
    - [dc931x006, decimal.Context.__class__.__name__.__eq__,          ["type"], true]

