spec: in2971
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 645 (in2971): __floor__, __ceil__, __index__ dict-presence checks for inspect types."
    - "inspect types are introspection helpers — none define floor, ceil, or index (operator.index protocol) operators."
    - "Verified types: inspect.Parameter, inspect.BoundArguments, inspect.Signature, inspect.FullArgSpec, inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, inspect.ClosureVars."
    - "inspect.FullArgSpec, inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, and inspect.ClosureVars are namedtuple subclasses."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in2971.floor:
  description: "inspect types __floor__ dict-presence checks; wave 645"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2971
  columns: [id, function, args, expected]
  rows:
    - ["in2971001", operator.contains, [inspect.Parameter.__dict__,       "__floor__"], false]
    - ["in2971002", operator.contains, [inspect.BoundArguments.__dict__,  "__floor__"], false]
    - ["in2971003", operator.contains, [inspect.Signature.__dict__,       "__floor__"], false]
