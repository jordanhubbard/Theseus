spec: curses_ascii
version: ">=3.x"
backend: python_module(curses.ascii)

docs: https://docs.python.org/3/library/curses.ascii.html

provenance:
  derived_from:
    - "Python curses.ascii documentation — https://docs.python.org/3/library/curses.ascii.html"
    - "POSIX.1-2017 — ASCII character classification functions"
    - "Test vectors verified by running Python 3.12 curses.ascii module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/curses/ascii.py"
  notes:
    - "curses.ascii provides ASCII-specific character classification functions, independent of locale."
    - "Unlike the built-in str methods, curses.ascii functions accept both single-character strings and ints."
    - "isctrl(c) and iscntrl(c) are synonyms; both return True for characters with ASCII code 0-31 or 127 (DEL)."
    - "NUL==0, SOH==1, ESC==27, SP==32, DEL==127 are standard ASCII control-code constants."
    - "isprint(c) is True for printable characters (ASCII 32-126, i.e. SP through ~)."
    - "isblank(c) is True for space (32) and horizontal tab (9)."
    - "ispunct(c) is True for printable non-alphanumeric, non-space characters."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table curses_ascii.func_names:
  kind: python_call_eq
  category: functions
  id_prefix: func_name

  columns: [id, function, args, expected]
  rows:
    - [isalnum,  "isalnum.__name__.__eq__",  ["isalnum"],  true]
    - [isalpha,  "isalpha.__name__.__eq__",  ["isalpha"],  true]
    - [isdigit,  "isdigit.__name__.__eq__",  ["isdigit"],  true]
    - [isspace,  "isspace.__name__.__eq__",  ["isspace"],  true]
    - [isupper,  "isupper.__name__.__eq__",  ["isupper"],  true]
    - [islower,  "islower.__name__.__eq__",  ["islower"],  true]
    - [ispunct,  "ispunct.__name__.__eq__",  ["ispunct"],  true]
    - [isprint,  "isprint.__name__.__eq__",  ["isprint"],  true]
    - [isctrl,   "isctrl.__name__.__eq__",   ["isctrl"],   true]
    - [iscntrl,  "iscntrl.__name__.__eq__",  ["iscntrl"],  true]
    - [isblank,  "isblank.__name__.__eq__",  ["isblank"],  true]

# ---------------------------------------------------------------------------
# isdigit — digit classification
# ---------------------------------------------------------------------------

invariant curses_ascii.isdigit.digit_true:
  description: "curses.ascii.isdigit('5') == True"
  category: behavior
  kind: python_call_eq
  function: isdigit
  args: ["5"]
  expected: true

invariant curses_ascii.isdigit.alpha_false:
  description: "curses.ascii.isdigit('a') == False"
  category: behavior
  kind: python_call_eq
  function: isdigit
  args: ["a"]
  expected: false

# ---------------------------------------------------------------------------
# isalpha — letter classification
# ---------------------------------------------------------------------------

invariant curses_ascii.isalpha.alpha_true:
  description: "curses.ascii.isalpha('a') == True"
  category: behavior
  kind: python_call_eq
  function: isalpha
  args: ["a"]
  expected: true

# ---------------------------------------------------------------------------
# isspace — whitespace classification
# ---------------------------------------------------------------------------

invariant curses_ascii.isspace.space_true:
  description: "curses.ascii.isspace(' ') == True"
  category: behavior
  kind: python_call_eq
  function: isspace
  args: [" "]
  expected: true

invariant curses_ascii.isspace.alpha_false:
  description: "curses.ascii.isspace('a') == False"
  category: behavior
  kind: python_call_eq
  function: isspace
  args: ["a"]
  expected: false

# ---------------------------------------------------------------------------
# isupper / islower — case classification
# ---------------------------------------------------------------------------

invariant curses_ascii.isupper.upper_true:
  description: "curses.ascii.isupper('A') == True"
  category: behavior
  kind: python_call_eq
  function: isupper
  args: ["A"]
  expected: true

invariant curses_ascii.islower.lower_true:
  description: "curses.ascii.islower('a') == True"
  category: behavior
  kind: python_call_eq
  function: islower
  args: ["a"]
  expected: true

# ---------------------------------------------------------------------------
# isprint — printable character classification
# ---------------------------------------------------------------------------

invariant curses_ascii.isprint.alpha_true:
  description: "curses.ascii.isprint('a') == True"
  category: behavior
  kind: python_call_eq
  function: isprint
  args: ["a"]
  expected: true

# ---------------------------------------------------------------------------
# isctrl — control character classification
# ---------------------------------------------------------------------------

invariant curses_ascii.isctrl.nul_true:
  description: "curses.ascii.isctrl(chr(0)) == True — NUL (code 0) is a control character"
  category: behavior
  kind: python_call_eq
  function: isctrl
  args: ["\x00"]
  expected: true

invariant curses_ascii.isctrl.alpha_false:
  description: "curses.ascii.isctrl('a') == False — 'a' is not a control character"
  category: behavior
  kind: python_call_eq
  function: isctrl
  args: ["a"]
  expected: false

# ---------------------------------------------------------------------------
# ASCII code constants — NUL, SOH, ESC, SP, DEL
# ---------------------------------------------------------------------------

table curses_ascii.constants.ascii_codes:
  kind: python_call_eq
  category: constants
  id_prefix: ascii_const

  columns: [id, function, args, expected]
  rows:
    - [nul, "NUL.__eq__", [0],   true]
    - [soh, "SOH.__eq__", [1],   true]
    - [esc, "ESC.__eq__", [27],  true]
    - [sp,  "SP.__eq__",  [32],  true]
    - [del, "DEL.__eq__", [127], true]
