spec: decimal_extra94
version: ">=3.9"
backend: python_module(decimal)
extends: decimal_extra93

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra93.zspec.zsdl."
    - "This spec covers: decimal.Decimal and decimal.Context class hierarchy and method identity."
    - "decimal.Decimal.__class__.__name__ = 'type' — Decimal itself is an instance of the standard 'type' metaclass."
    - "decimal.Decimal.__module__ = 'decimal' — although implemented in _decimal (C extension), the class reports __module__ = 'decimal' (the public module name)."
    - "decimal.Decimal.__bases__[0].__name__ = 'object' — Decimal directly extends object."
    - "decimal.Decimal.__mro__.__len__() = 2 (Decimal, object only)."
    - "decimal.Decimal.__init__.__class__.__name__ = 'wrapper_descriptor' — Decimal.__init__ resolves to object.__init__ (Decimal uses __new__ for construction, not __init__)."
    - "decimal.Decimal.__init__.__qualname__ = 'object.__init__' — because Decimal does not define its own __init__; it inherits object.__init__."
    - "decimal.Decimal.__add__.__class__.__name__ = 'wrapper_descriptor' — dunder arithmetic operators are slot wrappers on C extension types."
    - "decimal.Decimal.quantize.__class__.__name__ = 'method_descriptor' — regular named methods are method_descriptor (not wrapper_descriptor)."
    - "decimal.Decimal.sqrt.__class__.__name__ = 'method_descriptor' — same as quantize."
    - "decimal.Decimal.__new__.__class__.__name__ = 'builtin_function_or_method' — __new__ is a static method slot on C types."
    - "decimal.Decimal.__new__.__qualname__ = 'Decimal.__new__'."
    - "decimal.Context.__class__.__name__ = 'type' — Context uses the standard metaclass."
    - "decimal.Context.__module__ = 'decimal' — same as Decimal."
    - "decimal.Context.__bases__[0].__name__ = 'object' — Context also directly extends object."
    - "decimal.Context.__mro__.__len__() = 2 (Context, object only)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal class hierarchy
# Decimal is a C extension type registered as 'decimal.Decimal'.
# It extends object directly. __class__.__name__ == 'type' (standard metaclass).
# MRO length == 2 (Decimal, object).
# ---------------------------------------------------------------------------

table decimal_extra94.Decimal_class_hierarchy:
  description: "decimal.Decimal class hierarchy: __class__.__name__, __module__, __name__, __qualname__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalclsid94

  columns: [id, function, args, expected, description]
  rows:
    - [dec_meta_eq,       Decimal.__class__.__name__.__eq__,           ["type"],    true,  "Decimal.__class__.__name__ == 'type' (Decimal uses the standard type metaclass)"]
    - [dec_module_eq,     Decimal.__module__.__eq__,                   ["decimal"], true,  "Decimal.__module__ == 'decimal' (public module name, not '_decimal' the C extension)"]
    - [dec_name_eq,       Decimal.__name__.__eq__,                     ["Decimal"], true,  "Decimal.__name__ == 'Decimal' (the bare class name)"]
    - [dec_qualname_eq,   Decimal.__qualname__.__eq__,                 ["Decimal"], true,  "Decimal.__qualname__ == 'Decimal' (no enclosing class; same as __name__)"]
    - [dec_base_eq,       "Decimal.__bases__[0].__name__.__eq__",        ["object"],  true,  "Decimal.__bases__[0].__name__ == 'object' (Decimal directly extends object)"]
    - [dec_mro_len,       Decimal.__mro__.__len__,                     [],          2,     "Decimal.__mro__.__len__() == 2 (MRO is [Decimal, object])"]
    - [dec_meta_not_abc,  Decimal.__class__.__name__.__eq__,           ["ABCMeta"], false, "Decimal.__class__.__name__ is NOT 'ABCMeta' (Decimal does not use ABCMeta)"]
    - [dec_mod_not_c,     Decimal.__module__.__eq__,                   ["_decimal"], false, "Decimal.__module__ is NOT '_decimal' (it reports the public 'decimal' name)"]
    - [dec_qn_len,        Decimal.__qualname__.__len__,                [],          7,     "Decimal.__qualname__.__len__() == 7 ('Decimal' has 7 characters)"]
    - [dec_mro_not_3,     Decimal.__mro__.__len__.__eq__,              [3],         false, "Decimal.__mro__.__len__() is NOT 3 (no intermediate base between Decimal and object)"]

# ---------------------------------------------------------------------------
# decimal.Decimal method identity
# Key distinction: dunder slots (__add__, __sub__, etc.) are 'wrapper_descriptor';
# regular named methods (quantize, sqrt, ln, etc.) are 'method_descriptor'.
# Special case: __init__ resolves to object.__init__ (Decimal defines __new__
# for construction, not __init__), so __init__.__qualname__ = 'object.__init__'.
# __new__ is 'builtin_function_or_method'.
# ---------------------------------------------------------------------------

table decimal_extra94.Decimal_method_identity:
  description: "decimal.Decimal method class names: dunder slots are 'wrapper_descriptor', regular methods are 'method_descriptor', __new__ is 'builtin_function_or_method'"
  kind: python_call_eq
  category: method_class_names
  id_prefix: decimalclsid94

  columns: [id, function, args, expected, description]
  rows:
    - [dec_init_cls,       Decimal.__init__.__class__.__name__.__eq__,      ["wrapper_descriptor"],       true,  "Decimal.__init__ is 'wrapper_descriptor' (resolves to object.__init__, a C slot)"]
    - [dec_add_cls,        Decimal.__add__.__class__.__name__.__eq__,       ["wrapper_descriptor"],       true,  "Decimal.__add__ is 'wrapper_descriptor' (dunder arithmetic slots are wrapper_descriptor)"]
    - [dec_sub_cls,        Decimal.__sub__.__class__.__name__.__eq__,       ["wrapper_descriptor"],       true,  "Decimal.__sub__ is 'wrapper_descriptor' (dunder arithmetic slot)"]
    - [dec_str_cls,        Decimal.__str__.__class__.__name__.__eq__,       ["wrapper_descriptor"],       true,  "Decimal.__str__ is 'wrapper_descriptor' (dunder string slot)"]
    - [dec_repr_cls,       Decimal.__repr__.__class__.__name__.__eq__,      ["wrapper_descriptor"],       true,  "Decimal.__repr__ is 'wrapper_descriptor' (dunder repr slot)"]
    - [dec_quantize_cls,   Decimal.quantize.__class__.__name__.__eq__,      ["method_descriptor"],        true,  "Decimal.quantize is 'method_descriptor' (regular named C method via PyMethodDef)"]
    - [dec_sqrt_cls,       Decimal.sqrt.__class__.__name__.__eq__,          ["method_descriptor"],        true,  "Decimal.sqrt is 'method_descriptor' (regular named C method)"]
    - [dec_ln_cls,         Decimal.ln.__class__.__name__.__eq__,            ["method_descriptor"],        true,  "Decimal.ln is 'method_descriptor' (regular named C method)"]
    - [dec_new_cls,        Decimal.__new__.__class__.__name__.__eq__,       ["builtin_function_or_method"], true, "Decimal.__new__ is 'builtin_function_or_method' (static slot method used for construction)"]
    - [dec_init_qn,        Decimal.__init__.__qualname__.__eq__,            ["object.__init__"],          true,  "Decimal.__init__.__qualname__ == 'object.__init__' (Decimal inherits object.__init__)"]
    - [dec_add_not_md,     Decimal.__add__.__class__.__name__.__eq__,       ["method_descriptor"],        false, "Decimal.__add__ is NOT 'method_descriptor' (dunder slots are wrapper_descriptor, not method_descriptor)"]
    - [dec_quantize_not_wd,Decimal.quantize.__class__.__name__.__eq__,      ["wrapper_descriptor"],       false, "Decimal.quantize is NOT 'wrapper_descriptor' (regular named methods are method_descriptor)"]

# ---------------------------------------------------------------------------
# decimal.Context class hierarchy
# Context is also a C extension type from _decimal.
# It extends object directly; __module__ == 'decimal'; MRO length == 2.
# ---------------------------------------------------------------------------

table decimal_extra94.Context_class_hierarchy:
  description: "decimal.Context class hierarchy: __class__.__name__, __module__, __name__, __qualname__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalclsid94

  columns: [id, function, args, expected, description]
  rows:
    - [ctx_meta_eq,       Context.__class__.__name__.__eq__,           ["type"],    true,  "Context.__class__.__name__ == 'type' (Context uses the standard type metaclass)"]
    - [ctx_module_eq,     Context.__module__.__eq__,                   ["decimal"], true,  "Context.__module__ == 'decimal' (public module name)"]
    - [ctx_name_eq,       Context.__name__.__eq__,                     ["Context"], true,  "Context.__name__ == 'Context' (bare class name)"]
    - [ctx_qualname_eq,   Context.__qualname__.__eq__,                 ["Context"], true,  "Context.__qualname__ == 'Context' (no enclosing class)"]
    - [ctx_base_eq,       "Context.__bases__[0].__name__.__eq__",        ["object"],  true,  "Context.__bases__[0].__name__ == 'object' (Context directly extends object)"]
    - [ctx_mro_len,       Context.__mro__.__len__,                     [],          2,     "Context.__mro__.__len__() == 2 (MRO is [Context, object])"]
    - [ctx_qn_len,        Context.__qualname__.__len__,                [],          7,     "Context.__qualname__.__len__() == 7 ('Context' has 7 characters)"]
    - [ctx_mod_not_c,     Context.__module__.__eq__,                   ["_decimal"], false, "Context.__module__ is NOT '_decimal' (it reports 'decimal')"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra94.Decimal.class_name_is_type:
  description: "decimal.Decimal.__class__.__name__ == 'type' (Decimal is a C extension type that uses the standard type metaclass, just like built-in types such as int and str)"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant decimal_extra94.Decimal.module_is_decimal:
  description: "decimal.Decimal.__module__ == 'decimal' (the class reports the public module name 'decimal', not the private C extension name '_decimal')"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra94.Decimal.mro_len_2:
  description: "decimal.Decimal.__mro__.__len__() == 2 (the MRO of Decimal is [Decimal, object]; Decimal has no intermediate base classes)"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra94.Decimal.add_is_wrapper_descriptor:
  description: "decimal.Decimal.__add__.__class__.__name__ == 'wrapper_descriptor' (dunder arithmetic operators on C extension types are slot wrappers, exposed as wrapper_descriptor, distinct from regular named methods which are method_descriptor)"
  category: method_class_names
  kind: python_call_eq
  function: Decimal.__add__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra94.Decimal.quantize_is_method_descriptor:
  description: "decimal.Decimal.quantize.__class__.__name__ == 'method_descriptor' (regular named C methods on Decimal are exposed via PyMethodDef as method_descriptor objects, unlike dunder slots which are wrapper_descriptor)"
  category: method_class_names
  kind: python_call_eq
  function: Decimal.quantize.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra94.Decimal.init_qualname_is_object_init:
  description: "decimal.Decimal.__init__.__qualname__ == 'object.__init__' (Decimal does not define its own __init__; it uses __new__ for construction and inherits object.__init__, so the qualname reflects the defining class)"
  category: method_class_names
  kind: python_call_eq
  function: Decimal.__init__.__qualname__.__eq__
  args: ["object.__init__"]
  expected: true
