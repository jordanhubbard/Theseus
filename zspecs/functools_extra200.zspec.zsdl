spec: functools_extra200
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.total_ordering.__name__ == 'total_ordering' (len=14); total_ordering is a class decorator that fills in missing comparison methods given at least one of __lt__, __le__, __gt__, __ge__; verified with Python 3.14.3."
    - "functools.total_ordering.__module__ == 'functools' (len=9); defined at top level in functools.py; verified with Python 3.14.3."
    - "functools.total_ordering.__class__.__name__ == 'function' (len=8); total_ordering is a regular Python function (decorator factory); its __class__ is the built-in function type; verified with Python 3.14.3."
    - "functools.total_ordering.__qualname__ == 'total_ordering' (len=14); top-level function so qualname equals name; verified with Python 3.14.3."
    - "functools.cmp_to_key.__name__ == 'cmp_to_key' (len=10); cmp_to_key is a C-level built-in function in _functools that converts an old-style comparison function to a key function; verified with Python 3.14.3."
    - "functools.cmp_to_key.__module__ == '_functools' (len=10); cmp_to_key is implemented in C as part of _functools; its __module__ is '_functools' not 'functools'; verified with Python 3.14.3."
    - "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' (len=26); cmp_to_key is a C-level built-in so its __class__.__name__ is 'builtin_function_or_method'; verified with Python 3.14.3."
    - "functools.cmp_to_key.__qualname__ == 'cmp_to_key' (len=10); top-level C function so qualname equals name; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

