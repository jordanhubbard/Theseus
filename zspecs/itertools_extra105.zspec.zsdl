# ---------------------------------------------------------------------------
# Table 3: itertools C-type MRO second element is object
#
# Wave 258 theme: for all itertools C-extension types, the second element
# of the MRO (index 1) is always object. Checking __mro__[1].__name__.
#
# itertools.chain.__mro__[1].__name__ == 'object'
# itertools.cycle.__mro__[1].__name__ == 'object'
# itertools.accumulate.__mro__[1].__name__ == 'object'
# itertools.combinations.__mro__[1].__name__ == 'object'
# itertools.filterfalse.__mro__[1].__name__ == 'object'
# itertools.zip_longest.__mro__[1].__name__ == 'object'
#
# New to extra105.
# ---------------------------------------------------------------------------

table itertools_extra105.mro_second_is_object:
  description: "itertools C-type __mro__[1].__name__ == 'object' — the second MRO entry is always object for all C-extension iterator types; wave 258; new to extra105"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsmroobj105

  columns: [id, function, args, expected, description]
  rows:
    - ["chain_mro_1_name_object",
       "chain.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "itertools.chain.__mro__[1].__name__.__eq__('object') == True — chain directly inherits from object; __mro__[1] is object; object.__name__ is 'object'; str.__eq__('object') returns True; new to extra105"]
    - ["cycle_mro_1_name_object",
       "cycle.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "itertools.cycle.__mro__[1].__name__.__eq__('object') == True — cycle directly inherits from object; __mro__[1] is object; str.__eq__('object') returns True; new to extra105"]
    - ["accumulate_mro_1_name_object",
