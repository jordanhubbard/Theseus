       ["object"],
       true,
       "itertools.accumulate.__mro__[1].__name__.__eq__('object') == True — accumulate directly inherits from object; __mro__[1] is object; str.__eq__('object') returns True; new to extra105"]
    - ["combinations_mro_1_name_object",
       "combinations.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations.__mro__[1].__name__.__eq__('object') == True — combinations directly inherits from object; __mro__[1] is object; str.__eq__('object') returns True; new to extra105"]
    - ["filterfalse_mro_1_name_object",
       "filterfalse.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "itertools.filterfalse.__mro__[1].__name__.__eq__('object') == True — filterfalse directly inherits from object; __mro__[1] is object; str.__eq__('object') returns True; new to extra105"]
    - ["zip_longest_mro_1_name_object",
