spec: inspect_extra192
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.Signature.__name__ == 'Signature' (len=9); Signature is a regular Python class defined in Lib/inspect.py; verified with Python 3.14.3."
    - "inspect.Signature.__module__ == 'inspect' (len=7); Signature is defined in the inspect module; verified with Python 3.14.3."
    - "inspect.Signature.__bases__[0].__name__ == 'object'; Signature inherits directly from object with no intermediary base; verified with Python 3.14.3."
    - "inspect.Signature.__init__.__qualname__ == 'Signature.__init__' (len=18); the qualified name encodes the containing class; verified with Python 3.14.3."
    - "inspect.Signature.bind.__qualname__ == 'Signature.bind' (len=14); bind creates a BoundArguments mapping positional and keyword args; verified with Python 3.14.3."
    - "inspect.Signature.bind_partial.__qualname__ == 'Signature.bind_partial' (len=22); bind_partial allows partial binding; verified with Python 3.14.3."
    - "inspect.Signature.replace.__qualname__ == 'Signature.replace' (len=17); replace creates a modified copy of the Signature; verified with Python 3.14.3."
    - "inspect.Signature.from_callable.__qualname__ == 'Signature.from_callable' (len=23); from_callable is the class method constructor; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Signature class identity — __name__, __module__, __bases__
#
# inspect.Signature.__name__              == 'Signature' (len=9)
# inspect.Signature.__module__            == 'inspect' (len=7)
# inspect.Signature.__bases__[0].__name__ == 'object'
#
# Signature is a regular Python class defined in Lib/inspect.py that represents
# the call signature of a callable. It inherits directly from object.
# New to extra192.
# ---------------------------------------------------------------------------

table inspect_extra192.signature_class_identity:
  description: "inspect.Signature class identity: __name__=='Signature'(len=9); __module__=='inspect'(len=7); __bases__[0].__name__=='object'; new to extra192"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsig192

  columns: [id, function, args, expected, description]
  rows:
    - [sig_name_eq,
       Signature.__name__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — Signature is a Python-level class representing a callable's call signature; __name__ is 'Signature' (len=9: S-i-g-n-a-t-u-r-e); str.__eq__('Signature') returns True; verified with Python 3.14.3; new to extra192"]
    - [sig_name_len,
       Signature.__name__.__len__,
       [],
       9,
       "inspect.Signature.__name__.__len__() == 9 — 'Signature' has 9 characters: S-i-g-n-a-t-u-r-e; str.__len__() returns 9; verified with Python 3.14.3; new to extra192"]
    - [sig_module_eq,
       Signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in Lib/inspect.py; __module__ is 'inspect' (len=7: i-n-s-p-e-c-t); str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra192"]
    - [sig_module_len,
       Signature.__module__.__len__,
       [],
       7,
       "inspect.Signature.__module__.__len__() == 7 — 'inspect' has 7 characters: i-n-s-p-e-c-t; str.__len__() returns 7; verified with Python 3.14.3; new to extra192"]
    - [sig_bases_object,
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature inherits directly from object with no intermediary base class; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; verified with Python 3.14.3; new to extra192"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature method __qualname__ values — __init__, bind, bind_partial
#
# inspect.Signature.__init__.__qualname__    == 'Signature.__init__' (len=18)
# inspect.Signature.bind.__qualname__        == 'Signature.bind' (len=14)
# inspect.Signature.bind_partial.__qualname__ == 'Signature.bind_partial' (len=22)
#
# These three methods form the core API for constructing and using Signatures.
# __init__ constructs a Signature; bind maps args to parameters creating a
# BoundArguments; bind_partial allows partial binding. New to extra192.
# ---------------------------------------------------------------------------

table inspect_extra192.signature_method_qualnames_1:
  description: "inspect.Signature method qualnames: __init__=='Signature.__init__'(len=18); bind=='Signature.bind'(len=14); bind_partial=='Signature.bind_partial'(len=22); new to extra192"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsig192

  columns: [id, function, args, expected, description]
  rows:
    - [sig_init_qualname_eq,
       Signature.__init__.__qualname__.__eq__,
       ["Signature.__init__"],
       true,
       "inspect.Signature.__init__.__qualname__.__eq__('Signature.__init__') == True — the __qualname__ of a method encodes its containing class; 'Signature.__init__' is 18 chars: 'Signature'(9) + '.'(1) + '__init__'(8); str.__eq__('Signature.__init__') returns True; verified with Python 3.14.3; new to extra192"]
    - [sig_init_qualname_len,
       Signature.__init__.__qualname__.__len__,
       [],
       18,
       "inspect.Signature.__init__.__qualname__.__len__() == 18 — 'Signature.__init__' has 18 characters: 9 for 'Signature' + 1 for '.' + 8 for '__init__'; str.__len__() returns 18; verified with Python 3.14.3; new to extra192"]
    - [sig_bind_qualname_eq,
       Signature.bind.__qualname__.__eq__,
       ["Signature.bind"],
       true,
       "inspect.Signature.bind.__qualname__.__eq__('Signature.bind') == True — bind creates a BoundArguments mapping positional and keyword arguments to parameters; __qualname__ is 'Signature.bind' (len=14: 9+1+4); str.__eq__('Signature.bind') returns True; verified with Python 3.14.3; new to extra192"]
    - [sig_bind_qualname_len,
       Signature.bind.__qualname__.__len__,
       [],
       14,
       "inspect.Signature.bind.__qualname__.__len__() == 14 — 'Signature.bind' has 14 characters: 9 for 'Signature' + 1 for '.' + 4 for 'bind'; str.__len__() returns 14; verified with Python 3.14.3; new to extra192"]
    - [sig_bind_partial_qualname_eq,
       Signature.bind_partial.__qualname__.__eq__,
       ["Signature.bind_partial"],
       true,
       "inspect.Signature.bind_partial.__qualname__.__eq__('Signature.bind_partial') == True — bind_partial allows partial binding allowing omission of required arguments; __qualname__ is 'Signature.bind_partial' (len=22: 9+1+12); str.__eq__('Signature.bind_partial') returns True; verified with Python 3.14.3; new to extra192"]
    - [sig_bind_partial_qualname_len,
       Signature.bind_partial.__qualname__.__len__,
       [],
       22,
       "inspect.Signature.bind_partial.__qualname__.__len__() == 22 — 'Signature.bind_partial' has 22 characters: 9 for 'Signature' + 1 for '.' + 12 for 'bind_partial'; str.__len__() returns 22; verified with Python 3.14.3; new to extra192"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Signature method __qualname__ values — replace, from_callable
#
# inspect.Signature.replace.__qualname__       == 'Signature.replace' (len=17)
# inspect.Signature.from_callable.__qualname__ == 'Signature.from_callable' (len=23)
#
# replace creates a modified copy of the Signature with altered parameters
# or return annotation. from_callable is the classmethod constructor that
# creates a Signature from any callable object. New to extra192.
# ---------------------------------------------------------------------------

table inspect_extra192.signature_method_qualnames_2:
  description: "inspect.Signature method qualnames: replace=='Signature.replace'(len=17); from_callable=='Signature.from_callable'(len=23); new to extra192"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsig192

  columns: [id, function, args, expected, description]
  rows:
    - [sig_replace_qualname_eq,
       Signature.replace.__qualname__.__eq__,
       ["Signature.replace"],
       true,
       "inspect.Signature.replace.__qualname__.__eq__('Signature.replace') == True — replace creates a modified copy of the Signature with altered parameters or return annotation; __qualname__ is 'Signature.replace' (len=17: 9+1+7); str.__eq__('Signature.replace') returns True; verified with Python 3.14.3; new to extra192"]
    - [sig_replace_qualname_len,
       Signature.replace.__qualname__.__len__,
       [],
       17,
       "inspect.Signature.replace.__qualname__.__len__() == 17 — 'Signature.replace' has 17 characters: 9 for 'Signature' + 1 for '.' + 7 for 'replace'; str.__len__() returns 17; verified with Python 3.14.3; new to extra192"]
    - [sig_from_callable_qualname_eq,
       Signature.from_callable.__qualname__.__eq__,
       ["Signature.from_callable"],
       true,
       "inspect.Signature.from_callable.__qualname__.__eq__('Signature.from_callable') == True — from_callable is the classmethod constructor creating a Signature from any callable; __qualname__ is 'Signature.from_callable' (len=23: 9+1+13); str.__eq__('Signature.from_callable') returns True; verified with Python 3.14.3; new to extra192"]
    - [sig_from_callable_qualname_len,
       Signature.from_callable.__qualname__.__len__,
       [],
       23,
       "inspect.Signature.from_callable.__qualname__.__len__() == 23 — 'Signature.from_callable' has 23 characters: 9 for 'Signature' + 1 for '.' + 13 for 'from_callable'; str.__len__() returns 23; verified with Python 3.14.3; new to extra192"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra192
# ---------------------------------------------------------------------------

invariant inspect_extra192.signature_name_eq:
  description: "inspect.Signature.__name__.__eq__('Signature') == True — Signature is the Python-level callable signature class in the inspect module; __name__ is 'Signature' (len=9); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra192.signature_module_eq:
  description: "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra192.signature_bases_object:
  description: "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature inherits directly from object with no intermediary base; __bases__[0].__name__ is 'object'; verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: "Signature.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra192.signature_init_qualname_eq:
  description: "inspect.Signature.__init__.__qualname__.__eq__('Signature.__init__') == True — the qualified name encodes the class and method: 'Signature.__init__' (len=18: 9+1+8); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: Signature.__init__.__qualname__.__eq__
  args: ["Signature.__init__"]
  expected: true

invariant inspect_extra192.signature_bind_qualname_eq:
  description: "inspect.Signature.bind.__qualname__.__eq__('Signature.bind') == True — bind maps args to parameters creating a BoundArguments; __qualname__ is 'Signature.bind' (len=14); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: Signature.bind.__qualname__.__eq__
  args: ["Signature.bind"]
  expected: true

invariant inspect_extra192.signature_bind_partial_qualname_eq:
  description: "inspect.Signature.bind_partial.__qualname__.__eq__('Signature.bind_partial') == True — bind_partial allows partial binding omitting required arguments; __qualname__ is 'Signature.bind_partial' (len=22); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: Signature.bind_partial.__qualname__.__eq__
  args: ["Signature.bind_partial"]
  expected: true

invariant inspect_extra192.signature_replace_qualname_eq:
  description: "inspect.Signature.replace.__qualname__.__eq__('Signature.replace') == True — replace creates a modified copy of the Signature; __qualname__ is 'Signature.replace' (len=17); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: Signature.replace.__qualname__.__eq__
  args: ["Signature.replace"]
  expected: true

invariant inspect_extra192.signature_from_callable_qualname_eq:
  description: "inspect.Signature.from_callable.__qualname__.__eq__('Signature.from_callable') == True — from_callable is the classmethod constructor; __qualname__ is 'Signature.from_callable' (len=23); verified with Python 3.14.3; new to extra192"
  category: identity
  kind: python_call_eq
  function: Signature.from_callable.__qualname__.__eq__
