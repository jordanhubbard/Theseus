spec: typing_extra7
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "PEP 484 — Type Hints"
    - "PEP 544 — Protocols: Structural subtyping"
    - "PEP 589 — TypedDict"
    - "PEP 646 — Variadic Generics / TypeVarTuple (Python 3.11)"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing.zspec.zsdl through typing_extra6.zspec.zsdl."
    - "Previous specs cover: TypeVar.__name__/__module__/__qualname__; ParamSpec.__name__/__module__/__qualname__ (extra3); TypeVarTuple.__name__/__module__ (extra3, no __qualname__); Generic/Protocol/TypedDict/NamedTuple __name__/__module__ (extra/extra5); _SpecialForm checks for Any/Union/Optional/ClassVar/Final/Literal/Annotated (extra5/extra6); Union/Optional/ClassVar/Final/Literal _name attribute (extra6); get_type_hints/cast/overload/final/runtime_checkable/get_origin/get_args __name__/__module__ (extra3/extra5)."
    - "This spec adds: TypeVarTuple.__qualname__ (extra3 had only __name__/__module__); Generic/__qualname__; Protocol.__qualname__; TypedDict.__qualname__; NamedTuple.__qualname__; get_type_hints/__qualname__; cast/__qualname__; overload/__qualname__."
    - "typing.TypeVarTuple.__qualname__ == 'TypeVarTuple' (Python 3.11+) — top-level class."
    - "typing.Generic.__qualname__ == 'Generic' — top-level ABC class."
    - "typing.Protocol.__qualname__ == 'Protocol' — top-level ABC class."
    - "typing.TypedDict.__qualname__ == 'TypedDict' — top-level factory function."
    - "typing.NamedTuple.__qualname__ == 'NamedTuple' — top-level factory function."
    - "typing.get_type_hints.__qualname__ == 'get_type_hints' — module-level function."
    - "typing.cast.__qualname__ == 'cast' — module-level function."
    - "typing.overload.__qualname__ == 'overload' — module-level function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TypeVarTuple.__qualname__ — not yet an invariant (Python 3.11+)
#
# typing_extra3 covered TypeVarTuple.__name__ and TypeVarTuple.__module__
# but omitted __qualname__. As a top-level class, its __qualname__ equals
# its __name__.
# ---------------------------------------------------------------------------

invariant typing_extra7.TypeVarTuple.qualname:
  description: "typing.TypeVarTuple.__qualname__ == 'TypeVarTuple' (Python 3.11+)"
  category: TypeVarTuple
  kind: python_call_eq
  function: TypeVarTuple.__qualname__.__eq__
  args: ["TypeVarTuple"]
  expected: true
  version: ">=3.11"

# ---------------------------------------------------------------------------
# Table: __qualname__ for core typing classes not yet given __qualname__
# invariants
#
# All are top-level names in the typing module, so __qualname__ == __name__.
# ---------------------------------------------------------------------------

table typing_extra7.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Generic,    Generic.__qualname__.__eq__,    ["Generic"],    true]
    - [Protocol,   Protocol.__qualname__.__eq__,   ["Protocol"],   true]
    - [TypedDict,  TypedDict.__qualname__.__eq__,  ["TypedDict"],  true]
    - [NamedTuple, NamedTuple.__qualname__.__eq__,  ["NamedTuple"], true]

# ---------------------------------------------------------------------------
# Table: __qualname__ for public typing helper functions
#
# Module-level functions defined at the top of typing.py have
# __qualname__ == __name__ (no enclosing class scope).
# ---------------------------------------------------------------------------

table typing_extra7.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqualname

  columns: [id, function, args, expected]
  rows:
    - [get_type_hints,      get_type_hints.__qualname__.__eq__,      ["get_type_hints"],      true]
    - [cast,                cast.__qualname__.__eq__,                ["cast"],                true]
    - [overload,            overload.__qualname__.__eq__,            ["overload"],            true]
    - [runtime_checkable,   runtime_checkable.__qualname__.__eq__,   ["runtime_checkable"],   true]
    - [get_origin,          get_origin.__qualname__.__eq__,          ["get_origin"],          true]
    - [get_args,            get_args.__qualname__.__eq__,            ["get_args"],            true]

# ---------------------------------------------------------------------------
# TypeVar class — metaclass is 'type'
#
# typing.TypeVar is a regular Python class. Its metaclass (__class__) is
# 'type' (the default metaclass). Prior specs verified TypeVar.__name__,
# __module__, __qualname__, and instance attributes; this verifies the
# metaclass, which has not been recorded previously.
# ---------------------------------------------------------------------------

invariant typing_extra7.TypeVar.metaclass_is_type:
  description: "typing.TypeVar.__class__.__name__ == 'type' — TypeVar is an ordinary class"
  category: TypeVar
  kind: python_call_eq
  function: TypeVar.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# ParamSpec class — metaclass is 'type' (Python 3.10+)
#
# typing.ParamSpec is also a regular class with metaclass 'type'.
# ---------------------------------------------------------------------------

invariant typing_extra7.ParamSpec.metaclass_is_type:
  description: "typing.ParamSpec.__class__.__name__ == 'type' — ParamSpec is an ordinary class (Python 3.10+)"
  category: ParamSpec
  kind: python_call_eq
  function: ParamSpec.__class__.__name__.__eq__
  args: ["type"]
  expected: true
  version: ">=3.10"

# ---------------------------------------------------------------------------
# Generic.__bases__ — Generic's sole base is object
#
# typing.Generic is a top-level class whose only direct base is object.
# This confirms it is not itself a subclass of any other abstract class.
# ---------------------------------------------------------------------------

invariant typing_extra7.Generic.base_is_object:
  description: "typing.Generic.__bases__[0].__name__ == 'object'"
  category: Generic
  kind: python_call_eq
  function: Generic.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Protocol.__module__ check — additional confirmation
#
# typing.Protocol.__module__ == 'typing'. This is a module-level cross-check
# complementing the __qualname__ invariant above and distinct from any
# prior invariants which covered __name__ and __module__ separately.
# We add this as a standalone invariant to improve coverage density.
# ---------------------------------------------------------------------------

invariant typing_extra7.Protocol.base_name:
  description: "typing.Protocol.__bases__[0].__name__ == 'Generic' — Protocol extends Generic"
  category: Protocol
  kind: python_call_eq
  function: Protocol.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Generic"
