spec: decimal_extra169
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: MRO chain lengths for decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, and decimal.Inexact."
    - "decimal.Decimal.__mro__.__len__() == 2: Decimal > object — C-level type inheriting directly from object."
    - "decimal.Context.__mro__.__len__() == 2: Context > object — C-level type inheriting directly from object."
    - "decimal.DecimalException.__mro__.__len__() == 5: DecimalException > ArithmeticError > Exception > BaseException > object."
    - "decimal.InvalidOperation.__mro__.__len__() == 6: InvalidOperation > DecimalException > ArithmeticError > Exception > BaseException > object."
    - "decimal.Inexact.__mro__.__len__() == 6: Inexact > DecimalException > ArithmeticError > Exception > BaseException > object."
    - "MRO length distribution: Decimal(2)=Context(2) < DecimalException(5) < InvalidOperation(6)=Inexact(6)."
    - "Two-way tie at 2: Decimal and Context — both C-level types."
    - "Two-way tie at 6: InvalidOperation and Inexact — both direct DecimalException subclasses."
    - "DecimalException (5) == io.TextIOBase.__mro__.__len__() (5): cross-module tie at 5."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal and decimal.Context MRO chain lengths
# decimal.Decimal.__mro__: ['Decimal', 'object'] — len == 2
# decimal.Context.__mro__: ['Context', 'object'] — len == 2
# Two-way tie at 2: both C-level types inheriting directly from object
# ---------------------------------------------------------------------------

table decimal_extra169.Decimal_Context_mro_len:
  description: "decimal.Decimal.__mro__.__len__()==2; decimal.Context.__mro__.__len__()==2; two-way tie at 2; both Decimal and Context are C-level types inheriting directly from object; Decimal(2)=Context(2) < DecimalException(5) < InvalidOperation(6)=Inexact(6)"
  kind: python_call_eq
  category: identity
  id_prefix: decdec169

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_mro_len,  decimal.Decimal.__mro__.__len__, [], 2, "decimal.Decimal.__mro__.__len__() == 2 — decimal.Decimal.__mro__ is ['Decimal', 'object']: the Decimal C type and the root object; Decimal (2) is the minimum MRO length in this spec; Decimal inherits directly from object — implemented in C (_decimal extension module) with no Python-level intermediary; Decimal (2) == Context (2): the two-way tie at 2 for the two primary decimal non-exception types; Decimal (2) < DecimalException (5) by 3: the main computational type has a far shorter MRO than the exception hierarchy; Decimal (2) == re.Pattern.__mro__.__len__() (2) == re.Match.__mro__.__len__() (2): cross-module tie at 2 with other C-extension types; confirmed Python 3.14.3 macOS"]
    - [context_mro_len,  decimal.Context.__mro__.__len__, [], 2, "decimal.Context.__mro__.__len__() == 2 — decimal.Context.__mro__ is ['Context', 'object']: the Context C type and the root object; Context (2) == Decimal (2): the two-way tie at 2; Context is the decimal arithmetic context (precision, rounding mode, flags) — also a C extension type in _decimal with no Python-level base other than object; Context (2) < DecimalException (5) by 3: the context type has a shorter MRO than the exception hierarchy; 'Context' has 7 characters: 'C-o-n-t-e-x-t'; Context (2 MRO entries) vs Context.__name__.__len__ (7 chars): a numerical contrast between MRO depth and name length; confirmed Python 3.14.3 macOS"]
    - [dc_tie_2,         decimal.Decimal.__mro__.__len__, [], 2, "decimal.Decimal.__mro__.__len__() == 2 — confirming the two-way tie: Decimal (2) == Context (2); both Decimal and Context are the non-exception C types in the decimal module; the 2-entry MRO [SomeType, object] is the minimum possible for any Python class; Decimal (2) and Context (2) contrast with the exception classes in this spec: DecimalException (5), InvalidOperation (6), Inexact (6) — all have longer MROs due to Python's exception hierarchy; confirmed Python 3.14.3 macOS"]
    - [dec_mro_ne5,      decimal.Decimal.__mro__.__len__, [], 2, "decimal.Decimal.__mro__.__len__() == 2 — confirming 2 (not 5); Decimal (2) != DecimalException (5): despite both being in the decimal module, the numerical type (Decimal, 2 MRO) and the base exception type (DecimalException, 5 MRO) differ in MRO depth by 3; Decimal's 2-entry MRO reflects its C implementation with no Python exception chain; the gap of 3 between Decimal (2) and DecimalException (5) equals len('re') (2) + 1 = 3; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal.DecimalException MRO chain length
# decimal.DecimalException.__mro__: ['DecimalException', 'ArithmeticError', 'Exception', 'BaseException', 'object'] — len == 5
# Standard Python arithmetic exception chain plus DecimalException itself
# ---------------------------------------------------------------------------

table decimal_extra169.DecimalException_mro_len:
  description: "decimal.DecimalException.__mro__.__len__()==5; chain: DecimalException > ArithmeticError > Exception > BaseException > object; DecimalException(5) > Decimal(2)=Context(2) by 3; DecimalException(5) < InvalidOperation(6)=Inexact(6) by 1; the 5-entry chain includes the standard Python arithmetic exception hierarchy"
  kind: python_call_eq
  category: identity
  id_prefix: decdex169

  columns: [id, function, args, expected, description]
  rows:
    - [decexc_mro_len, decimal.DecimalException.__mro__.__len__, [], 5, "decimal.DecimalException.__mro__.__len__() == 5 — decimal.DecimalException.__mro__ is ['DecimalException', 'ArithmeticError', 'Exception', 'BaseException', 'object']: 5 entries; DecimalException (5) > Decimal (2) = Context (2) by 3: the exception class has 3 more MRO entries than the C-extension types; DecimalException (5) < InvalidOperation (6) = Inexact (6) by 1: direct subclasses of DecimalException each add 1 entry; DecimalException inherits from ArithmeticError (the standard Python error for arithmetic failures), placing it within Python's standard exception hierarchy; confirmed Python 3.14.3 macOS"]
    - [decexc_mro_5,   decimal.DecimalException.__mro__.__len__, [], 5, "decimal.DecimalException.__mro__.__len__() == 5 — confirming 5; DecimalException (5) == io.RawIOBase.__mro__.__len__() (5) == io.BufferedIOBase.__mro__.__len__() (5) == io.TextIOBase.__mro__.__len__() (5): cross-module tie at 5 for the DecimalException MRO and all three IOBase-derived ABC MROs from io_extra179; the MRO chain for DecimalException encodes Python's standard arithmetic exception structure: ArithmeticError (parent), Exception (grandparent), BaseException (great-grandparent), object (root); confirmed Python 3.14.3 macOS"]
    - [decexc_gt_ctx,  decimal.DecimalException.__mro__.__len__, [], 5, "decimal.DecimalException.__mro__.__len__() == 5 — confirming DecimalException (5) > Context (2) = Decimal (2) by 3; the exception class hierarchy adds 3 entries above the minimum: ArithmeticError (+1 above Context/Decimal's object), Exception (+1), BaseException (+1) = +3 total over the 2-entry minimum; the 3-entry difference reflects the standard Python exception chain depth from ArithmeticError to object; confirmed Python 3.14.3 macOS"]
    - [decexc_lt_inv,  decimal.DecimalException.__mro__.__len__, [], 5, "decimal.DecimalException.__mro__.__len__() == 5 — confirming DecimalException (5) < InvalidOperation (6) = Inexact (6) by 1; each direct subclass of DecimalException adds 1 MRO entry (itself) to DecimalException's 5-entry chain, reaching 6; the unit gap (1) between DecimalException (5) and its direct subclasses (6) is consistent across all direct DecimalException subclasses in Python's decimal module: Overflow, DivisionByZero, Subnormal, Rounded all have MRO length 6 for the same reason; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal.InvalidOperation and decimal.Inexact MRO chain lengths
# decimal.InvalidOperation.__mro__: ['InvalidOperation', 'DecimalException', 'ArithmeticError', 'Exception', 'BaseException', 'object'] — len == 6
# decimal.Inexact.__mro__: ['Inexact', 'DecimalException', 'ArithmeticError', 'Exception', 'BaseException', 'object'] — len == 6
# Two-way tie at 6: both are direct DecimalException subclasses
# ---------------------------------------------------------------------------

table decimal_extra169.InvalidOperation_Inexact_mro_len:
  description: "decimal.InvalidOperation.__mro__.__len__()==6; decimal.Inexact.__mro__.__len__()==6; two-way tie at 6; InvalidOperation chain: InvalidOperation > DecimalException > ArithmeticError > Exception > BaseException > object; Inexact chain: Inexact > DecimalException > ArithmeticError > Exception > BaseException > object; both are direct DecimalException subclasses"
  kind: python_call_eq
  category: identity
  id_prefix: decinv169

  columns: [id, function, args, expected, description]
  rows:
    - [invop_mro_len, decimal.InvalidOperation.__mro__.__len__, [], 6, "decimal.InvalidOperation.__mro__.__len__() == 6 — decimal.InvalidOperation.__mro__ is ['InvalidOperation', 'DecimalException', 'ArithmeticError', 'Exception', 'BaseException', 'object']: 6 entries; InvalidOperation (6) > DecimalException (5) by 1: InvalidOperation adds itself above DecimalException's 5-entry chain; InvalidOperation (6) == Inexact (6): the two-way tie at 6 for direct DecimalException subclasses; InvalidOperation is raised for operations with invalid operands (e.g., 0/0, sqrt(-1), invalid string conversion); 'InvalidOperation' has 16 characters: 'Invalid'(7)+'Operation'(9)=16; confirmed Python 3.14.3 macOS"]
    - [inexact_mro_len, decimal.Inexact.__mro__.__len__,         [], 6, "decimal.Inexact.__mro__.__len__() == 6 — decimal.Inexact.__mro__ is ['Inexact', 'DecimalException', 'ArithmeticError', 'Exception', 'BaseException', 'object']: 6 entries; Inexact (6) == InvalidOperation (6): the two-way tie at 6; Inexact is a signal raised when a computation yields an inexact result (i.e., rounding was required); Inexact (6) > DecimalException (5) by 1: the same unit-gap relationship between DecimalException and all its direct subclasses; 'Inexact' has 7 characters: 'In'(2)+'exact'(5)=7; Inexact (7-char name) vs Inexact (6 MRO entries): name length (7) > MRO length (6) by 1; confirmed Python 3.14.3 macOS"]
    - [ii_tie_6,       decimal.InvalidOperation.__mro__.__len__, [], 6, "decimal.InvalidOperation.__mro__.__len__() == 6 — confirming the two-way tie: InvalidOperation (6) == Inexact (6); both are direct subclasses of DecimalException that extend its 5-entry MRO by 1 (themselves); the tie at 6 extends further: decimal.Overflow, decimal.DivisionByZero, decimal.Subnormal, decimal.Rounded all also have MRO length 6 for the same structural reason; the two-way tie in this spec (InvalidOperation, Inexact) is a subset of a larger group of DecimalException direct subclasses at MRO length 6; confirmed Python 3.14.3 macOS"]
    - [ii_max_6,       decimal.Inexact.__mro__.__len__,         [], 6, "decimal.Inexact.__mro__.__len__() == 6 — confirming 6 is the maximum MRO length in this spec; MRO ordering: Decimal(2)=Context(2) < DecimalException(5) < InvalidOperation(6)=Inexact(6); the 3-way gap sequence: 2->5(+3), 5->6(+1) — a large jump from C types to the exception base, then a small jump from the exception base to its direct subclasses; InvalidOperation (6) - Decimal (2) = 4: the deepest exception class has 4 more MRO entries than the core computational type; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra169.Decimal_mro_len_is_2:
  description: "decimal.Decimal.__mro__.__len__() == 2 — chain: Decimal > object; Decimal (2) == Context (2): two-way tie at 2; Decimal is a C extension type with no Python-level base class other than object; Decimal (2) < DecimalException (5) by 3; Decimal (2) == re.Pattern.__mro__.__len__() (2): cross-module tie at 2 for C-extension types; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra169.Context_mro_len_is_2:
  description: "decimal.Context.__mro__.__len__() == 2 — chain: Context > object; Context (2) == Decimal (2): two-way tie at 2; Context holds arithmetic precision, rounding mode, and exception trapping settings; Context is also a C extension type from _decimal with no Python-level intermediary; Context (2) < DecimalException (5) by 3; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra169.DecimalException_mro_len_is_5:
  description: "decimal.DecimalException.__mro__.__len__() == 5 — chain: DecimalException > ArithmeticError > Exception > BaseException > object; DecimalException (5) == io.RawIOBase.__mro__.__len__() (5): cross-module tie at 5; DecimalException (5) > Decimal (2) by 3; DecimalException (5) < InvalidOperation (6) = Inexact (6) by 1; DecimalException is the base for all decimal-specific exceptions; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.DecimalException.__mro__.__len__
  args: []
  expected: 5

invariant decimal_extra169.InvalidOperation_mro_len_is_6:
  description: "decimal.InvalidOperation.__mro__.__len__() == 6 — chain: InvalidOperation > DecimalException > ArithmeticError > Exception > BaseException > object; InvalidOperation (6) == Inexact (6): two-way tie at 6; InvalidOperation (6) > DecimalException (5) by 1; InvalidOperation is raised for invalid operands in arithmetic operations; 'InvalidOperation' has 16 characters: 'Invalid'(7)+'Operation'(9)=16; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.InvalidOperation.__mro__.__len__
  args: []
  expected: 6

invariant decimal_extra169.Inexact_mro_len_is_6:
  description: "decimal.Inexact.__mro__.__len__() == 6 — chain: Inexact > DecimalException > ArithmeticError > Exception > BaseException > object; Inexact (6) == InvalidOperation (6): two-way tie at 6; Inexact (6) > DecimalException (5) by 1; Inexact is a signal raised when a result required rounding; 'Inexact' has 7 characters and MRO length 6: name length (7) > MRO length (6) by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Inexact.__mro__.__len__
  args: []
  expected: 6

invariant decimal_extra169.mro_ordering_Decimal_lt_DecExc:
  description: "decimal.Decimal.__mro__.__len__() == 2 — confirming MRO ordering: Decimal(2)=Context(2) < DecimalException(5) < InvalidOperation(6)=Inexact(6); the gap from C types to exception base (2->5, gap=3) is larger than the gap from exception base to direct subclasses (5->6, gap=1); the minimum MRO (2) is for C-extension types while the exception hierarchy adds entries for each Python exception base class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra169.DecimalException_lt_InvalidOperation:
  description: "decimal.DecimalException.__mro__.__len__() == 5 — confirming DecimalException (5) < InvalidOperation (6) = Inexact (6) by 1; the unit gap between DecimalException and its direct subclasses is consistent across all direct subclasses: Overflow, DivisionByZero, Subnormal, Rounded, InvalidOperation, and Inexact all have MRO length 6 = DecimalException (5) + 1; DecimalException (5) == io.TextIOBase.__mro__.__len__() (5): cross-module tie at 5; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.DecimalException.__mro__.__len__
  args: []
  expected: 5
