spec: functools_extra92
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra91

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra91.zspec.zsdl."
    - "This spec covers: functools callable identity via __class__.__name__ — whether each export is a 'builtin_function_or_method', 'type', or 'function' (Wave 250)."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is implemented in _functoolsmodule.c as a C builtin. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is implemented in _functoolsmodule.c as a C builtin. Verified with Python 3.14.3."
    - "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is a pure-Python function in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.partial.__class__.__name__ == 'type' — partial is a C extension type in _functoolsmodule.c. Verified with Python 3.14.3."
    - "functools.partialmethod.__class__.__name__ == 'type' — partialmethod is a pure-Python class in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.update_wrapper.__class__.__name__ == 'function' — update_wrapper is a pure-Python function in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.wraps.__class__.__name__ == 'function' — wraps is a pure-Python function in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.total_ordering.__class__.__name__ == 'function' — total_ordering is a pure-Python function in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.singledispatch.__class__.__name__ == 'function' — singledispatch is a pure-Python function in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.cached_property.__class__.__name__ == 'type' — cached_property is a pure-Python class in Lib/functools.py. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# C builtins: reduce and cmp_to_key __class__.__name__ == 'builtin_function_or_method'
#
# Wave 250 theme: functools callable identity — C builtins.
#
# functools.reduce.__class__.__name__.__eq__('builtin_function_or_method')    == True
# functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True
#
# No prior functools spec checks __class__.__name__ for callables via functoolsclsid92. New to extra92.
# ---------------------------------------------------------------------------

table functools_extra92.c_builtins_class_name:
  description: "reduce/cmp_to_key __class__.__name__==builtin_function_or_method; C builtins from _functoolsmodule.c; wave 250; new to extra92"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsclsid92

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_name_eq_builtin,
       reduce.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is implemented in Modules/_functoolsmodule.c as a C builtin function; __class__ is <class 'builtin_function_or_method'>; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; no prior functools spec checks reduce.__class__.__name__ via functoolsclsid92; new to extra92"]
    - [cmp_to_key_class_name_eq_builtin,
       cmp_to_key.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — cmp_to_key is implemented in Modules/_functoolsmodule.c as a C builtin function; __class__ is <class 'builtin_function_or_method'>; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; no prior functools spec checks cmp_to_key.__class__.__name__ via functoolsclsid92; new to extra92"]
    - [reduce_class_name_ne_type,
       reduce.__class__.__name__.__eq__,
       ["type"],
       false,
       "functools.reduce.__class__.__name__.__eq__('type') == False — reduce is a C builtin function, not a type; its __class__.__name__ is 'builtin_function_or_method', not 'type'; str.__eq__('type') returns False; confirms reduce is not a class; new to extra92"]
    - [cmp_to_key_class_name_ne_function,
       cmp_to_key.__class__.__name__.__eq__,
       ["function"],
       false,
       "functools.cmp_to_key.__class__.__name__.__eq__('function') == False — cmp_to_key is a C builtin function, not a Python function; its __class__.__name__ is 'builtin_function_or_method', not 'function'; str.__eq__('function') returns False; confirms cmp_to_key is not a pure-Python function; new to extra92"]

# ---------------------------------------------------------------------------
# Type classes: partial, partialmethod, cached_property __class__.__name__ == 'type'
#
# Wave 250 theme: functools callable identity — type classes.
#
# functools.partial.__class__.__name__.__eq__('type')          == True
# functools.partialmethod.__class__.__name__.__eq__('type')    == True
# functools.cached_property.__class__.__name__.__eq__('type')  == True
#
# No prior functools spec checks __class__.__name__ for type classes via functoolsclsid92. New to extra92.
# ---------------------------------------------------------------------------

table functools_extra92.type_classes_class_name:
  description: "partial/partialmethod/cached_property __class__.__name__==type; wave 250; new to extra92"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsclsid92

  columns: [id, function, args, expected, description]
  rows:
    - [partial_class_name_eq_type,
       partial.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is a C extension type defined in Modules/_functoolsmodule.c; its __class__ is <class 'type'> (the metaclass); __class__.__name__ is 'type'; str.__eq__('type') returns True; no prior functools spec checks partial.__class__.__name__ via functoolsclsid92; new to extra92"]
    - [partialmethod_class_name_eq_type,
       partialmethod.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partialmethod.__class__.__name__.__eq__('type') == True — partialmethod is a pure-Python class defined in Lib/functools.py; its __class__ is <class 'type'> (the metaclass); __class__.__name__ is 'type'; str.__eq__('type') returns True; no prior functools spec checks partialmethod.__class__.__name__ via functoolsclsid92; new to extra92"]
    - [cached_property_class_name_eq_type,
       cached_property.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.cached_property.__class__.__name__.__eq__('type') == True — cached_property is a pure-Python class defined in Lib/functools.py; its __class__ is <class 'type'> (the metaclass); __class__.__name__ is 'type'; str.__eq__('type') returns True; no prior functools spec checks cached_property.__class__.__name__ via functoolsclsid92; new to extra92"]
    - [partial_class_name_ne_function,
       partial.__class__.__name__.__eq__,
       ["function"],
       false,
       "functools.partial.__class__.__name__.__eq__('function') == False — partial is a type (class), not a Python function; its __class__.__name__ is 'type', not 'function'; str.__eq__('function') returns False; confirms partial is a class not a callable function; new to extra92"]

# ---------------------------------------------------------------------------
# Python functions: lru_cache, update_wrapper, wraps, total_ordering, singledispatch
# __class__.__name__ == 'function'
#
# Wave 250 theme: functools callable identity — pure-Python functions.
#
# functools.lru_cache.__class__.__name__.__eq__('function')       == True
# functools.update_wrapper.__class__.__name__.__eq__('function')  == True
# functools.wraps.__class__.__name__.__eq__('function')           == True
# functools.total_ordering.__class__.__name__.__eq__('function')  == True
#
# No prior functools spec checks these __class__.__name__ values via functoolsclsid92. New to extra92.
# ---------------------------------------------------------------------------

table functools_extra92.python_functions_class_name:
  description: "lru_cache/update_wrapper/wraps/total_ordering __class__.__name__==function; pure-Python functions; wave 250; new to extra92"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsclsid92

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_class_name_eq_function,
       lru_cache.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is a pure-Python function defined in Lib/functools.py that returns a decorator; its __class__ is <class 'function'>; __class__.__name__ is 'function'; str.__eq__('function') returns True; no prior functools spec checks lru_cache.__class__.__name__ via functoolsclsid92; new to extra92"]
    - [update_wrapper_class_name_eq_function,
       update_wrapper.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.update_wrapper.__class__.__name__.__eq__('function') == True — update_wrapper is a pure-Python function defined in Lib/functools.py that copies attributes from a wrapper to a wrapped function; its __class__ is <class 'function'>; __class__.__name__ is 'function'; str.__eq__('function') returns True; no prior functools spec checks update_wrapper.__class__.__name__ via functoolsclsid92; new to extra92"]
    - [wraps_class_name_eq_function,
       wraps.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.wraps.__class__.__name__.__eq__('function') == True — wraps is a pure-Python function defined in Lib/functools.py that is a decorator factory calling update_wrapper; its __class__ is <class 'function'>; __class__.__name__ is 'function'; str.__eq__('function') returns True; no prior functools spec checks wraps.__class__.__name__ via functoolsclsid92; new to extra92"]
    - [total_ordering_class_name_eq_function,
       total_ordering.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.total_ordering.__class__.__name__.__eq__('function') == True — total_ordering is a pure-Python class decorator function defined in Lib/functools.py that fills in missing comparison methods; its __class__ is <class 'function'>; __class__.__name__ is 'function'; str.__eq__('function') returns True; no prior functools spec checks total_ordering.__class__.__name__ via functoolsclsid92; new to extra92"]

# ---------------------------------------------------------------------------
# Cross-check: singledispatch function + negative checks for type classes
#
# Wave 250 theme: functools callable identity cross-checks.
#
# functools.singledispatch.__class__.__name__.__eq__('function')          == True
# functools.partialmethod.__class__.__name__.__eq__('builtin_function_or_method') == False
# functools.cached_property.__class__.__name__.__eq__('function')         == False
# functools.lru_cache.__class__.__name__.__eq__('type')                   == False
#
# No prior functools spec checks singledispatch __class__.__name__ via functoolsclsid92. New to extra92.
# ---------------------------------------------------------------------------

table functools_extra92.cross_check_class_names:
  description: "singledispatch __class__.__name__==function; type-class and function negative cross-checks; wave 250; new to extra92"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsclsid92

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_class_name_eq_function,
       singledispatch.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.singledispatch.__class__.__name__.__eq__('function') == True — singledispatch is a pure-Python function defined in Lib/functools.py that transforms a function into a single-dispatch generic function; its __class__ is <class 'function'>; __class__.__name__ is 'function'; str.__eq__('function') returns True; no prior functools spec checks singledispatch.__class__.__name__ via functoolsclsid92; new to extra92"]
    - [partialmethod_class_name_ne_builtin,
       partialmethod.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       false,
       "functools.partialmethod.__class__.__name__.__eq__('builtin_function_or_method') == False — partialmethod is a Python class, not a C builtin function; its __class__.__name__ is 'type', not 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns False; confirms partialmethod is a class; new to extra92"]
    - [cached_property_class_name_ne_function,
       cached_property.__class__.__name__.__eq__,
       ["function"],
       false,
       "functools.cached_property.__class__.__name__.__eq__('function') == False — cached_property is a Python class (descriptor), not a plain function; its __class__.__name__ is 'type', not 'function'; str.__eq__('function') returns False; confirms cached_property is a class not a function; new to extra92"]
    - [lru_cache_class_name_ne_type,
       lru_cache.__class__.__name__.__eq__,
       ["type"],
       false,
       "functools.lru_cache.__class__.__name__.__eq__('type') == False — lru_cache is a pure-Python function, not a class; its __class__.__name__ is 'function', not 'type'; str.__eq__('type') returns False; confirms lru_cache is a function not a type; new to extra92"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra92
# ---------------------------------------------------------------------------

invariant functools_extra92.reduce_class_name_builtin:
  description: "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C builtin from _functoolsmodule.c; wave 250; new to extra92"
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra92.partial_class_name_type:
  description: "functools.partial.__class__.__name__.__eq__('type') == True — partial is a C extension type; its metaclass is 'type'; wave 250; new to extra92"
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra92.lru_cache_class_name_function:
  description: "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is a pure-Python function; wave 250; new to extra92"
  kind: python_call_eq
  function: lru_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra92.singledispatch_class_name_function:
  description: "functools.singledispatch.__class__.__name__.__eq__('function') == True — singledispatch is a pure-Python function; wave 250; new to extra92"
  kind: python_call_eq
  function: singledispatch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra92.cached_property_class_name_type:
  description: "functools.cached_property.__class__.__name__.__eq__('type') == True — cached_property is a Python class (type); wave 250; new to extra92"
  kind: python_call_eq
  function: cached_property.__class__.__name__.__eq__
  args: ["type"]
  expected: true
