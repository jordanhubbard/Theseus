spec: asyncio_extra144
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-stream.html — Python asyncio streams documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio task documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/streams.py, Lib/asyncio/tasks.py"
  notes:
    - "This spec covers: asyncio.StreamReader — __doc__==None (no docstring; len==0); __name__=='StreamReader' (len=12); __module__=='asyncio.streams' (len=15). asyncio.StreamWriter — __doc__.__len__()==271 (multi-paragraph doc beginning 'Wraps a Transport.'); __name__=='StreamWriter' (len=12); __module__=='asyncio.streams' (len=15). asyncio.StreamReaderProtocol — __doc__.__len__()==297; __name__=='StreamReaderProtocol' (len=20); __module__=='asyncio.streams' (len=15). asyncio.open_connection — __qualname__=='open_connection' (len=15); __module__=='asyncio.streams' (len=15); __doc__.__len__()==658; co_argcount==2; co_varnames.__len__()==9. asyncio.start_server — __qualname__=='start_server' (len=12); __module__=='asyncio.streams' (len=15); __doc__.__len__()==854; co_argcount==3; co_varnames.__len__()==6. asyncio.sleep — __qualname__=='sleep' (len=5); __module__=='asyncio.tasks' (len=13); __doc__=='Coroutine that completes after a given time (in seconds).' (len=57); co_argcount==2; co_varnames.__len__()==5. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All three stream classes (StreamReader, StreamWriter, StreamReaderProtocol) share __module__=='asyncio.streams' (len=15). asyncio.open_connection and asyncio.start_server are coroutine functions also in asyncio.streams. asyncio.sleep is in asyncio.tasks (len=13, 2 shorter than asyncio.streams). StreamReader.__doc__ is None (no docstring); StreamWriter.__doc__.__len__()==271; StreamReaderProtocol.__doc__.__len__()==297 (26 more than StreamWriter). open_connection co_argcount==2 ('host','port'); start_server co_argcount==3 ('client_connected_cb','host','port'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio stream classes __name__, __module__, __doc__ — extra144
#
# asyncio.StreamReader.__doc__                     == None (no docstring)
# asyncio.StreamReader.__name__                    == 'StreamReader'         (len=12)
# asyncio.StreamReader.__module__                  == 'asyncio.streams'      (len=15)
# asyncio.StreamWriter.__doc__.__len__()           == 271
# asyncio.StreamWriter.__name__                    == 'StreamWriter'         (len=12)
# asyncio.StreamReaderProtocol.__doc__.__len__()   == 297
# asyncio.StreamReaderProtocol.__name__            == 'StreamReaderProtocol' (len=20)
# ---------------------------------------------------------------------------

table asyncio_extra144.stream_classes:
  description: "asyncio stream class __name__, __module__, and __doc__ checks — StreamReader.__name__.__eq__('StreamReader')==True (len=12: 'Stream'=6+'Reader'=6=12; no __doc__, it is None); StreamReader.__module__.__eq__('asyncio.streams')==True (len=15: 'asyncio'=7+'.'=1+'streams'=7=15, shared by StreamWriter and StreamReaderProtocol); StreamWriter.__doc__.__len__()==271 (multi-paragraph doc beginning 'Wraps a Transport.' and describing write, writelines, can_write_eof, get_extra_info, drain, and close methods); StreamWriter.__name__.__eq__('StreamWriter')==True (len=12: same length as StreamReader); StreamReaderProtocol.__doc__.__len__()==297 (doc begins 'Helper class to adapt between Protocol and StreamReader.', 26 chars longer than StreamWriter doc); StreamReaderProtocol.__name__.__eq__('StreamReaderProtocol')==True (len=20: 'Stream'=6+'Reader'=6+'Protocol'=8=20, the longest of the three stream class names); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciostream144

  columns: [id, function, args, expected, description]
  rows:
    - [sr_name_eq,   asyncio.StreamReader.__name__.__eq__,             ["StreamReader"],          true,  "asyncio.StreamReader.__name__ == 'StreamReader' (len=12); verified with Python 3.14.3"]
    - [sr_name_len,  asyncio.StreamReader.__name__.__len__,             [],                        12,    "asyncio.StreamReader.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [sr_mod_eq,    asyncio.StreamReader.__module__.__eq__,           ["asyncio.streams"],        true,  "asyncio.StreamReader.__module__ == 'asyncio.streams' (len=15); verified with Python 3.14.3"]
    - [sr_mod_len,   asyncio.StreamReader.__module__.__len__,           [],                        15,    "asyncio.StreamReader.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [sw_doc_len,   asyncio.StreamWriter.__doc__.__len__,              [],                        271,   "asyncio.StreamWriter.__doc__.__len__() == 271; verified with Python 3.14.3"]
    - [sw_name_eq,   asyncio.StreamWriter.__name__.__eq__,             ["StreamWriter"],           true,  "asyncio.StreamWriter.__name__ == 'StreamWriter' (len=12); verified with Python 3.14.3"]
    - [sw_name_len,  asyncio.StreamWriter.__name__.__len__,             [],                        12,    "asyncio.StreamWriter.__name__.__len__() == 12 (same as StreamReader); verified with Python 3.14.3"]
    - [sw_mod_len,   asyncio.StreamWriter.__module__.__len__,           [],                        15,    "asyncio.StreamWriter.__module__.__len__() == 15 ('asyncio.streams'); verified with Python 3.14.3"]
    - [srp_doc_len,  asyncio.StreamReaderProtocol.__doc__.__len__,      [],                        297,   "asyncio.StreamReaderProtocol.__doc__.__len__() == 297; verified with Python 3.14.3"]
    - [srp_name_eq,  asyncio.StreamReaderProtocol.__name__.__eq__,     ["StreamReaderProtocol"],   true,  "asyncio.StreamReaderProtocol.__name__ == 'StreamReaderProtocol' (len=20); verified with Python 3.14.3"]
    - [srp_name_len, asyncio.StreamReaderProtocol.__name__.__len__,     [],                        20,    "asyncio.StreamReaderProtocol.__name__.__len__() == 20; verified with Python 3.14.3"]
    - [srp_mod_len,  asyncio.StreamReaderProtocol.__module__.__len__,   [],                        15,    "asyncio.StreamReaderProtocol.__module__.__len__() == 15 ('asyncio.streams'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.open_connection and start_server — extra144
#
# asyncio.open_connection.__qualname__       == 'open_connection' (len=15)
# asyncio.open_connection.__module__         == 'asyncio.streams' (len=15)
# asyncio.open_connection.__doc__.__len__()  == 658
# asyncio.open_connection co_argcount        == 2
# asyncio.open_connection co_varnames len    == 9
# asyncio.start_server.__qualname__          == 'start_server'    (len=12)
# asyncio.start_server.__doc__.__len__()     == 854
# asyncio.start_server co_argcount          == 3
# asyncio.start_server co_varnames len      == 6
# ---------------------------------------------------------------------------

table asyncio_extra144.open_connection_start_server:
  description: "asyncio.open_connection and start_server __qualname__, __module__, __doc__, and code checks — open_connection.__qualname__.__eq__('open_connection')==True (len=15: top-level coroutine function, qualname equals name; same len as __module__=='asyncio.streams' len=15); open_connection.__module__.__eq__('asyncio.streams')==True (len=15); open_connection.__doc__.__len__()==658 (multi-paragraph doc beginning 'A wrapper for create_connection() returning a (reader, writer) pair.'); open_connection.__code__.co_argcount.__eq__(2)==True ('host','port'); open_connection.__code__.co_varnames.__len__()==9 ('host','port','limit','kwds','loop','reader','transport','_','writer' — 2 params + 7 locals); start_server.__qualname__.__eq__('start_server')==True (len=12: 3 shorter than open_connection qualname); start_server.__module__.__eq__('asyncio.streams')==True (len=15: same module); start_server.__doc__.__len__()==854 (the longer of the two functions, describing the server socket and connected client callbacks); start_server.__code__.co_argcount.__eq__(3)==True ('client_connected_cb','host','port'); start_server.__code__.co_varnames.__len__()==6 ('client_connected_cb','host','port','limit','kwds','factory' — 3 params + 3 locals); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioconn144

  columns: [id, function, args, expected, description]
  rows:
    - [oc_qn_eq,    asyncio.open_connection.__qualname__.__eq__,          ["open_connection"],  true,  "asyncio.open_connection.__qualname__ == 'open_connection' (len=15); verified with Python 3.14.3"]
    - [oc_qn_len,   asyncio.open_connection.__qualname__.__len__,          [],                  15,    "asyncio.open_connection.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [oc_mod_eq,   asyncio.open_connection.__module__.__eq__,            ["asyncio.streams"],  true,  "asyncio.open_connection.__module__ == 'asyncio.streams' (len=15); verified with Python 3.14.3"]
    - [oc_mod_len,  asyncio.open_connection.__module__.__len__,            [],                  15,    "asyncio.open_connection.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [oc_doc_len,  asyncio.open_connection.__doc__.__len__,               [],                  658,   "asyncio.open_connection.__doc__.__len__() == 658; verified with Python 3.14.3"]
    - [oc_argc,     asyncio.open_connection.__code__.co_argcount.__eq__,  [2],                  true,  "asyncio.open_connection.__code__.co_argcount == 2 ('host','port'); verified with Python 3.14.3"]
    - [oc_vlen,     asyncio.open_connection.__code__.co_varnames.__len__,  [],                  9,     "asyncio.open_connection.__code__.co_varnames.__len__() == 9; verified with Python 3.14.3"]
    - [ss_qn_eq,    asyncio.start_server.__qualname__.__eq__,             ["start_server"],     true,  "asyncio.start_server.__qualname__ == 'start_server' (len=12); verified with Python 3.14.3"]
    - [ss_qn_len,   asyncio.start_server.__qualname__.__len__,             [],                  12,    "asyncio.start_server.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [ss_mod_len,  asyncio.start_server.__module__.__len__,               [],                  15,    "asyncio.start_server.__module__.__len__() == 15 ('asyncio.streams'); verified with Python 3.14.3"]
    - [ss_doc_len,  asyncio.start_server.__doc__.__len__,                  [],                  854,   "asyncio.start_server.__doc__.__len__() == 854; verified with Python 3.14.3"]
    - [ss_argc,     asyncio.start_server.__code__.co_argcount.__eq__,     [3],                  true,  "asyncio.start_server.__code__.co_argcount == 3 ('client_connected_cb','host','port'); verified with Python 3.14.3"]
    - [ss_vlen,     asyncio.start_server.__code__.co_varnames.__len__,     [],                  6,     "asyncio.start_server.__code__.co_varnames.__len__() == 6; verified with Python 3.14.3"]

