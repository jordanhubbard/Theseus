table asyncio_extra144.sleep_func:
  description: "asyncio.sleep __qualname__, __module__, __doc__, and code checks — sleep.__qualname__.__eq__('sleep')==True (len=5: the shortest qualname in this spec, top-level coroutine function); sleep.__module__.__eq__('asyncio.tasks')==True (len=13: 'asyncio'=7+'.'=1+'tasks'=5=13, the only function in this spec not in asyncio.streams); sleep.__doc__.__eq__('Coroutine that completes after a given time (in seconds).')==True (len=57: complete one-sentence description); sleep.__code__.co_argcount.__eq__(2)==True ('delay','result'); sleep.__code__.co_varnames.__len__()==5 ('delay','result','loop','future','h' — 2 params + 3 locals); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosleep144

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,    asyncio.sleep.__qualname__.__eq__,          ["sleep"],                                                       true,  "asyncio.sleep.__qualname__ == 'sleep' (len=5); verified with Python 3.14.3"]
    - [qn_len,   asyncio.sleep.__qualname__.__len__,          [],                                                             5,     "asyncio.sleep.__qualname__.__len__() == 5; verified with Python 3.14.3"]
    - [mod_eq,   asyncio.sleep.__module__.__eq__,            ["asyncio.tasks"],                                               true,  "asyncio.sleep.__module__ == 'asyncio.tasks' (len=13); verified with Python 3.14.3"]
    - [mod_len,  asyncio.sleep.__module__.__len__,            [],                                                             13,    "asyncio.sleep.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [doc_eq,   asyncio.sleep.__doc__.__eq__,               ["Coroutine that completes after a given time (in seconds)."],   true,  "asyncio.sleep.__doc__ == 'Coroutine that completes after a given time (in seconds).' (len=57); verified with Python 3.14.3"]
    - [doc_len,  asyncio.sleep.__doc__.__len__,               [],                                                             57,    "asyncio.sleep.__doc__.__len__() == 57; verified with Python 3.14.3"]
    - [argc,     asyncio.sleep.__code__.co_argcount.__eq__,  [2],                                                             true,  "asyncio.sleep.__code__.co_argcount == 2 ('delay','result'); verified with Python 3.14.3"]
    - [vlen,     asyncio.sleep.__code__.co_varnames.__len__,  [],                                                             5,     "asyncio.sleep.__code__.co_varnames.__len__() == 5; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra144
# ---------------------------------------------------------------------------

invariant asyncio_extra144.stream_reader_name_len_12:
  description: "asyncio.StreamReader.__name__.__len__() == 12 — asyncio.StreamReader.__name__ is 'StreamReader' (12 chars: 'Stream'=6+'Reader'=6=12); StreamReader has no __doc__ (it is None); StreamReader.__module__=='asyncio.streams' (len=15); StreamReader ties with StreamWriter for the shortest stream class name (both len=12); compare StreamReaderProtocol (len=20: the longest); NEW in extra144: first standalone StreamReader name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.StreamReader.__name__.__len__
  args: []
  expected: 12

invariant asyncio_extra144.stream_writer_doc_len_271:
  description: "asyncio.StreamWriter.__doc__.__len__() == 271 — asyncio.StreamWriter.__doc__ is a 271-char multi-paragraph doc beginning 'Wraps a Transport.' and describing write(), writelines(), can_write_eof(), get_extra_info(), drain(), and close() methods; StreamWriter.__name__=='StreamWriter' (len=12); StreamWriter.__module__=='asyncio.streams' (len=15); compare StreamReaderProtocol.__doc__.__len__()==297 (26 chars longer); NEW in extra144: first standalone StreamWriter doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.StreamWriter.__doc__.__len__
  args: []
  expected: 271

invariant asyncio_extra144.stream_reader_protocol_doc_len_297:
  description: "asyncio.StreamReaderProtocol.__doc__.__len__() == 297 — asyncio.StreamReaderProtocol.__doc__ is a 297-char doc beginning 'Helper class to adapt between Protocol and StreamReader.' (the longest __doc__ of the three stream classes; 26 chars more than StreamWriter at 271; StreamReader has no doc); StreamReaderProtocol.__name__=='StreamReaderProtocol' (len=20: the longest class name in this spec); StreamReaderProtocol.__module__=='asyncio.streams' (len=15); NEW in extra144: first standalone StreamReaderProtocol doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.StreamReaderProtocol.__doc__.__len__
  args: []
  expected: 297

invariant asyncio_extra144.open_connection_doc_len_658:
  description: "asyncio.open_connection.__doc__.__len__() == 658 — asyncio.open_connection.__doc__ is a 658-char doc beginning 'A wrapper for create_connection() returning a (reader, writer) pair.'; open_connection.__qualname__=='open_connection' (len=15); open_connection.__module__=='asyncio.streams' (len=15: same length as qualname); co_argcount==2 ('host','port'); co_varnames.__len__()==9; compare start_server.__doc__.__len__()==854 (196 chars longer); NEW in extra144: first standalone open_connection doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.open_connection.__doc__.__len__
  args: []
  expected: 658

invariant asyncio_extra144.start_server_doc_len_854:
  description: "asyncio.start_server.__doc__.__len__() == 854 — asyncio.start_server.__doc__ is an 854-char doc beginning 'Start a socket server, call back for each client connected.' (the longest __doc__ in this spec; 196 chars more than open_connection at 658); start_server.__qualname__=='start_server' (len=12); start_server.__module__=='asyncio.streams' (len=15); co_argcount==3 ('client_connected_cb','host','port'); co_varnames.__len__()==6; NEW in extra144: first standalone start_server doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.start_server.__doc__.__len__
  args: []
  expected: 854

invariant asyncio_extra144.sleep_module_len_13:
  description: "asyncio.sleep.__module__.__len__() == 13 — asyncio.sleep.__module__ is 'asyncio.tasks' (13 chars: 'asyncio'=7+'.'=1+'tasks'=5=13); this is 2 chars shorter than 'asyncio.streams' (len=15); sleep is the only function in this spec not from asyncio.streams; sleep.__qualname__=='sleep' (len=5: the shortest qualname in this spec); sleep.__doc__.__len__()==57; co_argcount==2; co_varnames.__len__()==5; NEW in extra144: first standalone sleep module length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.sleep.__module__.__len__
  args: []
  expected: 13

invariant asyncio_extra144.open_connection_varnames_len_9:
  description: "asyncio.open_connection.__code__.co_varnames.__len__() == 9 — asyncio.open_connection.__code__.co_varnames is ('host','port','limit','kwds','loop','reader','transport','_','writer') (9 elements: 2 params + 7 locals); this is the largest varnames tuple of the coroutine functions in this spec (compare: start_server=6, sleep=5); open_connection co_argcount==2; open_connection.__qualname__=='open_connection' (len=15); NEW in extra144: first standalone open_connection co_varnames length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.open_connection.__code__.co_varnames.__len__
  args: []
  expected: 9
