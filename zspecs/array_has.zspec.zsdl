spec: array_has
version: ">=1.0.0"
backend: node(array-has)

docs: https://www.npmjs.com/package/array-has

provenance:
  derived_from:
    - "array-has README — https://www.npmjs.com/package/array-has"
    - "Test vectors verified with array-has via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "array-has source"
  notes:
    - "array-has is an npm package. Install: npm install array-has"
    - "Returns true if the array contains the given element."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_has.check:
  kind: node_module_call_eq
  function: ~
  category: arrays
  id_prefix: arrhas

  columns: [id, args, expected]
  rows:
    - [found,     [[1, 2, 3], 2],   true]
    - [not_found, [[1, 2, 3], 4],   false]
    - [string,    [["a", "b"], "a"],  true]

