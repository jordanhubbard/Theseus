spec: uuid_extra2386
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 606 (_extra2386): __str__ and __repr__ implementation type classification."
    - "uuid.UUID defines both __repr__ and __str__ in Python → both are 'function'."
    - "uuid.SafeUUID (IntEnum subclass) also has __repr__ and __str__ of type 'function' via enum machinery."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra2386.uuid_str_repr:
  description: "uuid.UUID __repr__ and __str__ implementation type via .__class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu2386
  columns: [id, function, args, expected]
  rows:
    - ["uu2386001", "uuid.UUID.__repr__.__class__.__name__", [], "function"]
    - ["uu2386002", "uuid.UUID.__str__.__class__.__name__", [], "function"]

table uuid_extra2386.safeuuid_str_repr:
  description: "uuid.SafeUUID __repr__ and __str__ implementation type via .__class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu2386
  columns: [id, function, args, expected]
  rows:
    - ["uu2386003", "uuid.SafeUUID.__repr__.__class__.__name__", [], "function"]
    - ["uu2386004", "uuid.SafeUUID.__str__.__class__.__name__", [], "function"]

table uuid_extra2386.uuid_repr_is_function:
  description: "uuid.UUID defines __repr__ in Python so .__repr__.__class__.__name__ is 'function'"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu2386
  columns: [id, function, args, expected]
  rows:
    - ["uu2386005", "uuid.UUID.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["uu2386006", "uuid.UUID.__str__.__class__.__name__.__eq__", ["function"], true]

table uuid_extra2386.safeuuid_repr_is_function:
  description: "uuid.SafeUUID (IntEnum) defines __repr__ and __str__ via enum machinery → 'function'"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu2386
  columns: [id, function, args, expected]
  rows:
    - ["uu2386007", "uuid.SafeUUID.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["uu2386008", "uuid.SafeUUID.__str__.__class__.__name__.__eq__", ["function"], true]

table uuid_extra2386.uuid_not_wrapper_descriptor:
  description: "uuid.UUID and uuid.SafeUUID do NOT use inherited C-slot wrapper_descriptor for __repr__ or __str__"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu2386
  columns: [id, function, args, expected]
  rows:
    - ["uu2386009", "uuid.UUID.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], false]
    - ["uu2386010", "uuid.UUID.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], false]
    - ["uu2386011", "uuid.SafeUUID.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], false]
    - ["uu2386012", "uuid.SafeUUID.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], false]

table uuid_extra2386.uuid_consistency:
  description: "Cross-check: both uuid.UUID and uuid.SafeUUID have 'function' for __repr__ and __str__"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu2386
  columns: [id, function, args, expected]
  rows:
    - ["uu2386013", "uuid.UUID.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["uu2386014", "uuid.UUID.__str__.__class__.__name__.__eq__", ["function"], true]
    - ["uu2386015", "uuid.SafeUUID.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["uu2386016", "uuid.SafeUUID.__str__.__class__.__name__.__eq__", ["function"], true]

table uuid_extra2386.uuid_repr_str_same_kind:
  description: "For uuid.UUID and uuid.SafeUUID, __repr__ and __str__ share the same implementation kind 'function'"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu2386
  columns: [id, function, args, expected]
  rows:
    - ["uu2386017", "uuid.UUID.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["uu2386018", "uuid.UUID.__str__.__class__.__name__.__eq__", ["function"], true]
    - ["uu2386019", "uuid.SafeUUID.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["uu2386020", "uuid.SafeUUID.__str__.__class__.__name__.__eq__", ["function"], true]
