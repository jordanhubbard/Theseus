spec: compute_variance
version: ">=3.0.0"
backend: node(compute-variance)

docs: https://www.npmjs.com/package/compute-variance

provenance:
  derived_from:
    - "compute-variance README — https://www.npmjs.com/package/compute-variance"
    - "Test vectors verified with compute-variance via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "compute-variance source"
  notes:
    - "compute-variance is an npm package. Install: npm install compute-variance"
    - "Returns the population variance of an array of numbers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table compute_variance.variance:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: cvar

  columns: [id, args, expected]
  rows:
    - [spread,   [[1, 2, 3]],     1]
    - [uniform,  [[2, 2, 2]],     0]
    - [two,      [[1, 3]],        2]
