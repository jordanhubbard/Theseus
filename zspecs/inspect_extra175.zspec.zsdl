spec: inspect_extra175
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Signature class identity — inspect.Signature.__name__=='Signature' (len=9); inspect.Signature.__module__=='inspect'; inspect.Signature.__mro__.__len__()==2 (Signature > object); inspect.BoundArguments.__name__=='BoundArguments' (len=14); inspect.BoundArguments.__module__=='inspect'; inspect.FullArgSpec.__class__.__name__=='type' (FullArgSpec is a namedtuple class so __class__ is the metaclass 'type'); inspect.FullArgSpec.__bases__[0].__name__=='tuple' (namedtuple inherits from tuple); inspect.FullArgSpec.__mro__.__len__()==3 (FullArgSpec > tuple > object)."
    - "inspect.Signature.__name__ == 'Signature' — inspect.Signature is a Python class in Lib/inspect.py representing the signature of a callable; its __name__ is 'Signature', 9 characters. Verified with Python 3.14.3."
    - "inspect.Signature.__module__ == 'inspect' — Signature is defined in Lib/inspect.py; its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.Signature.__mro__.__len__() == 2 — Signature inherits directly from object; its MRO is (Signature, object). Verified with Python 3.14.3."
    - "inspect.BoundArguments.__name__ == 'BoundArguments' — BoundArguments is a Python class in Lib/inspect.py representing a call mapping; its __name__ is 'BoundArguments', 14 characters. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__module__ == 'inspect' — BoundArguments is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__class__.__name__ == 'type' — FullArgSpec is a namedtuple class; as a class object its __class__ is the metaclass 'type'; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — as a namedtuple, FullArgSpec inherits from tuple; its first base class __name__ is 'tuple'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__mro__.__len__() == 3 — FullArgSpec is a namedtuple; its MRO is (FullArgSpec, tuple, object), length 3. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Signature class __name__ and __module__
#
# inspect.Signature.__name__ == 'Signature'
# inspect.Signature.__name__.__len__() == 9
# inspect.Signature.__module__ == 'inspect'
# inspect.Signature.__module__.__len__() == 7
#
# inspect.Signature is a Python class defined in Lib/inspect.py representing
# the call signature of a callable object. Its __name__ is 'Signature' (9
# chars) and its __module__ is 'inspect' (7 chars). New to extra175.
# ---------------------------------------------------------------------------

table inspect_extra175.signature_name_and_module:
  description: "inspect.Signature.__name__ 'Signature' len 9; __module__ 'inspect' len 7; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsig175

  columns: [id, function, args, expected, description]
  rows:
    - [signature_name_eq,
       "Signature.__name__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — inspect.Signature is a Python class in Lib/inspect.py representing the call signature of a callable, including its parameters and return annotation; its __name__ is 'Signature'; str.__eq__('Signature') returns True; new to extra175"]
    - [signature_name_len_9,
       "Signature.__name__.__len__",
       [],
       9,
       "inspect.Signature.__name__.__len__() == 9 — the name 'Signature' has exactly 9 characters: S-i-g-n-a-t-u-r-e; str.__len__() returns 9; new to extra175"]
    - [signature_module_inspect,
       "Signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — inspect.Signature is a Python class defined in Lib/inspect.py; its __module__ is the string 'inspect'; str.__eq__('inspect') returns True; new to extra175"]
    - [signature_module_len_7,
       "Signature.__module__.__len__",
       [],
       7,
       "inspect.Signature.__module__.__len__() == 7 — the module name 'inspect' has exactly 7 characters: i-n-s-p-e-c-t; str.__len__() returns 7; new to extra175"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature __mro__ length and entries
#
# inspect.Signature.__mro__.__len__() == 2
# inspect.Signature.__mro__[0].__name__ == 'Signature'
# inspect.Signature.__mro__[1].__name__ == 'object'
# inspect.Signature.__mro__.__len__() != 3
#
# inspect.Signature inherits directly from object with no intermediate base
# classes. Its MRO is (Signature, object), a 2-tuple. New to extra175.
# ---------------------------------------------------------------------------

table inspect_extra175.signature_mro:
  description: "inspect.Signature.__mro__: len 2, mro[0] 'Signature', mro[1] 'object'; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsig175

  columns: [id, function, args, expected, description]
  rows:
    - [signature_mro_len_2,
       "Signature.__mro__.__len__",
       [],
       2,
       "inspect.Signature.__mro__.__len__() == 2 — inspect.Signature is a Python class defined in Lib/inspect.py representing a callable's call signature; it inherits directly from object with no intermediate base classes; its __mro__ is (Signature, object), a tuple of length 2; tuple.__len__() returns 2; new to extra175"]
    - ["signature_mro_0_signature",
       "Signature.__mro__[0].__name__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__mro__[0].__name__.__eq__('Signature') == True — the first entry in Signature.__mro__ is the Signature class itself; its __name__ is 'Signature'; str.__eq__('Signature') returns True; new to extra175"]
    - ["signature_mro_1_object",
       "Signature.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__mro__[1].__name__.__eq__('object') == True — the second entry in Signature.__mro__ is the base class object; its __name__ is 'object'; this confirms Signature inherits directly from object; str.__eq__('object') returns True; new to extra175"]
    - [signature_mro_not_3,
       "Signature.__mro__.__len__",
       [],
       2,
       "inspect.Signature.__mro__.__len__() == 2 (not 3) — Signature inherits only from object; there is no intermediate class; tuple.__len__() returns 2; new to extra175"]

# ---------------------------------------------------------------------------
# Table 3: inspect.BoundArguments class __name__ and __module__
#
# inspect.BoundArguments.__name__ == 'BoundArguments'
# inspect.BoundArguments.__name__.__len__() == 14
# inspect.BoundArguments.__module__ == 'inspect'
# inspect.BoundArguments.__module__.__len__() == 7
#
# inspect.BoundArguments is a Python class defined in Lib/inspect.py. It is
# returned by Signature.bind() and Signature.bind_partial() and holds the
# mapping of parameters to actual argument values. Its __name__ is
# 'BoundArguments' (14 chars). New to extra175.
# ---------------------------------------------------------------------------

table inspect_extra175.boundarguments_name_and_module:
  description: "inspect.BoundArguments.__name__ 'BoundArguments' len 14; __module__ 'inspect' len 7; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsig175

  columns: [id, function, args, expected, description]
  rows:
    - [boundargs_name_eq,
       "BoundArguments.__name__.__eq__",
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — inspect.BoundArguments is a Python class in Lib/inspect.py returned by Signature.bind() that maps parameter names to argument values; its __name__ is 'BoundArguments'; str.__eq__('BoundArguments') returns True; new to extra175"]
    - [boundargs_name_len_14,
       "BoundArguments.__name__.__len__",
       [],
       14,
       "inspect.BoundArguments.__name__.__len__() == 14 — the name 'BoundArguments' has exactly 14 characters: B-o-u-n-d-A-r-g-u-m-e-n-t-s; str.__len__() returns 14; new to extra175"]
    - [boundargs_module_inspect,
       "BoundArguments.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is a Python class defined in Lib/inspect.py; its __module__ is the string 'inspect'; str.__eq__('inspect') returns True; new to extra175"]
    - [boundargs_module_len_7,
       "BoundArguments.__module__.__len__",
       [],
       7,
       "inspect.BoundArguments.__module__.__len__() == 7 — the module name 'inspect' has exactly 7 characters: i-n-s-p-e-c-t; str.__len__() returns 7; new to extra175"]

# ---------------------------------------------------------------------------
# Table 4: inspect.FullArgSpec namedtuple class identity
#
# inspect.FullArgSpec.__class__.__name__ == 'type'
# inspect.FullArgSpec.__bases__[0].__name__ == 'tuple'
# inspect.FullArgSpec.__mro__.__len__() == 3
# inspect.FullArgSpec.__name__ == 'FullArgSpec'
#
# inspect.FullArgSpec is a namedtuple class (created via collections.namedtuple)
# defined in Lib/inspect.py. As a class object, __class__ is the metaclass 'type',
# so __class__.__name__ is 'type'. Since namedtuple creates a subclass of tuple,
# FullArgSpec.__bases__[0].__name__ == 'tuple', and its full MRO is
# (FullArgSpec, tuple, object), giving __mro__.__len__() == 3.
# New to extra175.
# ---------------------------------------------------------------------------

table inspect_extra175.fullargspec_namedtuple_identity:
  description: "inspect.FullArgSpec: __class__.__name__ 'type'; __bases__[0] 'tuple'; __mro__ len 3; __name__ 'FullArgSpec'; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsig175

  columns: [id, function, args, expected, description]
  rows:
    - [fullargspec_class_name_type,
       "FullArgSpec.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.FullArgSpec.__class__.__name__.__eq__('type') == True — FullArgSpec is a namedtuple class; as a class object, its __class__ is the metaclass 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra175"]
    - ["fullargspec_bases_0_tuple",
       "FullArgSpec.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True — FullArgSpec is created by collections.namedtuple which produces a subclass of the built-in tuple type; its first (and only) direct base class is tuple; __bases__[0].__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra175"]
    - [fullargspec_mro_len_3,
       "FullArgSpec.__mro__.__len__",
       [],
       3,
       "inspect.FullArgSpec.__mro__.__len__() == 3 — FullArgSpec is a namedtuple and thus a subclass of tuple; its MRO is (FullArgSpec, tuple, object), a tuple of length 3; tuple.__len__() returns 3; new to extra175"]
    - [fullargspec_name_eq,
       "FullArgSpec.__name__.__eq__",
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__name__.__eq__('FullArgSpec') == True — FullArgSpec is a namedtuple class; its __name__ attribute is 'FullArgSpec'; str.__eq__('FullArgSpec') returns True; new to extra175"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra175
# ---------------------------------------------------------------------------

invariant inspect_extra175.signature_name_signature:
  description: "inspect.Signature.__name__ == 'Signature' — Python class in Lib/inspect.py with __name__ 'Signature' (9 chars); new to extra175"
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra175.signature_name_len_9:
  description: "inspect.Signature.__name__.__len__() == 9 — 'Signature' is 9 characters long; new to extra175"
  kind: python_call_eq
  function: Signature.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra175.signature_module_inspect:
  description: "inspect.Signature.__module__ == 'inspect' — Signature is defined in Lib/inspect.py; new to extra175"
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra175.signature_mro_len_2:
  description: "inspect.Signature.__mro__.__len__() == 2 — Signature inherits directly from object; MRO is (Signature, object); new to extra175"
  kind: python_call_eq
  function: Signature.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra175.boundarguments_name_boundarguments:
  description: "inspect.BoundArguments.__name__ == 'BoundArguments' — Python class in Lib/inspect.py with __name__ 'BoundArguments' (14 chars); new to extra175"
  kind: python_call_eq
  function: BoundArguments.__name__.__eq__
  args: ["BoundArguments"]
  expected: true

invariant inspect_extra175.boundarguments_module_inspect:
  description: "inspect.BoundArguments.__module__ == 'inspect' — BoundArguments is defined in Lib/inspect.py; new to extra175"
  kind: python_call_eq
  function: BoundArguments.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra175.fullargspec_class_name_type:
  description: "inspect.FullArgSpec.__class__.__name__ == 'type' — FullArgSpec is a namedtuple class; its __class__ is the metaclass 'type'; new to extra175"
  kind: python_call_eq
  function: FullArgSpec.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra175.fullargspec_bases_0_tuple:
  description: "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — namedtuple inherits from tuple; FullArgSpec's first base is tuple; new to extra175"
  kind: python_call_eq
  function: "FullArgSpec.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true

