spec: decimal_extra192
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec covers decimal.Decimal arithmetic method qualnames not covered by prior decimal_extra specs."
    - "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (len=15); confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__sub__.__qualname__ == 'Decimal.__sub__' (len=15); confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__' (len=15); confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__truediv__.__qualname__ == 'Decimal.__truediv__' (len=19); confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__neg__.__qualname__ == 'Decimal.__neg__' (len=15); confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__abs__.__qualname__ == 'Decimal.__abs__' (len=15); confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__round__.__qualname__ == 'Decimal.__round__' (len=17); confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__float__.__qualname__ == 'Decimal.__float__' (len=17); confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal binary arithmetic method qualnames
# __add__=='Decimal.__add__'(15), __sub__=='Decimal.__sub__'(15), __mul__=='Decimal.__mul__'(15)
# ---------------------------------------------------------------------------

table decimal_extra192.decimal_add_sub_mul_qualnames:
  description: "decimal.Decimal binary arithmetic qualnames: __add__='Decimal.__add__'(15), __sub__='Decimal.__sub__'(15), __mul__='Decimal.__mul__'(15)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalarith192

  columns: [id, function, args, expected, description]
  rows:
    - [add_qualname_eq,  Decimal.__add__.__qualname__.__eq__,  ["Decimal.__add__"], true, "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (len=15); addition operator; confirmed Python 3.14.3 macOS"]
    - [sub_qualname_eq,  Decimal.__sub__.__qualname__.__eq__,  ["Decimal.__sub__"], true, "decimal.Decimal.__sub__.__qualname__ == 'Decimal.__sub__' (len=15); subtraction operator; confirmed Python 3.14.3 macOS"]
    - [mul_qualname_eq,  Decimal.__mul__.__qualname__.__eq__,  ["Decimal.__mul__"], true, "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__' (len=15); multiplication operator; confirmed Python 3.14.3 macOS"]
    - [add_qualname_len, Decimal.__add__.__qualname__.__len__, [],                  15,   "decimal.Decimal.__add__.__qualname__.__len__() == 15 — Decimal.__add__ has 15 characters; confirmed Python 3.14.3 macOS"]
    - [sub_qualname_len, Decimal.__sub__.__qualname__.__len__, [],                  15,   "decimal.Decimal.__sub__.__qualname__.__len__() == 15 — Decimal.__sub__ has 15 characters; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal.Decimal truediv and unary method qualnames
# __truediv__=='Decimal.__truediv__'(19), __neg__=='Decimal.__neg__'(15), __abs__=='Decimal.__abs__'(15)
# ---------------------------------------------------------------------------

table decimal_extra192.decimal_truediv_neg_abs_qualnames:
  description: "decimal.Decimal truediv/unary qualnames: __truediv__='Decimal.__truediv__'(19), __neg__='Decimal.__neg__'(15), __abs__='Decimal.__abs__'(15)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalarith192

  columns: [id, function, args, expected, description]
  rows:
    - [truediv_qualname_eq,  Decimal.__truediv__.__qualname__.__eq__,  ["Decimal.__truediv__"], true, "decimal.Decimal.__truediv__.__qualname__ == 'Decimal.__truediv__' (len=19); true division operator; confirmed Python 3.14.3 macOS"]
    - [neg_qualname_eq,      Decimal.__neg__.__qualname__.__eq__,      ["Decimal.__neg__"],     true, "decimal.Decimal.__neg__.__qualname__ == 'Decimal.__neg__' (len=15); unary negation; confirmed Python 3.14.3 macOS"]
    - [abs_qualname_eq,      Decimal.__abs__.__qualname__.__eq__,      ["Decimal.__abs__"],     true, "decimal.Decimal.__abs__.__qualname__ == 'Decimal.__abs__' (len=15); absolute value; confirmed Python 3.14.3 macOS"]
    - [truediv_qualname_len, Decimal.__truediv__.__qualname__.__len__, [],                      19,   "decimal.Decimal.__truediv__.__qualname__.__len__() == 19 — Decimal.__truediv__ has 19 characters; confirmed Python 3.14.3 macOS"]
    - [mul_qualname_len,     Decimal.__mul__.__qualname__.__len__,     [],                      15,   "decimal.Decimal.__mul__.__qualname__.__len__() == 15 — Decimal.__mul__ has 15 characters; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal.Decimal round and float conversion method qualnames
# __round__=='Decimal.__round__'(17), __float__=='Decimal.__float__'(17)
# ---------------------------------------------------------------------------

table decimal_extra192.decimal_round_float_qualnames:
  description: "decimal.Decimal round and float qualnames: __round__='Decimal.__round__'(17), __float__='Decimal.__float__'(17)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalarith192

  columns: [id, function, args, expected, description]
  rows:
    - [round_qualname_eq,   Decimal.__round__.__qualname__.__eq__,   ["Decimal.__round__"],  true, "decimal.Decimal.__round__.__qualname__ == 'Decimal.__round__' (len=17); round() support; confirmed Python 3.14.3 macOS"]
    - [float_qualname_eq,   Decimal.__float__.__qualname__.__eq__,   ["Decimal.__float__"],  true, "decimal.Decimal.__float__.__qualname__ == 'Decimal.__float__' (len=17); float() conversion; confirmed Python 3.14.3 macOS"]
    - [round_qualname_len,  Decimal.__round__.__qualname__.__len__,  [],                     17,   "decimal.Decimal.__round__.__qualname__.__len__() == 17 — Decimal.__round__ has 17 characters; confirmed Python 3.14.3 macOS"]
    - [float_qualname_len,  Decimal.__float__.__qualname__.__len__,  [],                     17,   "decimal.Decimal.__float__.__qualname__.__len__() == 17 — Decimal.__float__ has 17 characters; confirmed Python 3.14.3 macOS"]
    - [neg_qualname_len,    Decimal.__neg__.__qualname__.__len__,    [],                     15,   "decimal.Decimal.__neg__.__qualname__.__len__() == 15 — Decimal.__neg__ has 15 characters; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra192.add_qualname_eq:
  description: "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' — qualified name (len=15) confirms the addition operator belongs to Decimal; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Decimal.__add__.__qualname__.__eq__
  args: ["Decimal.__add__"]
  expected: true

invariant decimal_extra192.sub_qualname_eq:
  description: "decimal.Decimal.__sub__.__qualname__ == 'Decimal.__sub__' — qualified name (len=15) confirms the subtraction operator belongs to Decimal; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Decimal.__sub__.__qualname__.__eq__
  args: ["Decimal.__sub__"]
  expected: true

invariant decimal_extra192.mul_qualname_eq:
  description: "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__' — qualified name (len=15) confirms the multiplication operator belongs to Decimal; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Decimal.__mul__.__qualname__.__eq__
  args: ["Decimal.__mul__"]
  expected: true

invariant decimal_extra192.truediv_qualname_eq:
  description: "decimal.Decimal.__truediv__.__qualname__ == 'Decimal.__truediv__' — qualified name (len=19) confirms true division belongs to Decimal; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Decimal.__truediv__.__qualname__.__eq__
  args: ["Decimal.__truediv__"]
  expected: true

invariant decimal_extra192.neg_qualname_eq:
  description: "decimal.Decimal.__neg__.__qualname__ == 'Decimal.__neg__' — qualified name (len=15) confirms the unary negation operator belongs to Decimal; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Decimal.__neg__.__qualname__.__eq__
  args: ["Decimal.__neg__"]
  expected: true

invariant decimal_extra192.abs_qualname_eq:
  description: "decimal.Decimal.__abs__.__qualname__ == 'Decimal.__abs__' — qualified name (len=15) confirms the absolute value operator belongs to Decimal; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Decimal.__abs__.__qualname__.__eq__
  args: ["Decimal.__abs__"]
  expected: true

invariant decimal_extra192.round_qualname_eq:
  description: "decimal.Decimal.__round__.__qualname__ == 'Decimal.__round__' — qualified name (len=17) confirms round() support belongs to Decimal; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Decimal.__round__.__qualname__.__eq__
  args: ["Decimal.__round__"]
  expected: true

invariant decimal_extra192.float_qualname_eq:
  description: "decimal.Decimal.__float__.__qualname__ == 'Decimal.__float__' — qualified name (len=17) confirms float() conversion belongs to Decimal; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Decimal.__float__.__qualname__.__eq__
  args: ["Decimal.__float__"]
  expected: true
