spec: textwrap_extra4
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends prior textwrap specs."
    - "Focus: __module__ and __name__ for textwrap functions and TextWrapper class attributes."
    - "textwrap.TextWrapper.__name__ == 'TextWrapper'."
    - "textwrap.TextWrapper.__module__ == 'textwrap'."
    - "textwrap.wrap.__name__ == 'wrap'."
    - "textwrap.fill.__name__ == 'fill'."
    - "textwrap.dedent.__name__ == 'dedent'."
    - "textwrap.indent.__name__ == 'indent'."
    - "textwrap.shorten.__name__ == 'shorten'."
    - "textwrap.TextWrapper().width == 70 (default)."
    - "textwrap.TextWrapper().initial_indent == '' (default)."
    - "textwrap.TextWrapper().subsequent_indent == '' (default)."
    - "textwrap.TextWrapper().expand_tabs == True (default)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table textwrap_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [wrap,    wrap.__name__.__eq__,    ["wrap"],    true]
    - [fill,    fill.__name__.__eq__,    ["fill"],    true]
    - [dedent,  dedent.__name__.__eq__,  ["dedent"],  true]
    - [indent,  indent.__name__.__eq__,  ["indent"],  true]
    - [shorten, shorten.__name__.__eq__, ["shorten"], true]

table textwrap_extra4.function_modules:
  kind: python_call_eq
  category: module
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [wrap,    wrap.__module__.__eq__,    ["textwrap"], true]
    - [fill,    fill.__module__.__eq__,    ["textwrap"], true]
    - [dedent,  dedent.__module__.__eq__,  ["textwrap"], true]
    - [indent,  indent.__module__.__eq__,  ["textwrap"], true]
    - [shorten, shorten.__module__.__eq__, ["textwrap"], true]

invariant textwrap_extra4.TextWrapper.class_name:
  description: "textwrap.TextWrapper.__name__ == 'TextWrapper'"
  category: class_names
  kind: python_call_eq
  function: TextWrapper.__name__.__eq__
  args: ["TextWrapper"]
  expected: true

invariant textwrap_extra4.TextWrapper.module:
  description: "textwrap.TextWrapper.__module__ == 'textwrap'"
  category: module
  kind: python_call_eq
  function: TextWrapper.__module__.__eq__
  args: ["textwrap"]
  expected: true

invariant textwrap_extra4.TextWrapper.width_default:
  description: "textwrap.TextWrapper().width == 70"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: width.__eq__
  method_args: [70]
  expected: true

invariant textwrap_extra4.TextWrapper.expand_tabs_default:
  description: "textwrap.TextWrapper().expand_tabs == True"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: expand_tabs.__eq__
  method_args: [true]
  expected: true

invariant textwrap_extra4.wrap.hello_world:
  description: "textwrap.wrap('hello world', width=100) == ['hello world']"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["hello world"]
  expected: ["hello world"]

invariant textwrap_extra4.fill.hello_world:
  description: "textwrap.fill('hello world', width=100) == 'hello world'"
  category: fill
  kind: python_call_eq
  function: fill
  args: ["hello world"]
  expected: "hello world"

invariant textwrap_extra4.dedent.basic:
  description: "textwrap.dedent('  hello') == 'hello'"
  category: dedent
  kind: python_call_eq
  function: dedent
  args: ["  hello"]
  expected: "hello"

invariant textwrap_extra4.dedent.multiline:
  description: "textwrap.dedent('  a\\n  b') == 'a\\nb'"
  category: dedent
  kind: python_call_eq
  function: dedent
  args: ["  a\n  b"]
  expected: "a\nb"
