spec: operator
version: ">=3.0"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified by running Python 3.14.3 operator module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "The operator module provides function equivalents for Python's built-in operators."
    - "operator.truediv() always returns float (true division), unlike operator.floordiv() which returns int for int args."
    - "operator.and_(), operator.or_() have trailing underscores to avoid shadowing Python builtins 'and', 'or'."
    - "operator.not_() returns bool, not_(False)==True, not_(True)==False."
    - "operator.truth() is equivalent to bool(); truth(0)==False, truth(1)==True."
    - "operator.contains(a, b) tests 'b in a' (note argument order: container first, item second)."
    - "operator.length_hint() returns len() for sequences that implement __len__."
    - "operator.concat() is for sequence concatenation (str, list, tuple); not for numeric addition."
    - "operator.index() calls __index__() and is only valid for integer-like types."
    - "operator.getitem(a, b) is equivalent to a[b]."
    - "All expected values verified by running Python 3.14.3 on macOS Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Arithmetic operators
# ---------------------------------------------------------------------------

table operator.arithmetic.vectors:
  kind: python_call_eq
  category: arithmetic
  id_prefix: arith
  function: add

  columns: [id, function, args, expected]
  rows:
    - [add_ints,    add,      [3, 4],    7]
    - [sub_ints,    sub,      [10, 3],   7]
    - [mul_ints,    mul,      [3, 4],    12]
    - [truediv,     truediv,  [7, 2],    3.5]
    - [floordiv,    floordiv, [7, 2],    3]
    - [mod_ints,    mod,      [10, 3],   1]
    - [pow_ints,    pow,      [2, 10],   1024]

# ---------------------------------------------------------------------------
# Unary operators
# ---------------------------------------------------------------------------

invariant operator.neg.positive_input:
  description: "operator.neg(5) == -5"
  category: unary
  kind: python_call_eq
  function: neg
  args: [5]
  expected: -5

invariant operator.neg.negative_input:
  description: "operator.neg(-3) == 3"
  category: unary
  kind: python_call_eq
  function: neg
  args: [-3]
  expected: 3

invariant operator.abs.negative:
  description: "operator.abs(-7) == 7"
  category: unary
  kind: python_call_eq
  function: abs
  args: [-7]
  expected: 7

invariant operator.abs.positive:
  description: "operator.abs(7) == 7"
  category: unary
  kind: python_call_eq
  function: abs
  args: [7]
  expected: 7

# ---------------------------------------------------------------------------
# Comparison operators
# ---------------------------------------------------------------------------

table operator.comparison.vectors:
  kind: python_call_eq
  category: comparison
  id_prefix: cmp

  columns: [id, function, args, expected]
  rows:
    - [lt_true,  lt, [3, 5],  true]
    - [lt_false, lt, [5, 3],  false]
    - [le_equal, le, [5, 5],  true]
    - [le_less,  le, [4, 5],  true]
    - [eq_true,  eq, [4, 4],  true]
    - [eq_false, eq, [4, 5],  false]
    - [ne_true,  ne, [3, 4],  true]
    - [ne_false, ne, [4, 4],  false]
    - [gt_true,  gt, [5, 3],  true]
    - [gt_false, gt, [3, 5],  false]
    - [ge_equal, ge, [5, 5],  true]
    - [ge_great, ge, [6, 5],  true]

# ---------------------------------------------------------------------------
# Bitwise operators
# ---------------------------------------------------------------------------

invariant operator.and_.basic:
  description: "operator.and_(0b1010, 0b1100) == 8 (bitwise AND)"
  category: bitwise
  kind: python_call_eq
  function: and_
  args: [10, 12]
  expected: 8

invariant operator.or_.basic:
  description: "operator.or_(0b1010, 0b0101) == 15 (bitwise OR)"
  category: bitwise
  kind: python_call_eq
  function: or_
  args: [10, 5]
  expected: 15

invariant operator.xor.basic:
  description: "operator.xor(0b1010, 0b1100) == 6 (bitwise XOR)"
  category: bitwise
  kind: python_call_eq
  function: xor
  args: [10, 12]
  expected: 6

# ---------------------------------------------------------------------------
# Logical operators
# ---------------------------------------------------------------------------

invariant operator.not_.false_input:
  description: "operator.not_(False) == True"
  category: logical
  kind: python_call_eq
  function: not_
  args: [false]
  expected: true

invariant operator.not_.true_input:
  description: "operator.not_(True) == False"
  category: logical
  kind: python_call_eq
  function: not_
  args: [true]
  expected: false

invariant operator.truth.zero:
  description: "operator.truth(0) == False"
  category: logical
  kind: python_call_eq
  function: truth
  args: [0]
  expected: false

invariant operator.truth.one:
  description: "operator.truth(1) == True"
  category: logical
  kind: python_call_eq
  function: truth
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# Sequence operators
# ---------------------------------------------------------------------------

invariant operator.contains.member:
  description: "operator.contains([1,2,3], 2) == True (2 in [1,2,3])"
  category: sequence
  kind: python_call_eq
  function: contains
  args: [[1, 2, 3], 2]
  expected: true

invariant operator.contains.non_member:
  description: "operator.contains([1,2,3], 5) == False (5 not in [1,2,3])"
  category: sequence
  kind: python_call_eq
  function: contains
  args: [[1, 2, 3], 5]
  expected: false

invariant operator.length_hint.list:
  description: "operator.length_hint([1,2,3]) == 3"
  category: sequence
  kind: python_call_eq
  function: length_hint
  args: [[1, 2, 3]]
  expected: 3

invariant operator.concat.strings:
  description: "operator.concat('foo', 'bar') == 'foobar'"
  category: sequence
  kind: python_call_eq
  function: concat
  args: ["foo", "bar"]
  expected: "foobar"

invariant operator.getitem.string_first:
  description: "operator.getitem('hello', 0) == 'h'"
  category: sequence
  kind: python_call_eq
  function: getitem
  args: ["hello", 0]
  expected: "h"

invariant operator.getitem.string_last:
  description: "operator.getitem('hello', 4) == 'o'"
  category: sequence
  kind: python_call_eq
  function: getitem
  args: ["hello", 4]
  expected: "o"

invariant operator.index.integer:
  description: "operator.index(42) == 42"
  category: sequence
  kind: python_call_eq
  function: index
  args: [42]
  expected: 42

