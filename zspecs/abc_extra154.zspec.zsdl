spec: abc_extra154
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.get_cache_token function identity and ABC/ABCMeta/abstractmethod class name verifications. abc.get_cache_token.__class__.__name__=='builtin_function_or_method' (len=26; get_cache_token is a C builtin from _abc extension module); abc.get_cache_token.__module__=='_abc' (len=4; the C extension module, NOT the Python 'abc' module — get_cache_token is implemented in Modules/_abc.c); abc.get_cache_token.__name__=='get_cache_token' (len=15: 'get'=3+'_'=1+'cache'=5+'_'=1+'token'=5=15); abc.ABC.__name__.__eq__('ABC')==True (len=3); abc.ABCMeta.__name__.__eq__('ABCMeta')==True (len=7); abc.abstractmethod.__class__.__name__.__eq__('function')==True (abstractmethod is a pure Python function in abc, NOT a builtin). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.get_cache_token.__module__=='_abc' (len=4: '_'=1+'abc'=3=4; NOT 'abc') — get_cache_token is implemented in the C extension Modules/_abc.c; it returns the current ABC cache token (a monotonically increasing integer that is bumped whenever a new virtual subclass is registered); its __module__ is '_abc' (the C extension) not 'abc' (the Python wrapper); compare: abc.update_abstractmethods.__module__=='abc' (update_abstractmethods is a pure Python function in abc.py); this module difference reflects the C vs Python implementation boundary. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.get_cache_token.__class__.__name__=='builtin_function_or_method' (len=26: 'builtin_function_or_method'='builtin'=7+'_'=1+'function'=8+'_'=1+'or'=2+'_'=1+'method'=6=26); this is the class name for C-implemented callable objects (built-in functions and methods); compare: abc.abstractmethod.__class__.__name__=='function' (len=8; abstractmethod is a pure Python function); get_cache_token (C builtin, len=26) vs abstractmethod (Python function, len=8) — the class name length difference reflects C vs Python implementation. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractmethod.__class__.__name__=='function' — abstractmethod is a pure Python function defined in Lib/abc.py; its __class__.__name__ is 'function' (len=8); this is different from abc.get_cache_token.__class__.__name__=='builtin_function_or_method' (len=26; C extension); abc.abstractmethod.__module__=='abc' (Python module); abc.abstractmethod.__name__=='abstractmethod' (len=14). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.get_cache_token function identity — extra154
#
# abc.get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') == True
# abc.get_cache_token.__module__.__eq__('_abc')                                == True
# abc.get_cache_token.__name__.__eq__('get_cache_token')                       == True
# ---------------------------------------------------------------------------

table abc_extra154.abc_get_cache_token_identity:
  description: "abc.get_cache_token function identity checks in abcgct154 namespace — abc.get_cache_token.__class__.__name__=='builtin_function_or_method' (len=26: 'builtin_function_or_method'=26; get_cache_token is a C builtin from the _abc extension module — NOT a Python function; 'builtin_function_or_method' is the type name for C-implemented callable objects); abc.get_cache_token.__module__=='_abc' (len=4: '_'=1+'abc'=3=4; NOT 'abc' the Python module — get_cache_token is implemented in Modules/_abc.c and exposed through the _abc C extension; this contrasts with abc.update_abstractmethods.__module__=='abc' which is a Python function in abc.py); abc.get_cache_token.__name__=='get_cache_token' (len=15: 'get'=3+'_'=1+'cache'=5+'_'=1+'token'=5=15; get_cache_token() returns the current ABC cache token — an integer bumped whenever a virtual subclass is registered via ABCMeta.register()); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcgct154

  columns: [id, function, args, expected, description]
  rows:
    - [gct_cls_eq,   abc.get_cache_token.__class__.__name__.__eq__,  ["builtin_function_or_method"],  true,  "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' (len=26; C builtin); verified with Python 3.14.3"]
    - [gct_mod_eq,   abc.get_cache_token.__module__.__eq__,          ["_abc"],                        true,  "abc.get_cache_token.__module__ == '_abc' (len=4; C extension, NOT the Python 'abc' module); verified with Python 3.14.3"]
    - [gct_name_eq,  abc.get_cache_token.__name__.__eq__,            ["get_cache_token"],             true,  "abc.get_cache_token.__name__ == 'get_cache_token' (len=15); verified with Python 3.14.3"]
    - [gct_name_len, abc.get_cache_token.__name__.__len__,           [],                              15,    "abc.get_cache_token.__name__.__len__() == 15 ('get_cache_token'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.get_cache_token class name length and abc.abstractmethod class identity — extra154
#
# abc.get_cache_token.__class__.__name__.__len__() == 26
# abc.abstractmethod.__class__.__name__.__eq__('function') == True
# ---------------------------------------------------------------------------

table abc_extra154.abc_get_cache_token_vs_abstractmethod_class:
  description: "abc.get_cache_token __class__.__name__ length and abc.abstractmethod __class__.__name__ identity checks in abcgctam154 namespace — abc.get_cache_token.__class__.__name__.__len__()==26 ('builtin_function_or_method'=26 is the C builtin class name; this is the longest class name in the abc spec series); abc.abstractmethod.__class__.__name__.__eq__('function')==True (abstractmethod is a pure Python function; __class__.__name__=='function' (len=8)); the contrast: get_cache_token (C builtin, class name len=26) vs abstractmethod (Python function, class name len=8) — 18 chars longer for the C builtin type name; abc.abstractmethod.__module__=='abc' (Python abc module) vs abc.get_cache_token.__module__=='_abc' (C extension _abc module); abc.abstractmethod.__name__=='abstractmethod' (len=14: 'abstract'=8+'method'=6=14); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcgctam154

  columns: [id, function, args, expected, description]
  rows:
    - [gct_cls_len,   abc.get_cache_token.__class__.__name__.__len__,   [],               26,    "abc.get_cache_token.__class__.__name__.__len__() == 26 ('builtin_function_or_method'; longest class name in abc series); verified with Python 3.14.3"]
    - [am_cls_eq,     abc.abstractmethod.__class__.__name__.__eq__,     ["function"],     true,  "abc.abstractmethod.__class__.__name__ == 'function' (len=8; Python function, not C builtin); verified with Python 3.14.3"]
    - [am_cls_len,    abc.abstractmethod.__class__.__name__.__len__,    [],               8,     "abc.abstractmethod.__class__.__name__.__len__() == 8 ('function'; 18 shorter than builtin_function_or_method=26); verified with Python 3.14.3"]
    - [gct_mod_len,   abc.get_cache_token.__module__.__len__,           [],               4,     "abc.get_cache_token.__module__.__len__() == 4 ('_abc'; shortest module name in abc series); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC and abc.ABCMeta class name identity — extra154
#
# abc.ABC.__name__.__eq__('ABC')         == True
# abc.ABCMeta.__name__.__eq__('ABCMeta') == True
# abc.abstractmethod.__name__.__eq__('abstractmethod') == True
# ---------------------------------------------------------------------------

table abc_extra154.abc_class_name_identity:
  description: "abc.ABC, abc.ABCMeta, and abc.abstractmethod class name identity checks in abcnames154 namespace — abc.ABC.__name__.__eq__('ABC')==True (ABC.__name__=='ABC' (len=3: 'A'+'B'+'C'=3; the shortest name in the abc module; ABC is the convenience base class for abstract classes — subclassing ABC is equivalent to using ABCMeta as the metaclass)); abc.ABCMeta.__name__.__eq__('ABCMeta')==True (ABCMeta.__name__=='ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7; the metaclass for all ABCs; inherits from type)); abc.abstractmethod.__name__.__eq__('abstractmethod')==True (abstractmethod.__name__=='abstractmethod' (len=14: 'abstract'=8+'method'=6=14; the decorator for declaring abstract methods)); name length ordering: ABC(3) < ABCMeta(7) < abstractmethod(14); all three are core public names in the abc module's API; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcnames154

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name_eq,   abc.ABC.__name__.__eq__,            ["ABC"],             true,  "abc.ABC.__name__ == 'ABC' (len=3; convenience base for abstract classes); verified with Python 3.14.3"]
    - [abcm_name_eq,  abc.ABCMeta.__name__.__eq__,        ["ABCMeta"],         true,  "abc.ABCMeta.__name__ == 'ABCMeta' (len=7; metaclass for ABCs); verified with Python 3.14.3"]
    - [am_name_eq,    abc.abstractmethod.__name__.__eq__,  ["abstractmethod"],  true,  "abc.abstractmethod.__name__ == 'abstractmethod' (len=14; abstract method decorator); verified with Python 3.14.3"]
    - [abc_name_len,  abc.ABC.__name__.__len__,            [],                  3,     "abc.ABC.__name__.__len__() == 3 ('ABC'; shortest abc class name); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra154
# ---------------------------------------------------------------------------

invariant abc_extra154.abc_get_cache_token_class_is_builtin:
  description: "abc.get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') returns True — abc.get_cache_token is a C builtin function; its __class__.__name__ is 'builtin_function_or_method' (len=26: 'builtin'=7+'_'=1+'function'=8+'_'=1+'or'=2+'_'=1+'method'=6=26); 'builtin_function_or_method' is the type name for C-implemented callable objects (both built-in functions like len and built-in methods like list.append have this class name); get_cache_token() returns a monotonically increasing integer token representing the current state of the ABC cache — it is bumped whenever ABCMeta.register() is called to register a virtual subclass; compare: abc.abstractmethod.__class__.__name__=='function' (len=8; abstractmethod is a Python function, 18 chars shorter class name than the C builtin class name=26); NEW in extra154: first standalone abc.get_cache_token.__class__.__name__ identity invariant in abcgct154 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra154.abc_get_cache_token_module_eq:
  description: "abc.get_cache_token.__module__.__eq__('_abc') returns True — abc.get_cache_token is implemented in the C extension module _abc (Modules/_abc.c in CPython); its __module__ is '_abc' (len=4: '_'=1+'abc'=3=4; NOT the Python 'abc' module with len=3); '_abc' begins with an underscore indicating it is a private C extension that backs the public 'abc' Python module; compare: abc.update_abstractmethods.__module__=='abc' (len=3; update_abstractmethods is a pure Python function in Lib/abc.py — its module is 'abc' not '_abc'); get_cache_token.__module__=='_abc' (len=4) vs update_abstractmethods.__module__=='abc' (len=3) — the underscore prefix adds 1 char; NEW in extra154: first standalone abc.get_cache_token.__module__ identity invariant in abcgct154 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra154.abc_get_cache_token_name_eq:
  description: "abc.get_cache_token.__name__.__eq__('get_cache_token') returns True — abc.get_cache_token is a C builtin function from the _abc extension; its __name__ is 'get_cache_token' (len=15: 'get'=3+'_'=1+'cache'=5+'_'=1+'token'=5=15); get_cache_token() is called with no arguments and returns an opaque token (an integer) representing the current state of the virtual subclass cache; the token is useful for caching subclass check results: if the token is unchanged since the last check, the cached result is still valid; __name__ length 15 is the same as len('open_connection')==15 (asyncio.open_connection co_name); NEW in extra154: first standalone abc.get_cache_token.__name__ identity invariant in abcgct154 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__name__.__eq__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra154.abc_abstractmethod_class_is_function:
  description: "abc.abstractmethod.__class__.__name__.__eq__('function') returns True — abc.abstractmethod is a pure Python function defined in Lib/abc.py; its __class__.__name__ is 'function' (len=8: 'f'+'u'+'n'+'c'+'t'+'i'+'o'+'n'=8); this contrasts with abc.get_cache_token.__class__.__name__=='builtin_function_or_method' (len=26; C extension builtin); abstractmethod is decorated as a regular Python function that sets __isabstractmethod__ = True on the decorated method; comparing implementation types: abstractmethod (Python function, class 'function') vs get_cache_token (C builtin, class 'builtin_function_or_method'); NEW in extra154: first standalone abc.abstractmethod.__class__.__name__ identity invariant in abcgctam154 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant abc_extra154.abc_ABC_name_eq:
  description: "abc.ABC.__name__.__eq__('ABC') returns True — abc.ABC is the convenience abstract base class helper; ABC.__name__=='ABC' (len=3: 'A'+'B'+'C'=3; the shortest name in the abc module); ABC is defined in Lib/abc.py as a simple class with ABCMeta as its metaclass; subclassing ABC is a convenient alternative to specifying metaclass=ABCMeta directly; ABC.__module__=='abc' (Python module); ABC.__mro__[0].__name__=='ABC' and ABC.__mro__[1].__name__=='object' (MRO has only 2 entries: ABC and object); compare name lengths: ABC(3) < ABCMeta(7) < abstractmethod(14) < get_cache_token(15); ABC is the shortest public abc name; NEW in extra154: first standalone abc.ABC.__name__ identity invariant in abcnames154 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__name__.__eq__
  args: ["ABC"]
  expected: true

