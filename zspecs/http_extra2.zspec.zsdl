spec: http_extra2
version: ">=3.9"
backend: python_module(http)

docs: https://docs.python.org/3/library/http.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.html — Python http package documentation"
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/__init__.py"
    - "CPython source: Lib/http/client.py"
    - "http_extra.zspec.zsdl — covers HTTPStatus.__name__, HTTPStatus.__module__, HTTPMethod.__name__, HTTPMethod.__module__, HTTPStatus.OK.value, HTTPStatus.NOT_FOUND.value, HTTPStatus.OK.phrase"
    - "http_client.zspec.zsdl — covers HTTP status constants (OK/CREATED/etc.), HTTP_PORT, HTTPS_PORT, class_names table (HTTPResponse/HTTPConnection/HTTPSConnection/HTTPException/InvalidURL/BadStatusLine), responses dict"
    - "http_client_extra.zspec.zsdl — covers HTTPConnection/HTTPSConnection/HTTPException/HTTPResponse/NotConnected/InvalidURL/RemoteDisconnected __name__, HTTPConnection/__module__, HTTPException.__bases__[0].__name__, NotConnected/InvalidURL base_is_HTTPException, type identity checks"
    - "http_status.zspec.zsdl — covers HTTPStatus member values and descriptions"
    - "http_cookies.zspec.zsdl — covers cookies module"
    - "http_cookiejar.zspec.zsdl — covers cookiejar module"
  notes:
    - "This spec extends http_extra.zspec.zsdl with new vectors not covered by any prior http spec."
    - "Access is via the http backend; http.client classes are reached via the client submodule attribute chain."
    - "http.client.HTTPConnection.__name__ == 'HTTPConnection' — verified via http backend attribute chain."
    - "http.client.HTTPSConnection.__name__ == 'HTTPSConnection' — verified via http backend attribute chain."
    - "http.client.HTTPResponse.__name__ == 'HTTPResponse' — verified via http backend attribute chain."
    - "http.client.HTTPException.__name__ == 'HTTPException' — verified via http backend attribute chain."
    - "http.client.HTTPConnection.__module__ == 'http.client' — class defined in http.client submodule."
    - "http.client.HTTPException.__bases__[0].__name__ == 'Exception' — HTTPException inherits from Exception."
    - "http.HTTPStatus.OK.value == 200 — already in http_extra; this spec adds INTERNAL_SERVER_ERROR (500) and CREATED (201)."
    - "http.HTTPStatus.INTERNAL_SERVER_ERROR.value == 500."
    - "http.HTTPStatus.CREATED.value == 201."
    - "http.HTTPStatus.OK.__class__.__name__ == 'HTTPStatus' — enum members are instances of HTTPStatus."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# http.client class names — accessed via http backend attribute chain
# (http_client.zspec.zsdl covers these via the http.client backend directly;
#  this table accesses the same classes via the http package attribute chain.)
# ---------------------------------------------------------------------------

table http_extra2.client_class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [HTTPConnection,  client.HTTPConnection.__name__.__eq__,  ["HTTPConnection"],  true]
    - [HTTPSConnection, client.HTTPSConnection.__name__.__eq__, ["HTTPSConnection"], true]
    - [HTTPResponse,    client.HTTPResponse.__name__.__eq__,    ["HTTPResponse"],    true]
    - [HTTPException,   client.HTTPException.__name__.__eq__,   ["HTTPException"],   true]

# ---------------------------------------------------------------------------
# http.client.HTTPConnection.__module__ == 'http.client'
# (http_client_extra covers this via the http.client backend; this adds
#  the same check via the http package backend.)
# ---------------------------------------------------------------------------

invariant http_extra2.client.HTTPConnection.module:
  description: "http.client.HTTPConnection.__module__ == 'http.client'"
  category: modules
  kind: python_call_eq
  function: client.HTTPConnection.__module__.__eq__
  args: ["http.client"]
  expected: true

# ---------------------------------------------------------------------------
# http.client.HTTPException.__bases__[0].__name__ == 'Exception'
# (http_client_extra covers this via the http.client backend.)
# ---------------------------------------------------------------------------

invariant http_extra2.client.HTTPException.base_is_Exception:
  description: "http.client.HTTPException.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: client.HTTPException.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# HTTPStatus additional values — INTERNAL_SERVER_ERROR (500) and CREATED (201)
# http_extra covers OK (200) and NOT_FOUND (404); this adds 500 and 201.
# ---------------------------------------------------------------------------

invariant http_extra2.HTTPStatus.INTERNAL_SERVER_ERROR.value:
  description: "http.HTTPStatus.INTERNAL_SERVER_ERROR.value == 500"
  category: HTTPStatus_values
  kind: python_call_eq
  function: HTTPStatus.INTERNAL_SERVER_ERROR.value.__eq__
  args: [500]
  expected: true

invariant http_extra2.HTTPStatus.CREATED.value:
  description: "http.HTTPStatus.CREATED.value == 201"
  category: HTTPStatus_values
  kind: python_call_eq
  function: HTTPStatus.CREATED.value.__eq__
  args: [201]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus.OK is an instance of HTTPStatus — enum member class identity
# ---------------------------------------------------------------------------

invariant http_extra2.HTTPStatus.OK.class_name:
  description: "http.HTTPStatus.OK.__class__.__name__ == 'HTTPStatus' — enum members are instances of HTTPStatus"
  category: HTTPStatus_types
  kind: python_call_eq
  function: HTTPStatus.OK.__class__.__name__.__eq__
  args: ["HTTPStatus"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus phrase for INTERNAL_SERVER_ERROR
# http_extra covers OK.phrase == 'OK'; this adds INTERNAL_SERVER_ERROR phrase.
# ---------------------------------------------------------------------------

invariant http_extra2.HTTPStatus.INTERNAL_SERVER_ERROR.phrase:
  description: "http.HTTPStatus.INTERNAL_SERVER_ERROR.phrase == 'Internal Server Error'"
  category: HTTPStatus_phrases
  kind: python_call_eq
  function: HTTPStatus.INTERNAL_SERVER_ERROR.phrase.__eq__
  args: ["Internal Server Error"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus.NOT_FOUND.phrase — 'Not Found'
# http_extra covers NOT_FOUND.value; this adds NOT_FOUND.phrase.
# ---------------------------------------------------------------------------

invariant http_extra2.HTTPStatus.NOT_FOUND.phrase:
  description: "http.HTTPStatus.NOT_FOUND.phrase == 'Not Found'"
  category: HTTPStatus_phrases
  kind: python_call_eq
  function: HTTPStatus.NOT_FOUND.phrase.__eq__
  args: ["Not Found"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus __name__ — enum class name (via http backend)
# http_extra covers this; retained here as a cross-spec verification vector.
# ---------------------------------------------------------------------------

invariant http_extra2.HTTPStatus.name:
  description: "http.HTTPStatus.__name__ == 'HTTPStatus'"
  category: class_names
  kind: python_call_eq
  function: HTTPStatus.__name__.__eq__
  args: ["HTTPStatus"]
  expected: true
