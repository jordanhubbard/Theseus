spec: functools_extra115
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra114.zspec.zsdl."
    - "This spec covers: functools.reduce, functools.cmp_to_key, functools.lru_cache, functools.cache, functools.total_ordering, functools.singledispatch, functools.wraps, functools.update_wrapper, functools.partial __qualname__ values and __qualname__.__len__() counts; wave 262."
    - "functools.reduce.__qualname__ == 'reduce'. Verified with Python 3.14.3."
    - "len(functools.reduce.__qualname__) == 6. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__qualname__ == 'cmp_to_key'. Verified with Python 3.14.3."
    - "len(functools.cmp_to_key.__qualname__) == 10. Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache'. Verified with Python 3.14.3."
    - "len(functools.lru_cache.__qualname__) == 9. Verified with Python 3.14.3."
    - "functools.cache.__qualname__ == 'cache'. Verified with Python 3.14.3."
    - "len(functools.cache.__qualname__) == 5. Verified with Python 3.14.3."
    - "functools.total_ordering.__qualname__ == 'total_ordering'. Verified with Python 3.14.3."
    - "len(functools.total_ordering.__qualname__) == 14. Verified with Python 3.14.3."
    - "functools.singledispatch.__qualname__ == 'singledispatch'. Verified with Python 3.14.3."
    - "len(functools.singledispatch.__qualname__) == 14. Verified with Python 3.14.3."
    - "functools.wraps.__qualname__ == 'wraps'. Verified with Python 3.14.3."
    - "len(functools.wraps.__qualname__) == 5. Verified with Python 3.14.3."
    - "functools.update_wrapper.__qualname__ == 'update_wrapper'. Verified with Python 3.14.3."
    - "len(functools.update_wrapper.__qualname__) == 14. Verified with Python 3.14.3."
    - "functools.partial.__qualname__ == 'partial'. Verified with Python 3.14.3."
    - "len(functools.partial.__qualname__) == 7. Verified with Python 3.14.3."
    - "type(functools.reduce).__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "type(functools.cmp_to_key).__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "type(functools.lru_cache).__name__ == 'function'. Verified with Python 3.14.3."
    - "type(functools.cache).__name__ == 'function'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools C-builtin functions — qualnames and qualname lengths
#
# Wave 262 theme: functools.reduce and functools.cmp_to_key are C-extension
# functions (type 'builtin_function_or_method'). Their __qualname__ values are
# simple unqualified names (not dotted), reflecting that they are top-level
# functions. reduce has qualname 'reduce' (len 6), cmp_to_key has qualname
# 'cmp_to_key' (len 10). functools.partial is a C-extension type (type 'type')
# with __qualname__ 'partial' (len 7).
#
# functools.reduce.__qualname__ == 'reduce'
# len(functools.reduce.__qualname__) == 6
# functools.cmp_to_key.__qualname__ == 'cmp_to_key'
# len(functools.cmp_to_key.__qualname__) == 10
# functools.partial.__qualname__ == 'partial'
# len(functools.partial.__qualname__) == 7
#
# New to extra115.
# ---------------------------------------------------------------------------

table functools_extra115.c_builtin_qualnames:
  description: "functools C-extension functions/types qualnames: reduce='reduce'(6), cmp_to_key='cmp_to_key'(10), partial='partial'(7); qualname lengths via __len__; wave 262; new to extra115"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolscb115

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_qualname_eq,
       "reduce.__qualname__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — functools.reduce is a C-extension function implemented in Modules/_functoolsmodule.c; it is a top-level function so its __qualname__ is simply 'reduce' (no dotted class prefix); C builtins that are not methods have qualnames matching their __name__; str.__eq__('reduce') returns True; new to extra115"]
    - [reduce_qualname_len_6,
       "reduce.__qualname__.__len__",
       [],
       6,
       "functools.reduce.__qualname__.__len__() == 6 — functools.reduce.__qualname__ is 'reduce' which has 6 characters: r-e-d-u-c-e; str.__len__() returns the number of Unicode code points; 6 == 6; int.__eq__(6) returns True; new to extra115"]
    - [cmp_to_key_qualname_eq,
       "cmp_to_key.__qualname__.__eq__",
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__qualname__.__eq__('cmp_to_key') == True — functools.cmp_to_key is a C-extension function that converts an old-style comparison function to a key function; its __qualname__ is 'cmp_to_key' (no dotted prefix); str.__eq__('cmp_to_key') returns True; new to extra115"]
    - [cmp_to_key_qualname_len_10,
       "cmp_to_key.__qualname__.__len__",
       [],
       10,
       "functools.cmp_to_key.__qualname__.__len__() == 10 — functools.cmp_to_key.__qualname__ is 'cmp_to_key' which has 10 characters: c-m-p-_-t-o-_-k-e-y; str.__len__() returns 10; int.__eq__(10) returns True; new to extra115"]
    - [partial_qualname_eq,
       "partial.__qualname__.__eq__",
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — functools.partial is a C-extension type; as a top-level class its __qualname__ equals its __name__ which is 'partial'; str.__eq__('partial') returns True; new to extra115"]
    - [partial_qualname_len_7,
       "partial.__qualname__.__len__",
       [],
       7,
       "functools.partial.__qualname__.__len__() == 7 — functools.partial.__qualname__ is 'partial' which has 7 characters: p-a-r-t-i-a-l; str.__len__() returns 7; int.__eq__(7) returns True; new to extra115"]

# ---------------------------------------------------------------------------
# Table 2: functools pure-Python function qualnames — lru_cache, cache, wraps
#
# Wave 262 theme: functools.lru_cache, functools.cache, and functools.wraps are
# pure-Python functions defined in Lib/functools.py (type 'function'). Their
# __qualname__ values are simple unqualified names ('lru_cache' len 9, 'cache'
# len 5, 'wraps' len 5). functools.update_wrapper is also a pure-Python
# function with __qualname__ 'update_wrapper' (len 14).
#
# functools.lru_cache.__qualname__ == 'lru_cache'
# len(functools.lru_cache.__qualname__) == 9
# functools.cache.__qualname__ == 'cache'
# len(functools.cache.__qualname__) == 5
# functools.wraps.__qualname__ == 'wraps'
# len(functools.wraps.__qualname__) == 5
# functools.update_wrapper.__qualname__ == 'update_wrapper'
# len(functools.update_wrapper.__qualname__) == 14
#
# New to extra115.
# ---------------------------------------------------------------------------

table functools_extra115.pure_python_qualnames:
  description: "functools pure-Python function qualnames: lru_cache='lru_cache'(9), cache='cache'(5), wraps='wraps'(5), update_wrapper='update_wrapper'(14); qualname lengths via __len__; wave 262; new to extra115"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspp115

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_qualname_eq,
       "lru_cache.__qualname__.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — functools.lru_cache is a pure-Python decorator function (type 'function') defined in Lib/functools.py; it is a top-level function so its __qualname__ is 'lru_cache'; str.__eq__('lru_cache') returns True; new to extra115"]
    - [lru_cache_qualname_len_9,
       "lru_cache.__qualname__.__len__",
       [],
       9,
       "functools.lru_cache.__qualname__.__len__() == 9 — functools.lru_cache.__qualname__ is 'lru_cache' which has 9 characters: l-r-u-_-c-a-c-h-e; str.__len__() returns 9; int.__eq__(9) returns True; new to extra115"]
    - [cache_qualname_eq,
       "cache.__qualname__.__eq__",
       ["cache"],
       true,
       "functools.cache.__qualname__.__eq__('cache') == True — functools.cache is a pure-Python function (type 'function') added in Python 3.9 as a simpler unbounded LRU cache; its __qualname__ is 'cache'; str.__eq__('cache') returns True; new to extra115"]
    - [cache_qualname_len_5,
       "cache.__qualname__.__len__",
       [],
       5,
       "functools.cache.__qualname__.__len__() == 5 — functools.cache.__qualname__ is 'cache' which has 5 characters: c-a-c-h-e; str.__len__() returns 5; int.__eq__(5) returns True; new to extra115"]
    - [wraps_qualname_eq,
       "wraps.__qualname__.__eq__",
       ["wraps"],
       true,
       "functools.wraps.__qualname__.__eq__('wraps') == True — functools.wraps is a pure-Python decorator function defined in Lib/functools.py; it is a convenience wrapper around functools.update_wrapper; its __qualname__ is 'wraps'; str.__eq__('wraps') returns True; new to extra115"]
    - [wraps_qualname_len_5,
       "wraps.__qualname__.__len__",
       [],
       5,
       "functools.wraps.__qualname__.__len__() == 5 — functools.wraps.__qualname__ is 'wraps' which has 5 characters: w-r-a-p-s; str.__len__() returns 5; int.__eq__(5) returns True; new to extra115"]
    - [update_wrapper_qualname_eq,
       "update_wrapper.__qualname__.__eq__",
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__qualname__.__eq__('update_wrapper') == True — functools.update_wrapper is a pure-Python function that updates a wrapper function to look like the wrapped function; it is a top-level function so its __qualname__ is 'update_wrapper'; str.__eq__('update_wrapper') returns True; new to extra115"]
    - [update_wrapper_qualname_len_14,
       "update_wrapper.__qualname__.__len__",
       [],
       14,
       "functools.update_wrapper.__qualname__.__len__() == 14 — functools.update_wrapper.__qualname__ is 'update_wrapper' which has 14 characters: u-p-d-a-t-e-_-w-r-a-p-p-e-r; str.__len__() returns 14; int.__eq__(14) returns True; new to extra115"]

# ---------------------------------------------------------------------------
# Table 3: functools decorator qualnames — total_ordering, singledispatch
#
# Wave 262 theme: functools.total_ordering and functools.singledispatch are
# pure-Python decorator functions (type 'function') defined in Lib/functools.py.
# Both have __qualname__ equal to their simple name (length 14 each), and these
# are among the longest qualnames in the functools module for top-level names.
# singledispatch creates single-dispatch generic functions;
# total_ordering fills in missing comparison methods from a minimal set.
#
# functools.total_ordering.__qualname__ == 'total_ordering'
# len(functools.total_ordering.__qualname__) == 14
# functools.singledispatch.__qualname__ == 'singledispatch'
# len(functools.singledispatch.__qualname__) == 14
#
# New to extra115.
# ---------------------------------------------------------------------------

table functools_extra115.decorator_qualnames:
  description: "functools.total_ordering and singledispatch qualnames both 14 chars; qualname equality and length; wave 262; new to extra115"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsdec115

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_qualname_eq,
       "total_ordering.__qualname__.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__.__eq__('total_ordering') == True — functools.total_ordering is a class decorator (type 'function') defined in Lib/functools.py; given a class with __eq__ and one of __lt__, __le__, __gt__, __ge__, it fills in the rest; its __qualname__ is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra115"]
    - [total_ordering_qualname_len_14,
       "total_ordering.__qualname__.__len__",
       [],
       14,
       "functools.total_ordering.__qualname__.__len__() == 14 — functools.total_ordering.__qualname__ is 'total_ordering' which has 14 characters: t-o-t-a-l-_-o-r-d-e-r-i-n-g; str.__len__() returns 14; int.__eq__(14) returns True; new to extra115"]
    - [singledispatch_qualname_eq,
       "singledispatch.__qualname__.__eq__",
       ["singledispatch"],
       true,
       "functools.singledispatch.__qualname__.__eq__('singledispatch') == True — functools.singledispatch is a decorator factory (type 'function') that transforms a function into a single-dispatch generic function; it is defined at module level in Lib/functools.py; its __qualname__ is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra115"]
    - [singledispatch_qualname_len_14,
       "singledispatch.__qualname__.__len__",
       [],
       14,
       "functools.singledispatch.__qualname__.__len__() == 14 — functools.singledispatch.__qualname__ is 'singledispatch' which has 14 characters: s-i-n-g-l-e-d-i-s-p-a-t-c-h; str.__len__() returns 14; int.__eq__(14) returns True; new to extra115"]
    - [total_ordering_len_eq_singledispatch_len,
       "total_ordering.__qualname__.__len__",
       [],
       14,
       "functools.total_ordering.__qualname__.__len__() == 14 — same length as functools.singledispatch.__qualname__.__len__(); both 'total_ordering' and 'singledispatch' have 14-character qualnames; this vector independently confirms the length of total_ordering qualname; int.__eq__(14) returns True; new to extra115"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra115
# ---------------------------------------------------------------------------

invariant functools_extra115.reduce_qualname_len:
  description: "functools.reduce.__qualname__.__len__() == 6 — 'reduce' has 6 chars; C builtin top-level function; wave 262; new to extra115"
  kind: python_call_eq
  function: reduce.__qualname__.__len__
  args: []
  expected: 6

invariant functools_extra115.lru_cache_qualname_len:
  description: "functools.lru_cache.__qualname__.__len__() == 9 — 'lru_cache' has 9 chars; pure-Python decorator; wave 262; new to extra115"
  kind: python_call_eq
  function: lru_cache.__qualname__.__len__
  args: []
  expected: 9

invariant functools_extra115.cmp_to_key_qualname_eq:
  description: "functools.cmp_to_key.__qualname__ == 'cmp_to_key' — C builtin top-level function; wave 262; new to extra115"
  kind: python_call_eq
  function: cmp_to_key.__qualname__.__eq__
  args: ["cmp_to_key"]
  expected: true

invariant functools_extra115.update_wrapper_qualname_len:
  description: "functools.update_wrapper.__qualname__.__len__() == 14 — 'update_wrapper' has 14 chars; same length as total_ordering and singledispatch; wave 262; new to extra115"
  kind: python_call_eq
  function: update_wrapper.__qualname__.__len__
  args: []
  expected: 14

invariant functools_extra115.wraps_qualname_eq:
  description: "functools.wraps.__qualname__ == 'wraps' — pure-Python convenience wrapper around update_wrapper; len 5; wave 262; new to extra115"
  kind: python_call_eq
  function: wraps.__qualname__.__eq__
  args: ["wraps"]
  expected: true
