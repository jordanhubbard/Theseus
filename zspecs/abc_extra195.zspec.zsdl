    - "abc.get_cache_token.__doc__.__class__.__name__ == 'str' (len=3) — get_cache_token has a non-None docstring. Verified with Python 3.14.3."
    - "abc.ABCMeta.register.__doc__.__class__.__name__ == 'str' (len=3) — ABCMeta.register has a non-None docstring. Verified with Python 3.14.3."
    - "abc.ABCMeta.__instancecheck__.__doc__.__class__.__name__ == 'str' (len=3) — ABCMeta.__instancecheck__ has a non-None docstring. Verified with Python 3.14.3."
    - "abc.ABCMeta.__subclasscheck__.__doc__.__class__.__name__ == 'str' (len=3) — ABCMeta.__subclasscheck__ has a non-None docstring. Verified with Python 3.14.3."
    - "All eight abc members have non-None __doc__ strings; __doc__.__class__.__name__ == 'str' for all of them."
    - "The string 'str' has length 3; __doc__.__class__.__name__.__len__() == 3 for all eight members."
    - "Prior abc specs cover __name__, __qualname__, __module__, __bases__, and method qualname checks. No prior spec covers __doc__.__class__.__name__ identity."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

