spec: decimal_extra2101
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2101 (decimal_extra2101): __class_getitem__, __init_subclass__, __subclasshook__, __mro_entries__ dict-presence checks."
    - "decimal.Decimal is the arbitrary-precision decimal number class; decimal.Context controls precision and rounding."
    - "Neither decimal.Decimal nor decimal.Context define __class_getitem__ in their own __dict__ — generic alias subscripting is not supported."
    - "Neither defines __init_subclass__ in their own __dict__ — the hook is inherited from object."
    - "Neither defines __subclasshook__ in their own __dict__ — no ABC virtual subclass customization."
    - "Neither defines __mro_entries__ in their own __dict__ — MRO resolution protocol is absent."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table decimal_extra2101.class_getitem_protocol:
  description: "decimal.Decimal and decimal.Context __class_getitem__ dict-presence checks — generic alias protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2101

  columns: [id, function, args, expected]
  rows:
    - ["dc2101001", "decimal.Decimal.__dict__.__contains__", ["__class_getitem__"], false]
    - ["dc2101002", "decimal.Context.__dict__.__contains__", ["__class_getitem__"], false]

