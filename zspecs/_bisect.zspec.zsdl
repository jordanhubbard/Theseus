spec: _bisect
version: ">=3.0"
backend: python_module(_bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/bisect.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "_bisect source: Modules/_bisectmodule.c (PSF; C extension)"
  not_derived_from:
    - "_bisect source: internal binary search implementation details"
  notes:
    - "_bisect is the C-extension backend for the bisect stdlib module."
    - "bisect_left returns the leftmost index i such that a[i-1] < x <= a[i]."
    - "bisect_right returns the rightmost index i such that a[i-1] <= x < a[i]."
    - "bisect_left([1,3,5,7,9], 5) == 2 — 5 exists at index 2; left insertion point is 2."
    - "bisect_right([1,3,5,7,9], 5) == 3 — right insertion point is after the existing 5."
    - "bisect_left([1,3,5,7,9], 0) == 0 — value smaller than all elements inserts at front."
    - "bisect_right([1,3,5,7,9], 10) == 5 — value larger than all elements appends at end."
    - "insort_left and insort_right insert a value in-place and return None."
    - "All expected values verified by running Python 3.12 _bisect module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table _bisect.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [bisect_left,  bisect_left.__name__.__eq__,  ["bisect_left"],  true]
    - [bisect_right, bisect_right.__name__.__eq__, ["bisect_right"], true]
    - [insort_left,  insort_left.__name__.__eq__,  ["insort_left"],  true]
    - [insort_right, insort_right.__name__.__eq__, ["insort_right"], true]

# ---------------------------------------------------------------------------
# Function module checks
# ---------------------------------------------------------------------------

table _bisect.function_modules:
  kind: python_call_eq
  category: functions
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [bisect_left,  bisect_left.__module__.__eq__,  ["_bisect"], true]
    - [bisect_right, bisect_right.__module__.__eq__, ["_bisect"], true]
    - [insort_left,  insort_left.__module__.__eq__,  ["_bisect"], true]
    - [insort_right, insort_right.__module__.__eq__, ["_bisect"], true]

# ---------------------------------------------------------------------------
# bisect_left — leftmost insertion point
# ---------------------------------------------------------------------------

invariant _bisect.bisect_left_existing:
  description: "bisect_left([1,3,5,7,9], 5) == 2 — left boundary of existing element"
  category: behavioral
  kind: python_call_eq
  function: bisect_left
  args: [[1, 3, 5, 7, 9], 5]
  expected: 2

invariant _bisect.bisect_left_before_all:
  description: "bisect_left([1,3,5,7,9], 0) == 0 — value smaller than all elements"
  category: behavioral
  kind: python_call_eq
  function: bisect_left
  args: [[1, 3, 5, 7, 9], 0]
  expected: 0

invariant _bisect.bisect_left_between:
  description: "bisect_left([1,3,5,7,9], 4) == 2 — gap between 3 and 5"
  category: behavioral
  kind: python_call_eq
  function: bisect_left
  args: [[1, 3, 5, 7, 9], 4]
  expected: 2

# ---------------------------------------------------------------------------
# bisect_right — rightmost insertion point
# ---------------------------------------------------------------------------

invariant _bisect.bisect_right_existing:
  description: "bisect_right([1,3,5,7,9], 5) == 3 — right boundary after existing element"
  category: behavioral
  kind: python_call_eq
  function: bisect_right
  args: [[1, 3, 5, 7, 9], 5]
  expected: 3

invariant _bisect.bisect_right_after_all:
  description: "bisect_right([1,3,5,7,9], 10) == 5 — value larger than all elements"
  category: behavioral
  kind: python_call_eq
  function: bisect_right
  args: [[1, 3, 5, 7, 9], 10]
  expected: 5

invariant _bisect.bisect_right_between:
  description: "bisect_right([1,3,5,7,9], 4) == 2 — gap between 3 and 5"
  category: behavioral
  kind: python_call_eq
  function: bisect_right
  args: [[1, 3, 5, 7, 9], 4]
  expected: 2

# ---------------------------------------------------------------------------
# insort_left — in-place insert, returns None
# ---------------------------------------------------------------------------

invariant _bisect.insort_left_returns_none:
  description: "insort_left([1,3,5], 4) returns None — modifies list in-place"
  category: behavioral
  kind: python_call_eq
  function: insort_left
  args: [[1, 3, 5], 4]
  expected: ~

# ---------------------------------------------------------------------------
# insort_right — in-place insert, returns None
# ---------------------------------------------------------------------------

invariant _bisect.insort_right_returns_none:
  description: "insort_right([1,3,5], 4) returns None — modifies list in-place"
  category: behavioral
  kind: python_call_eq
  function: insort_right
  args: [[1, 3, 5], 4]
  expected: ~
