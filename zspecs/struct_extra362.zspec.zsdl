spec: struct_extra362
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "struct.pack('i', 'not_an_int') raises struct.error. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('b', 200) raises struct.error (200 > 127, out of range for signed byte). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('i', b'ab') raises struct.error (buffer is 2 bytes, 'i' requires 4). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__name__ == 'calcsize'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.error is the exception class raised by pack/unpack/calcsize for format or value errors."
    - "Note: struct.pack('i', 'not_an_int') — 'i' format requires an integer; passing a string raises struct.error."
    - "Note: struct.pack('b', 200) — 'b' is signed byte (-128 to 127); 200 > 127 is out of range, raises struct.error."
    - "Note: struct.unpack('i', b'ab') — 'i' format requires exactly 4 bytes; b'ab' is 2 bytes, size mismatch raises struct.error."
    - "Note: struct.calcsize.__name__ is 'calcsize' and __module__ is '_struct' — it is a C built-in defined in the _struct C extension."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack('i', 'not_an_int') raises struct.error
# struct.pack('b', 200) raises struct.error
# struct.unpack('i', b'ab') raises struct.error
#
# Wave 362 theme: struct error behaviors for type mismatch, range overflow,
# and buffer size mismatch.
#
# struct.error is raised by pack() and unpack() for invalid inputs:
# - pack('i', 'not_an_int'): 'i' format requires an integer; a string
#   argument raises struct.error (required type mismatch).
# - pack('b', 200): 'b' is a signed byte (-128 to 127); 200 exceeds the
#   maximum value and raises struct.error (value out of range).
# - unpack('i', b'ab'): 'i' format requires exactly 4 bytes but b'ab' is
#   only 2 bytes; the buffer size mismatch raises struct.error.
# All three cases raise struct.error, not TypeError or ValueError.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra362.pack_unpack_error_behaviors:
  description: "pack('i','not_an_int') raises struct.error / pack('b',200) raises struct.error / unpack('i',b'ab') raises struct.error — all three cases raise struct.error: type mismatch ('i' requires int not str), value out of range ('b' signed byte max 127, 200>127), buffer size mismatch ('i' needs 4 bytes, b'ab' is 2 bytes); first structerrb362 anchor for pack/unpack error behaviors"
  kind: python_call_raises
  category: error_behaviors
  id_prefix: structerrb362

  columns: [id, function, args, expected]
  rows:
    - [pack_type_mismatch,   pack, ["i", "not_an_int"], struct.error]
    - [pack_byte_overflow,   pack, ["b", 200],          struct.error]
    - [unpack_size_mismatch, unpack, ["i", "ab"],       struct.error]

# ---------------------------------------------------------------------------
# struct.calcsize.__name__ == 'calcsize'
# struct.calcsize.__module__ == '_struct'
#
# Wave 362 theme: struct.calcsize function identity.
#
# struct.calcsize is a C built-in function defined in the _struct C extension
# (Modules/_struct.c). Its __name__ is 'calcsize' and its __module__ is
# '_struct'. This confirms that calcsize is implemented in C, not in the
# Python-level struct wrapper (Lib/struct.py). calcsize returns the size in
# bytes of the struct corresponding to the format string, useful for
# pre-allocating buffers before pack/unpack calls.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra362.calcsize_function_identity:
  description: "calcsize.__name__.__eq__('calcsize')==True / calcsize.__module__.__eq__('_struct')==True — struct.calcsize is a C built-in function in the _struct extension (Modules/_struct.c); __name__ is 'calcsize', __module__ is '_struct' (not 'struct'); contrast with struct.error whose __module__ is 'struct'; first structerrb362 anchor for calcsize function identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: structerrb362

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_name,   "calcsize.__name__.__eq__",   ["calcsize"], true, "struct.calcsize.__name__ is 'calcsize' — the C built-in function's registered name in _struct extension"]
    - [calcsize_module, "calcsize.__module__.__eq__", ["_struct"],  true, "struct.calcsize.__module__ is '_struct' — defined in _struct C extension (Modules/_struct.c), not Python wrapper"]

# ---------------------------------------------------------------------------
# struct.pack('b', 200) raises struct.error — standalone
#
# struct.pack('b', 200) raises struct.error. The 'b' format character is a
# signed C byte with range [-128, 127]. The value 200 exceeds the maximum
# (127) for a signed byte and triggers a struct.error with message 'byte
# format requires -128 <= number <= 127'. This is a value-out-of-range
# error, not a type error — the argument 200 is a valid int, but its value
# is outside the range of a C signed char (int8_t). For unsigned bytes,
# the 'B' format (range [0, 255]) would accept 200.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra362.pack_byte_overflow_raises:
  description: "struct.pack('b', 200) raises struct.error — 'b' is signed byte [-128,127]; 200 > 127 is out of range; struct.error (not ValueError/TypeError) is raised; for unsigned byte use 'B' format [0,255] which would accept 200; value-out-of-range error distinct from type error; first standalone for pack 'b' overflow under structerrb362"
  category: error_behaviors
  kind: python_call_raises
  function: pack
  args: ["b", 200]
  raises: struct.error

# ---------------------------------------------------------------------------
# struct.unpack('i', b'ab') raises struct.error — standalone
#
# struct.unpack('i', b'ab') raises struct.error. The 'i' format character
# requires exactly 4 bytes (the size of a C int on all modern platforms).
# b'ab' is only 2 bytes. The buffer size mismatch causes struct.unpack to
# raise struct.error with message 'unpack requires a buffer of 4 bytes'.
# This error occurs before any data interpretation — struct validates the
# buffer size against calcsize(format) before attempting to unpack.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra362.unpack_size_mismatch_raises:
  description: "struct.unpack('i', b'ab') raises struct.error — 'i' format requires 4 bytes (calcsize('i')==4); b'ab' is 2 bytes; buffer size mismatch raises struct.error before any data interpretation; error message: 'unpack requires a buffer of 4 bytes'; first standalone for unpack size mismatch under structerrb362"
  category: error_behaviors
  kind: python_call_raises
  function: unpack
  args: ["i", "ab"]
  raises: struct.error

# ---------------------------------------------------------------------------
# struct.calcsize.__name__ == 'calcsize' — standalone
#
# struct.calcsize.__name__ is 'calcsize'. struct.calcsize is one of the
# core C-level functions in the _struct extension. It computes the number
# of bytes required to pack values using a given format string. Unlike
# struct.error whose __module__ is 'struct' (Python wrapper), calcsize
# lives in the _struct C extension — confirmed by __module__ == '_struct'.
# The __name__ 'calcsize' is the function's registered name in the C
# module's PyMethodDef table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra362.calcsize_name_is_calcsize:
  description: "struct.calcsize.__name__.__eq__('calcsize') == True — calcsize is a C built-in with __name__ 'calcsize' (registered name in _struct PyMethodDef table); computes bytes needed for a format string; __module__ is '_struct' (C extension); contrast with struct.error whose __module__ is 'struct' (Python wrapper); first standalone for calcsize.__name__ under structerrb362"
  category: function_identity
  kind: python_call_eq
  function: calcsize.__name__.__eq__
  args: ["calcsize"]
  expected: true
