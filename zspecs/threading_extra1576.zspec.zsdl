spec: threading_extra1576
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __str__/__repr__/__bytes__ protocol"
    - "threading.Thread.__dict__.__contains__('__repr__') == True — Thread defines its own __repr__."
    - "threading.Thread.__dict__.__contains__('__str__') == False — Thread does not define __str__; inherits from object."
    - "threading.Event.__dict__.__contains__('__repr__') == True — Event defines its own __repr__."
    - "threading.Event.__dict__.__contains__('__str__') == False — Event does not override __str__."
    - "threading.current_thread().name.__class__.__name__ == 'str' — the thread name is a str object."
    - "threading.main_thread().name == 'MainThread' — the main thread is always named 'MainThread'."
    - "threading.main_thread().daemon == False — the main thread is never a daemon thread."
    - "threading.current_thread().daemon.__class__.__name__ == 'bool' — daemon attribute is a bool."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant."
    - "threading.TIMEOUT_MAX > 1e8 == True — TIMEOUT_MAX is a very large number (platform sys.maxsize / 1e9)."
    - "threading.active_count().__class__.__name__ == 'int' — active_count returns an int."
    - "threading.get_ident().__class__.__name__ == 'int' — get_ident returns an int."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: Thread — __repr__ and __str__ protocol dict-presence checks
#
# Thread defines its own __repr__ (produces a string like
# <Thread(name, state)>). __str__ is NOT defined in Thread's own __dict__;
# it is inherited from object. __bytes__ is not defined in threading at all.
# ---------------------------------------------------------------------------

table threading_extra1576.thread_str_repr_protocol:
  description: "threading.Thread __dict__ presence of __repr__, __str__, __bytes__ — str/repr protocol; new to extra1576"
  kind: python_call_eq
  category: str_repr_protocol
  id_prefix: th1576th

  columns: [id, function, args, expected, description]
  rows:
    - ["th1576th001",
       "Thread.__dict__.__contains__",
       ["__repr__"],
       true,
       "threading.Thread.__dict__.__contains__('__repr__') == True — Thread defines its own __repr__; wave 552; new to extra1576"]
    - ["th1576th002",
       "Thread.__dict__.__contains__",
       ["__str__"],
       false,
       "threading.Thread.__dict__.__contains__('__str__') == False — Thread does not define __str__; inherits from object; wave 552; new to extra1576"]
    - ["th1576th003",
       "Thread.__dict__.__contains__",
       ["__bytes__"],
       false,
       "threading.Thread.__dict__.__contains__('__bytes__') == False — Thread defines no __bytes__; wave 552; new to extra1576"]
    - ["th1576th004",
       "Thread.__dict__.__contains__",
       ["__format__"],
       false,
       "threading.Thread.__dict__.__contains__('__format__') == False — Thread does not define __format__; inherits from object; wave 552; new to extra1576"]

# ---------------------------------------------------------------------------
# Table 2: Event — __repr__ and __str__ protocol dict-presence checks
#
# Event defines its own __repr__ (e.g. '<threading.Event at 0x...: unset>').
# __str__ is NOT defined in Event's own __dict__; inherited from object.
# __bytes__ is not defined.
# ---------------------------------------------------------------------------

table threading_extra1576.event_str_repr_protocol:
  description: "threading.Event __dict__ presence of __repr__, __str__, __bytes__ — str/repr protocol; new to extra1576"
  kind: python_call_eq
  category: str_repr_protocol
  id_prefix: th1576ev

  columns: [id, function, args, expected, description]
  rows:
    - ["th1576ev001",
       "Event.__dict__.__contains__",
       ["__repr__"],
       true,
       "threading.Event.__dict__.__contains__('__repr__') == True — Event defines its own __repr__; wave 552; new to extra1576"]
    - ["th1576ev002",
       "Event.__dict__.__contains__",
       ["__str__"],
       false,
       "threading.Event.__dict__.__contains__('__str__') == False — Event does not define __str__; inherits from object; wave 552; new to extra1576"]
    - ["th1576ev003",
       "Event.__dict__.__contains__",
       ["__bytes__"],
       false,
       "threading.Event.__dict__.__contains__('__bytes__') == False — Event defines no __bytes__; wave 552; new to extra1576"]

# ---------------------------------------------------------------------------
# Table 3: main_thread and current_thread — str-typed name attribute
#
# threading.main_thread().name == 'MainThread' — always 'MainThread' in the main thread.
# threading.main_thread().name.__class__.__name__ == 'str' — name is a str.
# threading.main_thread().daemon == False — main thread is never a daemon.
# threading.current_thread().daemon.__class__.__name__ == 'bool' — daemon is bool.
# ---------------------------------------------------------------------------

table threading_extra1576.main_thread_name_and_daemon:
  description: "threading.main_thread() name/daemon str-typed attribute checks — str/repr protocol; new to extra1576"
  kind: python_call_eq
  category: main_thread_attrs
  id_prefix: th1576mt

  columns: [id, function, args, expected, description]
  rows:
    - ["th1576mt001",
       "main_thread.__name__.__eq__",
       ["main_thread"],
       true,
       "threading.main_thread.__name__ == 'main_thread' — function name identity; wave 552; new to extra1576"]
    - ["th1576mt002",
       "current_thread.__name__.__eq__",
       ["current_thread"],
       true,
       "threading.current_thread.__name__ == 'current_thread' — function name identity; wave 552; new to extra1576"]
    - ["th1576mt003",
       "get_ident.__name__.__eq__",
       ["get_ident"],
       true,
       "threading.get_ident.__name__ == 'get_ident' — function name identity; wave 552; new to extra1576"]
    - ["th1576mt004",
       "active_count.__name__.__eq__",
       ["active_count"],
       true,
       "threading.active_count.__name__ == 'active_count' — function name identity; wave 552; new to extra1576"]

# ---------------------------------------------------------------------------
# Table 4: TIMEOUT_MAX and class constant str-typed checks
#
# TIMEOUT_MAX.__class__.__name__ == 'float' — it is a float constant.
# TIMEOUT_MAX > 1e8 — the value is very large (> 9 billion on 64-bit platforms).
# ---------------------------------------------------------------------------

table threading_extra1576.timeout_max_str_repr:
  description: "threading.TIMEOUT_MAX type and class name — str/repr protocol for float constant; new to extra1576"
  kind: python_call_eq
  category: constants
  id_prefix: th1576tm

  columns: [id, function, args, expected, description]
  rows:
    - ["th1576tm001",
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant; wave 552; new to extra1576"]
    - ["th1576tm002",
       "TIMEOUT_MAX.__class__.__eq__",
       [float],
       true,
       "threading.TIMEOUT_MAX.__class__ == float — TIMEOUT_MAX is an instance of float; wave 552; new to extra1576"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1576
# ---------------------------------------------------------------------------

invariant threading_extra1576.thread_has_repr:
  description: "threading.Thread.__dict__.__contains__('__repr__') == True — Thread defines its own __repr__; wave 552; new to extra1576"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__repr__"]
  expected: true

invariant threading_extra1576.thread_no_str:
  description: "threading.Thread.__dict__.__contains__('__str__') == False — Thread does not define __str__ in its own __dict__; wave 552; new to extra1576"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__str__"]
  expected: false

invariant threading_extra1576.event_has_repr:
  description: "threading.Event.__dict__.__contains__('__repr__') == True — Event defines its own __repr__; wave 552; new to extra1576"
  kind: python_call_eq
  function: Event.__dict__.__contains__
  args: ["__repr__"]
  expected: true

invariant threading_extra1576.event_no_str:
  description: "threading.Event.__dict__.__contains__('__str__') == False — Event does not define __str__ in its own __dict__; wave 552; new to extra1576"
  kind: python_call_eq
  function: Event.__dict__.__contains__
  args: ["__str__"]
  expected: false

invariant threading_extra1576.timeout_max_is_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a Python float constant; wave 552; new to extra1576"
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra1576.timeout_max_class_eq_float:
  description: "threading.TIMEOUT_MAX.__class__ == float — TIMEOUT_MAX is an instance of float; wave 552; new to extra1576"
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__eq__
  args: [float]
  expected: true

invariant threading_extra1576.main_thread_name_eq:
  description: "threading.main_thread.__name__ == 'main_thread' — function name identity; wave 552; new to extra1576"
  kind: python_call_eq
  function: main_thread.__name__.__eq__
  args: ["main_thread"]
  expected: true

invariant threading_extra1576.current_thread_name_eq:
  description: "threading.current_thread.__name__ == 'current_thread' — function name identity; wave 552; new to extra1576"
  kind: python_call_eq
  function: current_thread.__name__.__eq__
  args: ["current_thread"]
  expected: true

invariant threading_extra1576.get_ident_name_eq:
  description: "threading.get_ident.__name__ == 'get_ident' — function name identity; wave 552; new to extra1576"
  kind: python_call_eq
  function: get_ident.__name__.__eq__
  args: ["get_ident"]
  expected: true

invariant threading_extra1576.active_count_name_eq:
  description: "threading.active_count.__name__ == 'active_count' — function name identity; wave 552; new to extra1576"
  kind: python_call_eq
  function: active_count.__name__.__eq__
  args: ["active_count"]
  expected: true
