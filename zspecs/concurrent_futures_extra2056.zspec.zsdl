spec: concurrent_futures_extra2056
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 584 (_extra2056): __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__ dict-presence checks."
    - "concurrent.futures types (Future, ThreadPoolExecutor, ProcessPoolExecutor, Executor) are concurrency primitives, not sequence/mapping/attribute-override types."
    - "Executor is an abstract base class; ThreadPoolExecutor and ProcessPoolExecutor extend it."
    - "None of these types define __getitem__, __setitem__, __delitem__, __len__, __getattr__, __setattr__, or __delattr__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra2056.getitem_protocol:
  description: "concurrent.futures types __getitem__/__setitem__/__delitem__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2056

  columns: [id, function, args, expected]
  rows:
    - ["cf2056001", "concurrent.futures.Future.__dict__.__contains__", ["__getitem__"], false]
    - ["cf2056002", "concurrent.futures.Future.__dict__.__contains__", ["__setitem__"], false]
    - ["cf2056003", "concurrent.futures.Future.__dict__.__contains__", ["__delitem__"], false]
    - ["cf2056004", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__getitem__"], false]
    - ["cf2056005", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__setitem__"], false]
    - ["cf2056006", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__delitem__"], false]
    - ["cf2056007", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__getitem__"], false]
    - ["cf2056008", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__setitem__"], false]
    - ["cf2056009", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__delitem__"], false]
    - ["cf2056010", "concurrent.futures.Executor.__dict__.__contains__", ["__getitem__"], false]
    - ["cf2056011", "concurrent.futures.Executor.__dict__.__contains__", ["__setitem__"], false]
    - ["cf2056012", "concurrent.futures.Executor.__dict__.__contains__", ["__delitem__"], false]

