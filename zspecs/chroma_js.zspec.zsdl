spec: chroma_js
version: ">=2.0.0"
backend: node(chroma-js)

docs: https://gka.github.io/chroma.js/

provenance:
  derived_from:
    - "chroma.js documentation — https://gka.github.io/chroma.js/"
    - "Test vectors verified with chroma-js via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "chroma-js source"
  notes:
    - "chroma.js is a popular color manipulation library — alternative to color, tinycolor."
    - "Install: npm install chroma-js"
    - "Module export IS the chroma() factory."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; throws on un-parseable color strings."
  stderr: "null"
  stickiness: "N/A — chroma instances immutable."
  codes: {}

# chroma(input).hex() — basic round-trip
table chroma_js.hex:
  kind: node_chain_eq
  category: hex
  entry: module
  id_prefix: hex

  columns: [id, entry_args, chain, expected]
  rows:
    - [named_red,    ["red"],     [{method: hex, args: []}], "#ff0000"]
    - [named_blue,   ["blue"],    [{method: hex, args: []}], "#0000ff"]
    - [hex_input,    ["#ff0000"], [{method: hex, args: []}], "#ff0000"]
    - [shorthand,    ["#f00"],    [{method: hex, args: []}], "#ff0000"]
    - [rgb_string,   ["rgb(255, 0, 0)"], [{method: hex, args: []}], "#ff0000"]

# chroma(input).rgb() — array form
table chroma_js.rgb:
  kind: node_chain_eq
  category: rgb
  entry: module
  id_prefix: rgb

  columns: [id, entry_args, chain, expected]
  rows:
    - [red,   ["red"],   [{method: rgb, args: []}], [255, 0, 0]]
    - [green, ["green"], [{method: rgb, args: []}], [0, 128, 0]]
    - [blue,  ["blue"],  [{method: rgb, args: []}], [0, 0, 255]]

# chroma(input).name() — reverse lookup for named colors
table chroma_js.name:
  kind: node_chain_eq
  category: name
  entry: module
  id_prefix: name

  columns: [id, entry_args, chain, expected]
  rows:
    - [red,     ["red"],     [{method: name, args: []}], "red"]
    - [blue,    ["blue"],    [{method: name, args: []}], "blue"]
    - [from_hex, ["#ff0000"], [{method: name, args: []}], "red"]

# chroma.mix(a, b, ratio).hex() — color blending
invariant chroma_js.mix_red_blue_half:
  description: "chroma.mix('red', 'blue', 0.5).hex() yields #b400b4 (LRGB midpoint)"
  category: mix
  kind: node_chain_eq
  entry: named
  function: mix
  entry_args: ["red", "blue", 0.5]
  chain:
    - {method: hex, args: []}
  expected: "#b400b4"

invariant chroma_js.alpha_appended_in_8char_hex:
  description: "chroma(...).alpha(0.5).hex() encodes alpha as the trailing 80 byte"
  category: alpha
  kind: node_chain_eq
  entry: module
  entry_args: ["red"]
  chain:
    - {method: alpha, args: [0.5]}
    - {method: hex, args: []}
  expected: "#ff000080"
