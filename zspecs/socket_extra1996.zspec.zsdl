spec: socket_extra1996
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
    - "CPython source: Lib/socket.py, Modules/_socket.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 580 (_extra1996): __index__, __complex__, __float__, __round__, __abs__ dict-presence checks."
    - "socket.socket is not a numeric type; it defines no integer or floating-point conversion protocols in its own __dict__."
    - "socket.error, socket.timeout, and socket.gaierror are Exception subclasses; they define no numeric protocols."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; they inherit numeric methods from int but define none in their own __dict__."
    - "All five numeric dunder methods are absent from all checked socket type dicts."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra1996.socket_index_protocol:
  description: "socket.socket __index__ dict-presence checks (socket is not a numeric type)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1996

  columns: [id, function, args, expected]
  rows:
    - ["sk1996001", "socket.socket.__dict__.__contains__", ["__index__"], false]
    - ["sk1996002", "socket.socket.__dict__.__contains__", ["__complex__"], false]
    - ["sk1996003", "socket.socket.__dict__.__contains__", ["__float__"], false]
    - ["sk1996004", "socket.socket.__dict__.__contains__", ["__round__"], false]
    - ["sk1996005", "socket.socket.__dict__.__contains__", ["__abs__"], false]

