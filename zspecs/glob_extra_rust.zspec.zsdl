  category: escape
  kind: python_call_eq
  function: glob_extra_escape_bracket
  args: []
  expected: "foo[[]1[]]"

invariant glob_extra_rust.glob_returns_list:
  description: "glob.glob('/tmp') returns a list"
  category: glob
  kind: python_call_eq
  function: glob_extra_glob_returns_list
  args: []
  expected: true

