spec: cf3046
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 650 (cf3046): __enter__, __exit__, __aenter__ dict-presence for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Key finding: concurrent.futures.Executor defines __enter__ and __exit__ (true) — it is the base class that provides the synchronous context manager protocol for executor use-as-resource patterns."
    - "ThreadPoolExecutor and ProcessPoolExecutor inherit __enter__/__exit__ from Executor; they do NOT define these in their own __dict__ (false)."
    - "concurrent.futures.Future defines neither __enter__ nor __exit__ nor __aenter__ (false for all) — it is not a context manager."
    - "No concurrent.futures class defines __aenter__ in its own __dict__ (all false) — none support async-with."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __enter__ dict-presence — operator.contains(Cls.__dict__, '__enter__')
#
# concurrent.futures.Executor defines __enter__ directly (true) — it provides
# the context manager protocol so executors can be used with 'with' statements.
# ThreadPoolExecutor and ProcessPoolExecutor inherit it from Executor (false).
# concurrent.futures.Future does not define __enter__ (false).
# ---------------------------------------------------------------------------

table cf3046.enter:
  description: "concurrent.futures types __enter__ dict-presence checks; wave 650"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3046

  columns: [id, function, args, expected]
  rows:
    - ["cf3046001", operator.contains, [concurrent.futures.Future.__dict__,              "__enter__"], false]
    - ["cf3046002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__enter__"], false]
    - ["cf3046003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__enter__"], false]
    - ["cf3046004", operator.contains, [concurrent.futures.Executor.__dict__,            "__enter__"], true]

# ---------------------------------------------------------------------------
# __exit__ dict-presence — operator.contains(Cls.__dict__, '__exit__')
#
# concurrent.futures.Executor defines __exit__ directly (true) — paired with
# __enter__ to complete the synchronous context manager protocol.
# ThreadPoolExecutor and ProcessPoolExecutor inherit it (false in their __dict__).
# concurrent.futures.Future does not define __exit__ (false).
# ---------------------------------------------------------------------------

table cf3046.exit:
  description: "concurrent.futures types __exit__ dict-presence checks; wave 650"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3046

  columns: [id, function, args, expected]
  rows:
    - ["cf3046005", operator.contains, [concurrent.futures.Future.__dict__,              "__exit__"], false]
    - ["cf3046006", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__exit__"], false]
    - ["cf3046007", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__exit__"], false]
    - ["cf3046008", operator.contains, [concurrent.futures.Executor.__dict__,            "__exit__"], true]

# ---------------------------------------------------------------------------
# __aenter__ dict-presence — operator.contains(Cls.__dict__, '__aenter__')
#
# No concurrent.futures class defines __aenter__ in its own __dict__; all false.
# concurrent.futures executors use only the synchronous context manager protocol.
# There is no async-with support in concurrent.futures.
# ---------------------------------------------------------------------------

table cf3046.aenter:
  description: "concurrent.futures types __aenter__ dict-presence checks; wave 650"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3046

  columns: [id, function, args, expected]
  rows:
    - ["cf3046009",  operator.contains, [concurrent.futures.Future.__dict__,              "__aenter__"], false]
    - ["cf3046010",  operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__aenter__"], false]
    - ["cf3046011",  operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__aenter__"], false]
    - ["cf3046012",  operator.contains, [concurrent.futures.Executor.__dict__,            "__aenter__"], false]

# ---------------------------------------------------------------------------
# combined — __enter__, __exit__, __aenter__ across all 4 cf subjects
#
# Covers the full matrix: 4 classes x 3 methods = 12 rows.
# __enter__: true only for Executor (base class defines the protocol).
# __exit__:  true only for Executor (symmetric with __enter__).
# __aenter__: all false — no async context manager support.
# ThreadPoolExecutor and ProcessPoolExecutor rely on Executor's inherited methods.
# ---------------------------------------------------------------------------

table cf3046.combined:
  description: "concurrent.futures types combined __enter__/__exit__/__aenter__; wave 650"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3046

  columns: [id, function, args, expected]
  rows:
    - ["cf3046013", operator.contains, [concurrent.futures.Future.__dict__,              "__enter__"],  false]
    - ["cf3046014", operator.contains, [concurrent.futures.Future.__dict__,              "__exit__"],   false]
    - ["cf3046015", operator.contains, [concurrent.futures.Future.__dict__,              "__aenter__"], false]
    - ["cf3046016", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__enter__"],  false]
    - ["cf3046017", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__exit__"],   false]
    - ["cf3046018", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__aenter__"], false]
    - ["cf3046019", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__enter__"],  false]
    - ["cf3046020", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__exit__"],   false]
    - ["cf3046021", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__aenter__"], false]
    - ["cf3046022", operator.contains, [concurrent.futures.Executor.__dict__,            "__enter__"],  true]
    - ["cf3046023", operator.contains, [concurrent.futures.Executor.__dict__,            "__exit__"],   true]
    - ["cf3046024", operator.contains, [concurrent.futures.Executor.__dict__,            "__aenter__"], false]
