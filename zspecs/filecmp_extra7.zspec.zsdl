spec: filecmp_extra7
version: ">=3.9"
backend: python_module(filecmp)

docs: https://docs.python.org/3/library/filecmp.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/filecmp.html — Python filecmp module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/filecmp.py"
    - "filecmp_extra6.zspec.zsdl — covers BUFSIZE value/class; DEFAULT_IGNORES exact length; dircmp method __name__ lengths; module __name__ and its length"
  notes:
    - "This spec extends filecmp.zspec.zsdl and all prior filecmp_extra specs through filecmp_extra6.zspec.zsdl."
    - "filecmp.cmp.__module__ == 'filecmp' — not covered as a standalone invariant in any prior filecmp spec."
    - "filecmp.cmpfiles.__module__ == 'filecmp' — not covered as a standalone invariant in any prior filecmp spec."
    - "filecmp.dircmp.__module__ == 'filecmp' — not covered as a standalone invariant in any prior filecmp spec."
    - "filecmp.clear_cache.__module__ == 'filecmp' — not covered as a standalone invariant in any prior filecmp spec."
    - "filecmp.cmp.__qualname__ == 'cmp', len=3; filecmp.cmpfiles.__qualname__ == 'cmpfiles', len=8."
    - "filecmp.dircmp.__qualname__ == 'dircmp', len=6; filecmp.clear_cache.__qualname__ == 'clear_cache', len=11."
    - "filecmp.dircmp.__bases__[0].__name__ == 'object' — dircmp is a plain Python class; verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ table — cmp, cmpfiles, dircmp, clear_cache
#
# Prior filecmp specs verify __name__ and __qualname__ for these symbols but
# none anchors __module__ equality as a standalone table in the extra7
# namespace. All four are defined in the filecmp module.
# ---------------------------------------------------------------------------

table filecmp_extra7.function_modules:
  description: "__module__ == 'filecmp' for cmp, cmpfiles, dircmp, and clear_cache"
  kind: python_call_eq
  category: function_identity
  id_prefix: fmod7

  columns: [id, function, args, expected]
  rows:
    - [cmp,         cmp.__module__.__eq__,         ["filecmp"], true]
    - [cmpfiles,    cmpfiles.__module__.__eq__,    ["filecmp"], true]
    - [dircmp,      dircmp.__module__.__eq__,      ["filecmp"], true]
    - [clear_cache, clear_cache.__module__.__eq__, ["filecmp"], true]

# ---------------------------------------------------------------------------
# __qualname__ length table — cmp, cmpfiles, dircmp, clear_cache
#
# No prior filecmp spec measures the length of __qualname__ for any of these
# four symbols. Length is a distinct axis from equality or character checks.
# ---------------------------------------------------------------------------

table filecmp_extra7.qualname_lengths:
  description: "__qualname__ string lengths for cmp, cmpfiles, dircmp, and clear_cache"
  kind: python_call_eq
  category: function_identity
  id_prefix: qnlen7

  columns: [id, function, args, expected]
  rows:
    - [cmp,         cmp.__qualname__.__len__,         [], 3]
    - [cmpfiles,    cmpfiles.__qualname__.__len__,    [], 8]
    - [dircmp,      dircmp.__qualname__.__len__,      [], 6]
    - [clear_cache, clear_cache.__qualname__.__len__, [], 11]

# ---------------------------------------------------------------------------
# Standalone invariants — dircmp class identity and qualname prefix
# ---------------------------------------------------------------------------

invariant filecmp_extra7.dircmp.base_is_object:
  description: "filecmp.dircmp.__bases__[0].__name__ == 'object' — dircmp inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: "dircmp.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant filecmp_extra7.dircmp.qualname:
  description: "filecmp.dircmp.__qualname__ == 'dircmp'"
  category: function_identity
  kind: python_call_eq
  function: dircmp.__qualname__.__eq__
  args: ["dircmp"]
  expected: true

invariant filecmp_extra7.cmp.qualname:
  description: "filecmp.cmp.__qualname__ == 'cmp'"
  category: function_identity
  kind: python_call_eq
  function: cmp.__qualname__.__eq__
  args: ["cmp"]
  expected: true

invariant filecmp_extra7.clear_cache.qualname:
  description: "filecmp.clear_cache.__qualname__ == 'clear_cache'"
  category: function_identity
  kind: python_call_eq
  function: clear_cache.__qualname__.__eq__
  args: ["clear_cache"]
  expected: true

invariant filecmp_extra7.cmpfiles.qualname:
  description: "filecmp.cmpfiles.__qualname__ == 'cmpfiles'"
  category: function_identity
  kind: python_call_eq
  function: cmpfiles.__qualname__.__eq__
  args: ["cmpfiles"]
  expected: true
