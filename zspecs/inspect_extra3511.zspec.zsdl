spec: in3511
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 681 (in3511): __get__, __set__, __delete__ dict-presence checks for inspect types."
    - "All values false — inspect introspection types do not implement the descriptor protocol."
    - "None of the inspect types define __get__, __set__, or __delete__ in their own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "None of these types implement the descriptor protocol in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
# ---------------------------------------------------------------------------

table in3511.get:
  description: "inspect types __get__ dict-presence checks; wave 681"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3511
  columns: [id, function, args, expected]
  rows:
    - ["in3511001", operator.contains, [inspect.Parameter.__dict__,           "__get__"], false]
    - ["in3511002", operator.contains, [inspect.Signature.__dict__,           "__get__"], false]
    - ["in3511003", operator.contains, [inspect.BoundArguments.__dict__,      "__get__"], false]
    - ["in3511004", operator.contains, [inspect.FrameInfo.__dict__,           "__get__"], false]
    - ["in3511005", operator.contains, [inspect.ArgInfo.__dict__,             "__get__"], false]
    - ["in3511006", operator.contains, [inspect.FullArgSpec.__dict__,         "__get__"], false]
    - ["in3511007", operator.contains, [inspect.Attribute.__dict__,           "__get__"], false]
    - ["in3511008", operator.contains, [inspect.ClassFoundException.__dict__, "__get__"], false]
    - ["in3511009", operator.contains, [inspect.EndOfBlock.__dict__,          "__get__"], false]

