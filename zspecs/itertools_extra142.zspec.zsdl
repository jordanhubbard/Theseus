spec: itertools_extra142
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.groupby (C type), itertools.accumulate (C type), itertools.starmap (C type), itertools.islice (C type), itertools.zip_longest (C type), itertools.pairwise (C type) — doc string len, __name__, __module__, MRO len (Wave 270)."
    - "itertools.groupby.__doc__ len == 323; __name__ == 'groupby' (len 7); MRO len == 2. Verified with Python 3.14.3."
    - "itertools.accumulate.__doc__ len == 69; __name__ == 'accumulate' (len 10); MRO len == 2. Verified with Python 3.14.3."
    - "itertools.starmap.__doc__ len == 126; __name__ == 'starmap' (len 7); MRO len == 2. Verified with Python 3.14.3."
    - "itertools.islice.__doc__ len == 453; __name__ == 'islice' (len 6); MRO len == 2. Verified with Python 3.14.3."
    - "itertools.zip_longest.__doc__ len == 427; __name__ == 'zip_longest' (len 11); MRO len == 2. Verified with Python 3.14.3."
    - "itertools.pairwise.__doc__ len == 112; __name__ == 'pairwise' (len 8); MRO len == 2. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.groupby — C type doc string, name, module, MRO
#
# Wave 270 theme: itertools.groupby — C extension type in itertoolsmodule.c.
#
# itertools.groupby.__class__.__name__ == 'type'
# itertools.groupby.__doc__.__class__.__name__ == 'str'
# len(itertools.groupby.__doc__) == 323
# itertools.groupby.__name__ == 'groupby' (len 7)
# itertools.groupby.__module__ == 'itertools' (len 9)
# len(itertools.groupby.__mro__) == 2
#
# groupby(iterable, key=None) groups consecutive elements by key function.
# New to extra142.
# ---------------------------------------------------------------------------

table itertools_extra142.groupby_type_attrs:
  description: "itertools.groupby: C type, __doc__ str len 323, __name__ len 7, __module__ 'itertools', MRO len 2; wave 270; new to extra142"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsgroupby142

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_class_eq_type,
       "groupby.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.groupby.__class__.__name__.__eq__('type') == True — groupby is a C extension type; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra142"]
    - [groupby_doc_class_eq_str,
       "groupby.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.groupby.__doc__.__class__.__name__.__eq__('str') == True — the groupby docstring is a plain Python str; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra142"]
    - [groupby_doc_len_eq_323,
       "groupby.__doc__.__len__",
       [],
       323,
       "itertools.groupby.__doc__.__len__() == 323 — the groupby docstring has 323 characters; len(__doc__) == 323; verified with Python 3.14.3; new to extra142"]
    - [groupby_name_eq,
       "groupby.__name__.__eq__",
       ["groupby"],
       true,
       "itertools.groupby.__name__.__eq__('groupby') == True — the C type's __name__ is 'groupby'; str.__eq__('groupby') returns True; new to extra142"]
    - [groupby_name_len_eq_7,
       "groupby.__name__.__len__",
       [],
       7,
       "itertools.groupby.__name__.__len__() == 7 — __name__ is 'groupby' which has 7 characters; len('groupby') == 7; new to extra142"]
    - [groupby_module_eq_itertools,
       "groupby.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.groupby.__module__.__eq__('itertools') == True — groupby is defined in itertoolsmodule.c; __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra142"]
    - [groupby_mro_len_eq_2,
       "groupby.__mro__.__len__",
       [],
       2,
       "itertools.groupby.__mro__.__len__() == 2 — groupby's MRO is [groupby, object]; len(__mro__) is 2; new to extra142"]

