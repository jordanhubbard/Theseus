spec: functools_extra2506
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: __add__, __sub__, and __mul__ dict-presence checks for functools classes."
    - "Theme: arithmetic operator dict-presence — checking whether classes define arithmetic operators in their class __dict__."
    - "functools.partial, functools.partialmethod, functools.cached_property, functools.singledispatchmethod, functools.singledispatch, functools.itemgetter — none define __add__, __sub__, or __mul__."
    - "functools.partial is a C extension type that wraps a callable with pre-applied positional args and keyword args; it has no concept of numeric addition, subtraction, or multiplication. Verified with Python 3.14."
    - "functools.partialmethod is a pure-Python descriptor for use in class bodies; it delegates to partial under the hood but itself defines no arithmetic protocol. Verified with Python 3.14."
    - "functools.cached_property is a pure-Python non-data descriptor that caches a computed value in the instance __dict__; it has no numeric semantics. Verified with Python 3.14."
    - "functools.singledispatchmethod is a pure-Python descriptor that dispatches method calls based on the first argument type; it defines no arithmetic protocol. Verified with Python 3.14."
    - "functools.singledispatch (the function decorator variant) is a callable wrapper; its underlying class defines no arithmetic operators. Verified with Python 3.14."
    - "functools.itemgetter is a C extension type that retrieves items from target objects; it is not a numeric type and defines no __add__, __sub__, or __mul__. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial — arithmetic operator absence
#
# Theme: __add__, __sub__, __mul__ absent from functools.partial.__dict__.
# partial is a C extension type that wraps a callable with pre-applied
# positional args and keyword args; it is not a numeric type and holds
# no arithmetic protocol in its class __dict__.
# ---------------------------------------------------------------------------

table functools_extra2506.partial_arithmetic:
  description: "__add__, __sub__, __mul__ absent from functools.partial.__dict__; wave 2506"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: ft2506

  columns: [id, function, args, expected]
  rows:
    - ["ft2506-001", "partial.__dict__.__contains__", ["__add__"], false]
    - ["ft2506-002", "partial.__dict__.__contains__", ["__sub__"], false]
    - ["ft2506-003", "partial.__dict__.__contains__", ["__mul__"], false]

# ---------------------------------------------------------------------------
# Table 2: functools.partialmethod — arithmetic operator absence
#
# Theme: __add__, __sub__, __mul__ absent from functools.partialmethod.__dict__.
# partialmethod is a pure-Python descriptor used inside class bodies to
# create partially-applied method definitions; it has no numeric role.
# ---------------------------------------------------------------------------

table functools_extra2506.partialmethod_arithmetic:
  description: "__add__, __sub__, __mul__ absent from functools.partialmethod.__dict__; wave 2506"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: ft2506

  columns: [id, function, args, expected]
  rows:
    - ["ft2506-004", "partialmethod.__dict__.__contains__", ["__add__"], false]
    - ["ft2506-005", "partialmethod.__dict__.__contains__", ["__sub__"], false]
    - ["ft2506-006", "partialmethod.__dict__.__contains__", ["__mul__"], false]

# ---------------------------------------------------------------------------
# Table 3: functools.cached_property — arithmetic operator absence
#
# Theme: __add__, __sub__, __mul__ absent from functools.cached_property.__dict__.
# cached_property is a non-data descriptor that stores the computed result in
# the instance __dict__ on first access; it is a caching mechanism, not a
# numeric type, and defines no arithmetic operators.
# ---------------------------------------------------------------------------

table functools_extra2506.cached_property_arithmetic:
  description: "__add__, __sub__, __mul__ absent from functools.cached_property.__dict__; wave 2506"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: ft2506

  columns: [id, function, args, expected]
  rows:
    - ["ft2506-007", "cached_property.__dict__.__contains__", ["__add__"], false]
    - ["ft2506-008", "cached_property.__dict__.__contains__", ["__sub__"], false]
    - ["ft2506-009", "cached_property.__dict__.__contains__", ["__mul__"], false]

# ---------------------------------------------------------------------------
# Table 4: functools.singledispatchmethod and functools.singledispatch
#
# Theme: __add__, __sub__, __mul__ absent from singledispatchmethod and
# singledispatch class __dict__.
# singledispatchmethod wraps a method to dispatch on the first non-self argument
# type; singledispatch wraps a function similarly for free functions.
# Neither has any arithmetic semantics.
# ---------------------------------------------------------------------------

table functools_extra2506.singledispatch_arithmetic:
  description: "__add__, __sub__, __mul__ absent from functools.singledispatchmethod and singledispatch __dict__; wave 2506"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: ft2506

  columns: [id, function, args, expected]
  rows:
    - ["ft2506-010", "singledispatchmethod.__dict__.__contains__", ["__add__"], false]
    - ["ft2506-011", "singledispatchmethod.__dict__.__contains__", ["__sub__"], false]
    - ["ft2506-012", "singledispatchmethod.__dict__.__contains__", ["__mul__"], false]
    - ["ft2506-013", "singledispatch.__dict__.__contains__", ["__add__"], false]
    - ["ft2506-014", "singledispatch.__dict__.__contains__", ["__sub__"], false]
    - ["ft2506-015", "singledispatch.__dict__.__contains__", ["__mul__"], false]

# ---------------------------------------------------------------------------
# Table 5: functools.itemgetter — arithmetic operator absence
#
# Theme: __add__, __sub__, __mul__ absent from functools.itemgetter.__dict__.
# itemgetter is a C extension type that retrieves items from target objects via
# their __getitem__; it is a retrieval utility, not a numeric type, and defines
# no arithmetic operators of its own.
# ---------------------------------------------------------------------------

table functools_extra2506.itemgetter_arithmetic:
  description: "__add__, __sub__, __mul__ absent from functools.itemgetter.__dict__; wave 2506"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: ft2506

  columns: [id, function, args, expected]
  rows:
    - ["ft2506-016", "itemgetter.__dict__.__contains__", ["__add__"], false]
    - ["ft2506-017", "itemgetter.__dict__.__contains__", ["__sub__"], false]
    - ["ft2506-018", "itemgetter.__dict__.__contains__", ["__mul__"], false]
