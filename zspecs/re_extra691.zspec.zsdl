spec: re_extra691
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re.Pattern and re.Match documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.Pattern and re.Match property __qualname__ and re.error identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra691.pattern_match_qualnames:
  description: "re.Pattern and re.Match property __qualname__ and re.error identity"
  kind: python_call_eq
  category: pattern_qualnames
  id_prefix: re691pm
  columns: [id, function, args, expected]
  rows:
    - [re691pm001, re.Pattern.pattern.__qualname__.__eq__,    ["Pattern.pattern"],    true]
    - [re691pm002, re.Pattern.flags.__qualname__.__eq__,      ["Pattern.flags"],      true]
    - [re691pm003, re.Pattern.groups.__qualname__.__eq__,     ["Pattern.groups"],     true]
    - [re691pm004, re.Pattern.groupindex.__qualname__.__eq__, ["Pattern.groupindex"], true]
    - [re691pm005, re.Match.string.__qualname__.__eq__,       ["Match.string"],       true]
    - [re691pm006, re.Match.re.__qualname__.__eq__,           ["Match.re"],           true]
    - [re691pm007, re.Match.pos.__qualname__.__eq__,          ["Match.pos"],          true]
    - [re691pm008, re.Match.endpos.__qualname__.__eq__,       ["Match.endpos"],       true]
    - [re691pm009, re.Match.lastindex.__qualname__.__eq__,    ["Match.lastindex"],    true]
    - [re691pm010, re.Match.lastgroup.__qualname__.__eq__,    ["Match.lastgroup"],    true]
    - [re691pm011, re.error.__qualname__.__eq__,              ["error"],              true]
    - [re691pm012, re.error.__module__.__eq__,                ["re"],                 true]
