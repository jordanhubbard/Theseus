spec: itertools_extra631
version: ">=3.9"
backend: python_module(itertools)
docs: "Remaining itertools __doc__ type checks and chain.from_iterable plus module membership checks."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __doc__.__class__.__name__, chain.from_iterable identity, and __module__ membership for select itertools types"
  created_at: "2026-04-12T00:00:00Z"

table itertools_extra631.doc_type_checks:
  description: "__doc__.__class__.__name__ checks for remaining itertools types"
  kind: python_call_eq
  category: itertools_doc_types
  id_prefix: it631dc
  columns: [id, function, args, expected]
  rows:
    - [it631dc001, itertools.starmap.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [it631dc002, itertools.accumulate.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [it631dc003, itertools.filterfalse.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [it631dc004, itertools.zip_longest.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [it631dc005, itertools.combinations_with_replacement.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [it631dc006, itertools.takewhile.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [it631dc007, itertools.dropwhile.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [it631dc008, itertools.pairwise.__doc__.__class__.__name__.__eq__, ["str"], true]

table itertools_extra631.chain_from_iterable_identity:
  description: "Identity checks for itertools.chain.from_iterable"
  kind: python_call_eq
  category: itertools_chain
  id_prefix: it631qn
  columns: [id, function, args, expected]
  rows:
    - [it631qn001, itertools.chain.from_iterable.__qualname__.__eq__, ["chain.from_iterable"], true]
    - [it631qn002, itertools.chain.from_iterable.__class__.__name__.__eq__, ["classmethod_descriptor"], true]

table itertools_extra631.module_membership:
  description: "__module__ checks for select itertools types"
  kind: python_call_eq
  category: itertools_module
  id_prefix: it631md
  columns: [id, function, args, expected]
  rows:
    - [it631md001, itertools.count.__module__.__eq__, ["itertools"], true]
    - [it631md002, itertools.combinations.__module__.__eq__, ["itertools"], true]
    - [it631md003, itertools.permutations.__module__.__eq__, ["itertools"], true]
    - [it631md004, itertools.groupby.__module__.__eq__, ["itertools"], true]
