spec: asyncio_extra2416
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/asyncio.html"
    - "CPython source — Lib/asyncio/ and Modules/_asynciomodule.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 608 (_extra2416): __iter__ and __next__ dict-presence and type classification."
    - "asyncio.Task and asyncio.Future define __iter__ in their class __dict__ (C extension slot for yield-from protocol)."
    - "asyncio.Task.__iter__ and asyncio.Future.__iter__ are wrapper_descriptor objects (C slots), not __next__."
    - "asyncio.AbstractEventLoop and asyncio.BaseEventLoop do NOT define __iter__ or __next__."
    - "asyncio.StreamReader uses async protocol (__aiter__/__anext__), NOT sync __iter__/__next__."
    - "asyncio.Queue, asyncio.Lock, asyncio.Event, asyncio.Condition define neither __iter__ nor __next__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
# Table 1: __iter__ presence in class __dict__ — asyncio coroutine/future types
# ===

table asyncio_extra2416.iter_in_dict:
  description: "asyncio.Task and asyncio.Future define __iter__ in their class __dict__ for the yield-from protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2416
  columns: [id, function, args, expected]
  rows:
    - ["as2416001", "asyncio.Task.__dict__.__contains__", ["__iter__"], true]
    - ["as2416002", "asyncio.Future.__dict__.__contains__", ["__iter__"], true]
    - ["as2416003", "asyncio.AbstractEventLoop.__dict__.__contains__", ["__iter__"], false]
    - ["as2416004", "asyncio.BaseEventLoop.__dict__.__contains__", ["__iter__"], false]
    - ["as2416005", "asyncio.StreamReader.__dict__.__contains__", ["__iter__"], false]
    - ["as2416006", "asyncio.Queue.__dict__.__contains__", ["__iter__"], false]
    - ["as2416007", "asyncio.Lock.__dict__.__contains__", ["__iter__"], false]
    - ["as2416008", "asyncio.Event.__dict__.__contains__", ["__iter__"], false]

# ===
# Table 2: __next__ absence in class __dict__ — asyncio types do not define __next__
# ===

table asyncio_extra2416.next_not_in_dict:
  description: "No asyncio class defines __next__ in its own __dict__; Task/Future use __iter__ only for yield-from"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2416
  columns: [id, function, args, expected]
  rows:
    - ["as2416009", "asyncio.Task.__dict__.__contains__", ["__next__"], false]
    - ["as2416010", "asyncio.Future.__dict__.__contains__", ["__next__"], false]
    - ["as2416011", "asyncio.AbstractEventLoop.__dict__.__contains__", ["__next__"], false]
    - ["as2416012", "asyncio.BaseEventLoop.__dict__.__contains__", ["__next__"], false]
    - ["as2416013", "asyncio.StreamReader.__dict__.__contains__", ["__next__"], false]
    - ["as2416014", "asyncio.Queue.__dict__.__contains__", ["__next__"], false]
    - ["as2416015", "asyncio.Condition.__dict__.__contains__", ["__next__"], false]

# ===
# Table 3: __aiter__/__anext__ in StreamReader class __dict__
# ===

table asyncio_extra2416.async_iter_in_dict:
  description: "asyncio.StreamReader defines __aiter__ and __anext__ (async iteration protocol) but not sync __iter__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2416
  columns: [id, function, args, expected]
  rows:
    - ["as2416016", "asyncio.StreamReader.__dict__.__contains__", ["__aiter__"], true]
    - ["as2416017", "asyncio.StreamReader.__dict__.__contains__", ["__anext__"], true]
    - ["as2416018", "asyncio.StreamReader.__dict__.__contains__", ["__iter__"], false]
    - ["as2416019", "asyncio.StreamReader.__dict__.__contains__", ["__next__"], false]

# ===
# Table 4: __iter__ descriptor type classification for Task and Future
# ===

table asyncio_extra2416.iter_descriptor_class:
  description: "__iter__ on Task and Future is a wrapper_descriptor (C extension slot); async methods on StreamReader are plain functions"
  kind: python_call_eq
  category: type_identity
  id_prefix: as2416
  columns: [id, function, args, expected]
  rows:
    - ["as2416020", "asyncio.Task.__iter__.__class__.__name__", [], "wrapper_descriptor"]
    - ["as2416021", "asyncio.Future.__iter__.__class__.__name__", [], "wrapper_descriptor"]
    - ["as2416022", "asyncio.StreamReader.__aiter__.__class__.__name__", [], "function"]
    - ["as2416023", "asyncio.StreamReader.__anext__.__class__.__name__", [], "function"]
    - ["as2416024", "asyncio.Task.__dict__.__contains__", ["__iter__"], true]
    - ["as2416025", "asyncio.Future.__dict__.__contains__", ["__next__"], false]
