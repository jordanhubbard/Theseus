spec: hashlib_extra52
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra51.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __name__.__class__.__name__.__eq__('str') (the __name__ attribute type axis)."
    - "hashlib_extra50.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __class__.__qualname__.__eq__ and __class__.__module__.__eq__('builtins')."
    - "hashlib_extra49.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256 __class__.__name__.__eq__('builtin_function_or_method') and new __class__.__name__.__eq__('function')."
    - "hashlib_extra44.zspec.zsdl — covers blake2b/blake2s __class__.__name__.__eq__('type')."
    - "hashlib_extra18.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/new __name__.__eq__ and __qualname__.__eq__ string values."
    - "hashlib_extra20.zspec.zsdl — covers md5/sha1/sha256/sha512/new/pbkdf2_hmac __name__.__eq__ string values."
    - "hashlib_extra6.zspec.zsdl — covers blake2b/blake2s __module__.__eq__('_blake2')."
  notes:
    - "This spec extends hashlib through hashlib_extra51; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: No prior hashlib spec checks __doc__.__class__.__name__.__eq__('str') for any hashlib callable. Prior specs check __name__ string values and callable type names, but no prior spec checks the TYPE of the __doc__ attribute. For all hashlib callables (C builtins, Python functions, C extension types) and the module itself, the __doc__ attribute is a Python str object. The __doc__.__class__.__name__ axis is entirely novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__doc__.__class__.__name__ == 'str'. sha256 is a builtin_function_or_method with a C-level docstring exposed as a Python str. No prior spec checks sha256.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.md5.__doc__.__class__.__name__ == 'str'. md5 is a builtin_function_or_method with a C-level docstring. No prior spec checks md5.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__doc__.__class__.__name__ == 'str'. sha1 is a builtin_function_or_method with a C-level docstring. No prior spec checks sha1.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__doc__.__class__.__name__ == 'str'. pbkdf2_hmac is a C builtin with a docstring. No prior spec checks pbkdf2_hmac.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__doc__.__class__.__name__ == 'str'. sha3_256 is an OpenSSL-backed builtin function with a docstring. No prior spec checks sha3_256.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.new.__doc__.__class__.__name__ == 'str'. new is a Python wrapper function with a docstring as a str. No prior spec checks new.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__doc__.__class__.__name__ == 'str'. blake2b is a C extension type with a docstring. No prior spec checks blake2b.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__doc__.__class__.__name__ == 'str'. blake2s is a C extension type with a docstring. No prior spec checks blake2s.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.__doc__.__class__.__name__ == 'str'. The hashlib module itself has a module-level docstring exposed as a Python str. No prior spec checks hashlib's own __doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior hashlib spec checks __doc__.__class__.__qualname__.__eq__('str') for any hashlib object. For built-in str, __qualname__ == __name__ == 'str', but the .__qualname__ attribute chain is distinct. Three representative objects (sha256, new, and the module itself) are checked. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__doc__.__class__.__qualname__ == 'str'. The __class__ of a str object is the built-in str type; its __qualname__ is 'str'. No prior spec checks sha256.__doc__.__class__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.new.__doc__.__class__.__qualname__ == 'str'. new's docstring is a str; its __class__.__qualname__ is 'str'. No prior spec checks new.__doc__.__class__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.__doc__.__class__.__qualname__ == 'str'. The module docstring's __class__.__qualname__ is 'str'. No prior spec checks hashlib.__doc__.__class__.__qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib module-level callable and module __doc__.__class__.__name__.__eq__('str')
#
# Every hashlib callable (sha256, md5, sha1, pbkdf2_hmac, sha3_256, new, blake2b,
# blake2s) and the module itself expose __doc__ as a Python str. No prior hashlib
# spec checks __doc__.__class__.__name__ for any hashlib object. This axis provides
# an independent structural regression vector: if a C extension change causes a
# docstring to become bytes or None, this table detects it.
# ---------------------------------------------------------------------------

table hashlib_extra52.doc_class_names:
  description: "hashlib sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s/module __doc__.__class__.__name__.__eq__('str') — verifies that each hashlib callable's docstring (and the module docstring) is a Python str; novel __doc__.__class__.__name__ axis; no prior hashlib spec checks __doc__.__class__.__name__ for any hashlib object"
  kind: python_call_eq
  category: type_structure
  id_prefix: hashlibdoc52

  columns: [id, function, args, expected]
  rows:
    - [sha256_doc_class_name_eq,     sha256.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [md5_doc_class_name_eq,        md5.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [sha1_doc_class_name_eq,       sha1.__doc__.__class__.__name__.__eq__,       ["str"], true]
    - [pbkdf2_hmac_doc_class_name_eq, pbkdf2_hmac.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sha3_256_doc_class_name_eq,   sha3_256.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [new_doc_class_name_eq,        new.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [blake2b_doc_class_name_eq,    blake2b.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [blake2s_doc_class_name_eq,    blake2s.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [module_doc_class_name_eq,     __doc__.__class__.__name__.__eq__,            ["str"], true]

# ---------------------------------------------------------------------------
# hashlib __doc__.__class__.__qualname__.__eq__('str')
#
# For the built-in str type, __qualname__ == __name__ == 'str', but accessing
# via .__qualname__ is a distinct attribute chain and an independent regression
# vector. No prior hashlib spec checks __doc__.__class__.__qualname__ for any
# hashlib object. Three representative objects confirm the pattern.
# ---------------------------------------------------------------------------

table hashlib_extra52.doc_class_qualnames:
  description: "hashlib sha256/new/module __doc__.__class__.__qualname__.__eq__('str') — str.__qualname__ == 'str'; novel __doc__.__class__.__qualname__ axis distinct from __doc__.__class__.__name__; no prior hashlib spec checks __doc__.__class__.__qualname__ for any hashlib object"
  kind: python_call_eq
  category: type_structure
  id_prefix: hashlibdocqual52

  columns: [id, function, args, expected]
  rows:
    - [sha256_doc_class_qualname_eq, sha256.__doc__.__class__.__qualname__.__eq__, ["str"], true]
    - [new_doc_class_qualname_eq,    new.__doc__.__class__.__qualname__.__eq__,    ["str"], true]
    - [module_doc_class_qualname_eq, __doc__.__class__.__qualname__.__eq__,        ["str"], true]
