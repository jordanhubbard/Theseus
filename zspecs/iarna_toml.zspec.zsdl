spec: iarna_toml
version: ">=2.2.0"
backend: node(@iarna/toml)

docs: https://github.com/iarna/iarna-toml#readme

provenance:
  derived_from:
    - "@iarna/toml README — https://github.com/iarna/iarna-toml#readme"
    - "TOML 1.0.0 specification — https://toml.io/en/v1.0.0"
    - "Test vectors verified with @iarna/toml via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "@iarna/toml source"
  notes:
    - "TOML parser/emitter conforming to TOML v1.0.0."
    - "Install: npm install @iarna/toml"
    - "parse(s) returns the JS value; stringify(obj) returns TOML text."
    - "Spec name underscored per ZSDL convention; npm package name is @iarna/toml (scoped)."
  rfcs:
    - "TOML 1.0.0 — https://toml.io/en/v1.0.0"
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "parse() throws on invalid TOML. Valid TOML produces a deterministic JS value."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table iarna_toml.parse:
  kind: node_module_call_eq
  category: parse
  function: parse
  id_prefix: parse

  columns: [id, args, expected]
  rows:
    - [string_value,    ["foo = \"bar\""],                       {foo: "bar"}]
    - [int_value,       ["n = 42"],                               {n: 42}]
    - [bool_true,       ["flag = true"],                          {flag: true}]
    - [bool_false,      ["flag = false"],                         {flag: false}]
    - [array,           ["arr = [1, 2, 3]"],                      {arr: [1, 2, 3]}]
    - [section,         ["[section]\nkey = 42"],                  {section: {key: 42}}]
    - [empty,           [""],                                      {}]
    - [comment_skipped, ["# comment\nfoo = \"bar\""],             {foo: "bar"}]
    - [multi_keys,      ["a = 1\nb = 2"],                         {a: 1, b: 2}]

table iarna_toml.stringify:
  kind: node_module_call_eq
  category: stringify
  function: stringify
  id_prefix: stringify

  columns: [id, args, expected]
  rows:
    - [single_pair,    [{foo: "bar"}],          "foo = \"bar\"\n"]
    - [multi_keys,     [{a: 1, b: 2}],          "a = 1\nb = 2\n"]
    - [boolean,        [{flag: true}],          "flag = true\n"]
    - [empty_object,   [{}],                     ""]
