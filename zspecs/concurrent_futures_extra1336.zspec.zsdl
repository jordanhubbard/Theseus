spec: concurrent_futures_extra1336
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 536 (_extra1336): focuses on __hash__ and __eq__ method checks for concurrent.futures classes."
    - "concurrent.futures.Future.__hash__.__class__.__name__ == 'wrapper_descriptor' — inherits object.__hash__, hashable by identity."
    - "concurrent.futures.Future.__hash__.__qualname__ == 'object.__hash__' — no custom __hash__ defined."
    - "concurrent.futures.Future.__eq__.__qualname__ == 'object.__eq__' — Future does not define custom equality."
    - "concurrent.futures.ThreadPoolExecutor.__hash__.__class__.__name__ == 'wrapper_descriptor' — executor is hashable by identity."
    - "concurrent.futures.ThreadPoolExecutor.__hash__.__qualname__ == 'object.__hash__' — inherits from object."
    - "concurrent.futures.ProcessPoolExecutor.__hash__.__class__.__name__ == 'wrapper_descriptor' — same as ThreadPoolExecutor."
    - "concurrent.futures.Executor.__hash__.__class__.__name__ == 'wrapper_descriptor' — abstract base is hashable by identity."
    - "All concurrent.futures classes inherit __eq__ from object — qualname is 'object.__eq__'."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table concurrent_futures_extra1336.hash_class_names:
  description: "concurrent.futures classes: __hash__ method class checks — all inherit wrapper_descriptor from object.__hash__"
  kind: python_call_eq
  category: identity
  id_prefix: cf1336hc
  columns: [id, function, args, expected]
  rows:
    - [cf1336hc001, concurrent.futures.Future.__hash__.__class__.__name__.__eq__,              ["wrapper_descriptor"], true]
    - [cf1336hc002, concurrent.futures.ThreadPoolExecutor.__hash__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [cf1336hc003, concurrent.futures.ProcessPoolExecutor.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [cf1336hc004, concurrent.futures.Executor.__hash__.__class__.__name__.__eq__,            ["wrapper_descriptor"], true]
    - [cf1336hc005, concurrent.futures.Future.__hash__.__qualname__.__eq__,                    ["object.__hash__"],    true]
    - [cf1336hc006, concurrent.futures.ThreadPoolExecutor.__hash__.__qualname__.__eq__,        ["object.__hash__"],    true]

