spec: asyncio_extra676
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-task.html"
  not_derived_from: ["CPython source code"]
  notes: ["Covers asyncio.Barrier (3.11+), asyncio.timeout, asyncio.TaskGroup identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra676.barrier_identity:
  description: "Identity checks for asyncio.Barrier class attributes"
  kind: python_call_eq
  category: class_identity
  id_prefix: as676bi
  columns: [id, function, args, expected]
  rows:
    - [as676bi001, asyncio.Barrier.__qualname__.__eq__, ["Barrier"], true]
    - [as676bi002, asyncio.Barrier.__module__.__eq__, ["asyncio.locks"], true]
    - [as676bi003, asyncio.Barrier.__class__.__name__.__eq__, ["type"], true]
    - [as676bi004, asyncio.Barrier.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [as676bi005, asyncio.Barrier.__init__.__qualname__.__eq__, ["Barrier.__init__"], true]
    - [as676bi006, asyncio.Barrier.wait.__qualname__.__eq__, ["Barrier.wait"], true]
    - [as676bi007, asyncio.Barrier.abort.__qualname__.__eq__, ["Barrier.abort"], true]
    - [as676bi008, asyncio.Barrier.reset.__qualname__.__eq__, ["Barrier.reset"], true]

