spec: abc_extra113
version: ">=3.11"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra112.zspec.zsdl."
    - "This spec covers: wave 258 theme — ABCMeta special and private method __qualname__ equality checks not previously covered. Prior specs covered: extra95 covered ABCMeta._abc_registry_clear/__qualname__.__len__() and _dump_registry/__qualname__.__len__(); extra96 covered ABCMeta._dump_registry/__qualname__.__len__() and ABCMeta.__subclasshook__/__qualname__.__len__(); extra100 covered ABCMeta.__prepare__/__qualname__.__len__()==19. NOT previously covered as equality checks: ABCMeta.__prepare__.__qualname__.__eq__('ABCMeta.__prepare__'); ABCMeta.__init_subclass__.__qualname__.__eq__('ABCMeta.__init_subclass__'); ABCMeta.__subclasshook__.__qualname__.__eq__('ABCMeta.__subclasshook__'); ABCMeta._dump_registry.__code__.co_qualname.__eq__('ABCMeta._dump_registry'); ABCMeta._abc_caches_clear.__code__.co_qualname.__eq__('ABCMeta._abc_caches_clear'); ABCMeta._abc_registry_clear.__code__.co_qualname.__eq__('ABCMeta._abc_registry_clear'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "ABCMeta.__prepare__.__qualname__ == 'ABCMeta.__prepare__' (len=19: 'ABCMeta.'=8+'__prepare__'=11=19). ABCMeta.__init_subclass__.__qualname__ == 'ABCMeta.__init_subclass__' (len=25: 'ABCMeta.'=8+'__init_subclass__'=17=25; tied with __instancecheck__==__subclasscheck__==25). ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (len=24: 'ABCMeta.'=8+'__subclasshook__'=16=24). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "ABCMeta._dump_registry.__code__.co_qualname == 'ABCMeta._dump_registry' (len=22: 'ABCMeta.'=8+'_dump_registry'=14=22; co_argcount=2: cls and file; co_varnames.__len__()==6). ABCMeta._abc_caches_clear.__code__.co_qualname == 'ABCMeta._abc_caches_clear' (len=25: tied with __init_subclass__; co_argcount=1). ABCMeta._abc_registry_clear.__code__.co_qualname == 'ABCMeta._abc_registry_clear' (len=27: 'ABCMeta.'=8+'_abc_registry_clear'=19=27; longest ABCMeta private method qualname; co_argcount=1). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta special method __qualname__ equality — extra113
#
# Wave 258 theme: __prepare__, __init_subclass__, __subclasshook__ __qualname__ equality.
#
# abc.ABCMeta.__prepare__.__qualname__        == 'ABCMeta.__prepare__'        (len=19)
# abc.ABCMeta.__subclasshook__.__qualname__   == 'ABCMeta.__subclasshook__'   (len=24)
# abc.ABCMeta.__init_subclass__.__qualname__  == 'ABCMeta.__init_subclass__'  (len=25)
# ---------------------------------------------------------------------------

table abc_extra113.abc_abcmeta_special_qualname_eq:
  description: "abc.ABCMeta special method __qualname__ equality checks in abcmeta113 namespace — wave 258 theme: __prepare__, __init_subclass__, __subclasshook__ __qualname__ equality; ABCMeta.__prepare__.__qualname__.__eq__('ABCMeta.__prepare__')==True (len=19: 'ABCMeta.'=8+'__prepare__'=11=19; __prepare__ is a classmethod called before the class body executes to create the namespace dict; ABCMeta.__prepare__ returns an empty dict by default; it is a builtin_function_or_method from C extension); ABCMeta.__prepare__.__qualname__.__len__()==19; ABCMeta.__subclasshook__.__qualname__.__eq__('ABCMeta.__subclasshook__')==True (len=24: 'ABCMeta.'=8+'__subclasshook__'=16=24; __subclasshook__ is the hook that allows customization of issubclass() checks; in ABCMeta it returns NotImplemented by default, deferring to the standard subclass machinery; it is a builtin_function_or_method); ABCMeta.__subclasshook__.__qualname__.__len__()==24; ABCMeta.__init_subclass__.__qualname__.__eq__('ABCMeta.__init_subclass__')==True (len=25: 'ABCMeta.'=8+'__init_subclass__'=17=25; __init_subclass__ is called on the base class whenever the class is subclassed; tied with __instancecheck__==__subclasscheck__==25; it is a builtin_function_or_method); ABCMeta.__init_subclass__.__qualname__.__len__()==25; compare qualname lengths: __prepare__=19 (shortest special method in this table) < __subclasshook__=24 (5 more: '__subclasshook__'=16 vs '__prepare__'=11, diff=5) < __init_subclass__=25 (tied with __instancecheck__==__subclasscheck__==25); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: abcmeta113

  columns: [id, function, args, expected, description]
  rows:
    - [prep_eq,   ABCMeta.__prepare__.__qualname__.__eq__,       ["ABCMeta.__prepare__"],       true, "ABCMeta.__prepare__.__qualname__ == 'ABCMeta.__prepare__' (len=19); verified with Python 3.14.3"]
    - [prep_len,  ABCMeta.__prepare__.__qualname__.__len__,      [],                            19,   "ABCMeta.__prepare__.__qualname__.__len__() == 19 ('ABCMeta.__prepare__'=19); verified with Python 3.14.3"]
    - [hook_eq,   ABCMeta.__subclasshook__.__qualname__.__eq__,  ["ABCMeta.__subclasshook__"],  true, "ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (len=24); verified with Python 3.14.3"]
    - [hook_len,  ABCMeta.__subclasshook__.__qualname__.__len__, [],                            24,   "ABCMeta.__subclasshook__.__qualname__.__len__() == 24 ('ABCMeta.__subclasshook__'=24); verified with Python 3.14.3"]
    - [isub_eq,   ABCMeta.__init_subclass__.__qualname__.__eq__, ["ABCMeta.__init_subclass__"], true, "ABCMeta.__init_subclass__.__qualname__ == 'ABCMeta.__init_subclass__' (len=25, tied with __instancecheck__); verified with Python 3.14.3"]
    - [isub_len,  ABCMeta.__init_subclass__.__qualname__.__len__, [],                           25,   "ABCMeta.__init_subclass__.__qualname__.__len__() == 25 (tied with __instancecheck__==__subclasscheck__==25); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta private method __code__.co_qualname equality — extra113
#
# Wave 258 theme: _dump_registry, _abc_caches_clear, _abc_registry_clear co_qualname equality.
#
# abc.ABCMeta._dump_registry.__code__.co_qualname     == 'ABCMeta._dump_registry'     (len=22)
# abc.ABCMeta._abc_caches_clear.__code__.co_qualname  == 'ABCMeta._abc_caches_clear'  (len=25)
# abc.ABCMeta._abc_registry_clear.__code__.co_qualname == 'ABCMeta._abc_registry_clear' (len=27)
# ---------------------------------------------------------------------------

table abc_extra113.abc_abcmeta_private_coqualname_eq:
  description: "abc.ABCMeta private method __code__.co_qualname equality checks in abcmeta113 namespace — wave 258 theme: _dump_registry, _abc_caches_clear, _abc_registry_clear co_qualname equality; ABCMeta._dump_registry.__code__.co_qualname.__eq__('ABCMeta._dump_registry')==True (len=22: 'ABCMeta.'=8+'_dump_registry'=14=22; _dump_registry prints a debug dump of the ABC registry to a file; co_argcount=2: cls and file; co_varnames.__len__()==6: cls, file, _abc_registry, _abc_cache, _abc_negative_cache, _abc_negative_cache_version); ABCMeta._dump_registry.__code__.co_qualname.__len__()==22; ABCMeta._dump_registry.__code__.co_argcount.__eq__(2)==True; ABCMeta._abc_caches_clear.__code__.co_qualname.__eq__('ABCMeta._abc_caches_clear')==True (len=25: 'ABCMeta.'=8+'_abc_caches_clear'=17=25; _abc_caches_clear clears the ABC's subclass/instance check caches; co_argcount=1: only cls; tied with __init_subclass__==25); ABCMeta._abc_caches_clear.__code__.co_qualname.__len__()==25; ABCMeta._abc_caches_clear.__code__.co_argcount.__eq__(1)==True; ABCMeta._abc_registry_clear.__code__.co_qualname.__eq__('ABCMeta._abc_registry_clear')==True (len=27: 'ABCMeta.'=8+'_abc_registry_clear'=19=27; the longest ABCMeta private method co_qualname; _abc_registry_clear clears the virtual subclass registry; co_argcount=1: only cls); ABCMeta._abc_registry_clear.__code__.co_qualname.__len__()==27; ABCMeta._abc_registry_clear.__code__.co_argcount.__eq__(1)==True; compare co_qualname lengths: _dump_registry=22 (shortest private method) < _abc_caches_clear=25 (3 more: '_abc_caches_clear'=17 vs '_dump_registry'=14, diff=3) < _abc_registry_clear=27 (longest; 2 more than _abc_caches_clear: '_abc_registry_clear'=19 vs '_abc_caches_clear'=17, diff=2); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcmeta113a

  columns: [id, function, args, expected, description]
  rows:
    - [dr_coq_eq,  abc.ABCMeta._dump_registry.__code__.co_qualname.__eq__,      ["ABCMeta._dump_registry"],     true, "ABCMeta._dump_registry.__code__.co_qualname == 'ABCMeta._dump_registry' (len=22); verified with Python 3.14.3"]
    - [dr_coq_len, abc.ABCMeta._dump_registry.__code__.co_qualname.__len__,     [],                             22,   "ABCMeta._dump_registry co_qualname.__len__() == 22 ('ABCMeta._dump_registry'=22, shortest private method); verified with Python 3.14.3"]
    - [dr_argc,    abc.ABCMeta._dump_registry.__code__.co_argcount.__eq__,      [2],                            true, "ABCMeta._dump_registry.__code__.co_argcount == 2 (cls and file; most args in private methods group); verified with Python 3.14.3"]
    - [dr_var_len, abc.ABCMeta._dump_registry.__code__.co_varnames.__len__,     [],                             6,    "ABCMeta._dump_registry co_varnames.__len__() == 6 (cls, file, _abc_registry, _abc_cache, _abc_negative_cache, _abc_negative_cache_version); verified with Python 3.14.3"]
    - [cc_coq_eq,  abc.ABCMeta._abc_caches_clear.__code__.co_qualname.__eq__,   ["ABCMeta._abc_caches_clear"],  true, "ABCMeta._abc_caches_clear.__code__.co_qualname == 'ABCMeta._abc_caches_clear' (len=25); verified with Python 3.14.3"]
    - [cc_coq_len, abc.ABCMeta._abc_caches_clear.__code__.co_qualname.__len__,  [],                             25,   "ABCMeta._abc_caches_clear co_qualname.__len__() == 25 (tied with __init_subclass__==25); verified with Python 3.14.3"]
    - [cc_argc,    abc.ABCMeta._abc_caches_clear.__code__.co_argcount.__eq__,   [1],                            true, "ABCMeta._abc_caches_clear.__code__.co_argcount == 1 (cls only; fewest args); verified with Python 3.14.3"]
    - [rc_coq_eq,  abc.ABCMeta._abc_registry_clear.__code__.co_qualname.__eq__, ["ABCMeta._abc_registry_clear"], true, "ABCMeta._abc_registry_clear.__code__.co_qualname == 'ABCMeta._abc_registry_clear' (len=27, longest); verified with Python 3.14.3"]
    - [rc_coq_len, abc.ABCMeta._abc_registry_clear.__code__.co_qualname.__len__, [],                            27,   "ABCMeta._abc_registry_clear co_qualname.__len__() == 27 (longest ABCMeta private method co_qualname); verified with Python 3.14.3"]
    - [rc_argc,    abc.ABCMeta._abc_registry_clear.__code__.co_argcount.__eq__, [1],                            true, "ABCMeta._abc_registry_clear.__code__.co_argcount == 1 (cls only; tied with _abc_caches_clear); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta qualname length cross-checks — extra113
#
# Wave 258 theme: comparing qualname lengths across all ABCMeta methods.
#
# __new__=15, register=16, __prepare__=19, _dump_registry=22, __subclasshook__=24,
# __instancecheck__==__subclasscheck__==__init_subclass__==_abc_caches_clear==25 (four-way tie),
# _abc_registry_clear=27 (longest)
# ---------------------------------------------------------------------------

table abc_extra113.abc_abcmeta_qualname_ordering:
  description: "abc.ABCMeta method qualname length ordering cross-checks in abcmeta113 namespace — wave 258 theme: confirming the complete qualname length ordering across all ABCMeta methods; ABCMeta.__new__ co_qualname len=15 (shortest; covered extra104); ABCMeta.register co_qualname len=16 (covered extra102); ABCMeta.__prepare__.__qualname__.__len__()==19; ABCMeta._dump_registry.__code__.co_qualname.__len__()==22; ABCMeta.__subclasshook__.__qualname__.__len__()==24; ABCMeta.__instancecheck__.__qualname__.__len__()==25 (covered extra101; tied with __subclasscheck__==__init_subclass__==_abc_caches_clear==25); ABCMeta.__subclasscheck__.__qualname__.__len__()==25 (covered extra102); ABCMeta.__init_subclass__.__qualname__.__len__()==25 (tied with __instancecheck__==__subclasscheck__); ABCMeta._abc_caches_clear.__code__.co_qualname.__len__()==25 (tied: four-way tie at 25); ABCMeta._abc_registry_clear.__code__.co_qualname.__len__()==27 (longest; 2 more than the four-way tie at 25); ordering: __new__=15 < register=16 < __prepare__=19 < _dump_registry=22 < __subclasshook__=24 < __instancecheck__==__subclasscheck__==__init_subclass__==_abc_caches_clear==25 (four-way tie) < _abc_registry_clear=27 (longest); all qualnames use 'ABCMeta.' prefix (len=8); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: abcmeta113b

  columns: [id, function, args, expected, description]
  rows:
    - [new_15,    abc.ABCMeta.__new__.__code__.co_qualname.__len__,           [], 15, "ABCMeta.__new__ co_qualname len=15 (shortest; covered extra104); verified with Python 3.14.3"]
    - [reg_16,    abc.ABCMeta.register.__code__.co_qualname.__len__,          [], 16, "ABCMeta.register co_qualname len=16 (covered extra102); verified with Python 3.14.3"]
    - [prep_19,   abc.ABCMeta.__prepare__.__qualname__.__len__,               [], 19, "ABCMeta.__prepare__ qualname len=19; verified with Python 3.14.3"]
    - [dr_22,     abc.ABCMeta._dump_registry.__code__.co_qualname.__len__,    [], 22, "ABCMeta._dump_registry co_qualname len=22; verified with Python 3.14.3"]
    - [hook_24,   abc.ABCMeta.__subclasshook__.__qualname__.__len__,          [], 24, "ABCMeta.__subclasshook__ qualname len=24; verified with Python 3.14.3"]
    - [ic_25,     abc.ABCMeta.__instancecheck__.__qualname__.__len__,         [], 25, "ABCMeta.__instancecheck__ qualname len=25 (four-way tie at 25); verified with Python 3.14.3"]
    - [sc_25,     abc.ABCMeta.__subclasscheck__.__qualname__.__len__,         [], 25, "ABCMeta.__subclasscheck__ qualname len=25 (tied with __instancecheck__); verified with Python 3.14.3"]
    - [isub_25,   abc.ABCMeta.__init_subclass__.__qualname__.__len__,         [], 25, "ABCMeta.__init_subclass__ qualname len=25 (tied: four-way tie at 25); verified with Python 3.14.3"]
    - [cc_25,     abc.ABCMeta._abc_caches_clear.__code__.co_qualname.__len__, [], 25, "ABCMeta._abc_caches_clear co_qualname len=25 (fourth in four-way tie at 25); verified with Python 3.14.3"]
    - [rc_27,     abc.ABCMeta._abc_registry_clear.__code__.co_qualname.__len__, [], 27, "ABCMeta._abc_registry_clear co_qualname len=27 (longest ABCMeta method qualname); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra113
# ---------------------------------------------------------------------------

invariant abc_extra113.ABCMeta_prepare_qualname_eq:
  description: "abc.ABCMeta.__prepare__.__qualname__.__eq__('ABCMeta.__prepare__') returns True — 'ABCMeta.__prepare__' has len=19: 'ABCMeta.'=8+'__prepare__'=11=19; ABCMeta.__prepare__ is a classmethod (builtin_function_or_method from C extension _abc); it is called by the Python interpreter before executing the class body to create the namespace dict; ABCMeta.__prepare__ returns an empty plain dict by default (type.__prepare__ is inherited and does the same); ABCMeta.__prepare__.__qualname__.__len__()==19 (shortest ABCMeta special method qualname in this spec; compare: __subclasshook__=24, __init_subclass__=25, __instancecheck__==__subclasscheck__==25); '__prepare__'=11 chars is shorter than '__subclasshook__'=16 and '__init_subclass__'=17; ABCMeta.__module__=='abc' (len=3); ABCMeta.__name__.__len__()==7; first standalone ABCMeta.__prepare__ qualname equality invariant in abcmeta113 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__prepare__.__qualname__.__eq__
  args: ["ABCMeta.__prepare__"]
  expected: true

invariant abc_extra113.ABCMeta_subclasshook_qualname_len_24:
  description: "abc.ABCMeta.__subclasshook__.__qualname__.__len__() == 24 — 'ABCMeta.__subclasshook__' = 'ABCMeta.'=8+'__subclasshook__'=16=24; ABCMeta.__subclasshook__.__qualname__.__eq__('ABCMeta.__subclasshook__')==True; ABCMeta.__subclasshook__ is a classmethod that can be overridden in ABC subclasses to customize issubclass() behavior; the base implementation in ABCMeta returns NotImplemented, deferring to the standard MRO-based subclass check; '__subclasshook__'=16 chars (5 more than '__prepare__'=11, matching the qualname length difference of 5: 24-19=5); compare: ABCMeta.__subclasshook__ qualname len=24 < __init_subclass__==__instancecheck__==__subclasscheck__==25 (1 less than the four-way tie; '__subclasshook__'=16 < '__init_subclass__'=17, diff=1); ABCMeta.__module__=='abc' (len=3); ABCMeta.__name__.__len__()==7; first standalone ABCMeta.__subclasshook__ qualname length invariant in abcmeta113 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__subclasshook__.__qualname__.__len__
  args: []
  expected: 24

invariant abc_extra113.ABCMeta_dump_registry_coqualname_eq:
  description: "abc.ABCMeta._dump_registry.__code__.co_qualname.__eq__('ABCMeta._dump_registry') returns True — 'ABCMeta._dump_registry' has len=22: 'ABCMeta.'=8+'_dump_registry'=14=22; ABCMeta._dump_registry is a pure-Python method (has __code__; compare: __prepare__/__subclasshook__/__init_subclass__ are C-extension builtins without __code__); _dump_registry prints a debug representation of the ABC's virtual subclass registry to a file; co_argcount=2 (cls and file); co_varnames.__len__()==6 (cls, file, _abc_registry, _abc_cache, _abc_negative_cache, _abc_negative_cache_version); len=22 places it between register=16 (6 shorter) and __subclasshook__=24 (2 longer): 16 < 22 < 24; ABCMeta._dump_registry.__code__.co_qualname.__len__()==22; ABCMeta._abc_caches_clear.__code__.co_qualname.__len__()==25; ABCMeta._abc_registry_clear.__code__.co_qualname.__len__()==27; first standalone _dump_registry co_qualname equality invariant in abcmeta113 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abc.ABCMeta._dump_registry.__code__.co_qualname.__eq__
  args: ["ABCMeta._dump_registry"]
  expected: true

invariant abc_extra113.ABCMeta_abc_registry_clear_coqualname_len_27:
  description: "abc.ABCMeta._abc_registry_clear.__code__.co_qualname.__len__() == 27 — 'ABCMeta._abc_registry_clear' = 'ABCMeta.'=8+'_abc_registry_clear'=19=27; this is the longest ABCMeta method co_qualname in any abc spec; ABCMeta._abc_registry_clear.__code__.co_qualname.__eq__('ABCMeta._abc_registry_clear')==True; ABCMeta._abc_registry_clear clears the virtual subclass registry (the set of classes registered via ABCMeta.register()); co_argcount=1 (cls only; the simplest signature despite the longest name); co_varnames == ('cls',) (len=1); compare: _abc_registry_clear=27 > _abc_caches_clear=25 (diff=2: '_abc_registry_clear'=19 vs '_abc_caches_clear'=17, diff=2) > __instancecheck__==__subclasscheck__==__init_subclass__=25 (same tier); '_abc_registry_clear'=19 chars is the longest private method name in ABCMeta; ABCMeta.__module__=='abc'; ABCMeta.__name__.__len__()==7; first standalone _abc_registry_clear co_qualname length invariant in abcmeta113 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abc.ABCMeta._abc_registry_clear.__code__.co_qualname.__len__
  args: []
  expected: 27

invariant abc_extra113.ABCMeta_abc_caches_clear_coqualname_eq:
  description: "abc.ABCMeta._abc_caches_clear.__code__.co_qualname.__eq__('ABCMeta._abc_caches_clear') returns True — 'ABCMeta._abc_caches_clear' has len=25: 'ABCMeta.'=8+'_abc_caches_clear'=17=25; tied with ABCMeta.__instancecheck__.__qualname__.__len__()==25 and ABCMeta.__subclasscheck__.__qualname__.__len__()==25 and ABCMeta.__init_subclass__.__qualname__.__len__()==25 (four-way tie at 25); ABCMeta._abc_caches_clear is a pure-Python method (has __code__; compare: __instancecheck__/__subclasscheck__/__init_subclass__ are C-extension builtins); _abc_caches_clear clears the subclass and instance check caches maintained in _abc_data to force re-evaluation on the next isinstance()/issubclass() call; co_argcount=1 (cls only; same as _abc_registry_clear); co_varnames == ('cls',) (len=1); '_abc_caches_clear'=17 chars is 2 shorter than '_abc_registry_clear'=19 (diff=2, matching co_qualname length difference); ABCMeta.__module__=='abc'; ABCMeta.__name__.__len__()==7; first standalone _abc_caches_clear co_qualname equality invariant in abcmeta113 namespace; wave 258; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: abc.ABCMeta._abc_caches_clear.__code__.co_qualname.__eq__
  args: ["ABCMeta._abc_caches_clear"]
  expected: true
