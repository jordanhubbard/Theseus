spec: change_case
version: ">=5.0.0"
backend: node(change-case)

docs: https://www.npmjs.com/package/change-case

provenance:
  derived_from:
    - "change-case README — https://www.npmjs.com/package/change-case"
    - "Test vectors verified with change-case via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "change-case source"
  notes:
    - "change-case is an npm package. Install: npm install change-case"
    - "Provides camelCase, snakeCase, pascalCase, constantCase and other transforms."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns transformed string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table change_case.camelCase:
  kind: node_module_call_eq
  function: camelCase
  category: transform
  id_prefix: ccamel

  columns: [id, args, expected]
  rows:
    - [spaced, ["hello world"],  "helloWorld"]
    - [snake,  ["foo_bar_baz"],  "fooBarBaz"]

table change_case.snakeCase:
  kind: node_module_call_eq
  function: snakeCase
  category: transform
  id_prefix: csnake

  columns: [id, args, expected]
  rows:
    - [spaced, ["Hello World"],  "hello_world"]
    - [camel,  ["fooBarBaz"],    "foo_bar_baz"]

table change_case.pascalCase:
  kind: node_module_call_eq
  function: pascalCase
  category: transform
  id_prefix: cpascal

  columns: [id, args, expected]
  rows:
    - [spaced, ["hello world"],  "HelloWorld"]

table change_case.constantCase:
  kind: node_module_call_eq
  function: constantCase
  category: transform
  id_prefix: cconst

  columns: [id, args, expected]
  rows:
    - [spaced, ["Hello World"],  "HELLO_WORLD"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:10:52Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
