spec: change_case
version: ">=4.0.0"
backend: node(change-case)

docs: https://github.com/blakeembrey/change-case#readme

provenance:
  derived_from:
    - "change-case README — https://github.com/blakeembrey/change-case#readme"
    - "Test vectors verified with change-case@4.1.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "change-case source"
  notes:
    - "change-case@4 (CJS) exports named functions: camelCase, snakeCase, pascalCase, etc."
    - "camelCase converts to lowerCamelCase."
    - "snakeCase converts to snake_case."
    - "pascalCase converts to UpperCamelCase."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns transformed string. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table change_case.transforms:
  kind: node_module_call_eq
  category: transforms
  id_prefix: cc

  columns: [id, function, args, expected]
  rows:
    - [camel_space,  camelCase,   ["hello world"],  "helloWorld"]
    - [snake_camel,  snakeCase,   ["helloWorld"],   "hello_world"]
    - [pascal_dash,  pascalCase,  ["hello-world"],  "HelloWorld"]
    - [camel_snake,  camelCase,   ["foo_bar_baz"],  "fooBarBaz"]
