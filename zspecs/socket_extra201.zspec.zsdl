spec: socket_extra201
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "socket.__name__ == 'socket' — the module's own name."
    - "socket.__package__ == '' — top-level module, empty string package."
    - "socket.__spec__.name == 'socket' — the ModuleSpec name matches the module name."
    - "socket.__loader__.__class__.__name__ == 'SourceFileLoader' — the visible socket module is a Python source file (Lib/socket.py) wrapping _socket."
    - "socket.__doc__.__class__.__name__ == 'str' — the module docstring is a str object."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket module-level dunder identity attributes — __name__ and __package__
# ---------------------------------------------------------------------------

table socket_extra201.module_name_attrs:
  description: "socket module __name__ and __package__ dunder attribute identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: socketmod201name

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,        __name__.__eq__,    ["socket"], true, "socket.__name__ == 'socket'"]
    - [package_eq,     __package__.__eq__, [""],       true, "socket.__package__ == '' — top-level module has empty package string"]
    - [name_is_str,    __name__.__class__.__name__.__eq__,    ["str"], true, "socket.__name__ is a str object"]
    - [package_is_str, __package__.__class__.__name__.__eq__, ["str"], true, "socket.__package__ is a str object"]

# ---------------------------------------------------------------------------
# socket module-level dunder spec attributes — __spec__.name
# ---------------------------------------------------------------------------

table socket_extra201.module_spec_attrs:
  description: "socket module __spec__ dunder attribute identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: socketmod201spec

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,       __spec__.name.__eq__,               ["socket"],    true, "socket.__spec__.name == 'socket'"]
    - [spec_name_is_str,   __spec__.name.__class__.__name__.__eq__, ["str"],   true, "socket.__spec__.name is a str object"]
    - [spec_name_matches,  __spec__.name.__eq__,               ["socket"],    true, "socket.__spec__.name equals socket.__name__"]
    - [spec_class_eq,      __spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "socket.__spec__ is a ModuleSpec object"]

# ---------------------------------------------------------------------------
# socket module-level dunder loader and doc attributes
# ---------------------------------------------------------------------------

table socket_extra201.module_loader_doc_attrs:
  description: "socket module __loader__ and __doc__ dunder attribute identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: socketmod201loader

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_eq,  __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "socket.__loader__.__class__.__name__ == 'SourceFileLoader' — socket is a Python source module wrapping _socket"]
    - [doc_class_eq,     __doc__.__class__.__name__.__eq__,    ["str"],              true, "socket.__doc__.__class__.__name__ == 'str' — module docstring is a str"]
    - [doc_is_str,       __doc__.__class__.__name__.__eq__,    ["str"],              true, "socket.__doc__ is a str object (module has a docstring)"]
    - [loader_is_obj,    __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "socket.__loader__ is a SourceFileLoader instance"]

# ---------------------------------------------------------------------------
# Standalone invariants (8 total)
# ---------------------------------------------------------------------------

invariant socket_extra201.name_eq:
  description: "socket.__name__ == 'socket'"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra201.package_eq:
  description: "socket.__package__ == '' — top-level module, empty package"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant socket_extra201.spec_name_eq:
  description: "socket.__spec__.name == 'socket'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra201.loader_class_name_eq:
  description: "socket.__loader__.__class__.__name__ == 'SourceFileLoader' — Lib/socket.py is the visible module, wrapping the C-level _socket extension"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant socket_extra201.doc_class_name_eq:
  description: "socket.__doc__.__class__.__name__ == 'str' — the module docstring is a str"
  category: identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant socket_extra201.name_is_str:
  description: "socket.__name__.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant socket_extra201.package_is_str:
  description: "socket.__package__.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __package__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant socket_extra201.spec_name_is_str:
  description: "socket.__spec__.name.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__class__.__name__.__eq__
  args: ["str"]
  expected: true

