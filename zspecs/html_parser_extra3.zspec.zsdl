spec: html_parser_extra3
version: ">=3.4"
backend: python_module(html.parser)

docs: https://docs.python.org/3/library/html.parser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/html.parser.html — Python html.parser documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/html/parser.py"
    - "html_parser.zspec.zsdl — covers HTMLParser.__name__, __module__, convert_charrefs default, getpos(), method names (feed/reset/close/getpos/handle_starttag/handle_endtag/handle_data/handle_comment/handle_charref/handle_entityref), reset/close return None"
    - "html_extra5.zspec.zsdl — covers HTMLParser.__qualname__, method __qualname__ for feed/reset/close/getpos/handle_starttag/handle_endtag/handle_data/handle_comment, HTMLParser.__class__.__name__, HTMLParser.__bases__[0].__name__"
    - "html_parser_extra2.zspec.zsdl — covers handle_decl/handle_pi/unknown_decl __name__ and __qualname__; CDATA_CONTENT_ELEMENTS type/membership; convert_charrefs=False; handle_charref/handle_entityref __qualname__"
  notes:
    - "This spec covers axes not yet in html_parser.zspec.zsdl, html_extra5.zspec.zsdl, or html_parser_extra2.zspec.zsdl."
    - "Focus: method __module__ checks for HTMLParser methods (not covered in any prior html.parser spec)."
    - "HTMLParser.feed.__module__ == 'html.parser' — methods are defined in the html.parser module."
    - "HTMLParser.reset.__module__ == 'html.parser'."
    - "HTMLParser.close.__module__ == 'html.parser'."
    - "HTMLParser.getpos.__module__ == 'html.parser'."
    - "HTMLParser.handle_starttag.__module__ == 'html.parser'."
    - "HTMLParser.handle_endtag.__module__ == 'html.parser'."
    - "HTMLParser.handle_data.__module__ == 'html.parser'."
    - "HTMLParser.handle_comment.__module__ == 'html.parser'."
    - "HTMLParser.handle_decl.__module__ == 'html.parser' — html_parser_extra2 checks __name__/__qualname__ for handle_decl but not __module__."
    - "HTMLParser.handle_pi.__module__ == 'html.parser' — html_parser_extra2 checks __name__/__qualname__ but not __module__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HTMLParser method __module__ checks — core interface methods
#
# html_parser.zspec.zsdl checks HTMLParser.__module__ (the class itself).
# html_extra5.zspec.zsdl checks method __qualname__ but not __module__.
# No prior spec checks __module__ for any HTMLParser instance method.
# Instance methods of a class share the module in which the class is defined.
# ---------------------------------------------------------------------------

table html_parser_extra3.core_method_modules:
  kind: python_call_eq
  category: modules
  id_prefix: mmod

  columns: [id, function, args, expected]
  rows:
    - [feed,           HTMLParser.feed.__module__.__eq__,           ["html.parser"], true]
    - [reset,          HTMLParser.reset.__module__.__eq__,          ["html.parser"], true]
    - [close,          HTMLParser.close.__module__.__eq__,          ["html.parser"], true]
    - [getpos,         HTMLParser.getpos.__module__.__eq__,         ["html.parser"], true]
    - [handle_starttag, HTMLParser.handle_starttag.__module__.__eq__, ["html.parser"], true]
    - [handle_endtag,  HTMLParser.handle_endtag.__module__.__eq__,  ["html.parser"], true]
    - [handle_data,    HTMLParser.handle_data.__module__.__eq__,    ["html.parser"], true]
    - [handle_comment, HTMLParser.handle_comment.__module__.__eq__, ["html.parser"], true]

# ---------------------------------------------------------------------------
# HTMLParser extended callback method __module__ checks
#
# html_parser_extra2 adds __name__ and __qualname__ for handle_decl,
# handle_pi, and unknown_decl. Their __module__ has not been tested.
# ---------------------------------------------------------------------------

table html_parser_extra3.extended_method_modules:
  kind: python_call_eq
  category: modules
  id_prefix: extmmod

  columns: [id, function, args, expected]
  rows:
    - [handle_decl,  HTMLParser.handle_decl.__module__.__eq__,  ["html.parser"], true]
    - [handle_pi,    HTMLParser.handle_pi.__module__.__eq__,    ["html.parser"], true]
    - [unknown_decl, HTMLParser.unknown_decl.__module__.__eq__, ["html.parser"], true]

# ---------------------------------------------------------------------------
# HTMLParser legacy callback method __module__ checks
#
# html_parser_extra2 adds __qualname__ for handle_charref/handle_entityref.
# Their __module__ has not been tested.
# ---------------------------------------------------------------------------

table html_parser_extra3.legacy_method_modules:
  kind: python_call_eq
  category: modules
  id_prefix: legmmod

  columns: [id, function, args, expected]
  rows:
    - [handle_charref,   HTMLParser.handle_charref.__module__.__eq__,   ["html.parser"], true]
    - [handle_entityref, HTMLParser.handle_entityref.__module__.__eq__, ["html.parser"], true]
