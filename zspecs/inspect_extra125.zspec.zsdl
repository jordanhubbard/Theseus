spec: inspect_extra125
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect module function code objects for getfile, findsource, classify_class_attrs, and getmodule (Wave 257)."
    - "inspect.getfile.__code__.co_varnames[0] == 'object' — first arg is named 'object'. Verified with Python 3.14.3."
    - "inspect.getfile.__code__.co_argcount == 1 — getfile takes one positional argument. Verified with Python 3.14.3."
    - "len(inspect.getfile.__code__.co_consts) == 9 — nine constant entries. Verified with Python 3.14.3."
    - "len(inspect.getfile.__code__.co_varnames) == 2 — two local variables: object, module. Verified with Python 3.14.3."
    - "inspect.findsource.__code__.co_varnames[0] == 'object'. Verified with Python 3.14.3."
    - "inspect.findsource.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "len(inspect.findsource.__code__.co_consts) == 12. Verified with Python 3.14.3."
    - "len(inspect.findsource.__code__.co_varnames) == 5. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__code__.co_varnames[0] == 'cls'. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "len(inspect.classify_class_attrs.__code__.co_varnames) == 20. Verified with Python 3.14.3."
    - "inspect.getmodule.__code__.co_varnames[0] == 'object'. Verified with Python 3.14.3."
    - "inspect.getmodule.__code__.co_argcount == 2 — takes object and optional _filename. Verified with Python 3.14.3."
    - "len(inspect.getmodule.__code__.co_varnames) == 10. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getfile and inspect.findsource code object attributes
#
# Wave 257 theme: inspect.getfile and findsource co_varnames and co_argcount.
#
# inspect.getfile.__code__.co_varnames[0] == 'object'
# inspect.getfile.__code__.co_argcount == 1
# len(inspect.getfile.__code__.co_consts) == 9
# len(inspect.getfile.__code__.co_varnames) == 2
# inspect.findsource.__code__.co_varnames[0] == 'object'
# inspect.findsource.__code__.co_argcount == 1
#
# getfile and findsource both take a single positional argument named 'object';
# they locate the source file of a Python object. New to extra125.
# ---------------------------------------------------------------------------

table inspect_extra125.getfile_findsource_code_attrs:
  description: "inspect.getfile and findsource code object attrs: co_varnames[0], co_argcount, co_consts len, co_varnames len; wave 257; new to extra125"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectcodeobj125

  columns: [id, function, args, expected, description]
  rows:
    - [getfile_co_varnames_first_eq_object,
       "getfile.__code__.co_varnames[0].__eq__",
       ["object"],
       true,
       "inspect.getfile.__code__.co_varnames[0].__eq__('object') == True — getfile is defined as 'def getfile(object):' in Lib/inspect.py; its first (and only) parameter is named 'object'; co_varnames[0] is 'object'; str.__eq__('object') returns True; new to extra125"]
    - [getfile_co_argcount_eq_1,
       "getfile.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getfile.__code__.co_argcount.__eq__(1) == True — getfile takes exactly one positional argument (the object whose source file is to be found); co_argcount is 1; int.__eq__(1) returns True; new to extra125"]
    - [getfile_co_consts_len_eq_9,
       "getfile.__code__.co_consts.__len__",
       [],
       9,
       "inspect.getfile.__code__.co_consts.__len__() == 9 — the co_consts tuple for getfile contains 9 entries including None, docstrings, and string error messages; len(co_consts) == 9; new to extra125"]
    - [getfile_co_varnames_len_eq_2,
       "getfile.__code__.co_varnames.__len__",
       [],
       2,
       "inspect.getfile.__code__.co_varnames.__len__() == 2 — getfile uses exactly 2 local variables: 'object' (the parameter) and 'module' (used internally); len(co_varnames) == 2; new to extra125"]
    - [findsource_co_varnames_first_eq_object,
       "findsource.__code__.co_varnames[0].__eq__",
       ["object"],
       true,
       "inspect.findsource.__code__.co_varnames[0].__eq__('object') == True — findsource is defined as 'def findsource(object):' in Lib/inspect.py; its first parameter is 'object'; co_varnames[0] is 'object'; str.__eq__('object') returns True; new to extra125"]
    - [findsource_co_argcount_eq_1,
       "findsource.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.findsource.__code__.co_argcount.__eq__(1) == True — findsource takes one positional argument (the object whose source is to be found); co_argcount is 1; int.__eq__(1) returns True; new to extra125"]
    - [findsource_co_varnames_len_eq_5,
       "findsource.__code__.co_varnames.__len__",
       [],
       5,
       "inspect.findsource.__code__.co_varnames.__len__() == 5 — findsource uses 5 local variables: 'object', 'file', 'module', 'lines', 'lnum'; len(co_varnames) == 5; new to extra125"]

# ---------------------------------------------------------------------------
# Table 2: inspect.classify_class_attrs code object attributes
#
# Wave 257 theme: inspect.classify_class_attrs co_varnames and co_argcount.
#
# inspect.classify_class_attrs.__code__.co_varnames[0] == 'cls'
# inspect.classify_class_attrs.__code__.co_argcount == 1
# len(inspect.classify_class_attrs.__code__.co_varnames) == 20
# len(inspect.classify_class_attrs.__code__.co_consts) == 11
#
# classify_class_attrs is a complex function that walks the MRO; it uses
# many local variables (20 total) despite taking only one argument ('cls').
# New to extra125.
# ---------------------------------------------------------------------------

table inspect_extra125.classify_class_attrs_code_attrs:
  description: "inspect.classify_class_attrs code object: co_varnames[0]=='cls', co_argcount==1, co_varnames len==20, co_consts len==11; wave 257; new to extra125"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectcodeobj125

  columns: [id, function, args, expected, description]
  rows:
    - [classify_co_varnames_first_eq_cls,
       "classify_class_attrs.__code__.co_varnames[0].__eq__",
       ["cls"],
       true,
       "inspect.classify_class_attrs.__code__.co_varnames[0].__eq__('cls') == True — classify_class_attrs is defined as 'def classify_class_attrs(cls):' in Lib/inspect.py; its first parameter is 'cls' (the class to inspect); co_varnames[0] is 'cls'; str.__eq__('cls') returns True; new to extra125"]
    - [classify_co_argcount_eq_1,
       "classify_class_attrs.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.classify_class_attrs.__code__.co_argcount.__eq__(1) == True — classify_class_attrs takes one positional argument (cls, the class whose attributes are to be classified); co_argcount is 1; int.__eq__(1) returns True; new to extra125"]
    - [classify_co_varnames_len_eq_20,
       "classify_class_attrs.__code__.co_varnames.__len__",
       [],
       20,
       "inspect.classify_class_attrs.__code__.co_varnames.__len__() == 20 — classify_class_attrs is a complex function that walks the MRO and inspects each attribute; it uses 20 local variables including cls, mro, metamro, class_bases, all_bases, names, and many more; len(co_varnames) == 20; new to extra125"]
    - [classify_co_consts_len_eq_11,
       "classify_class_attrs.__code__.co_consts.__len__",
       [],
       11,
       "inspect.classify_class_attrs.__code__.co_consts.__len__() == 11 — co_consts for classify_class_attrs contains 11 entries including None, docstring, string attribute kind labels such as 'class method', 'static method', 'property', 'method', 'data'; len(co_consts) == 11; new to extra125"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getmodule code object attributes
#
# Wave 257 theme: inspect.getmodule co_varnames and co_argcount.
#
# inspect.getmodule.__code__.co_varnames[0] == 'object'
# inspect.getmodule.__code__.co_argcount == 2
# len(inspect.getmodule.__code__.co_varnames) == 10
# len(inspect.getmodule.__code__.co_consts) == 7
#
# getmodule takes two arguments: the object and an optional _filename;
# it uses 10 local variables when walking the module registry. New to extra125.
# ---------------------------------------------------------------------------

table inspect_extra125.getmodule_code_attrs:
  description: "inspect.getmodule code object: co_varnames[0]=='object', co_argcount==2, co_varnames len==10, co_consts len==7; wave 257; new to extra125"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectcodeobj125

  columns: [id, function, args, expected, description]
  rows:
    - [getmodule_co_varnames_first_eq_object,
       "getmodule.__code__.co_varnames[0].__eq__",
       ["object"],
       true,
       "inspect.getmodule.__code__.co_varnames[0].__eq__('object') == True — getmodule is defined as 'def getmodule(object, _filename=None):' in Lib/inspect.py; its first parameter is 'object'; co_varnames[0] is 'object'; str.__eq__('object') returns True; new to extra125"]
    - [getmodule_co_argcount_eq_2,
       "getmodule.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmodule.__code__.co_argcount.__eq__(2) == True — getmodule takes two positional arguments: 'object' (the thing to identify) and '_filename' (optional hint); co_argcount is 2; int.__eq__(2) returns True; new to extra125"]
    - [getmodule_co_varnames_len_eq_10,
       "getmodule.__code__.co_varnames.__len__",
       [],
       10,
       "inspect.getmodule.__code__.co_varnames.__len__() == 10 — getmodule uses 10 local variables: 'object', '_filename', 'file', 'modname', 'module', 'f', 'main', 'mainobject', 'builtin', 'builtinobject'; len(co_varnames) == 10; new to extra125"]
    - [getmodule_co_consts_len_eq_7,
       "getmodule.__code__.co_consts.__len__",
       [],
       7,
       "inspect.getmodule.__code__.co_consts.__len__() == 7 — the co_consts tuple for getmodule contains 7 entries; len(co_consts) == 7; new to extra125"]
    - [findsource_co_consts_len_eq_12,
       "findsource.__code__.co_consts.__len__",
       [],
       12,
       "inspect.findsource.__code__.co_consts.__len__() == 12 — co_consts for findsource contains 12 entries including None, error message strings, and other constants used in source-finding logic; len(co_consts) == 12; new to extra125"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra125
# ---------------------------------------------------------------------------

invariant inspect_extra125.getfile_co_argcount:
  description: "inspect.getfile.__code__.co_argcount == 1 — getfile takes one positional arg; wave 257; new to extra125"
  kind: python_call_eq
  function: getfile.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra125.getfile_co_varnames_len:
  description: "len(inspect.getfile.__code__.co_varnames) == 2 — object and module; wave 257; new to extra125"
  kind: python_call_eq
  function: getfile.__code__.co_varnames.__len__
  args: []
  expected: 2

invariant inspect_extra125.classify_co_varnames_len:
  description: "len(inspect.classify_class_attrs.__code__.co_varnames) == 20 — complex MRO-walking function; wave 257; new to extra125"
  kind: python_call_eq
  function: classify_class_attrs.__code__.co_varnames.__len__
  args: []
  expected: 20

invariant inspect_extra125.getmodule_co_argcount:
  description: "inspect.getmodule.__code__.co_argcount == 2 — takes object and optional _filename; wave 257; new to extra125"
  kind: python_call_eq
  function: getmodule.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra125.findsource_co_varnames_len:
  description: "len(inspect.findsource.__code__.co_varnames) == 5 — object, file, module, lines, lnum; wave 257; new to extra125"
  kind: python_call_eq
  function: findsource.__code__.co_varnames.__len__
  args: []
  expected: 5
