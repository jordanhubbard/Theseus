spec: defu
version: ">=6.0.0"
backend: node(defu)

docs: https://github.com/unjs/defu#readme

provenance:
  derived_from:
    - "defu README — https://github.com/unjs/defu#readme"
    - "Test vectors verified with defu via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "defu source"
  notes:
    - "Recursively merge default options — first arg wins, arrays concatenated."
    - "Install: npm install defu"
    - "v6 CJS; default export and named exports defu / createDefu / defuFn / defuArrayFn."
    - "Reverse of Object.assign: leftmost (user) value takes precedence; defaults fill in missing keys."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant defu.basic_merge_picks_first:
  description: "defu({a:1}, {a:999}) keeps 1 (left wins)"
  category: merge
  kind: node_chain_eq
  entry: named
  function: defu
  entry_args: [{a: 1}, {a: 999}]
  chain:
    - {get: a}
  expected: 1

invariant defu.basic_merge_fills_missing:
  description: "defu({a:1}, {b:2}) returns {a:1, b:2}"
  category: merge
  kind: node_chain_eq
  entry: named
  function: defu
  entry_args: [{a: 1}, {b: 2}]
  chain:
    - {get: b}
  expected: 2

invariant defu.nested_merge_deep:
  description: "Nested objects merged recursively (left wins per-key)"
  category: merge
  kind: node_chain_eq
  entry: named
  function: defu
  entry_args: [{a: {x: 1}}, {a: {y: 2}}]
  chain:
    - {get: "a.x"}
  expected: 1

invariant defu.nested_merge_fills_default:
  description: "Default y from second arg is filled in"
  category: merge
  kind: node_chain_eq
  entry: named
  function: defu
  entry_args: [{a: {x: 1}}, {a: {y: 2}}]
  chain:
    - {get: "a.y"}
  expected: 2

invariant defu.arrays_are_concatenated:
  description: "Arrays from both args are concatenated (left first)"
  category: merge
  kind: node_chain_eq
  entry: named
  function: defu
  entry_args: [{arr: [1, 2]}, {arr: [3, 4]}]
  chain:
    - {get: arr}
  expected: [1, 2, 3, 4]

invariant defu.null_falls_through_to_default:
  description: "Null in user value lets default win"
  category: merge
  kind: node_chain_eq
  entry: named
  function: defu
  entry_args: [{a: ~}, {a: 1}]
  chain:
    - {get: a}
  expected: 1

invariant defu.empty_first_returns_defaults:
  description: "defu({}, {a:1, b:2}) returns the defaults"
  category: merge
  kind: node_chain_eq
  entry: named
  function: defu
  entry_args: [{}, {a: 1, b: 2}]
  chain:
    - {get: a}
  expected: 1
