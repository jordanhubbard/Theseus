spec: hashlib_extra238
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "NIST FIPS 180-4 — Secure Hash Standard (SHS)"

provenance:
  derived_from:
    - "NIST FIPS 180-4 — Secure Hash Standard (SHS)"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra237.zspec.zsdl — covers sha256/md5/sha1 hexdigest vectors and hexdigest length contracts"
    - "hashlib_extra236.zspec.zsdl — covers hmac.HMAC class identity and method qualnames"
    - "hashlib_extra235.zspec.zsdl — covers HASH method qualnames and hash object .name attribute"
    - "_hashlib.zspec.zsdl — covers _hashlib C extension identity"
    - "hashlib_extra.zspec.zsdl — covers sha256 __name__/__qualname__ and algorithms_available"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.sha512(b'').hexdigest() has 128 hex characters (64 bytes * 2)."
    - "hashlib.sha384(b'').hexdigest() has 96 hex characters (48 bytes * 2)."
    - "hashlib.sha512(b'').hexdigest() == 'cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e' — NIST FIPS 180-4 known test vector for SHA-512 of empty input."
    - "hashlib.sha384(b'').hexdigest() == '38b060a751ac96384cd9327eb1b1e36a21fdb71114be07434c0cc7bf63f6e1da274edebfe76f65fbd51ad2f14898b95b' — NIST FIPS 180-4 known test vector for SHA-384 of empty input."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SHA-512 known test vector contracts — hexdigest equality
#
# hashlib.sha512(b'').hexdigest() ==
#   'cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e'
#
# This is the NIST FIPS 180-4 known-answer test (KAT) vector for SHA-512 of
# the empty byte string. SHA-512 produces a 64-byte (512-bit) digest,
# represented as 128 hex characters. No prior hashlib_extra spec anchors
# the sha512 hexdigest value.
# ---------------------------------------------------------------------------

table hashlib_extra238.sha512_hexdigest_vectors:
  description: "sha512(b'').hexdigest()==NIST empty vector; sha512(b'abc').hexdigest()==NIST abc vector; SHA-512 known test vector contracts; new to hashlib_extra238"
  kind: python_call_eq
  category: hash_vectors
  id_prefix: hl238sha512

  columns: [id, function, args, expected, description]
  rows:
    - [sha512_empty_hexdigest,
       "sha512(b'').hexdigest.__eq__",
       ["cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e"],
       true,
       "hashlib.sha512(b'').hexdigest().__eq__('cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e') == True — NIST FIPS 180-4 test vector for SHA-512 of empty byte string; 128 hex characters representing 64 bytes; novel hexdigest value anchor for sha512; new to hashlib_extra238 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# SHA-384 known test vector contracts — hexdigest equality
#
# hashlib.sha384(b'').hexdigest() ==
#   '38b060a751ac96384cd9327eb1b1e36a21fdb71114be07434c0cc7bf63f6e1da274edebfe76f65fbd51ad2f14898b95b'
#
# This is the NIST FIPS 180-4 known-answer test (KAT) vector for SHA-384 of
# the empty byte string. SHA-384 produces a 48-byte (384-bit) digest,
# represented as 96 hex characters. Novel to hashlib_extra238.
# ---------------------------------------------------------------------------

table hashlib_extra238.sha384_hexdigest_vectors:
  description: "sha384(b'').hexdigest()==NIST empty vector; SHA-384 known test vector contracts; new to hashlib_extra238"
  kind: python_call_eq
  category: hash_vectors
  id_prefix: hl238sha384

  columns: [id, function, args, expected, description]
  rows:
    - [sha384_empty_hexdigest,
       "sha384(b'').hexdigest.__eq__",
       ["38b060a751ac96384cd9327eb1b1e36a21fdb71114be07434c0cc7bf63f6e1da274edebfe76f65fbd51ad2f14898b95b"],
       true,
       "hashlib.sha384(b'').hexdigest().__eq__('38b060a751ac96384cd9327eb1b1e36a21fdb71114be07434c0cc7bf63f6e1da274edebfe76f65fbd51ad2f14898b95b') == True — NIST FIPS 180-4 test vector for SHA-384 of empty byte string; 96 hex characters representing 48 bytes; novel hexdigest value anchor for sha384; new to hashlib_extra238 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# SHA-512 and SHA-384 hexdigest length contracts
#
# sha512 hexdigest has 128 hex characters (digest_size=64, 64*2=128).
# sha384 hexdigest has 96 hex characters (digest_size=48, 48*2=96).
# sha224 hexdigest has 56 hex characters (digest_size=28, 28*2=56).
#
# Novel to hashlib_extra238: no prior spec anchors sha512/sha384/sha224
# hexdigest().__len__() values.
# ---------------------------------------------------------------------------

table hashlib_extra238.sha512_sha384_hexdigest_lengths:
  description: "sha512 hexdigest len==128; sha384 hexdigest len==96; sha224 hexdigest len==56; hexdigest length equals digest_size*2; new to hashlib_extra238"
  kind: python_call_eq
  category: hash_lengths
  id_prefix: hl238len

  columns: [id, function, args, expected, description]
  rows:
    - [sha512_hexdigest_len,
       "sha512(b'').hexdigest().__len__",
       [],
       128,
       "hashlib.sha512(b'').hexdigest().__len__() == 128 — SHA-512 digest_size is 64 bytes; hexdigest encodes as 2 hex chars per byte giving 128 characters total; novel length anchor for sha512 hexdigest; new to hashlib_extra238 namespace; verified Python 3.14.3"]
    - [sha384_hexdigest_len,
       "sha384(b'').hexdigest().__len__",
       [],
       96,
       "hashlib.sha384(b'').hexdigest().__len__() == 96 — SHA-384 digest_size is 48 bytes; hexdigest encodes as 96 hex characters; novel length anchor for sha384 hexdigest; new to hashlib_extra238 namespace; verified Python 3.14.3"]
    - [sha224_hexdigest_len,
       "sha224(b'').hexdigest().__len__",
       [],
       56,
       "hashlib.sha224(b'').hexdigest().__len__() == 56 — SHA-224 digest_size is 28 bytes; hexdigest encodes as 56 hex characters; novel length anchor for sha224 hexdigest; new to hashlib_extra238 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra238.sha512_empty_hexdigest_eq:
  description: "hashlib.sha512(b'').hexdigest().__eq__('cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e') == True — SHA-512 of the empty byte string is the canonical zero-content hash defined in NIST FIPS 180-4; the 128-character hex string represents 64 bytes (512 bits); this is a fundamental known-answer test (KAT) vector; no prior hashlib spec in the hashlib_extra* namespace anchors any sha512 hexdigest() output value; hashlib_extra238 is the first namespace to anchor sha512 empty hexdigest as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_vectors
  kind: python_call_eq
  function: "sha512(b'').hexdigest.__eq__"
  args: ["cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e"]
  expected: true

invariant hashlib_extra238.sha512_hexdigest_len_128:
  description: "hashlib.sha512(b'').hexdigest().__len__() == 128 — SHA-512 always produces exactly 64 bytes of digest output; hexdigest() encodes each byte as exactly 2 lowercase hex characters, giving 128 characters total; this length is fixed for all SHA-512 inputs regardless of input length; digest_size==64 is the source of truth; 128 == 64 * 2; no prior spec anchors sha512 hexdigest length; hashlib_extra238 is the first namespace to anchor this as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_lengths
  kind: python_call_eq
  function: "sha512(b'').hexdigest().__len__"
  args: []
  expected: 128

invariant hashlib_extra238.sha384_empty_hexdigest_eq:
  description: "hashlib.sha384(b'').hexdigest().__eq__('38b060a751ac96384cd9327eb1b1e36a21fdb71114be07434c0cc7bf63f6e1da274edebfe76f65fbd51ad2f14898b95b') == True — SHA-384 of the empty byte string is the canonical zero-content hash defined in NIST FIPS 180-4; the 96-character hex string represents 48 bytes (384 bits); no prior hashlib spec anchors any sha384 hexdigest() output value; hashlib_extra238 is the first namespace to anchor sha384 empty hexdigest as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_vectors
  kind: python_call_eq
  function: "sha384(b'').hexdigest.__eq__"
  args: ["38b060a751ac96384cd9327eb1b1e36a21fdb71114be07434c0cc7bf63f6e1da274edebfe76f65fbd51ad2f14898b95b"]
  expected: true

invariant hashlib_extra238.sha384_hexdigest_len_96:
  description: "hashlib.sha384(b'').hexdigest().__len__() == 96 — SHA-384 always produces exactly 48 bytes of digest output; hexdigest() encodes each byte as exactly 2 lowercase hex characters, giving 96 characters total; digest_size==48 is the source of truth; 96 == 48 * 2; no prior spec anchors sha384 hexdigest length; hashlib_extra238 is the first namespace to anchor this as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_lengths
  kind: python_call_eq
  function: "sha384(b'').hexdigest().__len__"
  args: []
  expected: 96
