spec: decimal_extra191
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic Specification, Version 1.72"
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec covers decimal module structure attributes not covered by prior decimal_extra specs."
    - "decimal.__name__ == 'decimal' (len=7); the module's own __name__ attribute; confirmed Python 3.14.3 macOS."
    - "decimal.__package__ == '' (len=0); decimal is a single-file module, not a package; confirmed Python 3.14.3 macOS."
    - "decimal.__spec__.name == 'decimal' (len=7); ModuleSpec.name confirms the import name; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__name__.__len__() == 7 — D(1)e(2)c(3)i(4)m(5)a(6)l(7); confirmed Python 3.14.3 macOS."
    - "decimal.Context.__name__.__len__() == 7 — C(1)o(2)n(3)t(4)e(5)x(6)t(7); confirmed Python 3.14.3 macOS."
    - "decimal.InvalidOperation.__name__.__len__() == 16 — InvalidOperation has 16 characters; confirmed Python 3.14.3 macOS."
    - "decimal.ROUND_HALF_EVEN.__len__() == 15 — ROUND_HALF_EVEN is a string constant of length 15; confirmed Python 3.14.3 macOS."
    - "decimal.MAX_PREC.__class__.__name__ == 'int' (len=3); MAX_PREC is a plain integer constant; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal module-level identity — __name__, __package__, __spec__.name
# __name__=='decimal'(7), __package__==''(0), __spec__.name=='decimal'(7)
# ---------------------------------------------------------------------------

table decimal_extra191.module_identity:
  description: "decimal module identity: __name__='decimal'(7), __package__=''(0), __spec__.name='decimal'(7)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalmodule191

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,    decimal.__name__.__eq__,       ["decimal"], true, "decimal.__name__ == 'decimal' (len=7); the module's own __name__ attribute; confirmed Python 3.14.3 macOS"]
    - [module_package_eq, decimal.__package__.__eq__,    [""],        true, "decimal.__package__ == '' (len=0); decimal is a single-file module, not a package; confirmed Python 3.14.3 macOS"]
    - [spec_name_eq,      decimal.__spec__.name.__eq__,  ["decimal"], true, "decimal.__spec__.name == 'decimal' (len=7); ModuleSpec.name confirms the import name; confirmed Python 3.14.3 macOS"]
    - [module_name_len,   decimal.__name__.__len__,       [],         7,    "decimal.__name__.__len__() == 7 — d(1)e(2)c(3)i(4)m(5)a(6)l(7); confirmed Python 3.14.3 macOS"]
    - [spec_name_len,     decimal.__spec__.name.__len__,  [],         7,    "decimal.__spec__.name.__len__() == 7 — same as __name__; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal class name lengths — Decimal, Context, InvalidOperation
# Decimal(7), Context(7), InvalidOperation(16)
# ---------------------------------------------------------------------------

table decimal_extra191.class_name_lengths:
  description: "decimal class name lengths: Decimal(7), Context(7), InvalidOperation(16)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalmodule191

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_name_len,   decimal.Decimal.__name__.__len__,            [], 7,  "decimal.Decimal.__name__.__len__() == 7 — D(1)e(2)c(3)i(4)m(5)a(6)l(7); confirmed Python 3.14.3 macOS"]
    - [context_name_len,   decimal.Context.__name__.__len__,            [], 7,  "decimal.Context.__name__.__len__() == 7 — C(1)o(2)n(3)t(4)e(5)x(6)t(7); confirmed Python 3.14.3 macOS"]
    - [invalidop_name_len, decimal.InvalidOperation.__name__.__len__,   [], 16, "decimal.InvalidOperation.__name__.__len__() == 16 — InvalidOperation has 16 characters; confirmed Python 3.14.3 macOS"]
    - [decimal_name_eq,    decimal.Decimal.__name__.__eq__,             ["Decimal"], true, "decimal.Decimal.__name__ == 'Decimal' (len=7); confirmed Python 3.14.3 macOS"]
    - [context_name_eq,    decimal.Context.__name__.__eq__,             ["Context"], true, "decimal.Context.__name__ == 'Context' (len=7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: ROUND_HALF_EVEN length and MAX_PREC class name
# ROUND_HALF_EVEN.__len__()==15, MAX_PREC.__class__.__name__=='int'(3)
# ---------------------------------------------------------------------------

table decimal_extra191.constants_identity:
  description: "decimal constants: ROUND_HALF_EVEN.__len__()==15, MAX_PREC.__class__.__name__=='int'(3)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalmodule191

  columns: [id, function, args, expected, description]
  rows:
    - [round_half_even_len,       decimal.ROUND_HALF_EVEN.__len__,               [], 15,    "decimal.ROUND_HALF_EVEN.__len__() == 15 — ROUND_HALF_EVEN is a string constant of length 15; confirmed Python 3.14.3 macOS"]
    - [round_half_even_eq,        decimal.ROUND_HALF_EVEN.__eq__,                ["ROUND_HALF_EVEN"], true, "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' (len=15); it is a plain string naming the rounding mode; confirmed Python 3.14.3 macOS"]
    - [max_prec_class_eq,         decimal.MAX_PREC.__class__.__name__.__eq__,    ["int"], true, "decimal.MAX_PREC.__class__.__name__ == 'int' (len=3); MAX_PREC is a plain integer constant; confirmed Python 3.14.3 macOS"]
    - [max_prec_class_len,        decimal.MAX_PREC.__class__.__name__.__len__,   [], 3, "decimal.MAX_PREC.__class__.__name__.__len__() == 3 — i(1)n(2)t(3); confirmed Python 3.14.3 macOS"]
    - [invalidop_name_eq,         decimal.InvalidOperation.__name__.__eq__,      ["InvalidOperation"], true, "decimal.InvalidOperation.__name__ == 'InvalidOperation' (len=16); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra191.module_name_eq:
  description: "decimal.__name__ == 'decimal' — the module's own __name__ attribute (len=7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.__name__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra191.module_package_eq:
  description: "decimal.__package__ == '' — decimal is a single-file module, not a package; __package__ is an empty string (len=0); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.__package__.__eq__
  args: [""]
  expected: true

invariant decimal_extra191.spec_name_eq:
  description: "decimal.__spec__.name == 'decimal' — ModuleSpec.name confirms the import name (len=7); note: ModuleSpec uses .name not .__name__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.__spec__.name.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra191.decimal_name_len:
  description: "decimal.Decimal.__name__.__len__() == 7 — 'Decimal' has 7 characters: D(1)e(2)c(3)i(4)m(5)a(6)l(7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__name__.__len__
  args: []
  expected: 7

invariant decimal_extra191.context_name_len:
  description: "decimal.Context.__name__.__len__() == 7 — 'Context' has 7 characters: C(1)o(2)n(3)t(4)e(5)x(6)t(7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__name__.__len__
  args: []
  expected: 7

invariant decimal_extra191.invalidoperation_name_len:
  description: "decimal.InvalidOperation.__name__.__len__() == 16 — 'InvalidOperation' has 16 characters: I(1)n(2)v(3)a(4)l(5)i(6)d(7)O(8)p(9)e(10)r(11)a(12)t(13)i(14)o(15)n(16); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.InvalidOperation.__name__.__len__
  args: []
  expected: 16

invariant decimal_extra191.round_half_even_len:
  description: "decimal.ROUND_HALF_EVEN.__len__() == 15 — 'ROUND_HALF_EVEN' is a plain string constant of length 15; rounding modes in decimal are string constants; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_HALF_EVEN.__len__
  args: []
  expected: 15

invariant decimal_extra191.max_prec_class_name_eq:
  description: "decimal.MAX_PREC.__class__.__name__ == 'int' — MAX_PREC is a plain integer constant (len=3); it defines the maximum precision for decimal arithmetic; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.MAX_PREC.__class__.__name__.__eq__
  args: ["int"]
  expected: true
