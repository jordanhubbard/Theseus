spec: hashlib_extra89
version: ">=3.9"
extends: hashlib_extra88
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra88.zspec.zsdl — covers blake2b/blake2s method __qualname__.__len__() for copy/digest/hexdigest/update / blake2b method __class__.__name__=='method_descriptor' / blake2b/blake2s copy/__qualname__/__eq__ / blake2b.__name__.__eq__ (table + invariants)."
    - "hashlib_extra87.zspec.zsdl — covers blake2b/blake2s __dict__.__contains__ for copy/digest/hexdigest/update/MAX_DIGEST_SIZE/MAX_KEY_SIZE/PERSON_SIZE / __dict__.__class__.__name__=='mappingproxy' / blake2b.copy.__class__.__name__=='method_descriptor' (table + invariants)."
    - "hashlib_extra86.zspec.zsdl — covers blake2b/blake2s __class__.__name__/'type' / __name__ / __module__/'_blake2' / __qualname__ / __bases__[0].__name__/'object' / __mro__.__len__()==2 / SALT_SIZE.__class__.__name__/'int' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra88; it does NOT duplicate invariants present in those files."
    - "Wave 252 theme: hashlib blake2b and blake2s method __qualname__ string equality (the actual string values, not lengths)."
    - "hashlib.blake2b.copy.__qualname__.__eq__('blake2b.copy') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.digest.__qualname__.__eq__('blake2b.digest') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.hexdigest.__qualname__.__eq__('blake2b.hexdigest') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.update.__qualname__.__eq__('blake2b.update') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.copy.__qualname__.__eq__('blake2s.copy') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.digest.__qualname__.__eq__('blake2s.digest') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.hexdigest.__qualname__.__eq__('blake2s.hexdigest') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.update.__qualname__.__eq__('blake2s.update') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__qualname__.__eq__('blake2b') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__qualname__.__eq__('blake2s') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b.copy/__qualname__/__eq__('blake2b.copy')
# hashlib.blake2b.digest/__qualname__/__eq__('blake2b.digest')
# hashlib.blake2b.hexdigest/__qualname__/__eq__('blake2b.hexdigest')
# hashlib.blake2b.update/__qualname__/__eq__('blake2b.update')
#
# Wave 252 theme: blake2b method __qualname__ string equality.
#
# hashlib_extra88 checks __qualname__.__len__() and a partial __qualname__.__eq__
# for blake2b.copy and blake2b.digest; this table anchors all four with full
# string equality calls.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra89.blake2b_method_qualname_eq:
  description: "hashlib.blake2b/copy/__qualname__/__eq__('blake2b.copy')==True / blake2b/digest/__qualname__/__eq__('blake2b.digest')==True / blake2b/hexdigest/__qualname__/__eq__('blake2b.hexdigest')==True / blake2b/update/__qualname__/__eq__('blake2b.update')==True — blake2b C-type methods carry __qualname__ strings of the form 'blake2b.<name>'; hashlib_extra88 anchors lengths; this table anchors the full string values for all four methods; first full-string __qualname__.__eq__ anchor for hashlib.blake2b.hexdigest and hashlib.blake2b.update"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibqualstr89

  columns: [id, function, args, expected]
  rows:
    - [blake2b_copy_qualname_eq,      blake2b.copy.__qualname__.__eq__,      ["blake2b.copy"],      true]
    - [blake2b_digest_qualname_eq,    blake2b.digest.__qualname__.__eq__,    ["blake2b.digest"],    true]
    - [blake2b_hexdigest_qualname_eq, blake2b.hexdigest.__qualname__.__eq__, ["blake2b.hexdigest"], true]
    - [blake2b_update_qualname_eq,    blake2b.update.__qualname__.__eq__,    ["blake2b.update"],    true]

# ---------------------------------------------------------------------------
# hashlib.blake2s.copy/__qualname__/__eq__('blake2s.copy')
# hashlib.blake2s.digest/__qualname__/__eq__('blake2s.digest')
# hashlib.blake2s.hexdigest/__qualname__/__eq__('blake2s.hexdigest')
# hashlib.blake2s.update/__qualname__/__eq__('blake2s.update')
#
# Wave 252 theme: blake2s method __qualname__ string equality.
#
# hashlib_extra88 checks __qualname__.__len__() and __qualname__.__eq__ only
# for blake2s.copy; this table anchors all four blake2s methods with full
# string equality calls.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra89.blake2s_method_qualname_eq:
  description: "hashlib.blake2s/copy/__qualname__/__eq__('blake2s.copy')==True / blake2s/digest/__qualname__/__eq__('blake2s.digest')==True / blake2s/hexdigest/__qualname__/__eq__('blake2s.hexdigest')==True / blake2s/update/__qualname__/__eq__('blake2s.update')==True — blake2s C-type methods carry __qualname__ strings of the form 'blake2s.<name>'; hashlib_extra88 anchors lengths and anchors blake2s.copy.__qualname__.__eq__; this table anchors all four blake2s method strings; first full-string __qualname__.__eq__ anchor for hashlib.blake2s.digest/hexdigest/update"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibqualstr89

  columns: [id, function, args, expected]
  rows:
    - [blake2s_copy_qualname_eq,      blake2s.copy.__qualname__.__eq__,      ["blake2s.copy"],      true]
    - [blake2s_digest_qualname_eq,    blake2s.digest.__qualname__.__eq__,    ["blake2s.digest"],    true]
    - [blake2s_hexdigest_qualname_eq, blake2s.hexdigest.__qualname__.__eq__, ["blake2s.hexdigest"], true]
    - [blake2s_update_qualname_eq,    blake2s.update.__qualname__.__eq__,    ["blake2s.update"],    true]

# ---------------------------------------------------------------------------
# hashlib.blake2b/__qualname__/__eq__('blake2b')
# hashlib.blake2s/__qualname__/__eq__('blake2s')
# hashlib.blake2b/__qualname__/__len__() == 7
# hashlib.blake2s/__qualname__/__len__() == 7
#
# Wave 252 theme: blake2b and blake2s class __qualname__ string equality.
#
# hashlib_extra86 checks __qualname__ as a direct value; this table anchors
# __qualname__.__eq__ and __qualname__.__len__() for both class objects.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra89.blake2_class_qualname_eq:
  description: "hashlib.blake2b/__qualname__/__eq__('blake2b')==True / hashlib.blake2s/__qualname__/__eq__('blake2s')==True / hashlib.blake2b/__qualname__/__len__()==7 / hashlib.blake2s/__qualname__/__len__()==7 — blake2b and blake2s are top-level C type names; __qualname__ is the bare name 'blake2b'/'blake2s' (7 chars each); hashlib_extra86 anchors __qualname__ as a value; this table anchors __qualname__.__eq__ and __qualname__.__len__() as call forms; first __qualname__.__eq__ and __qualname__.__len__ anchor for hashlib.blake2b/blake2s class objects"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibqualstr89

  columns: [id, function, args, expected]
  rows:
    - [blake2b_class_qualname_eq,     blake2b.__qualname__.__eq__,     ["blake2b"], true]
    - [blake2s_class_qualname_eq,     blake2s.__qualname__.__eq__,     ["blake2s"], true]
    - [blake2b_class_qualname_len_7,  blake2b.__qualname__.__len__,    [],          7]
    - [blake2s_class_qualname_len_7,  blake2s.__qualname__.__len__,    [],          7]

# ---------------------------------------------------------------------------
# cross-check: blake2b/blake2s method __qualname__ string equality (mixed)
# blake2b.hexdigest/__qualname__/__eq__ / blake2b.update/__qualname__/__eq__
# blake2s.digest/__qualname__/__eq__ / blake2s.update/__qualname__/__eq__
#
# Wave 252 theme: cross-check blake2b/blake2s __qualname__ string equality.
#
# This table cross-anchors qualname string equality across both blake2b and
# blake2s method groups not already in the primary tables of this spec.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra89.blake2_qualname_cross_check:
  description: "hashlib.blake2b/hexdigest/__qualname__/__eq__('blake2b.hexdigest')==True / blake2b/update/__qualname__/__eq__('blake2b.update')==True / blake2s/digest/__qualname__/__eq__('blake2s.digest')==True / blake2s/hexdigest/__qualname__/__eq__('blake2s.hexdigest')==True — cross-check between blake2b and blake2s method qualname strings; confirms all four contain the class prefix; first cross-group __qualname__.__eq__ anchor for blake2b.hexdigest/update and blake2s.digest/hexdigest"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibqualstr89

  columns: [id, function, args, expected]
  rows:
    - [blake2b_hexdigest_qualname_eq2, blake2b.hexdigest.__qualname__.__eq__, ["blake2b.hexdigest"], true]
    - [blake2b_update_qualname_eq2,    blake2b.update.__qualname__.__eq__,    ["blake2b.update"],    true]
    - [blake2s_digest_qualname_eq2,    blake2s.digest.__qualname__.__eq__,    ["blake2s.digest"],    true]
    - [blake2s_hexdigest_qualname_eq2, blake2s.hexdigest.__qualname__.__eq__, ["blake2s.hexdigest"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b.hexdigest.__qualname__.__eq__('blake2b.hexdigest') — standalone
#
# blake2b.hexdigest.__qualname__ is 'blake2b.hexdigest'. hashlib_extra88 anchors
# the length (17). No prior hashlib spec checks the full string equality.
# First full __qualname__.__eq__ standalone for hashlib.blake2b.hexdigest.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra89.blake2b_hexdigest_qualname_eq:
  description: "hashlib.blake2b.hexdigest.__qualname__.__eq__('blake2b.hexdigest') == True — 'blake2b.hexdigest' is the full qualified name for this C-level method_descriptor; hashlib_extra88 anchors the length (17); this standalone anchors the full string equality; first __qualname__.__eq__ standalone for hashlib.blake2b.hexdigest"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.hexdigest.__qualname__.__eq__
  args: ["blake2b.hexdigest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.update.__qualname__.__eq__('blake2b.update') — standalone
#
# blake2b.update.__qualname__ is 'blake2b.update'. hashlib_extra88 anchors
# the length (14). No prior hashlib spec checks the full string equality.
# First full __qualname__.__eq__ standalone for hashlib.blake2b.update.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra89.blake2b_update_qualname_eq:
  description: "hashlib.blake2b.update.__qualname__.__eq__('blake2b.update') == True — 'blake2b.update' is the full qualified name for this C-level method_descriptor; hashlib_extra88 anchors the length (14); this standalone anchors the full string equality; first __qualname__.__eq__ standalone for hashlib.blake2b.update"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.update.__qualname__.__eq__
  args: ["blake2b.update"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.hexdigest.__qualname__.__eq__('blake2s.hexdigest') — standalone
#
# blake2s.hexdigest.__qualname__ is 'blake2s.hexdigest'. hashlib_extra88 anchors
# the length (17). No prior hashlib spec checks the full string equality for
# blake2s.hexdigest. First full __qualname__.__eq__ standalone for
# hashlib.blake2s.hexdigest. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra89.blake2s_hexdigest_qualname_eq:
  description: "hashlib.blake2s.hexdigest.__qualname__.__eq__('blake2s.hexdigest') == True — 'blake2s.hexdigest' is the full qualified name for this C-level method_descriptor; hashlib_extra88 anchors the length (17); this standalone anchors the full string equality; first __qualname__.__eq__ standalone for hashlib.blake2s.hexdigest"
  category: class_attrs
  kind: python_call_eq
  function: blake2s.hexdigest.__qualname__.__eq__
  args: ["blake2s.hexdigest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__qualname__.__eq__('blake2b') — standalone
#
# blake2b.__qualname__ is 'blake2b'. hashlib_extra86 anchors __qualname__ as
# a direct value. This standalone anchors __qualname__.__eq__ as a call.
# First __qualname__.__eq__ standalone for hashlib.blake2b class object.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra89.blake2b_class_qualname_eq:
  description: "hashlib.blake2b.__qualname__.__eq__('blake2b') == True — blake2b is a top-level C type with a simple unqualified __qualname__; hashlib_extra86 anchors __qualname__ as a value; this standalone anchors __qualname__.__eq__; first __qualname__.__eq__ standalone for hashlib.blake2b class object"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.__qualname__.__eq__
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.__qualname__.__eq__('blake2s') — standalone
#
# blake2s.__qualname__ is 'blake2s'. hashlib_extra86 anchors __qualname__ as
# a direct value. This standalone anchors __qualname__.__eq__ as a call.
# First __qualname__.__eq__ standalone for hashlib.blake2s class object.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra89.blake2s_class_qualname_eq:
  description: "hashlib.blake2s.__qualname__.__eq__('blake2s') == True — blake2s is a top-level C type with a simple unqualified __qualname__; hashlib_extra86 anchors __qualname__ as a value; this standalone anchors __qualname__.__eq__; first __qualname__.__eq__ standalone for hashlib.blake2s class object"
  category: class_attrs
  kind: python_call_eq
  function: blake2s.__qualname__.__eq__
  args: ["blake2s"]
  expected: true
