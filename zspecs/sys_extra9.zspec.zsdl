spec: sys_extra9
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
  notes:
    - "This spec extends sys.zspec.zsdl and prior extras through sys_extra8.zspec.zsdl."
    - "sys_extra8 covers float_info.dig/mant_dig/max_exp/min_exp values and hash_info.modulus/width bounds."
    - "No prior spec covers sys.float_info.radix or sys.float_info.rounds."
    - "No prior spec covers sys.hash_info.inf or sys.hash_info.nan values."
    - "No prior spec covers sys.int_info.bits_per_digit or sys.int_info.sizeof_digit."
    - "No prior spec covers sys.version_info.releaselevel class name."
    - "No prior spec covers sys.implementation.cache_tag."
    - "sys.float_info.radix == 2 — IEEE 754 double uses binary (base-2) radix."
    - "sys.float_info.rounds == 1 — IEEE 754 round-to-nearest-even mode."
    - "sys.hash_info.inf == 314159 — the hash of positive infinity is the fixed constant 314159."
    - "sys.hash_info.nan == 0 — the hash of NaN is 0 by Python convention."
    - "sys.int_info.bits_per_digit == 30 — CPython uses 30-bit digits for arbitrary-precision integers."
    - "sys.int_info.sizeof_digit == 4 — each CPython int digit occupies 4 bytes."
    - "sys.version_info.releaselevel.__class__.__name__ == 'str' — releaselevel is always a str."
    - "sys.implementation.cache_tag.__class__.__name__ == 'str' — cache_tag is a str like 'cpython-314'."
    - "sys.implementation.cache_tag.startswith('cpython') == True — CPython always uses 'cpython-' prefix."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# float_info — radix and rounds
#
# sys_extra8 covers dig/mant_dig/max_exp/min_exp.
# No prior spec covers radix (always 2 for IEEE 754) or rounds (always 1,
# indicating round-to-nearest-even).
# ---------------------------------------------------------------------------

invariant sys_extra9.float_info.radix_eq_2:
  description: "sys.float_info.radix == 2 — IEEE 754 double uses base-2 (binary) radix"
  category: float_info
  kind: python_call_eq
  function: float_info.radix.__eq__
  args: [2]
  expected: true

invariant sys_extra9.float_info.rounds_eq_1:
  description: "sys.float_info.rounds == 1 — IEEE 754 round-to-nearest-even rounding mode"
  category: float_info
  kind: python_call_eq
  function: float_info.rounds.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# hash_info — inf and nan fixed constants
#
# sys_extra8 covers hash_info.modulus > 0 and hash_info.width >= 32.
# No prior spec covers hash_info.inf or hash_info.nan.
# ---------------------------------------------------------------------------

invariant sys_extra9.hash_info.inf_eq_314159:
  description: "sys.hash_info.inf == 314159 — Python's fixed hash value for positive infinity"
  category: hash_info
  kind: python_call_eq
  function: hash_info.inf.__eq__
  args: [314159]
  expected: true

invariant sys_extra9.hash_info.nan_eq_0:
  description: "sys.hash_info.nan == 0 — Python's fixed hash value for NaN"
  category: hash_info
  kind: python_call_eq
  function: hash_info.nan.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# int_info — CPython internal integer representation constants
#
# No prior sys spec touches int_info field values (only class names in
# sys_extra4/sys_extra5 and qualname in sys_extra7).
# bits_per_digit == 30 and sizeof_digit == 4 are CPython implementation
# constants that are the same on all modern 64-bit CPython builds.
# ---------------------------------------------------------------------------

invariant sys_extra9.int_info.bits_per_digit_eq_30:
  description: "sys.int_info.bits_per_digit == 30 — CPython uses 30-bit digits for big integers"
  category: int_info
  kind: python_call_eq
  function: int_info.bits_per_digit.__eq__
  args: [30]
  expected: true

invariant sys_extra9.int_info.sizeof_digit_eq_4:
  description: "sys.int_info.sizeof_digit == 4 — each CPython big-int digit occupies 4 bytes"
  category: int_info
  kind: python_call_eq
  function: int_info.sizeof_digit.__eq__
  args: [4]
  expected: true

# ---------------------------------------------------------------------------
# int_info — field class names
#
# No prior spec checks class names for bits_per_digit or sizeof_digit.
# Both are plain Python ints.
# ---------------------------------------------------------------------------

table sys_extra9.int_info_field_types:
  kind: python_call_eq
  category: int_info
  id_prefix: ii

  columns: [id, function, args, expected]
  rows:
    - [bits_per_digit, int_info.bits_per_digit.__class__.__name__.__eq__, ["int"], true]
    - [sizeof_digit,   int_info.sizeof_digit.__class__.__name__.__eq__,   ["int"], true]

# ---------------------------------------------------------------------------
# version_info.releaselevel — class name
#
# sys_extra6 covers version_info.releaselevel is not covered for class name.
# releaselevel is always 'alpha', 'beta', 'candidate', or 'final' — always str.
# ---------------------------------------------------------------------------

invariant sys_extra9.version_info.releaselevel_class:
  description: "sys.version_info.releaselevel.__class__.__name__ == 'str' — releaselevel is always a str"
  category: version_info
  kind: python_call_eq
  function: version_info.releaselevel.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# sys.implementation.cache_tag — type and prefix
#
# No prior spec covers sys.implementation.cache_tag.
# On CPython it is a str like 'cpython-314'; always starts with 'cpython'.
# ---------------------------------------------------------------------------

invariant sys_extra9.implementation.cache_tag_class:
  description: "sys.implementation.cache_tag.__class__.__name__ == 'str' — cache_tag is a str"
  category: implementation
  kind: python_call_eq
  function: implementation.cache_tag.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sys_extra9.implementation.cache_tag_startswith_cpython:
  description: "sys.implementation.cache_tag.startswith('cpython') == True — CPython cache tags begin with 'cpython'"
  category: implementation
  kind: python_call_eq
  function: implementation.cache_tag.startswith
  args: ["cpython"]
  expected: true
