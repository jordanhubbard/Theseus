spec: decimal_extra200
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra199.zspec.zsdl — covers decimal.__spec__ deeper attributes"
    - "decimal_extra.zspec.zsdl — covers predicates, to_eng_string, Context/BasicContext/ExtendedContext class names, rounding modes"
  notes:
    - "decimal does not have __all__; hasattr(decimal, '__all__') == False; confirmed Python 3.14.3 macOS."
    - "decimal.__dict__.__contains__ is used instead to verify public names are accessible in the module namespace."
    - "decimal.__dict__.__contains__('Decimal') == True; confirmed Python 3.14.3 macOS."
    - "decimal.__dict__.__contains__('Context') == True; confirmed Python 3.14.3 macOS."
    - "decimal.__dict__.__contains__('DefaultContext') == True; confirmed Python 3.14.3 macOS."
    - "decimal.__dict__.__contains__('BasicContext') == True; confirmed Python 3.14.3 macOS."
    - "decimal.__dict__.__contains__('ExtendedContext') == True; confirmed Python 3.14.3 macOS."
    - "decimal.__dict__.__contains__('getcontext') == True; confirmed Python 3.14.3 macOS."
    - "decimal.__dict__.__contains__('setcontext') == True; confirmed Python 3.14.3 macOS."
    - "decimal.__dict__.__contains__('localcontext') == True; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__mro__.__len__() == 2; MRO is [Decimal, object]; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__mro__[0].__name__ == 'Decimal'; the class is first in its own MRO; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.__dict__ membership — core class names
# Decimal, Context, DefaultContext, BasicContext
# ---------------------------------------------------------------------------

table decimal_extra200.dict_membership_classes:
  description: "decimal.__dict__ membership checks for core class names (no __all__ present)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimalall200

  columns: [id, function, args, expected, description]
  rows:
    - [Decimal_in,        decimal.__dict__.__contains__,  ["Decimal"],        true,  "decimal.__dict__.__contains__('Decimal') == True; Decimal is the main numeric type; confirmed Python 3.14.3 macOS"]
    - [Context_in,        decimal.__dict__.__contains__,  ["Context"],        true,  "decimal.__dict__.__contains__('Context') == True; Context holds arithmetic settings; confirmed Python 3.14.3 macOS"]
    - [DefaultContext_in, decimal.__dict__.__contains__,  ["DefaultContext"], true,  "decimal.__dict__.__contains__('DefaultContext') == True; DefaultContext is the default arithmetic context instance; confirmed Python 3.14.3 macOS"]
    - [BasicContext_in,   decimal.__dict__.__contains__,  ["BasicContext"],   true,  "decimal.__dict__.__contains__('BasicContext') == True; BasicContext follows the IBM GDA Basic specification; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal.__dict__ membership — context classes and functions
# ExtendedContext, getcontext, setcontext, localcontext
# ---------------------------------------------------------------------------

table decimal_extra200.dict_membership_context:
  description: "decimal.__dict__ membership checks for context and function names"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimalall200

  columns: [id, function, args, expected, description]
  rows:
    - [ExtendedContext_in, decimal.__dict__.__contains__,  ["ExtendedContext"], true,  "decimal.__dict__.__contains__('ExtendedContext') == True; ExtendedContext follows the IBM GDA Extended specification; confirmed Python 3.14.3 macOS"]
    - [getcontext_in,      decimal.__dict__.__contains__,  ["getcontext"],      true,  "decimal.__dict__.__contains__('getcontext') == True; getcontext() returns the current thread context; confirmed Python 3.14.3 macOS"]
    - [setcontext_in,      decimal.__dict__.__contains__,  ["setcontext"],      true,  "decimal.__dict__.__contains__('setcontext') == True; setcontext() sets the current thread context; confirmed Python 3.14.3 macOS"]
    - [localcontext_in,    decimal.__dict__.__contains__,  ["localcontext"],    true,  "decimal.__dict__.__contains__('localcontext') == True; localcontext() is a context manager for temporary context changes; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal.Decimal.__mro__ identity
# __len__() == 2, MRO[0].__name__ == 'Decimal'
# ---------------------------------------------------------------------------

table decimal_extra200.decimal_mro_identity:
  description: "decimal.Decimal.__mro__ length and first element name"
  kind: python_call_eq
  category: mro_identity
  id_prefix: decimalall200

  columns: [id, function, args, expected, description]
  rows:
    - [mro_len_eq,         Decimal.__mro__.__len__,                       [],          2,         "decimal.Decimal.__mro__.__len__() == 2; MRO is [Decimal, object]; confirmed Python 3.14.3 macOS"]
    - [mro_class_name_eq,  Decimal.__mro__.__class__.__name__.__eq__,     ["tuple"],   true,      "decimal.Decimal.__mro__.__class__.__name__ == 'tuple'; MRO is always a tuple; confirmed Python 3.14.3 macOS"]
    - [mro0_name_eq,       "Decimal.__mro__[0].__name__.__eq__",          ["Decimal"], true,      "decimal.Decimal.__mro__[0].__name__ == 'Decimal'; the class itself is first in its own MRO; confirmed Python 3.14.3 macOS"]
    - [mro0_name_len,      "Decimal.__mro__[0].__name__.__len__",         [],          7,         "decimal.Decimal.__mro__[0].__name__.__len__() == 7; 'Decimal' has D(1)e(2)c(3)i(4)m(5)a(6)l(7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra200.dict_contains_Decimal:
  description: "decimal.__dict__.__contains__('Decimal') == True — Decimal is the primary numeric type; confirmed Python 3.14.3 macOS"
  category: dict_membership
  kind: python_call_eq
  function: decimal.__dict__.__contains__
  args: ["Decimal"]
  expected: true

invariant decimal_extra200.dict_contains_Context:
  description: "decimal.__dict__.__contains__('Context') == True — Context holds arithmetic precision and rounding settings; confirmed Python 3.14.3 macOS"
  category: dict_membership
  kind: python_call_eq
  function: decimal.__dict__.__contains__
  args: ["Context"]
  expected: true

invariant decimal_extra200.dict_contains_getcontext:
  description: "decimal.__dict__.__contains__('getcontext') == True — getcontext() retrieves the current thread-local context; confirmed Python 3.14.3 macOS"
  category: dict_membership
  kind: python_call_eq
  function: decimal.__dict__.__contains__
  args: ["getcontext"]
  expected: true

invariant decimal_extra200.dict_contains_localcontext:
  description: "decimal.__dict__.__contains__('localcontext') == True — localcontext() provides a temporary context via 'with' statement; confirmed Python 3.14.3 macOS"
  category: dict_membership
  kind: python_call_eq
  function: decimal.__dict__.__contains__
  args: ["localcontext"]
  expected: true

invariant decimal_extra200.mro_len_eq:
  description: "decimal.Decimal.__mro__.__len__() == 2 — MRO is [Decimal, object]; Decimal has no intermediate base; confirmed Python 3.14.3 macOS"
  category: mro_identity
  kind: python_call_eq
  function: Decimal.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra200.mro0_name_bracket_eq:
  description: "decimal.Decimal.__mro__[0].__name__ == 'Decimal' — the class itself is first in its own MRO; confirmed Python 3.14.3 macOS"
  category: mro_identity
  kind: python_call_eq
  function: "Decimal.__mro__[0].__name__.__eq__"
  args: ["Decimal"]
  expected: true

invariant decimal_extra200.mro_class_name_eq:
  description: "decimal.Decimal.__mro__.__class__.__name__ == 'tuple' — MRO is always a tuple; confirmed Python 3.14.3 macOS"
  category: mro_identity
  kind: python_call_eq
  function: Decimal.__mro__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant decimal_extra200.dict_contains_setcontext:
  description: "decimal.__dict__.__contains__('setcontext') == True — setcontext() sets the current thread-local context; confirmed Python 3.14.3 macOS"
  category: dict_membership
  kind: python_call_eq
  function: decimal.__dict__.__contains__
  args: ["setcontext"]
  expected: true
