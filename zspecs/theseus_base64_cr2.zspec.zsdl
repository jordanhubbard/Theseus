spec: theseus_base64_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_base64_cr2)
blocks: base64

docs: https://docs.python.org/3/library/base64.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/base64.html"
  notes:
    - "Clean-room extended base64 encoding. Do NOT import base64."
    - "b32encode(b): encode bytes as Base32 (uppercase A-Z + 2-7)."
    - "b32decode(s): decode Base32 string back to bytes."
    - "urlsafe_b64encode(b): Base64 with - and _ instead of + and /."
    - "urlsafe_b64decode(s): decode URL-safe Base64."
    - "base64_cr2_b32_roundtrip(): b32decode(b32encode(b'hello')) == b'hello'."
    - "base64_cr2_urlsafe_encode(): urlsafe_b64encode(b'\\xfb\\xff') contains only [A-Za-z0-9_-]."
    - "base64_cr2_urlsafe_roundtrip(): urlsafe_b64decode(urlsafe_b64encode(b'test')) == b'test'."
    - "Export: b32encode, b32decode, urlsafe_b64encode, urlsafe_b64decode."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_base64_cr2.b32_roundtrip:
  description: "b32decode(b32encode(b'hello')) == b'hello'"
  category: b32
  kind: python_call_eq
  function: base64_cr2_b32_roundtrip
  args: []
  expected: true

invariant theseus_base64_cr2.urlsafe_encode:
  description: "urlsafe_b64encode result contains only URL-safe chars"
  category: urlsafe
  kind: python_call_eq
  function: base64_cr2_urlsafe_encode
  args: []
  expected: true

invariant theseus_base64_cr2.urlsafe_roundtrip:
  description: "urlsafe_b64decode(urlsafe_b64encode(b'test')) == b'test'"
  category: urlsafe
  kind: python_call_eq
  function: base64_cr2_urlsafe_roundtrip
  args: []
  expected: true
