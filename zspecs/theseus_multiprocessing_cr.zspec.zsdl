spec: theseus_multiprocessing_cr
version: ">=3.0"
backend: python_cleanroom(theseus_multiprocessing_cr)
blocks: multiprocessing

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.html"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
  notes:
    - "Clean-room multiprocessing module. Do NOT import multiprocessing."

error_model: python_exceptions

invariant theseus_multiprocessing_cr.mp2_process:
  description: "Process class can be created and has standard attributes"
  category: behavior
  kind: python_call_eq
  function: mp2_process
  args: []
  expected: true

invariant theseus_multiprocessing_cr.mp2_queue:
  description: "Queue class supports put/get operations"
  category: behavior
  kind: python_call_eq
  function: mp2_queue
  args: []
  expected: true

invariant theseus_multiprocessing_cr.mp2_pool:
  description: "Pool class exists and is usable"
  category: behavior
  kind: python_call_eq
  function: mp2_pool
  args: []
  expected: true
