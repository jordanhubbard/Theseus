spec: socket_extra601
version: ">=3.9"
backend: python_module(socket)
docs: "Behavioral spec covering socket module top-level function identity — verifying __qualname__, __class__.__name__, and __module__ for key socket functions."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Rows split between builtin_function_or_method identity (C-level) and pure-Python function __module__ identity"
  created_at: "2026-04-12T00:00:00Z"

table socket_extra601.sk:
  id_prefix: sk601

  columns: [id, function, args, expected]
  rows:
    - [sk601fn01, socket.gethostname.__qualname__.__eq__, ["gethostname"], true]
    - [sk601fn02, socket.gethostbyname.__qualname__.__eq__, ["gethostbyname"], true]
    - [sk601fn03, socket.getaddrinfo.__qualname__.__eq__, ["getaddrinfo"], true]
    - [sk601fn04, socket.getnameinfo.__qualname__.__eq__, ["getnameinfo"], true]
    - [sk601fn05, socket.getfqdn.__qualname__.__eq__, ["getfqdn"], true]
    - [sk601fn06, socket.create_connection.__qualname__.__eq__, ["create_connection"], true]
    - [sk601fn07, socket.create_server.__qualname__.__eq__, ["create_server"], true]
    - [sk601dc01, socket.gethostname.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [sk601dc02, socket.gethostbyname.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [sk601dc03, socket.getaddrinfo.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [sk601dc04, socket.getnameinfo.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [sk601dc05, socket.create_connection.__module__.__eq__, ["socket"], true]
    - [sk601dc06, socket.create_server.__module__.__eq__, ["socket"], true]
