spec: decimal_extra258
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "decimal.localcontext.__module__ == '_decimal' — implemented in the C accelerator."
    - "decimal.localcontext.__class__.__name__ == 'builtin_function_or_method'."
    - "decimal.getcontext.__module__ == '_decimal'; __class__.__name__ == 'builtin_function_or_method'."
    - "decimal.setcontext.__module__ == '_decimal'; __class__.__name__ == 'builtin_function_or_method'."
    - "decimal.Context.__init__.__qualname__ == 'Context.__init__'; __class__.__name__ == 'wrapper_descriptor'."
    - "decimal.Context.clear_flags.__qualname__ == 'Context.clear_flags'."
    - "decimal.Context.copy.__qualname__ == 'Context.copy'."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.localcontext — function identity
# ---------------------------------------------------------------------------

invariant decimal_extra258.localcontext.name:
  description: "decimal.localcontext.__name__ == 'localcontext'"
  category: identity
  kind: python_call_eq
  function: localcontext.__name__.__eq__
  args: ["localcontext"]
  expected: true

invariant decimal_extra258.localcontext.qualname:
  description: "decimal.localcontext.__qualname__ == 'localcontext'"
  category: identity
  kind: python_call_eq
  function: localcontext.__qualname__.__eq__
  args: ["localcontext"]
  expected: true

invariant decimal_extra258.localcontext.module:
  description: "decimal.localcontext.__module__ == '_decimal' — implemented in C extension"
  category: identity
  kind: python_call_eq
  function: localcontext.__module__.__eq__
  args: ["_decimal"]
  expected: true

invariant decimal_extra258.localcontext.class_name:
  description: "decimal.localcontext.__class__.__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: localcontext.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

