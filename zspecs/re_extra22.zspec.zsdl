spec: re_extra22
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and prior extras through re_extra21.zspec.zsdl."
    - "re_extra21 covers: compile('.').__class__.__name__=='Pattern'; match('a','abc').__class__.__name__=='Match'; IGNORECASE/DOTALL class names; error.__bases__[0].__name__=='Exception'; table of object class names."
    - "re_extra20 covers: search hit class name via __class__.__name__.__eq__; search miss returns None; escape single metachar inputs."
    - "re_extra19 covers: DOTALL.__class__.__name__=='RegexFlag'; DOTALL.__int__()==16."
    - "re_extra18 covers: UNICODE.__class__.__name__=='RegexFlag'."
    - "NOT yet covered (now covered here): re.Pattern.__name__ == 'Pattern' — __name__ attribute of the Pattern type."
    - "NOT yet covered (now covered here): re.Match.__name__ == 'Match' — __name__ attribute of the Match type."
    - "NOT yet covered (now covered here): re.Pattern.__module__ == 're' — Pattern type is defined in the re module."
    - "NOT yet covered (now covered here): re.Match.__module__ == 're' — Match type is defined in the re module."
    - "NOT yet covered (now covered here): re.Pattern.__bases__[0].__name__ == 'object' — Pattern inherits directly from object."
    - "NOT yet covered (now covered here): re.Match.__bases__[0].__name__ == 'object' — Match inherits directly from object."
    - "NOT yet covered (now covered here): table of re function __name__ attributes — compile, match, search, findall, sub, split, fullmatch, purge."
    - "re.Pattern.__bases__[0].__name__ == 'object' verified at runtime (Python 3.12, macOS/Darwin 25.4.0)."
    - "re.Match.__bases__[0].__name__ == 'object' verified at runtime (Python 3.12, macOS/Darwin 25.4.0)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern — __name__ and __module__
#
# re_extra21 covers Pattern via compile().__class__.__name__ comparisons.
# No prior spec verifies re.Pattern.__name__ or re.Pattern.__module__ directly
# as standalone invariants using the type object itself.
# Verified: re.Pattern.__name__ == 'Pattern'; re.Pattern.__module__ == 're'.
# ---------------------------------------------------------------------------

invariant re_extra22.Pattern.name:
  description: "re.Pattern.__name__ == 'Pattern' — __name__ attribute of the Pattern type"
  category: types
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra22.Pattern.module:
  description: "re.Pattern.__module__ == 're' — Pattern type is defined in the re module"
  category: types
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.Match — __name__ and __module__
#
# No prior spec verifies re.Match.__name__ or re.Match.__module__ directly.
# Verified: re.Match.__name__ == 'Match'; re.Match.__module__ == 're'.
# ---------------------------------------------------------------------------

invariant re_extra22.Match.name:
  description: "re.Match.__name__ == 'Match' — __name__ attribute of the Match type"
  category: types
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra22.Match.module:
  description: "re.Match.__module__ == 're' — Match type is defined in the re module"
  category: types
  kind: python_call_eq
  function: Match.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.Pattern and re.Match base class — __bases__[0].__name__
#
# re_extra21 covers error.__bases__[0].__name__ == 'Exception'.
# No prior spec covers Pattern.__bases__[0].__name__ or Match.__bases__[0].__name__
# as standalone invariants.
# Verified: both resolve to 'object'.
# ---------------------------------------------------------------------------

invariant re_extra22.Pattern.bases_object:
  description: "re.Pattern.__bases__[0].__name__ == 'object' — Pattern inherits directly from object"
  category: types
  kind: python_call_eq
  function: "Pattern.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant re_extra22.Match.bases_object:
  description: "re.Match.__bases__[0].__name__ == 'object' — Match inherits directly from object"
  category: types
  kind: python_call_eq
  function: "Match.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Table: re function __name__ attributes
#
# Module-level functions expose a __name__ attribute equal to their simple name.
# No prior spec groups re function __name__ checks into a single table.
# All verified at runtime: compile.__name__=='compile', match.__name__=='match',
# search.__name__=='search', findall.__name__=='findall', sub.__name__=='sub',
# split.__name__=='split', fullmatch.__name__=='fullmatch', purge.__name__=='purge'.
# ---------------------------------------------------------------------------

table re_extra22.function_names:
  description: "re module function __name__ attributes — compile, match, search, findall, sub, split, fullmatch, purge"
  kind: python_call_eq
  category: function_identity
  id_prefix: fn22

  columns: [id, function, args, expected]
  rows:
    - [compile_name,   compile.__name__.__eq__,   ["compile"],   true]
    - [match_name,     match.__name__.__eq__,     ["match"],     true]
    - [search_name,    search.__name__.__eq__,    ["search"],    true]
    - [findall_name,   findall.__name__.__eq__,   ["findall"],   true]
    - [sub_name,       sub.__name__.__eq__,       ["sub"],       true]
    - [split_name,     split.__name__.__eq__,     ["split"],     true]
    - [fullmatch_name, fullmatch.__name__.__eq__, ["fullmatch"], true]
    - [purge_name,     purge.__name__.__eq__,     ["purge"],     true]
