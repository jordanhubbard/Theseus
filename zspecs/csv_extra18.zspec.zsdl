spec: csv_extra18
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra17.zspec.zsdl."
    - "csv_extra17 covers: DictReader/__bases__[0]/__name__; DictWriter/__bases__[0]/__name__; Error/__module__; Dialect/__module__; class __module__ table (DictReader, DictWriter, excel, excel_tab)."
    - "csv_extra16 covers: reader/__module__; writer/__module__; Dialect/Error/excel/excel_tab __bases__[0]/__name__ table; QUOTE_* __class__.__name__."
    - "csv_extra15 covers: reader/__name__; writer/__name__; DictReader/DictWriter/Dialect/excel/excel_tab __name__ table; QUOTE_* integer values."
    - "No prior spec covers: csv.DictReader.__qualname__ == 'DictReader' — qualname for pure-Python class."
    - "No prior spec covers: csv.DictWriter.__qualname__ == 'DictWriter' — qualname for pure-Python class."
    - "No prior spec covers: csv.Sniffer.__qualname__ == 'Sniffer' — qualname for the dialect-sniffing class."
    - "No prior spec covers: csv.excel.__qualname__ == 'excel' — qualname for the excel dialect class."
    - "No prior spec covers: csv.excel_tab.__qualname__ == 'excel_tab' — qualname for the excel_tab dialect class."
    - "No prior spec covers: csv.Dialect.__qualname__ == 'Dialect' — qualname for the base dialect class."
    - "No prior spec covers: csv.get_dialect.__module__ == '_csv' — C extension function module."
    - "No prior spec covers: csv.list_dialects.__module__ == '_csv' — C extension function module."
    - "csv_extra covers Error.__qualname__ only; all class qualnames (DictReader, DictWriter, Sniffer, excel, excel_tab, Dialect) are new."
    - "csv.get_dialect and csv.list_dialects are C extension functions; __module__ == '_csv'; only qualname checked in prior specs."
    - "csv.Sniffer.__module__ == 'csv' — pure-Python class; already covered in csv_extra. Sniffer.__qualname__ is new."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __qualname__ table — DictReader, DictWriter, Sniffer, excel, excel_tab, Dialect
#
# Prior csv specs cover reader.__qualname__, writer.__qualname__,
# Error.__qualname__, field_size_limit/__qualname__, get_dialect/__qualname__,
# list_dialects/__qualname__, register_dialect/__qualname__,
# unregister_dialect/__qualname__. The six class qualnames below have not
# appeared in any prior csv spec.
# ---------------------------------------------------------------------------

table csv_extra18.class_qualnames:
  description: "csv class __qualname__ values — each class qualname matches its simple name"
  kind: python_call_eq
  category: qualnames
  id_prefix: cqn18

  columns: [id, function, args, expected]
  rows:
    - [DictReader_qualname,  DictReader.__qualname__.__eq__,  ["DictReader"],  true]
    - [DictWriter_qualname,  DictWriter.__qualname__.__eq__,  ["DictWriter"],  true]
    - [Sniffer_qualname,     Sniffer.__qualname__.__eq__,     ["Sniffer"],     true]
    - [excel_qualname,       excel.__qualname__.__eq__,       ["excel"],       true]
    - [excel_tab_qualname,   excel_tab.__qualname__.__eq__,   ["excel_tab"],   true]
    - [Dialect_qualname,     Dialect.__qualname__.__eq__,     ["Dialect"],     true]

# ---------------------------------------------------------------------------
# csv.get_dialect and csv.list_dialects __module__ attributes
#
# Prior specs check get_dialect/__qualname__ and list_dialects/__qualname__.
# No prior spec checks __module__ for either function. Both are implemented
# in the C extension and return '_csv'.
# ---------------------------------------------------------------------------

invariant csv_extra18.get_dialect.module:
  description: "csv.get_dialect.__module__ == '_csv' — C extension function"
  category: module_identity
  kind: python_call_eq
  function: get_dialect.__module__.__eq__
  args: ["_csv"]
  expected: true

invariant csv_extra18.list_dialects.module:
  description: "csv.list_dialects.__module__ == '_csv' — C extension function"
  category: module_identity
  kind: python_call_eq
  function: list_dialects.__module__.__eq__
  args: ["_csv"]
  expected: true

# ---------------------------------------------------------------------------
# csv.Sniffer.__qualname__ standalone
#
# The table above covers Sniffer.__qualname__ in a row. This standalone
# invariant provides a named, directly queryable invariant for the same fact
# under the extra18 namespace.
# ---------------------------------------------------------------------------

invariant csv_extra18.Sniffer.qualname:
  description: "csv.Sniffer.__qualname__ == 'Sniffer' — pure-Python dialect-sniffing class"
  category: qualnames
  kind: python_call_eq
  function: Sniffer.__qualname__.__eq__
  args: ["Sniffer"]
  expected: true

# ---------------------------------------------------------------------------
# csv.Dialect.__qualname__ standalone
#
# The table above covers Dialect.__qualname__ in a row. This standalone
# invariant provides a named, directly queryable invariant under extra18.
# ---------------------------------------------------------------------------

invariant csv_extra18.Dialect.qualname:
  description: "csv.Dialect.__qualname__ == 'Dialect' — base dialect class qualname"
  category: qualnames
  kind: python_call_eq
  function: Dialect.__qualname__.__eq__
  args: ["Dialect"]
  expected: true
