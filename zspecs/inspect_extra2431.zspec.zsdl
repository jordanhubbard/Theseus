spec: inspect_extra2431
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Parameter, Signature, BoundArguments, FrameInfo, Traceback async iteration protocol dict-presence"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Theme: __aiter__ and __anext__ async iteration protocol dict-presence for inspect types."
    - "inspect.Parameter is a class representing a function parameter; no iteration protocol of any kind."
    - "inspect.Signature is a class representing a callable's signature; no iteration protocol."
    - "inspect.BoundArguments is a class holding bound arguments; no iteration protocol."
    - "inspect.FrameInfo is a named tuple subclass holding frame inspection info; no async protocol."
    - "inspect.Traceback is a named tuple subclass holding traceback info; no async protocol."
    - "None of these inspect types define __aiter__, __anext__, __iter__, or __next__ in their own __dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

table inspect_extra2431.async_iter_absent:
  description: "inspect types do not define __aiter__ or __anext__ in their class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2431

  columns: [id, function, args, expected]
  rows:
    - ["in2431001", "inspect.Parameter.__dict__.__contains__", ["__aiter__"], false]
    - ["in2431002", "inspect.Parameter.__dict__.__contains__", ["__anext__"], false]
    - ["in2431003", "inspect.Signature.__dict__.__contains__", ["__aiter__"], false]
    - ["in2431004", "inspect.Signature.__dict__.__contains__", ["__anext__"], false]
    - ["in2431005", "inspect.BoundArguments.__dict__.__contains__", ["__aiter__"], false]
    - ["in2431006", "inspect.BoundArguments.__dict__.__contains__", ["__anext__"], false]
    - ["in2431007", "inspect.FrameInfo.__dict__.__contains__", ["__aiter__"], false]
    - ["in2431008", "inspect.FrameInfo.__dict__.__contains__", ["__anext__"], false]
    - ["in2431009", "inspect.Traceback.__dict__.__contains__", ["__aiter__"], false]
    - ["in2431010", "inspect.Traceback.__dict__.__contains__", ["__anext__"], false]

table inspect_extra2431.sync_iter_also_absent:
  description: "inspect types do not define __iter__ or __next__ in their class __dict__ — confirming no iteration protocol of any kind"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2431

  columns: [id, function, args, expected]
  rows:
    - ["in2431011", "inspect.Parameter.__dict__.__contains__", ["__iter__"], false]
    - ["in2431012", "inspect.Parameter.__dict__.__contains__", ["__next__"], false]
    - ["in2431013", "inspect.Signature.__dict__.__contains__", ["__iter__"], false]
    - ["in2431014", "inspect.Signature.__dict__.__contains__", ["__next__"], false]
    - ["in2431015", "inspect.BoundArguments.__dict__.__contains__", ["__iter__"], false]
    - ["in2431016", "inspect.BoundArguments.__dict__.__contains__", ["__next__"], false]
    - ["in2431017", "inspect.FrameInfo.__dict__.__contains__", ["__iter__"], false]
    - ["in2431018", "inspect.FrameInfo.__dict__.__contains__", ["__next__"], false]
    - ["in2431019", "inspect.Traceback.__dict__.__contains__", ["__iter__"], false]
    - ["in2431020", "inspect.Traceback.__dict__.__contains__", ["__next__"], false]
