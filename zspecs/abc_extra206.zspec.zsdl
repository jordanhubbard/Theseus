       ["__abstractmethods__"],
       false,
       "abc.ABCMeta.__dict__.__contains__('__abstractmethods__') == False — __abstractmethods__ is NOT in ABCMeta.__dict__; it is set on concrete subclasses not on the metaclass; new to abc_extra206; verified Python 3.14.3"]
    - [abcmeta_no_get_dump_registry_info,
       "ABCMeta.__dict__.__contains__",
       ["_get_dump_registry_info"],
       false,
       "abc.ABCMeta.__dict__.__contains__('_get_dump_registry_info') == False — _get_dump_registry_info is NOT in ABCMeta.__dict__; the actual key is '_dump_registry'; new to abc_extra206; verified Python 3.14.3"]

