# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra206
# ---------------------------------------------------------------------------

invariant abc_extra206.abcmeta_dict_no_abstractmethods:
  description: "abc.ABCMeta.__dict__.__contains__('__abstractmethods__') == False — __abstractmethods__ is NOT an entry in ABCMeta.__dict__; it is a frozenset set on concrete class objects by ABCMeta.__new__ when the class has unimplemented abstract methods; it is an instance attribute of the metaclass, not defined on the metaclass itself; new to abc_extra206; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: "ABCMeta.__dict__.__contains__"
  args: ["__abstractmethods__"]
  expected: false

invariant abc_extra206.abcmeta_dict_no_get_dump_registry_info:
  description: "abc.ABCMeta.__dict__.__contains__('_get_dump_registry_info') == False — _get_dump_registry_info is NOT in ABCMeta.__dict__; the actual debug utility key is '_dump_registry'; new to abc_extra206; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: "ABCMeta.__dict__.__contains__"
  args: ["_get_dump_registry_info"]
  expected: false

invariant abc_extra206.abcmeta_dict_len:
  description: "abc.ABCMeta.__dict__.__len__() == 11 — ABCMeta.__dict__ has 11 entries: __doc__, __firstlineno__, __instancecheck__, __module__, __new__, __static_attributes__, __subclasscheck__, _abc_caches_clear, _abc_registry_clear, _dump_registry, register; new to abc_extra206; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: "ABCMeta.__dict__.__len__"
  args: []
  expected: 11

invariant abc_extra206.abcmeta_has_register:
  description: "abc.ABCMeta.__dict__.__contains__('register') == True — ABCMeta.register(subclass) is defined on ABCMeta; calling register makes subclass a virtual subclass of the ABC; new to abc_extra206; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: "ABCMeta.__dict__.__contains__"
  args: ["register"]
  expected: true

invariant abc_extra206.abcmeta_base_is_type:
  description: "abc.ABCMeta.__bases__[0].__name__.__eq__('type') == True — ABCMeta is a metaclass that inherits from the built-in type; this makes ABCMeta capable of intercepting class creation; new to abc_extra206; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: bases
  kind: python_call_eq
  function: "ABCMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra206.abc_base_is_object:
  description: "abc.ABC.__bases__[0].__name__.__eq__('object') == True — ABC is a helper class that directly inherits from object; ABC's metaclass is ABCMeta; new to abc_extra206; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: bases
  kind: python_call_eq
  function: "ABC.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant abc_extra206.abcmeta_has_instancecheck:
  description: "abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True — ABCMeta.__instancecheck__ is defined on ABCMeta; it is invoked by isinstance(obj, abc_class) when the class uses ABCMeta; new to abc_extra206; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: "ABCMeta.__dict__.__contains__"
  args: ["__instancecheck__"]
  expected: true

invariant abc_extra206.abcmeta_has_subclasscheck:
  description: "abc.ABCMeta.__dict__.__contains__('__subclasscheck__') == True — ABCMeta.__subclasscheck__ is defined on ABCMeta; it is invoked by issubclass(cls, abc_class) when the class uses ABCMeta; new to abc_extra206; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: "ABCMeta.__dict__.__contains__"
  args: ["__subclasscheck__"]
  expected: true

