    - [abcmeta_has_instancecheck,
       "ABCMeta.__dict__.__contains__",
       ["__instancecheck__"],
       true,
       "abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True — ABCMeta.__instancecheck__ supports isinstance(); new to abc_extra206; verified Python 3.14.3"]
    - [abcmeta_no_abstractmethods,
