spec: abc_extra206
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers abc.ABCMeta class __dict__ details and abc.ABC subclass base checks."
    - "abc.ABCMeta.__dict__.__contains__('__abstractmethods__') == False — __abstractmethods__ is NOT a key in ABCMeta.__dict__; it is an instance attribute set on concrete ABC subclasses, not on ABCMeta itself. Verified with Python 3.14.3."
    - "abc.ABCMeta.__dict__.__contains__('_get_dump_registry_info') == False — _get_dump_registry_info is NOT in ABCMeta.__dict__; the actual key is '_dump_registry'. Verified with Python 3.14.3."
    - "abc.ABCMeta.__dict__.__len__() == 11 — ABCMeta.__dict__ has 11 entries: __doc__, __firstlineno__, __instancecheck__, __module__, __new__, __static_attributes__, __subclasscheck__, _abc_caches_clear, _abc_registry_clear, _dump_registry, register. Verified with Python 3.14.3."
    - "abc.ABCMeta.__dict__.__contains__('register') == True — ABCMeta.register(subclass) registers a virtual subclass. Verified with Python 3.14.3."
    - "abc.ABCMeta.__dict__.__contains__('_dump_registry') == True — _dump_registry is a debugging utility in ABCMeta.__dict__. Verified with Python 3.14.3."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta inherits from the built-in type metaclass. Verified with Python 3.14.3."
    - "abc.ABC.__bases__[0].__name__ == 'object' — ABC inherits from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

