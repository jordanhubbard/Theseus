spec: struct_extra243
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra100.zspec.zsdl — covers Struct instance method qualname lengths / module-level function qualname lengths / Struct class-level method_descriptor types (table + invariants)."
    - "struct_extra.zspec.zsdl — covers calcsize for '>f'/'>d'/'>B'/'4s'/'>BHI' formats / Struct format/size attributes / pack_into method name (table + invariants)."
  notes:
    - "Wave 292 theme: struct.calcsize sizes for B/H/I/Q/f/d/10s format strings / Struct size attribute values / unpack integer results / struct.error class identity."
    - "struct.calcsize('B') == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('H') == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('I') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('Q') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('f') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('d') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('10s') == 10. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('B').size == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('>H').size == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('>I').size == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('>Q').size == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('B', b'\\xff')[0] == 255. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('>H', b'\\x01\\x00')[0] == 256. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('<H', b'\\x01\\x00')[0] == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__name__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: calcsize returns the number of bytes required to pack the given format string using the native byte order (no prefix). Format characters: B=1 byte unsigned char, H=2 bytes unsigned short, I=4 bytes unsigned int, Q=8 bytes unsigned long long, f=4 bytes float (IEEE 754 single), d=8 bytes double (IEEE 754 double), 10s=10 bytes fixed string."
    - "Note: Struct.size is the pre-computed pack size for the format — equivalent to calcsize but stored as an attribute on the compiled Struct object. Struct('B').size==calcsize('B')==1."
    - "Note: unpack returns a tuple; [0] gives the first integer result. '>' prefix means big-endian, '<' means little-endian. The same two bytes b'\\x01\\x00' decode as 256 big-endian but 1 little-endian."
    - "Note: struct.error.__name__ is 'error' (lowercase), following C extension naming convention."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.calcsize for B/H/I/Q/f/d/10s format strings (native byte order)
#
# Wave 292 theme: struct.calcsize sizes for common format characters.
#
# calcsize returns the number of bytes needed for a packed format. The native
# sizes (no byte-order prefix): B=1, H=2, I=4, Q=8, f=4, d=8, 10s=10.
# struct_extra.zspec.zsdl anchors calcsize for '>f'/'>d'/'>B'/'4s'/'>BHI';
# this spec anchors the native-order forms B/H/I/Q/f/d/10s as a grouped
# table under structcalc292. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra243.calcsize_basic_formats:
  description: "calcsize('B')==1 / calcsize('H')==2 / calcsize('I')==4 / calcsize('Q')==8 / calcsize('f')==4 / calcsize('d')==8 / calcsize('10s')==10 — native sizes without byte-order prefix; B=unsigned char (1B), H=unsigned short (2B), I=unsigned int (4B), Q=unsigned long long (8B), f=float IEEE-754 single (4B), d=double IEEE-754 double (8B), 10s=10-byte fixed string; struct_extra anchors '>B' and '>f'/'>d'; this anchors native-order forms; first structcalc292 anchor"
  kind: python_call_eq
  category: calcsize
  id_prefix: structcalc292
  function: calcsize

  columns: [id, args, expected]
  rows:
    - [B_uint8,  ["B"],   1]
    - [H_uint16, ["H"],   2]
    - [I_uint32, ["I"],   4]
    - [Q_uint64, ["Q"],   8]
    - [f_float,  ["f"],   4]
    - [d_double, ["d"],   8]
    - [ten_s,    ["10s"], 10]

# ---------------------------------------------------------------------------
# struct.Struct size attribute for B / >H / >I / >Q formats
#
# Wave 292 theme: Struct.size pre-computed format sizes.
#
# Struct.size is equivalent to calcsize for the compiled format. Using Struct
# verifies that the compiled form and the calcsize function agree.
# struct_extra.zspec.zsdl anchors Struct('>H').size==2 and Struct('>BHI').size==7;
# this spec anchors Struct('B').size==1, Struct('>I').size==4, Struct('>Q').size==8
# as standalone invariants. No prior struct spec anchors these Struct.size values
# under structcalc292. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra243.Struct_B_size_1:
  description: "struct.Struct('B').size == 1 — Struct.size for 'B' is 1; equals calcsize('B'); B=unsigned char 1 byte; struct_extra anchors Struct('>H').size==2; first standalone for Struct('B').size under structcalc292"
  category: struct_size
  kind: python_call_eq
  function: Struct
  args: ["B"]
  method: size.__eq__
  method_args: [1]
  expected: true

invariant struct_extra243.Struct_I_size_4:
  description: "struct.Struct('>I').size == 4 — Struct.size for '>I' (big-endian unsigned int) is 4; equals calcsize('I')==4; big-endian prefix ensures fixed layout; struct_extra anchors Struct('>H').size==2; first standalone for Struct('>I').size under structcalc292"
  category: struct_size
  kind: python_call_eq
  function: Struct
  args: [">I"]
  method: size.__eq__
  method_args: [4]
  expected: true

invariant struct_extra243.Struct_Q_size_8:
  description: "struct.Struct('>Q').size == 8 — Struct.size for '>Q' (big-endian unsigned long long) is 8; equals calcsize('Q')==8; largest single-field native integer size; first standalone for Struct('>Q').size under structcalc292"
  category: struct_size
  kind: python_call_eq
  function: Struct
  args: [">Q"]
  method: size.__eq__
  method_args: [8]
  expected: true

# ---------------------------------------------------------------------------
# struct.unpack integer results
#
# Wave 292 theme: struct.unpack() decoded integer values.
#
# unpack('B', b'\xff') returns (255,); unpack('>H', b'\x01\x00') returns (256,)
# (big-endian: 0x01*256 + 0x00); unpack('<H', b'\x01\x00') returns (1,)
# (little-endian: 0x00*256 + 0x01). The same two bytes decode differently
# under big-endian vs little-endian. Expressed as standalone invariants using
# function + method pattern to avoid parens in function: field.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra243.unpack_B_ff_eq_255:
  description: "struct.unpack('B', b'\\xff')[0] == 255 — unpack with 'B' format decodes one unsigned byte; b'\\xff' is the max value (255); unpack returns tuple (255,); result is a plain Python int; first structcalc292 anchor for unpack 'B' result"
  category: unpack_values
  kind: python_call_eq
  function: unpack
  args: ["B", "\xff"]
  method: "__getitem__.__call__"
  method_args: [0]
  expected: 255

invariant struct_extra243.unpack_H_be_eq_256:
  description: "struct.unpack('>H', b'\\x01\\x00')[0] == 256 — big-endian unsigned short; b'\\x01\\x00' decodes as 0x0100 == 256; '>' prefix forces big-endian byte order; first structcalc292 anchor for unpack '>H' big-endian result"
  category: unpack_values
  kind: python_call_eq
  function: unpack
  args: [">H", "\x01\x00"]
  method: "__getitem__.__call__"
  method_args: [0]
  expected: 256

invariant struct_extra243.unpack_H_le_eq_1:
  description: "struct.unpack('<H', b'\\x01\\x00')[0] == 1 — little-endian unsigned short; same bytes b'\\x01\\x00' decode as 0x0001 == 1 under '<' (little-endian) prefix; contrast with big-endian result of 256; first structcalc292 anchor for little-endian unpack result"
  category: unpack_values
  kind: python_call_eq
  function: unpack
  args: ["<H", "\x01\x00"]
  method: "__getitem__.__call__"
  method_args: [0]
  expected: 1

# ---------------------------------------------------------------------------
# struct.error class identity
#
# Wave 292 theme: struct.error class name and inheritance.
#
# struct.error is the exception class raised by the struct module for format
# errors and size mismatches. Its __name__ is 'error' (lowercase, following
# C extension naming convention). It inherits from Exception (not directly
# from BaseException). struct_extra93 anchors error.__bases__ and __module__;
# this spec anchors __name__ and __bases__[0].__name__ as a grouped table
# under structcalc292. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra243.error_class_identity:
  description: "error.__name__.__eq__('error')==True / \"struct.error.__bases__[0].__name__.__eq__\"('Exception')==True — struct.error.__name__ is lowercase 'error' (C extension naming convention); inherits from Exception (not BaseException); raised for format errors and size mismatches; struct_extra93 anchors error.__bases__ and __module__; this anchors __name__ and __bases__[0].__name__; first structcalc292 anchor for error class identity"
  kind: python_call_eq
  category: error_class
  id_prefix: structcalc292

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_eq,   "error.__name__.__eq__",                         ["error"],     true, "struct.error.__name__ is 'error' (lowercase; C extension convention)"]
    - [error_bases_exc, "struct.error.__bases__[0].__name__.__eq__",     ["Exception"], true, "struct.error inherits from Exception (not BaseException)"]

# ---------------------------------------------------------------------------
# struct.calcsize('B') == 1 — standalone
#
# struct.calcsize('B') is 1. The 'B' format character represents an unsigned
# char — a single byte holding a value from 0 to 255. This is the smallest
# possible calcsize value for a non-padding format character. Native,
# standard, and network byte orders all give the same result for single-byte
# formats because byte order only affects multi-byte values.
# struct_extra.zspec.zsdl anchors calcsize for '>B' in a table row; this spec
# anchors calcsize('B') (native order) as a standalone under structcalc292.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra243.calcsize_B_eq_1:
  description: "struct.calcsize('B') == 1 — 'B' is unsigned char (0–255), smallest non-padding format character; byte order prefix doesn't affect single-byte formats; struct_extra anchors calcsize('>B') in a table; this anchors native-order 'B' as standalone; first standalone under structcalc292"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["B"]
  expected: 1

# ---------------------------------------------------------------------------
# struct.calcsize('Q') == 8 — standalone
#
# struct.calcsize('Q') is 8. The 'Q' format character represents an unsigned
# long long — an 8-byte (64-bit) value from 0 to 2**64-1. This is the largest
# single-field calcsize value among the common integer format characters
# (B=1, H=2, I=4, Q=8). calcsize('Q') == calcsize('q') == calcsize('d') == 8.
# No prior struct spec anchors calcsize('Q') as a standalone under structcalc292.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra243.calcsize_Q_eq_8:
  description: "struct.calcsize('Q') == 8 — 'Q' is unsigned long long (0 to 2**64-1), largest common integer format at 8 bytes; calcsize('Q')==calcsize('q')==calcsize('d')==8; no prior struct spec anchors calcsize('Q') as standalone; first standalone under structcalc292"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["Q"]
  expected: 8

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error') — standalone
#
# struct.error.__name__ is 'error'. The struct module follows a C extension
# naming convention where the exception class is named with a lowercase 'error'
# rather than 'Error' (the Python convention). Other modules with the same
# pattern include re.error. struct.error is a subclass of Exception and is
# raised when a format string is invalid or a buffer size does not match the
# expected size for pack/unpack operations. struct_extra93 anchors
# error.__bases__ and __module__ in a table; this spec anchors error.__name__
# as a standalone under structcalc292. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra243.struct_error_name_eq:
  description: "struct.error.__name__.__eq__('error') == True — struct.error uses lowercase 'error' (C extension naming convention, unlike Python's 'Error' convention); raised for invalid format strings or buffer size mismatches; same pattern as re.error; struct_extra93 anchors __bases__ and __module__; this anchors __name__ as standalone; first standalone under structcalc292"
  category: error_class
  kind: python_call_eq
  function: "error.__name__.__eq__"
  args: ["error"]
  expected: true
