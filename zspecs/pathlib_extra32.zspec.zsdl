spec: pathlib_extra32
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra4.zspec.zsdl — covers __name__ for Path/PurePath methods"
    - "pathlib_extra28.zspec.zsdl — covers __qualname__ for Path.read_text/write_text/resolve/iterdir/is_absolute"
    - "pathlib_extra29.zspec.zsdl — covers __qualname__ for Path.stat/chmod/exists/is_file/is_dir/mkdir/rename/unlink/open"
    - "pathlib_extra30.zspec.zsdl — covers __qualname__ for Path.read_bytes/write_bytes/glob/rglob/absolute"
    - "pathlib_extra31.zspec.zsdl — covers Path/__module__; PurePath/__module__; PurePosixPath/PureWindowsPath/PosixPath __qualname__/__module__; Path.__bases__[0].__name__; PurePath.__bases__[0].__name__; PurePath.parts/name/stem/suffix fget.__qualname__"
  notes:
    - "This spec extends pathlib_extra31.zspec.zsdl."
    - "NEW in extra32 — Axis 1: PurePath.parent/parents fget.__qualname__ and fget.__module__ — not covered in extra31 (extra31 covers parts/name/stem/suffix only)."
    - "NEW in extra32 — Axis 2: PurePath.suffixes/drive/root/anchor fget.__qualname__ — the remaining PurePath properties not covered in extra31."
    - "NEW in extra32 — Axis 3: fget.__module__ for the extra32-covered PurePath properties — all are 'pathlib'."
    - "pathlib.PurePath.parent.fget.__qualname__ == 'PurePath.parent' — verified Python 3.12."
    - "pathlib.PurePath.parents.fget.__qualname__ == 'PurePath.parents' — verified Python 3.12."
    - "pathlib.PurePath.suffixes.fget.__qualname__ == 'PurePath.suffixes' — verified Python 3.12."
    - "pathlib.PurePath.drive.fget.__qualname__ == 'PurePath.drive' — verified Python 3.12."
    - "pathlib.PurePath.root.fget.__qualname__ == 'PurePath.root' — verified Python 3.12."
    - "pathlib.PurePath.anchor.fget.__qualname__ == 'PurePath.anchor' — verified Python 3.12."
    - "pathlib.PurePath.parent.fget.__module__ == 'pathlib' — verified Python 3.12."
    - "pathlib.PurePath.parents.fget.__module__ == 'pathlib' — verified Python 3.12."
    - "pathlib.PurePath.drive.fget.__module__ == 'pathlib' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePath.parent and PurePath.parents — property fget qualnames and modules
#
# pathlib_extra31 covers PurePath.parts/name/stem/suffix fget qualnames in
# a table. PurePath.parent and PurePath.parents were not included there.
# Both are properties returning the immediate parent path and the sequence
# of ancestor paths respectively. Their fget.__qualname__ values follow the
# standard dotted 'ClassName.attr' form and their __module__ is 'pathlib'.
# ---------------------------------------------------------------------------

table pathlib_extra32.parent_fget_identity:
  description: "fget.__qualname__ and fget.__module__ for PurePath.parent and PurePath.parents"
  kind: python_call_eq
  category: property_identity
  id_prefix: pfi32

  columns: [id, function, args, expected]
  rows:
    - [parent_qualname,  "PurePath.parent.fget.__qualname__.__eq__",  ["PurePath.parent"],  true]
    - [parent_module,    "PurePath.parent.fget.__module__.__eq__",    ["pathlib"],          true]
    - [parents_qualname, "PurePath.parents.fget.__qualname__.__eq__", ["PurePath.parents"], true]
    - [parents_module,   "PurePath.parents.fget.__module__.__eq__",   ["pathlib"],          true]

# ---------------------------------------------------------------------------
# PurePath.suffixes — property fget qualname and module
#
# PurePath.suffixes returns the list of file extensions (e.g. ['.tar', '.gz']).
# It is a property not covered in pathlib_extra31 (extra31 covers the singular
# 'suffix' but not the plural 'suffixes'). Its fget.__qualname__ follows the
# same dotted convention and its __module__ is 'pathlib'.
# ---------------------------------------------------------------------------

invariant pathlib_extra32.PurePath.suffixes.qualname:
  description: "pathlib.PurePath.suffixes.fget.__qualname__ == 'PurePath.suffixes' — property returning the list of all file extensions"
  category: property_identity
  kind: python_call_eq
  function: "PurePath.suffixes.fget.__qualname__.__eq__"
  args: ["PurePath.suffixes"]
  expected: true

invariant pathlib_extra32.PurePath.suffixes.module:
  description: "pathlib.PurePath.suffixes.fget.__module__ == 'pathlib' — getter defined in the pathlib module"
  category: property_identity
  kind: python_call_eq
  function: "PurePath.suffixes.fget.__module__.__eq__"
  args: ["pathlib"]
  expected: true

# ---------------------------------------------------------------------------
# PurePath.drive, PurePath.root, PurePath.anchor — property fget qualnames
#
# These three properties expose the filesystem root components of a path:
#   drive  — the drive letter or UNC share (empty on POSIX)
#   root   — the root directory separator ('/' on POSIX)
#   anchor — drive + root (shorthand for drive + root combined)
# None of these are covered in pathlib_extra31. Their fget.__qualname__
# values follow the standard dotted form.
# ---------------------------------------------------------------------------

table pathlib_extra32.root_component_fget_qualnames:
  description: "fget.__qualname__ for PurePath.drive, PurePath.root, and PurePath.anchor"
  kind: python_call_eq
  category: property_identity
  id_prefix: rcfq32

  columns: [id, function, args, expected]
  rows:
    - [drive,  "PurePath.drive.fget.__qualname__.__eq__",  ["PurePath.drive"],  true]
    - [root,   "PurePath.root.fget.__qualname__.__eq__",   ["PurePath.root"],   true]
    - [anchor, "PurePath.anchor.fget.__qualname__.__eq__", ["PurePath.anchor"], true]

# ---------------------------------------------------------------------------
# fget.__module__ for drive, root, anchor
#
# The module attribute of the getter functions confirms these properties are
# defined in pathlib.py rather than any C extension or re-export. No prior
# pathlib spec checks fget.__module__ for these three root-component properties.
# ---------------------------------------------------------------------------

table pathlib_extra32.root_component_fget_modules:
  description: "fget.__module__ for PurePath.drive, PurePath.root, and PurePath.anchor — all 'pathlib'"
  kind: python_call_eq
  category: property_identity
  id_prefix: rcfm32

  columns: [id, function, args, expected]
  rows:
    - [drive,  "PurePath.drive.fget.__module__.__eq__",  ["pathlib"], true]
    - [root,   "PurePath.root.fget.__module__.__eq__",   ["pathlib"], true]
    - [anchor, "PurePath.anchor.fget.__module__.__eq__", ["pathlib"], true]
