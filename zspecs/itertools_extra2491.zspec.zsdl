spec: itertools_extra2491
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: __setitem__, __delitem__, and __missing__ dict-presence checks for itertools iterator classes."
    - "Theme: mutable item access and missing-key protocol — checking class __dict__ membership via __contains__."
    - "All itertools iterator types are C extension types that implement the iterator protocol (__iter__, __next__) only; none implement the mutable mapping protocol."
    - "itertools.count, cycle, repeat, chain, islice, starmap, compress, dropwhile, takewhile, zip_longest — none define __setitem__, __delitem__, or __missing__ in their class __dict__. Verified with Python 3.14."
    - "itertools.product, permutations, combinations, combinations_with_replacement, accumulate, groupby, filterfalse, pairwise — none define __setitem__, __delitem__, or __missing__ in their class __dict__. Verified with Python 3.14."
    - "These are lazy sequence generators that produce values on demand; they hold no mapping state and have no reason to implement item mutation or missing-key fallback."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools counting/infinite iterators — item protocol absence
#
# Theme: __setitem__, __delitem__, __missing__ absent from count, cycle, repeat.
# These C extension types produce infinite or finite sequences; they hold no
# mapping state and define none of the mutable mapping dunder methods.
# ---------------------------------------------------------------------------

table itertools_extra2491.infinite_iterators_item_protocol:
  description: "__setitem__, __delitem__, __missing__ absent from itertools.count, cycle, repeat __dict__; wave 2491"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: it2491

  columns: [id, function, args, expected]
  rows:
    - ["it2491-001", "count.__dict__.__contains__", ["__setitem__"], false]
    - ["it2491-002", "count.__dict__.__contains__", ["__delitem__"], false]
    - ["it2491-003", "count.__dict__.__contains__", ["__missing__"], false]
    - ["it2491-004", "cycle.__dict__.__contains__", ["__setitem__"], false]
    - ["it2491-005", "cycle.__dict__.__contains__", ["__delitem__"], false]
    - ["it2491-006", "cycle.__dict__.__contains__", ["__missing__"], false]
    - ["it2491-007", "repeat.__dict__.__contains__", ["__setitem__"], false]
    - ["it2491-008", "repeat.__dict__.__contains__", ["__delitem__"], false]
    - ["it2491-009", "repeat.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# Table 2: itertools chaining/selection iterators — item protocol absence
#
# Theme: __setitem__, __delitem__, __missing__ absent from chain, islice,
# compress, dropwhile, takewhile, starmap.
# These types filter or chain iterables; they are not mappings.
# ---------------------------------------------------------------------------

table itertools_extra2491.chaining_selection_item_protocol:
  description: "__setitem__, __delitem__, __missing__ absent from itertools.chain, islice, compress, dropwhile, takewhile, starmap __dict__; wave 2491"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: it2491

  columns: [id, function, args, expected]
  rows:
    - ["it2491-010", "chain.__dict__.__contains__", ["__setitem__"], false]
    - ["it2491-011", "chain.__dict__.__contains__", ["__delitem__"], false]
    - ["it2491-012", "chain.__dict__.__contains__", ["__missing__"], false]
    - ["it2491-013", "islice.__dict__.__contains__", ["__setitem__"], false]
    - ["it2491-014", "islice.__dict__.__contains__", ["__delitem__"], false]
    - ["it2491-015", "islice.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# Table 3: itertools combinatoric iterators — item protocol absence
#
# Theme: __setitem__, __delitem__, __missing__ absent from product, permutations,
# combinations, combinations_with_replacement, accumulate, groupby,
# filterfalse, pairwise.
# Combinatoric generators produce tuples on demand; none hold mutable mapping state.
# ---------------------------------------------------------------------------

table itertools_extra2491.combinatoric_item_protocol:
  description: "__setitem__, __delitem__, __missing__ absent from itertools combinatoric iterator __dict__ entries; wave 2491"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: it2491

  columns: [id, function, args, expected]
  rows:
    - ["it2491-016", "product.__dict__.__contains__", ["__setitem__"], false]
    - ["it2491-017", "product.__dict__.__contains__", ["__delitem__"], false]
    - ["it2491-018", "product.__dict__.__contains__", ["__missing__"], false]
    - ["it2491-019", "permutations.__dict__.__contains__", ["__setitem__"], false]
    - ["it2491-020", "permutations.__dict__.__contains__", ["__delitem__"], false]
    - ["it2491-021", "permutations.__dict__.__contains__", ["__missing__"], false]
    - ["it2491-022", "combinations.__dict__.__contains__", ["__setitem__"], false]
    - ["it2491-023", "combinations.__dict__.__contains__", ["__delitem__"], false]
    - ["it2491-024", "combinations.__dict__.__contains__", ["__missing__"], false]
