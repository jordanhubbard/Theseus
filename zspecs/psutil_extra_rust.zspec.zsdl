spec: psutil_extra_rust
version: ">=3.9"
backend: rust_module(psutil_extra_rust)

docs: https://psutil.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "https://psutil.readthedocs.io/en/latest/ — psutil documentation"
  not_derived_from:
    - "psutil source: psutil/__init__.py"
  notes:
    - "psutil provides system and process utilities for Python."
    - "psutil.cpu_count() >= 1 — number of CPUs."
    - "psutil.virtual_memory().total > 0."
    - "psutil.disk_usage('/').total > 0."
    - "psutil.pid_exists(1) == True — PID 1 always exists."
    - "Expose psutil_cpu_count_positive() -> bool: psutil.cpu_count() >= 1."
    - "Expose psutil_mem_total_positive() -> bool: psutil.virtual_memory().total > 0."
    - "Expose psutil_pid_1_exists() -> bool: psutil.pid_exists(1)."
    - "All test vectors verified against psutil 7.0.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# psutil_cpu_count_positive — CPU count >= 1
invariant psutil_extra_rust.cpu.count_ge1:
  description: "psutil.cpu_count() >= 1"
  category: cpu
  kind: python_call_eq
  function: psutil_cpu_count_positive
  args: []
  expected: true

# psutil_mem_total_positive — virtual memory total > 0
invariant psutil_extra_rust.memory.total_positive:
  description: "psutil.virtual_memory().total > 0"
  category: memory
  kind: python_call_eq
  function: psutil_mem_total_positive
  args: []
  expected: true

# psutil_pid_1_exists — PID 1 always exists
invariant psutil_extra_rust.process.pid_1_exists:
  description: "psutil.pid_exists(1) == True"
  category: process
  kind: python_call_eq
  function: psutil_pid_1_exists
  args: []
  expected: true

