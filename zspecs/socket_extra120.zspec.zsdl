spec: socket_extra120
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra119.zspec.zsdl — covers SocketKind.__class__.__name__.__len__()==8 / SocketKind.__class__.__module__.__eq__('enum') / SocketKind.__class__.__module__.__len__()==4 / SOCK_RAW.name.__len__()==8 (table + invariants)."
    - "socket_extra111.zspec.zsdl — covers __spec__.__class__.__name__.__eq__('ModuleSpec') / __spec__.name.__eq__('socket') / __spec__.has_location==True / __loader__.__class__.__name__.__eq__('SourceFileLoader') / type(__spec__.origin).__name__.__eq__('str') (table + invariants)."
    - "socket_extra101.zspec.zsdl — covers __spec__.name.__len__()==6 / __spec__.__class__.__name__.__len__()==10 / __loader__.__class__.__name__.__len__()==16 as table rows and standalones."
    - "socket_extra59.zspec.zsdl — covers __spec__.origin.__class__.__name__.__eq__('str') / __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') / __loader__.__class__.__name__.__len__()==16 (table + invariants)."
    - "socket_extra58.zspec.zsdl — covers __loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') (table + invariants)."
  notes:
    - "This spec extends socket through socket_extra119; it does NOT duplicate invariants present in those files."
    - "Wave 280 theme: socket module __spec__ and __loader__ class module attribution not yet covered — extra111 anchors __spec__.__class__.__name__.__eq__('ModuleSpec'); extra111 anchors __loader__.__class__.__name__.__eq__('SourceFileLoader'); NOT YET covered: __spec__.__class__.__module__.__eq__('_frozen_importlib') and len==17; __loader__.__class__.__module__.__eq__('_frozen_importlib_external') and len==26."
    - "socket.__spec__.__class__.__module__ == '_frozen_importlib'. len('_frozen_importlib')==17. ModuleSpec is defined in importlib._bootstrap (Lib/importlib/_bootstrap.py), compiled into the frozen module '_frozen_importlib' baked into CPython binary. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__loader__.__class__.__module__ == '_frozen_importlib_external'. len('_frozen_importlib_external')==26. SourceFileLoader is defined in importlib._bootstrap_external (Lib/importlib/_bootstrap_external.py), compiled into '_frozen_importlib_external'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__spec__.__class__.__module__.__len__() == 17 — len('_frozen_importlib')==17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__loader__.__class__.__module__.__len__() == 26 — len('_frozen_importlib_external')==26. This is the longest module name string in this spec (and among the longest in all socket specs). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket is a Python module (Lib/socket.py) loaded via the importlib machinery. The ModuleSpec type comes from the frozen '_frozen_importlib' module (17 chars, the frozen copy of importlib._bootstrap). SourceFileLoader comes from the frozen '_frozen_importlib_external' module (26 chars, the frozen copy of importlib._bootstrap_external). These two frozen modules form the core of Python's import machinery; they are compiled into the CPython binary (Python/frozen.c) to allow the import system to bootstrap before the filesystem is accessible. '_frozen_importlib_external' is the longest standard frozen module name by far. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.__spec__.__class__.__module__.__eq__('_frozen_importlib') == True
# socket.__spec__.__class__.__module__.__len__() == 17
# socket.__loader__.__class__.__module__.__eq__('_frozen_importlib_external') == True
# socket.__loader__.__class__.__module__.__len__() == 26
# socket.__spec__.__class__.__name__.__len__() == 10
#
# Wave 280 theme: socket __spec__ and __loader__ class module attribution.
#
# socket.__spec__ is a ModuleSpec instance. ModuleSpec is defined in
# importlib._bootstrap, which CPython compiles into the frozen module
# '_frozen_importlib' (17 chars) baked into the interpreter binary (Python/frozen.c).
# socket.__loader__ is a SourceFileLoader instance. SourceFileLoader is defined in
# importlib._bootstrap_external, compiled into '_frozen_importlib_external' (26 chars).
# extra111 anchors __spec__.__class__.__name__.__eq__('ModuleSpec') and
# __loader__.__class__.__name__.__eq__('SourceFileLoader'); extra101 anchors their
# name lengths. No prior socket spec anchors the __class__.__module__ for either.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra120.spec_and_loader_class_module_attribution:
  description: "__spec__.__class__.__module__.__eq__('_frozen_importlib')==True / __spec__.__class__.__module__.__len__()==17 / __loader__.__class__.__module__.__eq__('_frozen_importlib_external')==True / __loader__.__class__.__module__.__len__()==26 / __spec__.__class__.__name__.__len__()==10 — ModuleSpec is from '_frozen_importlib' (17 chars; frozen importlib._bootstrap baked into CPython); SourceFileLoader is from '_frozen_importlib_external' (26 chars; frozen importlib._bootstrap_external); '_frozen_importlib_external' is 26 chars, longest frozen module name; extra111 anchors class names; no prior spec anchors class modules; first sockmeta120 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockmeta120

  columns: [id, function, args, expected, description]
  rows:
    - [spec_cls_mod_eq,    __spec__.__class__.__module__.__eq__,    ["_frozen_importlib"],          true, "__spec__.__class__.__module__ is '_frozen_importlib' (frozen importlib._bootstrap baked into CPython; same source as hashlib.__spec__.__class__.__module__)"]
    - [spec_cls_mod_len,   __spec__.__class__.__module__.__len__,   [],                             17,   "__spec__.__class__.__module__.__len__() is 17 (len('_frozen_importlib')==17; 17-char frozen module name)"]
    - [loader_cls_mod_eq,  __loader__.__class__.__module__.__eq__,  ["_frozen_importlib_external"], true, "__loader__.__class__.__module__ is '_frozen_importlib_external' (frozen importlib._bootstrap_external; 26 chars; SourceFileLoader defined there)"]
    - [loader_cls_mod_len, __loader__.__class__.__module__.__len__, [],                             26,   "__loader__.__class__.__module__.__len__() is 26 (len('_frozen_importlib_external')==26; longest frozen module name in this spec)"]
    - [spec_cls_name_len,  __spec__.__class__.__name__.__len__,     [],                             10,   "__spec__.__class__.__name__.__len__() is 10 (len('ModuleSpec')==10; extra101 anchors this as standalone; cross-check)"]

# ---------------------------------------------------------------------------
# socket.__spec__.__class__.__module__.__len__() == 17
# socket.__loader__.__class__.__module__.__len__() == 26
# socket.__spec__.__class__.__name__.__len__() == 10
# socket.__loader__.__class__.__name__.__len__() == 16
# socket.__spec__.name.__len__() == 6
#
# Wave 280 theme: length comparison across spec and loader class attributes.
#
# The frozen module name lengths form an interesting pattern: '_frozen_importlib'=17
# for ModuleSpec and '_frozen_importlib_external'=26 for SourceFileLoader. The
# difference is exactly 9 chars ('_external'=9). ModuleSpec class name is 10 chars,
# SourceFileLoader class name is 16 chars — a difference of 6. The socket module
# name itself is 6 chars ('socket'). These lengths form a tableau that can be
# verified for cross-consistency. No prior socket spec groups the frozen module
# lengths with the class name lengths and spec.name in one table. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table socket_extra120.spec_and_loader_class_lengths_comparison:
  description: "__spec__.__class__.__module__.__len__()==17 / __loader__.__class__.__module__.__len__()==26 / __spec__.__class__.__name__.__len__()==10 / __loader__.__class__.__name__.__len__()==16 / __spec__.name.__len__()==6 — frozen module lengths: '_frozen_importlib'=17 vs '_frozen_importlib_external'=26 (difference 9='_external'); class name lengths: 'ModuleSpec'=10 vs 'SourceFileLoader'=16 (difference 6='socket'); spec.name 'socket'=6 matches that difference coincidentally; extra101 anchors name lengths as standalones; first sockmeta120 length comparison anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockmeta120

  columns: [id, function, args, expected, description]
  rows:
    - [spec_cls_mod_len2,   __spec__.__class__.__module__.__len__,   [], 17, "__spec__.__class__.__module__.__len__() is 17 (len('_frozen_importlib')==17; cross-check)"]
    - [loader_cls_mod_len2, __loader__.__class__.__module__.__len__, [], 26, "__loader__.__class__.__module__.__len__() is 26 (len('_frozen_importlib_external')==26; '_external'=9 chars added over '_frozen_importlib'=17)"]
    - [spec_cls_name_len2,  __spec__.__class__.__name__.__len__,     [], 10, "__spec__.__class__.__name__.__len__() is 10 (len('ModuleSpec')==10; cross-check with extra101)"]
    - [loader_cls_name_len, __loader__.__class__.__name__.__len__,   [], 16, "__loader__.__class__.__name__.__len__() is 16 (len('SourceFileLoader')==16; cross-check with extra101)"]
    - [spec_name_len,       __spec__.name.__len__,                   [],  6, "__spec__.name.__len__() is 6 (len('socket')==6; cross-check with extra101; coincidentally equals class name length difference 16-10=6)"]

# ---------------------------------------------------------------------------
# socket.__spec__.__class__.__module__.__eq__('_frozen_importlib') == True
# socket.__loader__.__class__.__module__.__eq__('_frozen_importlib_external') == True
# socket.__spec__.__class__.__module__.__len__() == 17
# socket.__loader__.__class__.__module__.__len__() == 26
# socket.__spec__.name.__eq__('socket') == True
#
# Wave 280 theme: cross-check grouping both class module equalities with lengths.
#
# This table cross-checks all five key values for the frozen module attribution.
# It groups the equality and length checks for both ModuleSpec and SourceFileLoader
# class modules in one view, confirming that the two frozen bootstrap modules
# (_frozen_importlib and _frozen_importlib_external) are the homes of the two
# importlib types used to load the socket module. The spec.name confirms the
# module identity in the same cross-check. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra120.spec_and_loader_class_module_cross_check:
  description: "__spec__.__class__.__module__.__eq__('_frozen_importlib')==True / __loader__.__class__.__module__.__eq__('_frozen_importlib_external')==True / __spec__.__class__.__module__.__len__()==17 / __loader__.__class__.__module__.__len__()==26 / __spec__.name.__eq__('socket')==True — cross-check confirming both frozen module attributions and spec identity; ModuleSpec from '_frozen_importlib' (bootstrap) and SourceFileLoader from '_frozen_importlib_external' (bootstrap_external); spec.name confirms this is the socket module; first sockmeta120 cross-check anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockmeta120

  columns: [id, function, args, expected, description]
  rows:
    - [spec_cls_mod_eq2,    __spec__.__class__.__module__.__eq__,    ["_frozen_importlib"],          true, "__spec__.__class__.__module__ is '_frozen_importlib' (cross-check confirming frozen module attribution for ModuleSpec)"]
    - [loader_cls_mod_eq2,  __loader__.__class__.__module__.__eq__,  ["_frozen_importlib_external"], true, "__loader__.__class__.__module__ is '_frozen_importlib_external' (cross-check confirming frozen module attribution for SourceFileLoader)"]
    - [spec_cls_mod_len3,   __spec__.__class__.__module__.__len__,   [],                             17,   "__spec__.__class__.__module__.__len__() is 17 (cross-check confirming length)"]
    - [loader_cls_mod_len3, __loader__.__class__.__module__.__len__, [],                             26,   "__loader__.__class__.__module__.__len__() is 26 (cross-check; longest frozen module name)"]
    - [spec_name_eq,        __spec__.name.__eq__,                    ["socket"],                     true, "__spec__.name is 'socket' (cross-check confirming module identity in the same table; extra111 anchors this)"]

# ---------------------------------------------------------------------------
# socket.__spec__.__class__.__module__.__eq__('_frozen_importlib') — standalone
#
# socket.__spec__.__class__.__module__ is '_frozen_importlib'. ModuleSpec is the
# class that stores a module's import specification (name, loader, origin, etc.).
# It is defined in Lib/importlib/_bootstrap.py which CPython compiles into a frozen
# bytecode module named '_frozen_importlib' and embeds in the interpreter binary
# (Python/frozen.c). This frozen module allows the import machinery to bootstrap
# before the filesystem is accessible. extra111 anchors __spec__.__class__.__name__
# .__eq__('ModuleSpec'); no prior socket spec anchors __spec__.__class__.__module__
# as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra120.spec_class_module_frozen_importlib:
  description: "socket.__spec__.__class__.__module__.__eq__('_frozen_importlib') == True — ModuleSpec from frozen importlib._bootstrap baked into CPython binary (Python/frozen.c; 17-char frozen module name; allows import machinery to boot before filesystem accessible); extra111 anchors __spec__.__class__.__name__.__eq__('ModuleSpec'); no prior socket spec anchors __spec__.__class__.__module__ as standalone; first standalone under sockmeta120"
  category: type_identity
  kind: python_call_eq
  function: __spec__.__class__.__module__.__eq__
  args: ["_frozen_importlib"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__spec__.__class__.__module__.__len__() == 17 — standalone
#
# socket.__spec__.__class__.__module__.__len__() is 17. '_frozen_importlib' has
# 17 chars: '_'=1 + 'frozen'=6 + '_'=1 + 'importlib'=9 = 17. This is a 17-char
# string that also matches uuid.UUID.__weakref__.__class__.__name__.__len__()==17
# (len('getset_descriptor')==17) — a coincidence across different module families.
# extra101 anchors __spec__.__class__.__name__.__len__()==10; no prior socket spec
# anchors __spec__.__class__.__module__.__len__()==17 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra120.spec_class_module_len_17:
  description: "socket.__spec__.__class__.__module__.__len__() == 17 — len('_frozen_importlib')==17 ('_'=1 + 'frozen'=6 + '_'=1 + 'importlib'=9; frozen CPython bootstrap module for import machinery; same length as len('getset_descriptor')==17 across module families — coincidence); extra101 anchors __spec__.__class__.__name__.__len__()==10; no prior socket spec anchors __spec__ class module length as standalone; first standalone under sockmeta120"
  category: type_identity
  kind: python_call_eq
  function: __spec__.__class__.__module__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# socket.__loader__.__class__.__module__.__eq__('_frozen_importlib_external') — standalone
#
# socket.__loader__.__class__.__module__ is '_frozen_importlib_external'. SourceFileLoader
# is the loader class for .py source files. It is defined in
# Lib/importlib/_bootstrap_external.py which CPython compiles into the frozen module
# '_frozen_importlib_external' (26 chars) and bakes into the interpreter binary.
# This frozen module handles the filesystem-facing parts of the import machinery
# (file-based loaders, source cache, etc.), while '_frozen_importlib' handles the
# pure-Python machinery. extra111 anchors __loader__.__class__.__name__.__eq__
# ('SourceFileLoader'); no prior socket spec anchors __loader__.__class__.__module__
# as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra120.loader_class_module_frozen_importlib_external:
  description: "socket.__loader__.__class__.__module__.__eq__('_frozen_importlib_external') == True — SourceFileLoader from frozen importlib._bootstrap_external baked into CPython binary (Python/frozen.c; 26-char frozen module name; handles filesystem-facing import machinery including .py loaders and source cache; complements '_frozen_importlib'=17 which handles pure-Python machinery); extra111 anchors __loader__.__class__.__name__.__eq__('SourceFileLoader'); no prior socket spec anchors __loader__.__class__.__module__ as standalone; first standalone under sockmeta120"
  category: type_identity
  kind: python_call_eq
  function: __loader__.__class__.__module__.__eq__
  args: ["_frozen_importlib_external"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__loader__.__class__.__module__.__len__() == 26 — standalone
#
# socket.__loader__.__class__.__module__.__len__() is 26. '_frozen_importlib_external'
# has 26 chars: '_'=1 + 'frozen'=6 + '_'=1 + 'importlib'=9 + '_'=1 + 'external'=8 = 26.
# This is the longest module name string in any socket spec. It is 9 chars longer than
# '_frozen_importlib' (17 chars) — the difference '_external' (9 chars) reflects the
# split between the core bootstrap (importlib._bootstrap) and the filesystem-aware
# extension (importlib._bootstrap_external). No prior socket spec anchors
# __loader__.__class__.__module__.__len__()==26 as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant socket_extra120.loader_class_module_len_26:
  description: "socket.__loader__.__class__.__module__.__len__() == 26 — len('_frozen_importlib_external')==26 ('_frozen_importlib'=17 + '_external'=9; filesystem-aware part of frozen importlib bootstrap; longest module name string in any socket spec; 9 chars longer than '_frozen_importlib'=17 reflecting the _external suffix); no prior socket spec anchors __loader__ class module length as standalone; first standalone under sockmeta120"
  category: type_identity
  kind: python_call_eq
  function: __loader__.__class__.__module__.__len__
  args: []
  expected: 26
