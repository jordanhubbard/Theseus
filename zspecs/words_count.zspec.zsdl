spec: words_count
version: ">=2.0.2"
backend: node(words-count)

docs: https://www.npmjs.com/package/words-count

provenance:
  derived_from:
    - "words-count README — https://www.npmjs.com/package/words-count"
    - "Test vectors verified with words-count via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "words-count source"
  notes:
    - "words-count is an npm package. Install: npm install words-count"
    - "Counts the number of words in a string."
    - "Exports a default function plus named wordsCount, wordsSplit, wordsDetect."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table words_count.count:
  kind: node_module_call_eq
  function: "default"
  category: strings
  id_prefix: wcnt

  columns: [id, args, expected]
  rows:
    - [two_words,   ["hello world"],     2]
    - [three_words, ["one two three"],   3]
    - [empty,       [""],               0]
