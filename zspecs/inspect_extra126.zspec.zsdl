spec: inspect_extra126
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Parameter and inspect.Signature class identity attributes (Wave 258)."
    - "inspect.Parameter.__name__ == 'Parameter' (len 9). Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Parameter.__qualname__ == 'Parameter' (len 9). Verified with Python 3.14.3."
    - "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter inherits directly from object. Verified with Python 3.14.3."
    - "len(inspect.Parameter.__mro__) == 2 — MRO is [Parameter, object]. Verified with Python 3.14.3."
    - "inspect.Parameter.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "inspect.Signature.__name__ == 'Signature' (len 9). Verified with Python 3.14.3."
    - "inspect.Signature.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Signature.__qualname__ == 'Signature' (len 9). Verified with Python 3.14.3."
    - "inspect.Signature.__bases__[0].__name__ == 'object' — Signature inherits directly from object. Verified with Python 3.14.3."
    - "len(inspect.Signature.__mro__) == 2 — MRO is [Signature, object]. Verified with Python 3.14.3."
    - "inspect.Signature.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter class identity
#
# Wave 258 theme: inspect.Parameter class identity attributes.
#
# inspect.Parameter.__name__ == 'Parameter' (len 9)
# inspect.Parameter.__module__ == 'inspect'
# inspect.Parameter.__qualname__ == 'Parameter' (len 9)
# inspect.Parameter.__bases__[0].__name__ == 'object'
# len(inspect.Parameter.__mro__) == 2
# inspect.Parameter.__class__.__name__ == 'type'
#
# Parameter is a Python class defined in Lib/inspect.py representing a
# callable's parameter; it inherits directly from object; MRO length is 2.
# New to extra126.
# ---------------------------------------------------------------------------

table inspect_extra126.parameter_class_identity:
  description: "inspect.Parameter class identity: __name__, __module__, __qualname__, __bases__[0], MRO len, __class__.__name__; wave 258; new to extra126"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparam126

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_name_eq_Parameter,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter is a Python class defined with 'class Parameter:' in Lib/inspect.py; it represents a single parameter in a callable's signature; __name__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra126"]
    - [parameter_name_len_eq_9,
       "Parameter.__name__.__len__",
       [],
       9,
       "inspect.Parameter.__name__.__len__() == 9 — __name__ is 'Parameter' which has exactly 9 characters; len('Parameter') == 9; new to extra126"]
    - [parameter_module_eq_inspect,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra126"]
    - [parameter_qualname_eq_Parameter,
       "Parameter.__qualname__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__.__eq__('Parameter') == True — Parameter is defined at module scope in Lib/inspect.py; its __qualname__ is the simple class name 'Parameter'; str.__eq__('Parameter') returns True; new to extra126"]
    - [parameter_qualname_len_eq_9,
       "Parameter.__qualname__.__len__",
       [],
       9,
       "inspect.Parameter.__qualname__.__len__() == 9 — __qualname__ is 'Parameter' which has exactly 9 characters; len('Parameter') == 9; new to extra126"]
    - [parameter_bases_first_eq_object,
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter inherits directly from object with no intermediate base classes; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra126"]
    - [parameter_mro_len_eq_2,
       "Parameter.__mro__.__len__",
       [],
       2,
       "inspect.Parameter.__mro__.__len__() == 2 — Parameter inherits directly from object; MRO is [Parameter, object]; len(__mro__) is 2; new to extra126"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature class identity
#
# Wave 258 theme: inspect.Signature class identity attributes.
#
# inspect.Signature.__name__ == 'Signature' (len 9)
# inspect.Signature.__module__ == 'inspect'
# inspect.Signature.__qualname__ == 'Signature' (len 9)
# inspect.Signature.__bases__[0].__name__ == 'object'
# len(inspect.Signature.__mro__) == 2
# inspect.Signature.__class__.__name__ == 'type'
#
# Signature is a Python class defined in Lib/inspect.py representing the
# call signature of a callable; it inherits directly from object; MRO length is 2.
# New to extra126.
# ---------------------------------------------------------------------------

table inspect_extra126.signature_class_identity:
  description: "inspect.Signature class identity: __name__, __module__, __qualname__, __bases__[0], MRO len, __class__.__name__; wave 258; new to extra126"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparam126

  columns: [id, function, args, expected, description]
  rows:
    - [signature_name_eq_Signature,
       "Signature.__name__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — Signature is a Python class defined with 'class Signature:' in Lib/inspect.py; it represents the call signature of a callable object; __name__ is 'Signature'; str.__eq__('Signature') returns True; new to extra126"]
    - [signature_name_len_eq_9,
       "Signature.__name__.__len__",
       [],
       9,
       "inspect.Signature.__name__.__len__() == 9 — __name__ is 'Signature' which has exactly 9 characters; len('Signature') == 9; new to extra126"]
    - [signature_module_eq_inspect,
       "Signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra126"]
    - [signature_qualname_eq_Signature,
       "Signature.__qualname__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__qualname__.__eq__('Signature') == True — Signature is defined at module scope in Lib/inspect.py; its __qualname__ is the simple class name 'Signature'; str.__eq__('Signature') returns True; new to extra126"]
    - [signature_qualname_len_eq_9,
       "Signature.__qualname__.__len__",
       [],
       9,
       "inspect.Signature.__qualname__.__len__() == 9 — __qualname__ is 'Signature' which has exactly 9 characters; len('Signature') == 9; new to extra126"]
    - [signature_bases_first_eq_object,
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature inherits directly from object with no intermediate base classes; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra126"]
    - [signature_mro_len_eq_2,
       "Signature.__mro__.__len__",
       [],
       2,
       "inspect.Signature.__mro__.__len__() == 2 — Signature inherits directly from object; MRO is [Signature, object]; len(__mro__) is 2; new to extra126"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter and Signature __class__.__name__ == 'type'
#
# Wave 258 theme: inspect.Parameter and Signature metaclass identity.
#
# inspect.Parameter.__class__.__name__ == 'type'
# inspect.Signature.__class__.__name__ == 'type'
# inspect.Parameter.__name__.__eq__(inspect.Signature.__name__) == False
# inspect.Parameter.__module__.__eq__(inspect.Signature.__module__) == True
#
# Both Parameter and Signature are plain Python classes whose metaclass
# is the built-in type; they share the same __module__ and both have
# __name__ lengths of 9. New to extra126.
# ---------------------------------------------------------------------------

table inspect_extra126.parameter_signature_metaclass:
  description: "inspect.Parameter and Signature __class__.__name__=='type'; both are plain Python classes with metaclass type; wave 258; new to extra126"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparam126

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_class_name_eq_type,
       "Parameter.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.__class__.__name__.__eq__('type') == True — Parameter is a plain Python class defined in Lib/inspect.py; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra126"]
    - [signature_class_name_eq_type,
       "Signature.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Signature.__class__.__name__.__eq__('type') == True — Signature is a plain Python class defined in Lib/inspect.py; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra126"]
    - [parameter_name_not_eq_signature_name,
       "Parameter.__name__.__eq__",
       ["Signature"],
       false,
       "inspect.Parameter.__name__.__eq__('Signature') == False — Parameter.__name__ is 'Parameter', not 'Signature'; the two classes have different names even though they have the same length (9 chars each); str.__eq__('Signature') returns False; new to extra126"]
    - [parameter_module_eq_signature_module,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — both Parameter and Signature are defined in Lib/inspect.py; Parameter.__module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra126"]
    - [signature_qualname_not_eq_parameter_qualname,
       "Signature.__qualname__.__eq__",
       ["Parameter"],
       false,
       "inspect.Signature.__qualname__.__eq__('Parameter') == False — Signature.__qualname__ is 'Signature', not 'Parameter'; the two classes have distinct qualnames; str.__eq__('Parameter') returns False; new to extra126"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra126
# ---------------------------------------------------------------------------

invariant inspect_extra126.parameter_name:
  description: "inspect.Parameter.__name__ == 'Parameter' — plain Python class for signature parameters; wave 258; new to extra126"
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra126.parameter_module:
  description: "inspect.Parameter.__module__ == 'inspect' — defined in Lib/inspect.py; wave 258; new to extra126"
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra126.parameter_mro_len:
  description: "len(inspect.Parameter.__mro__) == 2 — MRO is [Parameter, object]; inherits directly from object; wave 258; new to extra126"
  kind: python_call_eq
  function: Parameter.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra126.signature_name:
  description: "inspect.Signature.__name__ == 'Signature' — plain Python class for callable signatures; wave 258; new to extra126"
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra126.signature_bases_first:
  description: "inspect.Signature.__bases__[0].__name__ == 'object' — Signature inherits directly from object; wave 258; new to extra126"
  kind: python_call_eq
  function: Signature.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true
