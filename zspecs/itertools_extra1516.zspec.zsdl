spec: itertools_extra1516
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave 548 theme: arithmetic/numeric operator protocol dict-presence checks — __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__ and reflected variants __radd__, __rmul__, __rsub__, __rtruediv__, __rfloordiv__, __rmod__, __rpow__ for itertools classes."
    - "itertools.chain: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "itertools.count: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "itertools.cycle: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "itertools.repeat: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "itertools.accumulate: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "itertools.combinations: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "All itertools classes implement the synchronous iterator protocol (__iter__ and __next__) but none implement any arithmetic operator protocol; they are iterators, not numeric types."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain and itertools.count — arithmetic operator protocol
# absence checks
#
# Wave 548 theme: chain concatenates iterables; count counts indefinitely.
#
# itertools.chain.__dict__.__contains__("__add__") == False
# itertools.chain.__dict__.__contains__("__mul__") == False
# itertools.chain.__dict__.__contains__("__sub__") == False
# itertools.count.__dict__.__contains__("__radd__") == False
# itertools.count.__dict__.__contains__("__rmul__") == False
# itertools.count.__dict__.__contains__("__floordiv__") == False
#
# Both are synchronous iterators. They have __iter__ and __next__ in __dict__
# but no arithmetic operator methods. New to extra1516.
# ---------------------------------------------------------------------------

table itertools_extra1516.chain_count_arithmetic_protocol_absence:
  description: "itertools.chain and count have no arithmetic operator methods in __dict__; both are synchronous iterators with no numeric support; wave 548; new to extra1516"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1516cc

  columns: [id, function, args, expected, description]
  rows:
    - [it1516cc001,
       "chain.__dict__.__contains__",
       ["__add__"],
       false,
       "itertools.chain.__dict__.__contains__('__add__') == False — chain is a synchronous iterator that concatenates multiple iterables into a single sequence; it is not a numeric type and does not implement the addition operator protocol; __add__ is not in chain.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cc002,
       "chain.__dict__.__contains__",
       ["__mul__"],
       false,
       "itertools.chain.__dict__.__contains__('__mul__') == False — chain does not implement the multiplication operator protocol; __mul__ is not in chain.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cc003,
       "chain.__dict__.__contains__",
       ["__sub__"],
       false,
       "itertools.chain.__dict__.__contains__('__sub__') == False — chain does not implement the subtraction operator protocol; __sub__ is not in chain.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cc004,
       "count.__dict__.__contains__",
       ["__radd__"],
       false,
       "itertools.count.__dict__.__contains__('__radd__') == False — count is a synchronous infinite counter iterator; it does not implement the reflected addition operator protocol; __radd__ is not in count.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cc005,
       "count.__dict__.__contains__",
       ["__rmul__"],
       false,
       "itertools.count.__dict__.__contains__('__rmul__') == False — count does not implement the reflected multiplication operator protocol; __rmul__ is not in count.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cc006,
       "count.__dict__.__contains__",
       ["__floordiv__"],
       false,
       "itertools.count.__dict__.__contains__('__floordiv__') == False — count does not implement the floor division operator protocol; __floordiv__ is not in count.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cc007,
       "chain.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.chain.__dict__.__contains__('__iter__') == True — chain IS a synchronous iterator and defines __iter__ in its __dict__; this is the synchronous iterator protocol, not any arithmetic operator protocol; verified with Python 3.12; new to extra1516"]
    - [it1516cc008,
       "count.__dict__.__contains__",
       ["__next__"],
       true,
       "itertools.count.__dict__.__contains__('__next__') == True — count defines __next__ in its __dict__ confirming it is a synchronous iterator; __next__ is the synchronous iteration protocol, distinct from any arithmetic operator protocol; verified with Python 3.12; new to extra1516"]

# ---------------------------------------------------------------------------
# Table 2: itertools.cycle, itertools.repeat, itertools.accumulate —
# arithmetic operator protocol absence checks
#
# Wave 548 theme: cycle cycles a sequence forever; repeat repeats a value;
# accumulate computes running aggregates.
#
# itertools.cycle.__dict__.__contains__("__add__") == False
# itertools.repeat.__dict__.__contains__("__mul__") == False
# itertools.accumulate.__dict__.__contains__("__truediv__") == False
# itertools.cycle.__dict__.__contains__("__rsub__") == False
# itertools.repeat.__dict__.__contains__("__rpow__") == False
# itertools.accumulate.__dict__.__contains__("__rmod__") == False
#
# All are synchronous iterators with __iter__ and __next__ in __dict__.
# New to extra1516.
# ---------------------------------------------------------------------------

table itertools_extra1516.cycle_repeat_accumulate_arithmetic_protocol_absence:
  description: "itertools.cycle, repeat, and accumulate have no arithmetic operator methods in __dict__; all are synchronous iterators with no numeric support; wave 548; new to extra1516"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1516cr

  columns: [id, function, args, expected, description]
  rows:
    - [it1516cr001,
       "cycle.__dict__.__contains__",
       ["__add__"],
       false,
       "itertools.cycle.__dict__.__contains__('__add__') == False — cycle is a synchronous iterator that cycles through a sequence indefinitely; it is not a numeric type and does not implement the addition operator protocol; __add__ is not in cycle.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cr002,
       "repeat.__dict__.__contains__",
       ["__mul__"],
       false,
       "itertools.repeat.__dict__.__contains__('__mul__') == False — repeat is a synchronous iterator that repeats a single value N times or indefinitely; it does not implement the multiplication operator protocol; __mul__ is not in repeat.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cr003,
       "accumulate.__dict__.__contains__",
       ["__truediv__"],
       false,
       "itertools.accumulate.__dict__.__contains__('__truediv__') == False — accumulate is a synchronous iterator that computes running totals or aggregates using a supplied function; it does not implement the true division operator protocol; __truediv__ is not in accumulate.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cr004,
       "cycle.__dict__.__contains__",
       ["__rsub__"],
       false,
       "itertools.cycle.__dict__.__contains__('__rsub__') == False — cycle does not implement the reflected subtraction operator protocol; __rsub__ is not in cycle.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cr005,
       "repeat.__dict__.__contains__",
       ["__rpow__"],
       false,
       "itertools.repeat.__dict__.__contains__('__rpow__') == False — repeat does not implement the reflected exponentiation operator protocol; __rpow__ is not in repeat.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cr006,
       "accumulate.__dict__.__contains__",
       ["__rmod__"],
       false,
       "itertools.accumulate.__dict__.__contains__('__rmod__') == False — accumulate does not implement the reflected modulo operator protocol; __rmod__ is not in accumulate.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cr007,
       "cycle.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.cycle.__dict__.__contains__('__iter__') == True — cycle IS a synchronous iterator and defines __iter__ in its __dict__; this is the synchronous iterator protocol, not any arithmetic operator protocol; verified with Python 3.12; new to extra1516"]
    - [it1516cr008,
       "accumulate.__dict__.__contains__",
       ["__next__"],
       true,
       "itertools.accumulate.__dict__.__contains__('__next__') == True — accumulate defines __next__ in its __dict__ confirming it is a synchronous iterator; the iteration protocol is present while any arithmetic operator protocol is wholly absent; verified with Python 3.12; new to extra1516"]

# ---------------------------------------------------------------------------
# Table 3: itertools.combinations — arithmetic operator protocol absence checks
#
# Wave 548 theme: combinations produces r-length subsequences.
#
# itertools.combinations.__dict__.__contains__("__add__") == False
# itertools.combinations.__dict__.__contains__("__mul__") == False
# itertools.combinations.__dict__.__contains__("__sub__") == False
# itertools.combinations.__dict__.__contains__("__floordiv__") == False
# itertools.combinations.__dict__.__contains__("__mod__") == False
# itertools.combinations.__dict__.__contains__("__rtruediv__") == False
#
# combinations is a synchronous iterator. It has __iter__ and __next__
# but no arithmetic operator methods. New to extra1516.
# ---------------------------------------------------------------------------

table itertools_extra1516.combinations_arithmetic_protocol_absence:
  description: "itertools.combinations has no arithmetic operator methods in __dict__; combinations is a synchronous iterator yielding r-length subsequences with no numeric support; wave 548; new to extra1516"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1516cb

  columns: [id, function, args, expected, description]
  rows:
    - [it1516cb001,
       "combinations.__dict__.__contains__",
       ["__add__"],
       false,
       "itertools.combinations.__dict__.__contains__('__add__') == False — combinations is a synchronous iterator yielding r-length subsequences from an input iterable; it is not a numeric type and does not implement the addition operator protocol; __add__ is not in combinations.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cb002,
       "combinations.__dict__.__contains__",
       ["__mul__"],
       false,
       "itertools.combinations.__dict__.__contains__('__mul__') == False — combinations does not implement the multiplication operator protocol; __mul__ is not in combinations.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cb003,
       "combinations.__dict__.__contains__",
       ["__sub__"],
       false,
       "itertools.combinations.__dict__.__contains__('__sub__') == False — combinations does not implement the subtraction operator protocol; __sub__ is not in combinations.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cb004,
       "combinations.__dict__.__contains__",
       ["__floordiv__"],
       false,
       "itertools.combinations.__dict__.__contains__('__floordiv__') == False — combinations does not implement the floor division operator protocol; __floordiv__ is not in combinations.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cb005,
       "combinations.__dict__.__contains__",
       ["__mod__"],
       false,
       "itertools.combinations.__dict__.__contains__('__mod__') == False — combinations does not implement the modulo operator protocol; __mod__ is not in combinations.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cb006,
       "combinations.__dict__.__contains__",
       ["__rtruediv__"],
       false,
       "itertools.combinations.__dict__.__contains__('__rtruediv__') == False — combinations does not implement the reflected true division operator protocol; __rtruediv__ is not in combinations.__dict__; verified with Python 3.12; new to extra1516"]
    - [it1516cb007,
       "combinations.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.combinations.__dict__.__contains__('__iter__') == True — combinations IS a synchronous iterator and defines __iter__ in its __dict__; this is the synchronous iterator protocol, not any arithmetic operator protocol; verified with Python 3.12; new to extra1516"]
    - [it1516cb008,
       "combinations.__dict__.__contains__",
       ["__next__"],
       true,
       "itertools.combinations.__dict__.__contains__('__next__') == True — combinations defines __next__ in its __dict__ confirming it is a synchronous iterator; __next__ is the synchronous iteration mechanism, wholly distinct from any absent arithmetic operator protocol; verified with Python 3.12; new to extra1516"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1516
# ---------------------------------------------------------------------------

invariant itertools_extra1516.chain_no_add:
  description: "itertools.chain.__dict__ does not contain '__add__' — chain is a synchronous iterator, not a numeric type; wave 548; new to extra1516"
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__add__"]
  expected: false

invariant itertools_extra1516.chain_no_mul:
  description: "itertools.chain.__dict__ does not contain '__mul__' — chain does not implement the multiplication operator protocol; wave 548; new to extra1516"
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__mul__"]
  expected: false

invariant itertools_extra1516.cycle_no_sub:
  description: "itertools.cycle.__dict__ does not contain '__sub__' — cycle does not implement the subtraction operator protocol; wave 548; new to extra1516"
  kind: python_call_eq
  function: cycle.__dict__.__contains__
  args: ["__sub__"]
  expected: false

invariant itertools_extra1516.repeat_no_mul:
  description: "itertools.repeat.__dict__ does not contain '__mul__' — repeat does not implement the multiplication operator protocol; wave 548; new to extra1516"
  kind: python_call_eq
  function: repeat.__dict__.__contains__
  args: ["__mul__"]
  expected: false

invariant itertools_extra1516.accumulate_no_add:
  description: "itertools.accumulate.__dict__ does not contain '__add__' — accumulate does not implement the addition operator protocol; wave 548; new to extra1516"
  kind: python_call_eq
  function: accumulate.__dict__.__contains__
  args: ["__add__"]
  expected: false

invariant itertools_extra1516.combinations_no_pow:
  description: "itertools.combinations.__dict__ does not contain '__pow__' — combinations does not implement the exponentiation operator protocol; wave 548; new to extra1516"
  kind: python_call_eq
  function: combinations.__dict__.__contains__
  args: ["__pow__"]
  expected: false

invariant itertools_extra1516.combinations_has_next:
  description: "itertools.combinations.__dict__ contains '__next__' — combinations IS a synchronous iterator; wave 548; new to extra1516"
  kind: python_call_eq
  function: combinations.__dict__.__contains__
  args: ["__next__"]
  expected: true
