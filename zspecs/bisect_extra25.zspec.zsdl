spec: bisect_extra25
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec extends bisect_extra24.zspec.zsdl."
    - "Prior specs covered: bisect.__name__/__package__, bisect_left/bisect_right/insort_left/insort_right/__name__/__module__, bisect/__insort alias resolution, name/qualname/module length tables (extra22-24), __qualname__.__eq__ table (extra23), __module__.__len__() and __module__.__eq__ for all 6 callables (extra23/24)."
    - "This spec covers: __class__.__name__.__len__() == 26 for all 6 callables (all are C builtins 'builtin_function_or_method'); bisect.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec'); bisect.__loader__.__class__.__name__.__len__() == 16 ('SourceFileLoader'); bisect.__doc__.__class__.__name__.__len__() == 3 ('str'); bisect.__name__.__len__() == 6 ('bisect' has no __all__)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "bisect has no __all__ attribute — the module exports 6 public callables without declaring __all__. Verified."
    - "bisect.bisect_left.__class__.__name__ == 'builtin_function_or_method', len == 26. Verified."
    - "bisect.bisect_right.__class__.__name__ == 'builtin_function_or_method', len == 26. Verified."
    - "bisect.insort_left.__class__.__name__ == 'builtin_function_or_method', len == 26. Verified."
    - "bisect.insort_right.__class__.__name__ == 'builtin_function_or_method', len == 26. Verified."
    - "bisect.bisect.__class__.__name__ == 'builtin_function_or_method', len == 26. Verified."
    - "bisect.insort.__class__.__name__ == 'builtin_function_or_method', len == 26. Verified."
    - "bisect.__spec__.__class__.__name__ == 'ModuleSpec', len == 10. Verified."
    - "bisect.__loader__.__class__.__name__ == 'SourceFileLoader', len == 16. Verified."
    - "bisect.__doc__.__class__.__name__ == 'str', len == 3. Verified."
    - "bisect.__name__ == 'bisect', len == 6. Verified."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __class__.__name__.__len__() for all 6 bisect callables — extra25
#
# Every bisect callable (bisect_left, bisect_right, insort_left, insort_right,
# and the aliases bisect and insort which resolve to bisect_right/insort_right)
# is a C builtin from _bisect. All have __class__.__name__ ==
# 'builtin_function_or_method' (len 26). No prior bisect spec covers
# __class__.__name__.__len__() for any callable. id_prefix bscnl25 is novel.
# ---------------------------------------------------------------------------

table bisect_extra25.callable_class_name_lens:
  description: "__class__.__name__.__len__() == 26 for all 6 bisect callables — all are C builtins ('builtin_function_or_method')"
  kind: python_call_eq
  category: function_type
  id_prefix: bscnl25

  columns: [id, function, method, method_args, expected]
  rows:
    - [bisect_left_cn,  bisect_left.__class__.__name__,  __len__, [], 26]
    - [bisect_right_cn, bisect_right.__class__.__name__, __len__, [], 26]
    - [insort_left_cn,  insort_left.__class__.__name__,  __len__, [], 26]
    - [insort_right_cn, insort_right.__class__.__name__, __len__, [], 26]
    - [bisect_alias_cn, bisect.__class__.__name__,       __len__, [], 26]
    - [insort_alias_cn, insort.__class__.__name__,       __len__, [], 26]

# ---------------------------------------------------------------------------
# bisect.__name__.__len__() == 6 — standalone, extra25 namespace
#
# bisect.__name__ == 'bisect', which has 6 characters. No prior bisect spec
# covers __name__.__len__() for the module itself (only for individual
# callables). bisect has no __all__, so this module-level name length
# provides a useful alternative identity anchor.
# ---------------------------------------------------------------------------

invariant bisect_extra25.module.name_len:
  description: "bisect.__name__.__len__() == 6 — 'bisect' has 6 characters; bisect has no __all__"
  category: module_identity
  kind: python_call_eq
  function: "__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# bisect.__doc__.__class__.__name__.__len__() == 3 — len('str') == 3
#
# bisect.__doc__ is a string. Its class name 'str' has length 3. No prior
# bisect spec covers __doc__.__class__.__name__.__len__(). Analogous to the
# heapq and struct checks in other extra25 specs; confirms the module-level
# docstring is a plain str.
# ---------------------------------------------------------------------------

invariant bisect_extra25.doc.class_name_len:
  description: "bisect.__doc__.__class__.__name__.__len__() == 3 — __doc__ is a str; len('str') == 3"
  category: module_metadata
  kind: python_call_eq
  function: "__doc__.__class__.__name__.__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# bisect.__spec__.__class__.__name__.__len__() == 10 — len('ModuleSpec') == 10
#
# bisect.__spec__ is an importlib.machinery.ModuleSpec instance. The class
# name 'ModuleSpec' has 10 characters. No prior bisect spec covers
# __spec__.__class__.__name__ or its length. Analogous to the heapq_extra23
# and struct_extra26 checks.
# ---------------------------------------------------------------------------

invariant bisect_extra25.spec.class_name_len:
  description: "bisect.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters"
  category: module_metadata
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# bisect.__loader__.__class__.__name__.__len__() == 16 — len('SourceFileLoader')
#
# bisect is loaded via importlib.machinery.SourceFileLoader. The class name
# 'SourceFileLoader' has 16 characters. No prior bisect spec covers
# __loader__.__class__.__name__ or its length. Mirrors heapq_extra23's
# analogous invariant; confirms the bisect module uses the same loader class.
# ---------------------------------------------------------------------------

invariant bisect_extra25.loader.class_name_len:
  description: "bisect.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters"
  category: module_metadata
  kind: python_call_eq
  function: "__loader__.__class__.__name__.__len__"
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# bisect.bisect_left.__class__.__name__.__len__() == 26 — standalone anchor
#
# bisect_left is a C builtin with __class__.__name__ == 'builtin_function_or_method'
# (len 26). Standalone invariant in extra25 for the canonical left-search
# function; complements the full table above by providing an individually
# named reference for the most frequently cited bisect callable.
# ---------------------------------------------------------------------------

invariant bisect_extra25.bisect_left.class_name_len:
  description: "bisect.bisect_left.__class__.__name__.__len__() == 26 — 'builtin_function_or_method' has 26 characters"
  category: function_type
  kind: python_call_eq
  function: bisect_left.__class__.__name__.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# bisect.insort.__class__.__name__.__len__() == 26 — alias standalone anchor
#
# bisect.insort is an alias for insort_right. Since it is the same underlying
# C function object, __class__.__name__ == 'builtin_function_or_method' (len 26).
# Standalone invariant confirms alias access preserves the C builtin type identity.
# ---------------------------------------------------------------------------

invariant bisect_extra25.insort_alias.class_name_len:
  description: "bisect.insort.__class__.__name__.__len__() == 26 — alias insort resolves to insort_right; same C builtin type"
  category: function_type
  kind: python_call_eq
  function: insort.__class__.__name__.__len__
  args: []
  expected: 26
