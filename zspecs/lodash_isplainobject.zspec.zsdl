spec: lodash_isplainobject
version: ">=4.0.0"
backend: node(lodash.isplainobject)

docs: https://lodash.com/docs/#isPlainObject

provenance:
  derived_from:
    - "lodash.isplainobject README — https://www.npmjs.com/package/lodash.isplainobject"
    - "Test vectors verified with lodash.isplainobject@4.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.isplainobject exports the _.isPlainObject function directly as module.exports."
    - "isPlainObject checks if value is a plain object (created by Object constructor or one with null prototype)."
    - "Arrays, null, and primitives return false."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_isplainobject.isplainobject:
  kind: node_module_call_eq
  function: ~
  category: isplainobject
  id_prefix: lipo

  columns: [id, args, expected]
  rows:
    - [plain,   [{"a": 1}],    true]
    - [empty,   [{}],          true]
    - [array,   [[1, 2, 3]],   false]
    - [null_v,  [null],        false]
    - [number,  [42],          false]
    - [string,  ["str"],       false]
