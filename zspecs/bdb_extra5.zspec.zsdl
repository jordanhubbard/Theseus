spec: bdb_extra5
version: ">=3.9"
backend: python_module(bdb)

docs: https://docs.python.org/3/library/bdb.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bdb.html — Python bdb module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bdb.py"
  notes:
    - "Extends bdb.zspec.zsdl through bdb_extra4.zspec.zsdl; does NOT duplicate invariants already present there."
    - "bdb covers: Bdb/__name__/__module__, Breakpoint/__name__, BdbQuit/__name__/__bases__[0]/__name__; set_trace/set_break/clear_break/clear_all_breaks/get_breaks/run/runcall/runeval/set_continue/set_quit __name__; Breakpoint.next is int."
    - "bdb_extra covers: Bdb/__name__/__module__, Breakpoint/__name__/__module__, BdbQuit/__name__/__module__/__bases__; set_trace/set_step/set_next/set_return/set_quit/set_break/run/runcall/runeval/set_continue/clear_break names."
    - "bdb_extra2 covers: Bdb.__bases__[0]/__name__=='object', checkfuncname/__name__/__module__, effective/__name__/__module__, class_qualnames table."
    - "bdb_extra3 covers: Bdb.__bases__.__len__==1, Breakpoint.__bases__[0]/__name__=='object', Breakpoint.__bases__.__len__==1, BdbQuit.__bases__[0]/__module__=='builtins', module __len__==3 table."
    - "bdb_extra4 covers: Bdb new method names table (canonic/reset/stop_here/break_here/user_line/user_return/do_clear/runctx/get_stack/format_stack_entry/dispatch_line/dispatch_call), Breakpoint method names (enable/disable/bpprint/bpformat/deleteMe), set_trace module-level __name__/__module__."
    - "NEW in this spec: Bdb method __qualname__ checks for dispatch_return/dispatch_exception/user_call/user_exception (not covered in any prior bdb spec); get_all_breaks/get_bpbynumber/clear_bpbynumber/clear_all_file_breaks/is_skipped_module __name__ checks (new methods); Bdb.__doc__ is a string; Breakpoint.__doc__ is a string."
    - "bdb.Bdb.dispatch_return.__qualname__ == 'Bdb.dispatch_return' — method qualname includes enclosing class."
    - "bdb.Bdb.is_skipped_module is a method that returns True if the current module is in the skip list."
    - "bdb.Bdb.__doc__.__class__.__name__ == 'str' — Bdb has a docstring (not None)."
    - "bdb.Breakpoint.__doc__.__class__.__name__ == 'str' — Breakpoint has a docstring."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Bdb method names not yet covered in any prior bdb spec
# bdb_extra4 covers canonic/reset/stop_here/break_here/user_line/user_return/
# do_clear/runctx/get_stack/format_stack_entry/dispatch_line/dispatch_call.
# This spec adds dispatch_return/dispatch_exception/user_call/user_exception/
# get_all_breaks/get_bpbynumber/clear_bpbynumber/clear_all_file_breaks/is_skipped_module.
# ---------------------------------------------------------------------------

table bdb_extra5.bdb_new_method_names:
  kind: python_call_eq
  category: methods
  id_prefix: method

  columns: [id, function, args, expected]
  rows:
    - [dispatch_return,     Bdb.dispatch_return.__name__.__eq__,     ["dispatch_return"],     true]
    - [dispatch_exception,  Bdb.dispatch_exception.__name__.__eq__,  ["dispatch_exception"],  true]
    - [user_call,           Bdb.user_call.__name__.__eq__,           ["user_call"],           true]
    - [user_exception,      Bdb.user_exception.__name__.__eq__,      ["user_exception"],      true]
    - [get_all_breaks,      Bdb.get_all_breaks.__name__.__eq__,      ["get_all_breaks"],      true]
    - [get_bpbynumber,      Bdb.get_bpbynumber.__name__.__eq__,      ["get_bpbynumber"],      true]
    - [clear_bpbynumber,    Bdb.clear_bpbynumber.__name__.__eq__,    ["clear_bpbynumber"],    true]
    - [clear_all_file_breaks, Bdb.clear_all_file_breaks.__name__.__eq__, ["clear_all_file_breaks"], true]
    - [is_skipped_module,   Bdb.is_skipped_module.__name__.__eq__,   ["is_skipped_module"],   true]

# ---------------------------------------------------------------------------
# Bdb method __qualname__ checks — dispatch and user hooks
# bdb_extra4 covers qualname for a subset of methods via the name table;
# this explicitly checks the __qualname__ attribute (class-qualified form).
# ---------------------------------------------------------------------------

table bdb_extra5.bdb_method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mqn

  columns: [id, function, args, expected]
  rows:
    - [dispatch_return,    Bdb.dispatch_return.__qualname__.__eq__,    ["Bdb.dispatch_return"],    true]
    - [dispatch_exception, Bdb.dispatch_exception.__qualname__.__eq__, ["Bdb.dispatch_exception"], true]
    - [user_call,          Bdb.user_call.__qualname__.__eq__,          ["Bdb.user_call"],          true]
    - [user_exception,     Bdb.user_exception.__qualname__.__eq__,     ["Bdb.user_exception"],     true]

# ---------------------------------------------------------------------------
# Bdb, Breakpoint, and BdbQuit __doc__ type checks
# No prior bdb spec checks whether any of these classes have a docstring.
# ---------------------------------------------------------------------------

invariant bdb_extra5.Bdb.doc_is_str:
  description: "bdb.Bdb.__doc__.__class__.__name__ == 'str' — Bdb has a docstring"
  category: class_doc
  kind: python_call_eq
  function: Bdb.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant bdb_extra5.Breakpoint.doc_is_str:
  description: "bdb.Breakpoint.__doc__.__class__.__name__ == 'str' — Breakpoint has a docstring"
  category: class_doc
  kind: python_call_eq
  function: Breakpoint.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
