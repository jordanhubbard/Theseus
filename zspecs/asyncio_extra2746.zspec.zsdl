  columns: [id, function, args, expected]
  rows:
    - ["as2746017", "asyncio.Queue.__dict__.__contains__",     ["__pow__"], false]
    - ["as2746018", "asyncio.Task.__dict__.__contains__",      ["__pow__"], false]
    - ["as2746019", "asyncio.Future.__dict__.__contains__",    ["__pow__"], false]
