# ---------------------------------------------------------------------------
# Table 4: combined __round__/__divmod__/__pow__ checks for Task, Future,
#          and Barrier
#
# Wave 630 theme: extended cross-operator coverage for asyncio coroutine and
# synchronization types. Task wraps a coroutine; Future represents an async
# result; Barrier coordinates a group of coroutines. None define any
# arithmetic operator protocol in their own __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra2746.task_future_barrier_arithmetic:
  description: "asyncio.Task, Future, Barrier combined __round__/__divmod__/__pow__ dict-presence checks — coroutine and coordination types define no arithmetic protocols"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2746

  columns: [id, function, args, expected]
  rows:
    - ["as2746025", "asyncio.Task.__dict__.__contains__",    ["__round__"],  false]
    - ["as2746026", "asyncio.Task.__dict__.__contains__",    ["__divmod__"], false]
    - ["as2746027", "asyncio.Task.__dict__.__contains__",    ["__pow__"],    false]
    - ["as2746028", "asyncio.Future.__dict__.__contains__",  ["__round__"],  false]
    - ["as2746029", "asyncio.Future.__dict__.__contains__",  ["__divmod__"], false]
    - ["as2746030", "asyncio.Future.__dict__.__contains__",  ["__pow__"],    false]
    - ["as2746031", "asyncio.Barrier.__dict__.__contains__", ["__round__"],  false]
    - ["as2746032", "asyncio.Barrier.__dict__.__contains__", ["__divmod__"], false]
    - ["as2746033", "asyncio.Barrier.__dict__.__contains__", ["__pow__"],    false]
