spec: asyncio_extra2746
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-queue.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 630 (_extra2746): __round__, __divmod__, __pow__ dict-presence checks."
    - "asyncio types (Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier) are concurrency primitives, not numeric types."
    - "None of these types define rounding, divmod, or power protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __round__ dict-presence checks
#
# Wave 630 theme: asyncio concurrency types do not implement the round
# operator. __round__ does not appear in any of these classes' own __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra2746.round_protocol:
  description: "asyncio types __round__ dict-presence checks — none define rounding in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2746

  columns: [id, function, args, expected]
  rows:
    - ["as2746001", "asyncio.Queue.__dict__.__contains__",     ["__round__"], false]
    - ["as2746002", "asyncio.Task.__dict__.__contains__",      ["__round__"], false]
    - ["as2746003", "asyncio.Future.__dict__.__contains__",    ["__round__"], false]
    - ["as2746004", "asyncio.Lock.__dict__.__contains__",      ["__round__"], false]
    - ["as2746005", "asyncio.Event.__dict__.__contains__",     ["__round__"], false]
    - ["as2746006", "asyncio.Semaphore.__dict__.__contains__", ["__round__"], false]
    - ["as2746007", "asyncio.Condition.__dict__.__contains__", ["__round__"], false]
    - ["as2746008", "asyncio.Barrier.__dict__.__contains__",   ["__round__"], false]

