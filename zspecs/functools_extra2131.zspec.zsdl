spec: functools_extra2131
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 2131 (_extra2131): exception protocol dict-presence checks — __cause__, __context__, __traceback__, __suppress_context__, __notes__, args, with_traceback in class __dict__ for functools types."
    - "Theme: exception protocol dict-presence — checking whether exception-related attributes are defined at the class level in __dict__ for functools types."
    - "functools has no exception types; partial, partialmethod, and cached_property are non-exception types."
    - "functools.partial defines 'args' in __dict__ as a data descriptor (slot wrapper for the positional args tuple). All other exception-protocol attrs are absent."
    - "functools.partialmethod does NOT define 'args' in __dict__ — it stores keywords separately and has no args slot/descriptor at the class level."
    - "functools.cached_property does NOT define any of the seven exception-protocol attributes in __dict__."
    - "Exception protocol attributes (__cause__, __context__, __traceback__, __suppress_context__, __notes__) are instance-level attributes set on exception instances, not class-level entries."
    - "with_traceback is a method defined on BaseException instances, not typically found in subclass __dict__ entries unless explicitly overridden."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: exception protocol dict-presence for functools.partial
#
# functools.partial is a C extension type wrapping a callable with fixed
# positional args and keyword args. It is NOT an exception type.
# 'args' IS in partial.__dict__ as a slot/data descriptor for the positional
# args tuple. All other exception-protocol attributes are absent.
# ---------------------------------------------------------------------------

table functools_extra2131.exception_protocol:
  description: "functools types exception-protocol attribute dict-presence checks — __cause__, __context__, __traceback__, __suppress_context__, __notes__, args, with_traceback"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2131

  columns: [id, function, args, expected]
  rows:
    - ["ft2131001", "functools.partial.__dict__.__contains__",         ["__cause__"],            false]
    - ["ft2131002", "functools.partial.__dict__.__contains__",         ["__context__"],          false]
    - ["ft2131003", "functools.partial.__dict__.__contains__",         ["__traceback__"],        false]
    - ["ft2131004", "functools.partial.__dict__.__contains__",         ["__suppress_context__"], false]
    - ["ft2131005", "functools.partial.__dict__.__contains__",         ["__notes__"],            false]
    - ["ft2131006", "functools.partial.__dict__.__contains__",         ["args"],                 true]
    - ["ft2131007", "functools.partial.__dict__.__contains__",         ["with_traceback"],       false]
    - ["ft2131008", "functools.partialmethod.__dict__.__contains__",   ["__cause__"],            false]
    - ["ft2131009", "functools.partialmethod.__dict__.__contains__",   ["__context__"],          false]
    - ["ft2131010", "functools.partialmethod.__dict__.__contains__",   ["__traceback__"],        false]
    - ["ft2131011", "functools.partialmethod.__dict__.__contains__",   ["__suppress_context__"], false]
    - ["ft2131012", "functools.partialmethod.__dict__.__contains__",   ["__notes__"],            false]
    - ["ft2131013", "functools.partialmethod.__dict__.__contains__",   ["args"],                 false]
    - ["ft2131014", "functools.partialmethod.__dict__.__contains__",   ["with_traceback"],       false]
    - ["ft2131015", "functools.cached_property.__dict__.__contains__", ["__cause__"],            false]
    - ["ft2131016", "functools.cached_property.__dict__.__contains__", ["__context__"],          false]
    - ["ft2131017", "functools.cached_property.__dict__.__contains__", ["__traceback__"],        false]
    - ["ft2131018", "functools.cached_property.__dict__.__contains__", ["__suppress_context__"], false]
    - ["ft2131019", "functools.cached_property.__dict__.__contains__", ["__notes__"],            false]
    - ["ft2131020", "functools.cached_property.__dict__.__contains__", ["args"],                 false]
    - ["ft2131021", "functools.cached_property.__dict__.__contains__", ["with_traceback"],       false]

# ---------------------------------------------------------------------------
# Table 2: non-exception type confirmation — functools types are not exceptions
#
# Confirming that partial, partialmethod, and cached_property are not
# exception types by checking that exception-specific class-level attributes
# are absent. This cross-checks the same result via __bases__ and issubclass.
# ---------------------------------------------------------------------------

table functools_extra2131.non_exception_types:
  description: "functools non-exception type checks — confirming partial, partialmethod, cached_property do not carry exception protocol class-level attrs"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2131

  columns: [id, function, args, expected]
  rows:
    - ["ft2131022", "functools.partial.__dict__.__contains__",         ["__cause__"],            false]
    - ["ft2131023", "functools.partial.__dict__.__contains__",         ["__context__"],          false]
    - ["ft2131024", "functools.partial.__dict__.__contains__",         ["with_traceback"],       false]
    - ["ft2131025", "functools.partialmethod.__dict__.__contains__",   ["__cause__"],            false]
    - ["ft2131026", "functools.partialmethod.__dict__.__contains__",   ["__context__"],          false]
    - ["ft2131027", "functools.partialmethod.__dict__.__contains__",   ["with_traceback"],       false]
    - ["ft2131028", "functools.cached_property.__dict__.__contains__", ["__cause__"],            false]
    - ["ft2131029", "functools.cached_property.__dict__.__contains__", ["__context__"],          false]
    - ["ft2131030", "functools.cached_property.__dict__.__contains__", ["with_traceback"],       false]
