spec: struct_extra43
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra42.zspec.zsdl — covers Struct.__class__.__name__.__eq__('type'), error.__class__.__name__.__eq__('type'), pack/unpack/calcsize/pack_into/unpack_from/iter_unpack.__class__.__name__.__eq__('builtin_function_or_method')."
    - "struct_extra41.zspec.zsdl — covers Struct.size/__name__.__eq__('size') and Struct.format/__name__/__qualname__.__eq__; Struct.size/format __class__.__name__.__eq__('getset_descriptor')."
    - "struct_extra40.zspec.zsdl — covers Struct.__init__/__repr__ __name__.__eq__ and __name__.__len__()==8."
    - "struct_extra38.zspec.zsdl — covers Struct/error __bases__[0].__qualname__.__eq__; error mro entry __name__.__eq__."
    - "struct_extra18.zspec.zsdl — covers Struct/__module__.__eq__('_struct') and all six module-level functions __module__.__eq__('_struct') and error/__module__.__eq__('struct')."
    - "struct_extra9.zspec.zsdl — covers Struct method pack/unpack/pack_into/unpack_from/iter_unpack __name__.__eq__ and __qualname__.__eq__."
  notes:
    - "This spec extends struct through struct_extra42; it does NOT duplicate invariants present in those files."
    - "Coverage gap: No prior struct spec checks __class__.__qualname__.__eq__ for Struct, error, or any of the six module-level functions. The __class__.__qualname__ axis mirrors __class__.__name__ for non-nested types and provides additional regression coverage. struct_extra42 covers __class__.__name__.__eq__ for the same set of objects. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__class__.__qualname__ == 'type'. Struct is a C extension type; its metaclass is the built-in type whose __qualname__ is 'type'. No prior spec checks Struct.__class__.__qualname__.__eq__('type'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.error.__class__.__qualname__ == 'type'. error is a C extension exception type; its metaclass is the built-in type. No prior spec checks error.__class__.__qualname__.__eq__('type'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.pack.__class__.__qualname__ == 'builtin_function_or_method'. pack is a C builtin in the _struct extension; its class's __qualname__ matches its __name__. No prior spec checks pack.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.unpack.__class__.__qualname__ == 'builtin_function_or_method'. Same C builtin calling convention as pack. No prior spec checks unpack.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.calcsize.__class__.__qualname__ == 'builtin_function_or_method'. Same C builtin calling convention. No prior spec checks calcsize.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.pack_into.__class__.__qualname__ == 'builtin_function_or_method'. Same C builtin calling convention. No prior spec checks pack_into.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__class__.__qualname__ == 'builtin_function_or_method'. Same C builtin calling convention. No prior spec checks unpack_from.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__class__.__qualname__ == 'builtin_function_or_method'. Same C builtin calling convention. No prior spec checks iter_unpack.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__class__.__module__ == 'builtins'. The built-in type metaclass has __module__ == 'builtins'. No prior spec checks Struct.__class__.__module__.__eq__('builtins'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.pack.__class__.__module__ == 'builtins'. The builtin_function_or_method type lives in the builtins module. No prior spec checks pack.__class__.__module__.__eq__('builtins'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.error.__class__.__module__ == 'builtins'. The type metaclass of the error exception class has __module__ == 'builtins'. No prior spec checks error.__class__.__module__.__eq__('builtins'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module-level callable __class__.__qualname__.__eq__ string values
#
# struct_extra42 covers __class__.__name__.__eq__ for the same objects.
# No prior struct spec checks __class__.__qualname__.__eq__ for Struct, error,
# pack, unpack, calcsize, pack_into, unpack_from, or iter_unpack.
# struct.Struct.__class__.__qualname__ == 'type'
# struct.error.__class__.__qualname__ == 'type'
# struct.pack/unpack/calcsize/pack_into/unpack_from/iter_unpack.__class__.__qualname__
#   == 'builtin_function_or_method'
# ---------------------------------------------------------------------------

table struct_extra43.callable_class_qualnames:
  description: "struct Struct/error __class__.__qualname__.__eq__('type') and pack/unpack/calcsize/pack_into/unpack_from/iter_unpack __class__.__qualname__.__eq__('builtin_function_or_method') — novel __class__.__qualname__ axis; no prior struct spec checks __class__.__qualname__.__eq__ for any of these objects"
  kind: python_call_eq
  category: type_structure
  id_prefix: structclsqual43

  columns: [id, function, args, expected]
  rows:
    - [Struct_class_qualname_eq,      Struct.__class__.__qualname__.__eq__,      ["type"],                       true]
    - [error_class_qualname_eq,       error.__class__.__qualname__.__eq__,       ["type"],                       true]
    - [pack_class_qualname_eq,        pack.__class__.__qualname__.__eq__,        ["builtin_function_or_method"], true]
    - [unpack_class_qualname_eq,      unpack.__class__.__qualname__.__eq__,      ["builtin_function_or_method"], true]
    - [calcsize_class_qualname_eq,    calcsize.__class__.__qualname__.__eq__,    ["builtin_function_or_method"], true]
    - [pack_into_class_qualname_eq,   pack_into.__class__.__qualname__.__eq__,   ["builtin_function_or_method"], true]
    - [unpack_from_class_qualname_eq, unpack_from.__class__.__qualname__.__eq__, ["builtin_function_or_method"], true]
    - [iter_unpack_class_qualname_eq, iter_unpack.__class__.__qualname__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# struct module-level object __class__.__module__.__eq__ string values
#
# No prior struct spec checks __class__.__module__.__eq__ for Struct, pack, or error
# at the metaclass/type level (struct_extra18 covers the objects' own __module__).
# struct.Struct.__class__.__module__ == 'builtins' (type metaclass → builtins)
# struct.pack.__class__.__module__ == 'builtins'   (builtin_function_or_method → builtins)
# struct.error.__class__.__module__ == 'builtins'  (type metaclass → builtins)
# Three rows cover the representative patterns.
# ---------------------------------------------------------------------------

table struct_extra43.callable_class_modules:
  description: "struct Struct/pack/error __class__.__module__.__eq__('builtins') — all struct module-level object metaclasses/types are defined in builtins; novel __class__.__module__ axis; no prior struct spec checks __class__.__module__.__eq__('builtins') for any struct object"
  kind: python_call_eq
  category: type_structure
  id_prefix: structclsmod43

  columns: [id, function, args, expected]
  rows:
    - [Struct_class_module_eq, Struct.__class__.__module__.__eq__, ["builtins"], true]
    - [pack_class_module_eq,   pack.__class__.__module__.__eq__,   ["builtins"], true]
    - [error_class_module_eq,  error.__class__.__module__.__eq__,  ["builtins"], true]
