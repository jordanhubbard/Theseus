spec: functools_extra158
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.singledispatch code attributes (__module__ 'functools', __name__ 'singledispatch'); functools.cached_property class identity (__name__ 'cached_property', __module__ 'functools', __bases__[0].__name__ 'object'); functools.total_ordering class identity (__name__ 'total_ordering', __module__ 'functools'); functools.WRAPPER_ASSIGNMENTS.__class__.__name__ 'tuple' (Wave 282)."
    - "functools.singledispatch.__module__ == 'functools' — singledispatch is a Python decorator function defined in Lib/functools.py; its __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.singledispatch.__name__ == 'singledispatch' — the __name__ of the singledispatch decorator function is 'singledispatch'. Verified with Python 3.14.3."
    - "functools.cached_property.__name__ == 'cached_property' — cached_property is a Python class in Lib/functools.py; its __name__ is 'cached_property'. Verified with Python 3.14.3."
    - "functools.cached_property.__module__ == 'functools' — cached_property is defined in Lib/functools.py; its __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property is a Python class that inherits directly from object; __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "functools.total_ordering.__name__ == 'total_ordering' — total_ordering is a Python class decorator in Lib/functools.py; its __name__ is 'total_ordering'. Verified with Python 3.14.3."
    - "functools.total_ordering.__module__ == 'functools' — total_ordering is defined in Lib/functools.py; its __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a module-level tuple constant listing the attributes that update_wrapper copies from the wrapped function; its __class__.__name__ is 'tuple'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.singledispatch code attributes
#
# Wave 282 theme: functools.singledispatch and functools.cached_property code
# attributes and class identity.
#
# functools.singledispatch.__module__ == 'functools'
# functools.singledispatch.__name__ == 'singledispatch'
# functools.cached_property.__name__ == 'cached_property'
# functools.cached_property.__module__ == 'functools'
#
# singledispatch is a pure-Python decorator function in Lib/functools.py that
# transforms a function into a single-dispatch generic function.
# cached_property is a Python class in Lib/functools.py that caches a method's
# result as a property on first access. New to extra158.
# ---------------------------------------------------------------------------

table functools_extra158.singledispatch_and_cached_property_identity:
  description: "functools.singledispatch: __module__ 'functools', __name__ 'singledispatch'; functools.cached_property: __name__ 'cached_property', __module__ 'functools'; wave 282; new to extra158"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolssdcpid158

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_module_eq_functools,
       "singledispatch.__module__.__eq__",
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is a Python decorator function defined in Lib/functools.py implementing single-dispatch generics; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra158"]
    - [singledispatch_name_eq,
       "singledispatch.__name__.__eq__",
       ["singledispatch"],
       true,
       "functools.singledispatch.__name__.__eq__('singledispatch') == True — singledispatch is the decorator that transforms a function into a single-dispatch generic function; its __name__ is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra158"]
    - [cached_property_name_eq,
       "cached_property.__name__.__eq__",
       ["cached_property"],
       true,
       "functools.cached_property.__name__.__eq__('cached_property') == True — cached_property is a Python class in Lib/functools.py that caches the result of a method call as a property on first access; its __name__ is 'cached_property'; str.__eq__('cached_property') returns True; new to extra158"]
    - [cached_property_module_eq_functools,
       "cached_property.__module__.__eq__",
       ["functools"],
       true,
       "functools.cached_property.__module__.__eq__('functools') == True — cached_property is defined in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra158"]
    - ["cached_property_bases_0_name_eq_object",
       "cached_property.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — cached_property is a Python class that inherits directly from object; __bases__ is (object,) so __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra158"]

# ---------------------------------------------------------------------------
# Table 2: functools.total_ordering and functools.WRAPPER_ASSIGNMENTS identity
#
# Wave 282 theme: functools.total_ordering class identity and
# functools.WRAPPER_ASSIGNMENTS type check.
#
# functools.total_ordering.__name__ == 'total_ordering'
# functools.total_ordering.__module__ == 'functools'
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
#
# total_ordering is a Python class decorator in Lib/functools.py that fills in
# missing comparison methods given __eq__ and one of __lt__, __le__, __gt__,
# or __ge__. WRAPPER_ASSIGNMENTS is a module-level tuple constant listing the
# function attributes that update_wrapper copies from the wrapped function.
# New to extra158.
# ---------------------------------------------------------------------------

table functools_extra158.total_ordering_and_wrapper_assignments:
  description: "functools.total_ordering: __name__ 'total_ordering', __module__ 'functools'; functools.WRAPPER_ASSIGNMENTS: class 'tuple'; wave 282; new to extra158"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolstowaid158

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_name_eq,
       "total_ordering.__name__.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__name__.__eq__('total_ordering') == True — total_ordering is a Python class decorator in Lib/functools.py that fills in missing comparison methods; its __name__ is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra158"]
    - [total_ordering_module_eq_functools,
       "total_ordering.__module__.__eq__",
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is defined in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra158"]
    - [wrapper_assignments_class_eq_tuple,
       "WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level tuple constant in functools listing the function attributes (__module__, __name__, __qualname__, __annotations__, __doc__, __dict__) copied by update_wrapper; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra158"]
    - [wrapper_assignments_class_class_eq_type,
       "WRAPPER_ASSIGNMENTS.__class__.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__class__.__name__.__eq__('type') == True — the metaclass of tuple is type; __class__.__class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra158"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra158
# ---------------------------------------------------------------------------

invariant functools_extra158.singledispatch_module_functools:
  description: "functools.singledispatch.__module__ == 'functools' — singledispatch is a Python decorator function in Lib/functools.py; wave 282; new to extra158"
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra158.singledispatch_name_eq:
  description: "functools.singledispatch.__name__ == 'singledispatch' — single-dispatch generic function decorator name; wave 282; new to extra158"
  kind: python_call_eq
  function: singledispatch.__name__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra158.cached_property_name_eq:
  description: "functools.cached_property.__name__ == 'cached_property' — Python class caching method result as property on first access; wave 282; new to extra158"
  kind: python_call_eq
  function: cached_property.__name__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra158.cached_property_module_functools:
  description: "functools.cached_property.__module__ == 'functools' — cached_property defined in Lib/functools.py; wave 282; new to extra158"
  kind: python_call_eq
  function: cached_property.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra158.cached_property_bases_object:
  description: "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property inherits directly from object; wave 282; new to extra158"
  kind: python_call_eq
  function: "cached_property.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra158.total_ordering_name_eq:
  description: "functools.total_ordering.__name__ == 'total_ordering' — class decorator filling in comparison methods; wave 282; new to extra158"
  kind: python_call_eq
  function: total_ordering.__name__.__eq__
  args: ["total_ordering"]
  expected: true

invariant functools_extra158.total_ordering_module_functools:
  description: "functools.total_ordering.__module__ == 'functools' — total_ordering defined in Lib/functools.py; wave 282; new to extra158"
  kind: python_call_eq
  function: total_ordering.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra158.wrapper_assignments_class_tuple:
  description: "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a tuple constant listing attributes copied by update_wrapper; wave 282; new to extra158"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true
