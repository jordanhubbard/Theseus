spec: socket_extra362
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "socket.gethostbyname.__name__ == 'gethostbyname'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__name__ == 'getfqdn'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOL_SOCKET == 65535 on macOS/Darwin 25.4.0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SO_REUSEADDR == 4 on macOS/Darwin 25.4.0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket(999, socket.SOCK_STREAM) raises OSError. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: gethostbyname is a C built-in in _socket extension (__module__=='_socket'); getfqdn is Python-level in socket.py (__module__=='socket')."
    - "Note: SOL_SOCKET == 65535 (0xFFFF) is macOS/BSD-specific. Linux uses SOL_SOCKET == 1."
    - "Note: SO_REUSEADDR == 4 is macOS/BSD-specific. Linux uses SO_REUSEADDR == 2."
    - "Note: socket.socket(999, SOCK_STREAM) raises OSError because address family 999 is not a valid/registered AF_* constant."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.gethostbyname.__name__ == 'gethostbyname'
# socket.gethostbyname.__module__ == '_socket'
# socket.getfqdn.__name__ == 'getfqdn'
# socket.getfqdn.__module__ == 'socket'
#
# Wave 362 theme: gethostbyname and getfqdn function identity.
#
# gethostbyname is a C built-in defined in the _socket C extension
# (Modules/socketmodule.c). Its __module__ is '_socket'. getfqdn is a
# pure-Python function defined in Lib/socket.py. Its __module__ is 'socket'.
# This split reflects the layered architecture: low-level OS calls are in
# the C extension (_socket), while higher-level utilities are in the Python
# wrapper (socket). gethostbyname calls getaddrinfo internally on modern
# platforms; getfqdn calls gethostname and gethostbyaddr.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra362.dns_function_identity:
  description: "gethostbyname.__name__.__eq__('gethostbyname')==True / gethostbyname.__module__.__eq__('_socket')==True / getfqdn.__name__.__eq__('getfqdn')==True / getfqdn.__module__.__eq__('socket')==True — gethostbyname is a C built-in in _socket extension; getfqdn is a Python function in socket.py; layered architecture: C extension for OS calls, Python wrapper for utilities; first socketfnid362 anchor for DNS function identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: socketfnid362

  columns: [id, function, args, expected, description]
  rows:
    - [gethostbyname_name,   "gethostbyname.__name__.__eq__",   ["gethostbyname"], true, "socket.gethostbyname.__name__ is 'gethostbyname' — C built-in function in _socket extension (Modules/socketmodule.c)"]
    - [gethostbyname_module, "gethostbyname.__module__.__eq__", ["_socket"],       true, "socket.gethostbyname.__module__ is '_socket' — defined in C extension, not Python wrapper"]
    - [getfqdn_name,         "getfqdn.__name__.__eq__",         ["getfqdn"],       true, "socket.getfqdn.__name__ is 'getfqdn' — pure-Python utility function defined in Lib/socket.py"]
    - [getfqdn_module,       "getfqdn.__module__.__eq__",       ["socket"],        true, "socket.getfqdn.__module__ is 'socket' — defined in Python wrapper (Lib/socket.py), not _socket C extension"]

# ---------------------------------------------------------------------------
# socket.SOL_SOCKET == 65535 (macOS)
# socket.SO_REUSEADDR == 4 (macOS)
#
# Wave 362 theme: SOL_SOCKET and SO_REUSEADDR constant values on macOS.
#
# SOL_SOCKET is the socket option level used with getsockopt/setsockopt to
# set options at the socket layer (rather than protocol layer). On macOS/BSD
# its value is 65535 (0xFFFF). On Linux it is 1. SO_REUSEADDR is the socket
# option that enables binding to a port in TIME_WAIT state. On macOS its
# value is 4. On Linux it is 2. Both values are macOS/BSD-specific constants
# from <sys/socket.h>.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra362.sol_socket_constants_macos:
  description: "SOL_SOCKET.__eq__(65535)==True / SO_REUSEADDR.__eq__(4)==True — macOS/BSD-specific socket option constants: SOL_SOCKET==65535 (0xFFFF, socket layer level for setsockopt/getsockopt; Linux uses 1), SO_REUSEADDR==4 (enable binding to TIME_WAIT port; Linux uses 2); from <sys/socket.h>; first socketfnid362 anchor for SOL_SOCKET and SO_REUSEADDR values"
  kind: python_call_eq
  category: socket_constants
  id_prefix: socketfnid362

  columns: [id, function, args, expected, description]
  rows:
    - [sol_socket_eq,   "SOL_SOCKET.__eq__",   [65535], true, "socket.SOL_SOCKET == 65535 (0xFFFF) on macOS/BSD — socket option level for setsockopt/getsockopt; Linux uses 1"]
    - [so_reuseaddr_eq, "SO_REUSEADDR.__eq__", [4],     true, "socket.SO_REUSEADDR == 4 on macOS/BSD — enables binding to TIME_WAIT port; Linux uses 2"]

# ---------------------------------------------------------------------------
# socket.socket(999, socket.SOCK_STREAM) raises OSError
#
# Wave 362 theme: invalid address family raises OSError.
#
# Creating a socket with an invalid address family (999) raises OSError.
# Address family 999 is not a registered AF_* constant on any platform.
# The OS rejects the syscall immediately with EAFNOSUPPORT (address family
# not supported), which Python maps to OSError. On macOS the underlying
# errno is EAFNOSUPPORT (47). OSError is the base exception for all OS-level
# failures in Python 3; socket.error is now an alias for OSError.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra362.socket_invalid_af_raises_oserror:
  description: "socket.socket(999, SOCK_STREAM) raises OSError — address family 999 is not a registered AF_* constant; OS rejects syscall with EAFNOSUPPORT (errno 47 on macOS); Python maps to OSError; socket.error is an alias for OSError in Python 3; first standalone for invalid AF raises OSError under socketfnid362"
  category: error_behaviors
  kind: python_call_raises
  function: socket
  args: [999, 1]
  raises: OSError

# ---------------------------------------------------------------------------
# socket.gethostbyname.__module__ == '_socket' — standalone
#
# socket.gethostbyname.__module__ is '_socket'. gethostbyname is one of
# the foundational DNS lookup functions in Python, wrapping the POSIX
# gethostbyname(3) call (or getaddrinfo on modern platforms). It is
# implemented as a C built-in in the _socket extension (Modules/socketmodule.c).
# Its __module__ being '_socket' (not 'socket') distinguishes it from
# Python-level functions like getfqdn whose __module__ is 'socket'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra362.gethostbyname_module_is__socket:
  description: "socket.gethostbyname.__module__.__eq__('_socket') == True — gethostbyname is a C built-in wrapping POSIX gethostbyname(3)/getaddrinfo; __module__ is '_socket' (Modules/socketmodule.c); contrast with getfqdn.__module__=='socket' (Python wrapper); C extension vs Python layer boundary; first standalone for gethostbyname.__module__ under socketfnid362"
  category: function_identity
  kind: python_call_eq
  function: gethostbyname.__module__.__eq__
  args: ["_socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOL_SOCKET == 65535 (macOS) — standalone
#
# socket.SOL_SOCKET is 65535 (0xFFFF) on macOS/Darwin. SOL_SOCKET is the
# socket option level constant used as the second argument to getsockopt()
# and setsockopt() when setting options at the socket layer (as opposed to
# a specific protocol layer like IPPROTO_TCP). The value 65535 (0xFFFF) is
# defined in the macOS/BSD <sys/socket.h> header. Linux uses SOL_SOCKET == 1.
# This is one of the most notable macOS/Linux socket API differences.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra362.SOL_SOCKET_eq_65535:
  description: "socket.SOL_SOCKET.__eq__(65535) == True — SOL_SOCKET is 65535 (0xFFFF) on macOS/BSD (<sys/socket.h>); second arg to getsockopt/setsockopt for socket-layer options; Linux uses SOL_SOCKET==1; macOS value is the most notable socket constant divergence from Linux; first standalone for SOL_SOCKET==65535 under socketfnid362"
  category: socket_constants
  kind: python_call_eq
  function: SOL_SOCKET.__eq__
  args: [65535]
  expected: true
