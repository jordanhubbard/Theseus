spec: lodash_topath
version: ">=4.0.0"
backend: node(lodash.topath)

docs: https://lodash.com/docs/#toPath

provenance:
  derived_from:
    - "lodash.topath README — https://www.npmjs.com/package/lodash.topath"
    - "Test vectors verified with lodash.topath@4.5.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.topath exports the _.toPath function directly as module.exports."
    - "toPath(value) converts a property path string to an array of path segments."
    - "Handles dot notation and bracket notation."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of path segments."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_topath.topath:
  kind: node_module_call_eq
  function: ~
  category: topath
  id_prefix: ltp

  columns: [id, args, expected]
  rows:
    - [dot_path,     ["a.b.c"],      ["a", "b", "c"]]
    - [bracket,      ["a[0].b"],     ["a", "0", "b"]]
    - [single,       ["foo"],        ["foo"]]
    - [array_path,   [["x", "y"]],  ["x", "y"]]
