spec: expand_tilde
version: ">=2.0.0"
backend: node(expand-tilde)

docs: https://github.com/jonschlinkert/expand-tilde#readme

provenance:
  derived_from:
    - "expand-tilde README — https://github.com/jonschlinkert/expand-tilde#readme"
    - "Test vectors verified with expand-tilde via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "expand-tilde source"
  notes:
    - "Replace leading '~' with the user's home directory in a file path."
    - "Install: npm install expand-tilde"
    - "v2 CJS; module export IS the function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string input."
  stderr: "null"
  stickiness: "N/A — depends on os.homedir() at call time."
  codes: {}

invariant expand_tilde.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant expand_tilde.absolute_path_unchanged:
  description: "Absolute path '/tmp' passes through unchanged"
  category: passthrough
  kind: node_chain_eq
  entry: module
  entry_args: ["/tmp"]
  chain: []
  expected: "/tmp"

invariant expand_tilde.relative_path_unchanged:
  description: "Relative path 'foo/bar' passes through unchanged"
  category: passthrough
  kind: node_chain_eq
  entry: module
  entry_args: ["foo/bar"]
  chain: []
  expected: "foo/bar"

invariant expand_tilde.tilde_alone_is_home:
  description: "Just '~' expands to a non-empty path (home directory)"
  category: expand
  kind: node_chain_eq
  entry: module
  entry_args: ["~"]
  chain:
    - {method: startsWith, args: ["/"]}
  expected: true

invariant expand_tilde.tilde_slash_path_starts_with_slash:
  description: "'~/foo' expands to a path starting with '/'"
  category: expand
  kind: node_chain_eq
  entry: module
  entry_args: ["~/foo"]
  chain:
    - {method: startsWith, args: ["/"]}
  expected: true

invariant expand_tilde.tilde_slash_path_ends_with_foo:
  description: "'~/foo' expanded result ends with '/foo'"
  category: expand
  kind: node_chain_eq
  entry: module
  entry_args: ["~/foo"]
  chain:
    - {method: endsWith, args: ["/foo"]}
  expected: true

invariant expand_tilde.empty_string_passthrough:
  description: "Empty input returns empty string"
  category: passthrough
  kind: node_chain_eq
  entry: module
  entry_args: [""]
  chain: []
  expected: ""
