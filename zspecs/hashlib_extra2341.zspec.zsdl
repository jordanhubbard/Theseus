spec: hashlib_extra2341
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 603 (_extra2341): __slots__ content and absence checks."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.blake2b is a C extension type; __dict__.__contains__('__slots__') == False."
    - "hashlib.blake2s is a C extension type; __dict__.__contains__('__slots__') == False."
    - "C extension types do not define __slots__ in the Python sense; their attribute layout is controlled by the C slot table."
    - "Complementary checks confirm known C-level attributes (name, digest_size, block_size, __new__, MAX_*) ARE present in __dict__."
    - "digestsize (alias without underscore) is NOT in __dict__ on CPython 3.12 for either blake2b or blake2s."
    - "__init__ is NOT in __dict__ for blake2b or blake2s — constructor handled by __new__ in C."
  created_at: "2026-04-12"

table hashlib_extra2341.blake2b_no_slots:
  description: "hashlib.blake2b is a C type — no Python __slots__ in its __dict__"
  kind: python_call_eq
  category: slots_absence
  id_prefix: hl2341
  columns: [id, function, args, expected]
  rows:
    - ["hl2341001", "hashlib.blake2b.__dict__.__contains__", ["__slots__"], false]
    - ["hl2341002", "hashlib.blake2b.__dict__.__contains__", ["__init__"], false]
    - ["hl2341003", "hashlib.blake2b.__dict__.__contains__", ["digestsize"], false]

table hashlib_extra2341.blake2b_dict_attrs:
  description: "hashlib.blake2b C-level attributes ARE present in __dict__"
  kind: python_call_eq
  category: slots_content
  id_prefix: hl2341
  columns: [id, function, args, expected]
  rows:
    - ["hl2341004", "hashlib.blake2b.__dict__.__contains__", ["name"], true]
    - ["hl2341005", "hashlib.blake2b.__dict__.__contains__", ["digest_size"], true]
    - ["hl2341006", "hashlib.blake2b.__dict__.__contains__", ["block_size"], true]
    - ["hl2341007", "hashlib.blake2b.__dict__.__contains__", ["__new__"], true]
    - ["hl2341008", "hashlib.blake2b.__dict__.__contains__", ["MAX_DIGEST_SIZE"], true]
    - ["hl2341009", "hashlib.blake2b.__dict__.__contains__", ["MAX_KEY_SIZE"], true]
    - ["hl2341010", "hashlib.blake2b.__dict__.__contains__", ["PERSON_SIZE"], true]
    - ["hl2341011", "hashlib.blake2b.__dict__.__contains__", ["SALT_SIZE"], true]

table hashlib_extra2341.blake2s_no_slots:
  description: "hashlib.blake2s is a C type — no Python __slots__ in its __dict__"
  kind: python_call_eq
  category: slots_absence
  id_prefix: hl2341
  columns: [id, function, args, expected]
  rows:
    - ["hl2341012", "hashlib.blake2s.__dict__.__contains__", ["__slots__"], false]
    - ["hl2341013", "hashlib.blake2s.__dict__.__contains__", ["__init__"], false]
    - ["hl2341014", "hashlib.blake2s.__dict__.__contains__", ["digestsize"], false]

table hashlib_extra2341.blake2s_dict_attrs:
  description: "hashlib.blake2s C-level attributes ARE present in __dict__"
  kind: python_call_eq
  category: slots_content
  id_prefix: hl2341
  columns: [id, function, args, expected]
  rows:
    - ["hl2341015", "hashlib.blake2s.__dict__.__contains__", ["name"], true]
    - ["hl2341016", "hashlib.blake2s.__dict__.__contains__", ["digest_size"], true]
    - ["hl2341017", "hashlib.blake2s.__dict__.__contains__", ["block_size"], true]
    - ["hl2341018", "hashlib.blake2s.__dict__.__contains__", ["__new__"], true]
    - ["hl2341019", "hashlib.blake2s.__dict__.__contains__", ["MAX_DIGEST_SIZE"], true]
    - ["hl2341020", "hashlib.blake2s.__dict__.__contains__", ["MAX_KEY_SIZE"], true]
    - ["hl2341021", "hashlib.blake2s.__dict__.__contains__", ["PERSON_SIZE"], true]
    - ["hl2341022", "hashlib.blake2s.__dict__.__contains__", ["SALT_SIZE"], true]
