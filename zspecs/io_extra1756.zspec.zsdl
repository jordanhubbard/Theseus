spec: io_extra1756
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 564 (_extra1756): arithmetic operator protocol dict-presence checks."
    - "io.RawIOBase: abstract base class for raw binary I/O — not a numeric type; no arithmetic operators in __dict__; all eight dunders absent."
    - "io.BufferedIOBase: abstract base class for buffered binary I/O — not a numeric type; no arithmetic operators in __dict__; all eight dunders absent."
    - "io.TextIOBase: abstract base class for text I/O — not a numeric type; no arithmetic operators in __dict__; all eight dunders absent."
    - "io.IOBase: root abstract base class for all I/O streams — not a numeric type; no arithmetic operators in __dict__; all eight dunders absent."
    - "io.BytesIO: concrete in-memory binary stream — not a numeric type; no arithmetic operators in __dict__; all eight dunders absent."
    - "io.StringIO: concrete in-memory text stream — not a numeric type; no arithmetic operators in __dict__; all eight dunders absent."
    - "io.FileIO: concrete raw binary file stream — not a numeric type; no arithmetic operators in __dict__; all eight dunders absent."
    - "No io type is numeric; the io module provides I/O stream abstractions only."
    - "Complementary checks: io.DEFAULT_BUFFER_SIZE is a positive integer; SEEK_SET/SEEK_CUR/SEEK_END are plain ints."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operator protocol dict-presence checks for io ABC types
#
# Wave 564 theme: which io types define __add__, __sub__, __mul__,
# __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__.
#
# io.RawIOBase: abstract base for raw binary I/O — not numeric.
# io.BufferedIOBase: abstract base for buffered binary I/O — not numeric.
# io.TextIOBase: abstract base for text I/O — not numeric.
# io.IOBase: root abstract base for all streams — not numeric.
# All eight arithmetic dunders are absent from each type's __dict__.
# ---------------------------------------------------------------------------

table io_extra1756.arithmetic_operators_abc:
  description: "io abstract base class types arithmetic operator dict-presence checks — all False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1756

  columns: [id, function, args, expected]
  rows:
    - ["io1756001", "io.RawIOBase.__dict__.__contains__", ["__add__"], false]
    - ["io1756002", "io.RawIOBase.__dict__.__contains__", ["__sub__"], false]
    - ["io1756003", "io.RawIOBase.__dict__.__contains__", ["__mul__"], false]
    - ["io1756004", "io.RawIOBase.__dict__.__contains__", ["__truediv__"], false]
    - ["io1756005", "io.RawIOBase.__dict__.__contains__", ["__neg__"], false]
    - ["io1756006", "io.BufferedIOBase.__dict__.__contains__", ["__add__"], false]
    - ["io1756007", "io.BufferedIOBase.__dict__.__contains__", ["__sub__"], false]
    - ["io1756008", "io.BufferedIOBase.__dict__.__contains__", ["__mul__"], false]
    - ["io1756009", "io.BufferedIOBase.__dict__.__contains__", ["__floordiv__"], false]
    - ["io1756010", "io.BufferedIOBase.__dict__.__contains__", ["__pow__"], false]
    - ["io1756011", "io.TextIOBase.__dict__.__contains__", ["__add__"], false]
    - ["io1756012", "io.TextIOBase.__dict__.__contains__", ["__neg__"], false]
    - ["io1756013", "io.TextIOBase.__dict__.__contains__", ["__pos__"], false]
    - ["io1756014", "io.IOBase.__dict__.__contains__", ["__add__"], false]
    - ["io1756015", "io.IOBase.__dict__.__contains__", ["__sub__"], false]
    - ["io1756016", "io.IOBase.__dict__.__contains__", ["__pow__"], false]

# ---------------------------------------------------------------------------
# Table 2: arithmetic operator protocol dict-presence checks for io concrete types
#
# io.BytesIO: in-memory binary stream — not numeric, no arithmetic operators.
# io.StringIO: in-memory text stream — not numeric, no arithmetic operators.
# io.FileIO: raw binary file stream — not numeric, no arithmetic operators.
# Complementary checks confirm io.DEFAULT_BUFFER_SIZE is a positive int and
# SEEK_SET/SEEK_CUR/SEEK_END are int objects.
# ---------------------------------------------------------------------------

table io_extra1756.arithmetic_operators_concrete:
  description: "io concrete types arithmetic operator dict-presence checks plus SEEK constant type checks — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1756

  columns: [id, function, args, expected]
  rows:
    - ["io1756017", "io.BytesIO.__dict__.__contains__", ["__add__"], false]
    - ["io1756018", "io.BytesIO.__dict__.__contains__", ["__sub__"], false]
    - ["io1756019", "io.BytesIO.__dict__.__contains__", ["__mul__"], false]
    - ["io1756020", "io.BytesIO.__dict__.__contains__", ["__neg__"], false]
    - ["io1756021", "io.StringIO.__dict__.__contains__", ["__add__"], false]
    - ["io1756022", "io.StringIO.__dict__.__contains__", ["__truediv__"], false]
    - ["io1756023", "io.StringIO.__dict__.__contains__", ["__pos__"], false]
    - ["io1756024", "io.FileIO.__dict__.__contains__", ["__add__"], false]
    - ["io1756025", "io.FileIO.__dict__.__contains__", ["__floordiv__"], false]
    - ["io1756026", "io.SEEK_SET.__class__.__name__.__eq__", ["int"], true]
    - ["io1756027", "io.SEEK_CUR.__class__.__name__.__eq__", ["int"], true]
    - ["io1756028", "io.SEEK_END.__class__.__name__.__eq__", ["int"], true]
