spec: itertools_extra220
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools error-raising behavior and class hierarchy checks."
    - "itertools.chain.__bases__[0].__name__ == 'object' — chain is a C-level class with object as its only base. Verified with Python 3.14.3."
    - "itertools.cycle.__bases__[0].__name__ == 'object' — cycle is a C-level class with object as its only base. Verified with Python 3.14.3."
    - "itertools.islice(range(10), -1) raises ValueError — stop argument must be None or a non-negative integer. Verified with Python 3.14.3."
    - "itertools.islice(range(10), 0, -1) raises ValueError — stop argument must be None or a non-negative integer. Verified with Python 3.14.3."
    - "itertools.combinations('ABC', 4) returns empty iterator (no error) — r > len(iterable) yields no combinations. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement('A', 0) yields one empty tuple — r=0 always gives exactly one empty combination. Verified with Python 3.14.3."
    - "itertools.product().__class__.__name__ == 'product'. Verified with Python 3.14.3."
    - "itertools.accumulate.__name__ == 'accumulate'; __module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.starmap.__name__ == 'starmap'; __module__ == 'itertools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools class hierarchy — chain and cycle base classes
#
# Both chain and cycle are C-level classes in itertoolsmodule.c.
# Verified with Python 3.14.3:
#   itertools.chain.__bases__[0].__name__ == 'object'
#   itertools.cycle.__bases__[0].__name__ == 'object'
# ---------------------------------------------------------------------------

table itertools_extra220.class_hierarchy:
  description: "itertools.chain and cycle base class checks; new to extra220"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra220bases

  columns: [id, function, args, expected, description]
  rows:
    - [chain_base_name_eq,
       chain.__bases__.__getitem__(0).__name__.__eq__,
       ["object"],
       true,
       "itertools.chain.__bases__[0].__name__.__eq__('object') == True — chain is a C-level iterator class defined in itertoolsmodule.c; it inherits directly from object; str.__eq__('object') returns True; new to extra220"]
    - [cycle_base_name_eq,
       cycle.__bases__.__getitem__(0).__name__.__eq__,
       ["object"],
       true,
       "itertools.cycle.__bases__[0].__name__.__eq__('object') == True — cycle is a C-level iterator class defined in itertoolsmodule.c; it inherits directly from object; str.__eq__('object') returns True; new to extra220"]

# ---------------------------------------------------------------------------
# Table 2: itertools.islice — ValueError on negative stop
#
# islice(iterable, stop) requires stop to be None or a non-negative integer.
# Verified with Python 3.14.3:
#   islice(range(10), -1) -> ValueError: Stop argument for islice() must be
#     None or an integer: 0 <= x <= sys.maxsize.
#   islice(range(10), 0, -1) -> same ValueError
# ---------------------------------------------------------------------------

table itertools_extra220.islice_negative_stop:
  description: "islice with negative stop raises ValueError; new to extra220"
  kind: python_call_raises
  category: errors
  id_prefix: itertoolsextra220islice

  columns: [id, function, args, expected, description]
  rows:
    - [islice_neg_stop_raises_ValueError,
       islice,
       "[range(10), -1]",
       ValueError,
       "itertools.islice(range(10), -1) raises ValueError — the stop argument must be None or an integer >= 0; -1 violates this constraint; Python raises ValueError: Stop argument for islice() must be None or an integer: 0 <= x <= sys.maxsize; new to extra220"]
    - [islice_neg_stop_with_start_raises_ValueError,
       islice,
       "[range(10), 0, -1]",
       ValueError,
       "itertools.islice(range(10), 0, -1) raises ValueError — the stop argument must be None or an integer >= 0 even when start is provided; -1 violates this constraint; Python raises ValueError: Stop argument for islice() must be None or an integer: 0 <= x <= sys.maxsize; new to extra220"]

# ---------------------------------------------------------------------------
# Table 3: itertools.combinations_with_replacement edge case
#
# combinations_with_replacement('A', 0) yields exactly one empty tuple.
# r=0 always produces one empty combination regardless of input.
# Verified with Python 3.14.3:
#   list(combinations_with_replacement('A', 0)) == [()]  (length 1)
# ---------------------------------------------------------------------------

table itertools_extra220.combinations_edge_cases:
  description: "itertools.combinations_with_replacement r=0 yields one empty tuple; new to extra220"
  kind: python_call_eq
  category: behavior
  id_prefix: itertoolsextra220cwr

  columns: [id, function, args, expected, description]
  rows:
    - [cwr_r0_len_eq,
       combinations_with_replacement.__call__,
       ["A", 0],
       1,
       "len(list(itertools.combinations_with_replacement('A', 0))) — when r=0, the only combination is the empty tuple; __call__('A', 0) returns an iterator; the iterator has exactly 1 element (the empty tuple ()); new to extra220"]

# ---------------------------------------------------------------------------
# Table 4: itertools.product, accumulate, starmap identity checks
#
# Verified with Python 3.14.3:
#   product().__class__.__name__ == 'product'
#   accumulate.__name__ == 'accumulate'; __module__ == 'itertools'
#   starmap.__name__ == 'starmap'; __module__ == 'itertools'
# ---------------------------------------------------------------------------

table itertools_extra220.identity_checks:
  description: "itertools product, accumulate, starmap identity checks; new to extra220"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra220identity

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_name_eq,
       accumulate.__name__.__eq__,
       ["accumulate"],
       true,
       "itertools.accumulate.__name__.__eq__('accumulate') == True — accumulate is a C-level class in itertoolsmodule.c; its __name__ is 'accumulate'; str.__eq__('accumulate') returns True; new to extra220"]
    - [accumulate_module_eq,
       accumulate.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.accumulate.__module__.__eq__('itertools') == True — accumulate belongs to the itertools module; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra220"]
    - [starmap_name_eq,
       starmap.__name__.__eq__,
       ["starmap"],
       true,
       "itertools.starmap.__name__.__eq__('starmap') == True — starmap is a C-level class in itertoolsmodule.c; its __name__ is 'starmap'; str.__eq__('starmap') returns True; new to extra220"]
    - [starmap_module_eq,
       starmap.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.starmap.__module__.__eq__('itertools') == True — starmap belongs to the itertools module; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra220"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra220
# ---------------------------------------------------------------------------

invariant itertools_extra220.islice_neg_stop_ValueError:
  description: "itertools.islice(range(10), -1) raises ValueError — stop must be >= 0; new to extra220"
  kind: python_call_raises
  category: errors
  function: islice
  args: "[range(10), -1]"
  expected: ValueError

invariant itertools_extra220.chain_base_name:
  description: "itertools.chain.__bases__[0].__name__.__eq__('object') == True; new to extra220"
  kind: python_call_eq
  function: chain.__bases__.__getitem__(0).__name__.__eq__
  args: ["object"]
  expected: true

invariant itertools_extra220.cycle_base_name:
  description: "itertools.cycle.__bases__[0].__name__.__eq__('object') == True; new to extra220"
  kind: python_call_eq
  function: cycle.__bases__.__getitem__(0).__name__.__eq__
  args: ["object"]
  expected: true

invariant itertools_extra220.accumulate_name:
  description: "itertools.accumulate.__name__.__eq__('accumulate') == True; new to extra220"
  kind: python_call_eq
  function: accumulate.__name__.__eq__
  args: ["accumulate"]
  expected: true

invariant itertools_extra220.accumulate_module:
  description: "itertools.accumulate.__module__.__eq__('itertools') == True; new to extra220"
  kind: python_call_eq
  function: accumulate.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra220.starmap_name:
  description: "itertools.starmap.__name__.__eq__('starmap') == True; new to extra220"
  kind: python_call_eq
  function: starmap.__name__.__eq__
  args: ["starmap"]
  expected: true

invariant itertools_extra220.starmap_module:
  description: "itertools.starmap.__module__.__eq__('itertools') == True; new to extra220"
  kind: python_call_eq
  function: starmap.__module__.__eq__
  args: ["itertools"]
  expected: true
