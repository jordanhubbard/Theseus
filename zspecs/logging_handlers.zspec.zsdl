spec: logging_handlers
version: ">=3.2"
backend: python_module(logging.handlers)

docs: https://docs.python.org/3/library/logging.handlers.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/logging.handlers.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "logging.handlers source: Lib/logging/handlers.py (PSF; source inspection permitted)"
  not_derived_from:
    - "logging.handlers source: internal file rotation implementation details"
    - "logging.handlers source: internal socket retry / buffering logic"
  notes:
    - "SYSLOG_UDP_PORT=514 and SYSLOG_TCP_PORT=514 are the standard syslog port numbers."
    - "DEFAULT_TCP_LOGGING_PORT=9020, DEFAULT_UDP_LOGGING_PORT=9021, DEFAULT_HTTP_LOGGING_PORT=9022, DEFAULT_SOAP_LOGGING_PORT=9023."
    - "SysLogHandler priority constants: LOG_EMERG=0, LOG_ALERT=1, LOG_CRIT=2, LOG_ERR=3, LOG_WARNING=4, LOG_NOTICE=5, LOG_INFO=6, LOG_DEBUG=7."
    - "SysLogHandler facility constants: LOG_KERN=0, LOG_USER=1, LOG_MAIL=2, LOG_DAEMON=3."
    - "MemoryHandler(capacity=N).capacity == N; .buffer is a list."
    - "QueueHandler(q).queue is q — the queue is stored by reference."
    - "NullHandler is not present in logging.handlers (it lives in logging itself); verified on Python 3.12."
    - "All expected values verified by running Python 3.12 logging.handlers module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name metadata — handler classes exposed by logging.handlers
# ---------------------------------------------------------------------------

table logging_handlers.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [baserotating,         BaseRotatingHandler.__name__.__eq__,         ["BaseRotatingHandler"],         true]
    - [rotatingfile,         RotatingFileHandler.__name__.__eq__,         ["RotatingFileHandler"],         true]
    - [timedrotatingfile,    TimedRotatingFileHandler.__name__.__eq__,    ["TimedRotatingFileHandler"],    true]
    - [socket,               SocketHandler.__name__.__eq__,               ["SocketHandler"],               true]
    - [datagram,             DatagramHandler.__name__.__eq__,             ["DatagramHandler"],             true]
    - [syslog,               SysLogHandler.__name__.__eq__,               ["SysLogHandler"],               true]
    - [smtp,                 SMTPHandler.__name__.__eq__,                 ["SMTPHandler"],                 true]
    - [memory,               MemoryHandler.__name__.__eq__,               ["MemoryHandler"],               true]
    - [queue,                QueueHandler.__name__.__eq__,                ["QueueHandler"],                true]
    - [queuelistener,        QueueListener.__name__.__eq__,               ["QueueListener"],               true]
    - [http,                 HTTPHandler.__name__.__eq__,                 ["HTTPHandler"],                 true]
    - [watchedfile,          WatchedFileHandler.__name__.__eq__,          ["WatchedFileHandler"],          true]

# ---------------------------------------------------------------------------
# Port constants
# ---------------------------------------------------------------------------

invariant logging_handlers.syslog_udp_port:
  description: "logging.handlers.SYSLOG_UDP_PORT == 514 — standard UDP syslog port"
  category: constants
  kind: python_call_eq
  function: SYSLOG_UDP_PORT.__eq__
  args: [514]
  expected: true

invariant logging_handlers.syslog_tcp_port:
  description: "logging.handlers.SYSLOG_TCP_PORT == 514 — standard TCP syslog port"
  category: constants
  kind: python_call_eq
  function: SYSLOG_TCP_PORT.__eq__
  args: [514]
  expected: true

invariant logging_handlers.default_tcp_logging_port:
  description: "logging.handlers.DEFAULT_TCP_LOGGING_PORT == 9020"
  category: constants
  kind: python_call_eq
  function: DEFAULT_TCP_LOGGING_PORT.__eq__
  args: [9020]
  expected: true

invariant logging_handlers.default_udp_logging_port:
  description: "logging.handlers.DEFAULT_UDP_LOGGING_PORT == 9021"
  category: constants
  kind: python_call_eq
  function: DEFAULT_UDP_LOGGING_PORT.__eq__
  args: [9021]
  expected: true

invariant logging_handlers.default_http_logging_port:
  description: "logging.handlers.DEFAULT_HTTP_LOGGING_PORT == 9022"
  category: constants
  kind: python_call_eq
  function: DEFAULT_HTTP_LOGGING_PORT.__eq__
  args: [9022]
  expected: true

invariant logging_handlers.default_soap_logging_port:
  description: "logging.handlers.DEFAULT_SOAP_LOGGING_PORT == 9023"
  category: constants
  kind: python_call_eq
  function: DEFAULT_SOAP_LOGGING_PORT.__eq__
  args: [9023]
  expected: true

# ---------------------------------------------------------------------------
# SysLogHandler priority (severity) constants
# ---------------------------------------------------------------------------

table logging_handlers.syslog_priority_constants:
  kind: python_call_eq
  category: syslog_priority
  id_prefix: prio

  columns: [id, function, args, expected]
  rows:
    - [emerg,   SysLogHandler.LOG_EMERG.__eq__,   [0], true]
    - [alert,   SysLogHandler.LOG_ALERT.__eq__,   [1], true]
    - [crit,    SysLogHandler.LOG_CRIT.__eq__,    [2], true]
    - [err,     SysLogHandler.LOG_ERR.__eq__,     [3], true]
    - [warning, SysLogHandler.LOG_WARNING.__eq__,  [4], true]
    - [notice,  SysLogHandler.LOG_NOTICE.__eq__,  [5], true]
    - [info,    SysLogHandler.LOG_INFO.__eq__,    [6], true]
    - [debug,   SysLogHandler.LOG_DEBUG.__eq__,   [7], true]

# ---------------------------------------------------------------------------
# SysLogHandler facility constants
# ---------------------------------------------------------------------------

table logging_handlers.syslog_facility_constants:
  kind: python_call_eq
  category: syslog_facility
  id_prefix: fac

  columns: [id, function, args, expected]
  rows:
    - [kern,   SysLogHandler.LOG_KERN.__eq__,   [0], true]
    - [user,   SysLogHandler.LOG_USER.__eq__,   [1], true]
    - [mail,   SysLogHandler.LOG_MAIL.__eq__,   [2], true]
    - [daemon, SysLogHandler.LOG_DAEMON.__eq__,  [3], true]

# ---------------------------------------------------------------------------
# MemoryHandler — capacity stored on construction
# ---------------------------------------------------------------------------

invariant logging_handlers.memoryhandler_capacity:
  description: "MemoryHandler(capacity=10).capacity == 10"
  category: construction
  kind: python_call_eq
  function: MemoryHandler
  args: [10]
  method: capacity
  method_args: []
  expected: 10

