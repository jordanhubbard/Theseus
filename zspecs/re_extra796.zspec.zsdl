spec: re_extra796
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - re module CPython source
    - Python standard library documentation
  not_derived_from:
    - any third-party regex libraries
  notes:
    - Covers re.Pattern, re.Match, re.error, and re.RegexFlag class identity attributes
    - Checks __qualname__, __module__, and __doc__.__class__.__name__ for each class
  created_at: "2026-04-12"

table re_extra796.name:
  description: Verify class identity attributes for re module public classes
  kind: python_call_eq
  category: stdlib_identity
  id_prefix: re796xx
  columns: [id, function, args, expected]
  rows:
    - [re796xx001, re.Pattern.__qualname__.__eq__, ["Pattern"], true]
    - [re796xx002, re.Pattern.__module__.__eq__, ["re"], true]
    - [re796xx003, re.Pattern.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re796xx004, re.Match.__qualname__.__eq__, ["Match"], true]
    - [re796xx005, re.Match.__module__.__eq__, ["re"], true]
    - [re796xx006, re.Match.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re796xx007, re.error.__qualname__.__eq__, ["error"], true]
    - [re796xx008, re.error.__module__.__eq__, ["re"], true]
    - [re796xx009, re.error.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re796xx010, re.RegexFlag.__qualname__.__eq__, ["RegexFlag"], true]
    - [re796xx011, re.RegexFlag.__module__.__eq__, ["re"], true]
    - [re796xx012, re.RegexFlag.__doc__.__class__.__name__.__eq__, ["str"], true]
