spec: hashlib_extra1351
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
  notes:
    - "Wave 537 (_extra1351): focuses on __slots__ and __weakref__ attribute checks at the class __dict__ level."
    - "hashlib.new('md5').__class__ is _hashlib.HASH — a C extension type; C types do not expose __slots__ or __weakref__ descriptors in their __dict__."
    - "hashlib.new('md5').__class__.__dict__.__contains__('__slots__') == False — C extension types use tp_members, not Python __slots__."
    - "hashlib.new('md5').__class__.__dict__.__contains__('__weakref__') == False — C extension types manage weakref support at the C level."
    - "hashlib.new('md5').__class__.__dict__.__contains__('__dict__') == False — HASH instances have no instance __dict__; all attributes are C-level."
    - "hashlib.algorithms_guaranteed.__class__ is set — a C builtin type with no __slots__, __weakref__, or __dict__ descriptors in its __dict__."
    - "set.__dict__.__contains__('__slots__') == False — set is a C builtin type."
    - "set.__dict__.__contains__('__weakref__') == False — set is a C builtin type with no weakref descriptor."
    - "set.__dict__.__contains__('__dict__') == False — set instances have no instance __dict__."
    - "HASH.__dict__ does contain method descriptors: digest, update, hexdigest, copy, name, digest_size, block_size."
    - "set.__dict__ does contain method descriptors: add, remove, discard."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table hashlib_extra1351.hash_class_slot_weakref_dict_checks:
  description: "hashlib HASH C extension class __dict__ containment checks for __slots__, __weakref__, and __dict__ descriptors; HASH is a C type with no Python-level slot machinery"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: hl1351hc
  columns: [id, function, args, expected]
  rows:
    - [hl1351hc001, hashlib.new("md5").__class__.__dict__.__contains__, ["__slots__"],    false]
    - [hl1351hc002, hashlib.new("md5").__class__.__dict__.__contains__, ["__weakref__"],  false]
    - [hl1351hc003, hashlib.new("md5").__class__.__dict__.__contains__, ["__dict__"],     false]
    - [hl1351hc004, hashlib.new("md5").__class__.__dict__.__contains__, ["digest"],       true]
    - [hl1351hc005, hashlib.new("md5").__class__.__dict__.__contains__, ["update"],       true]
    - [hl1351hc006, hashlib.new("md5").__class__.__dict__.__contains__, ["hexdigest"],    true]

table hashlib_extra1351.hash_class_method_presence_checks:
  description: "hashlib HASH class __dict__ containment checks for core hash method descriptors; verifies the C extension exposes expected attributes"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: hl1351hm
  columns: [id, function, args, expected]
  rows:
    - [hl1351hm001, hashlib.new("sha256").__class__.__dict__.__contains__, ["copy"],         true]
    - [hl1351hm002, hashlib.new("sha256").__class__.__dict__.__contains__, ["name"],         true]
    - [hl1351hm003, hashlib.new("sha256").__class__.__dict__.__contains__, ["digest_size"],  true]
    - [hl1351hm004, hashlib.new("sha256").__class__.__dict__.__contains__, ["block_size"],   true]
    - [hl1351hm005, hashlib.new("sha256").__class__.__dict__.__contains__, ["__slots__"],    false]
    - [hl1351hm006, hashlib.new("sha256").__class__.__dict__.__contains__, ["__weakref__"],  false]

table hashlib_extra1351.set_class_slot_weakref_dict_checks:
  description: "set class (the type of hashlib.algorithms_guaranteed) __dict__ containment checks; set is a C builtin type with no Python __slots__, __weakref__, or __dict__ descriptors"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: hl1351sc
  columns: [id, function, args, expected]
  rows:
    - [hl1351sc001, hashlib.algorithms_guaranteed.__class__.__dict__.__contains__, ["__slots__"],    false]
    - [hl1351sc002, hashlib.algorithms_guaranteed.__class__.__dict__.__contains__, ["__weakref__"],  false]
    - [hl1351sc003, hashlib.algorithms_guaranteed.__class__.__dict__.__contains__, ["__dict__"],     false]
    - [hl1351sc004, hashlib.algorithms_guaranteed.__class__.__dict__.__contains__, ["add"],          true]
    - [hl1351sc005, hashlib.algorithms_guaranteed.__class__.__dict__.__contains__, ["remove"],       true]
    - [hl1351sc006, hashlib.algorithms_guaranteed.__class__.__dict__.__contains__, ["discard"],      true]
