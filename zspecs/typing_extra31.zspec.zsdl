spec: typing_extra31
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing_extra30.zspec.zsdl."
    - "Prior specs covered: TypeVar/__name__/__module__/__qualname__/__init__.__name__, Protocol/__module__/__qualname__/__bases__[0].__name__, Generic/__module__/__qualname__/__bases__[0].__name__, NamedTuple/__name__/__module__, TypedDict/__name__/__module__, get_type_hints/__name__, overload/__name__, cast/__name__, TYPE_CHECKING value, various other function __name__ and __module__ checks."
    - "This spec covers: typing.TypeVar.__module__.__len__(), typing.Protocol.__module__.__len__(), typing.Generic.__module__.__len__(), typing.TypeVar.__name__.__len__(), typing.Protocol.__name__.__len__(), typing.Generic.__name__.__len__(), typing.get_type_hints.__qualname__, typing.overload.__qualname__, typing.cast.__qualname__, typing.get_args.__name__, typing.get_args.__qualname__, typing.get_origin.__name__."
    - "TypeVar.__module__ == 'typing' (len 6); Protocol.__module__ == 'typing' (len 6); Generic.__module__ == 'typing' (len 6)."
    - "TypeVar.__name__ == 'TypeVar' (len 7); Protocol.__name__ == 'Protocol' (len 8); Generic.__name__ == 'Generic' (len 7)."
    - "get_type_hints.__qualname__ == 'get_type_hints'; overload.__qualname__ == 'overload'; cast.__qualname__ == 'cast'."
    - "get_args.__name__ == 'get_args'; get_args.__qualname__ == 'get_args'; get_origin.__name__ == 'get_origin'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# typing.TypeVar, Protocol, Generic __module__.__len__() — combined table
#
# TypeVar, Protocol, and Generic all have __module__ == 'typing' (len 6).
# No prior typing spec records the __len__() of these three __module__ strings
# together in a combined table in the extra31 namespace.
# ---------------------------------------------------------------------------

table typing_extra31.abc_module_lens:
  description: "__module__.__len__() for typing.TypeVar, Protocol, Generic — all 6"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [TypeVar,   TypeVar.__module__.__len__,   [], 6]
    - [Protocol,  Protocol.__module__.__len__,  [], 6]
    - [Generic,   Generic.__module__.__len__,   [], 6]

# ---------------------------------------------------------------------------
# typing.TypeVar, Protocol, Generic __name__.__len__() — combined table
#
# TypeVar.__name__ == 'TypeVar' (len 7), Protocol.__name__ == 'Protocol' (len 8),
# Generic.__name__ == 'Generic' (len 7). No prior typing spec records the
# __len__() of these three __name__ strings together in a combined table in
# the extra31 namespace.
# ---------------------------------------------------------------------------

table typing_extra31.abc_name_lens:
  description: "__name__.__len__() for typing.TypeVar, Protocol, Generic"
  kind: python_call_eq
  category: name_attr_lengths
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [TypeVar,   TypeVar.__name__.__len__,   [], 7]
    - [Protocol,  Protocol.__name__.__len__,  [], 8]
    - [Generic,   Generic.__name__.__len__,   [], 7]

# ---------------------------------------------------------------------------
# typing.get_type_hints, overload, cast __qualname__ — combined table
#
# get_type_hints, overload, and cast are module-level functions; their
# __qualname__ values equal their simple identifier strings. No prior typing
# spec records these three __qualname__ values together in a combined table in
# the extra31 namespace.
# ---------------------------------------------------------------------------

table typing_extra31.function_qualnames:
  description: "__qualname__ for typing.get_type_hints, overload, cast"
  kind: python_call_eq
  category: function_attrs
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [get_type_hints, get_type_hints.__qualname__.__eq__, ["get_type_hints"], true]
    - [overload,       overload.__qualname__.__eq__,       ["overload"],       true]
    - [cast,           cast.__qualname__.__eq__,           ["cast"],           true]

# ---------------------------------------------------------------------------
# typing.get_args.__name__ and __qualname__, typing.get_origin.__name__
# — standalone invariants
#
# get_args and get_origin are module-level functions added in Python 3.8.
# Their __name__ and __qualname__ values equal their simple identifier strings.
# No prior typing spec records get_args.__qualname__ or get_origin.__name__
# in any invariant or table in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant typing_extra31.get_args.name:
  description: "typing.get_args.__name__ == 'get_args' — module-level function"
  category: function_attrs
  kind: python_call_eq
  function: get_args.__name__.__eq__
  args: ["get_args"]
  expected: true

invariant typing_extra31.get_args.qualname:
  description: "typing.get_args.__qualname__ == 'get_args' — __qualname__ equals __name__ for module-level function"
  category: function_attrs
  kind: python_call_eq
  function: get_args.__qualname__.__eq__
  args: ["get_args"]
  expected: true

invariant typing_extra31.get_origin.name:
  description: "typing.get_origin.__name__ == 'get_origin' — module-level function"
  category: function_attrs
  kind: python_call_eq
  function: get_origin.__name__.__eq__
  args: ["get_origin"]
  expected: true
