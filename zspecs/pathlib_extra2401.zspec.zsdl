spec: pathlib_extra2401
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Theme: __hash__ and __eq__ implementation type classification for pathlib classes."
    - "pathlib.PurePath defines __hash__ and __eq__ as Python functions (not C slot wrappers)."
    - "pathlib.PurePath.__hash__.__class__.__name__ == 'function' — Python-defined hash based on string representation."
    - "pathlib.PurePath.__eq__.__class__.__name__ == 'function' — Python-defined equality comparison."
    - "All pathlib path classes (PurePath, PurePosixPath, Path, PosixPath) share the SAME __hash__ and __eq__ function objects defined on PurePath."
    - "pathlib.PurePath.__hash__.__qualname__ == 'PurePath.__hash__' — confirms origin class."
    - "pathlib.PurePath.__eq__.__qualname__ == 'PurePath.__eq__' — confirms origin class."
    - "PurePosixPath, Path, and PosixPath inherit __hash__ and __eq__ from PurePath without overriding."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __hash__ and __eq__ are Python functions — not C slot wrappers
#
# PurePath defines value-based equality and hash using pure Python functions.
# This distinguishes pathlib from most C-extension types (which show
# wrapper_descriptor) and from unhashable types (which set __hash__ = None).
# ---------------------------------------------------------------------------

table pathlib_extra2401.purepath_hash_eq:
  kind: python_call_eq
  category: hash_eq_type
  id_prefix: pp2401

  columns: [id, function, args, expected]
  rows:
    - ["pp2401001", "pathlib.PurePath.__hash__.__class__.__name__.__eq__",       ["function"], true]
    - ["pp2401002", "pathlib.PurePath.__eq__.__class__.__name__.__eq__",         ["function"], true]
    - ["pp2401003", "pathlib.PurePosixPath.__hash__.__class__.__name__.__eq__",  ["function"], true]
    - ["pp2401004", "pathlib.PurePosixPath.__eq__.__class__.__name__.__eq__",    ["function"], true]
    - ["pp2401005", "pathlib.Path.__hash__.__class__.__name__.__eq__",           ["function"], true]
    - ["pp2401006", "pathlib.Path.__eq__.__class__.__name__.__eq__",             ["function"], true]
    - ["pp2401007", "pathlib.PosixPath.__hash__.__class__.__name__.__eq__",      ["function"], true]
    - ["pp2401008", "pathlib.PosixPath.__eq__.__class__.__name__.__eq__",        ["function"], true]

# ---------------------------------------------------------------------------
# __qualname__ — hash and eq originate from PurePath
#
# All subclasses inherit the exact same function objects defined on PurePath.
# Checking __qualname__ confirms the owning class of the implementation.
# ---------------------------------------------------------------------------

table pathlib_extra2401.hash_qualname:
  kind: python_call_eq
  category: hash_qualname
  id_prefix: pp2401

  columns: [id, function, args, expected]
  rows:
    - ["pp2401009",  "pathlib.PurePath.__hash__.__qualname__.__eq__",       ["PurePath.__hash__"], true]
    - ["pp2401010",  "pathlib.PurePath.__eq__.__qualname__.__eq__",         ["PurePath.__eq__"],   true]
    - ["pp2401011",  "pathlib.PurePosixPath.__hash__.__qualname__.__eq__",  ["PurePath.__hash__"], true]
    - ["pp2401012",  "pathlib.PurePosixPath.__eq__.__qualname__.__eq__",    ["PurePath.__eq__"],   true]
    - ["pp2401013",  "pathlib.Path.__hash__.__qualname__.__eq__",           ["PurePath.__hash__"], true]
    - ["pp2401014",  "pathlib.Path.__eq__.__qualname__.__eq__",             ["PurePath.__eq__"],   true]
    - ["pp2401015",  "pathlib.PosixPath.__hash__.__qualname__.__eq__",      ["PurePath.__hash__"], true]
    - ["pp2401016",  "pathlib.PosixPath.__eq__.__qualname__.__eq__",        ["PurePath.__eq__"],   true]

# ---------------------------------------------------------------------------
# __hash__ absent from subclass __dict__ — inheritance confirmed
#
# Neither PurePosixPath, Path, nor PosixPath defines __hash__ or __eq__
# in their own __dict__; the definitions live solely on PurePath.
# ---------------------------------------------------------------------------

table pathlib_extra2401.hash_not_in_subclass_dict:
  kind: python_call_eq
  category: hash_dict_membership
  id_prefix: pp2401

  columns: [id, function, args, expected]
  rows:
    - ["pp2401017", "pathlib.PurePosixPath.__dict__.__contains__", ["__hash__"], false]
    - ["pp2401018", "pathlib.PurePosixPath.__dict__.__contains__", ["__eq__"],   false]
    - ["pp2401019", "pathlib.Path.__dict__.__contains__",          ["__hash__"], false]
    - ["pp2401020", "pathlib.Path.__dict__.__contains__",          ["__eq__"],   false]
    - ["pp2401021", "pathlib.PosixPath.__dict__.__contains__",     ["__hash__"], false]
    - ["pp2401022", "pathlib.PosixPath.__dict__.__contains__",     ["__eq__"],   false]
    - ["pp2401023", "pathlib.PurePath.__dict__.__contains__",      ["__hash__"], true]
    - ["pp2401024", "pathlib.PurePath.__dict__.__contains__",      ["__eq__"],   true]
