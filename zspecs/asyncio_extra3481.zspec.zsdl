spec: as3481
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 679 (as3481): __enter__, __exit__, __call__ dict-presence checks for asyncio types."
    - "Theme: __enter__/__exit__/__call__ dict-presence (context manager and callable protocols)."
    - "All values False — asyncio types use async context managers (__aenter__/__aexit__), NOT the sync context manager protocol (__enter__/__exit__). None define __call__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: asyncio.Task, asyncio.Future, asyncio.Event, asyncio.Lock, asyncio.Semaphore, asyncio.BoundedSemaphore, asyncio.Condition, asyncio.Queue, asyncio.PriorityQueue, asyncio.LifoQueue."
    - "Key finding (__enter__): all 10 asyncio classes return false for __enter__. asyncio synchronization primitives (Lock, Semaphore, BoundedSemaphore, Condition) implement the async context manager protocol via __aenter__/__aexit__ — 'async with lock:' is valid but 'with lock:' is not. __enter__ is absent from their own __dict__. asyncio.Task/Future: coroutine result handles with no __enter__ in their own __dict__. asyncio.Queue/PriorityQueue/LifoQueue: item stores with no __enter__ defined at the class level."
    - "Key finding (__exit__): all 10 asyncio classes return false for __exit__. The async context manager types (Lock, Semaphore, BoundedSemaphore, Condition) define __aenter__/__aexit__ for use with 'async with', not the synchronous __exit__ dunder. __exit__ is absent from all 10 classes' own __dict__."
    - "Key finding (__call__): all 10 asyncio classes return false for __call__. Asyncio types are not callable as function-like objects; they expose their API via coroutine methods. None of the 10 types define __call__ in their own __dict__."
    - "Critical distinction: asyncio.Lock.__enter__ = false and asyncio.Lock.__exit__ = false. asyncio.Lock uses async context manager protocol (__aenter__/__aexit__), making 'async with lock:' valid. The synchronous __enter__/__exit__ protocol is NOT defined in asyncio.Lock.__dict__. Similarly for asyncio.Semaphore, asyncio.BoundedSemaphore, and asyncio.Condition."
    - "Cross-wave summary for asyncio subjects:"
    - "  Wave 656 (as3136): __call__/__len__/__getitem__ — all false for all 14."
    - "  Wave 657 (as3151): __setitem__/__delitem__/__contains__ — all false for all 14."
    - "  Wave 658 (as3166): __add__/__sub__/__mul__ — all false for all 14."
    - "  Wave 659 (as3181): __truediv__/__floordiv__/__mod__ — all false for all 14."
    - "  Wave 660 (as3196): __pow__/__lshift__/__rshift__ — all false for all 10."
    - "  Wave 661 (as3211): __and__/__or__/__xor__ — all false for all 10."
    - "  Wave 662 (as3226): __radd__/__rsub__/__rmul__ — all false for all 10."
    - "  Wave 663 (as3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 10."
    - "  Wave 664 (as3256): __rpow__/__rlshift__/__rrshift__ — all false for all 10."
    - "  Wave 665 (as3271): __rand__/__ror__/__rxor__ — all false for all 10."
    - "  Wave 666 (as3286): __iadd__/__isub__/__imul__ — all false for all 10."
    - "  Wave 667 (as3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 10."
    - "  Wave 668 (as3316): __ipow__/__ilshift__/__irshift__ — all false for all 10."
    - "  Wave 669 (as3331): __iand__/__ior__/__ixor__ — all false for all 10."
    - "  Wave 670 (as3346): __neg__/__pos__/__abs__ — all false for all 10."
    - "  Wave 671 (as3361): __invert__/__floor__/__ceil__ — all false for all 10."
    - "  Wave 672 (as3376): __trunc__/__round__/__index__ — all false for all 10."
    - "  Wave 673 (as3391): __int__/__float__/__complex__ — all false for all 10."
    - "  Wave 674 (as3406): __bool__/__str__/__repr__ — all false for all 10."
    - "  Wave 675 (as3421): __hash__/__eq__/__lt__ — all false for all 10."
    - "  Wave 676 (as3436): __le__/__gt__/__ge__ — all false for all 10."
    - "  Wave 677 (as3451): __getitem__/__setitem__/__delitem__ — all false for all 10."
    - "  Wave 678 (as3466): __iter__/__next__/__len__ — all false for all 10."
    - "  Wave 679 (as3481): __enter__/__exit__/__call__ — all false for all 10."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __enter__ dict-presence — operator.contains(Cls.__dict__, '__enter__')
#
# All 10 asyncio classes return false for __enter__.
# asyncio synchronization primitives implement the async context manager
#   protocol via __aenter__/__aexit__ — NOT the synchronous __enter__/__exit__.
# asyncio.Lock: 'async with lock:' is valid (uses __aenter__/__aexit__) but
#   'with lock:' raises AttributeError at runtime. __enter__ is absent from
#   asyncio.Lock.__dict__.
# asyncio.Semaphore/BoundedSemaphore/Condition: same pattern — async context
#   manager protocol only; no __enter__ in their own __dict__.
# asyncio.Task/Future: coroutine result handles; no __enter__ in their own __dict__.
# asyncio.Event: boolean-flag synchronization; no __enter__ in its own __dict__.
# asyncio.Queue/PriorityQueue/LifoQueue: item stores; no __enter__ defined at
#   the class level in their own __dict__.
# ---------------------------------------------------------------------------

table as3481.enter:
  description: "asyncio types __enter__ dict-presence checks; wave 679"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
