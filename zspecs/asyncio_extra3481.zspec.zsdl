    - ["as3481002", operator.contains, [asyncio.Future.__dict__,           "__enter__"], false]
    - ["as3481003", operator.contains, [asyncio.Event.__dict__,            "__enter__"], false]
    - ["as3481004", operator.contains, [asyncio.Lock.__dict__,             "__enter__"], false]
    - ["as3481005", operator.contains, [asyncio.Semaphore.__dict__,        "__enter__"], false]
    - ["as3481006", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__enter__"], false]
    - ["as3481007", operator.contains, [asyncio.Condition.__dict__,        "__enter__"], false]
    - ["as3481008", operator.contains, [asyncio.Queue.__dict__,            "__enter__"], false]
    - ["as3481009", operator.contains, [asyncio.PriorityQueue.__dict__,    "__enter__"], false]
    - ["as3481010", operator.contains, [asyncio.LifoQueue.__dict__,        "__enter__"], false]

# ---------------------------------------------------------------------------
# __exit__ dict-presence — operator.contains(Cls.__dict__, '__exit__')
#
# All 10 asyncio classes return false for __exit__.
# asyncio synchronization primitives define __aenter__/__aexit__ for use with
#   'async with' — the synchronous __exit__ dunder is absent from all class __dict__.
# asyncio.Lock: __exit__ is absent from asyncio.Lock.__dict__. The synchronous
#   context manager exit protocol is not supported by asyncio.Lock.
# asyncio.Semaphore/BoundedSemaphore/Condition: no __exit__ in their own __dict__.
#   These types are designed for use with 'async with', not 'with'.
# asyncio.Task/Future/Event: no __exit__ defined in their own __dict__.
# asyncio.Queue/PriorityQueue/LifoQueue: no __exit__ in their own __dict__.
# ---------------------------------------------------------------------------

