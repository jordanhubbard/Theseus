spec: threading_extra2
version: ">=3.2"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "threading.zspec.zsdl — covers class_names table (Thread/Lock/RLock/Condition/Semaphore/BoundedSemaphore/Event/Timer/Barrier), function_names table (current_thread/main_thread/active_count/enumerate), TIMEOUT_MAX, active_count_ge_1, Lock behavior, Event, Semaphore._value, current_thread.is_alive"
    - "threading_extra.zspec.zsdl — covers module checks for synchronization primitives, local.__name__/__module__, current_thread class name is str, get_ident returns int, TIMEOUT_MAX is float, stack_size returns int"
    - "threading_timer.zspec.zsdl — covers Timer base class and module, ThreadError module and base, main_thread name and class, current_thread name, enumerate, active_count is int"
    - "threading_sync.zspec.zsdl — covers Barrier, BoundedSemaphore, RLock, Condition runtime behavior"
  notes:
    - "This spec provides a self-contained reference for the __name__ attributes of the threading module's primary synchronization and thread-management classes and functions."
    - "threading.Thread.__name__ == 'Thread' — confirmed on CPython 3.12."
    - "threading.Lock.__name__ == 'lock' (lowercase) — Lock is a C-level type; its __name__ is 'lock', not 'Lock'."
    - "threading.RLock.__name__ == 'RLock' — confirmed on CPython 3.12."
    - "threading.Event.__name__ == 'Event' — confirmed on CPython 3.12."
    - "threading.Condition.__name__ == 'Condition' — confirmed on CPython 3.12."
    - "threading.Semaphore.__name__ == 'Semaphore' — confirmed on CPython 3.12."
    - "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' — confirmed on CPython 3.12."
    - "threading.Timer.__name__ == 'Timer' — confirmed on CPython 3.12."
    - "threading.Barrier.__name__ == 'Barrier' — confirmed on CPython 3.12."
    - "threading.current_thread.__name__ == 'current_thread' — confirmed on CPython 3.12."
    - "threading.main_thread.__name__ == 'main_thread' — confirmed on CPython 3.12."
    - "threading.active_count.__name__ == 'active_count' — confirmed on CPython 3.12."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ checks
# ---------------------------------------------------------------------------

table threading_extra2.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Thread,           Thread.__name__.__eq__,           ["Thread"],           true]
    - [Lock,             Lock.__name__.__eq__,              ["lock"],             true]
    - [RLock,            RLock.__name__.__eq__,             ["RLock"],            true]
    - [Event,            Event.__name__.__eq__,             ["Event"],            true]
    - [Condition,        Condition.__name__.__eq__,         ["Condition"],        true]
    - [Semaphore,        Semaphore.__name__.__eq__,         ["Semaphore"],        true]
    - [BoundedSemaphore, BoundedSemaphore.__name__.__eq__,  ["BoundedSemaphore"], true]
    - [Timer,            Timer.__name__.__eq__,             ["Timer"],            true]
    - [Barrier,          Barrier.__name__.__eq__,           ["Barrier"],          true]

# ---------------------------------------------------------------------------
# Function __name__ checks
# ---------------------------------------------------------------------------

table threading_extra2.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [current_thread, current_thread.__name__.__eq__, ["current_thread"], true]
    - [main_thread,    main_thread.__name__.__eq__,    ["main_thread"],    true]
    - [active_count,   active_count.__name__.__eq__,   ["active_count"],   true]
