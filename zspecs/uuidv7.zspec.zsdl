spec: uuidv7
version: ">=1.0.0"
backend: node(uuidv7)

docs: https://github.com/LiosK/uuidv7#readme

provenance:
  derived_from:
    - "uuidv7 README — https://github.com/LiosK/uuidv7#readme"
    - "RFC 9562 — Universally Unique Identifiers (UUID) version 7"
    - "Test vectors verified with uuidv7 via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "uuidv7 source"
  notes:
    - "UUIDv7 (timestamp-prefixed, sortable) generator — RFC 9562."
    - "Install: npm install uuidv7"
    - "v1 ESM only; named exports uuidv7 / uuidv4 / uuidv7obj / uuidv4obj / V7Generator / UUID."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw."
  stderr: "null"
  stickiness: "V7Generator instances maintain monotonic state."
  codes: {}

invariant uuidv7.has_uuidv7:
  description: "uuidv7 generator exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "uuidv7.constructor.name"}
  expected: "Function"

invariant uuidv7.has_uuidv4:
  description: "uuidv4 generator exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "uuidv4.constructor.name"}
  expected: "Function"

invariant uuidv7.has_UUID_class:
  description: "UUID class exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "UUID.constructor.name"}
  expected: "Function"

invariant uuidv7.has_V7Generator:
  description: "V7Generator class exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "V7Generator.constructor.name"}
  expected: "Function"

invariant uuidv7.uuidv7_returns_36_chars:
  description: "uuidv7() output is 36 characters (xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)"
  category: format
  kind: node_chain_eq
  entry: named
  function: uuidv7
  entry_args: []
  chain:
    - {get: length}
  expected: 36

invariant uuidv7.uuidv4_returns_36_chars:
  description: "uuidv4() output is 36 characters"
  category: format
  kind: node_chain_eq
  entry: named
  function: uuidv4
  entry_args: []
  chain:
    - {get: length}
  expected: 36

invariant uuidv7.uuidv7_has_v7_marker:
  description: "uuidv7 places version marker '7' at index 14 (3rd char of 3rd group)"
  category: format
  kind: node_chain_eq
  entry: named
  function: uuidv7
  entry_args: []
  chain:
    - {method: charAt, args: [14]}
  expected: "7"

invariant uuidv7.uuidv4_has_v4_marker:
  description: "uuidv4 places version marker '4' at index 14"
  category: format
  kind: node_chain_eq
  entry: named
  function: uuidv4
  entry_args: []
  chain:
    - {method: charAt, args: [14]}
  expected: "4"

invariant uuidv7.uuidv7_dash_at_8:
  description: "Standard UUID format has '-' at index 8"
  category: format
  kind: node_chain_eq
  entry: named
  function: uuidv7
  entry_args: []
  chain:
    - {method: charAt, args: [8]}
  expected: "-"
