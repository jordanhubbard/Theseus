spec: pipes_extra
version: ">=3.9,<3.13"
backend: python_module(pipes)

docs: https://docs.python.org/3/library/pipes.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pipes.html — Python pipes module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pipes.py"
  notes:
    - "Extends pipes.zspec.zsdl with additional method name, function name, and constant invariants."
    - "The pipes module was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13; this spec applies to >=3.9,<3.13."
    - "pipes.Template.__name__ == 'Template' and pipes.Template.__module__ == 'pipes'."
    - "pipes.Template.open.__name__ == 'open' — the open() method on a Template instance opens the pipeline."
    - "pipes.Template.append.__name__ == 'append' and pipes.Template.prepend.__name__ == 'prepend'."
    - "pipes.quote is a function that shell-quotes a single string; its __name__ == 'quote'."
    - "pipes.STDIN and pipes.STDOUT are both the string '-' — they represent standard input/output in pipeline descriptions."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Template class — name and module
# ---------------------------------------------------------------------------

invariant pipes_extra.Template.name:
  description: "pipes.Template.__name__ == 'Template'"
  category: classnames
  kind: python_call_eq
  function: Template.__name__.__eq__
  args: ["Template"]
  expected: true

invariant pipes_extra.Template.module:
  description: "pipes.Template.__module__ == 'pipes'"
  category: classnames
  kind: python_call_eq
  function: Template.__module__.__eq__
  args: ["pipes"]
  expected: true

# ---------------------------------------------------------------------------
# Template method names
# ---------------------------------------------------------------------------

invariant pipes_extra.Template.open_name:
  description: "pipes.Template.open.__name__ == 'open'"
  category: methods
  kind: python_call_eq
  function: Template.open.__name__.__eq__
  args: ["open"]
  expected: true

invariant pipes_extra.Template.append_name:
  description: "pipes.Template.append.__name__ == 'append'"
  category: methods
  kind: python_call_eq
  function: Template.append.__name__.__eq__
  args: ["append"]
  expected: true

invariant pipes_extra.Template.prepend_name:
  description: "pipes.Template.prepend.__name__ == 'prepend'"
  category: methods
  kind: python_call_eq
  function: Template.prepend.__name__.__eq__
  args: ["prepend"]
  expected: true

invariant pipes_extra.Template.reset_name:
  description: "pipes.Template.reset.__name__ == 'reset'"
  category: methods
  kind: python_call_eq
  function: Template.reset.__name__.__eq__
  args: ["reset"]
  expected: true

invariant pipes_extra.Template.clone_name:
  description: "pipes.Template.clone.__name__ == 'clone'"
  category: methods
  kind: python_call_eq
  function: Template.clone.__name__.__eq__
  args: ["clone"]
  expected: true

# ---------------------------------------------------------------------------
# quote function — name and type
# ---------------------------------------------------------------------------

invariant pipes_extra.quote.name:
  description: "pipes.quote.__name__ == 'quote'"
  category: functions
  kind: python_call_eq
  function: quote.__name__.__eq__
  args: ["quote"]
  expected: true

invariant pipes_extra.quote.is_function:
  description: "pipes.quote.__class__.__name__ == 'function' — quote is a plain function"
  category: functions
  kind: python_call_eq
  function: quote.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# STDIN and STDOUT constants
# ---------------------------------------------------------------------------

invariant pipes_extra.STDIN.value:
  description: "pipes.STDIN == '-' — STDIN sentinel is the string '-'"
  category: constants
  kind: python_call_eq
  function: STDIN.__eq__
  args: ["-"]
  expected: true

invariant pipes_extra.STDOUT.value:
  description: "pipes.STDOUT == '-' — STDOUT sentinel is the string '-'"
  category: constants
  kind: python_call_eq
  function: STDOUT.__eq__
  args: ["-"]
  expected: true

invariant pipes_extra.STDIN.is_str:
  description: "pipes.STDIN.__class__.__name__ == 'str' — STDIN is a string constant"
  category: constants
  kind: python_call_eq
  function: STDIN.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pipes_extra.STDOUT.is_str:
  description: "pipes.STDOUT.__class__.__name__ == 'str' — STDOUT is a string constant"
  category: constants
  kind: python_call_eq
  function: STDOUT.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pipes_extra.STDIN_eq_STDOUT:
  description: "pipes.STDIN == pipes.STDOUT — both are '-', assigned together"
  category: constants
  kind: python_call_eq
  function: STDIN.__eq__
  args: ["-"]
  expected: true
