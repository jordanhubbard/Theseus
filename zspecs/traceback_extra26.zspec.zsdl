spec: traceback_extra26
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
    - "traceback_extra25.zspec.zsdl — covers __mro__.__len__() for TracebackException (2), StackSummary (3), FrameSummary (2); __bases__[0].__name__.__len__() for all three classes; FrameSummary.__init__/__qualname__.__len__()==21; FrameSummary.line.fget/__qualname__.__len__()==17; TracebackException.__init__/__qualname__.__len__()==27."
    - "traceback_extra24.zspec.zsdl — covers module-level function __name__.__len__() for format_exception/format_stack/extract_tb/extract_stack/print_last/print_stack."
    - "traceback_extra23.zspec.zsdl — covers TracebackException method __qualname__.__len__() (from_exception=33, format=25, format_exception_only=40, __init__=27) and StackSummary (extract=20, from_list=22)."
  notes:
    - "This spec extends traceback_extra25.zspec.zsdl."
    - "Prior specs covered: TracebackException/StackSummary/FrameSummary __module__/__name__/__mro__/__bases__[0].__name__, method __qualname__.__len__() for TracebackException/StackSummary/FrameSummary methods, module-level function __name__.__len__()."
    - "This spec covers NEW angles: traceback.__all__.__len__()==20; traceback.__all__.__class__.__name__=='list' (len 4); TracebackException/__dict__.__class__.__name__=='mappingproxy' (len 12) and same for StackSummary/FrameSummary; module-level function __qualname__.__len__() for walk_stack (10)/walk_tb (7)/clear_frames (12)/format_exception (16)/print_exception (15); StackSummary.format.__qualname__.__len__()==19; TracebackException.format.__qualname__.__len__()==25."
    - "traceback.__all__.__len__() == 20 — 20 public names exported. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.__all__.__class__.__name__ == 'list' (len 4). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.TracebackException.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Same for StackSummary and FrameSummary. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.walk_stack.__qualname__ == 'walk_stack' (len 10). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.walk_tb.__qualname__ == 'walk_tb' (len 7). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.clear_frames.__qualname__ == 'clear_frames' (len 12). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.format_exception.__qualname__ == 'format_exception' (len 16). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.print_exception.__qualname__ == 'print_exception' (len 15). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.StackSummary.format.__qualname__ == 'StackSummary.format' (len 19). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "traceback.TracebackException.format.__qualname__ == 'TracebackException.format' (len 25). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# traceback.__all__.__len__() and __all__.__class__.__name__.__len__()
#
# No prior spec checks __all__.__len__() or __all__.__class__.__name__ for
# the traceback module. traceback.__all__ exports 20 public names and is a
# list (class name length 4).
# ---------------------------------------------------------------------------

invariant traceback_extra26.all.len:
  description: "traceback.__all__.__len__() == 20 — 20 public names exported"
  category: module_membership
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 20

invariant traceback_extra26.all.class.name.len:
  description: "traceback.__all__.__class__.__name__.__len__() == 4 — __all__ is a 'list'"
  category: module_membership
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Class __dict__.__class__.__name__.__len__() for traceback classes
#
# No prior spec checks __dict__.__class__.__name__.__len__() for any traceback
# class. TracebackException, StackSummary, and FrameSummary all expose their
# namespace via a mappingproxy (len 12).
# ---------------------------------------------------------------------------

invariant traceback_extra26.TracebackException.dict.class.name.len:
  description: "traceback.TracebackException.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy'"
  category: module_constants
  kind: python_call_eq
  function: TracebackException.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant traceback_extra26.StackSummary.dict.class.name.len:
  description: "traceback.StackSummary.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy'"
  category: module_constants
  kind: python_call_eq
  function: StackSummary.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Module-level function __qualname__.__len__() — walk_stack, walk_tb,
# clear_frames
#
# No prior spec checks __qualname__.__len__() for walk_stack, walk_tb, or
# clear_frames. walk_stack has qualname 'walk_stack' (len 10), walk_tb has
# 'walk_tb' (len 7), clear_frames has 'clear_frames' (len 12).
# ---------------------------------------------------------------------------

invariant traceback_extra26.walk_stack.qualname.len:
  description: "traceback.walk_stack.__qualname__.__len__() == 10 — 'walk_stack' has 10 characters"
  category: string_length
  kind: python_call_eq
  function: walk_stack.__qualname__.__len__
  args: []
  expected: 10

invariant traceback_extra26.walk_tb.qualname.len:
  description: "traceback.walk_tb.__qualname__.__len__() == 7 — 'walk_tb' has 7 characters"
  category: string_length
  kind: python_call_eq
  function: walk_tb.__qualname__.__len__
  args: []
  expected: 7

invariant traceback_extra26.clear_frames.qualname.len:
  description: "traceback.clear_frames.__qualname__.__len__() == 12 — 'clear_frames' has 12 characters"
  category: string_length
  kind: python_call_eq
  function: clear_frames.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Table: traceback.__all__ membership and class __dict__ type name lengths
#
# Groups __all__ membership checks and class __dict__.__class__.__name__.__len__()
# for the three main traceback classes. No prior spec groups these together.
# ---------------------------------------------------------------------------

table traceback_extra26.all_and_dict_class_names:
  description: "traceback.__all__.__len__() (20), __all__.__class__.__name__.__len__() (4), and class __dict__.__class__.__name__.__len__() for TracebackException/StackSummary/FrameSummary (all 12)"
  kind: python_call_eq
  category: module_membership

  columns: [id, function, args, expected, description]
  rows:
    - [all_len,
       __all__.__len__,
       [],
       20,
       "len(traceback.__all__) == 20"]
    - [all_class_name_len,
       __all__.__class__.__name__.__len__,
       [],
       4,
       "len('list') == 4 — __all__.__class__.__name__"]
    - [TE_dict_class_name_len,
       TracebackException.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len('mappingproxy') == 12 — TracebackException.__dict__.__class__.__name__"]
    - [SS_dict_class_name_len,
       StackSummary.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len('mappingproxy') == 12 — StackSummary.__dict__.__class__.__name__"]
    - [FS_dict_class_name_len,
       FrameSummary.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len('mappingproxy') == 12 — FrameSummary.__dict__.__class__.__name__"]

# ---------------------------------------------------------------------------
# Table: module-level function __qualname__.__len__()
#
# Groups qualname lengths for generator/utility functions and format/print
# functions. No prior spec covers __qualname__.__len__() for walk_stack,
# walk_tb, clear_frames, format_exception, or print_exception.
# walk_stack=10, walk_tb=7, clear_frames=12, format_exception=16,
# print_exception=15, StackSummary.format=19, TracebackException.format=25.
# ---------------------------------------------------------------------------

table traceback_extra26.function_qualname_lengths:
  description: "traceback function __qualname__.__len__() — walk_stack (10), walk_tb (7), clear_frames (12), format_exception (16), print_exception (15), StackSummary.format (19), TracebackException.format (25)"
  kind: python_call_eq
  category: string_length

  columns: [id, function, args, expected, description]
  rows:
    - [walk_stack_qualname_len,
       walk_stack.__qualname__.__len__,
       [],
       10,
       "len('walk_stack') == 10"]
    - [walk_tb_qualname_len,
       walk_tb.__qualname__.__len__,
       [],
       7,
       "len('walk_tb') == 7"]
    - [clear_frames_qualname_len,
       clear_frames.__qualname__.__len__,
       [],
       12,
       "len('clear_frames') == 12"]
    - [format_exception_qualname_len,
       format_exception.__qualname__.__len__,
       [],
       16,
       "len('format_exception') == 16"]
    - [print_exception_qualname_len,
       print_exception.__qualname__.__len__,
       [],
       15,
       "len('print_exception') == 15"]
    - [SS_format_qualname_len,
       StackSummary.format.__qualname__.__len__,
       [],
       19,
       "len('StackSummary.format') == 19"]
    - [TE_format_qualname_len,
       TracebackException.format.__qualname__.__len__,
       [],
       25,
       "len('TracebackException.format') == 25"]
