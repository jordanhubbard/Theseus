spec: itertools_extra200
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers __doc__.__class__.__name__ identity for public itertools iterator types: count, cycle, repeat, accumulate, chain, pairwise, batched, groupby."
    - "itertools.count.__doc__.__class__.__name__ == 'str' — count is a C-level type with a string docstring. Verified with Python 3.14.3."
    - "itertools.cycle.__doc__.__class__.__name__ == 'str' — cycle is a C-level type with a string docstring. Verified with Python 3.14.3."
    - "itertools.repeat.__doc__.__class__.__name__ == 'str' — repeat is a C-level type with a string docstring. Verified with Python 3.14.3."
    - "itertools.accumulate.__doc__.__class__.__name__ == 'str' — accumulate is a C-level type with a string docstring. Verified with Python 3.14.3."
    - "itertools.chain.__doc__.__class__.__name__ == 'str' — chain is a C-level type with a string docstring. Verified with Python 3.14.3."
    - "itertools.pairwise.__doc__.__class__.__name__ == 'str' — pairwise is a C-level type with a string docstring; added in Python 3.10. Verified with Python 3.14.3."
    - "itertools.batched.__doc__.__class__.__name__ == 'str' — batched is a C-level type with a string docstring; added in Python 3.12. Verified with Python 3.14.3."
    - "itertools.groupby.__doc__.__class__.__name__ == 'str' — groupby is a C-level type with a string docstring. Verified with Python 3.14.3."
    - "All itertools types are C-level types; their __doc__ is always a non-None string. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __doc__.__class__.__name__ for infinite itertools iterators
#
# count, cycle, repeat: infinite (or unbounded) itertools C-level types.
# All have non-None string docstrings; __class__.__name__ is 'str'.
# ---------------------------------------------------------------------------

table itertools_extra200.doc_class_infinite:
  description: "itertools infinite iterators: count, cycle, repeat __doc__.__class__.__name__=='str'; new to extra200"
  kind: python_call_eq
  category: doc_class_identity
  id_prefix: iterdocs200

  columns: [id, function, args, expected, description]
  rows:
    - [count_doc_class_str,
       count.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.count.__doc__.__class__.__name__.__eq__('str') == True — count is a C-level infinite counter type; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra200"]
    - [cycle_doc_class_str,
       cycle.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.cycle.__doc__.__class__.__name__.__eq__('str') == True — cycle is a C-level infinite cycling type; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra200"]
    - [repeat_doc_class_str,
       repeat.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.repeat.__doc__.__class__.__name__.__eq__('str') == True — repeat is a C-level type yielding a value repeatedly; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra200"]

# ---------------------------------------------------------------------------
# Table 2: __doc__.__class__.__name__ for accumulating and chaining iterators
#
# accumulate, chain: C-level itertools types for aggregation and chaining.
# pairwise: C-level type added in Python 3.10 for overlapping pairs.
# All have non-None string docstrings.
# ---------------------------------------------------------------------------

table itertools_extra200.doc_class_accumulate_chain:
  description: "itertools accumulate/chain/pairwise: __doc__.__class__.__name__=='str'; new to extra200"
  kind: python_call_eq
  category: doc_class_identity
  id_prefix: iterdocs200

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_doc_class_str,
       accumulate.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.accumulate.__doc__.__class__.__name__.__eq__('str') == True — accumulate is a C-level type for running aggregates; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra200"]
    - [chain_doc_class_str,
       chain.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.chain.__doc__.__class__.__name__.__eq__('str') == True — chain is a C-level type for chaining iterables; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra200"]
    - [pairwise_doc_class_str,
       pairwise.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.pairwise.__doc__.__class__.__name__.__eq__('str') == True — pairwise is a C-level type for overlapping consecutive pairs (Python 3.10+); its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra200"]

# ---------------------------------------------------------------------------
# Table 3: __doc__.__class__.__name__ for batched and groupby iterators
#
# batched: C-level type added in Python 3.12 for fixed-size batches.
# groupby: C-level type for grouping consecutive keys.
# Both have non-None string docstrings.
# ---------------------------------------------------------------------------

table itertools_extra200.doc_class_batched_groupby:
  description: "itertools batched and groupby: __doc__.__class__.__name__=='str'; new to extra200"
  kind: python_call_eq
  category: doc_class_identity
  id_prefix: iterdocs200

  columns: [id, function, args, expected, description]
  rows:
    - [batched_doc_class_str,
       batched.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.batched.__doc__.__class__.__name__.__eq__('str') == True — batched is a C-level type for fixed-size batches (Python 3.12+); its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra200"]
    - [groupby_doc_class_str,
       groupby.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.groupby.__doc__.__class__.__name__.__eq__('str') == True — groupby is a C-level type for grouping consecutive equal-key elements; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra200"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra200
# ---------------------------------------------------------------------------

invariant itertools_extra200.count_doc_class:
  description: "itertools.count.__doc__.__class__.__name__ == 'str' — C-level infinite counter type with string docstring; new to extra200"
  kind: python_call_eq
  function: count.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra200.cycle_doc_class:
  description: "itertools.cycle.__doc__.__class__.__name__ == 'str' — C-level infinite cycling type with string docstring; new to extra200"
