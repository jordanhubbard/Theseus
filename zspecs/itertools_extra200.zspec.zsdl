  expected: true

invariant itertools_extra200.pairwise_doc_class:
  description: "itertools.pairwise.__doc__.__class__.__name__ == 'str' — C-level pairwise type (Python 3.10+) with string docstring; new to extra200"
  kind: python_call_eq
