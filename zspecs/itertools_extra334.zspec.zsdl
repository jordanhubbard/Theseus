spec: itertools_extra334
version: ">=3.0"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "product.__name__ == 'product' — C-level type; __name__ is the class name."
    - "product.__doc__.__len__() == 681 — docstring length on Python 3.14 macOS."
    - "combinations.__name__ == 'combinations'."
    - "combinations.__doc__.__len__() == 134."
    - "combinations_with_replacement.__name__ == 'combinations_with_replacement'."
    - "combinations_with_replacement.__doc__.__len__() == 234."
    - "permutations.__name__ == 'permutations'."
    - "permutations.__doc__.__len__() == 140."
    - "itertools.__loader__.__class__.__name__ == 'type' — the loader for a built-in C extension is the module type itself."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks for product, combinations, combinations_with_replacement,
# and permutations (C-level types; __name__ is the class name string)
# ---------------------------------------------------------------------------

table itertools_extra334.classnames:
  kind: python_call_eq
  category: classnames
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [product,                      product.__name__.__eq__,                      ["product"],                      true]
    - [combinations,                 combinations.__name__.__eq__,                 ["combinations"],                 true]
    - [combinations_with_replacement, combinations_with_replacement.__name__.__eq__, ["combinations_with_replacement"], true]
    - [permutations,                 permutations.__name__.__eq__,                 ["permutations"],                 true]

# ---------------------------------------------------------------------------
# __doc__ length checks — verify docstring sizes on Python 3.14 macOS
# ---------------------------------------------------------------------------

table itertools_extra334.doc_lengths:
  kind: python_call_eq
  category: doc_lengths
  id_prefix: dlen

  columns: [id, function, args, expected]
  rows:
    - [product,                      product.__doc__.__len__,                      [], 681]
    - [combinations,                 combinations.__doc__.__len__,                 [], 134]
    - [combinations_with_replacement, combinations_with_replacement.__doc__.__len__, [], 234]
    - [permutations,                 permutations.__doc__.__len__,                 [], 140]

# ---------------------------------------------------------------------------
# __loader__ — class name of the module's loader
#
# itertools is a C extension; its __loader__ is the built-in module loader
# whose __class__.__name__ is 'type'.
# ---------------------------------------------------------------------------

invariant itertools_extra334.loader.class_name:
  description: "itertools.__loader__.__class__.__name__ == 'type'"
  category: loader
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true
