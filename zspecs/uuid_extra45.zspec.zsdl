spec: uuid_extra45
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra44.zspec.zsdl — covers NAMESPACE_OID/X500 __class__.__name__/__qualname__.__len__()==4; uuid.__name__.__eq__('uuid') and __name__.__len__()==4."
    - "uuid_extra43.zspec.zsdl — covers NAMESPACE_URL/OID/X500 __class__.__name__/__qualname__/__module__.__eq__ string values."
    - "uuid_extra42.zspec.zsdl — covers UUID.time_low/time_mid/clock_seq_low fget.__qualname__.__eq__; getnode/__module__.__eq__; uuid4/getnode/UUID __module__.__class__.__name__.__eq__('str')."
    - "uuid_extra41.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/getnode/module __doc__.__class__.__name__.__eq__('str') and UUID.hex/int/bytes/version fget.__qualname__.__eq__."
    - "uuid_extra39.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/NAMESPACE_DNS __class__.__qualname__.__eq__ and __class__.__module__.__eq__."
    - "uuid_extra31.zspec.zsdl — covers getnode.__name__.__eq__('getnode') and getnode.__qualname__.__eq__('getnode')."
    - "uuid_extra23.zspec.zsdl — covers UUID.__dict__.__class__.__name__.__len__()==12 (length only); NAMESPACE_DNS/URL __class__.__name__.__len__()==4; uuid1/3/4/5 __qualname__.__len__()==5."
    - "uuid_extra20.zspec.zsdl — covers uuid1/3/4/5 __qualname__.__eq__ in a table; NAMESPACE_DNS.__class__.__module__.__eq__('uuid')."
    - "uuid_extra5.zspec.zsdl — covers uuid1/3/4/5 __qualname__.__eq__ in a table."
  notes:
    - "This spec extends uuid through uuid_extra44; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: uuid_extra23 checks UUID.__dict__.__class__.__name__.__len__()==12 (the __len__ axis: len('mappingproxy')==12). No prior uuid spec checks UUID.__dict__.__class__.__name__.__eq__('mappingproxy') (the string value axis). These are independent regression vectors — the __eq__ check catches renames to a same-length name, while __len__ catches renames to a different-length name. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__class__.__name__ == 'mappingproxy'. UUID.__dict__ is a mappingproxy object (CPython's read-only view of a class namespace). uuid_extra23 covers __class__.__name__.__len__()==12 (length only). No prior spec checks __class__.__name__.__eq__('mappingproxy') for UUID.__dict__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior uuid spec checks __dict__.__class__.__qualname__ for UUID. uuid_extra23 checks __dict__.__class__.__name__.__len__()==12 (the __len__ axis on __name__, not __qualname__). For mappingproxy (a non-nested C type), __qualname__ == __name__ == 'mappingproxy'. The __class__.__qualname__ chain is an independent regression vector. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__class__.__qualname__ == 'mappingproxy'. The mappingproxy type's __qualname__ is 'mappingproxy'. No prior spec checks __dict__.__class__.__qualname__.__eq__ for UUID.__dict__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior uuid spec checks the uuid module's own __dict__.__class__.__name__ or __qualname__. uuid_extra44 checks uuid.__name__.__eq__('uuid') (the module's __name__ attribute), not its __dict__.__class__.__name__. Under python_module(uuid), function: __dict__.__class__.__name__.__eq__ resolves to uuid.__dict__.__class__.__name__.__eq__('mappingproxy'). Module namespaces are mappingproxy objects in CPython. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.__dict__.__class__.__name__ == 'mappingproxy'. The uuid module's namespace dict is a mappingproxy. No prior uuid spec checks __dict__.__class__.__name__.__eq__('mappingproxy') for the module itself. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.__dict__.__class__.__qualname__ == 'mappingproxy'. The mappingproxy type's __qualname__ for the module namespace. Independent of __name__ axis. No prior uuid spec checks __dict__.__class__.__qualname__.__eq__('mappingproxy') for the uuid module. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 4: No prior uuid spec checks NAMESPACE_DNS.__class__.__module__.__len__(). uuid_extra20 checks NAMESPACE_DNS.__class__.__module__.__eq__('uuid') (value axis only). The module name 'uuid' has 4 characters; __module__.__len__()==4 is an independent length regression vector. uuid_extra21 covers NAMESPACE_URL/OID/X500 __class__.__module__.__len__()==4 but NOT NAMESPACE_DNS. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__module__.__len__() == 4. len('uuid') == 4. uuid_extra20 checks __class__.__module__.__eq__('uuid') for NAMESPACE_DNS (value axis). uuid_extra21 covers NAMESPACE_URL/OID/X500 __class__.__module__.__len__()==4 but NOT NAMESPACE_DNS. No prior spec checks NAMESPACE_DNS.__class__.__module__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy')
#
# uuid_extra23 checks UUID.__dict__.__class__.__name__.__len__()==12 (len axis).
# No prior uuid spec checks the string VALUE: __class__.__name__.__eq__('mappingproxy').
# The __eq__ check is a distinct regression vector from the __len__ check:
# a rename to another 12-char name would be caught by __eq__ but not __len__,
# while a rename to a different-length name would be caught by __len__ only.
# ---------------------------------------------------------------------------

invariant uuid_extra45.UUID.dict_class_name_eq:
  description: "uuid.UUID.__dict__.__class__.__name__ == 'mappingproxy' — novel string value axis; uuid_extra23 covers __class__.__name__.__len__()==12 (length only); no prior uuid spec checks __class__.__name__.__eq__('mappingproxy') for UUID.__dict__"
  category: type_structure
  kind: python_call_eq
  function: UUID.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__class__.__qualname__.__eq__('mappingproxy')
#
# No prior uuid spec checks __dict__.__class__.__qualname__ for UUID.
# uuid_extra23 covers __dict__.__class__.__name__.__len__ (a different chain:
# __name__ not __qualname__, and __len__ not __eq__). For mappingproxy,
# a non-nested C type, __qualname__ == __name__ == 'mappingproxy'. The
# __class__.__qualname__ chain is an independent regression vector.
# ---------------------------------------------------------------------------

invariant uuid_extra45.UUID.dict_class_qualname_eq:
  description: "uuid.UUID.__dict__.__class__.__qualname__ == 'mappingproxy' — novel __class__.__qualname__ axis for UUID.__dict__; extra23 covers __class__.__name__.__len__ only (different chain); no prior uuid spec checks __dict__.__class__.__qualname__.__eq__ for UUID"
  category: type_structure
  kind: python_call_eq
  function: UUID.__dict__.__class__.__qualname__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# uuid module __dict__.__class__.__name__ and __qualname__
#
# No prior uuid spec checks the module's own __dict__.__class__.__name__
# or __qualname__. uuid_extra44 checks uuid.__name__.__eq__('uuid') (the
# module's __name__ attribute, not __dict__.__class__.__name__).
# Under python_module(uuid), function: __dict__.__class__.__name__.__eq__
# resolves to uuid.__dict__.__class__.__name__.__eq__('mappingproxy').
# Module namespaces in CPython are mappingproxy objects.
# ---------------------------------------------------------------------------

invariant uuid_extra45.module.dict_class_name_eq:
  description: "uuid.__dict__.__class__.__name__ == 'mappingproxy' — the uuid module's namespace dict is a mappingproxy; distinct from UUID.__dict__ (class dict); no prior uuid spec checks __dict__.__class__.__name__.__eq__('mappingproxy') for the module itself"
  category: module_identity
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant uuid_extra45.module.dict_class_qualname_eq:
  description: "uuid.__dict__.__class__.__qualname__ == 'mappingproxy' — the mappingproxy type's __qualname__ for the module namespace; independent of __name__ axis; no prior uuid spec checks __dict__.__class__.__qualname__.__eq__('mappingproxy') for the uuid module"
  category: module_identity
  kind: python_call_eq
  function: __dict__.__class__.__qualname__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__module__.__len__()
#
# uuid_extra20 checks NAMESPACE_DNS.__class__.__module__.__eq__('uuid')
#   (the value axis: the string equality).
# uuid_extra21 covers NAMESPACE_URL/OID/X500 __class__.__module__.__len__()==4
#   but NOT NAMESPACE_DNS.
# The module name 'uuid' has 4 characters. __module__.__len__()==4 is an
# independent length regression vector: if the module were renamed to a
# different-length name, only __len__ catches it; if renamed to a same-length
# name, only __eq__ catches it.
# ---------------------------------------------------------------------------

invariant uuid_extra45.NAMESPACE_DNS.class_module_len:
  description: "uuid.NAMESPACE_DNS.__class__.__module__.__len__() == 4 — len('uuid') == 4; uuid_extra20 checks __class__.__module__.__eq__('uuid') for NAMESPACE_DNS (value axis); uuid_extra21 covers NAMESPACE_URL/OID/X500 __class__.__module__.__len__()==4 but NOT NAMESPACE_DNS; no prior spec checks NAMESPACE_DNS.__class__.__module__.__len__()"
  category: type_structure
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__module__.__len__
  args: []
  expected: 4
