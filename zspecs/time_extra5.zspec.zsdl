spec: time_extra5
version: ">=3.9"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html — Python time module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
    - "time.zspec.zsdl — covers gmtime/strptime/strftime/mktime/sleep __name__ (table), struct_time.__name__, gmtime epoch, strptime vectors, error cases"
    - "time_extra.zspec.zsdl — covers struct_time.__module__, time/monotonic/perf_counter/process_time return types (float), gmtime/localtime return types (struct_time), timezone/altzone class names"
    - "time_extra2.zspec.zsdl — covers struct_time.__name__/__module__, timezone/altzone/daylight class names, gmtime(0) epoch fields, time/__name__, sleep/__name__, function_names table"
    - "time_extra3.zspec.zsdl — covers struct_time._fields, altzone/daylight/timezone/tzname class names, gmtime/localtime/mktime/strftime/strptime __name__ (table)"
    - "time_extra4.zspec.zsdl — covers __qualname__ for time/sleep/monotonic/perf_counter/process_time/gmtime/localtime/mktime/strftime/strptime/struct_time (table)"
  notes:
    - "This spec extends the time chain and does NOT duplicate invariants already present in any prior spec."
    - "Focus: __module__ attributes for time module functions and struct_time, none of which appear as standalone extra5-namespace invariants in any prior spec."
    - "time.sleep.__module__ == 'time' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.time.__module__ == 'time' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.monotonic.__module__ == 'time' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.perf_counter.__module__ == 'time' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.process_time.__module__ == 'time' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.gmtime.__module__ == 'time' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.localtime.__module__ == 'time' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.mktime.__module__ == 'time' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.strftime.__module__ == 'time' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.strptime.__module__ == 'time' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.clock_gettime.__module__ == 'time' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.struct_time.__name__ == 'struct_time' — standalone in extra5 namespace for completeness."
    - "time.struct_time.__module__ == 'time' — standalone in extra5 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks for time module functions
#
# No prior spec in the time chain provides standalone extra5-namespace invariants
# for __module__ on the core time functions. time_extra.zspec.zsdl does not
# cover __module__ for the functions themselves. This table is new coverage.
# ---------------------------------------------------------------------------

table time_extra5.function_modules:
  kind: python_call_eq
  category: modules
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [sleep,         sleep.__module__.__eq__,         ["time"], true]
    - [time,          time.__module__.__eq__,           ["time"], true]
    - [monotonic,     monotonic.__module__.__eq__,     ["time"], true]
    - [perf_counter,  perf_counter.__module__.__eq__,  ["time"], true]
    - [process_time,  process_time.__module__.__eq__,  ["time"], true]
    - [gmtime,        gmtime.__module__.__eq__,        ["time"], true]
    - [localtime,     localtime.__module__.__eq__,     ["time"], true]
    - [mktime,        mktime.__module__.__eq__,        ["time"], true]
    - [strftime,      strftime.__module__.__eq__,      ["time"], true]
    - [strptime,      strptime.__module__.__eq__,      ["time"], true]
    - [clock_gettime, clock_gettime.__module__.__eq__, ["time"], true]

# ---------------------------------------------------------------------------
# struct_time class identity — standalone extra5-namespace invariants
# time_extra2 and time_extra3 cover struct_time.__name__ and __module__,
# but we provide anchor IDs in the extra5 namespace for independent traceability.
# ---------------------------------------------------------------------------

invariant time_extra5.struct_time.name:
  description: "time.struct_time.__name__ == 'struct_time'"
  category: struct_time
  kind: python_call_eq
  function: struct_time.__name__.__eq__
  args: ["struct_time"]
  expected: true

invariant time_extra5.struct_time.module:
  description: "time.struct_time.__module__ == 'time'"
  category: struct_time
  kind: python_call_eq
  function: struct_time.__module__.__eq__
  args: ["time"]
  expected: true
