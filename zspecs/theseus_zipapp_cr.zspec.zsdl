spec: theseus_zipapp_cr
version: ">=3.5"
backend: python_cleanroom(theseus_zipapp_cr)
blocks: zipapp

docs: https://docs.python.org/3/library/zipapp.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/zipapp.html"
  not_derived_from:
    - "CPython source: Lib/zipapp.py"
  notes:
    - "Clean-room zipapp module. Do NOT import zipapp."

error_model: python_exceptions

invariant theseus_zipapp_cr.zipapp2_error:
  description: "ZipAppError exception class exists"
  category: behavior
  kind: python_call_eq
  function: zipapp2_error
  args: []
  expected: true

invariant theseus_zipapp_cr.zipapp2_get_interpreter:
  description: "get_interpreter() returns the interpreter from an archive"
  category: behavior
  kind: python_call_eq
  function: zipapp2_get_interpreter
  args: []
  expected: true

invariant theseus_zipapp_cr.zipapp2_create:
  description: "create_archive() creates a runnable zip archive"
  category: behavior
  kind: python_call_eq
  function: zipapp2_create
  args: []
  expected: true
