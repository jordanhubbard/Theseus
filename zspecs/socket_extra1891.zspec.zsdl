    - ["sk1891-fa-005", "socket.__dict__.__contains__", ["__fspath__"], false]
    - ["sk1891-fa-006", "socket.__dict__.__contains__", ["__aiter__"], false]
    - ["sk1891-fa-007", "socket.__dict__.__contains__", ["__length_hint__"], false]
    - ["sk1891-fa-008", "socket.socket.__dict__.__contains__", ["__length_hint__"], false]

