spec: socket_extra1891
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "Tests unary arithmetic protocol, async iteration protocol, __fspath__, and socket module type/constant membership"
    - "socket.socket is a networking class and does not implement numeric protocols"
    - "socket.error and socket.timeout are exception classes and do not implement numeric protocols"
    - "socket module dict does not implement numeric or async iteration protocols"
    - "socket module dict contains AF_UNIX, AF_INET, AF_INET6, SOCK_STREAM, SOCK_DGRAM, SOCK_RAW, SOCK_SEQPACKET, SOL_SOCKET, SO_REUSEADDR, SO_ERROR"
  created_at: "2026-04-12"

table socket_extra1891.unary_arithmetic:
  columns: [id, function, args, expected]
  rows:
    - ["sk1891-ua-001", "socket.socket.__dict__.__contains__", ["__abs__"], false]
    - ["sk1891-ua-002", "socket.socket.__dict__.__contains__", ["__neg__"], false]
    - ["sk1891-ua-003", "socket.socket.__dict__.__contains__", ["__pos__"], false]
    - ["sk1891-ua-004", "socket.error.__dict__.__contains__", ["__abs__"], false]
    - ["sk1891-ua-005", "socket.timeout.__dict__.__contains__", ["__abs__"], false]
    - ["sk1891-ua-006", "socket.__dict__.__contains__", ["__abs__"], false]
    - ["sk1891-ua-007", "socket.__dict__.__contains__", ["__neg__"], false]
    - ["sk1891-ua-008", "socket.__dict__.__contains__", ["__pos__"], false]

