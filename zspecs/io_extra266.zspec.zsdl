spec: io_extra266
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra265.zspec.zsdl — covers FileIO/RawIOBase/BufferedIOBase class identity and method qualnames"
    - "_io_extra.zspec.zsdl — covers IOBase/RawIOBase/FileIO/BytesIO/StringIO/BufferedRandom/TextIOWrapper/IncrementalNewlineDecoder class names and modules"
  notes:
    - "io.IOBase.__name__ == 'IOBase', __module__ == 'io' — the pure-Python wrapper class."
    - "io.IOBase.__bases__[0].__name__ == '_IOBase' — the C-level base class name; __module__ == '_io'."
    - "io.IOBase method qualnames all use '_IOBase.' prefix — methods are inherited from the C base."
    - "io.IOBase.close.__class__.__name__ == 'method_descriptor' — C-implemented descriptor."
    - "io.DEFAULT_BUFFER_SIZE == 131072 — the default I/O buffer size in bytes."
    - "type(io.DEFAULT_BUFFER_SIZE).__name__ == 'int'."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IOBase — class identity: name, module, base
# ---------------------------------------------------------------------------

invariant io_extra266.IOBase.class_name:
  description: "io.IOBase.__name__ == 'IOBase'"
  category: class_metadata
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true

invariant io_extra266.IOBase.module:
  description: "io.IOBase.__module__ == 'io'"
  category: class_metadata
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra266.IOBase.base_name:
  description: "io.IOBase.__bases__[0].__name__ == '_IOBase' — C-level base class"
  category: class_metadata
  kind: python_call_eq
  function: IOBase.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_IOBase"

invariant io_extra266.IOBase.base_module:
  description: "io.IOBase.__bases__[0].__module__ == '_io' — C-level base lives in _io extension"
  category: class_metadata
  kind: python_call_eq
  function: IOBase.__bases__.__getitem__
  args: [0]
  method: __module__
  method_args: []
  expected: "_io"

# ---------------------------------------------------------------------------
# IOBase — method qualnames (all inherited from _IOBase)
# ---------------------------------------------------------------------------

table io_extra266.IOBase.method_qualnames:
  description: "io.IOBase method __qualname__ attributes all use '_IOBase.' prefix — inherited from C base"
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [close,    IOBase.close.__qualname__.__eq__,    ["_IOBase.close"],    true]
    - [flush,    IOBase.flush.__qualname__.__eq__,    ["_IOBase.flush"],    true]
    - [readable, IOBase.readable.__qualname__.__eq__, ["_IOBase.readable"], true]
    - [writable, IOBase.writable.__qualname__.__eq__, ["_IOBase.writable"], true]
    - [seekable, IOBase.seekable.__qualname__.__eq__, ["_IOBase.seekable"], true]
    - [tell,     IOBase.tell.__qualname__.__eq__,     ["_IOBase.tell"],     true]
    - [truncate, IOBase.truncate.__qualname__.__eq__, ["_IOBase.truncate"], true]
    - [fileno,   IOBase.fileno.__qualname__.__eq__,   ["_IOBase.fileno"],   true]

# ---------------------------------------------------------------------------
# IOBase.close — descriptor class name
# ---------------------------------------------------------------------------

invariant io_extra266.IOBase.close.class_name:
  description: "io.IOBase.close.__class__.__name__ == 'method_descriptor' — C-implemented descriptor"
  category: method_identity
  kind: python_call_eq
  function: IOBase.close.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# DEFAULT_BUFFER_SIZE — constant value and type
# ---------------------------------------------------------------------------

invariant io_extra266.DEFAULT_BUFFER_SIZE.value:
  description: "io.DEFAULT_BUFFER_SIZE == 131072"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true

invariant io_extra266.DEFAULT_BUFFER_SIZE.type_name:
  description: "type(io.DEFAULT_BUFFER_SIZE).__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true
