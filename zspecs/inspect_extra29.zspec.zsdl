spec: inspect_extra29
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra28.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/__name__, getmembers/signature/Parameter/Signature/BoundArguments identity, Parameter kind class names, empty sentinel class names, class __bases__[0].__name__ for Parameter/Signature/BoundArguments (all 'object'), various __qualname__ and __module__ checks, __qualname__ equality table for 8 predicates, __module__.__len__() table for ismodule/isclass/signature/getmembers."
    - "This spec covers: __name__.__len__() for isfunction/ismethod/isbuiltin/isroutine/Parameter/Signature/BoundArguments; __name__.__len__() for isframe/iscode/isasyncgen/iscoroutine/isgenerator; __module__.__len__() for isfunction/ismethod/isbuiltin/isroutine/Parameter/Signature/BoundArguments."
    - "All inspect functions and classes have __module__ == 'inspect' (len 7)."
    - "Name lengths: isfunction=10, ismethod=8, isbuiltin=9, isroutine=9, Parameter=9, Signature=9, BoundArguments=14, isframe=7, iscode=6, isasyncgen=10, iscoroutine=11, isgenerator=11."
    - "For all inspect functions __qualname__.__len__() == __name__.__len__() since they are module-level names."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() table — predicate and class name string lengths
#
# isfunction and getmembers both have 10-character names; isbuiltin and isroutine
# are 9 characters; ismethod is 8; Parameter and Signature are both 9;
# BoundArguments is the longest at 14. This table records __name__.__len__()
# for seven key inspect objects in a single combined view. No prior inspect spec
# records these seven __name__.__len__() values together in a combined table in
# the extra29 namespace.
# ---------------------------------------------------------------------------

table inspect_extra29.predicate_class_name_lengths:
  description: "__name__.__len__() for inspect predicates and classes"
  kind: python_call_eq
  category: function_attrs
  id_prefix: name_len

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction,
       isfunction.__name__.__len__,
       [],
       10,
       "len(inspect.isfunction.__name__) == 10"]
    - [ismethod,
       ismethod.__name__.__len__,
       [],
       8,
       "len(inspect.ismethod.__name__) == 8"]
    - [isbuiltin,
       isbuiltin.__name__.__len__,
       [],
       9,
       "len(inspect.isbuiltin.__name__) == 9"]
    - [isroutine,
       isroutine.__name__.__len__,
       [],
       9,
       "len(inspect.isroutine.__name__) == 9"]
    - [Parameter,
       Parameter.__name__.__len__,
       [],
       9,
       "len(inspect.Parameter.__name__) == 9"]
    - [Signature,
       Signature.__name__.__len__,
       [],
       9,
       "len(inspect.Signature.__name__) == 9"]
    - [BoundArguments,
       BoundArguments.__name__.__len__,
       [],
       14,
       "len(inspect.BoundArguments.__name__) == 14"]

# ---------------------------------------------------------------------------
# __name__.__len__() table — introspection predicate name string lengths
#
# isframe (7) and iscode (6) check for frame and code objects respectively.
# isasyncgen (10), iscoroutine (11), and isgenerator (11) check for
# asynchronous and synchronous generator types. Their longer names reflect the
# compound concepts they test. No prior inspect spec records these five
# __name__.__len__() values together in a combined table in the extra29
# namespace.
# ---------------------------------------------------------------------------

table inspect_extra29.introspection_name_lengths:
  description: "__name__.__len__() for inspect frame/code/async/generator predicates"
  kind: python_call_eq
  category: function_attrs
  id_prefix: name_len

  columns: [id, function, args, expected, description]
  rows:
    - [iscode,
       iscode.__name__.__len__,
       [],
       6,
       "len(inspect.iscode.__name__) == 6"]
    - [isframe,
       isframe.__name__.__len__,
       [],
       7,
       "len(inspect.isframe.__name__) == 7"]
    - [isasyncgen,
       isasyncgen.__name__.__len__,
       [],
       10,
       "len(inspect.isasyncgen.__name__) == 10"]
    - [iscoroutine,
       iscoroutine.__name__.__len__,
       [],
       11,
       "len(inspect.iscoroutine.__name__) == 11"]
    - [isgenerator,
       isgenerator.__name__.__len__,
       [],
       11,
       "len(inspect.isgenerator.__name__) == 11"]

# ---------------------------------------------------------------------------
# __module__.__len__() table — module string lengths for predicates and classes
#
# isfunction, ismethod, isbuiltin, isroutine, Parameter, Signature, and
# BoundArguments all have __module__ == 'inspect' (len 7). The previous spec
# (extra28) recorded __module__.__len__() for ismodule/isclass/signature/
# getmembers; this table extends coverage to four more predicates and the three
# primary inspect classes. No prior inspect spec records these seven
# __module__.__len__() values together in a combined table in the extra29
# namespace.
# ---------------------------------------------------------------------------

table inspect_extra29.predicate_class_module_lengths:
  description: "__module__.__len__() for inspect predicates and classes — all 7 ('inspect')"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: module_len

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction,
       isfunction.__module__.__len__,
       [],
       7,
       "len(inspect.isfunction.__module__) == 7"]
    - [ismethod,
       ismethod.__module__.__len__,
       [],
       7,
       "len(inspect.ismethod.__module__) == 7"]
    - [isbuiltin,
       isbuiltin.__module__.__len__,
       [],
       7,
       "len(inspect.isbuiltin.__module__) == 7"]
    - [isroutine,
       isroutine.__module__.__len__,
       [],
       7,
       "len(inspect.isroutine.__module__) == 7"]
    - [Parameter,
       Parameter.__module__.__len__,
       [],
       7,
       "len(inspect.Parameter.__module__) == 7"]
    - [Signature,
       Signature.__module__.__len__,
       [],
       7,
       "len(inspect.Signature.__module__) == 7"]
    - [BoundArguments,
       BoundArguments.__module__.__len__,
       [],
       7,
       "len(inspect.BoundArguments.__module__) == 7"]

# ---------------------------------------------------------------------------
# BoundArguments.__name__.__len__() — standalone name string length
#
# inspect.BoundArguments.__name__ is 'BoundArguments', a 14-character string.
# BoundArguments is the longest-named of the three primary inspect classes
# (Parameter=9, Signature=9, BoundArguments=14). The compound name reflects
# that it holds arguments already bound to a Signature. No prior inspect spec
# records this standalone in the extra29 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra29.BoundArguments.name_len:
  description: "len(inspect.BoundArguments.__name__) == 14 — 'BoundArguments' is 14 chars"
  category: function_attrs
  kind: python_call_eq
  function: BoundArguments.__name__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# isfunction.__module__.__len__() — standalone module string length
#
# inspect.isfunction.__module__ is 'inspect', a 7-character string. isfunction
# is a pure Python function in Lib/inspect.py that returns True when the object
# is a Python function created by a def statement. All inspect functions and
# classes share this 7-character module string; isfunction is called out here
# as the canonical representative for the predicate group. No prior inspect spec
# records this standalone in the extra29 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra29.isfunction.module_len:
  description: "len(inspect.isfunction.__module__) == 7 — 'inspect' is 7 chars"
  category: module_attr_lengths
  kind: python_call_eq
  function: isfunction.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# iscoroutine.__name__.__len__() — standalone name string length
#
# inspect.iscoroutine.__name__ is 'iscoroutine', an 11-character string shared
# with isgenerator. iscoroutine returns True for coroutine objects created by
# async def functions. Its 11-character name is the same length as isgenerator,
# reflecting the parallel naming of coroutine and generator introspection
# predicates. No prior inspect spec records this standalone in the extra29
# namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra29.iscoroutine.name_len:
  description: "len(inspect.iscoroutine.__name__) == 11 — 'iscoroutine' is 11 chars"
  category: function_attrs
  kind: python_call_eq
  function: iscoroutine.__name__.__len__
  args: []
  expected: 11
