spec: socket_extra195
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "socket.socket.bind.__name__ == 'bind' (len=4); socket.socket.send.__name__ == 'send' (len=4); socket.socket.recv.__name__ == 'recv' (len=4) — shortest method names on socket.socket."
    - "socket.socket.close.__name__ == 'close' (len=5) — one character longer than the 4-character methods."
    - "socket.socket.listen.__name__ == 'listen' (len=6); socket.socket.accept.__name__ == 'accept' (len=6); socket.socket.fileno.__name__ == 'fileno' (len=6) — three methods with len=6."
    - "socket.socket.connect.__name__ == 'connect' (len=7) — the longest name among the eight socket methods covered here."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

