    - [send_name_len, socket.send.__name__.__len__, [], 4, "len(socket.socket.send.__name__) == 4 ('send' has 4 characters)"]
    - [recv_name_len, socket.recv.__name__.__len__, [], 4, "len(socket.socket.recv.__name__) == 4 ('recv' has 4 characters)"]

