spec: decimal_extra84
version: ">=3.9"
backend: python_module(decimal)
extends: decimal_extra83

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra83."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity; Decimal dunders; Decimal comparison/equality/hash; Context/__dict__ class and membership; getcontext/setcontext __class__.__name__/__module__; Decimal division/power operator; Context arithmetic method __class__.__name__; Decimal arithmetic/string/conversion dunder __qualname__; Decimal comparison operator __qualname__ lengths; Decimal to_*/normalize/quantize/sqrt/compare __qualname__; Decimal.__dict__.__contains__; Decimal/__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__(); Context/__name__/__module__/__qualname__; ROUND_* constants; Decimal method qualnames for quantize/normalize/to_integral_value/as_tuple/sqrt/compare/conjugate/copy_abs/fma."
    - "This spec covers: decimal.Context class identity — __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(). Also Context.__dict__ membership for methods (quantize, sqrt, copy) and properties (prec, rounding, Emax, Emin). Also decimal.Decimal.__name__ cross-check."
    - "decimal.Context.__name__ == 'Context' — top-level C type in the decimal module."
    - "decimal.Context.__module__ == 'decimal' — Context is exposed via the decimal module (not _decimal)."
    - "decimal.Context.__qualname__ == 'Context' — top-level class; qualname equals bare name."
    - "decimal.Context.__bases__[0].__name__ == 'object' — Context has no intermediate base class."
    - "decimal.Context.__mro__.__len__() == 2 — MRO: [Context, object]."
    - "decimal.Context.__dict__.__class__.__name__ == 'mappingproxy' — read-only view of the class namespace."
    - "decimal.Context.__dict__.__contains__('quantize') == True — Context defines quantize as a method."
    - "decimal.Context.__dict__.__contains__('sqrt') == True — Context defines sqrt as a method."
    - "decimal.Context.__dict__.__contains__('prec') == True — prec is defined in Context.__dict__ (property/slot)."
    - "decimal.Context.__dict__.__contains__('rounding') == True — rounding is defined in Context.__dict__."
    - "decimal.Context.__dict__.__contains__('Emax') == True — Emax is defined in Context.__dict__."
    - "decimal.Context.__dict__.__contains__('Emin') == True — Emin is defined in Context.__dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context class identity: __name__, __module__, __qualname__
# Context is a C-level type exposed via the decimal module; its __module__
# is 'decimal' (the public module), not '_decimal' (the C-extension module).
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra84.Context_class_identity_name_module:
  description: "decimal.Context __name__/__module__/__qualname__ string equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalctxid84

  columns: [id, function, args, expected]
  rows:
    - [ctx_name,     Context.__name__.__eq__,     ["Context"], true]
    - [ctx_module,   Context.__module__.__eq__,   ["decimal"], true]
    - [ctx_qualname, Context.__qualname__.__eq__,  ["Context"], true]

# ---------------------------------------------------------------------------
# decimal.Context class identity: __bases__[0].__name__ and __mro__.__len__()
# Context has no intermediate base class; __bases__[0] is object and MRO length is 2.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra84.Context_class_identity_bases_mro:
  description: "decimal.Context __bases__[0].__name__, __mro__.__len__(), __dict__.__class__.__name__"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalctxid84

  columns: [id, function, args, expected]
  rows:
    - [ctx_base0,      "Context.__bases__[0].__name__.__eq__",         ["object"],       true]
    - [ctx_mrolen,     Context.__mro__.__len__,                        [],               2]
    - [ctx_dict_class, "Context.__dict__.__class__.__name__.__eq__",   ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# decimal.Context.__dict__ membership for methods
# Context defines quantize, sqrt, and copy directly; these are C-level methods.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra84.Context_dict_method_membership:
  description: "decimal.Context.__dict__.__contains__ for quantize/sqrt/copy (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimalctxid84

  columns: [id, function, args, expected]
  rows:
    - [ctx_has_quantize, Context.__dict__.__contains__, ["quantize"], true]
    - [ctx_has_sqrt,     Context.__dict__.__contains__, ["sqrt"],     true]
    - [ctx_has_copy,     Context.__dict__.__contains__, ["copy"],     true]

# ---------------------------------------------------------------------------
# decimal.Context.__dict__ membership for properties/slots
# prec, rounding, Emax, Emin are defined in Context.__dict__ as properties/slots.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra84.Context_dict_property_membership:
  description: "decimal.Context.__dict__.__contains__ for prec/rounding/Emax/Emin; Decimal name cross-check"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimalctxid84

  columns: [id, function, args, expected]
  rows:
    - [ctx_has_prec,      Context.__dict__.__contains__,   ["prec"],      true]
    - [ctx_has_rounding,  Context.__dict__.__contains__,   ["rounding"],  true]
    - [ctx_has_emax,      Context.__dict__.__contains__,   ["Emax"],      true]
    - [ctx_has_emin,      Context.__dict__.__contains__,   ["Emin"],      true]
    - [dec_name_check,    Decimal.__name__.__eq__,         ["Decimal"],   true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra84.Context.name:
  description: "decimal.Context.__name__ == 'Context' (top-level C type; name is the bare class name)"
  category: class_identity
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra84.Context.module:
  description: "decimal.Context.__module__ == 'decimal' (exposed via decimal module, not _decimal)"
  category: class_identity
  kind: python_call_eq
  function: Context.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra84.Context.mro_len:
  description: "decimal.Context.__mro__.__len__() == 2 (MRO: Context, object; no intermediate base)"
  category: class_identity
  kind: python_call_eq
  function: Context.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra84.Context.dict_has_prec:
  description: "decimal.Context.__dict__.__contains__('prec') == True (prec is a property/slot defined in Context)"
  category: dict_membership
  kind: python_call_eq
  function: Context.__dict__.__contains__
  args: ["prec"]
  expected: true

invariant decimal_extra84.Context.dict_has_quantize:
  description: "decimal.Context.__dict__.__contains__('quantize') == True (quantize is a C-level method defined in Context)"
  category: dict_membership
  kind: python_call_eq
  function: Context.__dict__.__contains__
  args: ["quantize"]
  expected: true
