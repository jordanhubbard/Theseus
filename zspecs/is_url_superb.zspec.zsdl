spec: is_url_superb
version: ">=6.1.0"
backend: node(is-url-superb)

docs: https://www.npmjs.com/package/is-url-superb

provenance:
  derived_from:
    - "is-url-superb README — https://www.npmjs.com/package/is-url-superb"
    - "Test vectors verified with is-url-superb via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-url-superb source"
  notes:
    - "is-url-superb is an npm package. Install: npm install is-url-superb"
    - "Returns true if the given string is a valid URL, false otherwise."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_url_superb.check:
  kind: node_module_call_eq
  function: "default"
  category: validation
  id_prefix: isurl

  columns: [id, args, expected]
  rows:
    - [valid_http,   ["http://example.com"],   true]
    - [valid_https,  ["https://example.com"],  true]
    - [not_url,      ["not-a-url"],             false]
