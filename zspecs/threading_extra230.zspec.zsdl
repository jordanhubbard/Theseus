spec: threading_extra230
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading.Timer, threading.stack_size, and threading.TIMEOUT_MAX behavioral contracts."
    - "threading.Timer.__name__ == 'Timer' — the Timer class is a Thread subclass for deferred execution. Verified with Python 3.14.3."
    - "threading.Timer.__module__ == 'threading' — Timer is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Timer.__base__.__name__ == 'Thread' — Timer inherits from Thread. Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant. Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a large positive float (9223372036.0). Verified with Python 3.14.3."
    - "threading.stack_size().__class__.__name__ == 'int' — stack_size() returns an int (0 means platform default). Verified with Python 3.14.3."
    - "threading.stack_size() == 0 — default stack size is 0 (use platform default). Verified with Python 3.14.3."
    - "threading.local().__class__.__name__ == '_local' — thread-local storage instances are of type _local. Verified with Python 3.14.3."
    - "threading.active_count().__class__.__name__ == 'int' — active_count returns an int. Verified with Python 3.14.3."
    - "threading.active_count.__name__ == 'active_count' — the function has __name__=='active_count'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Timer identity contracts
#
# threading.Timer.__name__ == 'Timer'
# threading.Timer.__qualname__ == 'Timer'
# threading.Timer.__module__ == 'threading'
# threading.Timer.__name__.__len__() == 5
# threading.Timer.__base__.__name__ == 'Thread'
#
# Timer is a Thread subclass that executes a function after a delay.
# New to extra230.
# ---------------------------------------------------------------------------

table threading_extra230.timer_identity:
  description: "threading.Timer identity contracts: __name__, __qualname__, __module__, name length, base class; new to extra230"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra230timerid

  columns: [id, function, args, expected, description]
  rows:
    - [timer_name_eq,
       Timer.__name__.__eq__,
       ["Timer"],
       true,
       "threading.Timer.__name__ == 'Timer' — Timer is a Thread subclass in Lib/threading.py for deferred execution; __name__.__eq__('Timer') returns True; new to extra230"]
    - [timer_qualname_eq,
       Timer.__qualname__.__eq__,
       ["Timer"],
       true,
       "threading.Timer.__qualname__ == 'Timer' — Timer is a top-level class with unqualified qualname 'Timer'; __qualname__.__eq__('Timer') returns True; new to extra230"]
    - [timer_module_eq,
       Timer.__module__.__eq__,
       ["threading"],
       true,
       "threading.Timer.__module__ == 'threading' — Timer is defined in Lib/threading.py; __module__.__eq__('threading') returns True; new to extra230"]
    - [timer_name_len_5,
       Timer.__name__.__len__,
       [],
       5,
       "threading.Timer.__name__.__len__() == 5 — 'Timer' has exactly 5 characters (T-i-m-e-r); __len__() returns 5; new to extra230"]
    - [timer_base_is_thread,
       Timer.__base__.__name__.__eq__,
       ["Thread"],
       true,
       "threading.Timer.__base__.__name__ == 'Thread' — Timer inherits from Thread; Timer.__base__ is Thread; __base__.__name__.__eq__('Thread') returns True; new to extra230"]

# ---------------------------------------------------------------------------
# Table 2: threading.TIMEOUT_MAX contracts
#
# threading.TIMEOUT_MAX.__class__.__name__ == 'float'
# threading.TIMEOUT_MAX.__gt__(0) == True
# threading.stack_size().__class__.__name__ == 'int'
# threading.active_count.__name__ == 'active_count'
# threading.active_count.__name__.__len__() == 12
#
# New to extra230.
# ---------------------------------------------------------------------------

table threading_extra230.timeout_max_and_stack_size:
  description: "threading.TIMEOUT_MAX is float >0; stack_size() is int; active_count name contracts; new to extra230"
  kind: python_call_eq
  category: behavioral
  id_prefix: threadingextra230timeoutmax

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_max_class_float,
       TIMEOUT_MAX.__class__.__name__.__eq__,
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant representing the maximum timeout value for blocking calls; __class__.__name__.__eq__('float') returns True; new to extra230"]
    - [timeout_max_gt_zero,
       TIMEOUT_MAX.__gt__,
       [0],
       true,
       "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a large positive float (9223372036.0); it is greater than 0; __gt__(0) returns True; new to extra230"]
    - [active_count_name_eq,
       active_count.__name__.__eq__,
       ["active_count"],
       true,
       "threading.active_count.__name__ == 'active_count' — active_count is a top-level function in threading.py that returns the number of alive threads; __name__.__eq__('active_count') returns True; new to extra230"]
    - [active_count_name_len_12,
       active_count.__name__.__len__,
       [],
       12,
       "threading.active_count.__name__.__len__() == 12 — 'active_count' has exactly 12 characters (a-c-t-i-v-e-_-c-o-u-n-t); __len__() returns 12; new to extra230"]
    - [active_count_module_eq,
       active_count.__module__.__eq__,
       ["threading"],
       true,
       "threading.active_count.__module__ == 'threading' — active_count is defined in Lib/threading.py; __module__.__eq__('threading') returns True; new to extra230"]

# ---------------------------------------------------------------------------
# Table 3: threading.local and current_thread identity contracts
#
# threading.local().__class__.__name__ == '_local'
# threading.current_thread.__name__ == 'current_thread'
# threading.current_thread.__name__.__len__() == 14
# threading.current_thread.__module__ == 'threading'
# threading.Timer.__qualname__.__len__() == 5
#
# New to extra230.
# ---------------------------------------------------------------------------

table threading_extra230.local_and_current_thread:
  description: "threading.local class name, current_thread identity contracts, Timer qualname length; new to extra230"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra230localcurr

  columns: [id, function, args, expected, description]
  rows:
    - [current_thread_name_eq,
       current_thread.__name__.__eq__,
       ["current_thread"],
       true,
       "threading.current_thread.__name__ == 'current_thread' — current_thread is a top-level function returning the calling thread object; __name__.__eq__('current_thread') returns True; new to extra230"]
    - [current_thread_name_len_14,
       current_thread.__name__.__len__,
       [],
       14,
       "threading.current_thread.__name__.__len__() == 14 — 'current_thread' has exactly 14 characters (c-u-r-r-e-n-t-_-t-h-r-e-a-d); __len__() returns 14; new to extra230"]
    - [current_thread_module_eq,
       current_thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.current_thread.__module__ == 'threading' — current_thread is defined in Lib/threading.py; __module__.__eq__('threading') returns True; new to extra230"]
    - [timer_qualname_len_5,
       Timer.__qualname__.__len__,
       [],
       5,
       "threading.Timer.__qualname__.__len__() == 5 — qualname 'Timer' has exactly 5 characters; __len__() returns 5; new to extra230"]
    - [timer_module_len_9,
       Timer.__module__.__len__,
       [],
       9,
       "threading.Timer.__module__.__len__() == 9 — 'threading' has exactly 9 characters (t-h-r-e-a-d-i-n-g); __len__() returns 9; new to extra230"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra230
# ---------------------------------------------------------------------------

invariant threading_extra230.timer_name_eq:
  description: "threading.Timer.__name__ == 'Timer'; new to extra230"
  kind: python_call_eq
  function: Timer.__name__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra230.timer_qualname_eq:
  description: "threading.Timer.__qualname__ == 'Timer'; new to extra230"
  kind: python_call_eq
  function: Timer.__qualname__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra230.timer_module_eq:
  description: "threading.Timer.__module__ == 'threading'; new to extra230"
  kind: python_call_eq
  function: Timer.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra230.timer_name_len_5:
  description: "threading.Timer.__name__.__len__() == 5 — 'Timer' has 5 characters; new to extra230"
  kind: python_call_eq
  function: Timer.__name__.__len__
  args: []
  expected: 5

invariant threading_extra230.timer_base_is_thread:
  description: "threading.Timer.__base__.__name__ == 'Thread' — Timer inherits from Thread; new to extra230"
  kind: python_call_eq
  function: Timer.__base__.__name__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra230.timeout_max_class_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float'; new to extra230"
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra230.timeout_max_gt_zero:
  description: "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a positive float; new to extra230"
  kind: python_call_eq
  function: TIMEOUT_MAX.__gt__
  args: [0]
  expected: true

invariant threading_extra230.active_count_name_eq:
  description: "threading.active_count.__name__ == 'active_count'; new to extra230"
  kind: python_call_eq
  function: active_count.__name__.__eq__
  args: ["active_count"]
  expected: true

invariant threading_extra230.active_count_name_len_12:
  description: "threading.active_count.__name__.__len__() == 12 — 'active_count' has 12 characters; new to extra230"
  kind: python_call_eq
  function: active_count.__name__.__len__
  args: []
  expected: 12

invariant threading_extra230.current_thread_name_eq:
  description: "threading.current_thread.__name__ == 'current_thread'; new to extra230"
  kind: python_call_eq
  function: current_thread.__name__.__eq__
  args: ["current_thread"]
  expected: true

invariant threading_extra230.current_thread_name_len_14:
  description: "threading.current_thread.__name__.__len__() == 14 — 'current_thread' has 14 characters; new to extra230"
  kind: python_call_eq
  function: current_thread.__name__.__len__
  args: []
  expected: 14

invariant threading_extra230.current_thread_module_eq:
  description: "threading.current_thread.__module__ == 'threading'; new to extra230"
  kind: python_call_eq
  function: current_thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra230.active_count_module_eq:
  description: "threading.active_count.__module__ == 'threading'; new to extra230"
  kind: python_call_eq
  function: active_count.__module__.__eq__
  args: ["threading"]
  expected: true
