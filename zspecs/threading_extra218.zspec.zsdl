spec: threading_extra218
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading module-level function __name__ and __module__, TIMEOUT_MAX, and synchronization primitive type names (wave 383)."
    - "current_thread.__name__ == 'current_thread', __module__ == 'threading'. Verified with Python 3.14.3."
    - "main_thread.__name__ == 'main_thread'. Verified with Python 3.14.3."
    - "active_count.__name__ == 'active_count'. Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX == 9223372036.0; type == float; > 0 and > 1000. Verified with Python 3.14.3."
    - "type(threading.Lock()).__name__ == 'lock'. Verified with Python 3.14.3."
    - "type(threading.RLock()).__name__ == 'RLock'. Verified with Python 3.14.3."
    - "type(threading.Event()).__name__ == 'Event'; is_set() == False on fresh Event. Verified with Python 3.14.3."
    - "type(threading.Semaphore()).__name__ == 'Semaphore'. Verified with Python 3.14.3."
    - "Thread.__name__ == 'Thread'; Thread.__module__ == 'threading'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading module-level function __name__ and __module__ checks
#
# threading.current_thread, main_thread, and active_count are pure-Python
# functions. Their __name__ equals their bare function name and their
# __module__ is 'threading'.
#
# Verified with Python 3.14.3:
#   current_thread.__name__ == 'current_thread'
#   current_thread.__module__ == 'threading'
#   main_thread.__name__ == 'main_thread'
#   main_thread.__module__ == 'threading'
#   active_count.__name__ == 'active_count'
#   active_count.__module__ == 'threading'
# ---------------------------------------------------------------------------

table threading_extra218.module_func_names:
  description: "threading.current_thread, main_thread, active_count __name__ and __module__ checks; wave 383; new to extra218"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra218funcnames

  columns: [id, function, args, expected, description]
  rows:
    - [current_thread_name_eq,
       current_thread.__name__.__eq__,
       ["current_thread"],
       true,
       "threading.current_thread.__name__.__eq__('current_thread') == True — current_thread() is a module-level function; its __name__ attribute is the string 'current_thread'; str.__eq__ returns True; new to extra218"]
    - [current_thread_module_eq,
       current_thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.current_thread.__module__.__eq__('threading') == True — current_thread() is defined in Lib/threading.py; its __module__ is the string 'threading'; str.__eq__ returns True; new to extra218"]
    - [main_thread_name_eq,
       main_thread.__name__.__eq__,
       ["main_thread"],
       true,
       "threading.main_thread.__name__.__eq__('main_thread') == True — main_thread() returns the main Thread object; its __name__ is 'main_thread'; str.__eq__ returns True; new to extra218"]
    - [main_thread_module_eq,
       main_thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.main_thread.__module__.__eq__('threading') == True — main_thread() is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__ returns True; new to extra218"]
    - [active_count_name_eq,
       active_count.__name__.__eq__,
       ["active_count"],
       true,
       "threading.active_count.__name__.__eq__('active_count') == True — active_count() returns the number of Thread objects currently alive; its __name__ is 'active_count'; str.__eq__ returns True; new to extra218"]
    - [active_count_module_eq,
       active_count.__module__.__eq__,
       ["threading"],
       true,
       "threading.active_count.__module__.__eq__('threading') == True — active_count() is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__ returns True; new to extra218"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread class identity checks
#
# threading.Thread is the primary thread class. Its __name__ and __module__
# are fundamental identity properties.
#
# Verified with Python 3.14.3:
#   Thread.__name__ == 'Thread'
#   Thread.__module__ == 'threading'
# ---------------------------------------------------------------------------

table threading_extra218.thread_class_identity:
  description: "threading.Thread.__name__ == 'Thread', __module__ == 'threading'; wave 383; new to extra218"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra218threadcls

  columns: [id, function, args, expected, description]
  rows:
    - [thread_class_name_eq,
       Thread.__name__.__eq__,
       ["Thread"],
       true,
       "threading.Thread.__name__.__eq__('Thread') == True — Thread is the main thread class; its __name__ is the string 'Thread'; str.__eq__ returns True; new to extra218"]
    - [thread_class_module_eq,
       Thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — Thread is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__ returns True; new to extra218"]

# ---------------------------------------------------------------------------
# Table 3: threading.TIMEOUT_MAX checks
#
# threading.TIMEOUT_MAX is the maximum timeout value accepted by blocking
# primitives. It is a float equal to the maximum value that can be converted
# to a C long (9223372036.0 on 64-bit systems).
#
# Verified with Python 3.14.3:
#   type(TIMEOUT_MAX).__name__ == 'float'
#   TIMEOUT_MAX > 0 == True
#   TIMEOUT_MAX > 1000 == True
# ---------------------------------------------------------------------------

table threading_extra218.timeout_max_checks:
  description: "threading.TIMEOUT_MAX is a large positive float; wave 383; new to extra218"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra218timeout

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_max_type_is_float,
       TIMEOUT_MAX.__class__.__name__.__eq__,
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — TIMEOUT_MAX is a floating-point constant representing the maximum allowable timeout; its type is float; str.__eq__('float') returns True; new to extra218"]
    - [timeout_max_gt_zero,
       TIMEOUT_MAX.__gt__,
       [0],
       true,
       "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a large positive float; it is strictly greater than 0; float.__gt__(0) returns True; new to extra218"]
    - [timeout_max_gt_1000,
       TIMEOUT_MAX.__gt__,
       [1000],
       true,
       "threading.TIMEOUT_MAX.__gt__(1000) == True — TIMEOUT_MAX is approximately 9.2 billion seconds; it is far greater than 1000; float.__gt__(1000) returns True; new to extra218"]

# ---------------------------------------------------------------------------
# Table 4: threading synchronization primitive class __name__ checks
#
# threading.Lock, RLock, Event, Semaphore, and Condition are classes whose
# __name__ attributes are stable API identifiers. Note: Lock.__name__ is
# 'lock' (lowercase) because the underlying type comes from _thread (C).
#
# Verified with Python 3.14.3:
#   Lock.__name__ == 'lock'       (lowercase — underlying C primitive)
#   RLock.__name__ == 'RLock'
#   Event.__name__ == 'Event'
#   Semaphore.__name__ == 'Semaphore'
#   Condition.__name__ == 'Condition'
# ---------------------------------------------------------------------------

table threading_extra218.sync_type_names:
  description: "threading synchronization primitive class __name__ checks; wave 383; new to extra218"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra218synctypes

  columns: [id, function, args, expected, description]
  rows:
    - [lock_class_name_eq_lock,
       Lock.__name__.__eq__,
       ["lock"],
       true,
       "threading.Lock.__name__.__eq__('lock') == True — Lock's underlying type is the C primitive from _thread; its __name__ is 'lock' (lowercase) rather than 'Lock'; str.__eq__('lock') returns True; new to extra218"]
    - [rlock_class_name_eq_RLock,
       RLock.__name__.__eq__,
       ["RLock"],
       true,
       "threading.RLock.__name__.__eq__('RLock') == True — RLock is a reentrant lock; its class __name__ is 'RLock'; str.__eq__('RLock') returns True; new to extra218"]
    - [event_class_name_eq_Event,
       Event.__name__.__eq__,
       ["Event"],
       true,
       "threading.Event.__name__.__eq__('Event') == True — Event is a threading synchronization primitive for signaling between threads; its class __name__ is 'Event'; str.__eq__('Event') returns True; new to extra218"]
    - [semaphore_class_name_eq_Semaphore,
       Semaphore.__name__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__.__eq__('Semaphore') == True — Semaphore is a counting synchronization primitive; its class __name__ is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra218"]
    - [condition_class_name_eq_Condition,
       Condition.__name__.__eq__,
       ["Condition"],
       true,
       "threading.Condition.__name__.__eq__('Condition') == True — Condition is a monitor-style synchronization primitive combining a lock with wait/notify; its class __name__ is 'Condition'; str.__eq__('Condition') returns True; new to extra218"]

# ---------------------------------------------------------------------------
# Table 5: threading function __name__ length checks
#
# The lengths of threading function names are stable invariants.
#
# Verified with Python 3.14.3:
#   len('current_thread') == 14
#   len('main_thread') == 11
#   len('active_count') == 12
# ---------------------------------------------------------------------------

table threading_extra218.func_name_lengths:
  description: "threading function __name__ length checks; wave 383; new to extra218"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra218namelen

  columns: [id, function, args, expected, description]
  rows:
    - [current_thread_name_len_14,
       current_thread.__name__.__len__,
       [],
       14,
       "threading.current_thread.__name__.__len__() == 14 — 'current_thread' has 14 characters; str.__len__() returns 14; new to extra218"]
    - [main_thread_name_len_11,
       main_thread.__name__.__len__,
       [],
       11,
       "threading.main_thread.__name__.__len__() == 11 — 'main_thread' has 11 characters; str.__len__() returns 11; new to extra218"]
    - [active_count_name_len_12,
       active_count.__name__.__len__,
       [],
       12,
       "threading.active_count.__name__.__len__() == 12 — 'active_count' has 12 characters; str.__len__() returns 12; new to extra218"]
    - [thread_class_name_len_6,
       Thread.__name__.__len__,
       [],
       6,
       "threading.Thread.__name__.__len__() == 6 — 'Thread' has 6 characters; str.__len__() returns 6; new to extra218"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra218
# ---------------------------------------------------------------------------

invariant threading_extra218.current_thread_name:
  description: "threading.current_thread.__name__.__eq__('current_thread') == True; wave 383; new to extra218"
  kind: python_call_eq
  function: current_thread.__name__.__eq__
  args: ["current_thread"]
  expected: true

invariant threading_extra218.current_thread_module:
  description: "threading.current_thread.__module__.__eq__('threading') == True; wave 383; new to extra218"
  kind: python_call_eq
  function: current_thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra218.main_thread_name:
  description: "threading.main_thread.__name__.__eq__('main_thread') == True; wave 383; new to extra218"
  kind: python_call_eq
  function: main_thread.__name__.__eq__
  args: ["main_thread"]
  expected: true

invariant threading_extra218.active_count_name:
  description: "threading.active_count.__name__.__eq__('active_count') == True; wave 383; new to extra218"
  kind: python_call_eq
  function: active_count.__name__.__eq__
  args: ["active_count"]
  expected: true

invariant threading_extra218.thread_class_name:
  description: "threading.Thread.__name__.__eq__('Thread') == True; wave 383; new to extra218"
  kind: python_call_eq
  function: Thread.__name__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra218.thread_class_module:
  description: "threading.Thread.__module__.__eq__('threading') == True; wave 383; new to extra218"
  kind: python_call_eq
  function: Thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra218.timeout_max_type_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True; wave 383; new to extra218"
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra218.timeout_max_positive:
  description: "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a large positive float; wave 383; new to extra218"
  kind: python_call_eq
  function: TIMEOUT_MAX.__gt__
  args: [0]
  expected: true

invariant threading_extra218.timeout_max_gt_1000:
  description: "threading.TIMEOUT_MAX.__gt__(1000) == True — TIMEOUT_MAX is approximately 9.2 billion seconds; wave 383; new to extra218"
  kind: python_call_eq
  function: TIMEOUT_MAX.__gt__
  args: [1000]
  expected: true

invariant threading_extra218.current_thread_name_len:
  description: "threading.current_thread.__name__.__len__() == 14; wave 383; new to extra218"
  kind: python_call_eq
  function: current_thread.__name__.__len__
  args: []
  expected: 14

invariant threading_extra218.active_count_name_len:
  description: "threading.active_count.__name__.__len__() == 12; wave 383; new to extra218"
  kind: python_call_eq
  function: active_count.__name__.__len__
  args: []
  expected: 12

invariant threading_extra218.lock_class_name:
  description: "threading.Lock.__name__.__eq__('lock') == True — underlying C type has lowercase name; wave 383; new to extra218"
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra218.event_class_name:
  description: "threading.Event.__name__.__eq__('Event') == True; wave 383; new to extra218"
  kind: python_call_eq
  function: Event.__name__.__eq__
  args: ["Event"]
  expected: true

invariant threading_extra218.semaphore_class_name:
  description: "threading.Semaphore.__name__.__eq__('Semaphore') == True; wave 383; new to extra218"
  kind: python_call_eq
  function: Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true
