spec: url_parse
version: ">=1.5.0"
backend: node(url-parse)

docs: https://www.npmjs.com/package/url-parse

provenance:
  derived_from:
    - "url-parse README — https://www.npmjs.com/package/url-parse"
    - "Test vectors verified with url-parse via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "url-parse source"
  notes:
    - "url-parse is an npm package. Install: npm install url-parse"
    - "Url(str).toString() normalizes a URL: lowercases scheme and host, adds trailing slash to bare origins."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns normalized URL string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table url_parse.toString:
  kind: node_factory_call_eq
  factory: ~
  method: toString
  category: normalize
  id_prefix: urlp

  columns: [id, factory_args, expected]
  rows:
    - [uppercase_scheme, ["HTTPS://EXAMPLE.COM/PATH"], "https://example.com/PATH"]
    - [bare_origin,      ["https://example.com"],      "https://example.com/"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:13:35Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
