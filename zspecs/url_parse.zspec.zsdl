spec: url_parse
version: ">=1.5.0"
backend: node(url-parse)

docs: https://www.npmjs.com/package/url-parse

provenance:
  derived_from:
    - "url-parse README — https://www.npmjs.com/package/url-parse"
    - "Test vectors verified with url-parse via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "url-parse source"
  notes:
    - "url-parse is an npm package. Install: npm install url-parse"
    - "new Url(str) parses a URL; returns object with protocol (includes colon), hostname, port, pathname, query (includes ?), hash (includes #), auth."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns parsed URL object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table url_parse.parse:
  kind: node_constructor_call_eq
  class: ~
  ctor_args: ["https://user:pass@example.com:8080/path?q=1#hash"]
  method: toJSON
  category: parse
  id_prefix: urlp

  columns: [id, args, expected]
  rows:
    - [full, [],
       {"slashes": true, "protocol": "https:", "hash": "#hash",
        "query": "?q=1", "pathname": "/path", "auth": "user:pass",
        "host": "example.com:8080", "port": "8080",
        "hostname": "example.com", "password": "pass",
        "username": "user", "origin": "https://example.com:8080",
        "href": "https://user:pass@example.com:8080/path?q=1#hash"}]
