spec: io_extra291
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Abstract base classes for I/O"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c, Lib/io.py"
  notes:
    - "io.IOBase.__module__ is 'io' (not '_io') because the io module re-exports the C extension types"
    - "RawIOBase, BufferedIOBase, TextIOBase inherit from internal C-level types (_RawIOBase, _BufferedIOBase, _TextIOBase)"
    - "FileIO.__bases__[0].__name__ is '_RawIOBase', BytesIO bases is '_BufferedIOBase', StringIO bases is '_TextIOBase'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table io_extra291.class_names:
  description: "__name__ attribute for io ABC and concrete classes"
  kind: python_call_eq
  category: identity
  id_prefix: io291n

  columns: [id, function, args, expected, description]
  rows:
    - [io291n001, io.IOBase.__name__.__eq__, ["IOBase"], true, "IOBase __name__"]
    - [io291n002, io.RawIOBase.__name__.__eq__, ["RawIOBase"], true, "RawIOBase __name__"]
    - [io291n003, io.BufferedIOBase.__name__.__eq__, ["BufferedIOBase"], true, "BufferedIOBase __name__"]
    - [io291n004, io.TextIOBase.__name__.__eq__, ["TextIOBase"], true, "TextIOBase __name__"]
    - [io291n005, io.FileIO.__name__.__eq__, ["FileIO"], true, "FileIO __name__"]
    - [io291n006, io.BytesIO.__name__.__eq__, ["BytesIO"], true, "BytesIO __name__"]
    - [io291n007, io.StringIO.__name__.__eq__, ["StringIO"], true, "StringIO __name__"]
    - [io291n008, io.BufferedReader.__name__.__eq__, ["BufferedReader"], true, "BufferedReader __name__"]
    - [io291n009, io.BufferedWriter.__name__.__eq__, ["BufferedWriter"], true, "BufferedWriter __name__"]

table io_extra291.base_class_names:
  description: "__bases__[0].__name__ for io ABC hierarchy"
  kind: python_call_eq
  category: identity
  id_prefix: io291b

  columns: [id, function, args, expected, description]
  rows:
    - [io291b001, "io.RawIOBase.__bases__[0].__name__.__eq__", ["_RawIOBase"], true, "RawIOBase base is _RawIOBase"]
    - [io291b002, "io.BufferedIOBase.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true, "BufferedIOBase base is _BufferedIOBase"]
    - [io291b003, "io.TextIOBase.__bases__[0].__name__.__eq__", ["_TextIOBase"], true, "TextIOBase base is _TextIOBase"]
    - [io291b004, "io.FileIO.__bases__[0].__name__.__eq__", ["_RawIOBase"], true, "FileIO base is _RawIOBase"]
    - [io291b005, "io.BytesIO.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true, "BytesIO base is _BufferedIOBase"]
    - [io291b006, "io.StringIO.__bases__[0].__name__.__eq__", ["_TextIOBase"], true, "StringIO base is _TextIOBase"]

invariant io_extra291.iobase_module:
  description: "io.IOBase.__module__ is 'io'"
  category: identity
  kind: python_call_eq
  function: io.IOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra291.buffered_reader_base:
  description: "BufferedReader.__bases__[0].__name__ is '_BufferedIOBase'"
  category: identity
  kind: python_call_eq
  function: "io.BufferedReader.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra291.buffered_writer_base:
  description: "BufferedWriter.__bases__[0].__name__ is '_BufferedIOBase'"
  category: identity
  kind: python_call_eq
  function: "io.BufferedWriter.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true
