spec: decimal_extra203
version: ">=3.9"
backend: python_module(_pydecimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/ — C extension implementation"
  notes:
    - "This spec covers: __code__ attributes of decimal Python-level functions via the pure-Python _pydecimal module, since decimal.getcontext/setcontext/localcontext in the decimal module are C-level builtins with no __code__ attribute."
    - "_pydecimal.getcontext.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 67108867 on Python 3.14.3."
    - "_pydecimal.setcontext.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 67108867."
    - "_pydecimal.localcontext.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 67108875."
    - "_pydecimal.getcontext.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 4."
    - "_pydecimal.setcontext.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 4."
    - "_pydecimal.localcontext.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 6."
    - "_pydecimal.getcontext.__code__.co_filename.__class__.__name__ == 'str' — co_filename is source file path string."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _pydecimal.getcontext.__code__ co_flags and co_stacksize — class names
#
# _pydecimal.getcontext is a Python function.
# __code__.co_flags.__class__.__name__ == 'int'  (value 67108867)
# __code__.co_stacksize.__class__.__name__ == 'int'  (value 4)
# __code__.co_filename.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table decimal_extra203.getcontext_code_attrs:
  description: "_pydecimal.getcontext.__code__ attribute types — co_flags and co_stacksize are int; co_filename is str; co_flags==67108867; co_stacksize==4; verified Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: decimalcoflags203

  columns: [id, function, args, expected, description]
  rows:
    - [getctx_coflags_cls,     getcontext.__code__.co_flags.__class__.__name__.__eq__,     ["int"], true,  "_pydecimal.getcontext.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 67108867; verified Python 3.14.3"]
    - [getctx_costacksize_cls, getcontext.__code__.co_stacksize.__class__.__name__.__eq__, ["int"], true,  "_pydecimal.getcontext.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 4; verified Python 3.14.3"]
    - [getctx_cofilename_cls,  getcontext.__code__.co_filename.__class__.__name__.__eq__,  ["str"], true,  "_pydecimal.getcontext.__code__.co_filename.__class__.__name__ == 'str' — source file path; verified Python 3.14.3"]
    - [getctx_coflags_not_str, getcontext.__code__.co_flags.__class__.__name__.__eq__,     ["str"], false, "_pydecimal.getcontext.__code__.co_flags.__class__.__name__ != 'str' — co_flags is int bitmask; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# _pydecimal.setcontext.__code__ co_flags and co_stacksize — class names
#
# _pydecimal.setcontext is a Python function.
# __code__.co_flags.__class__.__name__ == 'int'  (value 67108867)
# __code__.co_stacksize.__class__.__name__ == 'int'  (value 4)
# ---------------------------------------------------------------------------

table decimal_extra203.setcontext_code_attrs:
  description: "_pydecimal.setcontext.__code__ attribute types — co_flags and co_stacksize are int; co_flags==67108867; co_stacksize==4; verified Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: decimalcoflags203

  columns: [id, function, args, expected, description]
  rows:
    - [setctx_coflags_cls,      setcontext.__code__.co_flags.__class__.__name__.__eq__,      ["int"], true,  "_pydecimal.setcontext.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 67108867; same as getcontext; verified Python 3.14.3"]
    - [setctx_costacksize_cls,  setcontext.__code__.co_stacksize.__class__.__name__.__eq__,  ["int"], true,  "_pydecimal.setcontext.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 4; same as getcontext; verified Python 3.14.3"]
    - [setctx_cofilename_cls,   setcontext.__code__.co_filename.__class__.__name__.__eq__,   ["str"], true,  "_pydecimal.setcontext.__code__.co_filename.__class__.__name__ == 'str' — source file path; verified Python 3.14.3"]
    - [setctx_coflags_not_float, setcontext.__code__.co_flags.__class__.__name__.__eq__,     ["float"], false, "_pydecimal.setcontext.__code__.co_flags.__class__.__name__ != 'float' — co_flags is int; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# _pydecimal.localcontext.__code__ co_flags and co_stacksize — class names
#
# _pydecimal.localcontext is a Python function.
# __code__.co_flags.__class__.__name__ == 'int'  (value 67108875)
# __code__.co_stacksize.__class__.__name__ == 'int'  (value 6)
# ---------------------------------------------------------------------------

table decimal_extra203.localcontext_code_attrs:
  description: "_pydecimal.localcontext.__code__ attribute types — co_flags and co_stacksize are int; co_flags==67108875; co_stacksize==6; larger than getcontext/setcontext; verified Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: decimalcoflags203

  columns: [id, function, args, expected, description]
  rows:
    - [localctx_coflags_cls,      localcontext.__code__.co_flags.__class__.__name__.__eq__,      ["int"], true,  "_pydecimal.localcontext.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 67108875; differs from getcontext/setcontext; verified Python 3.14.3"]
    - [localctx_costacksize_cls,  localcontext.__code__.co_stacksize.__class__.__name__.__eq__,  ["int"], true,  "_pydecimal.localcontext.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 6; larger than getcontext/setcontext (4); verified Python 3.14.3"]
    - [localctx_coflags_not_str,  localcontext.__code__.co_flags.__class__.__name__.__eq__,      ["str"], false, "_pydecimal.localcontext.__code__.co_flags.__class__.__name__ != 'str' — co_flags is int bitmask; verified Python 3.14.3"]
    - [localctx_cofilename_cls,   localcontext.__code__.co_filename.__class__.__name__.__eq__,   ["str"], true,  "_pydecimal.localcontext.__code__.co_filename.__class__.__name__ == 'str' — source file path; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — decimal_extra203
# ---------------------------------------------------------------------------

invariant decimal_extra203.getcontext_co_flags_class_name:
  description: "_pydecimal.getcontext.__code__.co_flags.__class__.__name__ == 'int' — co_flags is a CPython integer bitmask encoding function compilation flags; value 67108867 on Python 3.14.3; decimal.getcontext is a C builtin but _pydecimal.getcontext is the inspectable Python implementation; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: getcontext.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant decimal_extra203.setcontext_co_flags_class_name:
  description: "_pydecimal.setcontext.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 67108867 on Python 3.14.3; same bitmask as getcontext; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: setcontext.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant decimal_extra203.localcontext_co_flags_class_name:
  description: "_pydecimal.localcontext.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 67108875 on Python 3.14.3; differs from getcontext/setcontext (67108867) reflecting localcontext's context-manager characteristics; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: localcontext.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant decimal_extra203.getcontext_co_stacksize_class_name:
  description: "_pydecimal.getcontext.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is the maximum frame stack depth; value 4 on Python 3.14.3; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: getcontext.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant decimal_extra203.setcontext_co_stacksize_class_name:
  description: "_pydecimal.setcontext.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 4 on Python 3.14.3; same stack depth as getcontext; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: setcontext.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant decimal_extra203.localcontext_co_stacksize_class_name:
  description: "_pydecimal.localcontext.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 6 on Python 3.14.3; larger than getcontext/setcontext (4) due to localcontext's context-manager generator protocol; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: localcontext.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant decimal_extra203.getcontext_co_filename_class_name:
  description: "_pydecimal.getcontext.__code__.co_filename.__class__.__name__ == 'str' — co_filename records the source file path where getcontext was defined in _pydecimal.py; always a string in CPython; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: getcontext.__code__.co_filename.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra203.getcontext_co_flags_not_str:
  description: "_pydecimal.getcontext.__code__.co_flags.__class__.__name__ != 'str' — co_flags is always an integer in CPython; encodes compilation flags like CO_OPTIMIZED and CO_NEWLOCALS as bit positions; never a string; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: getcontext.__code__.co_flags.__class__.__name__.__eq__
  args: ["str"]
  expected: false
