spec: inspect_extra1066
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks inspect.Parameter class attributes (empty, POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD), BoundArguments class module, and Signature class module and qualname"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1066.parameter_class_attributes:
  description: "inspect.Parameter class attribute kind constant identity checks"
  kind: python_call_eq
  category: parameter_class_attrs
  id_prefix: ip1066pa
  columns: [id, function, args, expected]
  rows:
    - [ip1066pa001, inspect.Parameter.__qualname__.__eq__,                          ["Parameter"],                     true]
    - [ip1066pa002, inspect.Parameter.__module__.__eq__,                            ["inspect"],                       true]
    - [ip1066pa003, inspect.Parameter.__class__.__name__.__eq__,                    ["type"],                          true]
    - [ip1066pa004, inspect.Parameter.empty.__class__.__name__.__eq__,              ["_empty"],                        true]
    - [ip1066pa005, inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__,    ["_ParameterKind"],                true]
    - [ip1066pa006, inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__, ["_ParameterKind"],             true]
    - [ip1066pa007, inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__,     ["_ParameterKind"],                true]
    - [ip1066pa008, inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__,       ["_ParameterKind"],                true]
    - [ip1066pa009, inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__,        ["_ParameterKind"],                true]

table inspect_extra1066.signature_boundarguments_class:
  description: "inspect.Signature and inspect.BoundArguments class __module__ and __qualname__ checks"
  kind: python_call_eq
  category: signature_class
  id_prefix: ip1066sg
  columns: [id, function, args, expected]
  rows:
    - [ip1066sg001, inspect.Signature.__qualname__.__eq__,                          ["Signature"],                     true]
    - [ip1066sg002, inspect.Signature.__module__.__eq__,                            ["inspect"],                       true]
    - [ip1066sg003, inspect.Signature.__class__.__name__.__eq__,                    ["type"],                          true]
    - [ip1066sg004, inspect.BoundArguments.__qualname__.__eq__,                     ["BoundArguments"],                true]
    - [ip1066sg005, inspect.BoundArguments.__module__.__eq__,                       ["inspect"],                       true]
    - [ip1066sg006, inspect.BoundArguments.__class__.__name__.__eq__,               ["type"],                          true]
    - [ip1066sg007, inspect.Signature.__init__.__qualname__.__eq__,                 ["Signature.__init__"],            true]
    - [ip1066sg008, inspect.BoundArguments.__init__.__qualname__.__eq__,            ["BoundArguments.__init__"],       true]

table inspect_extra1066.parameter_kind_values:
  description: "inspect.Parameter kind constant integer value checks and _ParameterKind qualname"
  kind: python_call_eq
  category: parameter_kind_values
  id_prefix: ip1066pk
  columns: [id, function, args, expected]
  rows:
    - [ip1066pk001, inspect.Parameter.POSITIONAL_ONLY.__class__.__qualname__.__eq__,        ["_ParameterKind"],        true]
    - [ip1066pk002, inspect.Parameter.POSITIONAL_ONLY.__class__.__module__.__eq__,          ["inspect"],               true]
    - [ip1066pk003, inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__qualname__.__eq__,  ["_ParameterKind"],        true]
    - [ip1066pk004, inspect.Parameter.VAR_POSITIONAL.__class__.__qualname__.__eq__,         ["_ParameterKind"],        true]
    - [ip1066pk005, inspect.Parameter.KEYWORD_ONLY.__class__.__qualname__.__eq__,           ["_ParameterKind"],        true]
    - [ip1066pk006, inspect.Parameter.VAR_KEYWORD.__class__.__qualname__.__eq__,            ["_ParameterKind"],        true]
    - [ip1066pk007, inspect.Parameter.empty.__class__.__qualname__.__eq__,                  ["_empty"],                true]
    - [ip1066pk008, inspect.Parameter.empty.__class__.__module__.__eq__,                    ["inspect"],               true]
