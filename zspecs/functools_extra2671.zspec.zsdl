spec: functools_extra2671
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 625 theme: __sub__, __floordiv__, and __mod__ dict-presence checks (subtraction and integer division arithmetic)."
    - "functools.partial is a callable wrapper; it does not implement subtraction or integer division arithmetic protocols."
    - "functools.partialmethod is a descriptor; it similarly defines none of __sub__, __floordiv__, or __mod__."
    - "functools.cached_property is a data descriptor (defines __get__, __set__, __delete__) but not __sub__, __floordiv__, or __mod__."
    - "functools.singledispatchmethod is a descriptor wrapper; it does not define __sub__, __floordiv__, or __mod__."
    - "None of the functools public classes define __sub__, __floordiv__, or __mod__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __sub__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2671.sub_protocol:
  description: "__sub__ is absent from all functools class __dict__s — none implement subtraction"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2671

  columns: [id, function, args, expected]
  rows:
    - ["ft2671001", "functools.partial.__dict__.__contains__",              ["__sub__"], false]
    - ["ft2671002", "functools.partialmethod.__dict__.__contains__",        ["__sub__"], false]
    - ["ft2671003", "functools.cached_property.__dict__.__contains__",      ["__sub__"], false]
    - ["ft2671004", "functools.singledispatchmethod.__dict__.__contains__",  ["__sub__"], false]

# ---------------------------------------------------------------------------
# __floordiv__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2671.floordiv_protocol:
  description: "__floordiv__ is absent from all functools class __dict__s — none implement floor division"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2671

  columns: [id, function, args, expected]
  rows:
    - ["ft2671005", "functools.partial.__dict__.__contains__",              ["__floordiv__"], false]
    - ["ft2671006", "functools.partialmethod.__dict__.__contains__",        ["__floordiv__"], false]
    - ["ft2671007", "functools.cached_property.__dict__.__contains__",      ["__floordiv__"], false]
    - ["ft2671008", "functools.singledispatchmethod.__dict__.__contains__",  ["__floordiv__"], false]

# ---------------------------------------------------------------------------
# __mod__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2671.mod_protocol:
  description: "__mod__ is absent from all functools class __dict__s — none implement modulo"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2671

  columns: [id, function, args, expected]
  rows:
    - ["ft2671009", "functools.partial.__dict__.__contains__",              ["__mod__"], false]
    - ["ft2671010", "functools.partialmethod.__dict__.__contains__",        ["__mod__"], false]
    - ["ft2671011", "functools.cached_property.__dict__.__contains__",      ["__mod__"], false]
    - ["ft2671012", "functools.singledispatchmethod.__dict__.__contains__",  ["__mod__"], false]

# ---------------------------------------------------------------------------
# Combined view — partial and partialmethod vs. all three protocols
# ---------------------------------------------------------------------------

table functools_extra2671.partial_arithmetic_combined:
  description: "functools.partial and functools.partialmethod define none of __sub__, __floordiv__, __mod__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2671

  columns: [id, function, args, expected]
  rows:
    - ["ft2671013", "functools.partial.__dict__.__contains__",       ["__sub__"],      false]
    - ["ft2671014", "functools.partial.__dict__.__contains__",       ["__floordiv__"], false]
    - ["ft2671015", "functools.partial.__dict__.__contains__",       ["__mod__"],      false]
    - ["ft2671016", "functools.partialmethod.__dict__.__contains__", ["__sub__"],      false]
    - ["ft2671017", "functools.partialmethod.__dict__.__contains__", ["__floordiv__"], false]
    - ["ft2671018", "functools.partialmethod.__dict__.__contains__", ["__mod__"],      false]
