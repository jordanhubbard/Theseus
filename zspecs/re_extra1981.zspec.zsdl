spec: re_extra1981
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py, Modules/_sre.c"
    - "re_extra1966.zspec.zsdl — covers __enter__/__exit__/__del__ dict-presence"
    - "any proprietary source"
  notes:
    - "Wave 579 (_extra1981): __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence checks."
    - "re.Pattern and re.Match are C-level types (_sre); neither defines __sizeof__ at the Python level."
    - "re.error is an alias for re.PatternError since Python 3.13; defines no memory/rounding protocol."
    - "re.RegexFlag is an IntFlag enum subclass; it inherits __sizeof__ from object but does not define it."
    - "None of the re types define __length_hint__ — regex objects are not length-hintable iterators."
    - "None of the re types define __floor__, __ceil__, or __trunc__ — regex objects are not numeric."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __sizeof__ dict-presence — re types
# re.Pattern and re.Match are C-extension types; __sizeof__ is not overridden
# at the Python level in any of the public re types.
# ---------------------------------------------------------------------------

table re_extra1981.sizeof_protocol:
  description: "re type __dict__.__contains__('__sizeof__') — all False (no Python-level __sizeof__ override)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1981

  columns: [id, function, args, expected]
  rows:
    - ["re1981001", "re.Pattern.__dict__.__contains__",   ["__sizeof__"], false]
    - ["re1981002", "re.Match.__dict__.__contains__",     ["__sizeof__"], false]
    - ["re1981003", "re.error.__dict__.__contains__",     ["__sizeof__"], false]
    - ["re1981004", "re.RegexFlag.__dict__.__contains__", ["__sizeof__"], false]

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — re types
# __length_hint__ (PEP 424) is an iterator length estimation protocol.
# re.Pattern and re.Match are not iterators; none define __length_hint__.
# ---------------------------------------------------------------------------

table re_extra1981.length_hint_protocol:
  description: "re type __dict__.__contains__('__length_hint__') — all False (not length-hintable iterators)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1981

  columns: [id, function, args, expected]
  rows:
    - ["re1981005", "re.Pattern.__dict__.__contains__",   ["__length_hint__"], false]
    - ["re1981006", "re.Match.__dict__.__contains__",     ["__length_hint__"], false]
    - ["re1981007", "re.error.__dict__.__contains__",     ["__length_hint__"], false]
    - ["re1981008", "re.RegexFlag.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# __floor__ dict-presence — re types
# re types are not numeric; the math rounding protocol does not apply.
# ---------------------------------------------------------------------------

table re_extra1981.floor_protocol:
  description: "re type __dict__.__contains__('__floor__') — all False (non-numeric types)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1981

  columns: [id, function, args, expected]
  rows:
    - ["re1981009",  "re.Pattern.__dict__.__contains__",   ["__floor__"], false]
    - ["re1981010", "re.Match.__dict__.__contains__",     ["__floor__"], false]
    - ["re1981011", "re.error.__dict__.__contains__",     ["__floor__"], false]
    - ["re1981012", "re.RegexFlag.__dict__.__contains__", ["__floor__"], false]

