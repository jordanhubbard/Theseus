spec: abc_extra212
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.ABC.__subclasshook__ is a builtin_function_or_method (C-level classmethod)."
    - "abc.ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__'."
    - "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'."
    - "abc.get_cache_token is a C builtin with __module__ == '_abc'."
    - "abc.update_abstractmethods is pure Python with co_argcount == 1."
    - "abc.abstractmethod.__module__ == 'abc'."
    - "verified with Python 3.14.3."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC.__subclasshook__ identity — extra212 namespace
#
# ABC.__subclasshook__ is a C-level classmethod descriptor; its __name__
# and __qualname__ are stable identifiers.
# ---------------------------------------------------------------------------

table abc_extra212.subclasshook_identity:
  description: "abc.ABC.__subclasshook__ name and qualname checks in extra212 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc212hook

  columns: [id, function, args, expected, description]
  rows:
    - [hook_name,     ABC.__subclasshook__.__name__.__eq__,     ["__subclasshook__"],      true, "ABC.__subclasshook__.__name__ == '__subclasshook__'"]
    - [hook_qualname, ABC.__subclasshook__.__qualname__.__eq__, ["ABC.__subclasshook__"],   true, "ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__'"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__subclasscheck__ identity — extra212 namespace
# ---------------------------------------------------------------------------

table abc_extra212.subclasscheck_identity:
  description: "abc.ABCMeta.__subclasscheck__ name and qualname checks in extra212 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc212check

  columns: [id, function, args, expected, description]
  rows:
    - [check_name,     ABCMeta.__subclasscheck__.__name__.__eq__,     ["__subclasscheck__"],          true, "ABCMeta.__subclasscheck__.__name__ == '__subclasscheck__'"]
    - [check_qualname, ABCMeta.__subclasscheck__.__qualname__.__eq__, ["ABCMeta.__subclasscheck__"],   true, "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'"]

# ---------------------------------------------------------------------------
# abc.ABC class membership checks — extra212 namespace
#
# ABC must expose both __abstractmethods__ and __subclasshook__ in its dir().
# ---------------------------------------------------------------------------

table abc_extra212.abc_dir_membership:
  description: "abc.ABC dir() membership checks in extra212 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc212dir

  columns: [id, function, args, expected, description]
  rows:
    - [has_abstractmethods, ABC.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true, "ABC.__abstractmethods__ is a frozenset"]
    - [abc_name,            ABC.__name__.__eq__,                               ["ABC"],       true, "abc.ABC.__name__ == 'ABC'"]
    - [abc_module,          ABC.__module__.__eq__,                             ["abc"],       true, "abc.ABC.__module__ == 'abc'"]

# ---------------------------------------------------------------------------
# abc.ABCMeta class identity — extra212 namespace
# ---------------------------------------------------------------------------

table abc_extra212.abcmeta_identity:
  description: "abc.ABCMeta __name__, __module__, and register qualname checks in extra212 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc212meta

  columns: [id, function, args, expected, description]
  rows:
    - [meta_name,     ABCMeta.__name__.__eq__,             ["ABCMeta"],             true, "abc.ABCMeta.__name__ == 'ABCMeta'"]
    - [meta_module,   ABCMeta.__module__.__eq__,           ["abc"],                 true, "abc.ABCMeta.__module__ == 'abc'"]
    - [register_name, ABCMeta.register.__name__.__eq__,    ["register"],            true, "ABCMeta.register.__name__ == 'register'"]
    - [register_qual, ABCMeta.register.__qualname__.__eq__, ["ABCMeta.register"],   true, "ABCMeta.register.__qualname__ == 'ABCMeta.register'"]

# ---------------------------------------------------------------------------
# abc.get_cache_token identity — extra212 namespace
#
# get_cache_token is a C builtin; its __module__ is '_abc' (the C extension),
# not 'abc'.
# ---------------------------------------------------------------------------

table abc_extra212.get_cache_token_identity:
  description: "abc.get_cache_token name and module checks in extra212 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc212gct

  columns: [id, function, args, expected, description]
  rows:
    - [gct_name,   get_cache_token.__name__.__eq__,   ["get_cache_token"], true, "abc.get_cache_token.__name__ == 'get_cache_token'"]
    - [gct_module, get_cache_token.__module__.__eq__, ["_abc"],            true, "abc.get_cache_token.__module__ == '_abc'"]

# ---------------------------------------------------------------------------
# abc.update_abstractmethods identity — extra212 namespace
#
# update_abstractmethods is pure Python with one argument (cls); its
# co_argcount is 1 and co_varnames begins with 'cls'.
# ---------------------------------------------------------------------------

table abc_extra212.update_abstractmethods_identity:
  description: "abc.update_abstractmethods name, qualname, and module checks in extra212 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc212updabm

  columns: [id, function, args, expected, description]
  rows:
    - [upd_name,    update_abstractmethods.__name__.__eq__,    ["update_abstractmethods"], true, "abc.update_abstractmethods.__name__ == 'update_abstractmethods'"]
    - [upd_qualname, update_abstractmethods.__qualname__.__eq__, ["update_abstractmethods"], true, "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods'"]
    - [upd_module,  update_abstractmethods.__module__.__eq__,  ["abc"],                    true, "abc.update_abstractmethods.__module__ == 'abc'"]
    - [upd_argcount, update_abstractmethods.__code__.co_argcount.__eq__, [1],             true, "abc.update_abstractmethods.__code__.co_argcount == 1"]

# ---------------------------------------------------------------------------
# abc.abstractmethod identity — extra212 namespace
# ---------------------------------------------------------------------------

table abc_extra212.abstractmethod_identity:
  description: "abc.abstractmethod name, qualname, module checks in extra212 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc212abmeth

  columns: [id, function, args, expected, description]
  rows:
    - [abmeth_name,    abstractmethod.__name__.__eq__,    ["abstractmethod"], true, "abc.abstractmethod.__name__ == 'abstractmethod'"]
    - [abmeth_qualname, abstractmethod.__qualname__.__eq__, ["abstractmethod"], true, "abc.abstractmethod.__qualname__ == 'abstractmethod'"]
    - [abmeth_module,  abstractmethod.__module__.__eq__,  ["abc"],            true, "abc.abstractmethod.__module__ == 'abc'"]

# ---------------------------------------------------------------------------
# abc.ABC.__subclasshook__ name standalone — extra212 namespace
# ---------------------------------------------------------------------------

invariant abc_extra212.subclasshook_name:
  description: "abc.ABC.__subclasshook__.__name__ == '__subclasshook__'"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__subclasshook__.__name__.__eq__
  args: ["__subclasshook__"]
  expected: true

# ---------------------------------------------------------------------------
# abc.update_abstractmethods argcount standalone — extra212 namespace
# ---------------------------------------------------------------------------

invariant abc_extra212.update_abstractmethods_argcount:
  description: "abc.update_abstractmethods.__code__.co_argcount == 1"
  category: identity
  kind: python_call_eq
  function: abc.update_abstractmethods.__code__.co_argcount.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# abc.get_cache_token qualname standalone — extra212 namespace
# ---------------------------------------------------------------------------

invariant abc_extra212.get_cache_token_qualname:
  description: "abc.get_cache_token.__qualname__ == 'get_cache_token'"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__qualname__.__eq__
  args: ["get_cache_token"]
  expected: true
