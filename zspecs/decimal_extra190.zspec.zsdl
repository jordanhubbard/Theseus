spec: decimal_extra190
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra189.zspec.zsdl."
    - "This spec covers decimal special values and signals: InvalidOperation, DivisionByZero, Overflow class identity — __name__, __module__, __bases__[0].__name__, and name lengths."
    - "decimal.InvalidOperation.__name__ == 'InvalidOperation' (len=16); confirmed Python 3.14.3 macOS."
    - "decimal.InvalidOperation.__module__ == 'decimal' (len=7); despite the C accelerator being _decimal, all signal classes report __module__=='decimal'; confirmed Python 3.14.3 macOS."
    - "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' (len=16); InvalidOperation inherits from DecimalException; confirmed Python 3.14.3 macOS."
    - "decimal.DivisionByZero.__name__ == 'DivisionByZero' (len=14); confirmed Python 3.14.3 macOS."
    - "decimal.DivisionByZero.__module__ == 'decimal' (len=7); same module as InvalidOperation; confirmed Python 3.14.3 macOS."
    - "decimal.Overflow.__name__ == 'Overflow' (len=8); shortest signal class name in spec; confirmed Python 3.14.3 macOS."
    - "decimal.Overflow.__module__ == 'decimal' (len=7); same module as all other signal classes; confirmed Python 3.14.3 macOS."
    - "decimal.InvalidOperation.__name__.__len__() == 16 — I(1)n(2)v(3)a(4)l(5)i(6)d(7)O(8)p(9)e(10)r(11)a(12)t(13)i(14)o(15)n(16); same length as DecimalException; confirmed Python 3.14.3 macOS."
    - "Name length ordering: Overflow(8) < DivisionByZero(14) < InvalidOperation(16)==DecimalException(16); confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal signal class __name__ equality
# InvalidOperation(16), DivisionByZero(14), Overflow(8)
# ---------------------------------------------------------------------------

table decimal_extra190.signal_class_names:
  description: "decimal signal class __name__ values: InvalidOperation='InvalidOperation'(16), DivisionByZero='DivisionByZero'(14), Overflow='Overflow'(8)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalsignals190

  columns: [id, function, args, expected, description]
  rows:
    - [invalidop_name_eq,   decimal.InvalidOperation.__name__.__eq__, ["InvalidOperation"], true, "decimal.InvalidOperation.__name__ == 'InvalidOperation' (len=16); confirmed Python 3.14.3 macOS"]
    - [divbyzero_name_eq,   decimal.DivisionByZero.__name__.__eq__,   ["DivisionByZero"],   true, "decimal.DivisionByZero.__name__ == 'DivisionByZero' (len=14); confirmed Python 3.14.3 macOS"]
    - [overflow_name_eq,    decimal.Overflow.__name__.__eq__,         ["Overflow"],         true, "decimal.Overflow.__name__ == 'Overflow' (len=8); shortest signal class name in spec; confirmed Python 3.14.3 macOS"]
    - [invalidop_name_len,  decimal.InvalidOperation.__name__.__len__, [], 16, "decimal.InvalidOperation.__name__.__len__() == 16; longest signal class name in spec; confirmed Python 3.14.3 macOS"]
    - [overflow_name_len,   decimal.Overflow.__name__.__len__,        [], 8,  "decimal.Overflow.__name__.__len__() == 8; shortest signal class name in spec; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal signal class __module__ equality
# all report 'decimal' (len=7)
# ---------------------------------------------------------------------------

table decimal_extra190.signal_class_modules:
  description: "decimal signal class __module__ values: InvalidOperation, DivisionByZero, Overflow — all == 'decimal' (len=7)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalsignals190

  columns: [id, function, args, expected, description]
  rows:
    - [invalidop_module_eq,  decimal.InvalidOperation.__module__.__eq__, ["decimal"], true, "decimal.InvalidOperation.__module__ == 'decimal' (len=7); confirmed Python 3.14.3 macOS"]
    - [divbyzero_module_eq,  decimal.DivisionByZero.__module__.__eq__,   ["decimal"], true, "decimal.DivisionByZero.__module__ == 'decimal' (len=7); same module as InvalidOperation; confirmed Python 3.14.3 macOS"]
    - [overflow_module_eq,   decimal.Overflow.__module__.__eq__,         ["decimal"], true, "decimal.Overflow.__module__ == 'decimal' (len=7); same module as InvalidOperation; confirmed Python 3.14.3 macOS"]
    - [invalidop_module_len, decimal.InvalidOperation.__module__.__len__, [], 7, "decimal.InvalidOperation.__module__.__len__() == 7 — d(1)e(2)c(3)i(4)m(5)a(6)l(7); confirmed Python 3.14.3 macOS"]
    - [overflow_module_len,  decimal.Overflow.__module__.__len__,         [], 7, "decimal.Overflow.__module__.__len__() == 7; same length as InvalidOperation and DivisionByZero modules; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal signal base class identity
# all three inherit from DecimalException (len=16)
# ---------------------------------------------------------------------------

table decimal_extra190.signal_base_class_identity:
  description: "decimal signal base class identity: InvalidOperation, DivisionByZero, Overflow — all __bases__[0].__name__ == 'DecimalException' (len=16)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalsignals190

  columns: [id, function, args, expected, description]
  rows:
    - [invalidop_base_eq,  "decimal.InvalidOperation.__bases__[0].__name__.__eq__", ["DecimalException"], true, "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' (len=16); InvalidOperation inherits from DecimalException; confirmed Python 3.14.3 macOS"]
    - [divbyzero_base_eq,  "decimal.DivisionByZero.__bases__[0].__name__.__eq__",   ["DecimalException"], true, "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException' (len=16); DivisionByZero inherits from DecimalException; confirmed Python 3.14.3 macOS"]
    - [overflow_base_eq,   "decimal.Overflow.__bases__[0].__name__.__eq__",         ["DecimalException"], true, "decimal.Overflow.__bases__[0].__name__ == 'DecimalException' (len=16); Overflow inherits from DecimalException; confirmed Python 3.14.3 macOS"]
    - [invalidop_base_len, "decimal.InvalidOperation.__bases__[0].__name__.__len__", [], 16, "decimal.InvalidOperation.__bases__[0].__name__.__len__() == 16; 'DecimalException' same length as 'InvalidOperation'; confirmed Python 3.14.3 macOS"]
    - [divbyzero_name_len, decimal.DivisionByZero.__name__.__len__,                   [], 14, "decimal.DivisionByZero.__name__.__len__() == 14; between Overflow(8) and InvalidOperation(16); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra190.invalidoperation_name_eq:
  description: "decimal.InvalidOperation.__name__ == 'InvalidOperation' — class name string length 16 ('InvalidOperation'); InvalidOperation is the decimal signal raised for invalid arithmetic operations such as 0/0 or operations on NaN; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.InvalidOperation.__name__.__eq__
  args: ["InvalidOperation"]
  expected: true

invariant decimal_extra190.invalidoperation_module_eq:
  description: "decimal.InvalidOperation.__module__ == 'decimal' — the signal class is defined in the decimal module (len=7); despite the C accelerator _decimal, all public signal classes report __module__=='decimal' consistent with the public API; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.InvalidOperation.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra190.invalidoperation_base_name_eq:
  description: "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' — InvalidOperation inherits directly from DecimalException (len=16); DecimalException is the common base for all decimal signal classes and itself inherits from ArithmeticError; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.InvalidOperation.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra190.divisionbyzero_name_eq:
  description: "decimal.DivisionByZero.__name__ == 'DivisionByZero' — class name string length 14 ('DivisionByZero'); DivisionByZero is raised when a non-infinite number is divided by zero; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.DivisionByZero.__name__.__eq__
  args: ["DivisionByZero"]
  expected: true

invariant decimal_extra190.divisionbyzero_module_eq:
  description: "decimal.DivisionByZero.__module__ == 'decimal' — same module as InvalidOperation and Overflow (len=7); all decimal signal classes report the public module name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.DivisionByZero.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra190.overflow_name_eq:
  description: "decimal.Overflow.__name__ == 'Overflow' — class name string length 8 ('Overflow'); this is the shortest signal class name in the spec; Overflow is raised when the exponent of a result exceeds the largest allowable value; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Overflow.__name__.__eq__
  args: ["Overflow"]
  expected: true

invariant decimal_extra190.overflow_module_eq:
  description: "decimal.Overflow.__module__ == 'decimal' — same module as InvalidOperation and DivisionByZero (len=7); all three signal classes examined in this spec agree on the module name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Overflow.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra190.invalidoperation_name_len:
  description: "decimal.InvalidOperation.__name__.__len__() == 16 — 'InvalidOperation' has 16 characters: I(1)n(2)v(3)a(4)l(5)i(6)d(7)O(8)p(9)e(10)r(11)a(12)t(13)i(14)o(15)n(16); this is the longest signal class name in the spec and equals the length of 'DecimalException'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.InvalidOperation.__name__.__len__
  args: []
  expected: 16
