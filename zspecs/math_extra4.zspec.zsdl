spec: math_extra4
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl and prior math_extra specs."
    - "Focus: __module__ and __name__ for math functions not yet covered; additional math constants and function behaviors."
    - "math.tau == 2 * math.pi (approx 6.283185307179586)."
    - "math.inf is float infinity; math.isinf(math.inf) == True."
    - "math.nan is float NaN; math.isnan(math.nan) == True."
    - "math.comb(5, 2) == 10; math.perm(5, 2) == 20."
    - "math.prod([1, 2, 3, 4]) == 24."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table math_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [comb,  comb.__name__.__eq__,  ["comb"],  true]
    - [perm,  perm.__name__.__eq__,  ["perm"],  true]
    - [prod,  prod.__name__.__eq__,  ["prod"],  true]
    - [isqrt, isqrt.__name__.__eq__, ["isqrt"], true]
    - [dist,  dist.__name__.__eq__,  ["dist"],  true]
    - [lcm,   lcm.__name__.__eq__,   ["lcm"],   true]

table math_extra4.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [comb,  comb.__module__.__eq__,  ["math"], true]
    - [perm,  perm.__module__.__eq__,  ["math"], true]
    - [prod,  prod.__module__.__eq__,  ["math"], true]
    - [isqrt, isqrt.__module__.__eq__, ["math"], true]

invariant math_extra4.comb.five_choose_two:
  description: "math.comb(5, 2) == 10"
  category: combinatorics
  kind: python_call_eq
  function: comb
  args: [5, 2]
  expected: 10

invariant math_extra4.comb.five_choose_zero:
  description: "math.comb(5, 0) == 1"
  category: combinatorics
  kind: python_call_eq
  function: comb
  args: [5, 0]
  expected: 1

invariant math_extra4.perm.five_pick_two:
  description: "math.perm(5, 2) == 20"
  category: combinatorics
  kind: python_call_eq
  function: perm
  args: [5, 2]
  expected: 20

invariant math_extra4.perm.five_pick_zero:
  description: "math.perm(5, 0) == 1"
  category: combinatorics
  kind: python_call_eq
  function: perm
  args: [5, 0]
  expected: 1

invariant math_extra4.prod.four_elements:
  description: "math.prod([1, 2, 3, 4]) == 24"
  category: prod
  kind: python_call_eq
  function: prod
  args: [[1, 2, 3, 4]]
  expected: 24

invariant math_extra4.prod.empty:
  description: "math.prod([]) == 1 — empty product is 1"
  category: prod
  kind: python_call_eq
  function: prod
  args: [[]]
  expected: 1

invariant math_extra4.isqrt.nine:
  description: "math.isqrt(9) == 3"
  category: isqrt
  kind: python_call_eq
  function: isqrt
  args: [9]
  expected: 3

invariant math_extra4.isqrt.ten:
  description: "math.isqrt(10) == 3 — floor of sqrt(10)"
  category: isqrt
  kind: python_call_eq
  function: isqrt
  args: [10]
  expected: 3

invariant math_extra4.lcm.six_four:
  description: "math.lcm(6, 4) == 12"
  category: lcm
  kind: python_call_eq
  function: lcm
  args: [6, 4]
  expected: 12

invariant math_extra4.isinf.inf_true:
  description: "math.isinf(math.inf) == True"
  category: predicates
  kind: python_call_eq
  function: isinf
  args: [inf]
  expected: true

invariant math_extra4.isnan.nan_true:
  description: "math.isnan(math.nan) == True"
  category: predicates
  kind: python_call_eq
  function: isnan
  args: [nan]
  expected: true

invariant math_extra4.tau.value:
  description: "math.tau == 6.283185307179586 (2 * pi)"
  category: constants
  kind: python_call_eq
  function: tau.__eq__
  args: [6.283185307179586]
  expected: true
