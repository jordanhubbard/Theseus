spec: uuid_extra132
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra131.zspec.zsdl — covers UUID class __doc__ length and identity / uuid function __doc__ lengths (uuid1/uuid3/uuid4/uuid5/getnode) / uuid module __doc__ length / uuid.UUID __name__ and MRO (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/qualname / UUID.__str__/__repr__/__eq__/__hash__/__lt__ method qualname equality and length."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants __class__.__name__, hex values, str() values, version attributes."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__/__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__.__eq__ / SafeUUID.__bases__[0].__name__=='Enum'."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 / uuid3/uuid5/getnode __qualname__.__len__()."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra131."
    - "Wave 291 theme: uuid1/uuid4/uuid3/uuid5/getnode __code__.co_consts lengths / uuid1/uuid4 __code__.co_varnames lengths / UUID.__init__.__code__ attribute counts / UUID.__init__.__doc__ length."
    - "uuid.uuid1.__code__.co_consts.__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_consts.__len__() == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__code__.co_consts.__len__() == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__code__.co_consts.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__code__.co_consts.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__code__.co_varnames.__len__() == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_varnames.__len__() == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__code__.co_varnames.__len__() == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__code__.co_varnames.__len__() == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__code__.co_varnames.__len__() == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_argcount == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_varnames.__len__() == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_consts.__len__() == 29. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__doc__.__len__() == 1420. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__code__.co_cellvars.__len__() == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__code__.co_freevars.__len__() == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_cellvars.__len__() == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_freevars.__len__() == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid1.__code__.co_consts has 8 entries (docstring + None + constants used for timestamp arithmetic including 122192928000000000 for epoch offset and bitmasks). uuid4.__code__.co_consts has only 1 entry (just the docstring), reflecting its simplicity."
    - "Note: uuid1 has 13 co_varnames (node, clock_seq, uuid_time, safely_generated, is_safe, nanoseconds, timestamp, random, time_low, time_mid, time_hi_version, clock_seq_low, clock_seq_hi_variant) — complex timestamp decomposition. uuid4 has just 1 (int_uuid_4)."
    - "Note: UUID.__init__ has co_argcount==7 (self + hex + bytes + bytes_le + fields + int + version; is_safe is keyword-only). co_varnames.__len__()==15 covers all local variables."
    - "Note: UUID.__init__.__doc__.__len__()==1420 — this is the __init__ method docstring (not the class __doc__ which is 2787 chars). The __init__ docstring describes the calling convention for each input form."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_consts.__len__()==8
# uuid.uuid4.__code__.co_consts.__len__()==1
# uuid.uuid3.__code__.co_consts.__len__()==5
# uuid.uuid5.__code__.co_consts.__len__()==6
# uuid.getnode.__code__.co_consts.__len__()==3
#
# Wave 291 theme: uuid generator function co_consts lengths.
#
# co_consts holds literal constants embedded in the bytecode. uuid1 (8) has the
# most: docstring, None, and six numeric constants for timestamp arithmetic
# (epoch offset 122192928000000000, bitmasks 4294967295, 65535, 4095) and
# tuple literals. uuid4 (1) has only the docstring — it uses no literal constants
# beyond the random byte generation. No prior uuid spec anchors co_consts lengths
# under uuidcode132. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra132.generator_co_consts_lengths:
  description: "uuid.uuid1/__code__/co_consts/__len__()==8 / uuid4/co_consts/__len__()==1 / uuid3/co_consts/__len__()==5 / uuid5/co_consts/__len__()==6 / getnode/co_consts/__len__()==3 — uuid1 has the most constants (8: docstring + None + timestamp arithmetic constants); uuid4 has fewest (1: only the docstring); uuid3 and uuid5 differ by 1 (5 vs 6) as uuid5 needs an additional slice constant; no prior uuid spec anchors co_consts lengths; first uuidcode132 anchor"
  kind: python_call_eq
  category: code_object
  id_prefix: uuidcode132

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_co_consts_len,   uuid1.__code__.co_consts.__len__,   [], 8, "uuid.uuid1.__code__.co_consts.__len__() is 8 (docstring + None + 6 numeric/tuple constants for timestamp arithmetic)"]
    - [uuid4_co_consts_len,   uuid4.__code__.co_consts.__len__,   [], 1, "uuid.uuid4.__code__.co_consts.__len__() is 1 (only the docstring; no literal constants needed for random UUID generation)"]
    - [uuid3_co_consts_len,   uuid3.__code__.co_consts.__len__,   [], 5, "uuid.uuid3.__code__.co_consts.__len__() is 5 (docstring + utf-8 + None + False + usedforsecurity tuple)"]
    - [uuid5_co_consts_len,   uuid5.__code__.co_consts.__len__,   [], 6, "uuid.uuid5.__code__.co_consts.__len__() is 6 (same as uuid3 plus a slice constant for truncating SHA-1 to 16 bytes)"]
    - [getnode_co_consts_len, getnode.__code__.co_consts.__len__, [], 3, "uuid.getnode.__code__.co_consts.__len__() is 3 (docstring + error format string + 281474976710656 bitmask)"]

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_varnames.__len__()==13
# uuid.uuid4.__code__.co_varnames.__len__()==1
# uuid.uuid3.__code__.co_varnames.__len__()==5
# uuid.uuid5.__code__.co_varnames.__len__()==5
# uuid.getnode.__code__.co_varnames.__len__()==1
#
# Wave 291 theme: uuid generator function co_varnames lengths.
#
# co_varnames holds function arguments plus local variable names. uuid1 (13)
# has the most locals: 2 args (node, clock_seq) plus 11 locals for timestamp
# decomposition. uuid4 and getnode each have 1 local. uuid3 and uuid5 share
# the same co_varnames length (5). No prior uuid spec anchors co_varnames
# lengths under uuidcode132. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra132.generator_co_varnames_lengths:
  description: "uuid.uuid1/__code__/co_varnames/__len__()==13 / uuid4/co_varnames/__len__()==1 / uuid3/co_varnames/__len__()==5 / uuid5/co_varnames/__len__()==5 / getnode/co_varnames/__len__()==1 — uuid1 has 13 varnames (2 args + 11 locals for timestamp decomposition); uuid4 has 1 (int_uuid_4); getnode has 1 (getter); uuid3 and uuid5 share 5 varnames (namespace/name/hashlib/h/int_uuid_N); no prior uuid spec anchors co_varnames lengths; first uuidcode132 anchor"
  kind: python_call_eq
  category: code_object
  id_prefix: uuidcode132

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_co_varnames_len,   uuid1.__code__.co_varnames.__len__,   [], 13, "uuid.uuid1.__code__.co_varnames.__len__() is 13 (2 args: node/clock_seq + 11 locals for timestamp decomposition)"]
    - [uuid4_co_varnames_len,   uuid4.__code__.co_varnames.__len__,   [], 1,  "uuid.uuid4.__code__.co_varnames.__len__() is 1 ('int_uuid_4' — single local for random int)"]
    - [uuid3_co_varnames_len,   uuid3.__code__.co_varnames.__len__,   [], 5,  "uuid.uuid3.__code__.co_varnames.__len__() is 5 (namespace, name, hashlib, h, int_uuid_3)"]
    - [uuid5_co_varnames_len,   uuid5.__code__.co_varnames.__len__,   [], 5,  "uuid.uuid5.__code__.co_varnames.__len__() is 5 (namespace, name, hashlib, h, int_uuid_5 — same structure as uuid3)"]
    - [getnode_co_varnames_len, getnode.__code__.co_varnames.__len__, [], 1,  "uuid.getnode.__code__.co_varnames.__len__() is 1 ('getter' — single local for the hardware address getter function)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_argcount==7
# uuid.UUID.__init__.__code__.co_varnames.__len__()==15
# uuid.UUID.__init__.__code__.co_consts.__len__()==29
# uuid.UUID.__init__.__doc__.__len__()==1420
#
# Wave 291 theme: UUID.__init__ code object attributes.
#
# UUID.__init__ has co_argcount==7 (self + hex + bytes + bytes_le + fields + int +
# version; is_safe is keyword-only so not counted here). co_varnames.__len__()==15
# covers all argument and local names. co_consts.__len__()==29 reflects the many
# validation string literals embedded in the constructor. UUID.__init__.__doc__
# (1420 chars) is a separate docstring from UUID.__doc__ (2787 chars).
# No prior uuid spec anchors UUID.__init__ code object attribute counts under
# uuidcode132. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra132.UUID_init_code_attrs:
  description: "uuid.UUID/__init__/__code__/co_argcount==7 / co_varnames/__len__()==15 / co_consts/__len__()==29 / UUID/__init__/__doc__/__len__()==1420 — UUID.__init__ co_argcount==7 (self + hex/bytes/bytes_le/fields/int/version; is_safe is keyword-only); co_varnames==15 covers all args and locals; co_consts==29 reflects numerous validation string literals; __init__.__doc__ (1420) is distinct from class __doc__ (2787); no prior uuid spec anchors these under uuidcode132"
  kind: python_call_eq
  category: code_object
  id_prefix: uuidcode132

  columns: [id, function, args, expected, description]
  rows:
    - [init_co_argcount,   UUID.__init__.__code__.co_argcount.__eq__,   [7],    true, "uuid.UUID.__init__.__code__.co_argcount is 7 (self + hex + bytes + bytes_le + fields + int + version)"]
    - [init_co_varnames,   UUID.__init__.__code__.co_varnames.__len__,  [],     15,   "uuid.UUID.__init__.__code__.co_varnames.__len__() is 15 (7 args + 8 local variables)"]
    - [init_co_consts,     UUID.__init__.__code__.co_consts.__len__,    [],     29,   "uuid.UUID.__init__.__code__.co_consts.__len__() is 29 (many validation error message string literals)"]
    - [init_doc_len,       UUID.__init__.__doc__.__len__,               [],     1420, "uuid.UUID.__init__.__doc__.__len__() is 1420 (init docstring; distinct from class __doc__ which is 2787 chars)"]

# ---------------------------------------------------------------------------
# uuid.uuid1.__code__.co_consts.__len__()==8 — standalone
#
# uuid.uuid1.__code__.co_consts.__len__() is 8. The eight constants in uuid1's
# co_consts include: the docstring, None (implicit), a tuple ('bytes', 'is_safe'),
# the timestamp epoch offset constant 122192928000000000 (number of 100-ns intervals
# from 1582-10-15 to 1970-01-01), and bitmasks 4294967295, 65535, 4095, and a
# second tuple ('fields', 'version'). No prior uuid spec anchors
# uuid1.__code__.co_consts.__len__() as a standalone under uuidcode132.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra132.uuid1_co_consts_len_8:
  description: "uuid.uuid1.__code__.co_consts.__len__() == 8 — eight bytecode constants: docstring, None, ('bytes','is_safe') tuple, epoch offset 122192928000000000, bitmasks 4294967295/65535/4095, and ('fields','version') tuple; no prior uuid spec anchors this as a standalone; first standalone under uuidcode132"
  category: code_object
  kind: python_call_eq
  function: uuid1.__code__.co_consts.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# uuid.uuid4.__code__.co_consts.__len__()==1 — standalone
#
# uuid.uuid4.__code__.co_consts.__len__() is 1. uuid4 generates a random UUID
# using os.urandom(16) and requires no literal numeric constants — the only
# co_const is the docstring 'Generate a random UUID.' (23 chars). This is the
# minimum possible co_consts length for a Python function with a docstring.
# No prior uuid spec anchors uuid4.__code__.co_consts.__len__() as a standalone
# under uuidcode132. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra132.uuid4_co_consts_len_1:
  description: "uuid.uuid4.__code__.co_consts.__len__() == 1 — only the docstring 'Generate a random UUID.' is in co_consts; minimum possible length for a function with a docstring; uuid4 uses no literal numeric constants (random bytes from os.urandom); no prior uuid spec anchors this as a standalone; first standalone under uuidcode132"
  category: code_object
  kind: python_call_eq
  function: uuid4.__code__.co_consts.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_argcount==7 — standalone
#
# uuid.UUID.__init__.__code__.co_argcount is 7. The seven positional/keyword
# arguments are: self, hex, bytes, bytes_le, fields, int, version. The is_safe
# parameter is keyword-only and therefore NOT counted in co_argcount (Python
# counts only positional-or-keyword args in co_argcount; keyword-only args
# are counted separately in co_kwonlyargcount). No prior uuid spec anchors
# UUID.__init__.__code__.co_argcount as a standalone under uuidcode132.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra132.UUID_init_co_argcount_7:
  description: "uuid.UUID.__init__.__code__.co_argcount == 7 — the seven positional-or-keyword args are self/hex/bytes/bytes_le/fields/int/version; is_safe is keyword-only (counted in co_kwonlyargcount, not co_argcount); no prior uuid spec anchors this as a standalone; first standalone under uuidcode132"
  category: code_object
  kind: python_call_eq
  function: UUID.__init__.__code__.co_argcount.__eq__
  args: [7]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__doc__.__len__()==1420 — standalone
#
# uuid.UUID.__init__.__doc__.__len__() is 1420. The __init__ docstring
# (1420 chars) is distinct from the class-level UUID.__doc__ (2787 chars).
# The __init__ docstring describes the calling convention — showing five
# different UUID construction forms and their mutual exclusivity constraints.
# No prior uuid spec anchors UUID.__init__.__doc__.__len__() as a standalone
# under uuidcode132. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra132.UUID_init_doc_len_1420:
  description: "uuid.UUID.__init__.__doc__.__len__() == 1420 — __init__ docstring (1420 chars) is distinct from UUID class __doc__ (2787 chars); describes five UUID construction forms (hex/bytes/bytes_le/fields/int) and their mutual exclusivity; no prior uuid spec anchors this as a standalone; first standalone under uuidcode132"
  category: code_object
  kind: python_call_eq
  function: UUID.__init__.__doc__.__len__
  args: []
  expected: 1420

