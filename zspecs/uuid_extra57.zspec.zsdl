spec: uuid_extra57
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra56.zspec.zsdl — covers uuid4.__code__.co_varnames.__class__.__name__=='tuple' / uuid1.__code__.co_varnames.__class__.__name__=='tuple' / uuid1.__code__.co_varnames[0]=='node' / uuid4.__code__.co_filename.__contains__('.py') / uuid1.__code__.co_filename.__contains__('.py') / NAMESPACE_DNS/URL/OID/X500.__class__.__name__=='UUID' (table + invariants)."
    - "uuid_extra55.zspec.zsdl — covers uuid4.__code__.co_name ('uuid4') / uuid1.__code__.co_name ('uuid1') / uuid4.__code__.co_argcount==0 / uuid1.__code__.co_argcount==2 / UUID.__doc__.__contains__('hex') / UUID.__doc__.__contains__('int') (table + invariants)."
    - "uuid_extra54.zspec.zsdl — covers uuid4.__defaults__.__class__.__name__.__eq__('NoneType') / uuid1.__defaults__.__class__.__name__.__eq__('tuple') / uuid4.__code__.__class__.__name__.__eq__('code') / uuid1.__code__.__class__.__name__.__eq__('code') (table + invariants)."
    - "uuid_extra53.zspec.zsdl — covers uuid4/uuid1/uuid3/uuid5 __annotations__.__class__.__name__.__eq__('dict') / __annotations__.__len__()==0 / uuid4.__globals__.__class__.__name__.__eq__('dict') / uuid4.__globals__.__contains__('UUID') (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra56; it does NOT duplicate invariants present in those files."
    - "Wave 232 theme: __code__.co_consts / co_nlocals / co_stacksize chains for Python functions + UUID class identity checks."
    - "uuid4.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is always a tuple of constants for a Python code object; uuid4 is a pure Python function in Lib/uuid.py. No prior uuid spec checks uuid4.__code__.co_consts. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid1.__code__.co_consts.__class__.__name__ == 'tuple' — uuid1 is a pure Python function in Lib/uuid.py. No prior uuid spec checks uuid1.__code__.co_consts. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid4.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals is an integer count of local variables for a Python code object. No prior uuid spec checks uuid4.__code__.co_nlocals. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid1.__code__.co_nlocals.__class__.__name__ == 'int' — same reasoning. No prior uuid spec checks uuid1.__code__.co_nlocals. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid4.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is an integer indicating the required VM stack space for the code object. No prior uuid spec checks uuid4.__code__.co_stacksize. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid1.__code__.co_stacksize.__class__.__name__ == 'int' — same reasoning. No prior uuid spec checks uuid1.__code__.co_stacksize. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__bases__[0].__name__ == 'object' — UUID subclasses object directly (no intermediate base class). The [0] subscript in the bases chain requires double-quoting in table rows. No prior uuid spec checks UUID.__bases__[0].__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__mro__.__len__() == 2 — the MRO for UUID is [UUID, object], which has 2 entries. No prior uuid spec checks UUID.__mro__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__name__ == 'UUID' — the class name is 'UUID'. No prior uuid spec checks UUID.__name__.__eq__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__module__ == 'uuid' — UUID is defined in the uuid module. No prior uuid spec checks UUID.__module__.__eq__('uuid'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__qualname__ == 'UUID' — the qualified name of UUID is 'UUID' (top-level class). No prior uuid spec checks UUID.__qualname__.__eq__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid4 and uuid1 __code__.co_consts class name
#
# Wave 232 theme: __code__.co_consts chains for Python functions.
#
# co_consts is a tuple of constants used in the bytecode of a Python code
# object. Both uuid4 and uuid1 are pure Python functions in Lib/uuid.py so
# their co_consts is a tuple. No prior uuid spec checks co_consts for any
# uuid function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra57.co_consts_class_name:
  description: "uuid4.__code__.co_consts.__class__.__name__=='tuple' and uuid1.__code__.co_consts.__class__.__name__=='tuple' — co_consts is always a tuple of constants for Python code objects; both uuid4 and uuid1 are pure Python functions in Lib/uuid.py; no prior uuid spec checks co_consts for any uuid function; first co_consts anchor for uuid"
  kind: python_call_eq
  category: code_objects
  id_prefix: uuidcode4_57

  columns: [id, function, args, expected]
  rows:
    - [uuid4_co_consts_class_name, uuid4.__code__.co_consts.__class__.__name__.__eq__, ["tuple"], true]
    - [uuid1_co_consts_class_name, uuid1.__code__.co_consts.__class__.__name__.__eq__, ["tuple"], true]

# ---------------------------------------------------------------------------
# uuid4 and uuid1 __code__.co_nlocals class name
#
# Wave 232 theme: __code__.co_nlocals chains for Python functions.
#
# co_nlocals is an integer count of local variables (parameters plus locals)
# used by the code object. Both uuid4 and uuid1 are pure Python functions so
# co_nlocals is an int. No prior uuid spec checks co_nlocals for any uuid
# function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra57.co_nlocals_class_name:
  description: "uuid4.__code__.co_nlocals.__class__.__name__=='int' and uuid1.__code__.co_nlocals.__class__.__name__=='int' — co_nlocals is always an integer count of local variables for Python code objects; both uuid4 and uuid1 are pure Python functions in Lib/uuid.py; no prior uuid spec checks co_nlocals for any uuid function; first co_nlocals anchor for uuid"
  kind: python_call_eq
  category: code_objects
  id_prefix: uuidcode4_57

  columns: [id, function, args, expected]
  rows:
    - [uuid4_co_nlocals_class_name, uuid4.__code__.co_nlocals.__class__.__name__.__eq__, ["int"], true]
    - [uuid1_co_nlocals_class_name, uuid1.__code__.co_nlocals.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# uuid4 and uuid1 __code__.co_stacksize class name
#
# Wave 232 theme: __code__.co_stacksize chains for Python functions.
#
# co_stacksize is an integer indicating the required virtual machine stack
# space for the code object. Both uuid4 and uuid1 are pure Python functions
# so co_stacksize is an int. No prior uuid spec checks co_stacksize for any
# uuid function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra57.co_stacksize_class_name:
  description: "uuid4.__code__.co_stacksize.__class__.__name__=='int' and uuid1.__code__.co_stacksize.__class__.__name__=='int' — co_stacksize is always an integer indicating required VM stack space for Python code objects; both uuid4 and uuid1 are pure Python functions in Lib/uuid.py; no prior uuid spec checks co_stacksize for any uuid function; first co_stacksize anchor for uuid"
  kind: python_call_eq
  category: code_objects
  id_prefix: uuidcode4_57

  columns: [id, function, args, expected]
  rows:
    - [uuid4_co_stacksize_class_name, uuid4.__code__.co_stacksize.__class__.__name__.__eq__, ["int"], true]
    - [uuid1_co_stacksize_class_name, uuid1.__code__.co_stacksize.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# uuid.UUID class identity checks
#
# Wave 232 theme: UUID class identity — name, module, qualname, bases, MRO.
#
# uuid.UUID is the core class of the uuid module. It subclasses object
# directly, giving an MRO of [UUID, object] with length 2. Its __name__ is
# 'UUID', __module__ is 'uuid', and __qualname__ is 'UUID'. The [0] subscript
# in UUID.__bases__[0].__name__ requires double-quoting in table rows.
# No prior uuid spec checks UUID.__name__, UUID.__module__ ('uuid'),
# UUID.__qualname__, UUID.__bases__[0].__name__, or UUID.__mro__.__len__().
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra57.UUID_identity:
  description: "uuid.UUID.__name__=='UUID' / UUID.__module__=='uuid' / UUID.__qualname__=='UUID' / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 — UUID is the core class of the uuid module, subclasses object directly (MRO [UUID, object] len 2); no prior uuid spec checks UUID.__name__, UUID.__module__.__eq__('uuid'), UUID.__qualname__, UUID.__bases__[0].__name__, or UUID.__mro__.__len__(); first class identity anchor for UUID itself"
  kind: python_call_eq
  category: class_identity
  id_prefix: uuidcode4_57

  columns: [id, function, args, expected]
  rows:
    - [UUID_name_UUID,          UUID.__name__.__eq__,                    ["UUID"],   true]
    - [UUID_module_uuid,        UUID.__module__.__eq__,                  ["uuid"],   true]
    - [UUID_qualname_UUID,      UUID.__qualname__.__eq__,                ["UUID"],   true]
    - [UUID_bases_0_object,     "UUID.__bases__[0].__name__.__eq__",     ["object"], true]
    - [UUID_mro_len_2,          UUID.__mro__.__len__,                    [],         2]

# ---------------------------------------------------------------------------
# uuid4.__code__.co_consts.__class__.__name__.__eq__('tuple') — standalone
#
# uuid4 is a pure Python function in Lib/uuid.py. The code object's co_consts
# attribute is always a tuple containing the literal constants referenced in
# bytecode. No prior uuid spec checks uuid4.__code__.co_consts in any form.
# First co_consts anchor for any uuid function.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra57.uuid4_co_consts_tuple:
  description: "uuid.uuid4.__code__.co_consts.__class__.__name__.__eq__('tuple') == True — co_consts is always a tuple for Python code objects containing literal constants; uuid4 is a pure Python function in Lib/uuid.py; no prior uuid spec checks uuid4.__code__.co_consts; first co_consts anchor for any uuid function"
  category: code_objects
  kind: python_call_eq
  function: uuid4.__code__.co_consts.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# uuid4.__code__.co_nlocals.__class__.__name__.__eq__('int') — standalone
#
# uuid4 is a pure Python function in Lib/uuid.py. The code object's co_nlocals
# is an integer counting the number of local variables. No prior uuid spec checks
# uuid4.__code__.co_nlocals in any form. First co_nlocals anchor for uuid.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra57.uuid4_co_nlocals_int:
  description: "uuid.uuid4.__code__.co_nlocals.__class__.__name__.__eq__('int') == True — co_nlocals is always an integer count of local variables for Python code objects; uuid4 is a pure Python function in Lib/uuid.py; no prior uuid spec checks uuid4.__code__.co_nlocals; first co_nlocals anchor for any uuid function"
  category: code_objects
  kind: python_call_eq
  function: uuid4.__code__.co_nlocals.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# uuid4.__code__.co_stacksize.__class__.__name__.__eq__('int') — standalone
#
# uuid4 is a pure Python function in Lib/uuid.py. The code object's co_stacksize
# is an integer indicating the required VM stack space. No prior uuid spec checks
# uuid4.__code__.co_stacksize in any form. First co_stacksize anchor for uuid.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra57.uuid4_co_stacksize_int:
  description: "uuid.uuid4.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — co_stacksize is always an integer indicating required VM stack space for Python code objects; uuid4 is a pure Python function in Lib/uuid.py; no prior uuid spec checks uuid4.__code__.co_stacksize; first co_stacksize anchor for any uuid function"
  category: code_objects
  kind: python_call_eq
  function: uuid4.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__bases__[0].__name__.__eq__('object') — standalone
#
# uuid.UUID subclasses object directly — there is no intermediate base class.
# UUID.__bases__ is a tuple with a single entry: object. The [0] subscript
# accesses that entry and __name__ returns 'object'. No prior uuid spec checks
# UUID.__bases__[0].__name__. First base class identity anchor for UUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra57.UUID_bases_object:
  description: "uuid.UUID.__bases__[0].__name__.__eq__('object') == True — UUID subclasses object directly; __bases__ has one entry: object; no prior uuid spec checks UUID.__bases__[0].__name__; first base class identity anchor for uuid.UUID"
  category: class_identity
  kind: python_call_eq
  function: UUID.__bases__
  method_chain: ["__getitem__", "__getattribute__", "__eq__"]
  method_chain_args: [[0], ["__name__"], ["object"]]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__mro__.__len__() == 2 — standalone
#
# The MRO (method resolution order) of uuid.UUID is [UUID, object] — exactly
# 2 entries. UUID subclasses object directly with no intermediate classes.
# No prior uuid spec checks UUID.__mro__.__len__(). First MRO length anchor
# for uuid.UUID. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra57.UUID_mro_2:
  description: "uuid.UUID.__mro__.__len__() == 2 — MRO is [UUID, object] with 2 entries; UUID subclasses object directly with no intermediate classes; no prior uuid spec checks UUID.__mro__.__len__(); first MRO length anchor for uuid.UUID"
  category: class_identity
  kind: python_call_eq
  function: UUID.__mro__.__len__
  args: []
  expected: 2
