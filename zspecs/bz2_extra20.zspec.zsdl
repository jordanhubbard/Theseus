spec: bz2_extra20
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
  notes:
    - "This spec extends bz2_extra19.zspec.zsdl."
    - "Prior specs covered: BZ2File/__name__/__module__/__qualname__, BZ2Compressor/__name__/__module__, BZ2Decompressor/__name__/__module__, open/__name__/__module__, compress/__name__/__module__, decompress/__name__/__module__, BZ2File/__bases__[0].__name__, BZ2Compressor/__bases__[0].__name__, BZ2Decompressor/__bases__[0].__name__, various __qualname__ checks, BZ2File/__init__.__name__, BZ2Compressor/__init__.__name__, BZ2Decompressor/__init__.__name__, open/__qualname__, compress/__qualname__, decompress/__qualname__, open/__module__.__len__()==3, compress/__module__.__len__()==3, decompress/__module__.__len__()==3, BZ2File/__module__.__len__()==3."
    - "This spec covers: bz2.BZ2File.__module__.__len__(), bz2.BZ2Compressor.__module__.__len__(), bz2.BZ2Decompressor.__module__.__len__(), bz2.open.__module__.__len__(), bz2.compress.__module__.__len__(), bz2.decompress.__module__.__len__(), bz2.BZ2File.__name__.__len__(), bz2.BZ2Compressor.__name__.__len__(), bz2.BZ2Decompressor.__name__.__len__(), bz2.open.__name__.__len__(), bz2.compress.__name__.__len__(), bz2.decompress.__name__.__len__()."
    - "bz2.BZ2File.__module__.__len__() == 3: 'bz2' has three characters. Verified 2026-04-09."
    - "bz2.BZ2Compressor.__module__.__len__() == 4: '_bz2' has four characters (C extension type). Verified 2026-04-09."
    - "bz2.BZ2Decompressor.__module__.__len__() == 4: '_bz2' has four characters (C extension type). Verified 2026-04-09."
    - "bz2.open.__module__.__len__() == 3: 'bz2' has three characters. Verified 2026-04-09."
    - "bz2.compress.__module__.__len__() == 3: 'bz2' has three characters. Verified 2026-04-09."
    - "bz2.decompress.__module__.__len__() == 3: 'bz2' has three characters. Verified 2026-04-09."
    - "bz2.BZ2File.__name__.__len__() == 7: 'BZ2File' has seven characters. Verified 2026-04-09."
    - "bz2.BZ2Compressor.__name__.__len__() == 13: 'BZ2Compressor' has thirteen characters. Verified 2026-04-09."
    - "bz2.BZ2Decompressor.__name__.__len__() == 15: 'BZ2Decompressor' has fifteen characters. Verified 2026-04-09."
    - "bz2.open.__name__.__len__() == 4: 'open' has four characters. Verified 2026-04-09."
    - "bz2.compress.__name__.__len__() == 8: 'compress' has eight characters. Verified 2026-04-09."
    - "bz2.decompress.__name__.__len__() == 10: 'decompress' has ten characters. Verified 2026-04-09."
    - "BZ2Compressor and BZ2Decompressor are C extension types defined in _bz2; hence their __module__ is '_bz2' (len 4), not 'bz2' (len 3)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BZ2File.__module__.__len__() == 3 — re-anchored, extra20 namespace
#
# bz2.BZ2File.__module__ == 'bz2' (len 3). Re-anchored from extra19 in
# the extra20 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra20.BZ2File.module_len:
  description: "bz2.BZ2File.__module__.__len__() == 3 — 'bz2' module name has three characters (extra20)"
  category: module_affiliation
  kind: python_call_eq
  function: BZ2File.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# BZ2Compressor.__module__.__len__() == 4 — novel, extra20 anchor
#
# bz2.BZ2Compressor.__module__ == '_bz2' (len 4). BZ2Compressor is a C
# extension type defined in _bz2. No prior bz2 spec checks
# __module__.__len__() for BZ2Compressor. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra20.BZ2Compressor.module_len:
  description: "bz2.BZ2Compressor.__module__.__len__() == 4 — '_bz2' module name has four characters (extra20)"
  category: module_affiliation
  kind: python_call_eq
  function: BZ2Compressor.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# BZ2Decompressor.__module__.__len__() == 4 — novel, extra20 anchor
#
# bz2.BZ2Decompressor.__module__ == '_bz2' (len 4). BZ2Decompressor is a C
# extension type defined in _bz2. No prior bz2 spec checks
# __module__.__len__() for BZ2Decompressor. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra20.BZ2Decompressor.module_len:
  description: "bz2.BZ2Decompressor.__module__.__len__() == 4 — '_bz2' module name has four characters (extra20)"
  category: module_affiliation
  kind: python_call_eq
  function: BZ2Decompressor.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# open.__module__.__len__() == 3 — re-anchored, extra20 namespace
#
# bz2.open.__module__ == 'bz2' (len 3). Re-anchored from extra19 in
# the extra20 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra20.open.module_len:
  description: "bz2.open.__module__.__len__() == 3 — 'bz2' module name has three characters (extra20)"
  category: module_affiliation
  kind: python_call_eq
  function: open.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# compress.__module__.__len__() == 3 — re-anchored, extra20 namespace
#
# bz2.compress.__module__ == 'bz2' (len 3). Re-anchored from extra19 in
# the extra20 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra20.compress.module_len:
  description: "bz2.compress.__module__.__len__() == 3 — 'bz2' module name has three characters (extra20)"
  category: module_affiliation
  kind: python_call_eq
  function: compress.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# decompress.__module__.__len__() == 3 — re-anchored, extra20 namespace
#
# bz2.decompress.__module__ == 'bz2' (len 3). Re-anchored from extra19 in
# the extra20 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra20.decompress.module_len:
  description: "bz2.decompress.__module__.__len__() == 3 — 'bz2' module name has three characters (extra20)"
  category: module_affiliation
  kind: python_call_eq
  function: decompress.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# BZ2File.__name__.__len__() == 7 — novel, extra20 anchor
#
# bz2.BZ2File.__name__ == 'BZ2File' which has 7 characters. No prior bz2
# spec checks __name__.__len__() for BZ2File. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra20.BZ2File.name_len:
  description: "bz2.BZ2File.__name__.__len__() == 7 — 'BZ2File' class name has seven characters (extra20)"
  category: name_lengths
  kind: python_call_eq
  function: BZ2File.__name__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# BZ2Compressor.__name__.__len__() == 13 — novel, extra20 anchor
#
# bz2.BZ2Compressor.__name__ == 'BZ2Compressor' which has 13 characters.
# No prior bz2 spec checks __name__.__len__() for BZ2Compressor.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra20.BZ2Compressor.name_len:
  description: "bz2.BZ2Compressor.__name__.__len__() == 13 — 'BZ2Compressor' class name has thirteen characters (extra20)"
  category: name_lengths
  kind: python_call_eq
  function: BZ2Compressor.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# BZ2Decompressor.__name__.__len__() == 15 — novel, extra20 anchor
#
# bz2.BZ2Decompressor.__name__ == 'BZ2Decompressor' which has 15 characters.
# No prior bz2 spec checks __name__.__len__() for BZ2Decompressor.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra20.BZ2Decompressor.name_len:
  description: "bz2.BZ2Decompressor.__name__.__len__() == 15 — 'BZ2Decompressor' class name has fifteen characters (extra20)"
  category: name_lengths
  kind: python_call_eq
  function: BZ2Decompressor.__name__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# open.__name__.__len__() == 4 — novel, extra20 anchor
#
# bz2.open.__name__ == 'open' which has 4 characters. No prior bz2 spec
# checks __name__.__len__() for the open function. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra20.open.name_len:
  description: "bz2.open.__name__.__len__() == 4 — 'open' function name has four characters (extra20)"
  category: name_lengths
  kind: python_call_eq
  function: open.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# compress.__name__.__len__() == 8 — novel, extra20 anchor
#
# bz2.compress.__name__ == 'compress' which has 8 characters. No prior bz2
# spec checks __name__.__len__() for the compress function. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra20.compress.name_len:
  description: "bz2.compress.__name__.__len__() == 8 — 'compress' function name has eight characters (extra20)"
  category: name_lengths
  kind: python_call_eq
  function: compress.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# decompress.__name__.__len__() == 10 — novel, extra20 anchor
#
# bz2.decompress.__name__ == 'decompress' which has 10 characters. No prior
# bz2 spec checks __name__.__len__() for the decompress function.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra20.decompress.name_len:
  description: "bz2.decompress.__name__.__len__() == 10 — 'decompress' function name has ten characters (extra20)"
  category: name_lengths
  kind: python_call_eq
  function: decompress.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# __module__.__len__() table — BZ2File, BZ2Compressor, BZ2Decompressor,
#                              open, compress, decompress (extra20)
#
# BZ2File/open/compress/decompress have module 'bz2' (len 3);
# BZ2Compressor and BZ2Decompressor have module '_bz2' (len 4) as they are
# C extension types. This table anchors all six from the extra20 namespace.
# ---------------------------------------------------------------------------

table bz2_extra20.module_lengths:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: modlen20

  columns: [id, function, args, expected]
  rows:
    - [BZ2File,         BZ2File.__module__.__len__,         [], 3]
    - [BZ2Compressor,   BZ2Compressor.__module__.__len__,   [], 4]
    - [BZ2Decompressor, BZ2Decompressor.__module__.__len__, [], 4]
    - [open,            open.__module__.__len__,            [], 3]
    - [compress,        compress.__module__.__len__,        [], 3]
    - [decompress,      decompress.__module__.__len__,      [], 3]

# ---------------------------------------------------------------------------
# __name__.__len__() table — BZ2File, BZ2Compressor, BZ2Decompressor,
#                            open, compress, decompress (extra20)
#
# No prior bz2 spec presents __name__.__len__() checks in a table.
# BZ2File=7, BZ2Compressor=13, BZ2Decompressor=15, open=4, compress=8,
# decompress=10.
# ---------------------------------------------------------------------------

table bz2_extra20.name_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: namelen20

  columns: [id, function, args, expected]
  rows:
    - [BZ2File,         BZ2File.__name__.__len__,         [], 7]
    - [BZ2Compressor,   BZ2Compressor.__name__.__len__,   [], 13]
    - [BZ2Decompressor, BZ2Decompressor.__name__.__len__, [], 15]
    - [open,            open.__name__.__len__,            [], 4]
    - [compress,        compress.__name__.__len__,        [], 8]
    - [decompress,      decompress.__name__.__len__,      [], 10]
