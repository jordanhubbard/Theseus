spec: mailbox_extra3
version: ">=3.9"
backend: python_module(mailbox)

docs: https://docs.python.org/3/library/mailbox.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mailbox.html — Python mailbox documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/mailbox.py"
  notes:
    - "This spec extends mailbox.zspec.zsdl and prior extras."
    - "mailbox.zspec.zsdl covers: __name__ checks via table for Mailbox/Maildir/mbox/MH/Babyl/MMDF/Message and all message subclasses; exception __name__ table; Mailbox.__module__; hierarchy for Maildir/NoSuchMailboxError/NotEmptyError/ExternalClashError."
    - "mailbox_extra.zspec.zsdl covers: __module__ for all container/message/exception classes; Error.__name__ and base; mbox/MH/Babyl/MMDF/Message bases; Mailbox.__doc__ is str; FormatError base; all message-subclass bases."
    - "mailbox_extra2.zspec.zsdl covers: __qualname__ for Mailbox/Maildir/mbox/MH/Babyl/MMDF/Message and exception classes; Mailbox.__bases__[0].__name__=='object'; mbox.__bases__[0].__name__=='_singlefileMailbox'; Message base __qualname__; Error.__qualname__."
    - "This spec adds: __name__ standalone invariants for each container class and Message (complementing the table form in mailbox.zspec.zsdl with unique invariant IDs); __module__ for Message via standalone invariant; Mailbox.__name__ and Message.__name__ via __eq__ method_args form."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ standalone invariants for mailbox container classes
# (mailbox.zspec.zsdl covers these via table rows; here we add standalone
# invariant form with distinct IDs for individual traceability)
# ---------------------------------------------------------------------------

invariant mailbox_extra3.Mailbox.name:
  description: "mailbox.Mailbox.__name__ == 'Mailbox'"
  category: class_identity
  kind: python_call_eq
  function: Mailbox.__name__.__eq__
  args: ["Mailbox"]
  expected: true

invariant mailbox_extra3.Maildir.name:
  description: "mailbox.Maildir.__name__ == 'Maildir'"
  category: class_identity
  kind: python_call_eq
  function: Maildir.__name__.__eq__
  args: ["Maildir"]
  expected: true

invariant mailbox_extra3.mbox.name:
  description: "mailbox.mbox.__name__ == 'mbox'"
  category: class_identity
  kind: python_call_eq
  function: mbox.__name__.__eq__
  args: ["mbox"]
  expected: true

invariant mailbox_extra3.MH.name:
  description: "mailbox.MH.__name__ == 'MH'"
  category: class_identity
  kind: python_call_eq
  function: MH.__name__.__eq__
  args: ["MH"]
  expected: true

invariant mailbox_extra3.Babyl.name:
  description: "mailbox.Babyl.__name__ == 'Babyl'"
  category: class_identity
  kind: python_call_eq
  function: Babyl.__name__.__eq__
  args: ["Babyl"]
  expected: true

invariant mailbox_extra3.MMDF.name:
  description: "mailbox.MMDF.__name__ == 'MMDF'"
  category: class_identity
  kind: python_call_eq
  function: MMDF.__name__.__eq__
  args: ["MMDF"]
  expected: true

invariant mailbox_extra3.Message.name:
  description: "mailbox.Message.__name__ == 'Message'"
  category: class_identity
  kind: python_call_eq
  function: Message.__name__.__eq__
  args: ["Message"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ standalone invariant for Message class
# (mailbox_extra has this in a table row; here as a standalone invariant)
# ---------------------------------------------------------------------------

invariant mailbox_extra3.Message.module:
  description: "mailbox.Message.__module__ == 'mailbox'"
  category: module
  kind: python_call_eq
  function: Message.__module__.__eq__
  args: ["mailbox"]
  expected: true

# ---------------------------------------------------------------------------
# __name__ length checks — verify no trailing/leading whitespace in class names
# ---------------------------------------------------------------------------

invariant mailbox_extra3.Mailbox.name_len:
  description: "mailbox.Mailbox.__name__.__len__() == 7 — 'Mailbox' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: Mailbox.__name__.__len__
  args: []
  expected: 7

invariant mailbox_extra3.Maildir.name_len:
  description: "mailbox.Maildir.__name__.__len__() == 7 — 'Maildir' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: Maildir.__name__.__len__
  args: []
  expected: 7

invariant mailbox_extra3.mbox.name_len:
  description: "mailbox.mbox.__name__.__len__() == 4 — 'mbox' has 4 characters"
  category: class_identity
  kind: python_call_eq
  function: mbox.__name__.__len__
  args: []
  expected: 4

invariant mailbox_extra3.MH.name_len:
  description: "mailbox.MH.__name__.__len__() == 2 — 'MH' has 2 characters"
  category: class_identity
  kind: python_call_eq
  function: MH.__name__.__len__
  args: []
  expected: 2

invariant mailbox_extra3.Babyl.name_len:
  description: "mailbox.Babyl.__name__.__len__() == 5 — 'Babyl' has 5 characters"
  category: class_identity
  kind: python_call_eq
  function: Babyl.__name__.__len__
  args: []
  expected: 5

invariant mailbox_extra3.MMDF.name_len:
  description: "mailbox.MMDF.__name__.__len__() == 4 — 'MMDF' has 4 characters"
  category: class_identity
  kind: python_call_eq
  function: MMDF.__name__.__len__
  args: []
  expected: 4

invariant mailbox_extra3.Message.name_len:
  description: "mailbox.Message.__name__.__len__() == 7 — 'Message' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: Message.__name__.__len__
  args: []
  expected: 7
