spec: theseus_calendar_cr
version: ">=3.8"
backend: python_cleanroom(theseus_calendar_cr)
blocks: calendar

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/calendar.html"
  not_derived_from:
    - "CPython source: Lib/calendar.py (internal implementation)"
  notes:
    - "Clean-room calendar module. Do NOT import calendar."
    - "isleap(year): return True if year is a leap year."
    - "leapdays(y1, y2): count leap years in range."
    - "monthrange(year, month): return (weekday_of_first, days_in_month)."
    - "weekday(year, month, day): return weekday (0=Mon)."

error_model: python_exceptions

invariant theseus_calendar_cr.calendar2_isleap:
  description: "isleap(2000) is True, isleap(1900) is False"
  category: isleap
  kind: python_call_eq
  function: calendar2_isleap
  args: []
  expected: true

invariant theseus_calendar_cr.calendar2_monthrange:
  description: "monthrange(2024, 2) returns days=29 (leap year)"
  category: monthrange
  kind: python_call_eq
  function: calendar2_monthrange
  args: []
  expected: 29

invariant theseus_calendar_cr.calendar2_weekday:
  description: "weekday(2024, 1, 1) returns 0 (Monday)"
  category: weekday
  kind: python_call_eq
  function: calendar2_weekday
  args: []
  expected: 0
