spec: lodash_pickby
version: ">=4.0.0"
backend: node(lodash.pickby)

docs: https://lodash.com/docs/#pickBy

provenance:
  derived_from:
    - "lodash.pickby README — https://www.npmjs.com/package/lodash.pickby"
    - "Test vectors verified with lodash.pickby@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.pickby exports the _.pickBy function directly as module.exports."
    - "pickBy(object) with no iteratee picks properties with truthy values."
    - "pickBy(object, iteratee) picks properties where iteratee returns truthy."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns new object with picked properties."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_pickby.pickby:
  kind: node_module_call_eq
  function: ~
  category: pickby
  id_prefix: lpby

  columns: [id, args, expected]
  rows:
    - [truthy_only,  [{"a": 1, "b": 0, "c": "hello", "d": null}],
       {"a": 1, "c": "hello"}]
    - [all_truthy,   [{"x": 1, "y": 2}],
       {"x": 1, "y": 2}]
    - [none_truthy,  [{"a": 0, "b": null, "c": ""}],
       {}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
