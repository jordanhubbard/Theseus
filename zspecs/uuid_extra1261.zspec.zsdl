spec: uuid_extra1261
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra126.zspec.zsdl — covers NAMESPACE_DNS/URL/OID/X500 class names and version values / NAMESPACE_DNS hex / NIL.int == 0 (table + invariants)."
    - "uuid_extra125.zspec.zsdl — covers uuid.getnode __name__/__qualname__/__module__/co_argcount / uuid1/uuid3/uuid5/uuid4 co_varnames[0] / uuid.SafeUUID __name__/__qualname__/__module__/__class__.__name__ (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__ co_name/co_argcount/__qualname__ / UUID method qualname equality (table + invariants)."
  notes:
    - "Wave 531: uuid does NOT have __all__ on this Python version. Instead, this spec uses uuid.__dict__.__contains__ to check public-name membership in the module namespace. Also checks class identity of key symbols (UUID.__module__, RFC_4122.__class__.__name__, NAMESPACE_DNS.__class__.__name__, SafeUUID.__module__)."
    - "uuid.__all__ is absent (hasattr(uuid, '__all__') == False). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__dict__.__contains__ returns True for public names (UUID, uuid4, uuid1, uuid3, uuid5, NAMESPACE_DNS, NAMESPACE_URL, SafeUUID, RFC_4122, RESERVED_NCS) and False for absent names (xyz, foobar, sha256). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RFC_4122.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1261.dict_contains_true:
  description: "uuid.__dict__.__contains__ returns true for public names that are members of the uuid module namespace"
  kind: python_call_eq
  category: dict_membership_true
  id_prefix: uu1261dt
  columns: [id, function, args, expected]
  rows:
    - [uu1261dt001, uuid.__dict__.__contains__, ["UUID"],          true]
    - [uu1261dt002, uuid.__dict__.__contains__, ["uuid1"],         true]
    - [uu1261dt003, uuid.__dict__.__contains__, ["uuid3"],         true]
    - [uu1261dt004, uuid.__dict__.__contains__, ["uuid4"],         true]
    - [uu1261dt005, uuid.__dict__.__contains__, ["uuid5"],         true]
    - [uu1261dt006, uuid.__dict__.__contains__, ["NAMESPACE_DNS"], true]
    - [uu1261dt007, uuid.__dict__.__contains__, ["NAMESPACE_URL"], true]
    - [uu1261dt008, uuid.__dict__.__contains__, ["NAMESPACE_OID"], true]
    - [uu1261dt009, uuid.__dict__.__contains__, ["NAMESPACE_X500"],true]
    - [uu1261dt010, uuid.__dict__.__contains__, ["SafeUUID"],      true]
    - [uu1261dt011, uuid.__dict__.__contains__, ["RFC_4122"],      true]
    - [uu1261dt012, uuid.__dict__.__contains__, ["RESERVED_NCS"],  true]
    - [uu1261dt013, uuid.__dict__.__contains__, ["getnode"],       true]
    - [uu1261dt014, uuid.__dict__.__contains__, ["NIL"],           true]
    - [uu1261dt015, uuid.__dict__.__contains__, ["MAX"],           true]

table uuid_extra1261.dict_contains_false:
  description: "uuid.__dict__.__contains__ returns false for names not in the uuid module namespace"
  kind: python_call_eq
  category: dict_membership_false
  id_prefix: uu1261df
  columns: [id, function, args, expected]
  rows:
    - [uu1261df001, uuid.__dict__.__contains__, ["xyz"],       false]
    - [uu1261df002, uuid.__dict__.__contains__, ["foobar"],    false]
    - [uu1261df003, uuid.__dict__.__contains__, ["sha256"],    false]
    - [uu1261df004, uuid.__dict__.__contains__, ["uuid9"],     false]
    - [uu1261df005, uuid.__dict__.__contains__, ["UUID4"],     false]
    - [uu1261df006, uuid.__dict__.__contains__, ["uuid"],      false]
    - [uu1261df007, uuid.__dict__.__contains__, ["namespace"], false]
    - [uu1261df008, uuid.__dict__.__contains__, ["md5"],       false]
    - [uu1261df009, uuid.__dict__.__contains__, ["SAFE"],      false]
    - [uu1261df010, uuid.__dict__.__contains__, ["reserved"],  false]
    - [uu1261df011, uuid.__dict__.__contains__, ["socket"],    false]
    - [uu1261df012, uuid.__dict__.__contains__, [""],          false]

table uuid_extra1261.symbol_class_identity:
  description: "Class and module identity checks for key uuid symbols — UUID.__module__, RFC_4122.__class__.__name__, NAMESPACE_DNS.__class__.__name__, SafeUUID.__module__, UUID.__qualname__"
  kind: python_call_eq
  category: symbol_class_identity
  id_prefix: uu1261ci
  columns: [id, function, args, expected]
  rows:
    - [uu1261ci001, uuid.UUID.__module__.__eq__,                         ["uuid"],  true]
    - [uu1261ci002, uuid.UUID.__qualname__.__eq__,                       ["UUID"],  true]
    - [uu1261ci003, uuid.SafeUUID.__module__.__eq__,                     ["uuid"],  true]
    - [uu1261ci004, uuid.RFC_4122.__class__.__name__.__eq__,             ["str"],   true]
    - [uu1261ci005, uuid.NAMESPACE_DNS.__class__.__name__.__eq__,        ["UUID"],  true]
    - [uu1261ci006, uuid.NAMESPACE_URL.__class__.__name__.__eq__,        ["UUID"],  true]
    - [uu1261ci007, uuid.NAMESPACE_OID.__class__.__name__.__eq__,        ["UUID"],  true]
    - [uu1261ci008, uuid.NAMESPACE_X500.__class__.__name__.__eq__,       ["UUID"],  true]
    - [uu1261ci009, uuid.uuid4.__qualname__.__eq__,                      ["uuid4"], true]
    - [uu1261ci010, uuid.uuid1.__qualname__.__eq__,                      ["uuid1"], true]
    - [uu1261ci011, uuid.uuid3.__qualname__.__eq__,                      ["uuid3"], true]
    - [uu1261ci012, uuid.uuid5.__qualname__.__eq__,                      ["uuid5"], true]
    - [uu1261ci013, uuid.UUID.__module__.__eq__,                         ["builtins"], false]
    - [uu1261ci014, uuid.SafeUUID.__class__.__name__.__eq__,             ["EnumType"], true]
    - [uu1261ci015, uuid.__name__.__eq__,                                ["uuid"],  true]
