spec: color_string
version: ">=2.0.0"
backend: node(color-string)

docs: https://github.com/Qix-/color-string#readme

provenance:
  derived_from:
    - "color-string README — https://github.com/Qix-/color-string#readme"
    - "CSS Color Module Level 4 — https://www.w3.org/TR/css-color-4/"
    - "Test vectors verified with color-string via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "color-string source"
  notes:
    - "Lower-level color string parser/formatter; companion to the Qix `color` library."
    - "Install: npm install color-string"
    - "v2 is ESM with a CJS shim; functions are exposed via .default."
    - "get(input) returns {model, value: [r,g,b,a]} or null for unparsable input."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; .get() returns null on bad input (never throws)."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# get(input) — parse a CSS color string
table color_string.get_model:
  kind: node_chain_eq
  category: get_model
  entry: named
  function: default.get
  id_prefix: model

  columns: [id, entry_args, chain, expected]
  rows:
    - [hex_long,   ["#ff0000"],         [{get: model}], "rgb"]
    - [hex_short,  ["#f00"],            [{get: model}], "rgb"]
    - [named,      ["red"],             [{get: model}], "rgb"]
    - [rgb_func,   ["rgb(255,0,0)"],    [{get: model}], "rgb"]
    - [hsl_func,   ["hsl(0, 100%, 50%)"], [{get: model}], "hsl"]

table color_string.get_value:
  kind: node_chain_eq
  category: get_value
  entry: named
  function: default.get
  id_prefix: value

  columns: [id, entry_args, chain, expected]
  rows:
    - [red_rgb,
       ["#ff0000"],
       [{get: value}],
       [255, 0, 0, 1]]

    - [blue_rgb,
       ["#0000ff"],
       [{get: value}],
       [0, 0, 255, 1]]

    - [named_red,
       ["red"],
       [{get: value}],
       [255, 0, 0, 1]]

# Invalid input -> null
invariant color_string.invalid_input_returns_null:
  description: "get('not-a-color') returns null (no throw)"
  category: invalid
  kind: node_chain_eq
  entry: named
  function: default.get
  entry_args: ["not-a-color"]
  chain: []
  expected: ~
