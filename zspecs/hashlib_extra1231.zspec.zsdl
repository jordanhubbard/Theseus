spec: hashlib_extra1231
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib.__dict__.__contains__ for top-level module attributes: new, md5, sha1, sha224, sha256, sha384, sha512, algorithms_guaranteed, algorithms_available, pbkdf2_hmac, scrypt; also __dict__ class identity and module-level name/qualname attrs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1231.module_dict_contains_constructors:
  description: "hashlib.__dict__.__contains__ checks for hash constructor and function names"
  kind: python_call_eq
  category: module_dict_contains_constructors
  id_prefix: hl1231mc
  columns: [id, function, args, expected]
  rows:
    - [hl1231mc001, hashlib.__dict__.__contains__,                    ["new"],                       true]
    - [hl1231mc002, hashlib.__dict__.__contains__,                    ["md5"],                       true]
    - [hl1231mc003, hashlib.__dict__.__contains__,                    ["sha1"],                      true]
    - [hl1231mc004, hashlib.__dict__.__contains__,                    ["sha224"],                    true]
    - [hl1231mc005, hashlib.__dict__.__contains__,                    ["sha256"],                    true]
    - [hl1231mc006, hashlib.__dict__.__contains__,                    ["sha384"],                    true]
    - [hl1231mc007, hashlib.__dict__.__contains__,                    ["sha512"],                    true]
    - [hl1231mc008, hashlib.__dict__.__class__.__name__.__eq__,       ["dict"],                      true]
    - [hl1231mc009, hashlib.__dict__.__class__.__qualname__.__eq__,   ["dict"],                      true]

table hashlib_extra1231.module_dict_contains_sets_and_kdf:
  description: "hashlib.__dict__.__contains__ checks for algorithms_guaranteed, algorithms_available, pbkdf2_hmac, and scrypt"
  kind: python_call_eq
  category: module_dict_contains_sets_and_kdf
  id_prefix: hl1231sk
  columns: [id, function, args, expected]
  rows:
    - [hl1231sk001, hashlib.__dict__.__contains__,                    ["algorithms_guaranteed"],     true]
    - [hl1231sk002, hashlib.__dict__.__contains__,                    ["algorithms_available"],      true]
    - [hl1231sk003, hashlib.__dict__.__contains__,                    ["pbkdf2_hmac"],               true]
    - [hl1231sk004, hashlib.__dict__.__contains__,                    ["scrypt"],                    true]
    - [hl1231sk005, hashlib.__dict__.__class__.__module__.__eq__,     ["builtins"],                  true]
    - [hl1231sk006, hashlib.__dict__.__class__.__name__.__class__.__name__.__eq__, ["str"],          true]
    - [hl1231sk007, hashlib.__dict__.__class__.__module__.__class__.__name__.__eq__, ["str"],        true]
    - [hl1231sk008, hashlib.__dict__.__contains__,                    ["__name__"],                  true]
    - [hl1231sk009, hashlib.__dict__.__contains__,                    ["__doc__"],                   true]

table hashlib_extra1231.module_name_and_package_attrs:
  description: "hashlib module __name__, __package__, __spec__ presence and identity via __dict__.__contains__"
  kind: python_call_eq
  category: module_name_and_package_attrs
  id_prefix: hl1231np
  columns: [id, function, args, expected]
  rows:
    - [hl1231np001, hashlib.__dict__.__contains__,                    ["__package__"],               true]
    - [hl1231np002, hashlib.__dict__.__contains__,                    ["__spec__"],                  true]
    - [hl1231np003, hashlib.__dict__.__contains__,                    ["__loader__"],                true]
    - [hl1231np004, hashlib.__name__.__eq__,                          ["hashlib"],                   true]
    - [hl1231np005, hashlib.__name__.__class__.__name__.__eq__,       ["str"],                       true]
    - [hl1231np006, hashlib.__package__.__eq__,                       [""],                          true]
    - [hl1231np007, hashlib.__package__.__class__.__name__.__eq__,    ["str"],                       true]
    - [hl1231np008, hashlib.__dict__.__contains__,                    ["__builtins__"],              true]
    - [hl1231np009, hashlib.__dict__.__class__.__qualname__.__class__.__name__.__eq__, ["str"],      true]
