spec: theseus_dataclasses_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_dataclasses_cr3)
blocks: dataclasses

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html"
    - "PEP 557 — Data Classes"
  notes:
    - "Clean-room extended dataclasses utilities. Do NOT import dataclasses."
    - "fields(cls_or_instance): return tuple of Field objects for a dataclass."
    - "asdict(obj): recursively convert dataclass to dict."
    - "astuple(obj): recursively convert dataclass to tuple."
    - "dataclasses3_fields(): define Point dataclass with x, y; len(fields(Point)) == 2."
    - "dataclasses3_asdict(): asdict(Point(1, 2)) == {'x': 1, 'y': 2}."
    - "dataclasses3_astuple(): astuple(Point(1, 2)) == (1, 2)."
    - "Zero-arg invariant signatures — def dataclasses3_fields(): return hardcoded_result"
    - "Export: dataclass (decorator), fields(obj), asdict(obj), astuple(obj), field(...)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_dataclasses_cr3.fields:
  description: "len(fields(Point)) == 2 for a Point dataclass with x, y"
  category: fields
  kind: python_call_eq
  function: dataclasses3_fields
  args: []
  expected: 2

invariant theseus_dataclasses_cr3.asdict:
  description: "asdict(Point(1, 2)) == {'x': 1, 'y': 2}"
  category: asdict
  kind: python_call_eq
  function: dataclasses3_asdict
  args: []
  expected: {"x": 1, "y": 2}

invariant theseus_dataclasses_cr3.astuple:
  description: "astuple(Point(1, 2)) == (1, 2)"
  category: astuple
  kind: python_call_eq
  function: dataclasses3_astuple
  args: []
  expected: [1, 2]
