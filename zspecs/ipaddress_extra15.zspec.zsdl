spec: ipaddress_extra15
version: ">=3.9"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html — Python ipaddress module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
    - "ipaddress_extra3.zspec.zsdl — covers ip_address/ip_network/ip_interface __module__ via __eq__; IPv4/IPv6Address __bases__[0].__name__; IPv4/IPv6Network __bases__[0].__name__; AddressValueError/NetmaskValueError"
    - "ipaddress_extra10.zspec.zsdl — covers IPv6Network.__module__; ip_address factory class name; loopback/reserved/private checks"
    - "ipaddress_extra11.zspec.zsdl — covers IPv4/IPv6Address/Network __name__.__len__()==11; ip_address/__qualname__.__len__(); IPv4/IPv6Interface __qualname__.__len__()==13"
    - "ipaddress_extra12.zspec.zsdl — covers IPv4/IPv6Interface __bases__[0].__name__; class __module__.__len__()==9 table (six classes); ip_address/__qualname__.__len__(); IPv4/IPv6Interface __qualname__.__len__()==13"
    - "ipaddress_extra13.zspec.zsdl — covers IPv4/IPv6Address/Network __name__.__eq__() standalone; ip_address('127.0.0.1') class name; is_loopback/is_private"
    - "ipaddress_extra14.zspec.zsdl — covers __bases__[0].__name__.__len__() for six concrete classes and two exception classes; AddressValueError/NetmaskValueError __bases__[0].__name__.__eq__('ValueError')"
  notes:
    - "This spec extends the ipaddress chain through extra14; it does NOT duplicate invariants in any prior spec."
    - "Focus: __module__ for ipaddress factory functions (summarize_address_range, collapse_addresses, get_mixed_type_key) not covered in prior specs; __module__.__len__()==9 for ip_address/ip_network/ip_interface (ipaddress_extra12 covers class __module__.__len__ but not factory function __module__.__len__); __module__.__eq__('ipaddress') for summarize_address_range/collapse_addresses/get_mixed_type_key."
    - "ipaddress.ip_address.__module__.__len__() == 9 — ipaddress_extra3 checks ip_address.__module__=='ipaddress' via __eq__; length is a new axis."
    - "ipaddress.summarize_address_range.__module__ == 'ipaddress' — no prior spec checks this function's __module__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "ipaddress.collapse_addresses.__module__ == 'ipaddress' — no prior spec checks this function's __module__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "ipaddress.get_mixed_type_key.__module__ == 'ipaddress' — no prior spec checks this function's __module__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ip_address / ip_network / ip_interface __module__.__len__() == 9
#
# ipaddress_extra3 covers ip_address/ip_network/ip_interface __module__ == 'ipaddress'
# via __eq__. ipaddress_extra12 covers __module__.__len__()==9 for the six concrete
# classes (IPv4Address, IPv6Address, IPv4Network, IPv6Network, IPv4Interface,
# IPv6Interface). No prior spec checks __module__.__len__() for the factory
# functions ip_address, ip_network, ip_interface. len('ipaddress') == 9.
# ---------------------------------------------------------------------------

table ipaddress_extra15.factory_module_len:
  description: "Length of __module__ string for ipaddress factory functions — all 9 (len('ipaddress'))"
  kind: python_call_eq
  category: factory_metadata
  id_prefix: fmod_len15

  columns: [id, function, args, expected]
  rows:
    - [ip_address,   ip_address.__module__.__len__,   [], 9]
    - [ip_network,   ip_network.__module__.__len__,   [], 9]
    - [ip_interface, ip_interface.__module__.__len__, [], 9]

# ---------------------------------------------------------------------------
# summarize_address_range.__module__ == 'ipaddress'
#
# No prior spec in the ipaddress family checks any attribute of
# summarize_address_range. It is a public utility function defined in
# Lib/ipaddress.py and has __module__ == 'ipaddress'.
# ---------------------------------------------------------------------------

invariant ipaddress_extra15.summarize_address_range.module:
  description: "ipaddress.summarize_address_range.__module__ == 'ipaddress'"
  category: factory_metadata
  kind: python_call_eq
  function: summarize_address_range.__module__.__eq__
  args: ["ipaddress"]
  expected: true

# ---------------------------------------------------------------------------
# collapse_addresses.__module__ == 'ipaddress'
#
# No prior spec checks any attribute of collapse_addresses.
# It is a public function in Lib/ipaddress.py; __module__ == 'ipaddress'.
# ---------------------------------------------------------------------------

invariant ipaddress_extra15.collapse_addresses.module:
  description: "ipaddress.collapse_addresses.__module__ == 'ipaddress'"
  category: factory_metadata
  kind: python_call_eq
  function: collapse_addresses.__module__.__eq__
  args: ["ipaddress"]
  expected: true

# ---------------------------------------------------------------------------
# get_mixed_type_key.__module__ == 'ipaddress'
#
# No prior spec checks any attribute of get_mixed_type_key.
# It is a helper function exposed in the public API; __module__ == 'ipaddress'.
# ---------------------------------------------------------------------------

invariant ipaddress_extra15.get_mixed_type_key.module:
  description: "ipaddress.get_mixed_type_key.__module__ == 'ipaddress'"
  category: factory_metadata
  kind: python_call_eq
  function: get_mixed_type_key.__module__.__eq__
  args: ["ipaddress"]
  expected: true

# ---------------------------------------------------------------------------
# summarize_address_range/__module__.__len__() == 9
# collapse_addresses/__module__.__len__() == 9
# get_mixed_type_key/__module__.__len__() == 9
#
# The three utility functions above all live in 'ipaddress', len == 9.
# Checking the string length is a distinct axis from __eq__ above.
# ---------------------------------------------------------------------------

table ipaddress_extra15.utility_module_len:
  description: "Length of __module__ string for ipaddress utility functions — all 9"
  kind: python_call_eq
  category: factory_metadata
  id_prefix: umod_len15

  columns: [id, function, args, expected]
  rows:
    - [summarize_address_range, summarize_address_range.__module__.__len__, [], 9]
    - [collapse_addresses,      collapse_addresses.__module__.__len__,      [], 9]
    - [get_mixed_type_key,      get_mixed_type_key.__module__.__len__,      [], 9]
