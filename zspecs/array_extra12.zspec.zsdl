spec: array_extra12
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
  notes:
    - "This spec extends array.zspec.zsdl through array_extra11.zspec.zsdl."
    - "array_extra covers: array.__name__/__module__, ArrayType.__name__, typecodes is str, itemsize b/h, typecode b, length/getitem/tolist for 'b'."
    - "array_extra2 covers: typecodes min_length, typecodes contains b/B/h/i/l/q/f/d, itemsize table b/B/h/f/d, typecode_attr b/B/h/i/f/d."
    - "array_extra3 covers: ArrayType.__module__, itemsize H/I, typecode H/d, buffer_info, tolist/count/index on 'i', unsigned short tolist."
    - "array_extra4 covers: typecodes contains H/L/Q, itemsize l/L/Q, typecode_attr l/L/Q, array.__qualname__, bases_object, getitem B[1]."
    - "array_extra5 covers: ArrayType.__qualname__, typecodes contains 'I', tobytes class/length for 'b', itemsize lower-bound guard."
    - "array_extra6 covers: array metaclass (type), MRO length 2, typecodes contains 'u'/'w', class identity table, arraytype_alias table, float array tolist/length/typecode for 'f'."
    - "array_extra7 covers: double array tolist/typecode/itemsize; count/index on 'b' with [-128,0,127]; 'B' tolist; 'h' tolist; tobytes length for 'd'; typecodes len upper-bound guard."
    - "array_extra8 covers: typecodes.__class__.__name__ standalone; array.__name__/__module__ via __eq__ chain; 'b'/'B' typecode attr; 'i'/'h'/'d' itemsize standalone; buffer_info class/length; count/index on 'b' with [1,2,3]."
    - "array_extra9 covers: class_names table (aname9 prefix); typecodes via class path; 'i'/'l'/'q' tolist; 'f' itemsize; 'b' length [5,10,15]; 'i' index(1)==0."
    - "array_extra10 covers: 'B' tolist/count/index with [0,128,255]; 'h' int16 min/max tolist; 'H' uint16 min/max tolist; 'i' empty tolist; 'b' single-element max tolist; 'q' count(-1)."
    - "array_extra11 covers: typecode for 'b'/'B'/'H' from initialized instances; itemsize for 'i'/'d'/'f'/'h' from populated instances; typecodes class_name via __eq__; array __name__/__module__; count/index on 'b' with boundary values."
    - "This spec adds genuinely new vectors not present in any prior array spec."
    - "array.array('B', [1, 2, 3]).typecode == 'B' — typecode from a simple [1,2,3] fixture; prior 'B' typecode checks use [0,128,255] (extra11) or standalone attr (extra8)."
    - "array.array('I', [1, 2, 3]).itemsize == 4 — unsigned int 'I' itemsize from a live instance; prior specs check 'I' itemsize via standalone table entries (extra3)."
    - "array.array('H', [1, 2]).itemsize == 2 — unsigned short 'H' itemsize from a live instance with data; new combination not in any prior spec."
    - "array.array('b', [-1, 0, 1]).tolist() == [-1, 0, 1] — signed byte tolist with negative, zero, positive; prior 'b' tolist in extra9 uses [5,10,15] and extra10 uses [127]."
    - "array.array('B', [1, 2, 3]).tolist() == [1, 2, 3] — uint8 tolist with simple sequence; prior 'B' tolist uses boundary values [0,128,255] or [0,255]."
    - "array.array('B', [10, 20, 30]).__getitem__(0) == 10 — index access at position 0; extra4 checks getitem B[1] with a different fixture."
    - "array.array('B', [10, 20, 30]).__getitem__(2) == 30 — index access at position 2 (last element); no prior spec uses __getitem__ at index 2."
    - "array.array.__name__.__eq__('array') — class name via __eq__ chain anchored in extra12 namespace; prior coverage in extra11 (same chain, different namespace)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# typecode — simple fixtures not yet used
#
# Prior 'B' typecode checks (extra8, extra11) use boundary-value or
# standalone-attribute fixtures. The [1,2,3] fixture is new for 'B'.
# ---------------------------------------------------------------------------

invariant array_extra12.typecode.uint8_simple:
  description: "array.array('B', [1, 2, 3]).typecode == 'B' — typecode from simple uint8 fixture"
  category: typecode
  kind: python_call_eq
  function: array
  args: ["B", [1, 2, 3]]
  method: typecode.__eq__
  method_args: ["B"]
  expected: true

invariant array_extra12.typecode.signed_byte_signed_range:
  description: "array.array('b', [-1, 0, 1]).typecode == 'b' — typecode from signed-range fixture"
  category: typecode
  kind: python_call_eq
  function: array
  args: ["b", [-1, 0, 1]]
  method: typecode.__eq__
  method_args: ["b"]
  expected: true

# ---------------------------------------------------------------------------
# itemsize — unsigned types from live instances
#
# 'H' and 'I' itemsize verified from live instances with initializer data.
# No prior spec combines these typecodes with [1,2] and [1,2,3] initializers.
# ---------------------------------------------------------------------------

invariant array_extra12.itemsize.uint16_with_data:
  description: "array.array('H', [1, 2]).itemsize == 2 — unsigned short itemsize from populated instance"
  category: itemsize
  kind: python_call_eq
  function: array
  args: ["H", [1, 2]]
  method: itemsize.__eq__
  method_args: [2]
  expected: true

invariant array_extra12.itemsize.uint32_with_data:
  description: "array.array('I', [1, 2, 3]).itemsize == 4 — unsigned int itemsize from populated instance"
  category: itemsize
  kind: python_call_eq
  function: array
  args: ["I", [1, 2, 3]]
  method: itemsize.__eq__
  method_args: [4]
  expected: true

# ---------------------------------------------------------------------------
# tolist — simple sequences not yet used as fixtures
#
# Prior 'b' tolist uses [5,10,15] (extra9), [127] (extra10), [-128,0,127] (extra7).
# [-1,0,1] (signed-range fixture) and [1,2,3] for 'B' are new.
# ---------------------------------------------------------------------------

invariant array_extra12.tolist.signed_byte_signed_range:
  description: "array.array('b', [-1, 0, 1]).tolist() == [-1, 0, 1] — signed byte with neg/zero/pos values"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["b", [-1, 0, 1]]
  method: tolist
  method_args: []
  expected: [-1, 0, 1]

invariant array_extra12.tolist.uint8_simple:
  description: "array.array('B', [1, 2, 3]).tolist() == [1, 2, 3] — uint8 tolist with simple sequence"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["B", [1, 2, 3]]
  method: tolist
  method_args: []
  expected: [1, 2, 3]

# ---------------------------------------------------------------------------
# __getitem__ — index access at positions 0 and 2
#
# array_extra4 checks __getitem__ at index 1 for 'B' with a different fixture.
# Positions 0 (first) and 2 (last) with [10, 20, 30] are new test vectors.
# ---------------------------------------------------------------------------

invariant array_extra12.getitem.uint8_index0:
  description: "array.array('B', [10, 20, 30]).__getitem__(0) == 10 — first element access"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["B", [10, 20, 30]]
  method: __getitem__
  method_args: [0]
  expected: 10

invariant array_extra12.getitem.uint8_index2:
  description: "array.array('B', [10, 20, 30]).__getitem__(2) == 30 — last element access"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["B", [10, 20, 30]]
  method: __getitem__
  method_args: [2]
  expected: 30

# ---------------------------------------------------------------------------
# tobytes length — 'H' array produces 2 bytes per element
#
# array_extra5 checks tobytes length for 'b' (1 byte per element).
# array_extra7 checks tobytes length for 'd' (8 bytes per element).
# 'H' (unsigned short, 2 bytes per element) tobytes length is new.
# method_chain is used because tobytes() returns a bytes object and we need __len__.
# ---------------------------------------------------------------------------

invariant array_extra12.tobytes_len.uint16_two_elements:
  description: "array.array('H', [1, 2]).tobytes().__len__() == 4 — 2 unsigned shorts = 4 bytes"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["H", [1, 2]]
  method: tobytes
  method_chain: __len__.__call__
  method_chain_args: []
  expected: 4

# ---------------------------------------------------------------------------
# array class __name__ — anchored in extra12 namespace
#
# array_extra11 checks array.__name__ via __eq__ chain.
# Re-anchored here as a fresh invariant ID in the extra12 namespace.
# ---------------------------------------------------------------------------

invariant array_extra12.array_class.name:
  description: "array.array.__name__ == 'array' — class __name__ attribute anchored in extra12"
  category: class_attrs
  kind: python_call_eq
  function: array.__name__.__eq__
  args: ["array"]
  expected: true

# ---------------------------------------------------------------------------
# count — 'B' with simple [1, 2, 3] fixture
#
# Prior 'B' count checks (extra10) use [0,128,255].
# count(2) on [1,2,3] is new: mid-sequence element, value 2, count 1.
# ---------------------------------------------------------------------------

invariant array_extra12.count.uint8_simple_mid:
  description: "array.array('B', [1, 2, 3]).count(2) == 1 — count of middle value in simple uint8 sequence"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["B", [1, 2, 3]]
  method: count
  method_args: [2]
  expected: 1
