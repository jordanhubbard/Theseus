spec: pathlib_extra71
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python code object co_varnames, co_filename, and co_flags documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra70.zspec.zsdl — covers Path.open/__code__.co_name.__eq__('open'); Path.read_text/__code__.co_name.__eq__('read_text'); Path.open/__code__.co_argcount.__eq__(6); PurePath.__repr__/__code__.co_name.__eq__('__repr__'); Path.__doc__.__contains__('filesystem')."
    - "pathlib_extra69.zspec.zsdl — covers Path.open/__defaults__.__class__.__name__.__eq__('tuple') and __len__()==5; Path.read_text/__defaults__.__class__.__name__.__eq__('tuple') and __len__()==3; Path.open/__code__.__class__.__name__.__eq__('code'); Path.__init__/__code__.__class__.__name__.__eq__('code'); Path.__doc__.__contains__('PurePath'/'system')."
    - "pathlib_extra68.zspec.zsdl — covers Path.open/__annotations__/__globals__ class identity; PurePath.__doc__.__contains__('path'/'Base')."
    - "pathlib_extra67.zspec.zsdl — covers PurePath/__str__/__repr__/__fspath__/__eq__/__hash__ __qualname__.__eq__(); Path.open/read_text/write_text __qualname__.__eq__()."
  notes:
    - "This spec extends pathlib_extra70.zspec.zsdl."
    - "Theme: __code__ attribute chains — co_varnames, co_filename, co_flags for Path.open/Path.read_text and more pathlib functions."
    - "Path is a pure Python class. Path.open, Path.read_text, Path.iterdir, Path.mkdir, Path.exists are Python functions with __code__ objects."
    - "Path.open.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple of local variable names in CPython code objects. No prior pathlib spec checks Path.open.__code__.co_varnames.__class__.__name__ in pathlibcode3_71 namespace. Novel co_varnames class-name anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.open.__code__.co_varnames[0] == 'self' — the first local variable for a method is always 'self'. No prior pathlib spec checks Path.open.__code__.co_varnames[0] in pathlibcode3_71 namespace. Table function values containing '[' must be double-quoted. Novel co_varnames[0] anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.open.__code__.co_filename.__contains__('.py') == True — co_filename holds the source file path; pathlib is pure Python so the path contains '.py'. No prior pathlib spec checks co_filename.__contains__('.py') for any pathlib function in pathlibcode3_71 namespace. Novel co_filename anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.open.__code__.co_flags.__class__.__name__ == 'int' — co_flags is always an integer bitmask encoding code object properties. No prior pathlib spec checks co_flags.__class__.__name__ for any pathlib function. Novel co_flags class-name anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.open, Path.read_text, Path.iterdir __code__.co_varnames class name
#
# co_varnames is a tuple of all local variable names (parameters first, then
# locals). In CPython this is always stored as a Python tuple.
#
#   Path.open.__code__.co_varnames.__class__.__name__     == 'tuple'
#   Path.read_text.__code__.co_varnames.__class__.__name__ == 'tuple'
#   Path.iterdir.__code__.co_varnames.__class__.__name__   == 'tuple'
#
# No prior pathlib spec checks co_varnames.__class__.__name__ for any
# pathlib function in the pathlibcode3_71 namespace. Novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra71.co_varnames_class_name:
  description: "Path.open/read_text/iterdir __code__.co_varnames.__class__.__name__.__eq__('tuple') — co_varnames is always a tuple of local variable names in CPython; Path is pure Python; no prior pathlib spec checks co_varnames.__class__.__name__ for any pathlib function in pathlibcode3_71 namespace; novel co_varnames class-name anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_covarnames
  id_prefix: pathlibcode3_71covarclass

  columns: [id, function, args, expected]
  rows:
    - [open_co_varnames_class,      Path.open.__code__.co_varnames.__class__.__name__.__eq__,      ["tuple"], true]
    - [read_text_co_varnames_class, Path.read_text.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true]
    - [iterdir_co_varnames_class,   Path.iterdir.__code__.co_varnames.__class__.__name__.__eq__,   ["tuple"], true]

# ---------------------------------------------------------------------------
# Path.open, Path.read_text, Path.iterdir __code__.co_varnames[0]
#
# For methods, co_varnames[0] is always 'self' (the first positional argument).
#
#   Path.open.__code__.co_varnames[0]      == 'self'
#   Path.read_text.__code__.co_varnames[0] == 'self'
#   Path.iterdir.__code__.co_varnames[0]   == 'self'
#
# No prior pathlib spec checks co_varnames[0] for any pathlib function.
# Table function values containing '[' MUST be double-quoted YAML strings.
# Novel co_varnames[0] anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra71.co_varnames_first_arg:
  description: "Path.open/read_text/iterdir __code__.co_varnames[0].__eq__('self') — for methods co_varnames[0] is always 'self'; no prior pathlib spec checks co_varnames[0] for any pathlib function in pathlibcode3_71 namespace; function values with '[' are double-quoted per ZSDL rules; novel co_varnames[0] anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_covarnames
  id_prefix: pathlibcode3_71covarself

  columns: [id, function, args, expected]
  rows:
    - [open_co_varnames_0_self,      "Path.open.__code__.co_varnames[0].__eq__",      ["self"], true]
    - [read_text_co_varnames_0_self, "Path.read_text.__code__.co_varnames[0].__eq__", ["self"], true]
    - [iterdir_co_varnames_0_self,   "Path.iterdir.__code__.co_varnames[0].__eq__",   ["self"], true]

# ---------------------------------------------------------------------------
# Path.open, Path.read_text, Path.mkdir __code__.co_filename contains '.py'
#
# co_filename holds the source file path from which the code was compiled.
# pathlib is a pure Python module so the filename contains '.py'.
#
#   Path.open.__code__.co_filename.__contains__('.py')      == True
#   Path.read_text.__code__.co_filename.__contains__('.py') == True
#   Path.mkdir.__code__.co_filename.__contains__('.py')     == True
#
# No prior pathlib spec checks co_filename.__contains__('.py') for any
# pathlib function in the pathlibcode3_71 namespace. Novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra71.co_filename_contains_py:
  description: "Path.open/read_text/mkdir __code__.co_filename.__contains__('.py') — pathlib is pure Python; co_filename holds the source file path containing '.py'; no prior pathlib spec checks co_filename.__contains__('.py') for any pathlib function in pathlibcode3_71 namespace; novel co_filename anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_cofilename
  id_prefix: pathlibcode3_71cofile

  columns: [id, function, args, expected]
  rows:
    - [open_co_filename_contains_py,      Path.open.__code__.co_filename.__contains__,      [".py"], true]
    - [read_text_co_filename_contains_py, Path.read_text.__code__.co_filename.__contains__, [".py"], true]
    - [mkdir_co_filename_contains_py,     Path.mkdir.__code__.co_filename.__contains__,     [".py"], true]

# ---------------------------------------------------------------------------
# Path.open, Path.read_text, Path.iterdir __code__.co_flags class name
#
# co_flags is an integer bitmask encoding various properties of the code
# object (e.g., CO_OPTIMIZED, CO_NEWLOCALS, CO_VARARGS, CO_VARKEYWORDS,
# CO_NESTED, CO_GENERATOR, etc.). Its type is always int.
#
#   Path.open.__code__.co_flags.__class__.__name__      == 'int'
#   Path.read_text.__code__.co_flags.__class__.__name__ == 'int'
#   Path.iterdir.__code__.co_flags.__class__.__name__   == 'int'
#
# No prior pathlib spec checks co_flags.__class__.__name__ for any pathlib
# function. Novel co_flags class-name anchors in pathlibcode3_71 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra71.co_flags_class_name:
  description: "Path.open/read_text/iterdir __code__.co_flags.__class__.__name__.__eq__('int') — co_flags is an integer bitmask encoding code object properties; no prior pathlib spec checks co_flags.__class__.__name__ for any pathlib function in pathlibcode3_71 namespace; novel co_flags class-name anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_coflags
  id_prefix: pathlibcode3_71coflags

  columns: [id, function, args, expected]
  rows:
    - [open_co_flags_class,      Path.open.__code__.co_flags.__class__.__name__.__eq__,      ["int"], true]
    - [read_text_co_flags_class, Path.read_text.__code__.co_flags.__class__.__name__.__eq__, ["int"], true]
    - [iterdir_co_flags_class,   Path.iterdir.__code__.co_flags.__class__.__name__.__eq__,   ["int"], true]

invariant pathlib_extra71.path_open_co_varnames_tuple:
  description: "Path.open.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is a tuple of local variable names in CPython; Path.open is pure Python; no prior pathlib spec checks co_varnames.__class__.__name__ for any pathlib function in pathlibcode3_71 namespace; novel co_varnames class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_covarnames
  kind: python_call_eq
  function: Path.open.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant pathlib_extra71.path_open_co_varnames_self:
  description: "Path.open.__code__.co_varnames[0].__eq__('self') == True — for methods co_varnames[0] is always 'self'; no prior pathlib spec checks co_varnames[0] for Path.open in pathlibcode3_71 namespace; novel co_varnames[0] anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_covarnames
  kind: python_call_eq
  function: "Path.open.__code__.co_varnames[0].__eq__"
  args: ["self"]
  expected: true

invariant pathlib_extra71.path_read_text_co_varnames_self:
  description: "Path.read_text.__code__.co_varnames[0].__eq__('self') == True — for methods co_varnames[0] is always 'self'; no prior pathlib spec checks co_varnames[0] for Path.read_text in pathlibcode3_71 namespace; novel co_varnames[0] anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_covarnames
  kind: python_call_eq
  function: "Path.read_text.__code__.co_varnames[0].__eq__"
  args: ["self"]
  expected: true

invariant pathlib_extra71.path_open_co_filename_contains_py:
  description: "Path.open.__code__.co_filename.__contains__('.py') == True — pathlib is pure Python; co_filename holds the source file path containing '.py'; no prior pathlib spec checks co_filename.__contains__('.py') for any pathlib function in pathlibcode3_71 namespace; novel co_filename anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_cofilename
  kind: python_call_eq
  function: Path.open.__code__.co_filename.__contains__
  args: [".py"]
  expected: true

invariant pathlib_extra71.path_open_co_flags_int:
  description: "Path.open.__code__.co_flags.__class__.__name__.__eq__('int') == True — co_flags is an integer bitmask encoding code object properties; no prior pathlib spec checks co_flags.__class__.__name__ for any pathlib function in pathlibcode3_71 namespace; novel co_flags class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_coflags
  kind: python_call_eq
  function: Path.open.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true
