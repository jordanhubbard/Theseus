spec: concurrent_futures_extra2416
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/concurrent.futures.html"
    - "CPython source — Lib/concurrent/futures/_base.py, thread.py, process.py"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 608 (_extra2416): __iter__ and __next__ dict-presence and type classification."
    - "concurrent.futures.Future is a high-level future; it does NOT define __iter__ or __next__."
    - "concurrent.futures.Executor and its subclasses (ThreadPoolExecutor, ProcessPoolExecutor) are not iterable."
    - "Executor implements context manager protocol (__enter__/__exit__) but not iteration protocol."
    - "None of the public classes in concurrent.futures define __iter__ or __next__ in their own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
# Table 1: __iter__ absence in class __dict__ for concurrent.futures types
# ===

table concurrent_futures_extra2416.iter_not_in_dict:
  description: "No concurrent.futures class defines __iter__ in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2416
  columns: [id, function, args, expected]
  rows:
    - ["cf2416001", "concurrent.futures.Future.__dict__.__contains__", ["__iter__"], false]
    - ["cf2416002", "concurrent.futures.Executor.__dict__.__contains__", ["__iter__"], false]
    - ["cf2416003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__iter__"], false]
    - ["cf2416004", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__iter__"], false]

# ===
# Table 2: __next__ absence in class __dict__ for concurrent.futures types
# ===

table concurrent_futures_extra2416.next_not_in_dict:
  description: "No concurrent.futures class defines __next__ in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2416
  columns: [id, function, args, expected]
  rows:
    - ["cf2416005", "concurrent.futures.Future.__dict__.__contains__", ["__next__"], false]
    - ["cf2416006", "concurrent.futures.Executor.__dict__.__contains__", ["__next__"], false]
    - ["cf2416007", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__next__"], false]
    - ["cf2416008", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__next__"], false]

# ===
# Table 3: context manager protocol present, iteration protocol absent — Executor
# ===

table concurrent_futures_extra2416.context_not_iter:
  description: "Executor defines context manager protocol (__enter__) in its __dict__ but not iteration protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2416
  columns: [id, function, args, expected]
  rows:
    - ["cf2416009", "concurrent.futures.Executor.__dict__.__contains__", ["__enter__"], true]
    - ["cf2416010", "concurrent.futures.Executor.__dict__.__contains__", ["__exit__"], true]
    - ["cf2416011", "concurrent.futures.Executor.__dict__.__contains__", ["__iter__"], false]
    - ["cf2416012", "concurrent.futures.Executor.__dict__.__contains__", ["__next__"], false]
    - ["cf2416013", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__enter__"], false]
    - ["cf2416014", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__iter__"], false]
    - ["cf2416015", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__enter__"], false]
    - ["cf2416016", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__iter__"], false]

# ===
# Table 4: full matrix — iter/next absent for all public concurrent.futures types
# ===

table concurrent_futures_extra2416.full_matrix:
