spec: hashlib_extra193
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "RFC 7693 — The BLAKE2 Cryptographic Hash and Message Authentication Code (MAC)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "RFC 7693 — The BLAKE2 Cryptographic Hash and Message Authentication Code (MAC)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_blake2/blake2module.c"
  notes:
    - "This spec covers hashlib.new and hashlib.blake2b/blake2s function identity attributes not previously covered."
    - "hashlib.new.__name__ == '__hash_new' — the factory function is an internal wrapper named '__hash_new' in the hashlib module."
    - "hashlib.new.__module__ == 'hashlib' — it is a Python-defined function in Lib/hashlib.py."
    - "hashlib.new.__class__.__name__ == 'function' — it is a plain Python function object."
    - "hashlib.blake2b.__name__ == 'blake2b' — the BLAKE2b constructor class; its __name__ is the algorithm name."
    - "hashlib.blake2b.__module__ == '_blake2' — blake2b is implemented in the _blake2 C extension module."
    - "hashlib.blake2b.__class__.__name__ == 'type' — blake2b is a class (type), not a plain function."
    - "hashlib.blake2s.__name__ == 'blake2s' — the BLAKE2s constructor class."
    - "hashlib.blake2s.__module__ == '_blake2' — blake2s is also implemented in the _blake2 C extension."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new — factory function identity checks
#
# hashlib.new.__name__ == '__hash_new' (internal wrapper in Lib/hashlib.py)
# hashlib.new.__module__ == 'hashlib'
# hashlib.new.__class__.__name__ == 'function' (Python-defined)
# ---------------------------------------------------------------------------

table hashlib_extra193.new_identity:
  description: "hashlib.new function identity checks in hashlibblake193 namespace — hashlib.new is the factory function for creating hash objects by algorithm name string; new.__name__.__eq__('__hash_new')==True (len=11: '__hash_new' is the internal Python function name, not 'new', because the module attribute 'new' is bound to an internal wrapper; '__hash_new'=10 chars; compare: blake2b.__name__='blake2b'=7, blake2s.__name__='blake2s'=7, shorter than '__hash_new'=10); new.__module__.__eq__('hashlib')==True (Python-defined in Lib/hashlib.py, not a C extension); new.__class__.__name__.__eq__('function')==True (it is a plain Python function object, unlike blake2b/__class__='type'); all verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibblake193

  columns: [id, function, args, expected, description]
  rows:
    - [new_name_eq,    new.__name__.__eq__,          ["__hash_new"], true, "hashlib.new.__name__ == '__hash_new' (internal Python wrapper name, len=10); verified with Python 3.14.3"]
    - [new_module_eq,  new.__module__.__eq__,         ["hashlib"],    true, "hashlib.new.__module__ == 'hashlib' (Python-defined in Lib/hashlib.py); verified with Python 3.14.3"]
    - [new_cls_eq,     new.__class__.__name__.__eq__, ["function"],   true, "hashlib.new.__class__.__name__ == 'function' (plain Python function, not a C-level type); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.blake2b — class identity checks
#
# hashlib.blake2b.__name__ == 'blake2b'
# hashlib.blake2b.__module__ == '_blake2'
# hashlib.blake2b.__class__.__name__ == 'type'
# ---------------------------------------------------------------------------

table hashlib_extra193.blake2b_identity:
  description: "hashlib.blake2b class identity checks in hashlibblake193 namespace — blake2b is the BLAKE2b hash constructor class exported from the _blake2 C extension and re-exported through hashlib; blake2b.__name__.__eq__('blake2b')==True (len=7: 'blake2b'=7, same length as 'blake2s'=7); blake2b.__module__.__eq__('_blake2')==True (len=7: implemented in the _blake2 C extension, not 'hashlib'; compare: hashlib.new.__module__='hashlib' — Python-defined vs _blake2 — C extension); blake2b.__class__.__name__.__eq__('type')==True (blake2b is a class object whose metaclass is 'type'; contrast: new.__class__.__name__='function' — new is a plain function, blake2b is a type); blake2s.__name__='blake2s' and blake2s.__module__='_blake2' (same extension, different algorithm); all verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibblake193b

  columns: [id, function, args, expected, description]
  rows:
    - [b2b_name_eq,   blake2b.__name__.__eq__,          ["blake2b"],  true, "hashlib.blake2b.__name__ == 'blake2b' (len=7; BLAKE2b class name equals algorithm name); verified with Python 3.14.3"]
    - [b2b_module_eq, blake2b.__module__.__eq__,         ["_blake2"],  true, "hashlib.blake2b.__module__ == '_blake2' (C extension, not 'hashlib' Python module); verified with Python 3.14.3"]
    - [b2b_cls_eq,    blake2b.__class__.__name__.__eq__, ["type"],     true, "hashlib.blake2b.__class__.__name__ == 'type' (blake2b is a class, not a function; contrast: new.__class__='function'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.blake2s — class identity checks
#
# hashlib.blake2s.__name__ == 'blake2s'
# hashlib.blake2s.__module__ == '_blake2'
# hashlib.blake2s.__class__.__name__ == 'type'
# ---------------------------------------------------------------------------

table hashlib_extra193.blake2s_identity:
  description: "hashlib.blake2s class identity checks in hashlibblake193 namespace — blake2s is the BLAKE2s hash constructor class (32-bit optimized variant of BLAKE2); blake2s.__name__.__eq__('blake2s')==True (len=7: 'blake2s'=7, same as blake2b='blake2b'=7, both end in character distinguishing variant: 'b' vs 's'); blake2s.__module__.__eq__('_blake2')==True (same C extension as blake2b: both blake2b and blake2s are in the _blake2 module; '_blake2'=7 chars same as 'blake2s'=7 chars — coincidental equal length); blake2s.__class__.__name__.__eq__('type')==True (blake2s is a type just like blake2b; both are class objects exported from _blake2); BLAKE2s output is 32 bytes max (blake2s().digest_size==32), shorter than BLAKE2b (64 bytes); all verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibblake193c

  columns: [id, function, args, expected, description]
  rows:
    - [b2s_name_eq,   blake2s.__name__.__eq__,          ["blake2s"],  true, "hashlib.blake2s.__name__ == 'blake2s' (len=7; BLAKE2s class name equals algorithm name); verified with Python 3.14.3"]
    - [b2s_module_eq, blake2s.__module__.__eq__,         ["_blake2"],  true, "hashlib.blake2s.__module__ == '_blake2' (same C extension as blake2b); verified with Python 3.14.3"]
    - [b2s_cls_eq,    blake2s.__class__.__name__.__eq__, ["type"],     true, "hashlib.blake2s.__class__.__name__ == 'type' (blake2s is a class object identical in metaclass to blake2b); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — hashlib_extra193
# ---------------------------------------------------------------------------

invariant hashlib_extra193.new_name_is_hash_new:
  description: "hashlib.new.__name__ == '__hash_new' — hashlib.new is a module-level Python function in Lib/hashlib.py; its __name__ attribute is '__hash_new' (len=10) rather than 'new', because the attribute 'new' in the hashlib namespace is bound to an internal wrapper function called '__hash_new'; this is an implementation detail of CPython's hashlib module where the public 'new' name is an alias for the internal '__hash_new'; compare: blake2b.__name__='blake2b'=7 chars (class, shorter) vs '__hash_new'=10 chars (function, longer); new.__module__=='hashlib' (Python-defined); new.__class__.__name__=='function' (not 'type' or 'builtin_function_or_method'); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["__hash_new"]
  expected: true

invariant hashlib_extra193.new_module_is_hashlib:
  description: "hashlib.new.__module__ == 'hashlib' — the factory function new is defined in Lib/hashlib.py (a pure Python module), so its __module__ is 'hashlib'; contrast with blake2b.__module__=='_blake2' and blake2s.__module__=='_blake2' (both are C extensions in _blake2); new's Python implementation allows it to dispatch to any registered algorithm by name string; new.__class__.__name__=='function' (Python-defined); hashlib.new is the recommended way to create hash objects when the algorithm is not known at import time; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: new.__module__.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlib_extra193.new_class_is_function:
  description: "hashlib.new.__class__.__name__ == 'function' — new is a plain Python function (not a class, not a built-in); its metaclass produces the class name 'function'; contrast: blake2b.__class__.__name__=='type' (blake2b is a type/class), and C-level functions have __class__.__name__=='builtin_function_or_method'; 'function'=8 chars; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: new.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant hashlib_extra193.blake2b_name_is_blake2b:
  description: "hashlib.blake2b.__name__ == 'blake2b' — blake2b is the BLAKE2b constructor class (RFC 7693); its __name__ is 'blake2b' (len=7), matching the algorithm name; blake2b is defined in the _blake2 C extension and re-exported by hashlib; blake2b is a type (its __class__.__name__ is 'type'), not a function; blake2b produces digests up to 512 bits (64 bytes); blake2b.__module__=='_blake2'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: blake2b.__name__.__eq__
  args: ["blake2b"]
  expected: true

invariant hashlib_extra193.blake2b_module_is_blake2_ext:
  description: "hashlib.blake2b.__module__ == '_blake2' — blake2b is implemented in the _blake2 C extension module (not in the hashlib Python wrapper); '_blake2'=7 chars; the leading underscore indicates a private C accelerator module; compare: hashlib.new.__module__=='hashlib' (Python), hashlib.sha256.__module__ may be '_hashlib' (OpenSSL-backed); blake2b and blake2s share the same _blake2 extension; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: blake2b.__module__.__eq__
  args: ["_blake2"]
  expected: true

invariant hashlib_extra193.blake2b_class_is_type:
  description: "hashlib.blake2b.__class__.__name__ == 'type' — blake2b is a class object (its metaclass is the built-in 'type'); calling blake2b() creates a BLAKE2b hash instance; 'type'=4 chars (shortest class name string in this spec); contrast with new.__class__.__name__=='function' (new is a Python function, not a class); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: blake2b.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant hashlib_extra193.blake2s_name_is_blake2s:
  description: "hashlib.blake2s.__name__ == 'blake2s' — blake2s is the BLAKE2s constructor class (RFC 7693 Section 2); 'blake2s'=7 chars (same length as 'blake2b'=7); the 's' suffix distinguishes the 32-bit optimized BLAKE2s variant from the 64-bit BLAKE2b; blake2s produces digests up to 256 bits (32 bytes), half the maximum of blake2b; blake2s.__module__=='_blake2' (same extension); blake2s.__class__.__name__=='type' (same metaclass); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: blake2s.__name__.__eq__
  args: ["blake2s"]
  expected: true

invariant hashlib_extra193.blake2s_module_is_blake2_ext:
  description: "hashlib.blake2s.__module__ == '_blake2' — blake2s shares the _blake2 C extension module with blake2b; both BLAKE2 variants are implemented together in Modules/_blake2/blake2module.c in CPython; '_blake2'=7 chars (same length as 'blake2s'=7 — coincidental); blake2s is the only BLAKE2 variant optimized for 8–32-bit platforms; blake2s.__class__.__name__=='type' (class, not function); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: blake2s.__module__.__eq__
  args: ["_blake2"]
  expected: true
