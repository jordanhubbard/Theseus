spec: itertools_extra92
version: ">=3.9"
backend: python_module(itertools)
extends: itertools_extra91

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra91.zspec.zsdl."
    - "This spec covers: itertools C-type __module__ equality — all itertools types have __module__ == 'itertools' (Wave 252)."
    - "itertools.chain.__module__ == 'itertools' — C extension type registered under the itertools module. Verified with Python 3.14.3."
    - "itertools.product.__module__ == 'itertools' — C extension type. Verified with Python 3.14.3."
    - "itertools.combinations.__module__ == 'itertools' — C extension type. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__module__ == 'itertools' — C extension type. Verified with Python 3.14.3."
    - "itertools.permutations.__module__ == 'itertools' — C extension type. Verified with Python 3.14.3."
    - "itertools.accumulate.__module__ == 'itertools' — C extension type. Verified with Python 3.14.3."
    - "itertools.groupby.__module__ == 'itertools' — C extension type. Verified with Python 3.14.3."
    - "itertools.islice.__module__ == 'itertools' — C extension type. Verified with Python 3.14.3."
    - "itertools.starmap.__module__ == 'itertools' — C extension type. Verified with Python 3.14.3."
    - "itertools.filterfalse.__module__ == 'itertools' — C extension type. Verified with Python 3.14.3."
    - "itertools.takewhile.__module__ == 'itertools' — C extension type. Verified with Python 3.14.3."
    - "itertools.count.__module__ == 'itertools' — C extension type. Verified with Python 3.14.3."
    - "itertools.repeat.__module__ == 'itertools' — C extension type. Verified with Python 3.14.3."
    - "itertools.dropwhile.__module__ == 'itertools' — C extension type. Verified with Python 3.14.3."
    - "itertools.zip_longest.__module__ == 'itertools' — C extension type. Verified with Python 3.14.3."
    - "itertools.cycle.__module__ == 'itertools' — C extension type. Verified with Python 3.14.3."
    - "itertools.compress.__module__ == 'itertools' — C extension type. Verified with Python 3.14.3."
    - "itertools.pairwise.__module__ == 'itertools' — C extension type (added in Python 3.10). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: chain/product/combinations/combinations_with_replacement/permutations
#
# Wave 252 theme: itertools C-type __module__ == 'itertools' — group 1.
#
# itertools.chain.__module__.__eq__('itertools')                        == True
# itertools.product.__module__.__eq__('itertools')                     == True
# itertools.combinations.__module__.__eq__('itertools')                == True
# itertools.combinations_with_replacement.__module__.__eq__('itertools') == True
# itertools.permutations.__module__.__eq__('itertools')                == True
#
# All five combinatoric/combining C types in itertoolsmodule.c report __module__ == 'itertools'.
# Prior spec extra91 checked __dict__.__class__.__name__; this spec (extra92) checks __module__. New to extra92.
# ---------------------------------------------------------------------------

table itertools_extra92.module_eq_group1:
  description: "chain/product/combinations/combinations_with_replacement/permutations __module__ == 'itertools'; C types in itertoolsmodule.c; wave 252; new to extra92"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsmodule92

  columns: [id, function, args, expected, description]
  rows:
    - [chain_module_eq_itertools,
       "chain.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.chain.__module__.__eq__('itertools') == True — chain is a C extension type in Modules/itertoolsmodule.c; PyTypeObject.tp_dict entry for __module__ is set to 'itertools' when the module is initialized; str.__eq__('itertools') returns True; prior spec extra91 checked chain.__dict__.__class__.__name__; this spec (extra92) checks __module__; new to extra92"]
    - [product_module_eq_itertools,
       "product.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — product is a C extension type; __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra92"]
    - [combinations_module_eq_itertools,
       "combinations.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.combinations.__module__.__eq__('itertools') == True — combinations is a C extension type; __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra92"]
    - [combinations_with_replacement_module_eq_itertools,
       "combinations_with_replacement.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.combinations_with_replacement.__module__.__eq__('itertools') == True — combinations_with_replacement is a C extension type; __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra92"]
    - [permutations_module_eq_itertools,
       "permutations.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.permutations.__module__.__eq__('itertools') == True — permutations is a C extension type; __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra92"]

