spec: itertools_extra11
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools.zspec.zsdl and prior extras through itertools_extra10.zspec.zsdl."
    - "itertools_extra10 covers: takewhile first element; dropwhile first element; count(5,2) first element; repeat(42,5).__length_hint__(); starmap(max,...) first element; groupby('AABBB') first key; accumulate([1,2,3],max) first element; islice([10,20,30,40],2,4) first element."
    - "NOT yet covered: combinations first-element behavioral test (only length/class covered); permutations first-element behavioral test (only length/class covered); product first-element and count behavioral tests; cycle first three elements; chain.from_iterable first-element actual call."
    - "combinations([1,2,3], 2).__next__() == (1, 2) — first combination in lexicographic order."
    - "combinations('ABC', 2).__length_hint__() == 3 — C(3,2) = 3 pairs."
    - "permutations([1,2,3], 2).__next__() == (1, 2) — first permutation in lexicographic order."
    - "product([1,2],[3,4]).__next__() == (1, 3) — first product pair: first of each input."
    - "product([1,2],[3,4]).__length_hint__() == 4 — 2*2 = 4 product tuples."
    - "cycle([1,2,3]).__next__() == 1 — first element of the cycled sequence."
    - "chain.from_iterable([[1,2],[3,4]]).__next__() == 1 — from_iterable flattens; first element is 1."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# combinations — first-element behavioral test
#
# itertools_extra2 covers combinations([1,2,3],2).__length_hint__() == 3 and
# class name only. No prior spec tests combinations for its first yielded value.
# combinations([1,2,3], 2) yields (1,2), (1,3), (2,3) in lexicographic order.
# The first element is (1, 2).
# combinations('ABC', 2) yields C(3,2)=3 pairs; __length_hint__() == 3.
# ---------------------------------------------------------------------------

invariant itertools_extra11.combinations.first_element:
  description: "combinations([1,2,3], 2).__next__() == (1, 2) — first combination in lexicographic order"
  category: combinations
  kind: python_call_eq
  function: combinations
  args: [[1, 2, 3], 2]
  method: __next__
  expected: [1, 2]

invariant itertools_extra11.combinations.string_length_hint:
  description: "combinations('ABC', 2).__length_hint__() == 3 — C(3,2) = 3 combinations"
  category: combinations
  kind: python_call_eq
  function: combinations
  args: ["ABC", 2]
  method: __length_hint__
  expected: 3

# ---------------------------------------------------------------------------
# permutations — first-element behavioral test
#
# itertools_extra2 covers permutations([1,2,3],2).__length_hint__() == 6 and
# class name. No prior spec tests permutations for its first yielded value.
# permutations([1,2,3], 2) yields (1,2),(1,3),(2,1),(2,3),(3,1),(3,2).
# The first element is (1, 2).
# ---------------------------------------------------------------------------

invariant itertools_extra11.permutations.first_element:
  description: "permutations([1,2,3], 2).__next__() == (1, 2) — first permutation in lexicographic order"
  category: permutations
  kind: python_call_eq
  function: permutations
  args: [[1, 2, 3], 2]
  method: __next__
  expected: [1, 2]

invariant itertools_extra11.permutations.two_item_count:
  description: "permutations([1,2], 2).__length_hint__() == 2 — P(2,2) = 2 ordered pairs"
  category: permutations
  kind: python_call_eq
  function: permutations
  args: [[1, 2], 2]
  method: __length_hint__
  expected: 2

# ---------------------------------------------------------------------------
# product — first-element and count behavioral tests
#
# itertools.zspec covers product('AB','CD').__next__ via class name only.
# itertools_extra4/5 cover product.__name__/__qualname__/__class__ metadata.
# No prior spec tests product for its actual first yielded value or element count.
# product([1,2],[3,4]) yields (1,3),(1,4),(2,3),(2,4) — 4 total tuples.
# First element is (1, 3): first of each input combined.
# ---------------------------------------------------------------------------

invariant itertools_extra11.product.first_element:
  description: "product([1,2],[3,4]).__next__() == (1, 3) — first product tuple: first of each input"
  category: product
  kind: python_call_eq
  function: product
  args: [[1, 2], [3, 4]]
  method: __next__
  expected: [1, 3]

invariant itertools_extra11.product.length_hint_four:
  description: "product([1,2],[3,4]).__length_hint__() == 4 — 2*2 = 4 product tuples"
  category: product
  kind: python_call_eq
  function: product
  args: [[1, 2], [3, 4]]
  method: __length_hint__
  expected: 4

invariant itertools_extra11.product.three_way_count:
  description: "product([1,2],[3,4],[5,6]).__length_hint__() == 8 — 2*2*2 = 8 product tuples"
  category: product
  kind: python_call_eq
  function: product
  args: [[1, 2], [3, 4], [5, 6]]
  method: __length_hint__
  expected: 8

# ---------------------------------------------------------------------------
# cycle — first-element behavioral test
#
# itertools_extra2 covers cycle([1]).__class__.__name__ == 'cycle' (class name
# only). No prior spec tests cycle for its first yielded value. cycle([1,2,3])
# repeats infinitely: 1, 2, 3, 1, 2, 3, ... The first element is 1.
# ---------------------------------------------------------------------------

invariant itertools_extra11.cycle.first_element:
  description: "cycle([1,2,3]).__next__() == 1 — first element of the cycled sequence"
  category: cycle
  kind: python_call_eq
  function: cycle
  args: [[1, 2, 3]]
  method: __next__
  expected: 1

invariant itertools_extra11.cycle.string_first_element:
  description: "cycle('XYZ').__next__() == 'X' — cycle works on any iterable; first char of string"
  category: cycle
  kind: python_call_eq
  function: cycle
  args: ["XYZ"]
  method: __next__
  expected: "X"

# ---------------------------------------------------------------------------
# chain.from_iterable — first-element actual call behavioral test
#
# itertools_extra6 covers chain.from_iterable.__qualname__ == 'chain.from_iterable'
# and __name__ == 'from_iterable' (metadata only). No prior spec tests
# chain.from_iterable for its actual first yielded value.
# chain.from_iterable([[1,2],[3,4]]) flattens the nested iterables; yields 1,2,3,4.
# The first element is 1.
# ---------------------------------------------------------------------------

invariant itertools_extra11.chain.from_iterable.first_element:
  description: "chain.from_iterable([[1,2],[3,4]]).__next__() == 1 — from_iterable flattens; first element is 1"
  category: chain
  kind: python_call_eq
  function: chain.from_iterable
  args: [[[1, 2], [3, 4]]]
  method: __next__
  expected: 1

invariant itertools_extra11.chain.from_iterable.string_first:
  description: "chain.from_iterable(['abc','de']).__next__() == 'a' — from_iterable on strings; first char"
  category: chain
  kind: python_call_eq
  function: chain.from_iterable
  args: [["abc", "de"]]
  method: __next__
  expected: "a"
