spec: functools_extra1651
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __init_subclass__ class creation hook"
    - "functools.partial is a C extension type; it does not define __init_subclass__ in its own __dict__"
    - "functools.partialmethod is a pure Python class; it does not define __init_subclass__ in its own __dict__"
    - "functools.cached_property is a pure Python class; it does not define __init_subclass__ in its own __dict__"
    - "object.__init_subclass__ is always present — it is the default no-op hook defined by object itself"
    - "functools.cached_property defines __set_name__ for descriptor name registration"
    - "functools.partial and functools.cached_property both define __class_getitem__ for generic alias support"
    - "functools.partialmethod defines __class_getitem__ for generic alias support"
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: functools classes do NOT define __init_subclass__ in their own
# __dict__. They inherit the default no-op from object. Only object itself
# carries __init_subclass__ as the universal fallback hook.
# ---------------------------------------------------------------------------

table functools_extra1651.no_init_subclass:
  description: "functools classes do not define __init_subclass__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1651ni

  columns: [id, function, args, expected]
  rows:
    - ["fu1651ni001", "functools.partial.__dict__.__contains__",          ["__init_subclass__"], false]
    - ["fu1651ni002", "functools.partialmethod.__dict__.__contains__",    ["__init_subclass__"], false]
    - ["fu1651ni003", "functools.cached_property.__dict__.__contains__",  ["__init_subclass__"], false]
    - ["fu1651ni004", "object.__dict__.__contains__",                     ["__init_subclass__"], true]
    - ["fu1651ni005", "functools.partial.__dict__.__contains__",          ["__subclasshook__"],  false]
    - ["fu1651ni006", "functools.partialmethod.__dict__.__contains__",    ["__subclasshook__"],  false]
    - ["fu1651ni007", "functools.cached_property.__dict__.__contains__",  ["__subclasshook__"],  false]
    - ["fu1651ni008", "functools.partial.__dict__.__contains__",          ["__instancecheck__"], false]
    - ["fu1651ni009", "functools.partialmethod.__dict__.__contains__",    ["__instancecheck__"], false]
    - ["fu1651ni010", "functools.cached_property.__dict__.__contains__",  ["__instancecheck__"], false]
    - ["fu1651ni011", "functools.partial.__dict__.__contains__",          ["__subclasscheck__"], false]
    - ["fu1651ni012", "functools.partialmethod.__dict__.__contains__",    ["__subclasscheck__"], false]
    - ["fu1651ni013", "functools.cached_property.__dict__.__contains__",  ["__subclasscheck__"], false]
    - ["fu1651ni014", "object.__dict__.__contains__",                     ["__subclasshook__"],  false]
    - ["fu1651ni015", "object.__dict__.__contains__",                     ["__new__"],           true]
    - ["fu1651ni016", "object.__dict__.__contains__",                     ["__init__"],          true]
    - ["fu1651ni017", "functools.partial.__dict__.__contains__",          ["__new__"],           true]
    - ["fu1651ni018", "functools.partialmethod.__dict__.__contains__",    ["__new__"],           true]
    - ["fu1651ni019", "functools.cached_property.__dict__.__contains__",  ["__init__"],          true]
    - ["fu1651ni020", "functools.partial.__dict__.__contains__",          ["__init__"],          false]
    - ["fu1651ni021", "functools.partialmethod.__dict__.__contains__",    ["__init__"],          false]
    - ["fu1651ni022", "functools.partial.__dict__.__contains__",          ["__reduce__"],        true]
    - ["fu1651ni023", "functools.partialmethod.__dict__.__contains__",    ["__reduce__"],        false]
    - ["fu1651ni024", "functools.cached_property.__dict__.__contains__",  ["__reduce__"],        false]
    - ["fu1651ni025", "object.__dict__.__contains__",                     ["__init_subclass__"], true]

# ---------------------------------------------------------------------------
# Table 2: __set_name__ presence checks.
# functools.cached_property defines __set_name__ so the descriptor can record
# the attribute name at class creation time (used to avoid repeated __dict__
# lookups). partial and partialmethod are not descriptors in the same sense
# and do not define __set_name__.
# ---------------------------------------------------------------------------

table functools_extra1651.set_name_checks:
  description: "__set_name__ presence: cached_property has it; partial and partialmethod do not"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1651sn

  columns: [id, function, args, expected]
  rows:
    - ["fu1651sn001", "functools.cached_property.__dict__.__contains__", ["__set_name__"],    true]
    - ["fu1651sn002", "functools.partial.__dict__.__contains__",         ["__set_name__"],    false]
    - ["fu1651sn003", "functools.partialmethod.__dict__.__contains__",   ["__set_name__"],    false]
    - ["fu1651sn004", "object.__dict__.__contains__",                    ["__set_name__"],    false]
    - ["fu1651sn005", "functools.cached_property.__dict__.__contains__", ["__get__"],         true]
    - ["fu1651sn006", "functools.cached_property.__dict__.__contains__", ["__set__"],         false]
    - ["fu1651sn007", "functools.cached_property.__dict__.__contains__", ["__delete__"],      false]
    - ["fu1651sn008", "functools.partialmethod.__dict__.__contains__",   ["__get__"],         true]
    - ["fu1651sn009", "functools.partial.__dict__.__contains__",         ["__get__"],         false]
    - ["fu1651sn010", "functools.cached_property.__dict__.__contains__", ["attrname"],        false]
    - ["fu1651sn011", "functools.cached_property.__dict__.__contains__", ["func"],            false]
    - ["fu1651sn012", "functools.partialmethod.__dict__.__contains__",   ["__set_name__"],    false]
    - ["fu1651sn013", "functools.cached_property.__dict__.__contains__", ["__set_name__"],    true]
    - ["fu1651sn014", "functools.partial.__dict__.__contains__",         ["__repr__"],        true]
    - ["fu1651sn015", "functools.partialmethod.__dict__.__contains__",   ["__repr__"],        true]
    - ["fu1651sn016", "functools.cached_property.__dict__.__contains__", ["__repr__"],        false]
    - ["fu1651sn017", "functools.partial.__dict__.__contains__",         ["__eq__"],          false]
    - ["fu1651sn018", "functools.partialmethod.__dict__.__contains__",   ["__eq__"],          false]
    - ["fu1651sn019", "functools.cached_property.__dict__.__contains__", ["__eq__"],          false]
    - ["fu1651sn020", "functools.partial.__dict__.__contains__",         ["__hash__"],        false]
    - ["fu1651sn021", "functools.partialmethod.__dict__.__contains__",   ["__hash__"],        false]
    - ["fu1651sn022", "functools.cached_property.__dict__.__contains__", ["__hash__"],        false]
    - ["fu1651sn023", "functools.partial.__dict__.__contains__",         ["func"],            true]
    - ["fu1651sn024", "functools.partial.__dict__.__contains__",         ["args"],            true]
    - ["fu1651sn025", "functools.partial.__dict__.__contains__",         ["keywords"],        true]

# ---------------------------------------------------------------------------
# Table 3: __class_getitem__ presence for generic alias support (PEP 585).
# functools.partial, functools.partialmethod, and functools.cached_property
# all define __class_getitem__ so they can be used in type hints as
# partial[int], partialmethod[str], cached_property[bool], etc.
# ---------------------------------------------------------------------------

table functools_extra1651.class_getitem_checks:
  description: "__class_getitem__ presence: all three functools classes support generic alias syntax"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1651cg

  columns: [id, function, args, expected]
  rows:
    - ["fu1651cg001", "functools.partial.__dict__.__contains__",         ["__class_getitem__"], true]
    - ["fu1651cg002", "functools.partialmethod.__dict__.__contains__",   ["__class_getitem__"], true]
    - ["fu1651cg003", "functools.cached_property.__dict__.__contains__", ["__class_getitem__"], true]
    - ["fu1651cg004", "object.__dict__.__contains__",                    ["__class_getitem__"], false]
    - ["fu1651cg005", "functools.partial.__dict__.__contains__",         ["__or__"],            false]
    - ["fu1651cg006", "functools.partialmethod.__dict__.__contains__",   ["__or__"],            false]
    - ["fu1651cg007", "functools.cached_property.__dict__.__contains__", ["__or__"],            false]
    - ["fu1651cg008", "functools.partial.__dict__.__contains__",         ["__ror__"],           false]
    - ["fu1651cg009", "functools.partialmethod.__dict__.__contains__",   ["__ror__"],           false]
    - ["fu1651cg010", "functools.cached_property.__dict__.__contains__", ["__ror__"],           false]
    - ["fu1651cg011", "functools.partial.__dict__.__contains__",         ["__doc__"],           true]
    - ["fu1651cg012", "functools.partialmethod.__dict__.__contains__",   ["__doc__"],           true]
    - ["fu1651cg013", "functools.cached_property.__dict__.__contains__", ["__doc__"],           true]
    - ["fu1651cg014", "functools.partial.__dict__.__contains__",         ["__class_getitem__"], true]
    - ["fu1651cg015", "functools.partialmethod.__dict__.__contains__",   ["__class_getitem__"], true]
    - ["fu1651cg016", "functools.cached_property.__dict__.__contains__", ["__class_getitem__"], true]
    - ["fu1651cg017", "functools.partial.__dict__.__contains__",         ["__module__"],        true]
    - ["fu1651cg018", "functools.partialmethod.__dict__.__contains__",   ["__module__"],        true]
    - ["fu1651cg019", "functools.cached_property.__dict__.__contains__", ["__module__"],        true]
    - ["fu1651cg020", "functools.partial.__dict__.__contains__",         ["__weakref__"],       false]
    - ["fu1651cg021", "functools.partialmethod.__dict__.__contains__",   ["__weakref__"],       true]
    - ["fu1651cg022", "functools.cached_property.__dict__.__contains__", ["__weakref__"],       true]
    - ["fu1651cg023", "functools.partial.__dict__.__contains__",         ["__dict__"],          true]
    - ["fu1651cg024", "functools.partialmethod.__dict__.__contains__",   ["__dict__"],          true]
    - ["fu1651cg025", "functools.cached_property.__dict__.__contains__", ["__dict__"],          true]
