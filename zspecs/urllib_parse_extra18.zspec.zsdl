spec: urllib_parse_extra18
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html
rfcs:
  - "RFC 3986 — Uniform Resource Identifier (URI): Generic Syntax"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
    - "urllib_parse_extra4.zspec.zsdl — covers __qualname__.__eq__ for urlparse/urlsplit/urljoin/urlencode/quote/unquote and ParseResult/SplitResult/DefragResult."
    - "urllib_parse_extra5.zspec.zsdl — covers __qualname__.__eq__ for quote_plus/unquote_plus/parse_qs/parse_qsl."
    - "urllib_parse_extra14.zspec.zsdl — covers __qualname__.__len__() for urlparse/urlencode/quote/unquote/urljoin/urlsplit and result classes ParseResult/SplitResult."
    - "urllib_parse_extra15.zspec.zsdl — covers __qualname__.__eq__ and __len__() for urlunparse; __len__() for quote_plus/unquote_plus."
    - "urllib_parse_extra16.zspec.zsdl — covers ParseResult.geturl.__qualname__; urldefrag __qualname__/__len__(); DefragResult __qualname__/__len__(); cross-namespace anchors."
    - "urllib_parse_extra17.zspec.zsdl — covers __module__ for ParseResult/SplitResult/DefragResult; ParseResult._fields type and len; cross-namespace qualname lengths and anchors for quote/unquote/urljoin/urlparse."
  notes:
    - "This spec extends the urllib_parse chain through urllib_parse_extra17; it does NOT duplicate invariants in any prior spec."
    - "Focus: (1) __module__ for module-level functions urlparse/urlsplit/urlunsplit/urlunparse/urlencode/urljoin/quote/unquote/quote_plus/unquote_plus — all == 'urllib.parse' (len 12); no prior spec checks __module__ for these functions; (2) ParseResult.__bases__[0].__name__ == '_ParseResultBase' and SplitResult.__bases__[0].__name__ == '_SplitResultBase' — the internal NamedTuple base classes; (3) SplitResult._fields tuple length == 5 (five fields vs ParseResult's six)."
    - "All ten module-level functions have __module__ == 'urllib.parse' (len 12). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.ParseResult.__bases__[0].__name__ == '_ParseResultBase' — len 16. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.SplitResult.__bases__[0].__name__ == '_SplitResultBase' — len 16. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.SplitResult._fields has 5 fields: scheme/netloc/path/query/fragment (no params). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for urlparse, urlsplit, urlunsplit, urlunparse
#
# urllib_parse_extra4/14/15/16/17 cover __qualname__ for these functions.
# No prior spec checks __module__ for any of them. All four are defined in
# 'urllib.parse' (len 12).
# ---------------------------------------------------------------------------

table urllib_parse_extra18.url_function_modules_a:
  description: "__module__.__eq__ for urlparse, urlsplit, urlunsplit, urlunparse — all defined in 'urllib.parse'"
  kind: python_call_eq
  category: function_module
  id_prefix: ufma18

  columns: [id, function, args, expected]
  rows:
    - [urlparse,   urlparse.__module__.__eq__,   ["urllib.parse"], true]
    - [urlsplit,   urlsplit.__module__.__eq__,   ["urllib.parse"], true]
    - [urlunsplit, urlunsplit.__module__.__eq__, ["urllib.parse"], true]
    - [urlunparse, urlunparse.__module__.__eq__, ["urllib.parse"], true]

# ---------------------------------------------------------------------------
# __module__ for urlencode, urljoin, quote, unquote, quote_plus, unquote_plus
#
# No prior spec checks __module__ for these six functions. All are defined in
# 'urllib.parse' (len 12).
# ---------------------------------------------------------------------------

table urllib_parse_extra18.url_function_modules_b:
  description: "__module__.__eq__ for urlencode, urljoin, quote, unquote, quote_plus, unquote_plus — all 'urllib.parse'"
  kind: python_call_eq
  category: function_module
  id_prefix: ufmb18

  columns: [id, function, args, expected]
  rows:
    - [urlencode,    urlencode.__module__.__eq__,    ["urllib.parse"], true]
    - [urljoin,      urljoin.__module__.__eq__,      ["urllib.parse"], true]
    - [quote,        quote.__module__.__eq__,        ["urllib.parse"], true]
    - [unquote,      unquote.__module__.__eq__,      ["urllib.parse"], true]
    - [quote_plus,   quote_plus.__module__.__eq__,   ["urllib.parse"], true]
    - [unquote_plus, unquote_plus.__module__.__eq__, ["urllib.parse"], true]

invariant urllib_parse_extra18.urlparse.module_len:
  description: "len(urllib.parse.urlparse.__module__) == 12 — len('urllib.parse') == 12; representative length check for all function modules"
  category: function_module
  kind: python_call_eq
  function: urlparse.__module__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# ParseResult.__bases__[0].__name__ and SplitResult.__bases__[0].__name__
#
# ParseResult and SplitResult are NamedTuple subclasses. Their immediate base
# class is an internal private class: _ParseResultBase and _SplitResultBase
# respectively (both len 16). No prior spec checks __bases__[0].__name__
# for ParseResult or SplitResult (extra17 only checks _fields and __module__).
# ---------------------------------------------------------------------------

invariant urllib_parse_extra18.ParseResult.bases0_name_eq:
  description: "urllib.parse.ParseResult.__bases__[0].__name__ == '_ParseResultBase' — internal NamedTuple base class"
  category: class_hierarchy
  kind: python_call_eq
  "function": "ParseResult.__bases__[0].__name__.__eq__"
  args: ["_ParseResultBase"]
  expected: true

invariant urllib_parse_extra18.ParseResult.bases0_name_len:
  description: "len(urllib.parse.ParseResult.__bases__[0].__name__) == 16 — len('_ParseResultBase') == 16"
  category: class_hierarchy
  kind: python_call_eq
  "function": "ParseResult.__bases__[0].__name__.__len__"
  args: []
  expected: 16

invariant urllib_parse_extra18.SplitResult.bases0_name_eq:
  description: "urllib.parse.SplitResult.__bases__[0].__name__ == '_SplitResultBase' — internal NamedTuple base class"
  category: class_hierarchy
  kind: python_call_eq
  "function": "SplitResult.__bases__[0].__name__.__eq__"
  args: ["_SplitResultBase"]
  expected: true

invariant urllib_parse_extra18.SplitResult.bases0_name_len:
  description: "len(urllib.parse.SplitResult.__bases__[0].__name__) == 16 — len('_SplitResultBase') == 16"
  category: class_hierarchy
  kind: python_call_eq
  "function": "SplitResult.__bases__[0].__name__.__len__"
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# SplitResult._fields length
#
# urllib_parse_extra17 checks ParseResult._fields length == 6 (scheme, netloc,
# path, params, query, fragment). SplitResult._fields has only 5 fields:
# scheme, netloc, path, query, fragment — no 'params' field.
# No prior spec checks SplitResult._fields length.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra18.SplitResult.fields_len:
  description: "len(urllib.parse.SplitResult._fields) == 5 — SplitResult has five fields: scheme, netloc, path, query, fragment (no params)"
  category: named_tuple_structure
  kind: python_call_eq
  "function": "SplitResult._fields.__len__"
  args: []
  expected: 5

invariant urllib_parse_extra18.SplitResult.fields_class_name:
  description: "urllib.parse.SplitResult._fields.__class__.__name__ == 'tuple' — _fields is a plain tuple of field name strings"
  category: named_tuple_structure
  kind: python_call_eq
  "function": "SplitResult._fields.__class__.__name__.__eq__"
  args: ["tuple"]
  expected: true
