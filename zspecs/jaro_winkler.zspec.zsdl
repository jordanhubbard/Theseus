spec: jaro_winkler
version: ">=0.2.8"
backend: node(jaro-winkler)

docs: https://www.npmjs.com/package/jaro-winkler

provenance:
  derived_from:
    - "jaro-winkler README — https://www.npmjs.com/package/jaro-winkler"
    - "Test vectors verified with jaro-winkler via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "jaro-winkler source"
  notes:
    - "jaro-winkler is an npm package. Install: npm install jaro-winkler"
    - "Returns the Jaro-Winkler similarity between two strings (0 to 1)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number between 0 and 1."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table jaro_winkler.jaroWinkler:
  kind: node_module_call_eq
  function: ~
  category: similarity
  id_prefix: jaro

  columns: [id, args, expected]
  rows:
    - [identical,  ["hello",  "hello"],   1]
    - [no_match,   ["abc",    "xyz"],     0]
