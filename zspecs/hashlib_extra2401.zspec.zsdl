spec: hashlib_extra2401
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "hashlib_extra2401: __hash__ and __eq__ implementation type classification for hashlib.blake2b and hashlib.blake2s."
    - "hashlib.blake2b is a C extension type (_blake2.blake2b). Its class-level __hash__ and __eq__ are inherited from object as slot wrappers, so .__class__.__name__ == 'wrapper_descriptor'."
    - "hashlib.blake2s is similarly a C extension type inheriting __hash__ and __eq__ from object — both are 'wrapper_descriptor'."
    - "Neither hashlib.blake2b nor hashlib.blake2s defines its own __hash__ or __eq__ in its __dict__ — both are False for __dict__.__contains__."
    - "Instances of blake2b and blake2s ARE hashable (they do not set __hash__ = None), they simply inherit object's default identity-based hash."
    - "All expected values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2401.blake2b_hash_eq:
  description: "hashlib.blake2b class-level __hash__ and __eq__ are both 'wrapper_descriptor' — inherited from object, not overridden"
  kind: python_call_eq
  category: hash_eq_classification
  id_prefix: hl2401bh

  columns: [id, function, args, expected]
  rows:
    - ["hl2401001", "hashlib.blake2b.__hash__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["hl2401002", "hashlib.blake2b.__eq__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true]
    - ["hl2401003", "hashlib.blake2b.__hash__.__class__.__name__.__eq__", ["function"],           false]
    - ["hl2401004", "hashlib.blake2b.__eq__.__class__.__name__.__eq__",   ["function"],           false]
    - ["hl2401005", "hashlib.blake2b.__hash__.__class__.__name__.__eq__", ["method-wrapper"],     false]
    - ["hl2401006", "hashlib.blake2b.__eq__.__class__.__name__.__eq__",   ["method-wrapper"],     false]

table hashlib_extra2401.blake2s_hash_eq:
  description: "hashlib.blake2s class-level __hash__ and __eq__ are both 'wrapper_descriptor' — inherited from object, not overridden"
  kind: python_call_eq
  category: hash_eq_classification
  id_prefix: hl2401bs

  columns: [id, function, args, expected]
  rows:
    - ["hl2401007", "hashlib.blake2s.__hash__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["hl2401008", "hashlib.blake2s.__eq__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true]
    - ["hl2401009", "hashlib.blake2s.__hash__.__class__.__name__.__eq__", ["function"],           false]
    - ["hl2401010", "hashlib.blake2s.__eq__.__class__.__name__.__eq__",   ["function"],           false]
    - ["hl2401011", "hashlib.blake2s.__hash__.__class__.__name__.__eq__", ["method-wrapper"],     false]
    - ["hl2401012", "hashlib.blake2s.__eq__.__class__.__name__.__eq__",   ["method-wrapper"],     false]

table hashlib_extra2401.blake2b_dict_contains:
  description: "hashlib.blake2b.__dict__.__contains__ returns false for __hash__ and __eq__ — neither is defined in the class's own __dict__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2401bd

  columns: [id, function, args, expected]
  rows:
    - ["hl2401013", "hashlib.blake2b.__dict__.__contains__", ["__hash__"], false]
    - ["hl2401014", "hashlib.blake2b.__dict__.__contains__", ["__eq__"],   false]
    - ["hl2401015", "hashlib.blake2b.__dict__.__contains__", ["digest"],   true]
    - ["hl2401016", "hashlib.blake2b.__dict__.__contains__", ["update"],   true]

table hashlib_extra2401.blake2s_dict_contains:
  description: "hashlib.blake2s.__dict__.__contains__ returns false for __hash__ and __eq__ — neither is defined in the class's own __dict__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2401sd

  columns: [id, function, args, expected]
  rows:
    - ["hl2401017", "hashlib.blake2s.__dict__.__contains__", ["__hash__"], false]
    - ["hl2401018", "hashlib.blake2s.__dict__.__contains__", ["__eq__"],   false]
    - ["hl2401019", "hashlib.blake2s.__dict__.__contains__", ["digest"],   true]
    - ["hl2401020", "hashlib.blake2s.__dict__.__contains__", ["update"],   true]
