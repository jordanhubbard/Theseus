spec: inspect_extra2131
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 2131 (_extra2131): exception protocol dict-presence checks — __cause__, __context__, __traceback__, __suppress_context__, __notes__, args, with_traceback in class __dict__ for inspect types."
    - "Theme: exception protocol dict-presence — checking whether exception-related attributes are defined at the class level in __dict__ for inspect types, including both exception and non-exception types."
    - "inspect has two exception types: inspect.ClassFoundException (subclass of Exception) and inspect.EndOfBlock (subclass of Exception). Both are internal sentinel exceptions used by the module's own code walking."
    - "For exception types (ClassFoundException, EndOfBlock): __cause__, __context__, __traceback__, __suppress_context__, __notes__, args, and with_traceback are all absent from the class __dict__. These are instance-level attributes set when exceptions are raised, not class-level entries."
    - "inspect.BoundArguments, inspect.ArgInfo, inspect.Arguments, inspect.FullArgSpec are namedtuple-based types that carry 'args' as a namedtuple field — 'args' IS present in their __dict__ as a namedtuple property/descriptor."
    - "inspect.Parameter and inspect.Signature are pure Python classes without exception protocol attributes in __dict__."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: exception protocol dict-presence for inspect exception types
#
# inspect.ClassFoundException and inspect.EndOfBlock are internal exception
# types. Even though they ARE exception types, the exception protocol
# attributes (__cause__, __context__, etc.) are NOT class-level __dict__
# entries — they are set on instances at raise time by the interpreter.
# ---------------------------------------------------------------------------

table inspect_extra2131.exception_protocol:
  description: "inspect exception types (ClassFoundException, EndOfBlock) exception-protocol dict-presence checks — all False (instance-level, not class-level)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2131

  columns: [id, function, args, expected]
  rows:
    - ["in2131001", "inspect.ClassFoundException.__dict__.__contains__", ["__cause__"],            false]
    - ["in2131002", "inspect.ClassFoundException.__dict__.__contains__", ["__context__"],          false]
    - ["in2131003", "inspect.ClassFoundException.__dict__.__contains__", ["__traceback__"],        false]
    - ["in2131004", "inspect.ClassFoundException.__dict__.__contains__", ["__suppress_context__"], false]
    - ["in2131005", "inspect.ClassFoundException.__dict__.__contains__", ["__notes__"],            false]
    - ["in2131006", "inspect.ClassFoundException.__dict__.__contains__", ["args"],                 false]
    - ["in2131007", "inspect.ClassFoundException.__dict__.__contains__", ["with_traceback"],       false]
    - ["in2131008", "inspect.EndOfBlock.__dict__.__contains__",          ["__cause__"],            false]
    - ["in2131009", "inspect.EndOfBlock.__dict__.__contains__",          ["__context__"],          false]
    - ["in2131010", "inspect.EndOfBlock.__dict__.__contains__",          ["__traceback__"],        false]
    - ["in2131011", "inspect.EndOfBlock.__dict__.__contains__",          ["__suppress_context__"], false]
    - ["in2131012", "inspect.EndOfBlock.__dict__.__contains__",          ["__notes__"],            false]
    - ["in2131013", "inspect.EndOfBlock.__dict__.__contains__",          ["args"],                 false]
    - ["in2131014", "inspect.EndOfBlock.__dict__.__contains__",          ["with_traceback"],       false]

# ---------------------------------------------------------------------------
# Table 2: exception protocol dict-presence for inspect non-exception types
#
# Parameter, Signature — standard inspect types for introspecting call
# signatures. Neither is an exception type. None of the exception protocol
# attrs are present in their class __dict__.
# ---------------------------------------------------------------------------

table inspect_extra2131.non_exception_types:
  description: "inspect non-exception types (Parameter, Signature) exception-protocol dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2131

  columns: [id, function, args, expected]
  rows:
    - ["in2131015", "inspect.Parameter.__dict__.__contains__",  ["__cause__"],            false]
    - ["in2131016", "inspect.Parameter.__dict__.__contains__",  ["__context__"],          false]
    - ["in2131017", "inspect.Parameter.__dict__.__contains__",  ["__traceback__"],        false]
    - ["in2131018", "inspect.Parameter.__dict__.__contains__",  ["__suppress_context__"], false]
    - ["in2131019", "inspect.Parameter.__dict__.__contains__",  ["__notes__"],            false]
    - ["in2131020", "inspect.Parameter.__dict__.__contains__",  ["args"],                 false]
    - ["in2131021", "inspect.Parameter.__dict__.__contains__",  ["with_traceback"],       false]
    - ["in2131022", "inspect.Signature.__dict__.__contains__",  ["__cause__"],            false]
    - ["in2131023", "inspect.Signature.__dict__.__contains__",  ["__context__"],          false]
    - ["in2131024", "inspect.Signature.__dict__.__contains__",  ["__traceback__"],        false]
    - ["in2131025", "inspect.Signature.__dict__.__contains__",  ["__suppress_context__"], false]
    - ["in2131026", "inspect.Signature.__dict__.__contains__",  ["__notes__"],            false]
    - ["in2131027", "inspect.Signature.__dict__.__contains__",  ["args"],                 false]
    - ["in2131028", "inspect.Signature.__dict__.__contains__",  ["with_traceback"],       false]

# ---------------------------------------------------------------------------
# Table 3: exception protocol dict-presence for namedtuple-based inspect types
#
# BoundArguments, ArgInfo, Arguments, FullArgSpec carry 'args' as a
# namedtuple field descriptor in __dict__. All exception-specific attrs
# (__cause__, __context__, etc.) are absent — they are not exception types.
# ---------------------------------------------------------------------------

table inspect_extra2131.namedtuple_args_presence:
  description: "inspect namedtuple-based types — 'args' field IS in __dict__ as namedtuple descriptor; exception protocol attrs absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2131

  columns: [id, function, args, expected]
  rows:
    - ["in2131029", "inspect.BoundArguments.__dict__.__contains__", ["__cause__"],            false]
    - ["in2131030", "inspect.BoundArguments.__dict__.__contains__", ["__context__"],          false]
    - ["in2131031", "inspect.BoundArguments.__dict__.__contains__", ["__traceback__"],        false]
    - ["in2131032", "inspect.BoundArguments.__dict__.__contains__", ["__suppress_context__"], false]
    - ["in2131033", "inspect.BoundArguments.__dict__.__contains__", ["__notes__"],            false]
    - ["in2131034", "inspect.BoundArguments.__dict__.__contains__", ["args"],                 true]
    - ["in2131035", "inspect.BoundArguments.__dict__.__contains__", ["with_traceback"],       false]
    - ["in2131036", "inspect.ArgInfo.__dict__.__contains__",        ["__cause__"],            false]
    - ["in2131037", "inspect.ArgInfo.__dict__.__contains__",        ["__context__"],          false]
    - ["in2131038", "inspect.ArgInfo.__dict__.__contains__",        ["args"],                 true]
    - ["in2131039", "inspect.ArgInfo.__dict__.__contains__",        ["with_traceback"],       false]
    - ["in2131040", "inspect.Arguments.__dict__.__contains__",      ["__cause__"],            false]
    - ["in2131041", "inspect.Arguments.__dict__.__contains__",      ["__context__"],          false]
    - ["in2131042", "inspect.Arguments.__dict__.__contains__",      ["args"],                 true]
    - ["in2131043", "inspect.Arguments.__dict__.__contains__",      ["with_traceback"],       false]
    - ["in2131044", "inspect.FullArgSpec.__dict__.__contains__",    ["__cause__"],            false]
    - ["in2131045", "inspect.FullArgSpec.__dict__.__contains__",    ["__context__"],          false]
    - ["in2131046", "inspect.FullArgSpec.__dict__.__contains__",    ["args"],                 true]
    - ["in2131047", "inspect.FullArgSpec.__dict__.__contains__",    ["with_traceback"],       false]
