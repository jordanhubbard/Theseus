spec: struct_extra261
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra260.zspec.zsdl — covers struct pack_into/unpack_from/iter_unpack function identity; unpack_from offset behavior; iter_unpack result class; calcsize for '!I'."
    - "struct_extra259.zspec.zsdl — covers struct module identity (__name__, __package__, __spec__, __loader__), __all__ type/len/members, pack error conditions."
    - "struct_extra.zspec.zsdl — covers Struct format/size attrs; calcsize extra formats; pack_into/unpack_from/iter_unpack function names; error class name and base."
    - "_struct.zspec.zsdl — covers Struct class name/module/size; pack/unpack/calcsize function names; Struct instance pack length."
  notes:
    - "Standard size format characters (with '!' big-endian prefix) have deterministic sizes on all platforms per C99/IEEE 754: b/B=1, h/H=2, i/I/l/L=4, q/Q=8, f=4, d=8. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "Native format characters (no prefix) may vary by platform: on macOS 64-bit, l/L are 8 bytes; on 32-bit platforms they are 4 bytes. This spec focuses on standard sizes which are portable."
    - "struct.calcsize('!b') == 1 — signed char, standard size 1 byte. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!h') == 2 — signed short, standard size 2 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!i') == 4 — signed int, standard size 4 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!l') == 4 — signed long, standard size 4 bytes (differs from native macOS 64-bit which gives 8). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!q') == 8 — signed long long, standard size 8 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!f') == 4 — IEEE 754 single-precision float, always 4 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!d') == 8 — IEEE 754 double-precision float, always 8 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Standard format sizes with '!' (big-endian) prefix — portable across platforms
# These are specified by the struct module documentation and C standards.
# b/B: 1 byte; h/H: 2 bytes; i/I/l/L: 4 bytes; q/Q: 8 bytes; f: 4 bytes; d: 8 bytes
# ---------------------------------------------------------------------------

table struct_extra261.standard_format_sizes:
  description: "struct.calcsize with '!' big-endian prefix — standard sizes are deterministic on all platforms: b/B=1, h/H=2, i/I/l/L=4, q/Q=8, f=4, d=8; verified with Python 3.14.3"
  kind: python_call_eq
  category: calcsize
  id_prefix: structstd261

  columns: [id, function, args, expected, description]
  rows:
    - [bang_b,   calcsize, ["!b"], 1, "struct.calcsize('!b') == 1 — big-endian signed char is 1 byte"]
    - [bang_B,   calcsize, ["!B"], 1, "struct.calcsize('!B') == 1 — big-endian unsigned char is 1 byte"]
    - [bang_h,   calcsize, ["!h"], 2, "struct.calcsize('!h') == 2 — big-endian signed short is 2 bytes"]
    - [bang_H,   calcsize, ["!H"], 2, "struct.calcsize('!H') == 2 — big-endian unsigned short is 2 bytes"]
    - [bang_i,   calcsize, ["!i"], 4, "struct.calcsize('!i') == 4 — big-endian signed int is 4 bytes"]

# ---------------------------------------------------------------------------
# Remaining standard format sizes: !I, !l, !L, !q, !Q, !f, !d
# ---------------------------------------------------------------------------

table struct_extra261.standard_format_sizes2:
  description: "struct.calcsize with '!' prefix for I/l/L/q/Q/f/d — I/l/L=4, q/Q=8, f=4, d=8; verified with Python 3.14.3"
  kind: python_call_eq
  category: calcsize
  id_prefix: structstd261b

  columns: [id, function, args, expected, description]
  rows:
    - [bang_I,   calcsize, ["!I"], 4, "struct.calcsize('!I') == 4 — big-endian unsigned int is 4 bytes"]
    - [bang_l,   calcsize, ["!l"], 4, "struct.calcsize('!l') == 4 — big-endian signed long is 4 bytes (standard size; native macOS 64-bit gives 8)"]
    - [bang_L,   calcsize, ["!L"], 4, "struct.calcsize('!L') == 4 — big-endian unsigned long is 4 bytes (standard size)"]
    - [bang_q,   calcsize, ["!q"], 8, "struct.calcsize('!q') == 8 — big-endian signed long long is 8 bytes"]
    - [bang_Q,   calcsize, ["!Q"], 8, "struct.calcsize('!Q') == 8 — big-endian unsigned long long is 8 bytes"]

# ---------------------------------------------------------------------------
# IEEE 754 float and double standard sizes
# '!f' == 4 (single precision), '!d' == 8 (double precision)
# ---------------------------------------------------------------------------

invariant struct_extra261.bang_f_size:
  description: "struct.calcsize('!f') == 4 — big-endian IEEE 754 single-precision float is always 4 bytes"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!f"]
  expected: 4

invariant struct_extra261.bang_d_size:
  description: "struct.calcsize('!d') == 8 — big-endian IEEE 754 double-precision float is always 8 bytes"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!d"]
  expected: 8

# ---------------------------------------------------------------------------
# Native format sizes — platform-specific but verified on macOS 64-bit
# b/B/h/H/i/I are the same as standard; l/L are 8 on macOS 64-bit
# q/Q/f/d are the same as standard
# ---------------------------------------------------------------------------

invariant struct_extra261.native_b_size:
  description: "struct.calcsize('b') == 1 — native signed char is 1 byte on all platforms"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["b"]
  expected: 1

invariant struct_extra261.native_h_size:
  description: "struct.calcsize('h') == 2 — native signed short is 2 bytes on all platforms"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["h"]
  expected: 2

invariant struct_extra261.native_i_size:
  description: "struct.calcsize('i') == 4 — native signed int is 4 bytes on all platforms"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["i"]
  expected: 4

invariant struct_extra261.native_q_size:
  description: "struct.calcsize('q') == 8 — native signed long long is 8 bytes on all platforms"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["q"]
  expected: 8

invariant struct_extra261.native_f_size:
  description: "struct.calcsize('f') == 4 — native IEEE 754 single-precision float is 4 bytes on all platforms"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["f"]
  expected: 4

invariant struct_extra261.native_d_size:
  description: "struct.calcsize('d') == 8 — native IEEE 754 double-precision float is 8 bytes on all platforms"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["d"]
  expected: 8

invariant struct_extra261.native_bool_size:
  description: "struct.calcsize('?') == 1 — native bool is 1 byte on all platforms"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["?"]
  expected: 1
