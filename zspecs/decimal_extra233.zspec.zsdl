spec: decimal_extra233
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal abs/__abs__, __floor__, __ceil__, and to_integral_value contracts."
    - "abs(decimal.Decimal('-1.5')) returns Decimal('1.5') — result class is Decimal; verified Python 3.14.3 macOS."
    - "abs(decimal.Decimal('1.5')) returns Decimal('1.5') — positive value unchanged; verified Python 3.14.3 macOS."
    - "Decimal.__floor__ delegates to math.floor; returns a plain int; verified Python 3.14.3 macOS."
    - "Decimal.__ceil__ delegates to math.ceil; returns a plain int; verified Python 3.14.3 macOS."
    - "math.floor(Decimal('1.7')) == 1 — floor rounds toward negative infinity; verified Python 3.14.3 macOS."
    - "math.floor(Decimal('-1.7')) == -2 — floor rounds toward negative infinity; verified Python 3.14.3 macOS."
    - "math.ceil(Decimal('1.2')) == 2 — ceil rounds toward positive infinity; verified Python 3.14.3 macOS."
    - "math.ceil(Decimal('-1.2')) == -1 — ceil rounds toward positive infinity; verified Python 3.14.3 macOS."
    - "to_integral_value uses ROUND_HALF_EVEN (banker's rounding): 1.5->2, 2.5->2, -2.5->-2; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.__abs__() contracts
# abs() calls __abs__() which returns a new Decimal with the sign cleared.
# Result class is always Decimal (not int or float).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra233.Decimal.abs.negative_str:
  description: "decimal.Decimal('-1.5').__abs__().__str__() == '1.5' — absolute value of negative clears sign; verified Python 3.14.3 macOS"
  category: abs
  kind: python_call_eq
  function: Decimal
  args: ["-1.5"]
  method: __abs__
  method_chain: __str__
  expected: "1.5"

invariant decimal_extra233.Decimal.abs.positive_str:
  description: "decimal.Decimal('1.5').__abs__().__str__() == '1.5' — absolute value of positive is unchanged; verified Python 3.14.3 macOS"
  category: abs
  kind: python_call_eq
  function: Decimal
  args: ["1.5"]
  method: __abs__
  method_chain: __str__
  expected: "1.5"

invariant decimal_extra233.Decimal.abs.zero_str:
  description: "decimal.Decimal('0').__abs__().__str__() == '0' — absolute value of zero is zero; verified Python 3.14.3 macOS"
  category: abs
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: __abs__
  method_chain: __str__
  expected: "0"

invariant decimal_extra233.Decimal.abs.negative_pi_str:
  description: "decimal.Decimal('-3.14').__abs__().__str__() == '3.14' — absolute value of -3.14 is 3.14; verified Python 3.14.3 macOS"
  category: abs
  kind: python_call_eq
  function: Decimal
  args: ["-3.14"]
  method: __abs__
  method_chain: __str__
  expected: "3.14"

invariant decimal_extra233.Decimal.abs.result_class:
  description: "decimal.Decimal('-1.5').__abs__().__class__.__name__ == 'Decimal' — result of __abs__ is a Decimal not an int; verified Python 3.14.3 macOS"
  category: abs
  kind: python_call_eq
  function: Decimal
  args: ["-1.5"]
  method: __abs__
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["Decimal"]
  expected: true

# ---------------------------------------------------------------------------
# decimal.Decimal.__floor__() contracts
# Decimal.__floor__() returns a plain int (the largest integer <= self).
# Rounds toward negative infinity. Used by math.floor().
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra233.Decimal.floor.positive_round_down:
  description: "decimal.Decimal('1.7').__floor__() == 1 — floor of 1.7 rounds down to 1; verified Python 3.14.3 macOS"
  category: floor
  kind: python_call_eq
  function: Decimal
  args: ["1.7"]
  method: __floor__
  expected: 1

invariant decimal_extra233.Decimal.floor.negative_round_away:
  description: "decimal.Decimal('-1.7').__floor__() == -2 — floor of -1.7 rounds toward -inf giving -2; verified Python 3.14.3 macOS"
  category: floor
  kind: python_call_eq
  function: Decimal
  args: ["-1.7"]
  method: __floor__
  expected: -2

invariant decimal_extra233.Decimal.floor.exact_integer:
  description: "decimal.Decimal('3.0').__floor__() == 3 — floor of exact integer returns that integer; verified Python 3.14.3 macOS"
  category: floor
  kind: python_call_eq
  function: Decimal
  args: ["3.0"]
  method: __floor__
  expected: 3

# ---------------------------------------------------------------------------
# decimal.Decimal.__ceil__() contracts
# Decimal.__ceil__() returns a plain int (the smallest integer >= self).
# Rounds toward positive infinity. Used by math.ceil().
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra233.Decimal.ceil.positive_round_up:
  description: "decimal.Decimal('1.2').__ceil__() == 2 — ceil of 1.2 rounds up to 2; verified Python 3.14.3 macOS"
  category: ceil
  kind: python_call_eq
  function: Decimal
  args: ["1.2"]
  method: __ceil__
  expected: 2

invariant decimal_extra233.Decimal.ceil.negative_round_toward_zero:
  description: "decimal.Decimal('-1.2').__ceil__() == -1 — ceil of -1.2 rounds toward +inf giving -1; verified Python 3.14.3 macOS"
  category: ceil
  kind: python_call_eq
  function: Decimal
  args: ["-1.2"]
  method: __ceil__
  expected: -1

invariant decimal_extra233.Decimal.ceil.exact_integer:
  description: "decimal.Decimal('3.0').__ceil__() == 3 — ceil of exact integer returns that integer; verified Python 3.14.3 macOS"
  category: ceil
  kind: python_call_eq
  function: Decimal
  args: ["3.0"]
  method: __ceil__
  expected: 3

# ---------------------------------------------------------------------------
# decimal.Decimal.to_integral_value() contracts
# to_integral_value() rounds to the nearest integer using ROUND_HALF_EVEN
# (banker's rounding) by default. Returns a Decimal, not an int.
# Half-way values round to the nearest even integer: 1.5->2, 2.5->2, -2.5->-2.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra233.Decimal.to_integral.1_7_str:
  description: "decimal.Decimal('1.7').to_integral_value().__str__() == '2' — rounds up to 2 (nearest integer); verified Python 3.14.3 macOS"
  category: to_integral
  kind: python_call_eq
  function: Decimal
  args: ["1.7"]
  method: to_integral_value
  method_chain: __str__
  expected: "2"

invariant decimal_extra233.Decimal.to_integral.neg_1_7_str:
  description: "decimal.Decimal('-1.7').to_integral_value().__str__() == '-2' — rounds away from zero to -2; verified Python 3.14.3 macOS"
  category: to_integral
  kind: python_call_eq
  function: Decimal
  args: ["-1.7"]
  method: to_integral_value
  method_chain: __str__
  expected: "-2"

invariant decimal_extra233.Decimal.to_integral.1_5_bankers:
  description: "decimal.Decimal('1.5').to_integral_value().__str__() == '2' — banker's rounding: 1.5 rounds to even 2; verified Python 3.14.3 macOS"
  category: to_integral
  kind: python_call_eq
  function: Decimal
  args: ["1.5"]
  method: to_integral_value
  method_chain: __str__
  expected: "2"

invariant decimal_extra233.Decimal.to_integral.2_5_bankers:
  description: "decimal.Decimal('2.5').to_integral_value().__str__() == '2' — banker's rounding: 2.5 rounds to even 2; verified Python 3.14.3 macOS"
  category: to_integral
  kind: python_call_eq
  function: Decimal
  args: ["2.5"]
  method: to_integral_value
  method_chain: __str__
  expected: "2"

invariant decimal_extra233.Decimal.to_integral.neg_2_5_bankers:
  description: "decimal.Decimal('-2.5').to_integral_value().__str__() == '-2' — banker's rounding: -2.5 rounds to even -2; verified Python 3.14.3 macOS"
  category: to_integral
  kind: python_call_eq
  function: Decimal
  args: ["-2.5"]
  method: to_integral_value
  method_chain: __str__
  expected: "-2"
