spec: multiprocessing_extra2461
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "Test vectors verified by running Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/queues.py"
    - "CPython source: Lib/multiprocessing/synchronize.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "Theme: __len__ and __length_hint__ dict-presence — checking whether multiprocessing classes define the length protocol in their class __dict__."
    - "multiprocessing.queues.Queue defines qsize() (with OS caveats) but NOT __len__; it is not a Python sequence."
    - "multiprocessing.queues.JoinableQueue, SimpleQueue, pool.Pool, and synchronize primitives all lack __len__ and __length_hint__."
    - "All classes tested: multiprocessing.queues.Queue, JoinableQueue, SimpleQueue, pool.Pool, synchronize.Semaphore, synchronize.Event."
    - "All expected values verified by running Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.queues.Queue — IPC queue; uses qsize() not __len__
# ---------------------------------------------------------------------------

table multiprocessing_extra2461.queues.Queue.len_protocol:
  description: "multiprocessing.queues.Queue class __dict__ does NOT contain __len__ or __length_hint__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: mp2461

  columns: [id, function, args, expected]
  rows:
    - ["mp2461-001", multiprocessing.queues.Queue.__dict__.__contains__, ["__len__"],         false]
    - ["mp2461-002", multiprocessing.queues.Queue.__dict__.__contains__, ["__length_hint__"], false]

table multiprocessing_extra2461.queues.Queue.method_presence:
  description: "multiprocessing.queues.Queue class __dict__ contains put, get, qsize, and empty"
  kind: python_call_eq
  category: dict_presence
  id_prefix: mp2461

  columns: [id, function, args, expected]
  rows:
    - ["mp2461-010", multiprocessing.queues.Queue.__dict__.__contains__, ["put"],   true]
    - ["mp2461-011", multiprocessing.queues.Queue.__dict__.__contains__, ["get"],   true]
    - ["mp2461-012", multiprocessing.queues.Queue.__dict__.__contains__, ["qsize"], true]
    - ["mp2461-013", multiprocessing.queues.Queue.__dict__.__contains__, ["empty"], true]
    - ["mp2461-014", multiprocessing.queues.Queue.__dict__.__contains__, ["close"], true]

# ---------------------------------------------------------------------------
# multiprocessing.queues.JoinableQueue — adds task_done/join; still no __len__
# ---------------------------------------------------------------------------

table multiprocessing_extra2461.queues.JoinableQueue.len_protocol:
  description: "multiprocessing.queues.JoinableQueue class __dict__ does NOT contain __len__ or __length_hint__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: mp2461

  columns: [id, function, args, expected]
  rows:
    - ["mp2461-020", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["__len__"],         false]
    - ["mp2461-021", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["__length_hint__"], false]

table multiprocessing_extra2461.queues.JoinableQueue.method_presence:
  description: "multiprocessing.queues.JoinableQueue class __dict__ contains put, task_done, and join"
  kind: python_call_eq
  category: dict_presence
  id_prefix: mp2461

  columns: [id, function, args, expected]
  rows:
    - ["mp2461-030", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["put"],       true]
    - ["mp2461-031", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["task_done"], true]
    - ["mp2461-032", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["join"],      true]

# ---------------------------------------------------------------------------
# multiprocessing.queues.SimpleQueue — lightweight queue; no __len__
# ---------------------------------------------------------------------------

table multiprocessing_extra2461.queues.SimpleQueue.len_protocol:
  description: "multiprocessing.queues.SimpleQueue class __dict__ does NOT contain __len__ or __length_hint__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: mp2461

  columns: [id, function, args, expected]
  rows:
    - ["mp2461-040", multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["__len__"],         false]
    - ["mp2461-041", multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["__length_hint__"], false]
    - ["mp2461-042", multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["get"],             true]
    - ["mp2461-043", multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["empty"],           true]

