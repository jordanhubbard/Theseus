spec: decimal_extra2476
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "Theme: __contains__ and __getitem__ dict-presence — checking whether decimal.Decimal defines membership test and item access protocol in its class __dict__."
    - "decimal.Decimal is a numeric type — it defines no __contains__ or __getitem__ in its own __dict__."
    - "decimal.Decimal.__dict__ does NOT contain '__contains__' (False) — Decimal is not a container."
    - "decimal.Decimal.__dict__ does NOT contain '__getitem__' (False) — Decimal does not support subscript access."
    - "decimal.Decimal.__dict__ DOES contain arithmetic dunders: __add__, __mul__, __sub__, __truediv__, __neg__, __abs__ (all True)."
    - "decimal.Decimal.__dict__ DOES contain conversion dunders: __float__, __int__, __str__, __repr__ (all True)."
    - "decimal.Decimal.__dict__ DOES contain comparison dunders: __eq__, __lt__, __gt__, __hash__ (all True)."
    - "decimal.Decimal.__dict__ DOES contain numeric predicates: is_nan, is_finite, is_zero, is_signed (all True)."
    - "decimal.Decimal.__dict__ DOES contain math methods: sqrt, as_tuple, quantize (all True)."
    - "Accessing a missing key via decimal.Decimal.__dict__.__getitem__ raises KeyError."
    - "Note: pre-existing compile errors exist for decimal_extra88, decimal_extra520, decimal_extra161, decimal_extra1606 — those are separate spec files, not this one."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__.__contains__ — container protocol absent
# Decimal is a numeric scalar type; it defines no __contains__ or __getitem__.
# Contrast with re.Match, which defines __getitem__ for group subscript access.
# ---------------------------------------------------------------------------

table decimal_extra2476.Decimal_dict_protocol_absence:
  description: "decimal.Decimal.__dict__ does not contain __contains__ or __getitem__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: dc2476

  columns: [id, function, args, expected]
  rows:
    - ["dc2476001", decimal.Decimal.__dict__.__contains__, ["__contains__"], false]
    - ["dc2476002", decimal.Decimal.__dict__.__contains__, ["__getitem__"],  false]

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__.__contains__ — arithmetic dunders present
# The standard numeric protocol dunders are defined directly on Decimal.
# ---------------------------------------------------------------------------

table decimal_extra2476.Decimal_dict_arithmetic_presence:
  description: "decimal.Decimal.__dict__ contains arithmetic dunders: __add__, __mul__, __sub__, __truediv__, __neg__, __abs__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: dc2476

  columns: [id, function, args, expected]
  rows:
    - ["dc2476003", decimal.Decimal.__dict__.__contains__, ["__add__"],     true]
    - ["dc2476004", decimal.Decimal.__dict__.__contains__, ["__mul__"],     true]
    - ["dc2476005", decimal.Decimal.__dict__.__contains__, ["__sub__"],     true]
    - ["dc2476006", decimal.Decimal.__dict__.__contains__, ["__truediv__"], true]
    - ["dc2476007", decimal.Decimal.__dict__.__contains__, ["__neg__"],     true]
    - ["dc2476008", decimal.Decimal.__dict__.__contains__, ["__abs__"],     true]

