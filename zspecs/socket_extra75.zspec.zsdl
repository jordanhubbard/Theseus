spec: socket_extra75
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra74.zspec.zsdl — covers socket.socket.sendto/recvfrom/shutdown/__qualname__ eq and len / socket.__dict__.__class__.__name__=='mappingproxy' (table + invariants)."
    - "socket_extra73.zspec.zsdl — covers socket.recv/send/__qualname__ len / AF_INET6/SOCK_DGRAM/SOCK_RAW/__class__/__name__ / gethostname/gethostbyname/getnameinfo/setdefaulttimeout/__class__/__name__=='builtin_function_or_method' (table + invariants)."
    - "socket_extra72.zspec.zsdl — covers socket.socket.accept/connect/bind/listen/close/__qualname__.__len__() (table + invariants)."
    - "socket_extra69.zspec.zsdl — covers socket.socket.__dict__.__contains__ accept/makefile/setblocking/settimeout (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra74; it does NOT duplicate invariants present in those files."
    - "Wave 242 theme: socket socket.__dict__ membership + module-level function qualnames."
    - "In python_module(socket), 'socket' in the module namespace refers to the socket.socket class (the Python-level class defined in Lib/socket.py that wraps _socket.socket). 'socket.__dict__' is socket.socket.__dict__."
    - "socket.socket.__dict__.__contains__('close') == True — close is a Python method defined in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('detach') == True — detach is a Python method defined in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('dup') == True — dup is a Python method defined in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('sendfile') == True — sendfile is a Python method defined in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('get_inheritable') == True — get_inheritable is a Python method defined in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('set_inheritable') == True — set_inheritable is a Python method defined in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__qualname__ == 'gethostname' — C builtins have simple qualnames equal to their __name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__qualname__ == 'gethostbyname' — simple qualname for C builtin. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getnameinfo.__qualname__ == 'getnameinfo' — simple qualname for C builtin. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__qualname__ == 'setdefaulttimeout' — simple qualname for C builtin. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__ for close and detach
#
# Wave 242 theme: socket socket.__dict__ membership.
#
# socket.socket (the Python class in socket.py) defines close and detach as
# Python methods. socket_extra69 covers accept/makefile/setblocking/settimeout.
# No prior socket spec checks close or detach in socket.__dict__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra75.socket_dict_contains_close_detach:
  description: "socket.socket/__dict__.__contains__('close')==True / socket/__dict__.__contains__('detach')==True — close and detach are Python methods defined in socket.py on the socket.socket class; socket_extra69 covers accept/makefile; no prior socket spec checks close or detach in socket.__dict__; first close and detach dict contains anchor"
  kind: python_call_eq
  category: class_dict
  id_prefix: socketmore75

  columns: [id, function, args, expected]
  rows:
    - [socket_dict_contains_close,  socket.__dict__.__contains__, ["close"],  true]
    - [socket_dict_contains_detach, socket.__dict__.__contains__, ["detach"], true]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__ for dup and sendfile
#
# Wave 242 theme: socket socket.__dict__ membership.
#
# socket.socket defines dup and sendfile as Python methods in socket.py.
# No prior socket spec checks dup or sendfile in socket.__dict__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra75.socket_dict_contains_dup_sendfile:
  description: "socket.socket/__dict__.__contains__('dup')==True / socket/__dict__.__contains__('sendfile')==True — dup and sendfile are Python methods defined in socket.py on the socket.socket class; no prior socket spec checks dup or sendfile in socket.__dict__; first dup and sendfile dict contains anchor"
  kind: python_call_eq
  category: class_dict
  id_prefix: socketmore75

  columns: [id, function, args, expected]
  rows:
    - [socket_dict_contains_dup,      socket.__dict__.__contains__, ["dup"],      true]
    - [socket_dict_contains_sendfile, socket.__dict__.__contains__, ["sendfile"], true]

# ---------------------------------------------------------------------------
# socket.gethostname and gethostbyname __qualname__ identity
#
# Wave 242 theme: module-level function qualnames.
#
# socket.gethostname.__qualname__ is 'gethostname' (simple name, C builtin).
# socket.gethostbyname.__qualname__ is 'gethostbyname' (simple name, C builtin).
# socket_extra73 covers __class__.__name__=='builtin_function_or_method' for these.
# No prior socket spec checks gethostname.__qualname__ or gethostbyname.__qualname__
# equality. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra75.gethostname_gethostbyname_qualname:
  description: "socket.gethostname/__qualname__.__eq__('gethostname')==True / gethostbyname/__qualname__.__eq__('gethostbyname')==True — gethostname and gethostbyname are C builtins with simple qualnames equal to their function name; socket_extra73 covers their class name; no prior socket spec checks gethostname/__qualname__ or gethostbyname/__qualname__ equality; first qualname identity anchor for gethostname and gethostbyname"
  kind: python_call_eq
  category: qualnames
  id_prefix: socketmore75

  columns: [id, function, args, expected]
  rows:
    - [gethostname_qualname_eq,   gethostname.__qualname__.__eq__,   ["gethostname"],   true]
    - [gethostbyname_qualname_eq, gethostbyname.__qualname__.__eq__, ["gethostbyname"], true]

# ---------------------------------------------------------------------------
# socket.getnameinfo and setdefaulttimeout __qualname__ identity
#
# Wave 242 theme: module-level function qualnames.
#
# socket.getnameinfo.__qualname__ is 'getnameinfo' (simple name, C builtin).
# socket.setdefaulttimeout.__qualname__ is 'setdefaulttimeout' (simple name, C builtin).
# No prior socket spec checks getnameinfo.__qualname__ or setdefaulttimeout.__qualname__
# equality. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra75.getnameinfo_setdefaulttimeout_qualname:
  description: "socket.getnameinfo/__qualname__.__eq__('getnameinfo')==True / setdefaulttimeout/__qualname__.__eq__('setdefaulttimeout')==True — getnameinfo and setdefaulttimeout are C builtins with simple qualnames; no prior socket spec checks getnameinfo/__qualname__ or setdefaulttimeout/__qualname__ equality; first qualname identity anchor for getnameinfo and setdefaulttimeout"
  kind: python_call_eq
  category: qualnames
  id_prefix: socketmore75

  columns: [id, function, args, expected]
  rows:
    - [getnameinfo_qualname_eq,       getnameinfo.__qualname__.__eq__,       ["getnameinfo"],       true]
    - [setdefaulttimeout_qualname_eq, setdefaulttimeout.__qualname__.__eq__, ["setdefaulttimeout"], true]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('close') — standalone
#
# socket.socket defines close in its __dict__. No prior socket spec checks
# close in socket.__dict__ as a standalone. First close dict contains standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra75.socket_dict_contains_close:
  description: "socket.socket.__dict__.__contains__('close') == True — close is a Python method defined in socket.py; no prior socket spec checks close in socket.__dict__ as a standalone; first close dict contains standalone"
  category: class_dict
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["close"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('sendfile') — standalone
#
# socket.socket defines sendfile in its __dict__. No prior socket spec checks
# sendfile in socket.__dict__ as a standalone. First sendfile dict contains standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra75.socket_dict_contains_sendfile:
  description: "socket.socket.__dict__.__contains__('sendfile') == True — sendfile is a Python method defined in socket.py; no prior socket spec checks sendfile in socket.__dict__ as a standalone; first sendfile dict contains standalone"
  category: class_dict
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["sendfile"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gethostname.__qualname__.__eq__('gethostname') — standalone
#
# socket.gethostname.__qualname__ is 'gethostname'. No prior socket spec checks
# gethostname.__qualname__ equality as a standalone. First qualname identity
# standalone for gethostname. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra75.gethostname_qualname_eq:
  description: "socket.gethostname.__qualname__.__eq__('gethostname') == True — gethostname is a C builtin with simple qualname 'gethostname'; no prior socket spec checks gethostname.__qualname__ equality as a standalone; first qualname identity standalone for gethostname"
  category: qualnames
  kind: python_call_eq
  function: gethostname.__qualname__.__eq__
  args: ["gethostname"]
  expected: true

