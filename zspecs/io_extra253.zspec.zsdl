spec: io_extra253
version: ">=3.2"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE type/positive and SEEK_* type checks"
    - "io_extra200.zspec.zsdl — covers StringIO class identity and method qualnames"
    - "io_extra252.zspec.zsdl — covers SEEK_* values and DEFAULT_BUFFER_SIZE exact value"
  notes:
    - "This spec covers: io.StringIO behavioral contracts — read, getvalue, write, readline, writable, readable."
    - "StringIO('hello').read() == 'hello' — read() returns all content when no size given; verified Python 3.14.3 macOS."
    - "StringIO('hello').getvalue() == 'hello' — getvalue() returns entire stream contents regardless of position; verified Python 3.14.3 macOS."
    - "StringIO().write('abc') == 3 — write() returns the number of characters written (int); verified Python 3.14.3 macOS."
    - "StringIO().write('hello') == 5 — write() returns 5 for a 5-character string; verified Python 3.14.3 macOS."
    - "StringIO('hello').readline() == 'hello' — readline() with no newline returns full content; verified Python 3.14.3 macOS."
    - "StringIO().writable() == True and StringIO().readable() == True; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# StringIO read() behavioral contracts
# read() with no size reads from current position to end of stream.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra253.stringio_read:
  description: "StringIO.read() behavioral contracts: read full content for various initial strings; verified Python 3.14.3"
  kind: python_call_eq
  category: read
  id_prefix: iostriobeh253
  function: StringIO
  method: read

  columns: [id, args, expected]
  rows:
    - [read_hello,    ["hello"],    "hello"]
    - [read_empty,    [""],         ""]
    - [read_abc,      ["abc"],      "abc"]
    - [read_spaces,   ["   "],      "   "]
    - [read_newlines, ["a\nb\nc"],  "a\nb\nc"]

# ---------------------------------------------------------------------------
# StringIO getvalue() behavioral contracts
# getvalue() returns the entire contents regardless of current stream position.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra253.stringio_getvalue:
  description: "StringIO.getvalue() behavioral contracts for various initial strings; verified Python 3.14.3"
  kind: python_call_eq
  category: getvalue
  id_prefix: iostriobeh253
  function: StringIO
  method: getvalue

  columns: [id, args, expected]
  rows:
    - [getvalue_hello,  ["hello"],  "hello"]
    - [getvalue_empty,  [""],       ""]
    - [getvalue_abc,    ["abc"],    "abc"]
    - [getvalue_number, ["42"],     "42"]

# ---------------------------------------------------------------------------
# StringIO write() behavioral contracts
# write(s) returns the number of characters written (an int).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra253.stringio_write:
  description: "StringIO.write(s) returns number of characters written; verified Python 3.14.3"
  kind: python_call_eq
  category: write
  id_prefix: iostriobeh253
  function: StringIO
  method: write

  columns: [id, args, method_args, expected]
  rows:
    - [write_abc,   [], ["abc"],   3]
    - [write_hello, [], ["hello"], 5]
    - [write_x,     [], ["x"],     1]
    - [write_empty, [], [""],      0]

# ---------------------------------------------------------------------------
# StringIO readline() behavioral contracts
# readline() reads up to and including the next newline (or EOF).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra253.stringio_readline:
  description: "StringIO.readline() behavioral contracts; verified Python 3.14.3"
  kind: python_call_eq
  category: readline
  id_prefix: iostriobeh253
  function: StringIO
  method: readline

  columns: [id, args, expected]
  rows:
    - [readline_hello, ["hello"], "hello"]
    - [readline_empty, [""],      ""]
    - [readline_abc,   ["abc"],   "abc"]

# ---------------------------------------------------------------------------
# StringIO writable() and readable() predicates
# Both always return True for StringIO objects.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra253.stringio_predicates:
  description: "StringIO.writable() and StringIO.readable() both return True; verified Python 3.14.3"
  kind: python_call_eq
  category: predicates
  id_prefix: iostriobeh253
  function: StringIO

  columns: [id, args, method, expected]
  rows:
    - [writable_empty, [], writable, true]
    - [readable_empty, [], readable, true]

# ---------------------------------------------------------------------------
# Standalone invariants — StringIO read
# ---------------------------------------------------------------------------

invariant io_extra253.StringIO.read.hello:
  description: "io.StringIO('hello').read() == 'hello' — read() returns all content of a StringIO initialized with 'hello'; verified Python 3.14.3 macOS"
  category: read
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: read
  expected: "hello"

invariant io_extra253.StringIO.read.empty:
  description: "io.StringIO('').read() == '' — reading from an empty StringIO returns an empty string; verified Python 3.14.3 macOS"
  category: read
  kind: python_call_eq
  function: StringIO
  args: [""]
  method: read
  expected: ""

invariant io_extra253.StringIO.read.abc:
  description: "io.StringIO('abc').read() == 'abc' — read() returns all content of a StringIO initialized with 'abc'; verified Python 3.14.3 macOS"
  category: read
  kind: python_call_eq
  function: StringIO
  args: ["abc"]
  method: read
  expected: "abc"

# ---------------------------------------------------------------------------
# Standalone invariants — StringIO getvalue
# ---------------------------------------------------------------------------

invariant io_extra253.StringIO.getvalue.hello:
  description: "io.StringIO('hello').getvalue() == 'hello' — getvalue returns entire stream contents regardless of position; verified Python 3.14.3 macOS"
  category: getvalue
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: getvalue
  expected: "hello"

invariant io_extra253.StringIO.getvalue.empty:
  description: "io.StringIO('').getvalue() == '' — getvalue on empty StringIO returns empty string; verified Python 3.14.3 macOS"
  category: getvalue
  kind: python_call_eq
  function: StringIO
  args: [""]
  method: getvalue
  expected: ""

# ---------------------------------------------------------------------------
# Standalone invariants — StringIO write
# ---------------------------------------------------------------------------

invariant io_extra253.StringIO.write.abc_returns_3:
  description: "io.StringIO().write('abc') == 3 — write() returns the number of characters written; 'abc' has 3 characters; verified Python 3.14.3 macOS"
  category: write
  kind: python_call_eq
  function: StringIO
  args: []
  method: write
  method_args: ["abc"]
  expected: 3

invariant io_extra253.StringIO.write.hello_returns_5:
  description: "io.StringIO().write('hello') == 5 — write() returns 5 for a 5-character string 'hello'; verified Python 3.14.3 macOS"
  category: write
  kind: python_call_eq
  function: StringIO
  args: []
  method: write
  method_args: ["hello"]
  expected: 5

invariant io_extra253.StringIO.write.empty_returns_0:
  description: "io.StringIO().write('') == 0 — write() returns 0 when writing an empty string; verified Python 3.14.3 macOS"
  category: write
  kind: python_call_eq
  function: StringIO
  args: []
  method: write
  method_args: [""]
  expected: 0

# ---------------------------------------------------------------------------
# Standalone invariants — StringIO readline
# ---------------------------------------------------------------------------

invariant io_extra253.StringIO.readline.hello:
  description: "io.StringIO('hello').readline() == 'hello' — readline on single-line content without newline returns full content; verified Python 3.14.3 macOS"
  category: readline
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: readline
  expected: "hello"

invariant io_extra253.StringIO.readline.empty:
  description: "io.StringIO('').readline() == '' — readline on empty StringIO returns empty string; verified Python 3.14.3 macOS"
  category: readline
  kind: python_call_eq
  function: StringIO
  args: [""]
  method: readline
  expected: ""

# ---------------------------------------------------------------------------
# Standalone invariants — StringIO writable / readable
# ---------------------------------------------------------------------------

invariant io_extra253.StringIO.writable.true:
  description: "io.StringIO().writable() == True — StringIO is always writable; verified Python 3.14.3 macOS"
  category: predicates
  kind: python_call_eq
  function: StringIO
  args: []
  method: writable
  expected: true

invariant io_extra253.StringIO.readable.true:
  description: "io.StringIO().readable() == True — StringIO is always readable; verified Python 3.14.3 macOS"
  category: predicates
  kind: python_call_eq
  function: StringIO
  args: []
  method: readable
  expected: true
