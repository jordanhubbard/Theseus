spec: hashlib_extra2236
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_blake2/blake2module.c"
    - "CPython source: Modules/_hashopenssl.c"
  notes:
    - "Theme: __slots__ and slot descriptor protocol — checking __slots__, __weakref__, __dict__, __abstractmethods__, __init__, __new__ presence in class __dict__."
    - "hashlib.blake2b and hashlib.blake2s are C extension types from the _blake2 module."
    - "C extension types do not define __slots__ at the Python level; __slots__ is absent from their __dict__."
    - "C extension types do not expose __weakref__ or __dict__ descriptors in __dict__ (GC handled at C level)."
    - "C extension types do not define __abstractmethods__ or __init__ in __dict__."
    - "blake2b.__dict__ contains __new__ (C tp_new slot is exposed as __new__)."
    - "blake2s.__dict__ contains __new__ (C tp_new slot is exposed as __new__)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table hashlib_extra2236.blake2b_slots:
  description: "hashlib.blake2b C extension type — __slots__ descriptor protocol membership"
  kind: python_call_eq
  category: slots_protocol
  id_prefix: hl2236
  columns: [id, function, args, expected]
  rows:
    - ["hl2236001", hashlib.blake2b.__dict__.__contains__, ["__slots__"], false]
    - ["hl2236002", hashlib.blake2b.__dict__.__contains__, ["__weakref__"], false]
    - ["hl2236003", hashlib.blake2b.__dict__.__contains__, ["__dict__"], false]
    - ["hl2236004", hashlib.blake2b.__dict__.__contains__, ["__abstractmethods__"], false]
    - ["hl2236005", hashlib.blake2b.__dict__.__contains__, ["__init__"], false]
    - ["hl2236006", hashlib.blake2b.__dict__.__contains__, ["__new__"], true]
    - ["hl2236007", hashlib.blake2b.__dict__.__contains__, ["__subclasshook__"], false]

table hashlib_extra2236.blake2s_slots:
  description: "hashlib.blake2s C extension type — __slots__ descriptor protocol membership"
  kind: python_call_eq
  category: slots_protocol
  id_prefix: hl2236
  columns: [id, function, args, expected]
  rows:
    - ["hl2236008", hashlib.blake2s.__dict__.__contains__, ["__slots__"], false]
    - ["hl2236009", hashlib.blake2s.__dict__.__contains__, ["__weakref__"], false]
    - ["hl2236010", hashlib.blake2s.__dict__.__contains__, ["__dict__"], false]
    - ["hl2236011", hashlib.blake2s.__dict__.__contains__, ["__abstractmethods__"], false]
    - ["hl2236012", hashlib.blake2s.__dict__.__contains__, ["__init__"], false]
    - ["hl2236013", hashlib.blake2s.__dict__.__contains__, ["__new__"], true]
    - ["hl2236014", hashlib.blake2s.__dict__.__contains__, ["__subclasshook__"], false]

table hashlib_extra2236.blake2b_classname:
  description: "hashlib.blake2b class identity attributes"
  kind: python_call_eq
  category: classnames
  id_prefix: hl2236
  columns: [id, function, args, expected]
  rows:
    - ["hl2236015", hashlib.blake2b.__name__.__eq__, ["blake2b"], true]
    - ["hl2236016", hashlib.blake2b.__module__.__eq__, ["_blake2"], true]
    - ["hl2236017", hashlib.blake2b.__class__.__name__.__eq__, ["type"], true]
    - ["hl2236018", hashlib.blake2b.__qualname__.__eq__, ["blake2b"], true]

table hashlib_extra2236.blake2s_classname:
  description: "hashlib.blake2s class identity attributes"
  kind: python_call_eq
  category: classnames
  id_prefix: hl2236
  columns: [id, function, args, expected]
  rows:
    - ["hl2236019", hashlib.blake2s.__name__.__eq__, ["blake2s"], true]
    - ["hl2236020", hashlib.blake2s.__module__.__eq__, ["_blake2"], true]
    - ["hl2236021", hashlib.blake2s.__class__.__name__.__eq__, ["type"], true]
    - ["hl2236022", hashlib.blake2s.__qualname__.__eq__, ["blake2s"], true]

table hashlib_extra2236.blake2b_slots_absent_cross:
  description: "hashlib.blake2b — cross-check slot keys absent, confirming C extension has no Python-level __slots__"
  kind: python_call_eq
  category: slots_protocol
  id_prefix: hl2236
  columns: [id, function, args, expected]
  rows:
    - ["hl2236023", hashlib.blake2b.__dict__.__contains__, ["__doc__"], true]
    - ["hl2236024", hashlib.blake2b.__dict__.__contains__, ["__new__"], true]
    - ["hl2236025", hashlib.blake2s.__dict__.__contains__, ["__doc__"], true]
