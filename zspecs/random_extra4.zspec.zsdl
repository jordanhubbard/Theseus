spec: random_extra4
version: ">=3.9"
backend: python_module(random)

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/random.html — Python random module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/random.py"
  notes:
    - "This spec extends prior random specs."
    - "Focus: __module__ and __name__ for random functions/classes not yet covered; class hierarchy."
    - "random.Random is a class; random.SystemRandom is a class (uses os.urandom)."
    - "random.seed.__name__ == 'seed'; random.sample.__name__ == 'sample'."
    - "random.shuffle.__name__ == 'shuffle'; random.choices.__name__ == 'choices'."
    - "random.Random.__bases__[0].__name__ == '_random.Random' or 'Random' depending on implementation."
    - "random.SystemRandom.__module__ == 'random'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table random_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [seed,    seed.__name__.__eq__,    ["seed"],    true]
    - [sample,  sample.__name__.__eq__,  ["sample"],  true]
    - [shuffle, shuffle.__name__.__eq__, ["shuffle"], true]
    - [choices, choices.__name__.__eq__, ["choices"], true]
    - [gauss,   gauss.__name__.__eq__,   ["gauss"],   true]
    - [uniform, uniform.__name__.__eq__, ["uniform"], true]

table random_extra4.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Random,       Random.__name__.__eq__,       ["Random"],       true]
    - [SystemRandom, SystemRandom.__name__.__eq__, ["SystemRandom"], true]

invariant random_extra4.Random.module:
  description: "random.Random.__module__ == 'random'"
  category: module
  kind: python_call_eq
  function: Random.__module__.__eq__
  args: ["random"]
  expected: true

invariant random_extra4.SystemRandom.module:
  description: "random.SystemRandom.__module__ == 'random'"
  category: module
  kind: python_call_eq
  function: SystemRandom.__module__.__eq__
  args: ["random"]
  expected: true

invariant random_extra4.sample.returns_list:
  description: "random.sample([1,2,3,4,5], 3).__class__.__name__ == 'list'"
  category: sample
  kind: python_call_eq
  function: sample
  args: [[1, 2, 3, 4, 5], 3]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["list"]
  expected: true

invariant random_extra4.sample.length:
  description: "len(random.sample([1,2,3,4,5], 3)) == 3"
  category: sample
  kind: python_call_eq
  function: sample
  args: [[1, 2, 3, 4, 5], 3]
  method: __len__
  method_args: []
  expected: 3

invariant random_extra4.choices.returns_list:
  description: "random.choices([1,2,3], k=2).__class__.__name__ == 'list'"
  category: choices
  kind: python_call_eq
  function: choices
  args: [[1, 2, 3]]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["list"]
  expected: true

invariant random_extra4.BPF.value:
  description: "random.BPF == 53 — bits per float (Mersenne Twister precision)"
  category: constants
  kind: python_call_eq
  function: BPF.__eq__
  args: [53]
  expected: true
