spec: itertools_extra2596
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2596 (_extra2596): __get__, __set__, __delete__ descriptor-protocol dict-presence checks for itertools types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "itertools types are C extension iterator types. None implement the descriptor protocol."
    - "chain, count, repeat, cycle, islice, compress, dropwhile, takewhile, starmap, groupby, filterfalse, accumulate, zip_longest, pairwise, product, permutations, combinations: all return False for __get__, __set__, __delete__ in __dict__."
    - "Because no itertools type defines __get__, none qualify as descriptors (data or non-data) under the descriptor protocol."
    - "These types exist as iterable C objects, not as class-attribute binding mechanisms."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __get__ dict-presence for itertools types
#
# None of the itertools iterator types define __get__ in their own __dict__.
# They are not descriptors of any kind (data or non-data). These types are
# C extension objects that implement the iterator protocol (__iter__,
# __next__) but not the descriptor protocol.
# ---------------------------------------------------------------------------

table itertools_extra2596.get_protocol:
  description: "itertools types __get__ dict-presence — all False, no itertools type is a descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2596

  columns: [id, function, args, expected]
  rows:
    - ["it2596001", "itertools.chain.__dict__.__contains__", ["__get__"], false]
    - ["it2596002", "itertools.count.__dict__.__contains__", ["__get__"], false]
    - ["it2596003", "itertools.repeat.__dict__.__contains__", ["__get__"], false]
    - ["it2596004", "itertools.cycle.__dict__.__contains__", ["__get__"], false]
    - ["it2596005", "itertools.islice.__dict__.__contains__", ["__get__"], false]
    - ["it2596006", "itertools.compress.__dict__.__contains__", ["__get__"], false]
    - ["it2596007", "itertools.dropwhile.__dict__.__contains__", ["__get__"], false]

# ---------------------------------------------------------------------------
# Table 2: __set__ dict-presence for itertools types
#
# None of the itertools types define __set__. Combined with the absence of
# __get__, this means no itertools type participates in the descriptor
# protocol at all. __set__ alone (without __get__) would be unusual but
# is theoretically possible; in practice itertools types have neither.
# ---------------------------------------------------------------------------

table itertools_extra2596.set_protocol:
  description: "itertools types __set__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2596

  columns: [id, function, args, expected]
  rows:
    - ["it2596008", "itertools.chain.__dict__.__contains__", ["__set__"], false]
    - ["it2596009", "itertools.count.__dict__.__contains__", ["__set__"], false]
    - ["it2596010", "itertools.repeat.__dict__.__contains__", ["__set__"], false]
    - ["it2596011", "itertools.cycle.__dict__.__contains__", ["__set__"], false]
    - ["it2596012", "itertools.islice.__dict__.__contains__", ["__set__"], false]
    - ["it2596013", "itertools.compress.__dict__.__contains__", ["__set__"], false]
    - ["it2596014", "itertools.dropwhile.__dict__.__contains__", ["__set__"], false]

# ---------------------------------------------------------------------------
# Table 3: __delete__ dict-presence for itertools types
#
# None of the itertools types define __delete__. These combinatorial and
# filtering iterator types expose no attribute-deletion hook.
# ---------------------------------------------------------------------------

table itertools_extra2596.delete_protocol:
  description: "itertools types __delete__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2596

  columns: [id, function, args, expected]
  rows:
    - ["it2596015", "itertools.takewhile.__dict__.__contains__", ["__delete__"], false]
    - ["it2596016", "itertools.starmap.__dict__.__contains__", ["__delete__"], false]
    - ["it2596017", "itertools.groupby.__dict__.__contains__", ["__delete__"], false]
    - ["it2596018", "itertools.filterfalse.__dict__.__contains__", ["__delete__"], false]
    - ["it2596019", "itertools.accumulate.__dict__.__contains__", ["__delete__"], false]
    - ["it2596020", "itertools.zip_longest.__dict__.__contains__", ["__delete__"], false]
    - ["it2596021", "itertools.pairwise.__dict__.__contains__", ["__delete__"], false]

# ---------------------------------------------------------------------------
# Table 4: Combinatorial itertools types — full descriptor protocol check
#
# The combinatorial itertools types (product, permutations, combinations,
# combinations_with_replacement) are C extension types implementing the
# iterator protocol only. None define any descriptor dunders.
# ---------------------------------------------------------------------------

table itertools_extra2596.combinatorial_descriptor_check:
  description: "Combinatorial itertools types have no descriptor protocol dunders"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2596

  columns: [id, function, args, expected]
  rows:
    - ["it2596022", "itertools.product.__dict__.__contains__", ["__get__"], false]
    - ["it2596023", "itertools.product.__dict__.__contains__", ["__set__"], false]
    - ["it2596024", "itertools.product.__dict__.__contains__", ["__delete__"], false]
    - ["it2596025", "itertools.permutations.__dict__.__contains__", ["__get__"], false]
    - ["it2596026", "itertools.permutations.__dict__.__contains__", ["__set__"], false]
    - ["it2596027", "itertools.combinations.__dict__.__contains__", ["__get__"], false]
    - ["it2596028", "itertools.combinations.__dict__.__contains__", ["__set__"], false]
    - ["it2596029", "itertools.combinations.__dict__.__contains__", ["__delete__"], false]
