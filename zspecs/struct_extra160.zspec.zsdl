spec: struct_extra160
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra159.zspec.zsdl — covers struct.__spec__.origin.__class__.__name__=='str' / origin.__contains__('struct') / submodule_search_locations NoneType / __spec__.__class__.__name__=='ModuleSpec' / spec attribute lengths (table + invariants)."
    - "struct_extra158.zspec.zsdl — covers struct.Struct.__new__/__str__ qualnames; struct.error class identity / error.__bases__[0].__name__=='Exception' (table + invariants)."
    - "struct_extra157.zspec.zsdl — covers struct.Struct.__repr__/__sizeof__ qualnames and lengths; wrapper_descriptor/method_descriptor types (table + invariants)."
    - "struct_extra155.zspec.zsdl — covers struct.Struct.size/__format__ getset_descriptor qualnames (table + invariants)."
    - "struct_extra154.zspec.zsdl — covers struct.Struct.pack/__unpack/__pack_into qualnames and method_descriptor type (table + invariants)."
    - "struct_extra153.zspec.zsdl — covers struct.Struct.__init__.__qualname__ / Struct.__doc__.__len__()==40 / error.__doc__ NoneType (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra159."
    - "Wave 346 theme: struct.Struct.__dict__ key membership checks via __dict__.__contains__ — 'pack', 'unpack', 'pack_into', 'unpack_from', 'iter_unpack', 'size', 'format'. Also struct.Struct.__dict__.__len__()==16 and __dict__.__class__.__name__=='mappingproxy'."
    - "struct.Struct.__dict__.__len__() == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__class__.__name__ == 'mappingproxy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('pack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('pack_into') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('unpack_from') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('iter_unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('size') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('format') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.__dict__.__len__() == 16. The Struct class has 16 entries in its __dict__: 'pack', 'unpack', 'pack_into', 'unpack_from', 'iter_unpack' (5 method_descriptor methods), 'size', 'format' (2 getset_descriptor properties), '__init__', '__new__', '__repr__', '__doc__', '__getattribute__', '__delattr__', '__setattr__', '__sizeof__', '__module__' (11 dunder/infra entries). Total = 16."
    - "Note: struct.Struct.__dict__ keys verified: ['__delattr__', '__doc__', '__getattribute__', '__init__', '__module__', '__new__', '__repr__', '__setattr__', '__sizeof__', 'format', 'iter_unpack', 'pack', 'pack_into', 'size', 'unpack', 'unpack_from']. This is a C extension type dict (mappingproxy wrapping the Struct type's tp_methods and tp_getset slots)."
    - "Note: 'pack', 'unpack', 'pack_into', 'unpack_from', 'iter_unpack' are method_descriptor objects (struct_extra154 anchors pack/unpack/pack_into qualnames). 'size' and 'format' are getset_descriptor objects (struct_extra155 anchors their qualnames). All 7 are defined directly on the Struct C type."
    - "Note: struct.Struct.__dict__.__class__.__name__ == 'mappingproxy' (12 chars). All class __dict__ attributes in Python are mappingproxy objects. For C extension types like struct.Struct, the mappingproxy wraps the type's C-level method and attribute tables."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('pack')
# struct.Struct.__dict__.__contains__('unpack')
# struct.Struct.__dict__.__contains__('pack_into')
# struct.Struct.__dict__.__contains__('unpack_from')
#
# Wave 346 theme: struct.Struct.__dict__ pack/unpack method membership.
#
# Struct.__dict__.__contains__('pack') == True (method_descriptor).
# Struct.__dict__.__contains__('unpack') == True (method_descriptor).
# Struct.__dict__.__contains__('pack_into') == True (method_descriptor).
# Struct.__dict__.__contains__('unpack_from') == True (method_descriptor).
# struct_extra154 anchors pack/unpack/pack_into qualnames; this spec anchors membership
# via __dict__.__contains__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra160.Struct_dict_pack_unpack_membership:
  description: "struct.Struct.__dict__.__contains__('pack')==True / __dict__.__contains__('unpack')==True / __dict__.__contains__('pack_into')==True / __dict__.__contains__('unpack_from')==True — __dict__.__contains__('pack') is True ('pack' is a method_descriptor in Struct.__dict__; packs values into bytes according to the format string; struct_extra154 anchors Struct.pack.__qualname__=='Struct.pack' as a table row; confirmed here as dict member); __dict__.__contains__('unpack') is True ('unpack' is a method_descriptor; unpacks bytes into a tuple of values; struct_extra154 anchors Struct.unpack.__qualname__=='Struct.unpack' as a row; confirmed here); __dict__.__contains__('pack_into') is True ('pack_into' is a method_descriptor; packs values into a writable buffer at an offset; struct_extra154 anchors Struct.pack_into.__qualname__ as a row; confirmed here); __dict__.__contains__('unpack_from') is True ('unpack_from' is a method_descriptor; unpacks from a buffer at an offset; defined directly on Struct C type; method_descriptor type); first structdict160 anchor for pack/unpack __contains__ membership"
  kind: python_call_eq
  category: identity
  id_prefix: structdict160

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_pack,        "Struct.__dict__.__contains__", ["pack"],        true, "struct.Struct.__dict__.__contains__('pack') == True ('pack' is a method_descriptor; packs values into bytes; struct_extra154 anchors qualname)"]
    - [dict_has_unpack,      "Struct.__dict__.__contains__", ["unpack"],      true, "struct.Struct.__dict__.__contains__('unpack') == True ('unpack' is a method_descriptor; unpacks bytes into tuple; struct_extra154 anchors qualname)"]
    - [dict_has_pack_into,   "Struct.__dict__.__contains__", ["pack_into"],   true, "struct.Struct.__dict__.__contains__('pack_into') == True ('pack_into' is a method_descriptor; packs into buffer at offset; struct_extra154 anchors qualname)"]
    - [dict_has_unpack_from, "Struct.__dict__.__contains__", ["unpack_from"], true, "struct.Struct.__dict__.__contains__('unpack_from') == True ('unpack_from' is a method_descriptor; unpacks from buffer at offset; method_descriptor type)"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__ iter_unpack, size, format membership
#
# Wave 346 theme: struct.Struct.__dict__ iteration and getset_descriptor membership.
#
# Struct.__dict__.__contains__('iter_unpack') == True (method_descriptor).
# Struct.__dict__.__contains__('size') == True (getset_descriptor).
# Struct.__dict__.__contains__('format') == True (getset_descriptor).
# Struct.__dict__.__len__() == 16.
# No prior struct spec anchors iter_unpack/__contains__ or size/__format__ as a table under
# structdict160. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra160.Struct_dict_iter_size_format_and_len:
  description: "struct.Struct.__dict__.__contains__('iter_unpack')==True / __dict__.__contains__('size')==True / __dict__.__contains__('format')==True / __dict__.__len__()==16 — __dict__.__contains__('iter_unpack') is True ('iter_unpack' is a method_descriptor in Struct.__dict__; returns an iterator that unpacks from a buffer one occurrence at a time; buffer size must be a multiple of the format size; defined directly on Struct C type; method_descriptor type like pack/unpack/pack_into/unpack_from); __dict__.__contains__('size') is True ('size' is a getset_descriptor; returns the calculated size of the struct in bytes; struct_extra155 anchors Struct.size.__qualname__=='Struct.size' as a row; confirmed here as dict member); __dict__.__contains__('format') is True ('format' is a getset_descriptor; returns the format string used to create the Struct; struct_extra155 anchors Struct.format.__qualname__=='Struct.format' as a row; confirmed here); __dict__.__len__() is 16 (16 entries total: 5 methods + 2 getsets + 9 infra/dunders; first structdict160 anchor for __len__()==16); first structdict160 anchor for iter_unpack/size/format __contains__ membership"
  kind: python_call_eq
  category: identity
  id_prefix: structdict160

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_iter_unpack, "Struct.__dict__.__contains__", ["iter_unpack"], true, "struct.Struct.__dict__.__contains__('iter_unpack') == True ('iter_unpack' is a method_descriptor; returns iterator unpacking buffer one at a time)"]
    - [dict_has_size,        "Struct.__dict__.__contains__", ["size"],        true, "struct.Struct.__dict__.__contains__('size') == True ('size' is a getset_descriptor; returns struct size in bytes; struct_extra155 anchors qualname)"]
    - [dict_has_format,      "Struct.__dict__.__contains__", ["format"],      true, "struct.Struct.__dict__.__contains__('format') == True ('format' is a getset_descriptor; returns the format string; struct_extra155 anchors qualname)"]
    - [dict_len_16,          "Struct.__dict__.__len__",      [], 16,               "struct.Struct.__dict__.__len__() is 16 (5 methods + 2 getsets + 9 dunders/infra; first structdict160 anchor for __len__()==16)"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__ class name and membership confirmation
#
# Wave 346 theme: struct.Struct.__dict__ meta-attributes.
#
# Struct.__dict__.__class__.__name__ == 'mappingproxy' (12 chars).
# Struct.__dict__.__len__() == 16 (confirmed).
# Struct.__dict__.__contains__('pack') == True (confirmed).
# Struct.__dict__.__contains__('iter_unpack') == True (confirmed).
# No prior struct spec anchors Struct.__dict__.__class__.__name__ as a table under
# structdict160. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra160.Struct_dict_meta_and_confirmation:
  description: "struct.Struct.__dict__.__class__.__name__.__eq__('mappingproxy')==True / __dict__.__len__()==16 / __dict__.__contains__('pack')==True / __dict__.__contains__('iter_unpack')==True — __dict__.__class__.__name__ is 'mappingproxy' (12 chars = 'mapping'=7 + 'proxy'=5; C extension type __dict__ is a mappingproxy; same as uuid.UUID.__dict__.__class__.__name__; all class __dict__ objects are mappingproxy to prevent direct mutation); __dict__.__len__() is 16 (confirmed; 5 method_descriptors: pack/unpack/pack_into/unpack_from/iter_unpack + 2 getset_descriptors: size/format + 9 dunders/infra: __delattr__/__doc__/__getattribute__/__init__/__module__/__new__/__repr__/__setattr__/__sizeof__; 5+2+9=16); __dict__.__contains__('pack') is True (confirmed; primary packing method; method_descriptor); __dict__.__contains__('iter_unpack') is True (confirmed; iterator unpacking method; method_descriptor); first structdict160 anchor for __class__.__name__ as a table"
  kind: python_call_eq
  category: identity
  id_prefix: structdict160

  columns: [id, function, args, expected, description]
  rows:
    - [dict_class_proxy,       "Struct.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true, "struct.Struct.__dict__.__class__.__name__ == 'mappingproxy' (12 chars = 'mapping'=7 + 'proxy'=5; all class __dict__ objects are mappingproxy)"]
    - [dict_len_16_b,          "Struct.__dict__.__len__",                   [], 16,            "struct.Struct.__dict__.__len__() is 16 (confirmed; 5 methods + 2 getsets + 9 dunders/infra = 16)"]
    - [dict_has_pack_b,        "Struct.__dict__.__contains__",              ["pack"],          true, "struct.Struct.__dict__.__contains__('pack') == True (confirmed; primary packing method; method_descriptor type)"]
    - [dict_has_iter_unpack_b, "Struct.__dict__.__contains__",              ["iter_unpack"],   true, "struct.Struct.__dict__.__contains__('iter_unpack') == True (confirmed; iterator unpacking method; method_descriptor type)"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('pack') — standalone
#
# struct.Struct.__dict__.__contains__('pack') is True. The 'pack' method is a
# method_descriptor defined on the Struct C type. It packs values according to the
# format string stored in the Struct instance. struct_extra154 anchors Struct.pack qualname
# as a table row ('Struct.pack' = 11 chars). 'pack' is in Struct.__dict__ because it is
# defined directly on the Struct C type (via tp_methods in Modules/_struct.c), not inherited.
# struct.Struct.__dict__.__contains__('pack') == True confirms direct membership, allowing
# access as Struct.__dict__['pack'] without MRO traversal.
# No prior struct spec anchors this as a standalone under structdict160.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra160.Struct_dict_contains_pack:
  description: "struct.Struct.__dict__.__contains__('pack') == True — 'pack' is a method_descriptor in Struct.__dict__; packs Python values into bytes per the format string; struct_extra154 anchors Struct.pack.__qualname__=='Struct.pack' as table row; 'pack' defined directly on Struct C type (tp_methods in Modules/_struct.c); Struct.__dict__.__len__()==16; Struct.__dict__.__class__.__name__=='mappingproxy'; first structdict160 standalone for __contains__('pack')"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('unpack') — standalone
#
# struct.Struct.__dict__.__contains__('unpack') is True. The 'unpack' method is a
# method_descriptor on the Struct C type. It unpacks bytes from a buffer (of exactly
# struct.size bytes) into a tuple of Python values according to the format string.
# 'unpack' is the inverse of 'pack': pack converts Python values to bytes; unpack
# converts bytes back to Python values. struct_extra154 anchors Struct.unpack qualname.
# Struct.__dict__.__contains__('unpack') == True confirms direct membership on the C type.
# No prior struct spec anchors this as a standalone under structdict160.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra160.Struct_dict_contains_unpack:
  description: "struct.Struct.__dict__.__contains__('unpack') == True — 'unpack' is a method_descriptor in Struct.__dict__; unpacks bytes (exactly struct.size bytes) into tuple of Python values; inverse of 'pack'; struct_extra154 anchors Struct.unpack.__qualname__ as table row; 'unpack' defined directly on Struct C type; Struct.__dict__.__len__()==16; first structdict160 standalone for __contains__('unpack')"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__len__() == 16 — standalone
#
# struct.Struct.__dict__.__len__() is 16. The Struct class __dict__ has exactly 16 entries:
# 5 method_descriptor methods: pack, unpack, pack_into, unpack_from, iter_unpack
# 2 getset_descriptor properties: size, format
# 9 dunder/infrastructure entries: __delattr__, __doc__, __getattribute__, __init__,
#   __module__, __new__, __repr__, __setattr__, __sizeof__
# Total: 5 + 2 + 9 = 16.
# No prior struct spec anchors Struct.__dict__.__len__()==16 as a standalone under
# structdict160. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra160.Struct_dict_len_16:
  description: "struct.Struct.__dict__.__len__() == 16 — 16 entries: 5 method_descriptors (pack/unpack/pack_into/unpack_from/iter_unpack) + 2 getset_descriptors (size/format) + 9 dunders/infra (__delattr__/__doc__/__getattribute__/__init__/__module__/__new__/__repr__/__setattr__/__sizeof__); 5+2+9=16; Struct.__dict__.__class__.__name__=='mappingproxy'; contrast with uuid.UUID.__dict__.__len__()==37 (UUID is a pure Python class with many more members); first structdict160 standalone for __len__()==16"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('iter_unpack') — standalone
#
# struct.Struct.__dict__.__contains__('iter_unpack') is True. The 'iter_unpack' method
# is a method_descriptor on the Struct C type. It returns an iterator that unpacks from a
# buffer one occurrence at a time. Unlike 'unpack' which requires a buffer of exactly
# struct.size bytes, iter_unpack accepts a buffer whose size is a multiple of struct.size
# and yields successive tuples. 'iter_unpack' was added in Python 3.4.
# struct.Struct.__dict__.__contains__('iter_unpack') == True confirms direct membership.
# No prior struct spec anchors this as a standalone under structdict160.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra160.Struct_dict_contains_iter_unpack:
  description: "struct.Struct.__dict__.__contains__('iter_unpack') == True — 'iter_unpack' is a method_descriptor in Struct.__dict__; returns iterator that unpacks from buffer one occurrence at a time; buffer size must be multiple of struct.size; yields successive tuples; added in Python 3.4; unlike 'unpack' (requires exactly struct.size bytes), iter_unpack handles multi-occurrence buffers; Struct.__dict__.__len__()==16; first structdict160 standalone for __contains__('iter_unpack')"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["iter_unpack"]
  expected: true
