spec: inspect_extra1591
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — descriptor protocol absence checks via __dict__.__contains__ for inspect.Parameter, inspect.Signature, inspect.BoundArguments, inspect.FrameInfo; and behavioral invariants for inspect.isdatadescriptor, inspect.ismethoddescriptor, inspect.isgetsetdescriptor, inspect.ismemberdescriptor applied to property, classmethod, staticmethod, int.real, and functools descriptors"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Behavioral invariants: inspect introspection classes (Parameter, Signature, BoundArguments, FrameInfo) do not implement the descriptor protocol. inspect.isdatadescriptor returns True for property() and int.real (getset_descriptor), False for classmethod, staticmethod, and functools.cached_property instances. inspect.ismethoddescriptor returns True for classmethod and staticmethod, False for property. inspect.isgetsetdescriptor returns True for int.real but False for property. inspect.ismemberdescriptor returns True for slot descriptors but False for int.real."]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1591.class_no_descriptor:
  description: "inspect.Parameter, inspect.Signature, inspect.BoundArguments, inspect.FrameInfo: none define descriptor protocol methods in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1591cd

  columns: [id, function, args, expected]
  rows:
    - [in1591cd001, inspect.Parameter.__dict__.__contains__,      ["__get__"],      false]
    - [in1591cd002, inspect.Parameter.__dict__.__contains__,      ["__set__"],      false]
    - [in1591cd003, inspect.Parameter.__dict__.__contains__,      ["__delete__"],   false]
    - [in1591cd004, inspect.Parameter.__dict__.__contains__,      ["__set_name__"], false]
    - [in1591cd005, inspect.Signature.__dict__.__contains__,      ["__get__"],      false]
    - [in1591cd006, inspect.Signature.__dict__.__contains__,      ["__set__"],      false]
    - [in1591cd007, inspect.Signature.__dict__.__contains__,      ["__delete__"],   false]
    - [in1591cd008, inspect.Signature.__dict__.__contains__,      ["__set_name__"], false]
    - [in1591cd009, inspect.BoundArguments.__dict__.__contains__,  ["__get__"],     false]
    - [in1591cd010, inspect.BoundArguments.__dict__.__contains__,  ["__set__"],     false]
    - [in1591cd011, inspect.BoundArguments.__dict__.__contains__,  ["__delete__"],  false]
    - [in1591cd012, inspect.BoundArguments.__dict__.__contains__,  ["__set_name__"], false]
    - [in1591cd013, inspect.FrameInfo.__dict__.__contains__,       ["__get__"],     false]
    - [in1591cd014, inspect.FrameInfo.__dict__.__contains__,       ["__set__"],     false]
    - [in1591cd015, inspect.FrameInfo.__dict__.__contains__,       ["__delete__"],  false]
    - [in1591cd016, inspect.FrameInfo.__dict__.__contains__,       ["__set_name__"], false]
    - [in1591cd017, inspect.Parameter.__dict__.__class__.__name__.__eq__,      ["mappingproxy"], true]
    - [in1591cd018, inspect.Signature.__dict__.__class__.__name__.__eq__,      ["mappingproxy"], true]
    - [in1591cd019, inspect.BoundArguments.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [in1591cd020, inspect.Parameter.__class__.__name__.__eq__,      ["type"], true]
    - [in1591cd021, inspect.Signature.__class__.__name__.__eq__,      ["type"], true]
    - [in1591cd022, inspect.BoundArguments.__class__.__name__.__eq__, ["type"], true]
    - [in1591cd023, inspect.Parameter.__module__.__eq__,      ["inspect"], true]
    - [in1591cd024, inspect.Signature.__module__.__eq__,      ["inspect"], true]
    - [in1591cd025, inspect.BoundArguments.__module__.__eq__, ["inspect"], true]

table inspect_extra1591.isdatadescriptor_checks:
  description: "inspect.isdatadescriptor distinguishes data descriptors (property, getset) from non-data descriptors (classmethod, staticmethod, cached_property) and plain callables"
  kind: python_call_eq
  category: descriptor_classification
  id_prefix: in1591dd

  columns: [id, function, args, expected]
  rows:
    - [in1591dd001, inspect.isdatadescriptor, [property()],                        true]
    - [in1591dd002, inspect.isdatadescriptor, [classmethod(lambda: None)],          false]
    - [in1591dd003, inspect.isdatadescriptor, [staticmethod(lambda: None)],         false]
    - [in1591dd004, inspect.isdatadescriptor, [int.real],                           true]
    - [in1591dd005, inspect.ismethoddescriptor, [classmethod(lambda: None)],        true]
    - [in1591dd006, inspect.ismethoddescriptor, [staticmethod(lambda: None)],       true]
    - [in1591dd007, inspect.ismethoddescriptor, [property()],                       false]
    - [in1591dd008, inspect.ismethoddescriptor, [int.real],                         false]
    - [in1591dd009, inspect.isgetsetdescriptor, [property()],                       false]
    - [in1591dd010, inspect.isgetsetdescriptor, [int.real],                         true]
    - [in1591dd011, inspect.ismemberdescriptor,  [int.real],                        false]
    - [in1591dd012, inspect.isdatadescriptor.__class__.__name__.__eq__,  ["function"], true]
    - [in1591dd013, inspect.ismethoddescriptor.__class__.__name__.__eq__, ["function"], true]
    - [in1591dd014, inspect.isgetsetdescriptor.__class__.__name__.__eq__, ["function"], true]
    - [in1591dd015, inspect.ismemberdescriptor.__class__.__name__.__eq__, ["function"], true]
    - [in1591dd016, inspect.isdatadescriptor.__module__.__eq__,  ["inspect"], true]
    - [in1591dd017, inspect.ismethoddescriptor.__module__.__eq__, ["inspect"], true]
    - [in1591dd018, inspect.isgetsetdescriptor.__module__.__eq__, ["inspect"], true]
    - [in1591dd019, inspect.ismemberdescriptor.__module__.__eq__, ["inspect"], true]
    - [in1591dd020, inspect.isdatadescriptor.__qualname__.__eq__,  ["isdatadescriptor"],  true]
    - [in1591dd021, inspect.ismethoddescriptor.__qualname__.__eq__, ["ismethoddescriptor"], true]
    - [in1591dd022, inspect.isgetsetdescriptor.__qualname__.__eq__, ["isgetsetdescriptor"], true]
    - [in1591dd023, inspect.ismemberdescriptor.__qualname__.__eq__, ["ismemberdescriptor"],  true]

table inspect_extra1591.descriptor_type_checks:
  description: "Descriptor classification for functools descriptors and slot member descriptors via inspect predicate functions"
  kind: python_call_eq
  category: descriptor_classification
  id_prefix: in1591dt

  columns: [id, function, args, expected]
  rows:
    - [in1591dt001, inspect.isdatadescriptor,    [functools.cached_property(lambda self: None)], false]
    - [in1591dt002, inspect.ismethoddescriptor,  [functools.cached_property(lambda self: None)], true]
    - [in1591dt003, inspect.isgetsetdescriptor,  [functools.cached_property(lambda self: None)], false]
    - [in1591dt004, inspect.ismemberdescriptor,  [functools.cached_property(lambda self: None)], false]
    - [in1591dt005, inspect.isdatadescriptor,    [functools.partialmethod(lambda self: None)],   false]
    - [in1591dt006, inspect.ismethoddescriptor,  [functools.partialmethod(lambda self: None)],   true]
    - [in1591dt007, inspect.isgetsetdescriptor,  [functools.partialmethod(lambda self: None)],   false]
    - [in1591dt008, inspect.ismemberdescriptor,  [functools.partialmethod(lambda self: None)],   false]
    - [in1591dt009, inspect.isdatadescriptor,    [functools.partial(lambda: None)],              false]
    - [in1591dt010, inspect.ismethoddescriptor,  [functools.partial(lambda: None)],              true]
    - [in1591dt011, inspect.isgetsetdescriptor,  [functools.partial(lambda: None)],              false]
    - [in1591dt012, inspect.ismemberdescriptor,  [functools.partial(lambda: None)],              false]
    - [in1591dt013, inspect.isdatadescriptor.__name__.__eq__,  ["isdatadescriptor"],  true]
    - [in1591dt014, inspect.ismethoddescriptor.__name__.__eq__, ["ismethoddescriptor"], true]
    - [in1591dt015, inspect.isgetsetdescriptor.__name__.__eq__, ["isgetsetdescriptor"], true]
    - [in1591dt016, inspect.ismemberdescriptor.__name__.__eq__, ["ismemberdescriptor"],  true]
    - [in1591dt017, inspect.isgetsetdescriptor, [int.real],    true]
    - [in1591dt018, inspect.isgetsetdescriptor, [float.real],  true]
    - [in1591dt019, inspect.isdatadescriptor,   [float.real],  true]
    - [in1591dt020, inspect.ismemberdescriptor, [float.real],  false]
    - [in1591dt021, inspect.ismemberdescriptor, [complex.real],  true]
    - [in1591dt022, inspect.isdatadescriptor,   [complex.real],  true]
    - [in1591dt023, inspect.isgetsetdescriptor, [complex.real],  false]
    - [in1591dt024, inspect.ismemberdescriptor, [complex.imag],  true]
    - [in1591dt025, inspect.isgetsetdescriptor, [bytes.decode],  false]
