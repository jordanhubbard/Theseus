spec: multiprocessing_extra961
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing exceptions documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing exception class __name__, __module__, and __qualname__ attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra961.process_error_attrs:
  description: "multiprocessing.ProcessError name, module, and qualname identity"
  kind: python_call_eq
  category: exception_attrs
  id_prefix: mp961pe
  columns: [id, function, args, expected]
  rows:
    - [mp961pe001, multiprocessing.ProcessError.__name__.__eq__,     ["ProcessError"],          true]
    - [mp961pe002, multiprocessing.ProcessError.__module__.__eq__,   ["multiprocessing.context"], true]
    - [mp961pe003, multiprocessing.ProcessError.__qualname__.__eq__,  ["ProcessError"],          true]

table multiprocessing_extra961.authentication_and_buffer_error_attrs:
  description: "multiprocessing.AuthenticationError and multiprocessing.BufferTooShort name and module identity"
  kind: python_call_eq
  category: exception_attrs
  id_prefix: mp961ab
  columns: [id, function, args, expected]
  rows:
    - [mp961ab001, multiprocessing.AuthenticationError.__name__.__eq__,    ["AuthenticationError"],      true]
    - [mp961ab002, multiprocessing.AuthenticationError.__module__.__eq__,  ["multiprocessing.context"],  true]
    - [mp961ab003, multiprocessing.AuthenticationError.__qualname__.__eq__, ["AuthenticationError"],      true]
    - [mp961ab004, multiprocessing.BufferTooShort.__name__.__eq__,         ["BufferTooShort"],            true]
    - [mp961ab005, multiprocessing.BufferTooShort.__module__.__eq__,       ["multiprocessing.context"],  true]
    - [mp961ab006, multiprocessing.BufferTooShort.__qualname__.__eq__,      ["BufferTooShort"],            true]

table multiprocessing_extra961.lookup_and_timeout_error_attrs:
  description: "multiprocessing.ProcessLookupError and multiprocessing.TimeoutError name and module identity"
  kind: python_call_eq
  category: exception_attrs
  id_prefix: mp961lt
  columns: [id, function, args, expected]
  rows:
    - [mp961lt001, multiprocessing.ProcessLookupError.__name__.__eq__,    ["ProcessLookupError"],      true]
    - [mp961lt002, multiprocessing.ProcessLookupError.__module__.__eq__,  ["multiprocessing.context"], true]
    - [mp961lt003, multiprocessing.ProcessLookupError.__qualname__.__eq__, ["ProcessLookupError"],      true]
    - [mp961lt004, multiprocessing.TimeoutError.__name__.__eq__,          ["TimeoutError"],             true]
    - [mp961lt005, multiprocessing.TimeoutError.__module__.__eq__,        ["multiprocessing.context"],  true]
    - [mp961lt006, multiprocessing.TimeoutError.__qualname__.__eq__,       ["TimeoutError"],             true]
    - [mp961lt007, multiprocessing.__name__.__eq__,                        ["multiprocessing"],          true]
