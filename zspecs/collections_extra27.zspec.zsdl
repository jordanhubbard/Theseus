spec: collections_extra27
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections_extra26.zspec.zsdl."
    - "collections_extra26 covers: __qualname__.__eq__ for deque.append/appendleft/rotate; OrderedDict.move_to_end; Counter.update/most_common; ChainMap.new_child."
    - "collections_extra25 covers: __qualname__.__len__() for nine core collections classes."
    - "No prior collections spec records __qualname__.__eq__ for deque.pop, popleft, extend, and defaultdict.__missing__ together in the extra27 namespace."
    - "Focus: __qualname__ values for three remaining deque mutation methods and the defaultdict.__missing__ hook."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — deque pop/popleft/extend methods
#
# collections.deque.pop, popleft, and extend are C-level methods on the deque
# type. Their qualnames follow the 'deque.<method>' pattern. collections_extra26
# covers append/appendleft/rotate; this table extends coverage to the remaining
# three mutation methods.
# No prior collections spec records these method qualnames in the extra27 namespace.
# ---------------------------------------------------------------------------

table collections_extra27.deque_pop_extend_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra27.deque_pop_extend_qualnames.pop,
       deque.pop.__qualname__.__eq__,
       ["deque.pop"],
       true,
       "collections.deque.pop.__qualname__ == 'deque.pop'"]
    - [collections_extra27.deque_pop_extend_qualnames.popleft,
       deque.popleft.__qualname__.__eq__,
       ["deque.popleft"],
       true,
       "collections.deque.popleft.__qualname__ == 'deque.popleft'"]
    - [collections_extra27.deque_pop_extend_qualnames.extend,
       deque.extend.__qualname__.__eq__,
       ["deque.extend"],
       true,
       "collections.deque.extend.__qualname__ == 'deque.extend'"]

# ---------------------------------------------------------------------------
# defaultdict.__missing__.__qualname__.__eq__ — standalone method qualname
#
# collections.defaultdict.__missing__ is the hook method called when a key is
# not found. It is defined in the C-level defaultdict type. Its qualname is
# 'defaultdict.__missing__', confirming it belongs to the defaultdict class scope.
# No prior collections spec records this in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra27.defaultdict.missing.qualname:
  description: "collections.defaultdict.__missing__.__qualname__ == 'defaultdict.__missing__'"
  category: qualnames
  kind: python_call_eq
  function: "defaultdict.__missing__.__qualname__.__eq__"
  args: ["defaultdict.__missing__"]
  expected: true

# ---------------------------------------------------------------------------
# deque.pop.__qualname__.__eq__ — standalone method qualname
#
# collections.deque.pop is a C-level method that removes and returns an element
# from the right end of the deque. Its qualname 'deque.pop' confirms its
# scope within the C-level deque type.
# No prior collections spec records this standalone in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra27.deque.pop.qualname:
  description: "collections.deque.pop.__qualname__ == 'deque.pop'"
  category: qualnames
  kind: python_call_eq
  function: deque.pop.__qualname__.__eq__
  args: ["deque.pop"]
  expected: true

# ---------------------------------------------------------------------------
# deque.extend.__qualname__.__eq__ — standalone method qualname
#
# collections.deque.extend is a C-level method that extends the deque by
# appending elements from an iterable. Its qualname 'deque.extend' reflects
# the enclosing C type name.
# No prior collections spec records this standalone in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra27.deque.extend.qualname:
  description: "collections.deque.extend.__qualname__ == 'deque.extend'"
  category: qualnames
  kind: python_call_eq
  function: deque.extend.__qualname__.__eq__
  args: ["deque.extend"]
  expected: true
