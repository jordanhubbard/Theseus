spec: concurrent_futures_extra2086
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2086 (_extra2086): __format__, __bytes__, __fspath__, __buffer__/__release_buffer__ dict-presence checks."
    - "concurrent.futures types (Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor) are concurrency abstractions."
    - "Executor is an abstract base class; ThreadPoolExecutor and ProcessPoolExecutor are concrete executors."
    - "None of these types define __format__, __bytes__, __fspath__, __buffer__, or __release_buffer__ in their own __dict__."
    - "__format__ is the string-formatting protocol; executor types rely on object.__format__ via inheritance."
    - "__bytes__ is the bytes-conversion protocol; futures and executors are not byte-serializable."
    - "__fspath__ is the filesystem-path protocol; executor types are not path-like objects."
    - "__buffer__ and __release_buffer__ are the PEP 688 buffer protocol; futures do not expose raw memory buffers."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra2086.format_protocol:
  description: "concurrent.futures types __format__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2086

  columns: [id, function, args, expected]
  rows:
    - ["cf2086001", "concurrent.futures.Future.__dict__.__contains__", ["__format__"], false]
    - ["cf2086002", "concurrent.futures.Executor.__dict__.__contains__", ["__format__"], false]
    - ["cf2086003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__format__"], false]
    - ["cf2086004", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__format__"], false]

