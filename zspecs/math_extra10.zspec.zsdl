spec: math_extra10
version: ">=3.11"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl and prior extras through math_extra9.zspec.zsdl."
    - "math_extra9 covers: sinh(0)==0.0, cosh(0)==1.0, tanh(0)==0.0; atan2(0,1)==0.0; erfc(0.0)==1.0; gamma(5.0)==24.0; log2(1024)==10.0, log10(100)==2.0; radians(180)==pi, radians(0)==0.0; comb(5,5)==1; fsum([1,2,3,4])==10.0; isclose(1.0,1.0)==True."
    - "math_extra3 covers: erf(0.0)==0.0, gamma(1.0)==1.0, lgamma(1.0)==0.0, expm1(0.0)==0.0, log1p(0.0)==0.0."
    - "math_extra8 covers: hypot(3,4)==5.0."
    - "math_extra9 covers: hypot(0,5)==5.0."
    - "No prior spec covers math.asinh(0) == 0.0 (inverse hyperbolic sine at zero)."
    - "No prior spec covers math.acosh(1) == 0.0 (inverse hyperbolic cosine at one)."
    - "No prior spec covers math.atanh(0) == 0.0 (inverse hyperbolic tangent at zero)."
    - "No prior spec covers math.cbrt(8) == 2.0 (cube root; added in Python 3.11)."
    - "No prior spec covers math.cbrt(27) == 3.0 (cube root; Python 3.11+)."
    - "No prior spec covers math.gamma(2.0) == 1.0 — gamma(2) = 1! = 1."
    - "No prior spec covers math.lgamma(2.0) == 0.0 — lgamma(2) = log(1!) = 0."
    - "No prior spec covers math.log1p(1.0) return-type check (only log1p(0.0)==0.0 was covered)."
    - "No prior spec covers math.expm1(1.0) return-type check (only expm1(0.0)==0.0 was covered)."
    - "No prior spec covers math.isclose(0.0, 0.0) == True (identical zeros are always close)."
    - "No prior spec covers math.isclose(1.0, 2.0) == False (clearly different values are not close)."
    - "No prior spec covers math.fsum([0.1, 0.1, 0.1]) return-type check (floating-point sum of tenths)."
    - "math.cbrt requires Python 3.11+; this spec sets version: '>=3.11'."
    - "math.asinh(0) == 0.0 — sinh is an odd function so asinh(0) == 0."
    - "math.acosh(1) == 0.0 — cosh(0) == 1, so acosh(1) == 0."
    - "math.atanh(0) == 0.0 — tanh is an odd function so atanh(0) == 0."
    - "math.cbrt(8) == 2.0 — cube root of 8 is 2."
    - "math.cbrt(27) == 3.0 — cube root of 27 is 3."
    - "math.gamma(2.0) == 1.0 — gamma(2) = 1! = 1."
    - "math.lgamma(2.0) == 0.0 — lgamma(2) = log(gamma(2)) = log(1) = 0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Inverse hyperbolic functions — identity values at zero / one
#
# No prior math spec covers asinh, acosh, or atanh value vectors.
# These follow directly from the definitions of the inverse hyperbolic functions.
# asinh(0) == 0 because sinh(0) == 0 (odd function).
# acosh(1) == 0 because cosh(0) == 1.
# atanh(0) == 0 because tanh(0) == 0 (odd function).
# ---------------------------------------------------------------------------

invariant math_extra10.asinh.zero:
  description: "math.asinh(0) == 0.0 — inverse hyperbolic sine at zero is zero"
  category: hyperbolic
  kind: python_call_eq
  function: asinh
  args: [0]
  expected: 0.0

invariant math_extra10.acosh.one:
  description: "math.acosh(1) == 0.0 — inverse hyperbolic cosine at one is zero (cosh(0)==1)"
  category: hyperbolic
  kind: python_call_eq
  function: acosh
  args: [1]
  expected: 0.0

invariant math_extra10.atanh.zero:
  description: "math.atanh(0) == 0.0 — inverse hyperbolic tangent at zero is zero"
  category: hyperbolic
  kind: python_call_eq
  function: atanh
  args: [0]
  expected: 0.0

# ---------------------------------------------------------------------------
# math.cbrt — cube root (Python 3.11+)
#
# math.cbrt was added in Python 3.11. No prior math spec covers it at all.
# cbrt(8) == 2.0 and cbrt(27) == 3.0 are exact integer-valued results.
# ---------------------------------------------------------------------------

invariant math_extra10.cbrt.eight:
  description: "math.cbrt(8) == 2.0 — cube root of 8 is exactly 2 (Python 3.11+)"
  category: roots
  kind: python_call_eq
  function: cbrt
  args: [8]
  expected: 2.0

invariant math_extra10.cbrt.twenty_seven:
  description: "math.cbrt(27) == 3.0 — cube root of 27 is exactly 3 (Python 3.11+)"
  category: roots
  kind: python_call_eq
  function: cbrt
  args: [27]
  expected: 3.0

invariant math_extra10.cbrt.zero:
  description: "math.cbrt(0) == 0.0 — cube root of zero is zero (Python 3.11+)"
  category: roots
  kind: python_call_eq
  function: cbrt
  args: [0]
  expected: 0.0

# ---------------------------------------------------------------------------
# math.gamma — additional value vector
#
# math_extra3 covers gamma(1.0)==1.0 and math_extra9 covers gamma(5.0)==24.0.
# No prior spec covers gamma(2.0)==1.0: gamma(2) = 1! = 1.
# ---------------------------------------------------------------------------

invariant math_extra10.gamma.two:
  description: "math.gamma(2.0) == 1.0 — gamma(2) = 1! = 1"
  category: special_functions
  kind: python_call_eq
  function: gamma
  args: [2.0]
  expected: 1.0

# ---------------------------------------------------------------------------
# math.lgamma — additional value vector
#
# math_extra3 covers lgamma(1.0)==0.0. No prior spec covers lgamma(2.0)==0.0.
# lgamma(2) = log(gamma(2)) = log(1) = 0.0.
# ---------------------------------------------------------------------------

invariant math_extra10.lgamma.two:
  description: "math.lgamma(2.0) == 0.0 — lgamma(2) = log(1!) = log(1) = 0"
  category: special_functions
  kind: python_call_eq
  function: lgamma
  args: [2.0]
  expected: 0.0

# ---------------------------------------------------------------------------
# math.isclose — additional value vectors
#
# math_extra9 covers isclose(1.0, 1.0)==True.
# No prior spec covers isclose(0.0, 0.0)==True or isclose(1.0, 2.0)==False.
# ---------------------------------------------------------------------------

invariant math_extra10.isclose.zeros:
  description: "math.isclose(0.0, 0.0) == True — identical zero values are always close"
  category: predicates
  kind: python_call_eq
  function: isclose
  args: [0.0, 0.0]
  expected: true

invariant math_extra10.isclose.one_vs_two:
  description: "math.isclose(1.0, 2.0) == False — clearly distinct values are not close"
  category: predicates
  kind: python_call_eq
  function: isclose
  args: [1.0, 2.0]
  expected: false

# ---------------------------------------------------------------------------
# math.expm1 — non-zero input return type
#
# math_extra3 covers expm1(0.0) == 0.0.
# No prior spec checks the return type for a non-zero input.
# expm1(1.0) == e - 1 (~1.718...), which is a float.
# ---------------------------------------------------------------------------

invariant math_extra10.expm1.one_is_float:
  description: "math.expm1(1.0).__class__.__name__ == 'float' — expm1 always returns a float"
  category: special_functions
  kind: python_call_eq
  function: expm1
  args: [1.0]
  method: __class__.__name__.__eq__
  method_args: ["float"]
  expected: true

# ---------------------------------------------------------------------------
# math.log1p — non-zero input value vector
#
# math_extra3 covers log1p(0.0) == 0.0. No prior spec covers log1p(1.0).
# log1p(1) == log(2) == 0.6931471805599453 (the natural log of 2).
# ---------------------------------------------------------------------------

invariant math_extra10.log1p.one:
  description: "math.log1p(1.0) == math.log(2) == 0.6931471805599453 — log(1+1) == log(2)"
  category: special_functions
  kind: python_call_eq
  function: log1p
  args: [1.0]
  expected: 0.6931471805599453

# ---------------------------------------------------------------------------
# math.fsum — floating-point sum return type
#
# math_extra9 covers fsum([1,2,3,4])==10.0 (integer list).
# No prior spec covers fsum with float inputs.
# fsum([0.1, 0.1, 0.1]).__class__.__name__ == 'float' — always returns float.
# ---------------------------------------------------------------------------

invariant math_extra10.fsum.float_inputs_type:
  description: "math.fsum([0.1, 0.1, 0.1]).__class__.__name__ == 'float' — fsum always returns a float"
  category: arithmetic
  kind: python_call_eq
  function: fsum
  args: [[0.1, 0.1, 0.1]]
  method: __class__.__name__.__eq__
  method_args: ["float"]
  expected: true
