spec: hashlib_extra1531
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "https://docs.python.org/3/library/_hashlib.html — CPython _hashlib C extension type docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha3/sha3module.c"
    - "hashlib_extra1516.zspec.zsdl — covers arithmetic operator absence on _hashlib.HASH via md5()/sha256().__class__.__dict__; pack/unpack method presence."
    - "hashlib_extra991.zspec.zsdl — covers function __qualname__ class names, __module__ attributes, and package identity."
  notes:
    - "This spec is wave 549 / suffix _extra1531. Theme: comparison operator dict-presence checks on _hashlib.HASH."
    - "_hashlib.HASH is the C-extension type returned by hashlib.md5(), hashlib.sha256(), etc. It is a hash state container, not a comparable value."
    - "Verified: md5().__class__.__dict__.__contains__('__lt__') == False — HASH does not define __lt__."
    - "Verified: md5().__class__.__dict__.__contains__('__le__') == False — HASH does not define __le__."
    - "Verified: md5().__class__.__dict__.__contains__('__gt__') == False — HASH does not define __gt__."
    - "Verified: md5().__class__.__dict__.__contains__('__ge__') == False — HASH does not define __ge__."
    - "Verified: md5().__class__.__dict__.__contains__('__eq__') == False — HASH does not define __eq__."
    - "Verified: md5().__class__.__dict__.__contains__('__hash__') == False — HASH does not define __hash__."
    - "Verified: md5().__class__.__dict__.__contains__('__ne__') == False — HASH does not define __ne__."
    - "Verified True (present): update, digest, hexdigest, copy, name, digest_size, block_size."
    - "sha256().__class__ returns the same _hashlib.HASH type — comparison ops equally absent."
    - "hashlib.blake2b is a separate C-extension type; it also defines no comparison operators in its __dict__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _hashlib.HASH (via md5) — comparison operator absence checks
#
# _hashlib.HASH is a cryptographic hash-state object. Hash objects have no
# natural ordering or equality semantics — two different HASH objects cannot
# be meaningfully compared with <, <=, >, >=, ==, or !=. Accordingly none of
# these comparison dunders appear in HASH.__dict__. The True entries (update,
# digest, hexdigest, copy) confirm that the dict-presence mechanism works.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table hashlib_extra1531.hash_cmp_absent_md5:
  description: "Comparison operator dunders absent from _hashlib.HASH.__dict__ (via md5())"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl1531ca

  columns: [id, function, args, expected]
  rows:
    - ["hl1531ca001", "md5().__class__.__dict__.__contains__", ["__lt__"],   false]
    - ["hl1531ca002", "md5().__class__.__dict__.__contains__", ["__le__"],   false]
    - ["hl1531ca003", "md5().__class__.__dict__.__contains__", ["__gt__"],   false]
    - ["hl1531ca004", "md5().__class__.__dict__.__contains__", ["__ge__"],   false]
    - ["hl1531ca005", "md5().__class__.__dict__.__contains__", ["__eq__"],   false]
    - ["hl1531ca006", "md5().__class__.__dict__.__contains__", ["__hash__"], false]
    - ["hl1531ca007", "md5().__class__.__dict__.__contains__", ["__ne__"],   false]
    - ["hl1531ca008", "md5().__class__.__dict__.__contains__", ["update"],   true]
    - ["hl1531ca009", "md5().__class__.__dict__.__contains__", ["digest"],   true]

# ---------------------------------------------------------------------------
# _hashlib.HASH (via sha256) — comparison operator absence checks
#
# sha256() returns the same _hashlib.HASH C-extension type as md5(). The
# absence of comparison dunders is therefore identical. This table provides
# independent confirmation through a different constructor path, and also
# verifies the hexdigest and copy methods are present.
# ---------------------------------------------------------------------------

table hashlib_extra1531.hash_cmp_absent_sha256:
  description: "Comparison operator dunders absent from _hashlib.HASH.__dict__ (via sha256())"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl1531sb

  columns: [id, function, args, expected]
  rows:
    - ["hl1531sb001", "sha256().__class__.__dict__.__contains__", ["__lt__"],    false]
    - ["hl1531sb002", "sha256().__class__.__dict__.__contains__", ["__le__"],    false]
    - ["hl1531sb003", "sha256().__class__.__dict__.__contains__", ["__gt__"],    false]
    - ["hl1531sb004", "sha256().__class__.__dict__.__contains__", ["__ge__"],    false]
    - ["hl1531sb005", "sha256().__class__.__dict__.__contains__", ["__eq__"],    false]
    - ["hl1531sb006", "sha256().__class__.__dict__.__contains__", ["__hash__"],  false]
    - ["hl1531sb007", "sha256().__class__.__dict__.__contains__", ["__ne__"],    false]
    - ["hl1531sb008", "sha256().__class__.__dict__.__contains__", ["hexdigest"], true]
    - ["hl1531sb009", "sha256().__class__.__dict__.__contains__", ["copy"],      true]

# ---------------------------------------------------------------------------
# hashlib.blake2b — comparison operator absence checks
#
# blake2b is a separate C-extension type (not the same as _hashlib.HASH).
# It implements the BLAKE2b hash algorithm and is accessible directly as
# hashlib.blake2b. Like _hashlib.HASH, blake2b objects have no comparison
# semantics and none of the standard comparison dunders appear in its __dict__.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table hashlib_extra1531.blake2b_cmp_absent:
  description: "Comparison operator dunders absent from hashlib.blake2b.__dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl1531bc

  columns: [id, function, args, expected]
  rows:
    - ["hl1531bc001", "blake2b.__dict__.__contains__", ["__lt__"],      false]
    - ["hl1531bc002", "blake2b.__dict__.__contains__", ["__le__"],      false]
    - ["hl1531bc003", "blake2b.__dict__.__contains__", ["__gt__"],      false]
    - ["hl1531bc004", "blake2b.__dict__.__contains__", ["__ge__"],      false]
    - ["hl1531bc005", "blake2b.__dict__.__contains__", ["__eq__"],      false]
    - ["hl1531bc006", "blake2b.__dict__.__contains__", ["__hash__"],    false]
    - ["hl1531bc007", "blake2b.__dict__.__contains__", ["__ne__"],      false]
    - ["hl1531bc008", "blake2b.__dict__.__contains__", ["digest_size"], true]
    - ["hl1531bc009", "blake2b.__dict__.__contains__", ["block_size"],  true]
    - ["hl1531bc010", "blake2b.__dict__.__contains__", ["name"],        true]
