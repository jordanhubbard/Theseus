spec: re_extra149
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.__all__ module-level public API list — its class (__name__=='list'), length (31), and membership tests. Also covers re.__version__, re.__spec__.name, and re.__doc__ class and length."
    - "re.__all__ is a list of 31 strings: the complete public API of the re module, covering functions (match, fullmatch, search, sub, subn, split, findall, finditer, compile, purge, escape), exception (error, PatternError), types (Pattern, Match), flag constants (A, I, L, M, S, X, U, ASCII, IGNORECASE, LOCALE, MULTILINE, DOTALL, VERBOSE, UNICODE, NOFLAG), and the enum class (RegexFlag)."
    - "re.__version__ == '2.2.1' (len=5); it is a str — the legacy version string of the re module."
    - "re.__spec__.name == 're' (len=2); re.__doc__.__class__.__name__ == 'str'; re.__doc__.__len__() == 6152."
    - "re.__all__.__len__() == 31 — the largest __all__ among the four modules in this spec family (io=24, pathlib=7, re=31, decimal has no __all__)."
    - "re.__all__ contains both 'error' and 'PatternError' (both are present; error is the legacy alias)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.__all__ list identity
# re.__all__.__class__.__name__ == 'list'; re.__all__.__len__() == 31.
# ---------------------------------------------------------------------------

table re_extra149.all_list_identity:
  description: "re.__all__ list identity: __class__.__name__=='list', __len__()==31"
  kind: python_call_eq
  category: identity
  id_prefix: reall149

  columns: [id, function, args, expected, description]
  rows:
    - [all_cls_eq,  __all__.__class__.__name__.__eq__, ["list"], true, "re.__all__.__class__.__name__ == 'list' (re.__all__ is a plain Python list, not a tuple or set)"]
    - [all_len_eq,  __all__.__len__,                   [],       31,   "re.__all__.__len__() == 31 (the re module exports 31 public names; the largest __all__ among io, pathlib, re, and decimal in this spec family)"]

# ---------------------------------------------------------------------------
# re.__all__ membership — core functions and types
# Functions: match, fullmatch, search, sub, subn, split, findall, finditer,
#            compile, purge, escape.
# Types: Pattern, Match.
# Exceptions: error, PatternError.
# ---------------------------------------------------------------------------

table re_extra149.all_membership_functions_and_types:
  description: "re.__all__ membership: compile, Pattern, Match, search, findall, finditer, sub, match, error, PatternError all present"
  kind: python_call_eq
  category: identity
  id_prefix: reall149

  columns: [id, function, args, expected, description]
  rows:
    - [has_compile,      __all__.__contains__, ["compile"],     true, "re.__all__ contains 'compile' (compiles a regex pattern into a Pattern object; the central function of the re module)"]
    - [has_pattern,      __all__.__contains__, ["Pattern"],     true, "re.__all__ contains 'Pattern' (the compiled regex type; available directly since Python 3.7; formerly only accessible as type(re.compile('')))"]
    - [has_match_type,   __all__.__contains__, ["Match"],       true, "re.__all__ contains 'Match' (the match result type returned by successful re.match(), re.search(), etc.)"]
    - [has_search,       __all__.__contains__, ["search"],      true, "re.__all__ contains 'search' (scans through a string looking for the first location where the pattern matches)"]
    - [has_match,        __all__.__contains__, ["match"],       true, "re.__all__ contains 'match' (matches pattern only at the beginning of the string)"]
    - [has_fullmatch,    __all__.__contains__, ["fullmatch"],   true, "re.__all__ contains 'fullmatch' (matches pattern against the entire string)"]
    - [has_findall,      __all__.__contains__, ["findall"],     true, "re.__all__ contains 'findall' (returns all non-overlapping matches as a list)"]
    - [has_finditer,     __all__.__contains__, ["finditer"],    true, "re.__all__ contains 'finditer' (returns an iterator of match objects)"]
    - [has_sub,          __all__.__contains__, ["sub"],         true, "re.__all__ contains 'sub' (replaces pattern matches with a replacement string or function)"]
    - [has_subn,         __all__.__contains__, ["subn"],        true, "re.__all__ contains 'subn' (like sub but also returns the number of substitutions made)"]
    - [has_split,        __all__.__contains__, ["split"],       true, "re.__all__ contains 'split' (splits string by the occurrences of the pattern)"]
    - [has_escape,       __all__.__contains__, ["escape"],      true, "re.__all__ contains 'escape' (returns string with all non-alphanumerics escaped)"]
    - [has_purge,        __all__.__contains__, ["purge"],       true, "re.__all__ contains 'purge' (clears the regular expression cache)"]
    - [has_error,        __all__.__contains__, ["error"],       true, "re.__all__ contains 'error' (the legacy alias for PatternError; both are in __all__)"]
    - [has_patternerr,   __all__.__contains__, ["PatternError"],true, "re.__all__ contains 'PatternError' (the canonical exception class; re.error is an alias for it; both appear in __all__)"]

# ---------------------------------------------------------------------------
# re.__all__ membership — flag constants and RegexFlag enum
# Short aliases: A, I, L, M, S, X, U.
# Long names: ASCII, IGNORECASE, LOCALE, MULTILINE, DOTALL, VERBOSE, UNICODE, NOFLAG.
# Enum class: RegexFlag.
# ---------------------------------------------------------------------------

table re_extra149.all_membership_flags:
  description: "re.__all__ membership: flag constants A/I/L/M/S/X/U, ASCII/IGNORECASE/LOCALE/MULTILINE/DOTALL/VERBOSE/UNICODE/NOFLAG, and RegexFlag all present"
  kind: python_call_eq
  category: identity
  id_prefix: reall149

  columns: [id, function, args, expected, description]
  rows:
    - [has_A,           __all__.__contains__, ["A"],           true, "re.__all__ contains 'A' (short alias for re.ASCII; single-character flag aliases are included in __all__)"]
    - [has_I,           __all__.__contains__, ["I"],           true, "re.__all__ contains 'I' (short alias for re.IGNORECASE)"]
    - [has_M,           __all__.__contains__, ["M"],           true, "re.__all__ contains 'M' (short alias for re.MULTILINE)"]
    - [has_S,           __all__.__contains__, ["S"],           true, "re.__all__ contains 'S' (short alias for re.DOTALL)"]
    - [has_ASCII,       __all__.__contains__, ["ASCII"],       true, "re.__all__ contains 'ASCII' (full name for the ASCII flag; value=256)"]
    - [has_IGNORECASE,  __all__.__contains__, ["IGNORECASE"],  true, "re.__all__ contains 'IGNORECASE' (full name for case-insensitive matching flag; value=2)"]
    - [has_MULTILINE,   __all__.__contains__, ["MULTILINE"],   true, "re.__all__ contains 'MULTILINE' (full name for multiline matching flag; value=8)"]
    - [has_DOTALL,      __all__.__contains__, ["DOTALL"],      true, "re.__all__ contains 'DOTALL' (full name for dot-all flag, makes . match newlines; value=16)"]
    - [has_UNICODE,     __all__.__contains__, ["UNICODE"],     true, "re.__all__ contains 'UNICODE' (full name for Unicode matching flag; value=32; default for str patterns)"]
    - [has_VERBOSE,     __all__.__contains__, ["VERBOSE"],     true, "re.__all__ contains 'VERBOSE' (full name for verbose mode flag; value=64)"]
    - [has_NOFLAG,      __all__.__contains__, ["NOFLAG"],      true, "re.__all__ contains 'NOFLAG' (explicitly no flags; value=0; added to allow callers to signal intentional absence of flags)"]
    - [has_RegexFlag,   __all__.__contains__, ["RegexFlag"],   true, "re.__all__ contains 'RegexFlag' (the IntFlag enum class that all flag constants belong to; MRO length=7 as covered in re_extra148)"]

# ---------------------------------------------------------------------------
# re module-level scalar attributes: __version__, __spec__.name, __doc__
# re.__version__ == '2.2.1' (str, len=5); re.__spec__.name == 're' (len=2).
# re.__doc__.__len__() == 6152.
# ---------------------------------------------------------------------------

table re_extra149.module_level_attrs:
  description: "re module-level attrs: __version__=='2.2.1' (str, len=5), __spec__.name=='re' (len=2), __doc__ is str (len=6152)"
  kind: python_call_eq
  category: identity
  id_prefix: reall149

  columns: [id, function, args, expected, description]
  rows:
    - [ver_eq,         __version__.__eq__,                  ["2.2.1"], true, "re.__version__ == '2.2.1' (the legacy version string of the re module; it predates the PEP 396 deprecation of module __version__ attributes)"]
    - [ver_cls_eq,     __version__.__class__.__name__.__eq__,["str"],  true, "re.__version__.__class__.__name__ == 'str' (the version is a plain string, not a version object)"]
    - [ver_len_eq,     __version__.__len__,                 [],        5,    "re.__version__.__len__() == 5 ('2.2.1' has 5 characters: major.minor.patch with dots)"]
    - [spec_name_eq,   __spec__.name.__eq__,                ["re"],    true, "re.__spec__.name == 're' (the module spec name is the bare 're', len=2)"]
    - [spec_name_len,  __spec__.name.__len__,               [],        2,    "re.__spec__.name.__len__() == 2 ('re' has 2 characters; same length as io.__spec__.name from io_extra153)"]
    - [doc_cls_eq,     __doc__.__class__.__name__.__eq__,   ["str"],   true, "re.__doc__.__class__.__name__ == 'str' (the re module has a non-None docstring of type str)"]
    - [doc_len_eq,     __doc__.__len__,                     [],        6152, "re.__doc__.__len__() == 6152 (the re module docstring is 6152 characters long; it is a comprehensive reference covering the special character syntax, flags, and all functions)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra149.all.class_is_list:
  description: "re.__all__.__class__.__name__ == 'list' — re.__all__ is a plain Python list; it is the largest __all__ in this spec family: re has 31 entries vs io's 24 (io_extra153) and pathlib's 7 (pathlib_extra153)"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant re_extra149.all.len_31:
  description: "re.__all__.__len__() == 31 — the re module exports 31 public names: 11 functions (match, fullmatch, search, sub, subn, split, findall, finditer, compile, purge, escape), 2 types (Pattern, Match), 2 exception names (error, PatternError), 7 short flag aliases (A, I, L, M, S, X, U), 8 long flag names (ASCII, IGNORECASE, LOCALE, MULTILINE, DOTALL, VERBOSE, UNICODE, NOFLAG), and 1 enum class (RegexFlag)"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 31

invariant re_extra149.all.contains_compile:
  description: "re.__all__.__contains__('compile') == True — re.compile() is the core function that compiles a regex pattern string into a Pattern object; the returned Pattern object provides match, search, findall, etc. methods that avoid re-parsing the pattern on each call"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["compile"]
  expected: true

invariant re_extra149.all.contains_Pattern:
  description: "re.__all__.__contains__('Pattern') == True — re.Pattern is the compiled regex type; it was added to re.__all__ in Python 3.7 when it became directly accessible; previously only accessible as type(re.compile('')); its identity is covered in detail in re_extra147"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Pattern"]
  expected: true

invariant re_extra149.all.contains_Match:
  description: "re.__all__.__contains__('Match') == True — re.Match is the match result type; it was added to re.__all__ alongside Pattern in Python 3.7; match objects always have boolean value True (covered in re.Match.__doc__ from re_extra147)"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Match"]
  expected: true

invariant re_extra149.version_eq_2_2_1:
  description: "re.__version__ == '2.2.1' (len=5) — this legacy version string dates from the original 're' module implementation; it is a str, not a packaging.version.Version or similar object; the value '2.2.1' reflects the internal versioning of the SRE (Secret Labs' Regular Expression Engine) codebase"
  category: identity
  kind: python_call_eq
  function: __version__.__eq__
  args: ["2.2.1"]
  expected: true

invariant re_extra149.spec_name_eq_re:
  description: "re.__spec__.name == 're' (len=2) — the re module spec name is the bare 're'; the re module is implemented partly in Python (Lib/re/__init__.py) and partly as a C extension (_sre); the public module name is simply 're'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["re"]
  expected: true

invariant re_extra149.doc.len_6152:
  description: "re.__doc__.__len__() == 6152 — the re module-level docstring is 6152 characters long; it is the longest module docstring in this spec family (re=6152 vs io=1473 from io_extra153 and pathlib=192 from pathlib_extra153); it includes the complete reference for special characters, flags, and all re functions"
  category: identity
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 6152

