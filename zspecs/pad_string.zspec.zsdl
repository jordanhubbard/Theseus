spec: pad_string
version: ">=0.2.1"
backend: node(pad-string)

docs: https://www.npmjs.com/package/pad-string

provenance:
  derived_from:
    - "pad-string README — https://www.npmjs.com/package/pad-string"
    - "Test vectors verified with pad-string via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "pad-string source"
  notes:
    - "pad-string is an npm package. Install: npm install pad-string"
    - "Exports padStart, padEnd, and padBothEnds functions."
    - "Default pad character is a space."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table pad_string.pad_start:
  kind: node_module_call_eq
  function: padStart
  category: strings
  id_prefix: padst

  columns: [id, args, expected]
  rows:
    - [pad_spaces, ["hi", 5], "   hi"]
    - [already,    ["hello", 3], "hello"]

table pad_string.pad_end:
  kind: node_module_call_eq
  function: padEnd
  category: strings
  id_prefix: padend

  columns: [id, args, expected]
  rows:
    - [pad_spaces, ["hi", 5], "hi   "]
    - [already,    ["hello", 3], "hello"]

table pad_string.pad_both_ends:
  kind: node_module_call_eq
  function: padBothEnds
  category: strings
  id_prefix: padboth

  columns: [id, args, expected]
  rows:
    - [pad_even, ["hi", 6], "  hi  "]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:23:30Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
