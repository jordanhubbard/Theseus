spec: io2866
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/io_extra2851.zspec.zsdl — wave 637 predecessor (covered __rlshift__, __rrshift__, __rpow__)"
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "Wave 638 theme: __rand__, __ror__, __rxor__ dict-presence checks (reflected bitwise AND, OR, XOR operators)."
    - "io classes are I/O stream objects, not numeric types — none define reflected bitwise AND, OR, or XOR operators."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, and io.TextIOBase do NOT define __rand__, __ror__, or __rxor__."
    - "io.BytesIO, io.StringIO, io.FileIO do NOT define any of these reflected operators."
    - "io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper, io.IncrementalNewlineDecoder also absent for all three."
    - "Absence is consistent across all 12 io classes tested — io streams have no arithmetic or bitwise semantics."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __rand__ dict-presence — absent from all io ABC and concrete classes
# ---------------------------------------------------------------------------

table io2866.rand:
  description: "__rand__ is absent from all io class __dict__s — io streams are not bitwise-AND operands"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2866

  columns: [id, function, args, expected]
  rows:
    - ["io2866001", "io.IOBase.__dict__.__contains__",              ["__rand__"], false]
    - ["io2866002", "io.RawIOBase.__dict__.__contains__",           ["__rand__"], false]
    - ["io2866003", "io.BufferedIOBase.__dict__.__contains__",      ["__rand__"], false]
    - ["io2866004", "io.TextIOBase.__dict__.__contains__",          ["__rand__"], false]
    - ["io2866005", "io.BytesIO.__dict__.__contains__",             ["__rand__"], false]
    - ["io2866006", "io.StringIO.__dict__.__contains__",            ["__rand__"], false]
    - ["io2866007", "io.FileIO.__dict__.__contains__",              ["__rand__"], false]
    - ["io2866008", "io.BufferedReader.__dict__.__contains__",      ["__rand__"], false]
    - ["io2866009", "io.BufferedWriter.__dict__.__contains__",      ["__rand__"], false]
    - ["io2866010", "io.BufferedRandom.__dict__.__contains__",      ["__rand__"], false]
    - ["io2866011", "io.TextIOWrapper.__dict__.__contains__",       ["__rand__"], false]
    - ["io2866012", "io.IncrementalNewlineDecoder.__dict__.__contains__", ["__rand__"], false]

