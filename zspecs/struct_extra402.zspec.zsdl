spec: struct_extra402
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "struct.Struct.iter_unpack.__name__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__name__ == 'pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__name__ == 'unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('Q') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('H') == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('B') == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('f') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('l') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.iter_unpack, pack_into, and unpack_from are wrapper_descriptor objects — C slot wrappers that expose C methods of the Struct type as Python callables. Their __name__ attribute is the bare method name without class qualification. struct.calcsize returns the size in bytes of the packed struct for a given format string; on 64-bit macOS the native 'l' (signed long) is 8 bytes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct instance method __name__ attributes
#
# Wave 402 theme: struct.Struct method identity and calcsize format sizes.
#
# struct.Struct is a C extension type in _struct. Its instance methods
# (iter_unpack, pack_into, unpack_from) are wrapper_descriptor objects that
# wrap C-level method slots. Accessed on the class, they carry a __name__
# equal to the bare method name (no class qualification).
#
# iter_unpack — returns an iterator of tuples, one per struct-sized chunk
# pack_into   — packs into a writable buffer at a given offset
# unpack_from — unpacks from a buffer at a given offset
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra402.method_names:
  description: "struct.Struct iter_unpack, pack_into, unpack_from __name__ attributes — C extension type wrapper_descriptor methods; __name__ is the bare method name without class prefix; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: structmn402

  columns: [id, function, args, expected]
  rows:
    - [iter_unpack_name,  Struct.iter_unpack.__name__.__eq__,  ["iter_unpack"],  true]
    - [pack_into_name,    Struct.pack_into.__name__.__eq__,    ["pack_into"],    true]
    - [unpack_from_name,  Struct.unpack_from.__name__.__eq__,  ["unpack_from"],  true]

# ---------------------------------------------------------------------------
# struct.calcsize for standard format characters
#
# struct.calcsize(fmt) returns the size in bytes of the struct packed by fmt.
# Using native byte order (no prefix), sizes reflect the platform ABI.
# On 64-bit macOS/Darwin:
#   'Q' (unsigned long long) = 8 bytes
#   'H' (unsigned short)     = 2 bytes
#   'B' (unsigned char)      = 1 byte
#   'f' (float)              = 4 bytes
#   'l' (signed long)        = 8 bytes  (64-bit on LP64 platforms)
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra402.calcsize_Q:
  description: "struct.calcsize('Q') == 8 — unsigned long long is 8 bytes on 64-bit macOS/Darwin LP64 ABI; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["Q"]
  expected: 8

invariant struct_extra402.calcsize_H:
  description: "struct.calcsize('H') == 2 — unsigned short is 2 bytes; standard across all common platforms; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["H"]
  expected: 2

invariant struct_extra402.calcsize_B:
  description: "struct.calcsize('B') == 1 — unsigned char is 1 byte; smallest addressable unit; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["B"]
  expected: 1

invariant struct_extra402.calcsize_f:
  description: "struct.calcsize('f') == 4 — IEEE 754 single-precision float is 4 bytes; standard across all common platforms; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["f"]
  expected: 4

invariant struct_extra402.calcsize_l:
  description: "struct.calcsize('l') == 8 — signed long is 8 bytes on 64-bit macOS/Darwin LP64 ABI; differs from Windows LLP64 where long is 4 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["l"]
  expected: 8
