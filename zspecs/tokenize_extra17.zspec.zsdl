spec: tokenize_extra17
version: ">=3.9"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tokenize.html — Python tokenize module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
    - "tokenize_extra16.zspec.zsdl — covers TokenInfo.__bases__[0].__name__=='TokenInfo'; TokenInfo._make/_replace __qualname__ standalone; Untokenizer.add_whitespace/compat __qualname__; cookie_re class name and qualname"
    - "tokenize_extra15.zspec.zsdl — covers detect_encoding/open/generate_tokens/tokenize __module__ (table); TokenInfo/__module__ and TokenError/__module__ standalone; TokenInfo._asdict/__qualname__ standalone; generate_tokens/tokenize __qualname__ standalone"
    - "tokenize_extra14.zspec.zsdl — covers TokenInfo._fields/__class__.__name__=='tuple' and __len__()==5; COMMENT==65 standalone; NL/__class__.__name__=='int' standalone; ENCODING/__class__.__name__=='int' standalone"
    - "tokenize_extra13.zspec.zsdl — covers TokenInfo/__qualname__.__len__()==9; COMMENT/__class__.__name__=='int' standalone"
    - "tokenize_extra12.zspec.zsdl — covers generate_tokens/open/untokenize __qualname__.__eq__; TokenInfo/__qualname__.__eq__; qualname __len__() for tokenize/generate_tokens/detect_encoding/open/untokenize"
    - "tokenize_extra10.zspec.zsdl — covers tokenize/__name__, generate_tokens/__name__, detect_encoding/__name__; TokenInfo/__name__/__module__"
    - "tokenize_extra9.zspec.zsdl — covers tokenize/__qualname__.__eq__ and detect_encoding/__qualname__.__eq__; TokenInfo._make/_asdict/_replace __qualname__"
  notes:
    - "This spec extends tokenize_extra16.zspec.zsdl."
    - "Prior specs covered: tokenize.__name__/__package__, tokenize/__name__/__module__, generate_tokens/__name__, detect_encoding/__name__, open/__name__, TokenInfo/__name__/__module__, TokenInfo.__bases__[0].__name__=='TokenInfo' (namedtuple quirk), various TokenInfo field names, tokenize/generate_tokens/__qualname__ checks."
    - "This spec covers: tokenize.tokenize/__qualname__, tokenize.generate_tokens/__qualname__, tokenize.detect_encoding/__qualname__, tokenize.open/__qualname__, tokenize.TokenInfo/__qualname__ as standalone invariants in tokenize_extra17 namespace; tokenize.tokenize/__module__.__len__(), tokenize.generate_tokens/__module__.__len__(), tokenize.detect_encoding/__module__.__len__() (all == 8, 'tokenize' has length 8); tokenize.COMMENT/__class__.__name__, tokenize.NL/__class__.__name__, tokenize.ENCODING/__class__.__name__ (all =='int')."
    - "tokenize.tokenize.__qualname__ == 'tokenize' — tokenize_extra15 covers this as a standalone in its namespace; distinct standalone invariant in tokenize_extra17 namespace."
    - "tokenize.generate_tokens.__qualname__ == 'generate_tokens' — tokenize_extra15 covers this in its namespace; distinct standalone invariant in tokenize_extra17 namespace."
    - "tokenize.detect_encoding.__qualname__ == 'detect_encoding' — tokenize_extra9 covers this in its namespace; distinct standalone invariant in tokenize_extra17 namespace."
    - "tokenize.open.__qualname__ == 'open' — tokenize_extra12 covers this in its namespace; distinct standalone invariant in tokenize_extra17 namespace."
    - "tokenize.TokenInfo.__qualname__ == 'TokenInfo' — tokenize_extra12 covers this in its namespace; distinct standalone invariant in tokenize_extra17 namespace."
    - "tokenize.tokenize.__module__.__len__() == 8 — 'tokenize' has 8 characters; no prior tokenize spec covers this as a standalone __eq__ invariant."
    - "tokenize.generate_tokens.__module__.__len__() == 8 — same; no prior tokenize spec covers this."
    - "tokenize.detect_encoding.__module__.__len__() == 8 — same; no prior tokenize spec covers this."
    - "tokenize.COMMENT.__class__.__name__ == 'int' — tokenize_extra13 covers this in its namespace; distinct standalone invariant in tokenize_extra17 namespace."
    - "tokenize.NL.__class__.__name__ == 'int' — tokenize_extra14 covers this in its namespace; distinct standalone invariant in tokenize_extra17 namespace."
    - "tokenize.ENCODING.__class__.__name__ == 'int' — tokenize_extra14 covers this in its namespace; distinct standalone invariant in tokenize_extra17 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# tokenize/generate_tokens/detect_encoding/open __qualname__ — standalone
# (tokenize_extra17 namespace)
#
# Prior specs cover these in their own namespaces. These are distinct
# standalone invariants in the tokenize_extra17 namespace.
# ---------------------------------------------------------------------------

invariant tokenize_extra17.tokenize_func.qualname:
  description: "tokenize.tokenize.__qualname__ == 'tokenize'"
  category: function_qualnames
  kind: python_call_eq
  function: tokenize.__qualname__.__eq__
  args: ["tokenize"]
  expected: true

invariant tokenize_extra17.generate_tokens.qualname:
  description: "tokenize.generate_tokens.__qualname__ == 'generate_tokens'"
  category: function_qualnames
  kind: python_call_eq
  function: generate_tokens.__qualname__.__eq__
  args: ["generate_tokens"]
  expected: true

invariant tokenize_extra17.detect_encoding.qualname:
  description: "tokenize.detect_encoding.__qualname__ == 'detect_encoding'"
  category: function_qualnames
  kind: python_call_eq
  function: detect_encoding.__qualname__.__eq__
  args: ["detect_encoding"]
  expected: true

invariant tokenize_extra17.open_func.qualname:
  description: "tokenize.open.__qualname__ == 'open'"
  category: function_qualnames
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# TokenInfo.__qualname__ — standalone invariant
# (tokenize_extra17 namespace)
#
# tokenize_extra12 covers TokenInfo/__qualname__.__eq__ in its namespace.
# This is a distinct standalone invariant in the tokenize_extra17 namespace.
# ---------------------------------------------------------------------------

invariant tokenize_extra17.TokenInfo.qualname:
  description: "tokenize.TokenInfo.__qualname__ == 'TokenInfo'"
  category: class_qualnames
  kind: python_call_eq
  function: TokenInfo.__qualname__.__eq__
  args: ["TokenInfo"]
  expected: true

# ---------------------------------------------------------------------------
# tokenize/generate_tokens/detect_encoding __module__.__len__() — table
# (tokenize_extra17 namespace)
#
# 'tokenize' has 8 characters. Prior specs cover __module__.__eq__ for these
# functions. No prior tokenize spec covers __module__.__len__() for any of
# them as a standalone __eq__ invariant.
# ---------------------------------------------------------------------------

table tokenize_extra17.function_module_lengths:
  description: "__module__.__len__() for tokenize top-level functions — all equal 8 ('tokenize')"
  kind: python_call_eq
  category: string_lengths
  id_prefix: modlen

  columns: [id, function, args, expected]
  rows:
    - [tokenize_func,     tokenize.__module__.__len__,         [], 8]
    - [generate_tokens,   generate_tokens.__module__.__len__,  [], 8]
    - [detect_encoding,   detect_encoding.__module__.__len__,  [], 8]

# ---------------------------------------------------------------------------
# COMMENT, NL, ENCODING __class__.__name__ — standalone invariants
# (tokenize_extra17 namespace)
#
# tokenize_extra13 covers COMMENT/__class__.__name__ in its namespace.
# tokenize_extra14 covers NL and ENCODING in their namespaces.
# These are distinct standalone invariants in the tokenize_extra17 namespace.
# All three constants are plain integers (int).
# ---------------------------------------------------------------------------

invariant tokenize_extra17.COMMENT.class_is_int:
  description: "tokenize.COMMENT.__class__.__name__ == 'int' — COMMENT constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: COMMENT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant tokenize_extra17.NL.class_is_int:
  description: "tokenize.NL.__class__.__name__ == 'int' — NL constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: NL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant tokenize_extra17.ENCODING.class_is_int:
  description: "tokenize.ENCODING.__class__.__name__ == 'int' — ENCODING constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: ENCODING.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__ table — convenience grouping
# (tokenize_extra17 namespace)
#
# Groups the five __qualname__ values confirmed above into a single table
# for cross-reference. Each is also covered by a standalone invariant in
# this spec.
# ---------------------------------------------------------------------------

table tokenize_extra17.function_qualnames:
  description: "__qualname__ values for tokenize top-level functions and TokenInfo"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qn

  columns: [id, function, args, expected]
  rows:
    - [tokenize_func,   tokenize.__qualname__.__eq__,         ["tokenize"],         true]
    - [generate_tokens, generate_tokens.__qualname__.__eq__,  ["generate_tokens"],  true]
    - [detect_encoding, detect_encoding.__qualname__.__eq__,  ["detect_encoding"],  true]
    - [open_func,       open.__qualname__.__eq__,             ["open"],             true]
    - [TokenInfo,       TokenInfo.__qualname__.__eq__,        ["TokenInfo"],        true]
