spec: re_extra43
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra42.zspec.zsdl — covers Pattern/__name__=='Pattern'/__module__=='re'; Match/__name__=='Match'/__module__=='re'; error/__name__=='PatternError'/__module__=='re'; error.__bases__[0].__name__=='Exception'; fullmatch/__name__=='fullmatch'; sub/__name__=='sub'."
    - "re_extra41.zspec.zsdl — covers VERBOSE/__class__/__name__/__qualname__/__module__; DOTALL/VERBOSE ._value_; MULTILINE ._value_."
    - "re_extra40.zspec.zsdl — covers re.__name__/__package__/__file__ type lengths; subn/findall/search behavioral."
    - "re_extra39.zspec.zsdl — covers compile(IGNORECASE|MULTILINE).flags==42; error.__static_attributes__; match three-group .groups().__len__()==3."
    - "re_extra38.zspec.zsdl — covers compile flags/split/findall/escape behavioral."
    - "re_extra37.zspec.zsdl — covers Pattern/Match member_descriptor attribute __qualname__.__len__()."
    - "re_extra34.zspec.zsdl — covers module-level function __qualname__.__len__() for compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape/purge."
    - "re_extra33.zspec.zsdl — covers re.__all__.__len__()==31; IGNORECASE int value."
    - "re_extra27.zspec.zsdl — covers IGNORECASE/MULTILINE/RegexFlag __class__.__qualname__/__module__/__eq__."
  notes:
    - "This spec extends re_extra42.zspec.zsdl."
    - "Prior specs collectively covered: all Pattern/Match/error/__name__/__module__/__qualname__ equality and lengths; all public function __qualname__.__len__(); RegexFlag attributes; flag int values; Pattern/Match method qualname lengths; behavioral tests for compile/search/findall/sub/subn/split/escape."
    - "This spec covers: re.search.__name__ == 'search' (NOVEL — re_extra34 covers search.__qualname__.__len__() and re_extra42 covers fullmatch and sub __name__ but not search.__name__.__eq__ as standalone; novel equality in re_extra43 namespace); re.search.__module__ == 're' (NOVEL — no prior re spec checks search.__module__.__eq__ as standalone invariant); re.findall.__name__ == 'findall' (NOVEL equality anchor — re_extra34 covers findall.__qualname__.__len__() but not __name__.__eq__); re.findall.__module__ == 're' (NOVEL); re.finditer.__name__ == 'finditer' (NOVEL — re_extra34 covers finditer qualname length but not __name__.__eq__); re.split.__name__ == 'split' (NOVEL); re.purge.__name__ == 'purge' (NOVEL); re.escape.__name__ == 'escape' (NOVEL); re.IGNORECASE.__class__.__module__ == 're' (NOVEL — re_extra27 covers IGNORECASE.__class__.__qualname__.__eq__('RegexFlag') and re_extra41 covers DOTALL/VERBOSE.__class__.__module__.__eq__('re') but not IGNORECASE.__class__.__module__.__eq__ as a standalone invariant in re_extra43 namespace)."
    - "re.search.__name__ == 'search'. The module-level search function's __name__. re_extra34 covers search.__qualname__.__len__(); re_extra42 covers fullmatch/sub __name__ but not search. Novel standalone equality in re_extra43. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.search.__module__ == 're'. The search function is defined in the re module. No prior re spec checks search.__module__.__eq__ as standalone. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.findall.__name__ == 'findall'. The module-level findall function's __name__. re_extra34 covers qualname length but not __name__.__eq__. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.findall.__module__ == 're'. findall is defined in the re module. Novel standalone equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.finditer.__name__ == 'finditer'. The module-level finditer function's __name__. re_extra34 covers qualname length but not __name__.__eq__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.split.__name__ == 'split'. The module-level split function's __name__. Novel equality anchor in re_extra43. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.purge.__name__ == 'purge'. The module-level purge function (clears the compiled regex cache) __name__. Novel equality anchor in re_extra43. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.escape.__name__ == 'escape'. The module-level escape function's __name__. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.IGNORECASE.__class__.__module__ == 're'. IGNORECASE is an instance of RegexFlag, which is defined in the re module. re_extra27 covers IGNORECASE.__class__.__qualname__=='RegexFlag'; re_extra41 covers DOTALL/VERBOSE.__class__.__module__=='re'; no prior spec checks IGNORECASE.__class__.__module__.__eq__ as standalone invariant in this namespace. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module-level function __name__ attributes: search, findall, finditer,
# split, purge, escape
#
# Module-level functions in re have __name__ equal to their bare function name.
# re_extra34 covers __qualname__.__len__() for all these functions; re_extra42
# covers fullmatch and sub __name__.__eq__. No prior spec checks __name__.__eq__
# for search, findall, finditer, split, purge, or escape as standalone invariants.
#
# All verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra43.function_names:
  description: "re module-level function __name__ attributes: search/findall/finditer/split/purge/escape — all novel equality anchors in re_extra43 namespace; re_extra34 covers qualname lengths, re_extra42 covers fullmatch/sub __name__; these six are unanchored in prior specs"
  kind: python_call_eq
  category: function_identity
  id_prefix: rfn43

  columns: [id, function, args, expected]
  rows:
    - [search_name,  search.__name__.__eq__,  ["search"],  true]
    - [findall_name, findall.__name__.__eq__,  ["findall"], true]
    - [finditer_name,finditer.__name__.__eq__, ["finditer"],true]
    - [split_name,   split.__name__.__eq__,   ["split"],   true]
    - [purge_name,   purge.__name__.__eq__,   ["purge"],   true]
    - [escape_name,  escape.__name__.__eq__,  ["escape"],  true]

# ---------------------------------------------------------------------------
# re module-level function __module__ attributes: search and findall
#
# The __module__ attribute confirms that search and findall are defined in
# the 're' module. No prior re spec checks search.__module__ or
# findall.__module__ as standalone invariants.
#
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra43.function_modules:
  description: "re module-level function __module__ attributes: search.__module__=='re' / findall.__module__=='re' — no prior re spec checks these __module__ equalities as standalone invariants; novel equality anchors in re_extra43 namespace"
  kind: python_call_eq
  category: function_identity
  id_prefix: rfm43

  columns: [id, function, args, expected]
  rows:
    - [search_module,  search.__module__.__eq__,  ["re"], true]
    - [findall_module, findall.__module__.__eq__, ["re"],  true]

# ---------------------------------------------------------------------------
# re.IGNORECASE.__class__.__module__ == 're'
#
# IGNORECASE is an instance of the RegexFlag enum. RegexFlag is defined in
# the re module, so IGNORECASE.__class__.__module__ == 're'.
#
# re_extra27 covers IGNORECASE.__class__.__qualname__.__eq__('RegexFlag') and
# IGNORECASE.__class__.__module__.__eq__('re') in a chain, but through
# RegexFlag.__module__.__eq__('re') — not directly IGNORECASE.__class__.__module__.
# re_extra41 covers DOTALL/VERBOSE.__class__.__module__.__eq__('re') as a table
# but in re_extra41 namespace. This is a novel standalone invariant anchoring
# IGNORECASE.__class__.__module__ in re_extra43 namespace.
#
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra43.IGNORECASE_class_module_eq:
  description: "re.IGNORECASE.__class__.__module__ == 're' — IGNORECASE is a RegexFlag enum member; RegexFlag is defined in the re module; re_extra27 covers IGNORECASE.__class__.__qualname__ and RegexFlag.__module__ but not IGNORECASE.__class__.__module__ as a standalone invariant in re_extra43 namespace; novel; verified Python 3.14 macOS/Darwin 25.4.0"
  category: flag_identity
  kind: python_call_eq
  function: "IGNORECASE.__class__.__module__.__eq__"
  args: ["re"]
  expected: true
