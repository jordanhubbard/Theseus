spec: collections_abc_extra4
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — Python collections.abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "This spec extends collections_abc.zspec.zsdl, collections_abc_extra.zspec.zsdl, collections_abc_extra2.zspec.zsdl, and collections_abc_extra3.zspec.zsdl."
    - "Prior specs cover: __name__, __module__, __qualname__ for all major ABCs (Sequence, Mapping, MutableSequence, MutableMapping, Set, MutableSet, Iterable, Iterator, Generator, Awaitable, Coroutine, Callable, Hashable, Sized, Container, Collection, Reversible, AsyncIterable, AsyncIterator, AsyncGenerator)."
    - "Prior specs cover: hierarchy checks for Iterator->Iterable, Generator->Iterator, MutableSequence->Sequence, MutableMapping->Mapping, Coroutine->Awaitable, AsyncIterator->AsyncIterable, AsyncGenerator->AsyncIterator, MutableSet->Set."
    - "No prior spec checks __abstractmethods__ for any ABC."
    - "No prior spec checks __qualname__ for MappingView, KeysView, ItemsView, ValuesView."
    - "No prior spec checks KeysView.__bases__[0].__name__ == 'MappingView' or ItemsView.__bases__[0].__name__ == 'MappingView' or ValuesView.__bases__[0].__name__ == 'MappingView'."
    - "No prior spec checks MappingView.__bases__[0].__name__ == 'Sized' — MappingView directly inherits from Sized."
    - "collections.abc.Mapping.__abstractmethods__ == frozenset({'__getitem__', '__iter__', '__len__'})."
    - "collections.abc.Sized.__abstractmethods__ == frozenset({'__len__'})."
    - "collections.abc.Iterable.__abstractmethods__ == frozenset({'__iter__'})."
    - "collections.abc.Container.__abstractmethods__ == frozenset({'__contains__'})."
    - "collections.abc.Hashable.__abstractmethods__ == frozenset({'__hash__'})."
    - "All MappingView subclasses (KeysView, ItemsView, ValuesView) have MappingView as their first base."
    - "MappingView itself has Sized as its first base."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __abstractmethods__ membership — ABCs must declare specific abstract methods
#
# No prior collections.abc spec checks __abstractmethods__ on any ABC.
# Each ABC's __abstractmethods__ is a frozenset naming the methods that must
# be implemented by concrete subclasses.
# ---------------------------------------------------------------------------

invariant collections_abc_extra4.Mapping.abstractmethods_contains_getitem:
  description: "collections.abc.Mapping.__abstractmethods__.__contains__('__getitem__') == True"
  category: abstractmethods
  kind: python_call_eq
  function: Mapping.__abstractmethods__.__contains__
  args: ["__getitem__"]
  expected: true

invariant collections_abc_extra4.Mapping.abstractmethods_contains_iter:
  description: "collections.abc.Mapping.__abstractmethods__.__contains__('__iter__') == True"
  category: abstractmethods
  kind: python_call_eq
  function: Mapping.__abstractmethods__.__contains__
  args: ["__iter__"]
  expected: true

invariant collections_abc_extra4.Mapping.abstractmethods_contains_len:
  description: "collections.abc.Mapping.__abstractmethods__.__contains__('__len__') == True"
  category: abstractmethods
  kind: python_call_eq
  function: Mapping.__abstractmethods__.__contains__
  args: ["__len__"]
  expected: true

invariant collections_abc_extra4.Sized.abstractmethods_contains_len:
  description: "collections.abc.Sized.__abstractmethods__.__contains__('__len__') == True — Sized requires __len__"
  category: abstractmethods
  kind: python_call_eq
  function: Sized.__abstractmethods__.__contains__
  args: ["__len__"]
  expected: true

invariant collections_abc_extra4.Iterable.abstractmethods_contains_iter:
  description: "collections.abc.Iterable.__abstractmethods__.__contains__('__iter__') == True — Iterable requires __iter__"
  category: abstractmethods
  kind: python_call_eq
  function: Iterable.__abstractmethods__.__contains__
  args: ["__iter__"]
  expected: true

invariant collections_abc_extra4.Container.abstractmethods_contains_contains:
  description: "collections.abc.Container.__abstractmethods__.__contains__('__contains__') == True"
  category: abstractmethods
  kind: python_call_eq
  function: Container.__abstractmethods__.__contains__
  args: ["__contains__"]
  expected: true

invariant collections_abc_extra4.Hashable.abstractmethods_contains_hash:
  description: "collections.abc.Hashable.__abstractmethods__.__contains__('__hash__') == True — Hashable requires __hash__"
  category: abstractmethods
  kind: python_call_eq
  function: Hashable.__abstractmethods__.__contains__
  args: ["__hash__"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ checks for MappingView, KeysView, ItemsView, ValuesView
#
# collections_abc_extra3 covers __qualname__ for Sequence/MutableSequence/
# Mapping/MutableMapping/Set/MutableSet/Iterable/Iterator/Generator/
# Awaitable/Coroutine/Callable/Hashable/Sized.
# No prior spec covers __qualname__ for MappingView, KeysView, ItemsView,
# or ValuesView. For module-level classes, __qualname__ == __name__.
# ---------------------------------------------------------------------------

table collections_abc_extra4.view_qualnames:
  kind: python_call_eq
  category: qualname
  id_prefix: qn

  columns: [id, function, args, expected]
  rows:
    - [MappingView, MappingView.__qualname__.__eq__, ["MappingView"], true]
    - [KeysView,    KeysView.__qualname__.__eq__,    ["KeysView"],    true]
    - [ItemsView,   ItemsView.__qualname__.__eq__,   ["ItemsView"],   true]
    - [ValuesView,  ValuesView.__qualname__.__eq__,  ["ValuesView"],  true]

# ---------------------------------------------------------------------------
# MappingView, KeysView, ItemsView, ValuesView — class hierarchy
#
# No prior spec checks the inheritance hierarchy for these four view classes.
# KeysView, ItemsView, and ValuesView all directly inherit from MappingView.
# MappingView directly inherits from Sized.
# ---------------------------------------------------------------------------

invariant collections_abc_extra4.MappingView.base_is_Sized:
  description: "collections.abc.MappingView.__bases__[0].__name__ == 'Sized' — MappingView directly inherits from Sized"
  category: class_hierarchy
  kind: python_call_eq
  function: MappingView.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Sized"

invariant collections_abc_extra4.KeysView.base_is_MappingView:
  description: "collections.abc.KeysView.__bases__[0].__name__ == 'MappingView' — KeysView directly inherits from MappingView"
  category: class_hierarchy
  kind: python_call_eq
  function: KeysView.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "MappingView"

invariant collections_abc_extra4.ItemsView.base_is_MappingView:
  description: "collections.abc.ItemsView.__bases__[0].__name__ == 'MappingView' — ItemsView directly inherits from MappingView"
  category: class_hierarchy
  kind: python_call_eq
  function: ItemsView.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "MappingView"

invariant collections_abc_extra4.ValuesView.base_is_MappingView:
  description: "collections.abc.ValuesView.__bases__[0].__name__ == 'MappingView' — ValuesView directly inherits from MappingView"
  category: class_hierarchy
  kind: python_call_eq
  function: ValuesView.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "MappingView"
