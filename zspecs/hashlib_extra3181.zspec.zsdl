spec: hl3181
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 659 (hl3181): __truediv__, __floordiv__, __mod__ dict-presence checks for hashlib types."
    - "type(hashlib.md5()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "type(hashlib.blake2s(b'')) is _blake2.blake2s — distinct from HASH and blake2b."
    - "None of the hashlib types define __truediv__, __floordiv__, or __mod__ in their own __dict__."
    - "Hash objects are digest machines — they expose an update/digest API only and do not support division or modulo operations."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3181.truediv:
  description: "hashlib types __truediv__ dict-presence checks; wave 659"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl3181
  columns: [id, function, args, expected]
  rows:
    - ["hl3181001", operator.contains, [type(hashlib.md5()).__dict__,        "__truediv__"], false]
    - ["hl3181002", operator.contains, [type(hashlib.sha256()).__dict__,     "__truediv__"], false]
    - ["hl3181003", operator.contains, [type(hashlib.sha512()).__dict__,     "__truediv__"], false]
    - ["hl3181004", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__truediv__"], false]
    - ["hl3181005", operator.contains, [type(hashlib.blake2s(b'')).__dict__, "__truediv__"], false]

