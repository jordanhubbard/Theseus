    - ["hl3181008", operator.contains, [type(hashlib.sha512()).__dict__,     "__floordiv__"], false]
    - ["hl3181009", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__floordiv__"], false]
    - ["hl3181010", operator.contains, [type(hashlib.blake2s(b'')).__dict__, "__floordiv__"], false]

