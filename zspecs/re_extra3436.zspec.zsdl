spec: re3436
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 676 (re3436): __le__, __gt__, __ge__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __le__/__gt__/__ge__ dict-presence (x<=y, x>y, x>=y)."
    - "No re class defines __le__ in its own __dict__: re.Pattern and re.Match are compiled-pattern and read-only match result objects; <= is not explicitly defined. re.RegexFlag is an IntFlag enum but __le__ is not present in re.RegexFlag.__dict__."
    - "No re class defines __gt__ in its own __dict__: re.Pattern, re.Match, and re.RegexFlag do not implement ordering in their own __dict__s."
    - "No re class defines __ge__ in its own __dict__: re.Pattern, re.Match, and re.RegexFlag do not implement ordering in their own __dict__s."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all ordering operators absent from re class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __le__ dict-presence — operator.contains(Cls.__dict__, '__le__')
#
# No re class defines __le__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum but <= support is not stored in re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

table re3436.le:
  description: "re types __le__ dict-presence checks; wave 676"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3436

  columns: [id, function, args, expected]
  rows:
    - ["re3436001", operator.contains, [re.Pattern.__dict__,   "__le__"], false]
    - ["re3436002", operator.contains, [re.Match.__dict__,     "__le__"], false]
    - ["re3436003", operator.contains, [re.RegexFlag.__dict__, "__le__"], false]

