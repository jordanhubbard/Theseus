spec: concurrent_futures_extra257
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED' (len=15, str); FIRST_EXCEPTION == 'FIRST_EXCEPTION' (len=15, same length); ALL_COMPLETED == 'ALL_COMPLETED' (len=13, shorter by 2)."
    - "FIRST_COMPLETED and FIRST_EXCEPTION share the same string length (15); ALL_COMPLETED is 2 characters shorter (13)."
    - "concurrent.futures.CancelledError.__qualname__ == 'CancelledError' (len=14); __bases__[0].__name__ == 'Error' (len=5); __bases__[0].__bases__[0].__name__ == 'Exception' (len=9)."
    - "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor' (len=14, same as CancelledError); __bases__[0].__name__ == 'RuntimeError' (len=12)."
    - "CancelledError and BrokenExecutor share __qualname__ length 14 — a numeric coincidence."
    - "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' (len=18); ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' (len=19)."
    - "ProcessPoolExecutor.__qualname__ length (19) is exactly 1 more than ThreadPoolExecutor.__qualname__ length (18)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures wait-return constants
#
# concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED' (len=15)
# concurrent.futures.FIRST_EXCEPTION == 'FIRST_EXCEPTION' (len=15)
# concurrent.futures.ALL_COMPLETED == 'ALL_COMPLETED' (len=13)
# type(FIRST_COMPLETED).__name__ == 'str'
# ---------------------------------------------------------------------------

table concurrent_futures_extra257.wait_return_constants:
  description: "concurrent.futures wait-return constants: FIRST_COMPLETED(len=15) and FIRST_EXCEPTION(len=15) share identical string length; ALL_COMPLETED(len=13) is 2 chars shorter; all are str type; verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: cf257wrc

  columns: [id, function, args, expected, description]
  rows:
    - [fc_eq,              FIRST_COMPLETED.__eq__,                                  ["FIRST_COMPLETED"],               true, "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED'; verified with Python 3.14.4"]
    - [fc_len,             FIRST_COMPLETED.__len__,                                 [],                                15,   "concurrent.futures.FIRST_COMPLETED.__len__() == 15 — same length as FIRST_EXCEPTION; verified with Python 3.14.4"]
    - [fc_cls_eq,          FIRST_COMPLETED.__class__.__name__.__eq__,               ["str"],                           true, "type(concurrent.futures.FIRST_COMPLETED).__name__ == 'str'; verified with Python 3.14.4"]
    - [fe_eq,              FIRST_EXCEPTION.__eq__,                                  ["FIRST_EXCEPTION"],               true, "concurrent.futures.FIRST_EXCEPTION == 'FIRST_EXCEPTION'; verified with Python 3.14.4"]
    - [fe_len,             FIRST_EXCEPTION.__len__,                                 [],                                15,   "concurrent.futures.FIRST_EXCEPTION.__len__() == 15 — same length as FIRST_COMPLETED; verified with Python 3.14.4"]
    - [fe_cls_eq,          FIRST_EXCEPTION.__class__.__name__.__eq__,               ["str"],                           true, "type(concurrent.futures.FIRST_EXCEPTION).__name__ == 'str'; verified with Python 3.14.4"]
    - [ac_eq,              ALL_COMPLETED.__eq__,                                    ["ALL_COMPLETED"],                 true, "concurrent.futures.ALL_COMPLETED == 'ALL_COMPLETED'; verified with Python 3.14.4"]
    - [ac_len,             ALL_COMPLETED.__len__,                                   [],                                13,   "concurrent.futures.ALL_COMPLETED.__len__() == 13 — 2 shorter than FIRST_COMPLETED/FIRST_EXCEPTION; verified with Python 3.14.4"]
    - [ac_cls_eq,          ALL_COMPLETED.__class__.__name__.__eq__,                 ["str"],                           true, "type(concurrent.futures.ALL_COMPLETED).__name__ == 'str'; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# concurrent.futures.CancelledError class identity
#
# concurrent.futures.CancelledError.__qualname__ == 'CancelledError' (len=14)
# concurrent.futures.CancelledError.__bases__[0].__name__ == 'Error' (len=5)
# concurrent.futures.CancelledError.__bases__[0].__bases__[0].__name__ == 'Exception' (len=9)
# ---------------------------------------------------------------------------

table concurrent_futures_extra257.cancelled_error_identity:
  description: "concurrent.futures.CancelledError(len=14) class identity — inherits from Error(len=5); Error inherits from Exception(len=9); CancelledError and BrokenExecutor share qualname length 14; verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: cf257ce

  columns: [id, function, args, expected, description]
  rows:
    - [ce_name_eq,         CancelledError.__name__.__eq__,                          ["CancelledError"],                true, "concurrent.futures.CancelledError.__name__ == 'CancelledError'; verified with Python 3.14.4"]
    - [ce_name_len,        CancelledError.__name__.__len__,                         [],                               14,   "concurrent.futures.CancelledError.__name__.__len__() == 14 — same length as BrokenExecutor name; verified with Python 3.14.4"]
    - [ce_qn_eq,           CancelledError.__qualname__.__eq__,                      ["CancelledError"],                true, "concurrent.futures.CancelledError.__qualname__ == 'CancelledError'; verified with Python 3.14.4"]
    - [ce_mod_eq,          CancelledError.__module__.__eq__,                        ["concurrent.futures._base"],      true, "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base'; verified with Python 3.14.4"]
    - [ce_base_eq,         "CancelledError.__bases__[0].__name__.__eq__",           ["Error"],                         true, "concurrent.futures.CancelledError.__bases__[0].__name__ == 'Error'; verified with Python 3.14.4"]
    - [ce_base_len,        "CancelledError.__bases__[0].__name__.__len__",          [],                               5,    "concurrent.futures.CancelledError.__bases__[0].__name__.__len__() == 5 — 'Error'; verified with Python 3.14.4"]
    - [ce_base2_eq,        "CancelledError.__bases__[0].__bases__[0].__name__.__eq__", ["Exception"],                 true, "concurrent.futures.CancelledError.__bases__[0].__bases__[0].__name__ == 'Exception'; verified with Python 3.14.4"]
    - [ce_base2_len,       "CancelledError.__bases__[0].__bases__[0].__name__.__len__", [],                           9,    "concurrent.futures.CancelledError.__bases__[0].__bases__[0].__name__.__len__() == 9 — 'Exception'; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# concurrent.futures.BrokenExecutor, ThreadPoolExecutor, ProcessPoolExecutor identity
#
# concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor' (len=14)
# concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' (len=12)
# concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' (len=18)
# concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' (len=19)
# ---------------------------------------------------------------------------

table concurrent_futures_extra257.executor_subclass_identity:
  description: "concurrent.futures BrokenExecutor(len=14) base is RuntimeError(len=12); ThreadPoolExecutor qualname len=18; ProcessPoolExecutor qualname len=19 (exactly 1 more than ThreadPoolExecutor); BrokenExecutor and CancelledError share qualname length 14; verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: cf257es

  columns: [id, function, args, expected, description]
  rows:
    - [be_name_eq,         BrokenExecutor.__name__.__eq__,                          ["BrokenExecutor"],                true, "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor'; verified with Python 3.14.4"]
    - [be_name_len,        BrokenExecutor.__name__.__len__,                         [],                               14,   "concurrent.futures.BrokenExecutor.__name__.__len__() == 14 — same length as CancelledError name; verified with Python 3.14.4"]
    - [be_qn_eq,           BrokenExecutor.__qualname__.__eq__,                      ["BrokenExecutor"],                true, "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor'; verified with Python 3.14.4"]
    - [be_base_eq,         "BrokenExecutor.__bases__[0].__name__.__eq__",           ["RuntimeError"],                  true, "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'; verified with Python 3.14.4"]
    - [be_base_len,        "BrokenExecutor.__bases__[0].__name__.__len__",          [],                               12,   "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__len__() == 12 — 'RuntimeError'; verified with Python 3.14.4"]
    - [tpe_name_eq,        ThreadPoolExecutor.__name__.__eq__,                      ["ThreadPoolExecutor"],            true, "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'; verified with Python 3.14.4"]
    - [tpe_qn_eq,          ThreadPoolExecutor.__qualname__.__eq__,                  ["ThreadPoolExecutor"],            true, "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor'; verified with Python 3.14.4"]
    - [tpe_qn_len,         ThreadPoolExecutor.__qualname__.__len__,                 [],                               18,   "concurrent.futures.ThreadPoolExecutor.__qualname__.__len__() == 18 — 1 shorter than ProcessPoolExecutor; verified with Python 3.14.4"]
    - [tpe_mod_eq,         ThreadPoolExecutor.__module__.__eq__,                    ["concurrent.futures.thread"],     true, "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'; verified with Python 3.14.4"]
    - [ppe_name_eq,        ProcessPoolExecutor.__name__.__eq__,                     ["ProcessPoolExecutor"],           true, "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor'; verified with Python 3.14.4"]
    - [ppe_qn_eq,          ProcessPoolExecutor.__qualname__.__eq__,                 ["ProcessPoolExecutor"],           true, "concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor'; verified with Python 3.14.4"]
    - [ppe_qn_len,         ProcessPoolExecutor.__qualname__.__len__,                [],                               19,   "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__() == 19 — 1 longer than ThreadPoolExecutor; verified with Python 3.14.4"]
    - [ppe_mod_eq,         ProcessPoolExecutor.__module__.__eq__,                   ["concurrent.futures.process"],    true, "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process'; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra257
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra257.first_completed_and_first_exception_same_length:
  description: "concurrent.futures.FIRST_COMPLETED.__len__() == 15 — 'FIRST_COMPLETED' and 'FIRST_EXCEPTION' both have length 15; ALL_COMPLETED has length 13 (2 shorter); all three are str type; the constants are used as return_when arguments to concurrent.futures.wait(); verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: FIRST_COMPLETED.__len__
  args: []
  expected: 15

invariant concurrent_futures_extra257.cancelled_error_base_is_error:
  description: "concurrent.futures.CancelledError.__bases__[0].__name__.__eq__('Error') returns True — CancelledError inherits from concurrent.futures.Error; Error inherits from Exception; CancelledError and BrokenExecutor both have __qualname__ length 14 — a numeric coincidence; verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: "CancelledError.__bases__[0].__name__.__eq__"
  args: ["Error"]
  expected: true

invariant concurrent_futures_extra257.process_pool_qualname_longer_than_thread_pool:
  description: "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__() == 19 — 'ProcessPoolExecutor' (len=19) is exactly 1 character longer than 'ThreadPoolExecutor' (len=18); this reflects 'Process' (7 chars) vs 'Thread' (6 chars) prefix; both executors inherit from Executor which inherits from object; verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__qualname__.__len__
  args: []
  expected: 19
