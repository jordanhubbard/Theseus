spec: parse_color
version: ">=1.0.0"
backend: node(parse-color)

docs: https://www.npmjs.com/package/parse-color

provenance:
  derived_from:
    - "parse-color README — https://www.npmjs.com/package/parse-color"
    - "Test vectors verified with parse-color via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "parse-color source"
  notes:
    - "parse-color is an npm package. Install: npm install parse-color"
    - "Parses a CSS color string into rgb, hsl, hsv, cmyk, hex, and keyword fields."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an object with multiple color space representations."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table parse_color.parse:
  kind: node_module_call_eq
  function: ~
  category: parse
  id_prefix: parsecolor

  columns: [id, args, expected]
  rows:
    - [red_hex, ["#ff0000"],
       {"rgb": [255, 0, 0], "hsl": [0, 100, 50], "hsv": [0, 100, 100],
        "cmyk": [0, 100, 100, 0], "keyword": "red", "hex": "#ff0000",
        "rgba": [255, 0, 0, 1], "hsla": [0, 100, 50, 1],
        "hsva": [0, 100, 100, 1], "cmyka": [0, 100, 100, 0, 1]}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:30:59Z
  iterations: 1
  pass_count: 1
  fail_count: 0
  total_invariants: 1
  notes: Synthesis succeeded in 1 iteration(s). 1 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
