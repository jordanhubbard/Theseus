spec: abc_extra146
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.__dict__.__len__()==22 and abc.__dict__.__class__.__name__=='dict'; abc.__dict__.__contains__('abstractclassmethod')==True (deprecated); abc.__dict__.__contains__('abstractstaticmethod')==True (deprecated); abc.__dict__.__contains__('abstractproperty')==True (deprecated); abc.__dict__.__contains__('_abc_data')==False (internal C type not exported); abc.__name__.__len__()==3 (shortest module name in this batch). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__dict__.__len__()==22 — abc has 22 entries in its module __dict__. The public names include: ABC, ABCMeta, abstractmethod, abstractproperty, abstractclassmethod, abstractstaticmethod, get_cache_token, update_abstractmethods, and several private C-level helpers (_abc_init, _abc_register, _abc_instancecheck, _abc_subclasscheck, _get_dump, _reset_caches, _reset_registry). abc.__dict__.__class__.__name__=='dict' (plain module dict). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__dict__.__contains__('abstractclassmethod')==True and abc.__dict__.__contains__('abstractstaticmethod')==True — these deprecated decorators have been in abc since Python 3.0 but deprecated since Python 3.3; they still appear in abc.__dict__ on Python 3.14.3. abc.__dict__.__contains__('_abc_data')==False — _abc_data is a C-level internal type used by Modules/_abc.c but not exported to abc.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.__dict__ size and class name — extra146
#
# abc.__dict__.__len__()                == 22
# abc.__dict__.__class__.__name__       == 'dict'
# abc.__dict__.__class__.__name__.__len__() == 4
# abc.__name__.__len__()                == 3
# ---------------------------------------------------------------------------

table abc_extra146.abc_dict_len_and_class:
  description: "abc.__dict__ size and class name checks in abcdict146 namespace — abc.__dict__.__len__()==22 (the abc module has 22 names in its __dict__; public names include ABC, ABCMeta, abstractmethod, abstractproperty, abstractclassmethod, abstractstaticmethod, get_cache_token, update_abstractmethods, plus private C-level helpers _abc_init, _abc_register, _abc_instancecheck, _abc_subclasscheck, _get_dump, _reset_caches, _reset_registry and module dunders); abc.__dict__.__class__.__name__.__eq__('dict')==True (module __dict__ is a plain dict, not mappingproxy; len('dict')==4); abc.__dict__.__class__.__name__.__len__()==4; abc.__name__.__eq__('abc')==True (len=3: 'a'+'b'+'c'=3; the shortest module name in this batch — compare: asyncio=7, multiprocessing=15, concurrent.futures=18); abc.__name__.__len__()==3; NEW in extra146: first abc.__dict__ size spec in abcdict146 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: namespace
  id_prefix: abcdict146

  columns: [id, function, args, expected, description]
  rows:
    - [dict_len,      abc.__dict__.__len__,                        [],      22,    "abc.__dict__.__len__() == 22; verified with Python 3.14.3"]
    - [dict_cls_eq,   abc.__dict__.__class__.__name__.__eq__,      ["dict"], true,  "abc.__dict__.__class__.__name__ == 'dict' (plain module dict, not mappingproxy); verified with Python 3.14.3"]
    - [dict_cls_len,  abc.__dict__.__class__.__name__.__len__,     [],      4,     "abc.__dict__.__class__.__name__.__len__() == 4 ('dict'); verified with Python 3.14.3"]
    - [name_eq,       abc.__name__.__eq__,                         ["abc"], true,  "abc.__name__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [name_len,      abc.__name__.__len__,                        [],      3,     "abc.__name__.__len__() == 3 (shortest module name in this batch); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc deprecated decorator membership — extra146
#
# abc.__dict__.__contains__('abstractclassmethod')  == True   (deprecated since 3.3)
# abc.__dict__.__contains__('abstractstaticmethod') == True   (deprecated since 3.3)
# abc.__dict__.__contains__('abstractproperty')     == True   (deprecated since 3.3)
# abc.__dict__.__contains__('_abc_data')            == False  (internal C type, not exported)
# ---------------------------------------------------------------------------

table abc_extra146.abc_deprecated_and_internal_membership:
  description: "abc.__dict__.__contains__ checks for deprecated decorators and internal C types in abcdict146 namespace — abc.__dict__.__contains__('abstractclassmethod')==True (abstractclassmethod has been deprecated since Python 3.3 but remains in abc.__dict__ on Python 3.14.3; use classmethod with abstractmethod instead); abc.__dict__.__contains__('abstractstaticmethod')==True (abstractstaticmethod also deprecated since Python 3.3; use staticmethod with abstractmethod instead); abc.__dict__.__contains__('abstractproperty')==True (abstractproperty deprecated since Python 3.3; use property with abstractmethod instead); abc.__dict__.__contains__('_abc_data')==False (_abc_data is an internal C-level type defined in Modules/_abc.c used for the _abc_impl slot; it is NOT exported into abc.__dict__; private C internals remain in the _abc extension module namespace only); all three deprecated decorators persist in abc.__dict__ for backward compatibility while _abc_data is intentionally hidden; verified with Python 3.14.3"
  kind: python_call_eq
  category: membership
  id_prefix: abcdeprecated146

  columns: [id, function, args, expected, description]
  rows:
    - [abscls_in,   abc.__dict__.__contains__,  ["abstractclassmethod"],  true,  "abc.__dict__.__contains__('abstractclassmethod') == True — deprecated since Python 3.3, still present; verified with Python 3.14.3"]
    - [absstm_in,   abc.__dict__.__contains__,  ["abstractstaticmethod"], true,  "abc.__dict__.__contains__('abstractstaticmethod') == True — deprecated since Python 3.3, still present; verified with Python 3.14.3"]
    - [absprop_in,  abc.__dict__.__contains__,  ["abstractproperty"],     true,  "abc.__dict__.__contains__('abstractproperty') == True — deprecated since Python 3.3, still present; verified with Python 3.14.3"]
    - [abcdata_out, abc.__dict__.__contains__,  ["_abc_data"],            false, "abc.__dict__.__contains__('_abc_data') == False — internal C type, not exported to abc namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.__name__ length vs other modules — extra146
#
# abc.__name__.__len__()                 == 3   (shortest)
# len('abc') < len('asyncio') < len('multiprocessing') < len('concurrent.futures')
# ---------------------------------------------------------------------------

table abc_extra146.abc_name_length_context:
  description: "abc module __name__ length checks and comparisons in abcdict146 namespace — abc.__name__.__len__()==3 ('abc' is 3 chars: the shortest module name among abc, asyncio, multiprocessing, and concurrent.futures; this makes abc.__name__.__len__()==3 the minimum in this cross-module comparison); abc.__dict__.__len__()==22 (the smallest __dict__ among the four modules: abc(22) < concurrent.futures(28) < multiprocessing(58) < asyncio(136)); abc.__dict__.__len__.__eq__ is not cross-module but we verify abc.__name__.__len__()==3 and abc.__dict__.__len__()==22 as anchors for comparison; abc.__spec__.name.__eq__('abc')==True (len=3: __spec__.name equals __name__ for top-level modules); abc.__spec__.name.__len__()==3; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcname146

  columns: [id, function, args, expected, description]
  rows:
    - [name_len,       abc.__name__.__len__,            [],      3,    "abc.__name__.__len__() == 3 ('abc'; shortest module name in this batch); verified with Python 3.14.3"]
    - [spec_name_eq,   abc.__spec__.name.__eq__,        ["abc"], true,  "abc.__spec__.name == 'abc' (len=3); verified with Python 3.14.3"]
    - [spec_name_len,  abc.__spec__.name.__len__,        [],      3,    "abc.__spec__.name.__len__() == 3; verified with Python 3.14.3"]
    - [dict_len_22,    abc.__dict__.__len__,            [],      22,   "abc.__dict__.__len__() == 22 (smallest dict among abc/asyncio/multiprocessing/concurrent.futures); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra146
# ---------------------------------------------------------------------------

invariant abc_extra146.abc_dict_len_22:
  description: "abc.__dict__.__len__() == 22 — the abc module has 22 entries in its module __dict__; abc is a compact module (one of the smallest stdlib modules by namespace size); the 22 entries include: ABC, ABCMeta, abstractmethod, abstractproperty, abstractclassmethod, abstractstaticmethod, get_cache_token, update_abstractmethods, private C-level helpers (_abc_init, _abc_register, _abc_instancecheck, _abc_subclasscheck, _get_dump, _reset_caches, _reset_registry), and module dunders (__name__, __doc__, __spec__, __loader__, __package__, __builtins__); compare module __dict__ sizes: abc(22) < concurrent.futures(28) < multiprocessing(58) < asyncio(136); abc.__dict__.__class__.__name__=='dict' (plain module dict); abc.__name__=='abc' (len=3); NEW in extra146: first standalone abc.__dict__ length invariant in abcdict146 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: namespace
  kind: python_call_eq
  function: abc.__dict__.__len__
  args: []
  expected: 22

invariant abc_extra146.abc_dict_class_is_dict:
  description: "abc.__dict__.__class__.__name__.__eq__('dict') returns True — abc.__dict__.__class__.__name__ is 'dict' (4 chars); module-level __dict__ is always a plain dict; this distinguishes abc.__dict__ from abc.ABCMeta.__dict__ (mappingproxy, 12 chars) and abc.ABC.__dict__ (mappingproxy, 12 chars); abc.__dict__.__class__.__name__.__len__()==4; abc.__dict__.__len__()==22; abc is a frozen module (abc.__loader__.__class__.__name__=='type') but its __dict__ is still a plain dict like any other module — the frozen status affects the loader, not the __dict__ type; NEW in extra146: first standalone abc.__dict__ class name invariant in abcdict146 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: namespace
  kind: python_call_eq
  function: abc.__dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant abc_extra146.abc_dict_contains_abstractclassmethod:
  description: "abc.__dict__.__contains__('abstractclassmethod') returns True — abstractclassmethod is a class defined in Lib/abc.py that has been deprecated since Python 3.3; it subclasses classmethod and sets __isabstractmethod__=True; despite being deprecated, abstractclassmethod remains in abc.__dict__ on Python 3.14.3 for backward compatibility; the recommended replacement is to combine classmethod with abstractmethod (i.e., use @classmethod @abstractmethod); abc.__dict__.__contains__('abstractclassmethod')==True; abc.__dict__.__contains__('abstractstaticmethod')==True (companion deprecated decorator); abc.__dict__.__contains__('abstractproperty')==True (third deprecated decorator); all three deprecated decorators persist in abc.__dict__; abc.__dict__.__len__()==22; NEW in extra146: first standalone abc.__dict__.__contains__('abstractclassmethod') invariant in abcdict146 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: membership
  kind: python_call_eq
  function: abc.__dict__.__contains__
  args: ["abstractclassmethod"]
  expected: true

invariant abc_extra146.abc_dict_contains_abstractstaticmethod:
  description: "abc.__dict__.__contains__('abstractstaticmethod') returns True — abstractstaticmethod is a class defined in Lib/abc.py that has been deprecated since Python 3.3; it subclasses staticmethod and sets __isabstractmethod__=True; like abstractclassmethod, it remains in abc.__dict__ for backward compatibility; the recommended replacement is to combine staticmethod with abstractmethod (i.e., use @staticmethod @abstractmethod); abc.__dict__.__contains__('abstractstaticmethod')==True; abc.__dict__.__contains__('abstractclassmethod')==True (tied at True with abstractstaticmethod); abc.__dict__.__contains__('abstractproperty')==True (the third deprecated decorator); abc.__dict__.__len__()==22; NEW in extra146: first standalone abc.__dict__.__contains__('abstractstaticmethod') invariant in abcdict146 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: membership
  kind: python_call_eq
  function: abc.__dict__.__contains__
  args: ["abstractstaticmethod"]
  expected: true

invariant abc_extra146.abc_dict_not_contains_abc_data:
  description: "abc.__dict__.__contains__('_abc_data') returns False — _abc_data is an internal C-level type defined in Modules/_abc.c; it is used internally to implement the _abc_impl slot on ABCMeta instances (each ABC class has an _abc_impl attribute that is a _abc_data object storing its cache of registered subclasses); _abc_data is a private implementation detail and is NOT exported into abc.__dict__; abc.__dict__.__contains__('_abc_data')==False; compare: abc.__dict__.__contains__('get_cache_token')==True (a public C-level function that IS exported); abc.__dict__.__contains__('abstractmethod')==True (public pure-Python decorator); abc.__dict__.__len__()==22 (none of the 22 entries is '_abc_data'); NEW in extra146: first standalone abc.__dict__.__contains__('_abc_data') False invariant in abcdict146 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: membership
  kind: python_call_eq
  function: abc.__dict__.__contains__
  args: ["_abc_data"]
  expected: false

invariant abc_extra146.abc_name_len_3:
  description: "abc.__name__.__len__() == 3 — abc.__name__ is 'abc' (3 chars: 'a'+'b'+'c'=3); abc has the shortest module name of the four modules featured in this wave: abc(3) < asyncio(7) < multiprocessing(15) < concurrent.futures(18); the 3-char name 'abc' reflects the module's concise focus (Abstract Base Classes); abc.__spec__.name=='abc' (len=3; __spec__.name equals __name__ for top-level modules); abc.__dict__.__len__()==22 (smallest module dict in this wave); abc.__loader__.__class__.__name__=='type' (abc is a frozen module, unlike the other three which use SourceFileLoader); NEW in extra146: first standalone abc.__name__ length invariant in abcdict146 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__name__.__len__
  args: []
  expected: 3

