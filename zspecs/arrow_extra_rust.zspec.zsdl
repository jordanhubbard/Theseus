spec: arrow_extra_rust
version: ">=3.9"
backend: rust_module(arrow_extra_rust)

docs: https://arrow.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "https://arrow.readthedocs.io/en/latest/ — Arrow documentation"
  not_derived_from:
    - "arrow source: arrow/__init__.py"
  notes:
    - "Arrow is a Python datetime library with a friendlier API."
    - "arrow.now().year >= 2024."
    - "arrow.utcnow().tzname() == 'UTC'."
    - "arrow.Arrow(2024, 1, 15).year == 2024."
    - "arrow.Arrow(2024, 1, 15).month == 1."
    - "arrow.Arrow(2024, 1, 15).day == 15."
    - "Expose arrow_extra_year(y, m, d) -> int: arrow.Arrow(y, m, d).year."
    - "Expose arrow_extra_month(y, m, d) -> int: arrow.Arrow(y, m, d).month."
    - "Expose arrow_extra_day(y, m, d) -> int: arrow.Arrow(y, m, d).day."
    - "All test vectors verified against arrow 1.3.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# arrow_extra_year — year field
table arrow_extra_rust.datetime.year:
  kind: python_call_eq
  category: year
  id_prefix: arx_y
  function: arrow_extra_year

  columns: [id, args, expected]
  rows:
    - [y2024, [2024, 1, 15], 2024]
    - [y2000, [2000, 6, 1],  2000]

# arrow_extra_month — month field
table arrow_extra_rust.datetime.month:
  kind: python_call_eq
  category: month
  id_prefix: arx_m
  function: arrow_extra_month

  columns: [id, args, expected]
  rows:
    - [jan,  [2024, 1, 15], 1]
    - [june, [2000, 6, 1],  6]

# arrow_extra_day — day field
table arrow_extra_rust.datetime.day:
  kind: python_call_eq
  category: day
  id_prefix: arx_d
  function: arrow_extra_day

  columns: [id, args, expected]
  rows:
    - [fifteen, [2024, 1, 15], 15]
    - [first,   [2000, 6, 1],   1]

