spec: as3511
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 681 (as3511): __get__, __set__, __delete__ dict-presence checks for asyncio types."
    - "All values false — asyncio types implement coroutine/async context manager protocols but not the descriptor protocol."
    - "None of the asyncio types define __get__, __set__, or __delete__ in their own __dict__."
    - "asyncio.Lock, Semaphore, BoundedSemaphore, Condition: implement async context manager (__aenter__/__aexit__), not descriptor protocol."
    - "asyncio.Future, Task: coroutine/task handles, no descriptor protocol."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
# ---------------------------------------------------------------------------

table as3511.get:
  description: "asyncio types __get__ dict-presence checks; wave 681"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: as3511
  columns: [id, function, args, expected]
  rows:
    - ["as3511001", operator.contains, [asyncio.Task.__dict__,             "__get__"], false]
    - ["as3511002", operator.contains, [asyncio.Future.__dict__,           "__get__"], false]
    - ["as3511003", operator.contains, [asyncio.Event.__dict__,            "__get__"], false]
    - ["as3511004", operator.contains, [asyncio.Lock.__dict__,             "__get__"], false]
    - ["as3511005", operator.contains, [asyncio.Semaphore.__dict__,        "__get__"], false]
    - ["as3511006", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__get__"], false]
    - ["as3511007", operator.contains, [asyncio.Condition.__dict__,        "__get__"], false]
    - ["as3511008", operator.contains, [asyncio.Queue.__dict__,            "__get__"], false]
    - ["as3511009", operator.contains, [asyncio.PriorityQueue.__dict__,    "__get__"], false]
    - ["as3511010", operator.contains, [asyncio.LifoQueue.__dict__,        "__get__"], false]

