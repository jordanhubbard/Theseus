spec: logging_extra15
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends logging.zspec.zsdl through logging_extra14.zspec.zsdl."
    - "logging_extra13 covers: CRITICAL/ERROR/WARNING/INFO/DEBUG/NOTSET level constants; getLevelName(10)=='DEBUG'; getLogger/basicConfig/disable/captureWarnings __name__."
    - "logging_extra12 covers: MRO lengths for NullHandler/Filter/LogRecord/Filterer/FileHandler; NullHandler base class; getLevelName str->int for INFO/WARNING/ERROR/CRITICAL/NOTSET."
    - "logging_extra10 covers: getLevelName(int)->str for DEBUG; getLevelName str->int for DEBUG."
    - "NOT yet covered: getLevelName(20)=='INFO' as a standalone invariant (int->str direction for INFO)."
    - "NOT yet covered: getLevelName(30)=='WARNING' as a standalone invariant (int->str direction for WARNING)."
    - "NOT yet covered: getLevelName(40)=='ERROR' as a standalone invariant (int->str direction for ERROR)."
    - "NOT yet covered: getLevelName(50)=='CRITICAL' as a standalone invariant (int->str direction for CRITICAL)."
    - "NOT yet covered: getLevelName('DEBUG')==10 as a standalone int result invariant (str->int, DEBUG direction)."
    - "NOT yet covered: getLevelName('ERROR')==40 as a standalone int result invariant."
    - "NOT yet covered: getLogger.__module__ == 'logging' as a standalone invariant."
    - "NOT yet covered: basicConfig.__module__ == 'logging' as a standalone invariant."
    - "NOT yet covered: disable.__module__ == 'logging' as a standalone invariant."
    - "NOT yet covered: captureWarnings.__module__ == 'logging' as a standalone invariant."
    - "getLevelName is a bidirectional lookup: int->str yields the level name, str->int yields the numeric level."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# getLevelName — integer → name direction for INFO, WARNING, ERROR, CRITICAL
#
# logging_extra13 records getLevelName(10)=='DEBUG'. No prior spec records
# the int->str direction for INFO(20), WARNING(30), ERROR(40), or CRITICAL(50)
# as standalone boolean __eq__ invariants.
# ---------------------------------------------------------------------------

invariant logging_extra15.getLevelName.info_int_to_str:
  description: "logging.getLevelName(20) == 'INFO' — integer-to-name direction"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: [20]
  method: __eq__
  method_args: ["INFO"]
  expected: true

invariant logging_extra15.getLevelName.warning_int_to_str:
  description: "logging.getLevelName(30) == 'WARNING' — integer-to-name direction"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: [30]
  method: __eq__
  method_args: ["WARNING"]
  expected: true

invariant logging_extra15.getLevelName.error_int_to_str:
  description: "logging.getLevelName(40) == 'ERROR' — integer-to-name direction"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: [40]
  method: __eq__
  method_args: ["ERROR"]
  expected: true

invariant logging_extra15.getLevelName.critical_int_to_str:
  description: "logging.getLevelName(50) == 'CRITICAL' — integer-to-name direction"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: [50]
  method: __eq__
  method_args: ["CRITICAL"]
  expected: true

# ---------------------------------------------------------------------------
# getLevelName — string → integer direction for DEBUG and ERROR
#
# logging_extra12 covers str->int for INFO/WARNING/ERROR/CRITICAL/NOTSET.
# logging_extra10 covers str->int for DEBUG. All six standard names are covered;
# verify two here as int-equality checks using a direct expected value (not __eq__
# predicate) to exercise the non-boolean expected form.
# ---------------------------------------------------------------------------

invariant logging_extra15.getLevelName.debug_str_to_int:
  description: "logging.getLevelName('DEBUG') == 10 — string-to-int direction"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: ["DEBUG"]
  expected: 10

invariant logging_extra15.getLevelName.error_str_to_int:
  description: "logging.getLevelName('ERROR') == 40 — string-to-int direction"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: ["ERROR"]
  expected: 40

# ---------------------------------------------------------------------------
# Module-level function __module__ checks
#
# logging_extra13 records __name__ for getLogger, basicConfig, disable, and
# captureWarnings. No prior logging spec records __module__ for these four
# functions as standalone __eq__ invariants. All are defined in logging/__init__.py
# and thus have __module__ == 'logging'.
# ---------------------------------------------------------------------------

invariant logging_extra15.getLogger.module:
  description: "logging.getLogger.__module__ == 'logging'"
  category: function_modules
  kind: python_call_eq
  function: getLogger.__module__.__eq__
  args: ["logging"]
  expected: true

invariant logging_extra15.basicConfig.module:
  description: "logging.basicConfig.__module__ == 'logging'"
  category: function_modules
  kind: python_call_eq
  function: basicConfig.__module__.__eq__
  args: ["logging"]
  expected: true

invariant logging_extra15.disable.module:
  description: "logging.disable.__module__ == 'logging'"
  category: function_modules
  kind: python_call_eq
  function: disable.__module__.__eq__
  args: ["logging"]
  expected: true

invariant logging_extra15.captureWarnings.module:
  description: "logging.captureWarnings.__module__ == 'logging'"
  category: function_modules
  kind: python_call_eq
  function: captureWarnings.__module__.__eq__
  args: ["logging"]
  expected: true
