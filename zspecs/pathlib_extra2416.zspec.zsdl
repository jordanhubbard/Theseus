# ===
# Table 4: pathlib.Sequence — defines __iter__ as a function, not __next__
# ===

table pathlib_extra2416.sequence_iter:
  description: "pathlib.Sequence defines __iter__ in its __dict__ as a plain function; __next__ is absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2416
  columns: [id, function, args, expected]
  rows:
    - ["pp2416019", "pathlib.Sequence.__dict__.__contains__", ["__iter__"], true]
    - ["pp2416020", "pathlib.Sequence.__dict__.__contains__", ["__next__"], false]
    - ["pp2416021", "pathlib.Sequence.__iter__.__class__.__name__", [], "function"]
