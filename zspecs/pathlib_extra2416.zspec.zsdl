spec: pathlib_extra2416
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/pathlib.html"
    - "CPython source — Lib/pathlib/__init__.py"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 608 (_extra2416): __iter__ and __next__ dict-presence and type classification."
    - "pathlib path classes (PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath) do not support iteration; none define __iter__ or __next__ in their class __dict__."
    - "pathlib.Sequence (from collections.abc) defines __iter__ as a regular function in its own __dict__, not as a wrapper_descriptor."
    - "pathlib.UnsupportedOperation, PathInfo, DirEntryInfo do not define __iter__ or __next__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
# Table 1: __iter__ in class __dict__ — path classes
# ===

table pathlib_extra2416.iter_in_dict_paths:
  description: "__iter__ dict-presence for pathlib path classes — none define __iter__ directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2416
  columns: [id, function, args, expected]
  rows:
    - ["pp2416001", "pathlib.PurePath.__dict__.__contains__", ["__iter__"], false]
    - ["pp2416002", "pathlib.PurePosixPath.__dict__.__contains__", ["__iter__"], false]
    - ["pp2416003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__iter__"], false]
    - ["pp2416004", "pathlib.Path.__dict__.__contains__", ["__iter__"], false]
    - ["pp2416005", "pathlib.PosixPath.__dict__.__contains__", ["__iter__"], false]
    - ["pp2416006", "pathlib.WindowsPath.__dict__.__contains__", ["__iter__"], false]

