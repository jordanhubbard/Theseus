  description: "__iter__ and __next__ dict-presence for pathlib utility classes (UnsupportedOperation, PathInfo, DirEntryInfo)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2416
  columns: [id, function, args, expected]
  rows:
    - ["pp2416013", "pathlib.UnsupportedOperation.__dict__.__contains__", ["__iter__"], false]
    - ["pp2416014", "pathlib.UnsupportedOperation.__dict__.__contains__", ["__next__"], false]
    - ["pp2416015", "pathlib.PathInfo.__dict__.__contains__", ["__iter__"], false]
    - ["pp2416016", "pathlib.PathInfo.__dict__.__contains__", ["__next__"], false]
    - ["pp2416017", "pathlib.DirEntryInfo.__dict__.__contains__", ["__iter__"], false]
