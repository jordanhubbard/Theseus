  columns: [id, function, args, expected]
  rows:
    - ["pp2416007", "pathlib.PurePath.__dict__.__contains__", ["__next__"], false]
    - ["pp2416008", "pathlib.PurePosixPath.__dict__.__contains__", ["__next__"], false]
    - ["pp2416009", "pathlib.PureWindowsPath.__dict__.__contains__", ["__next__"], false]
    - ["pp2416010", "pathlib.Path.__dict__.__contains__", ["__next__"], false]
    - ["pp2416011", "pathlib.PosixPath.__dict__.__contains__", ["__next__"], false]
    - ["pp2416012", "pathlib.WindowsPath.__dict__.__contains__", ["__next__"], false]

