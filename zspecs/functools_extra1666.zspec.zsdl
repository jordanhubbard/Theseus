spec: functools_extra1666
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "Python functools documentation — https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14 on macOS Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES, and callable type checks"
    - "functools_extra.zspec.zsdl — covers __name__ and __module__ for public symbols"
  notes:
    - "Theme: __new__ — object construction protocol."
    - "functools.partial is a C extension type; its __dict__ contains '__new__' but NOT '__init__'."
    - "functools.partialmethod is a Python class; its __dict__ contains '__new__' but NOT '__init__'."
    - "functools.cached_property is a Python class; its __dict__ does NOT contain '__new__' but DOES contain '__init__'."
    - "functools.lru_cache, cache, wraps, total_ordering, singledispatch are plain Python functions — not types; __dict__ on a function object does not carry '__new__' or '__init__' entries."
    - "functools.reduce and cmp_to_key are C-level built-in functions; they have no class __dict__ to query."
    - "partial defines __new__ because it is implemented as a C type that uses tp_new to validate its constructor arguments."
    - "partialmethod defines __new__ (in Python) to normalize the wrapped callable before the descriptor is stored."
    - "cached_property uses __init__ (standard Python class pattern) rather than __new__."
    - "All type() and callable() results confirmed by running Python 3.14 on macOS Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: new_init_presence
#
# Records whether each functools class defines __new__ and/or __init__ in
# its own __dict__.  Only class objects (type(X).__name__ == 'type') are
# included; plain function objects are listed as a separate group.
#
# Columns:
#   id       — quoted row identifier
#   function — dotted attribute chain to evaluate
#   args     — argument list (always ["__new__"] or ["__init__"])
#   expected — true / false
# ---------------------------------------------------------------------------

table functools_extra1666.new_init_presence:
  kind: python_call_eq
  category: new_init_presence
  id_prefix: fu1666

  columns: [id, function, args, expected]
  rows:
    - ["partial_has_new",            partial.__dict__.__contains__,            ["__new__"],   true]
    - ["partial_has_no_init",        partial.__dict__.__contains__,            ["__init__"],  false]
    - ["partialmethod_has_new",      partialmethod.__dict__.__contains__,      ["__new__"],   true]
    - ["partialmethod_has_no_init",  partialmethod.__dict__.__contains__,      ["__init__"],  false]
    - ["cached_property_no_new",     cached_property.__dict__.__contains__,    ["__new__"],   false]
    - ["cached_property_has_init",   cached_property.__dict__.__contains__,    ["__init__"],  true]
    - ["partial_has_repr",           partial.__dict__.__contains__,            ["__repr__"],  true]
    - ["partial_has_call",           partial.__dict__.__contains__,            ["__call__"],  true]
    - ["partial_has_get",            partial.__dict__.__contains__,            ["__get__"],   true]
    - ["partial_has_reduce",         partial.__dict__.__contains__,            ["__reduce__"], true]
    - ["partial_has_setstate",       partial.__dict__.__contains__,            ["__setstate__"], true]
    - ["partial_has_class_getitem",  partial.__dict__.__contains__,            ["__class_getitem__"], true]
    - ["partial_has_func",           partial.__dict__.__contains__,            ["func"],      true]
    - ["partial_has_args",           partial.__dict__.__contains__,            ["args"],      true]
    - ["partial_has_keywords",       partial.__dict__.__contains__,            ["keywords"],  true]
    - ["partialmethod_has_repr",     partialmethod.__dict__.__contains__,      ["__repr__"],  true]
    - ["partialmethod_has_get",      partialmethod.__dict__.__contains__,      ["__get__"],   true]
    - ["partialmethod_has_isabstractmethod", partialmethod.__dict__.__contains__, ["__isabstractmethod__"], true]
    - ["partialmethod_has_class_getitem", partialmethod.__dict__.__contains__, ["__class_getitem__"], true]
    - ["cached_property_has_get",    cached_property.__dict__.__contains__,    ["__get__"],  true]
    - ["cached_property_has_set_name", cached_property.__dict__.__contains__,  ["__set_name__"], true]
    - ["cached_property_has_class_getitem", cached_property.__dict__.__contains__, ["__class_getitem__"], true]
    - ["cached_property_no_set",     cached_property.__dict__.__contains__,    ["__set__"],  false]
    - ["cached_property_has_no_new_confirm", cached_property.__dict__.__contains__, ["__new__"], false]

# ---------------------------------------------------------------------------
# Table 2: callable_type_checks
#
# Verifies that all public functools symbols are callable and records their
# type-name.  Distinguishes C built-in, Python type, and Python function.
# ---------------------------------------------------------------------------

table functools_extra1666.callable_type_checks:
  kind: python_call_eq
  category: callable_type_checks
  id_prefix: fu1666

  columns: [id, function, args, expected]
  rows:
    - ["partial_callable",          partial.__class__.__name__.__eq__,          ["type"],                      true]
    - ["partialmethod_callable",    partialmethod.__class__.__name__.__eq__,    ["type"],                      true]
    - ["cached_property_callable",  cached_property.__class__.__name__.__eq__,  ["type"],                      true]
    - ["lru_cache_is_function",     lru_cache.__class__.__name__.__eq__,        ["function"],                  true]
    - ["cache_is_function",         cache.__class__.__name__.__eq__,            ["function"],                  true]
    - ["wraps_is_function",         wraps.__class__.__name__.__eq__,            ["function"],                  true]
    - ["total_ordering_is_function", total_ordering.__class__.__name__.__eq__,  ["function"],                  true]
    - ["singledispatch_is_function", singledispatch.__class__.__name__.__eq__,  ["function"],                  true]
    - ["reduce_is_builtin",         reduce.__class__.__name__.__eq__,           ["builtin_function_or_method"], true]
    - ["cmp_to_key_is_builtin",     cmp_to_key.__class__.__name__.__eq__,       ["builtin_function_or_method"], true]
    - ["partial_name_is_partial",   partial.__name__.__eq__,                    ["partial"],                   true]
    - ["partialmethod_name",        partialmethod.__name__.__eq__,              ["partialmethod"],             true]
    - ["cached_property_name",      cached_property.__name__.__eq__,            ["cached_property"],           true]
    - ["lru_cache_name",            lru_cache.__name__.__eq__,                  ["lru_cache"],                 true]
    - ["cache_name",                cache.__name__.__eq__,                      ["cache"],                     true]
    - ["reduce_name",               reduce.__name__.__eq__,                     ["reduce"],                    true]
    - ["cmp_to_key_name",           cmp_to_key.__name__.__eq__,                 ["cmp_to_key"],                true]
    - ["partial_module",            partial.__module__.__eq__,                  ["functools"],                 true]
    - ["partialmethod_module",      partialmethod.__module__.__eq__,            ["functools"],                 true]
    - ["cached_property_module",    cached_property.__module__.__eq__,          ["functools"],                 true]
    - ["lru_cache_module",          lru_cache.__module__.__eq__,                ["functools"],                 true]
    - ["reduce_module",             reduce.__module__.__eq__,                   ["functools"],                 true]
    - ["cmp_to_key_module",         cmp_to_key.__module__.__eq__,               ["functools"],                 true]

# ---------------------------------------------------------------------------
# Table 3: functools_method_presence
#
# Checks for the presence of descriptor and protocol methods on the three
# class objects in functools: partial, partialmethod, and cached_property.
# This documents the full construction-and-descriptor protocol for each.
# ---------------------------------------------------------------------------

table functools_extra1666.functools_method_presence:
  kind: python_call_eq
  category: method_presence
  id_prefix: fu1666

  columns: [id, function, args, expected]
  rows:
    - ["partial_new_present",           partial.__dict__.__contains__,            ["__new__"],              true]
    - ["partial_repr_present",          partial.__dict__.__contains__,            ["__repr__"],             true]
    - ["partial_call_present",          partial.__dict__.__contains__,            ["__call__"],             true]
    - ["partial_get_present",           partial.__dict__.__contains__,            ["__get__"],              true]
    - ["partial_reduce_present",        partial.__dict__.__contains__,            ["__reduce__"],           true]
    - ["partial_setstate_present",      partial.__dict__.__contains__,            ["__setstate__"],         true]
    - ["partial_class_getitem_present", partial.__dict__.__contains__,            ["__class_getitem__"],   true]
    - ["partial_func_attr_present",     partial.__dict__.__contains__,            ["func"],                 true]
    - ["partial_args_attr_present",     partial.__dict__.__contains__,            ["args"],                 true]
    - ["partial_keywords_attr_present", partial.__dict__.__contains__,            ["keywords"],             true]
    - ["partial_init_absent",           partial.__dict__.__contains__,            ["__init__"],             false]
    - ["partialmethod_new_present",     partialmethod.__dict__.__contains__,      ["__new__"],              true]
    - ["partialmethod_repr_present",    partialmethod.__dict__.__contains__,      ["__repr__"],             true]
    - ["partialmethod_get_present",     partialmethod.__dict__.__contains__,      ["__get__"],              true]
    - ["partialmethod_make_unbound",    partialmethod.__dict__.__contains__,      ["_make_unbound_method"], true]
    - ["partialmethod_isabstractmethod",partialmethod.__dict__.__contains__,      ["__isabstractmethod__"], true]
    - ["partialmethod_class_getitem",   partialmethod.__dict__.__contains__,      ["__class_getitem__"],   true]
    - ["partialmethod_init_absent",     partialmethod.__dict__.__contains__,      ["__init__"],             false]
    - ["cached_prop_init_present",      cached_property.__dict__.__contains__,    ["__init__"],             true]
    - ["cached_prop_get_present",       cached_property.__dict__.__contains__,    ["__get__"],              true]
    - ["cached_prop_set_name_present",  cached_property.__dict__.__contains__,    ["__set_name__"],         true]
    - ["cached_prop_class_getitem",     cached_property.__dict__.__contains__,    ["__class_getitem__"],   true]
    - ["cached_prop_new_absent",        cached_property.__dict__.__contains__,    ["__new__"],              false]
    - ["cached_prop_set_absent",        cached_property.__dict__.__contains__,    ["__set__"],              false]
