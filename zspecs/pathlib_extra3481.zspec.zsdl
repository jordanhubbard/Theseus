spec: pp3481
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 679 (pp3481): __enter__, __exit__, __call__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __enter__/__exit__/__call__ dict-presence (context manager / callable protocol)."
    - "No pathlib class defines __enter__ in its own __dict__: path objects are value types and do not implement the context manager protocol."
    - "No pathlib class defines __exit__ in its own __dict__: path objects do not implement the context manager exit in their own __dict__s."
    - "No pathlib class defines __call__ in its own __dict__: path objects are not callable."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __enter__ dict-presence — operator.contains(Cls.__dict__, '__enter__')
#
# No pathlib class defines __enter__ in its own __dict__; all false.
# Path objects are immutable filesystem path value types and do not
# implement the context manager protocol.
# ---------------------------------------------------------------------------

table pp3481.enter:
  description: "pathlib types __enter__ dict-presence checks; wave 679"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3481

  columns: [id, function, args, expected]
  rows:
    - ["pp3481001", operator.contains, [pathlib.PurePath.__dict__,         "__enter__"], false]
    - ["pp3481002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__enter__"], false]
    - ["pp3481003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__enter__"], false]
    - ["pp3481004", operator.contains, [pathlib.Path.__dict__,             "__enter__"], false]
    - ["pp3481005", operator.contains, [pathlib.PosixPath.__dict__,        "__enter__"], false]

