spec: string_extra31
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/string.py"
    - "string_extra30.zspec.zsdl — covers Formatter.check_unused_args/convert_field/get_value/_vformat __qualname__ lens; Template.get_identifiers/is_valid/_invalid __qualname__ lens; string.__name__.__len__()==6; Formatter.__qualname__.__len__()==9; Template.__qualname__.__len__()==8; Template.flags.__class__.__name__.__len__()==8."
    - "string_extra29.zspec.zsdl — covers __all__ len (12), Template.pattern/__delimiter__/idpattern class names and lengths; Formatter/Template __dict__.__class__.__name__.__len__()==12; ascii_letters/digits __class__.__name__.__len__()==3; capwords.__name__.__len__()==8."
    - "string_extra28.zspec.zsdl — covers __mro__.__len__() for Formatter (2) and Template (2); __bases__[0].__name__.__len__() (6 for both); string constant __len__() for printable/digits/hexdigits/ascii_letters/ascii_lowercase/ascii_uppercase/octdigits/punctuation/whitespace; Template.__init__.__qualname__.__len__()==17."
  notes:
    - "This spec extends string_extra30.zspec.zsdl."
    - "Prior specs covered: all string constant __len__() values; all major Template/Formatter method __qualname__.__len__(); Template/__init__ (17), __mro__/__bases__[0]/__dict__ sizes; __all__ len (12); delimiter/idpattern/pattern attributes; capwords name len (8); module __name__.__len__()==6; Formatter/Template __qualname__ lens."
    - "This spec covers NEW angles: Template.__name__.__len__()==8; Template.__qualname__.__len__()==8 (standalone invariant); Template.__mro__.__len__()==2; Template.__bases__[0].__name__.__len__()==6; Formatter.__name__.__len__()==9; Formatter.__qualname__.__len__()==9 (standalone invariant); Formatter.__mro__.__len__()==2; string.ascii_letters.__class__.__name__.__len__()==3; string.digits.__class__.__name__.__len__()==3; string.punctuation.__len__()==32."
    - "Template.__mro__ == [Template, object] — depth 2. Formatter.__mro__ == [Formatter, object] — depth 2. Both classes inherit directly from object."
    - "Template.__bases__[0].__name__ == 'object' (len 6). Same for Formatter."
    - "string.punctuation has 32 characters: !\"#$%&'()*+,-./:;<=>?@[\\]^_`{|}~"
    - "string.ascii_letters and string.digits are plain str objects; 'str' has len 3."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Template class identity: __name__, __qualname__, __mro__, __bases__
#
# Template.__name__ == 'Template' (len 8). Template.__qualname__ == 'Template'
# (len 8) — agrees with __name__ for this top-level class. Template.__mro__
# has 2 entries: [Template, object]. Template.__bases__[0].__name__ == 'object'
# (len 6). These identity attributes confirm Template's simple single-inheritance
# from object.
# ---------------------------------------------------------------------------

table string_extra31.Template_class_identity:
  description: "string.Template class identity: __name__.__len__()==8, __qualname__.__len__()==8, __mro__.__len__()==2, __bases__[0].__name__.__len__()==6"
  kind: python_call_eq
  category: class_identity
  id_prefix: tmpl_id

  columns: [id, function, args, expected, description]
  rows:
    - [name_len,
       Template.__name__.__len__,
       [],
       8,
       "len(string.Template.__name__) == 8 — 'Template'"]
    - [qualname_len,
       Template.__qualname__.__len__,
       [],
       8,
       "len(string.Template.__qualname__) == 8 — 'Template'"]
    - [mro_len,
       Template.__mro__.__len__,
       [],
       2,
       "len(string.Template.__mro__) == 2 — [Template, object]"]
    - [bases_name_len,
       "Template.__bases__[0].__name__.__len__",
       [],
       6,
       "string.Template.__bases__[0].__name__ == 'object' (len 6)"]

# ---------------------------------------------------------------------------
# Formatter class identity: __name__, __qualname__, __mro__, __bases__
#
# Formatter.__name__ == 'Formatter' (len 9). Formatter.__qualname__ == 'Formatter'
# (len 9) — agrees with __name__ for this top-level class. Formatter.__mro__
# has 2 entries: [Formatter, object]. Formatter.__bases__[0].__name__ == 'object'
# (len 6). Formatter has the same simple inheritance chain as Template.
# ---------------------------------------------------------------------------

table string_extra31.Formatter_class_identity:
  description: "string.Formatter class identity: __name__.__len__()==9, __qualname__.__len__()==9, __mro__.__len__()==2, __bases__[0].__name__.__len__()==6"
  kind: python_call_eq
  category: class_identity
  id_prefix: fmt_id

  columns: [id, function, args, expected, description]
  rows:
    - [name_len,
       Formatter.__name__.__len__,
       [],
       9,
       "len(string.Formatter.__name__) == 9 — 'Formatter'"]
    - [qualname_len,
       Formatter.__qualname__.__len__,
       [],
       9,
       "len(string.Formatter.__qualname__) == 9 — 'Formatter'"]
    - [mro_len,
       Formatter.__mro__.__len__,
       [],
       2,
       "len(string.Formatter.__mro__) == 2 — [Formatter, object]"]
    - [bases_name_len,
       "Formatter.__bases__[0].__name__.__len__",
       [],
       6,
       "string.Formatter.__bases__[0].__name__ == 'object' (len 6)"]

# ---------------------------------------------------------------------------
# string module constants: ascii_letters, digits class names; punctuation len
#
# string.ascii_letters and string.digits are plain str instances; 'str' has
# len 3. string.punctuation contains 32 characters: all standard ASCII
# punctuation marks. No prior string spec records punctuation.__len__()==32
# as a standalone invariant in this namespace.
# ---------------------------------------------------------------------------

invariant string_extra31.ascii_letters.class.name.len:
  description: "string.ascii_letters.__class__.__name__.__len__() == 3 — ascii_letters is a 'str'"
  category: module_constants
  kind: python_call_eq
  function: ascii_letters.__class__.__name__.__len__
  args: []
  expected: 3

invariant string_extra31.digits.class.name.len:
  description: "string.digits.__class__.__name__.__len__() == 3 — digits is a 'str'"
  category: module_constants
  kind: python_call_eq
  function: digits.__class__.__name__.__len__
  args: []
  expected: 3

invariant string_extra31.punctuation.len:
  description: "string.punctuation.__len__() == 32 — standard ASCII punctuation has 32 characters"
  category: module_constants
  kind: python_call_eq
  function: punctuation.__len__
  args: []
  expected: 32
