spec: functools_extra2146
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 2146 (_extra2146): numeric conversion protocol dict-presence checks — __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__ in class __dict__ for functools types."
    - "Theme: numeric conversion protocol dict-presence — checking whether numeric dunder methods (math.trunc, math.floor, math.ceil, integer index protocol, complex conversion, truth testing, int conversion) are defined at the class level in __dict__ for functools types."
    - "functools.partial is a C extension type; it does not define any numeric conversion dunders in its own __dict__. These are all inherited from object."
    - "functools.partialmethod is a pure Python class; it does not define any numeric conversion dunders."
    - "functools.cached_property is a descriptor class; it does not define any numeric conversion dunders."
    - "functools._lru_cache_wrapper is a C extension type wrapping lru_cache'd functions; it defines no numeric conversion dunders."
    - "functools.singledispatchmethod is a descriptor class for single-dispatch methods; it defines no numeric conversion dunders."
    - "All seven target methods (__trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__) are absent from all five functools class __dict__ objects."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: numeric conversion protocol dict-presence for functools.partial
#
# functools.partial is a C type (Modules/_functoolsmodule.c). Its __dict__ is
# a mappingproxy containing only the attributes defined at the C level.
# None of the numeric conversion protocol dunders are defined there.
# ---------------------------------------------------------------------------

table functools_extra2146.partial_numeric_protocol:
  description: "functools.partial class __dict__ numeric conversion protocol dict-presence — all False (inherited from object, not defined at class level)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2146

  columns: [id, function, args, expected]
  rows:
    - ["ft2146001", "functools.partial.__dict__.__contains__", ["__trunc__"],   false]
    - ["ft2146002", "functools.partial.__dict__.__contains__", ["__floor__"],   false]
    - ["ft2146003", "functools.partial.__dict__.__contains__", ["__ceil__"],    false]
    - ["ft2146004", "functools.partial.__dict__.__contains__", ["__index__"],   false]
    - ["ft2146005", "functools.partial.__dict__.__contains__", ["__complex__"], false]
    - ["ft2146006", "functools.partial.__dict__.__contains__", ["__bool__"],    false]
    - ["ft2146007", "functools.partial.__dict__.__contains__", ["__int__"],     false]

