spec: asyncio_extra1471
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — Tasks and coroutines"
    - "https://docs.python.org/3/library/asyncio-sync.html — Synchronization primitives"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "asyncio_extra1456.zspec.zsdl — covers __contains__ and __iter__ dict membership checks"
    - "asyncio_extra.zspec.zsdl — covers __module__ and class name checks"
    - "CPython source: Lib/asyncio/queues.py, Lib/asyncio/locks.py, Lib/asyncio/tasks.py"
  notes:
    - "Wave 545 (_extra1471): focuses on __len__ and __getitem__ method presence and type checks for asyncio classes."
    - "asyncio.Queue does not define '__len__' in its own __dict__ — Queue is an async FIFO queue, not a sequence. Verified Python 3.14.4."
    - "asyncio.Queue does not define '__getitem__' in its own __dict__ — Queue items are retrieved via get(), not index access. Verified Python 3.14.4."
    - "asyncio.Task does not define '__len__' or '__getitem__' in its own __dict__ — Task is a coroutine wrapper, not a container. Verified Python 3.14.4."
    - "asyncio.Future does not define '__len__' or '__getitem__' in its own __dict__ — Future is a result placeholder, not a sequence. Verified Python 3.14.4."
    - "asyncio.Lock does not define '__len__' or '__getitem__' in its own __dict__ — Lock is a synchronization primitive, not a container. Verified Python 3.14.4."
    - "asyncio.Event does not define '__len__' or '__getitem__' in its own __dict__ — Event is a signaling primitive, not a sequence. Verified Python 3.14.4."
    - "asyncio.Semaphore does not define '__len__' or '__getitem__' in its own __dict__ — Semaphore is a counting primitive, not a container. Verified Python 3.14.4."
    - "asyncio.Barrier does not define '__len__' or '__getitem__' in its own __dict__ — Barrier is a synchronization primitive, not a sequence. Verified Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio class __len__ dict absence
#
# Wave 545 theme: '__len__' not in own __dict__ for asyncio classes.
# Queue, Task, Future, Lock, Event, Semaphore, and Barrier are all
# async primitives or coroutine wrappers — none are sequences or sized
# containers that define __len__ in their own class __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra1471.len_dict_membership:
  description: "asyncio classes: '__len__' not in own __dict__ for Queue, Task, Future, Lock, Event, Semaphore, Barrier; wave 545; new to extra1471"
  kind: python_call_eq
  category: len_dict_membership
  id_prefix: as1471ld

  columns: [id, function, args, expected, description]
  rows:
    - [as1471ld001,
       "Queue.__dict__.__contains__",
       ["__len__"],
       false,
       "asyncio.Queue.__dict__.__contains__('__len__') == False — Queue is an async FIFO queue; items retrieved via get(), not index; no __len__ in own class __dict__; new to extra1471"]
    - [as1471ld002,
       "Task.__dict__.__contains__",
       ["__len__"],
       false,
       "asyncio.Task.__dict__.__contains__('__len__') == False — Task is a coroutine wrapper; manages async execution, not a sequence; no __len__ in own class __dict__; new to extra1471"]
    - [as1471ld003,
       "Future.__dict__.__contains__",
       ["__len__"],
       false,
       "asyncio.Future.__dict__.__contains__('__len__') == False — Future is a result placeholder; holds one eventual value, not a collection; no __len__ in own class __dict__; new to extra1471"]
    - [as1471ld004,
       "Lock.__dict__.__contains__",
       ["__len__"],
       false,
       "asyncio.Lock.__dict__.__contains__('__len__') == False — Lock is a synchronization primitive; is not a container; no __len__ in own class __dict__; new to extra1471"]
    - [as1471ld005,
       "Event.__dict__.__contains__",
       ["__len__"],
       false,
       "asyncio.Event.__dict__.__contains__('__len__') == False — Event is a signaling primitive; is not a container; no __len__ in own class __dict__; new to extra1471"]
    - [as1471ld006,
       "Semaphore.__dict__.__contains__",
       ["__len__"],
       false,
       "asyncio.Semaphore.__dict__.__contains__('__len__') == False — Semaphore is a counting synchronization primitive; is not a sequence; no __len__ in own class __dict__; new to extra1471"]
    - [as1471ld007,
       "Barrier.__dict__.__contains__",
       ["__len__"],
       false,
       "asyncio.Barrier.__dict__.__contains__('__len__') == False — Barrier is a synchronization primitive; is not a container; no __len__ in own class __dict__; new to extra1471"]
    - [as1471ld008,
       "Task.__dict__.__contains__",
       ["__len__"],
       false,
       "asyncio.Task.__dict__.__contains__('__len__') == False — cross-check: Task manages a single coroutine, sized-container protocol entirely absent; new to extra1471"]

# ---------------------------------------------------------------------------
# Table 2: asyncio class __getitem__ dict absence
#
# Wave 545 theme: '__getitem__' not in own __dict__ for asyncio classes.
# None of the asyncio classes support index-based item access; they are
# all async primitives whose items (if any) are consumed via awaitable
# methods rather than subscript notation.
# ---------------------------------------------------------------------------

table asyncio_extra1471.getitem_dict_membership:
  description: "asyncio classes: '__getitem__' not in own __dict__ for Queue, Task, Future, Lock, Event, Semaphore, Barrier; wave 545; new to extra1471"
  kind: python_call_eq
  category: getitem_dict_membership
  id_prefix: as1471gi

  columns: [id, function, args, expected, description]
  rows:
    - [as1471gi001,
       "Queue.__dict__.__contains__",
       ["__getitem__"],
       false,
       "asyncio.Queue.__dict__.__contains__('__getitem__') == False — Queue items are retrieved via await queue.get(), not index notation; no __getitem__ in own class __dict__; new to extra1471"]
    - [as1471gi002,
       "Task.__dict__.__contains__",
       ["__getitem__"],
       false,
       "asyncio.Task.__dict__.__contains__('__getitem__') == False — Task wraps a single coroutine; subscript access not defined; no __getitem__ in own class __dict__; new to extra1471"]
    - [as1471gi003,
       "Future.__dict__.__contains__",
       ["__getitem__"],
       false,
       "asyncio.Future.__dict__.__contains__('__getitem__') == False — Future holds one eventual result; subscript access not defined; no __getitem__ in own class __dict__; new to extra1471"]
    - [as1471gi004,
       "Lock.__dict__.__contains__",
       ["__getitem__"],
       false,
       "asyncio.Lock.__dict__.__contains__('__getitem__') == False — Lock is a synchronization primitive; subscript access not applicable; no __getitem__ in own class __dict__; new to extra1471"]
    - [as1471gi005,
       "Event.__dict__.__contains__",
       ["__getitem__"],
       false,
       "asyncio.Event.__dict__.__contains__('__getitem__') == False — Event is a signaling primitive; subscript access not applicable; no __getitem__ in own class __dict__; new to extra1471"]
    - [as1471gi006,
       "Semaphore.__dict__.__contains__",
       ["__getitem__"],
       false,
       "asyncio.Semaphore.__dict__.__contains__('__getitem__') == False — Semaphore is a counting primitive; subscript access not applicable; no __getitem__ in own class __dict__; new to extra1471"]
    - [as1471gi007,
       "Barrier.__dict__.__contains__",
       ["__getitem__"],
       false,
       "asyncio.Barrier.__dict__.__contains__('__getitem__') == False — Barrier is a synchronization primitive; subscript access not applicable; no __getitem__ in own class __dict__; new to extra1471"]
    - [as1471gi008,
       "Future.__dict__.__contains__",
       ["__getitem__"],
       false,
       "asyncio.Future.__dict__.__contains__('__getitem__') == False — cross-check: Future is awaited for its single result; sequence protocol entirely absent; new to extra1471"]

# ---------------------------------------------------------------------------
# Table 3: asyncio cross-protocol absence — __len__ and __getitem__ together
#
# Wave 545 theme: confirm that both sized-container (__len__) and sequence
# (__getitem__) protocols are absent from these asyncio classes, verifying
# that neither half of the sequence protocol is present in any of them.
# ---------------------------------------------------------------------------

table asyncio_extra1471.sequence_protocol_absence:
  description: "asyncio classes: both '__len__' and '__getitem__' absent from own __dict__; cross-check for Queue, Task, Future, Lock; wave 545; new to extra1471"
  kind: python_call_eq
  category: sequence_protocol_absence
  id_prefix: as1471sp

  columns: [id, function, args, expected, description]
  rows:
    - [as1471sp001,
       "Queue.__dict__.__contains__",
       ["__len__"],
       false,
       "asyncio.Queue.__dict__.__contains__('__len__') == False — sequence protocol cross-check: sized half absent from Queue; new to extra1471"]
    - [as1471sp002,
       "Queue.__dict__.__contains__",
       ["__getitem__"],
       false,
       "asyncio.Queue.__dict__.__contains__('__getitem__') == False — sequence protocol cross-check: subscript half absent from Queue; new to extra1471"]
    - [as1471sp003,
       "Task.__dict__.__contains__",
       ["__len__"],
       false,
       "asyncio.Task.__dict__.__contains__('__len__') == False — sequence protocol cross-check: sized half absent from Task; new to extra1471"]
    - [as1471sp004,
       "Task.__dict__.__contains__",
       ["__getitem__"],
       false,
       "asyncio.Task.__dict__.__contains__('__getitem__') == False — sequence protocol cross-check: subscript half absent from Task; new to extra1471"]
    - [as1471sp005,
       "Future.__dict__.__contains__",
       ["__len__"],
       false,
       "asyncio.Future.__dict__.__contains__('__len__') == False — sequence protocol cross-check: sized half absent from Future; new to extra1471"]
    - [as1471sp006,
       "Future.__dict__.__contains__",
       ["__getitem__"],
       false,
       "asyncio.Future.__dict__.__contains__('__getitem__') == False — sequence protocol cross-check: subscript half absent from Future; new to extra1471"]
    - [as1471sp007,
       "Semaphore.__dict__.__contains__",
       ["__len__"],
       false,
       "asyncio.Semaphore.__dict__.__contains__('__len__') == False — sequence protocol cross-check: sized half absent from Semaphore; new to extra1471"]
    - [as1471sp008,
       "Barrier.__dict__.__contains__",
       ["__getitem__"],
       false,
       "asyncio.Barrier.__dict__.__contains__('__getitem__') == False — sequence protocol cross-check: subscript half absent from Barrier; new to extra1471"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1471
# ---------------------------------------------------------------------------

invariant asyncio_extra1471.Queue_len_not_in_dict:
  description: "'__len__' not in asyncio.Queue.__dict__ — Queue does not define the sized protocol; wave 545; new to extra1471"
  kind: python_call_eq
  function: Queue.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant asyncio_extra1471.Queue_getitem_not_in_dict:
  description: "'__getitem__' not in asyncio.Queue.__dict__ — Queue does not define subscript access; wave 545; new to extra1471"
  kind: python_call_eq
  function: Queue.__dict__.__contains__
  args: ["__getitem__"]
  expected: false

invariant asyncio_extra1471.Task_len_not_in_dict:
  description: "'__len__' not in asyncio.Task.__dict__ — Task does not define the sized protocol; wave 545; new to extra1471"
  kind: python_call_eq
  function: Task.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant asyncio_extra1471.Future_getitem_not_in_dict:
  description: "'__getitem__' not in asyncio.Future.__dict__ — Future does not define subscript access; wave 545; new to extra1471"
  kind: python_call_eq
  function: Future.__dict__.__contains__
  args: ["__getitem__"]
  expected: false
