spec: just_truncate
version: ">=2.2.0"
backend: node(just-truncate)

docs: https://www.npmjs.com/package/just-truncate

provenance:
  derived_from:
    - "just-truncate README — https://www.npmjs.com/package/just-truncate"
    - "Test vectors verified with just-truncate via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "just-truncate source"
  notes:
    - "just-truncate is an npm package. Install: npm install just-truncate"
    - "Truncates a string to the given length, appending '...' (or custom string) if truncated."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_truncate.truncate:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: jtrunc

  columns: [id, args, expected]
  rows:
    - [short,    ["hello world", 5],           "he..."]
    - [no_cut,   ["hello", 10],                "hello"]
    - [custom,   ["hello world", 8, "..."],    "hello..."]
