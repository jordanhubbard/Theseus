spec: inspect_extra291
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module compile flags and namedtuple identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py, Include/cpython/code.h"
  notes:
    - "CO_OPTIMIZED=1, CO_NEWLOCALS=2, CO_VARARGS=4, CO_VARKEYWORDS=8, CO_NESTED=16, CO_GENERATOR=32, CO_NOFREE=64, CO_COROUTINE=128"
    - "inspect.FullArgSpec and inspect.Attribute are namedtuples; their base class is tuple"
    - "FullArgSpec.__module__ and Attribute.__module__ are both 'inspect'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table inspect_extra291.co_flags:
  description: "inspect module compile flag integer values"
  kind: python_call_eq
  category: identity
  id_prefix: ins291f

  columns: [id, function, args, expected, description]
  rows:
    - [ins291f_001, inspect.CO_OPTIMIZED.__eq__, [1], true, "CO_OPTIMIZED is 1"]
    - [ins291f_002, inspect.CO_NEWLOCALS.__eq__, [2], true, "CO_NEWLOCALS is 2"]
    - [ins291f_003, inspect.CO_VARARGS.__eq__, [4], true, "CO_VARARGS is 4"]
    - [ins291f_004, inspect.CO_VARKEYWORDS.__eq__, [8], true, "CO_VARKEYWORDS is 8"]
    - [ins291f_005, inspect.CO_NESTED.__eq__, [16], true, "CO_NESTED is 16"]
    - [ins291f_006, inspect.CO_GENERATOR.__eq__, [32], true, "CO_GENERATOR is 32"]
    - [ins291f_007, inspect.CO_NOFREE.__eq__, [64], true, "CO_NOFREE is 64"]
    - [ins291f_008, inspect.CO_COROUTINE.__eq__, [128], true, "CO_COROUTINE is 128"]

table inspect_extra291.namedtuple_identity:
  description: "inspect namedtuple class identity (name, module, base)"
  kind: python_call_eq
  category: identity
  id_prefix: ins291n

  columns: [id, function, args, expected, description]
  rows:
    - [ins291n_001, inspect.FullArgSpec.__name__.__eq__, ["FullArgSpec"], true, "FullArgSpec __name__ is 'FullArgSpec'"]
    - [ins291n_002, inspect.FullArgSpec.__module__.__eq__, ["inspect"], true, "FullArgSpec __module__ is 'inspect'"]
    - [ins291n_003, inspect.FullArgSpec.__base__.__name__.__eq__, ["tuple"], true, "FullArgSpec base class is tuple (namedtuple)"]
    - [ins291n_004, inspect.Attribute.__name__.__eq__, ["Attribute"], true, "Attribute __name__ is 'Attribute'"]
    - [ins291n_005, inspect.Attribute.__module__.__eq__, ["inspect"], true, "Attribute __module__ is 'inspect'"]
    - [ins291n_006, inspect.Attribute.__base__.__name__.__eq__, ["tuple"], true, "Attribute base class is tuple (namedtuple)"]

invariant inspect_extra291.inv_co_optimized:
  description: "inspect.CO_OPTIMIZED equals 1"
  category: identity
  kind: python_call_eq
  function: inspect.CO_OPTIMIZED.__eq__
  args: [1]
  expected: true

invariant inspect_extra291.inv_co_coroutine:
  description: "inspect.CO_COROUTINE equals 128"
  category: identity
  kind: python_call_eq
  function: inspect.CO_COROUTINE.__eq__
  args: [128]
  expected: true

invariant inspect_extra291.inv_fullargspec_base:
  description: "inspect.FullArgSpec base class is tuple"
  category: identity
  kind: python_call_eq
  function: inspect.FullArgSpec.__base__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra291.inv_attribute_module:
  description: "inspect.Attribute.__module__ is 'inspect'"
  category: identity
  kind: python_call_eq
  function: inspect.Attribute.__module__.__eq__
  args: ["inspect"]
  expected: true
