spec: statuses
version: ">=2.0.0"
backend: node(statuses)

docs: https://github.com/jshttp/statuses#readme

provenance:
  derived_from:
    - "statuses README — https://github.com/jshttp/statuses#readme"
    - "Test vectors verified with statuses@2.0.2 via Node.js 25.6.0 on macOS/Darwin 25.4.0, 2026-04-09"
    - "statuses source: index.js (MIT; source inspection permitted)"
    - "HTTP status code definitions — RFC 7231, RFC 7538, RFC 6585"
  not_derived_from: []
  notes:
    - "statuses exports a function: statuses(code) returns the status message string for a given HTTP code."
    - "The module also exposes statuses.message, statuses.redirect, statuses.empty, statuses.retry, and statuses.codes."
    - "Calling statuses(code) directly is the primary API: statuses(200) → 'OK'."
    - "statuses.message is a plain object mapping code numbers to message strings."
    - "statuses.redirect is a plain object with redirect code numbers as keys (values: true)."
    - "statuses.empty is a plain object with body-less response code numbers as keys (values: true)."
    - "The function: null form invokes node_module_call_eq as m(...args), i.e. statuses(code)."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "statuses(code) throws for unknown codes. All invariants in this spec use well-known codes. node exits 0 for all invariants."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# statuses(code) — HTTP status code → message string
# Calling the module directly as a function (function field omitted → m(...args)).
# ---------------------------------------------------------------------------

table statuses.message:
  kind: node_module_call_eq
  category: message
  id_prefix: status

  columns: [id, args, expected]
  rows:
    - [100_continue,           [100], "Continue"]
    - [101_switching_protocols,[101], "Switching Protocols"]
    - [200_ok,                 [200], "OK"]
    - [201_created,            [201], "Created"]
    - [204_no_content,         [204], "No Content"]
    - [301_moved_permanently,  [301], "Moved Permanently"]
    - [302_found,              [302], "Found"]
    - [304_not_modified,       [304], "Not Modified"]
    - [400_bad_request,        [400], "Bad Request"]
    - [401_unauthorized,       [401], "Unauthorized"]
    - [403_forbidden,          [403], "Forbidden"]
    - [404_not_found,          [404], "Not Found"]
    - [500_internal_server_error, [500], "Internal Server Error"]
    - [503_service_unavailable,   [503], "Service Unavailable"]
