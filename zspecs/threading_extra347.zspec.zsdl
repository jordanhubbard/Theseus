spec: threading_extra347
version: ">=3.2"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.current_thread().__class__.__name__ == '_MainThread' — when running in the main thread, current_thread() returns the main thread object."
    - "threading.current_thread().name == 'MainThread' — the main thread is always named 'MainThread'."
    - "threading.current_thread().daemon == False — the main thread is never a daemon thread."
    - "threading.current_thread().is_alive() == True — the main thread is alive while running."
    - "threading.main_thread().__class__.__name__ == '_MainThread' — main_thread() always returns the main thread object."
    - "threading.main_thread().name == 'MainThread' — main thread name is always 'MainThread'."
    - "threading.main_thread().is_alive() == True — the main thread is alive while running."
    - "threading.enumerate().__len__() == 1 — when only the main thread is running, enumerate() returns a one-element list."
    - "threading.current_thread() is threading.main_thread() — both return the same object when called from the main thread."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.current_thread() — class name, name, daemon, is_alive
#
# When the spec is evaluated in the main thread, current_thread() returns
# the _MainThread singleton.
# ---------------------------------------------------------------------------

invariant threading_extra347.current_thread.class_name:
  description: "threading.current_thread().__class__.__name__ == '_MainThread'"
  category: current_thread
  kind: python_call_eq
  function: current_thread().__class__.__name__.__eq__
  args: ["_MainThread"]
  expected: true

invariant threading_extra347.current_thread.name:
  description: "threading.current_thread().name == 'MainThread'"
  category: current_thread
  kind: python_call_eq
  function: current_thread().name.__eq__
  args: ["MainThread"]
  expected: true

invariant threading_extra347.current_thread.daemon:
  description: "threading.current_thread().daemon == False — main thread is never a daemon"
  category: current_thread
  kind: python_call_eq
  function: current_thread().daemon.__eq__
  args: [false]
  expected: true

invariant threading_extra347.current_thread.is_alive:
  description: "threading.current_thread().is_alive() == True"
  category: current_thread
  kind: python_call_eq
  function: current_thread().is_alive
  args: []
  expected: true

# ---------------------------------------------------------------------------
# threading.main_thread() — class name, name, is_alive
# ---------------------------------------------------------------------------

invariant threading_extra347.main_thread.class_name:
  description: "threading.main_thread().__class__.__name__ == '_MainThread'"
  category: main_thread
  kind: python_call_eq
  function: main_thread().__class__.__name__.__eq__
  args: ["_MainThread"]
  expected: true

invariant threading_extra347.main_thread.name:
  description: "threading.main_thread().name == 'MainThread'"
  category: main_thread
  kind: python_call_eq
  function: main_thread().name.__eq__
  args: ["MainThread"]
  expected: true

invariant threading_extra347.main_thread.is_alive:
  description: "threading.main_thread().is_alive() == True"
  category: main_thread
  kind: python_call_eq
  function: main_thread().is_alive
  args: []
  expected: true

# ---------------------------------------------------------------------------
# threading.enumerate() — length when only main thread is running
# ---------------------------------------------------------------------------

invariant threading_extra347.enumerate.length:
  description: "threading.enumerate().__len__() == 1 — only main thread running"
  category: enumerate
  kind: python_call_eq
  function: enumerate().__len__
  args: []
  expected: 1
