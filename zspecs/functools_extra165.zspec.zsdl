spec: functools_extra165
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.cached_property.__set_name__.__qualname__ 'cached_property.__set_name__'; functools.cached_property.__doc__.__class__.__name__ 'NoneType'; functools.cached_property.__init__.__qualname__ 'cached_property.__init__'; functools.cached_property.__get__.__qualname__ 'cached_property.__get__'; functools.lru_cache.__code__.co_argcount 2; functools.lru_cache.__code__.co_name 'lru_cache'; functools.cache.__code__.co_argcount 1; functools.cache.__code__.co_name 'cache' (Wave 289)."
    - "functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__' — cached_property is a Python descriptor class in Lib/functools.py; its __set_name__ method is called when the descriptor is assigned to a class attribute; __qualname__ is 'cached_property.__set_name__'. Verified with Python 3.14.3."
    - "functools.cached_property.__doc__.__class__.__name__ == 'NoneType' — cached_property has no class-level docstring; its __doc__ is None; None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3."
    - "functools.cached_property.__init__.__qualname__ == 'cached_property.__init__' — cached_property.__init__ initializes the descriptor with a callable; __qualname__ is 'cached_property.__init__'. Verified with Python 3.14.3."
    - "functools.cached_property.__get__.__qualname__ == 'cached_property.__get__' — cached_property.__get__ implements the descriptor protocol by computing and caching the property value on the instance; __qualname__ is 'cached_property.__get__'. Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_argcount == 2 — lru_cache(maxsize=128, typed=False) takes 2 positional-or-keyword arguments; co_argcount is 2. Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_name == 'lru_cache' — lru_cache is a Python function in Lib/functools.py; its code object co_name is 'lru_cache'. Verified with Python 3.14.3."
    - "functools.cache.__code__.co_argcount == 1 — cache(user_function) takes 1 positional-or-keyword argument; co_argcount is 1. Verified with Python 3.14.3."
    - "functools.cache.__code__.co_name == 'cache' — cache is a Python function in Lib/functools.py; its code object co_name is 'cache'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.cached_property descriptor method qualnames
#
# Wave 289 theme: functools.cached_property method __qualname__ attributes and
# __doc__ class.
#
# functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__'
# functools.cached_property.__doc__.__class__.__name__ == 'NoneType'
# functools.cached_property.__init__.__qualname__ == 'cached_property.__init__'
# functools.cached_property.__get__.__qualname__ == 'cached_property.__get__'
#
# functools.cached_property is a Python descriptor class defined in
# Lib/functools.py. It caches the result of a method call on the instance
# dict, so subsequent accesses return the cached value without calling the
# method again. __set_name__ is called by the metaclass when the descriptor
# is assigned to a class attribute — its __qualname__ is
# 'cached_property.__set_name__'. cached_property has no docstring (__doc__
# is None). __init__ and __get__ are normal Python instance methods whose
# __qualnames__ follow the 'cached_property.<method>' pattern. New to extra165.
# ---------------------------------------------------------------------------

table functools_extra165.cached_property_method_qualnames:
  description: "functools.cached_property: __set_name__ qualname 'cached_property.__set_name__', __doc__ class 'NoneType', __init__ qualname 'cached_property.__init__', __get__ qualname 'cached_property.__get__'; wave 289; new to extra165"
  kind: python_call_eq
  category: identity
  id_prefix: functoolscpropq165

  columns: [id, function, args, expected, description]
  rows:
    - [cprop_set_name_qn_eq,
       "cached_property.__set_name__.__qualname__.__eq__",
       ["cached_property.__set_name__"],
       true,
       "functools.cached_property.__set_name__.__qualname__.__eq__('cached_property.__set_name__') == True — cached_property is a descriptor class in Lib/functools.py; __set_name__ is called by the metaclass when the descriptor is assigned to a class attribute; its __qualname__ is 'cached_property.__set_name__'; str.__eq__('cached_property.__set_name__') returns True; new to extra165"]
    - [cprop_doc_class_eq_nonetype,
       "cached_property.__doc__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "functools.cached_property.__doc__.__class__.__name__.__eq__('NoneType') == True — cached_property has no class-level docstring; its __doc__ attribute is None; None.__class__.__name__ is 'NoneType'; str.__eq__('NoneType') returns True; new to extra165"]
    - [cprop_init_qn_eq,
       "cached_property.__init__.__qualname__.__eq__",
       ["cached_property.__init__"],
       true,
       "functools.cached_property.__init__.__qualname__.__eq__('cached_property.__init__') == True — cached_property.__init__ takes a callable and stores it; it also initialises the attrname and func attributes; its __qualname__ is 'cached_property.__init__'; str.__eq__('cached_property.__init__') returns True; new to extra165"]
    - [cprop_get_qn_eq,
       "cached_property.__get__.__qualname__.__eq__",
       ["cached_property.__get__"],
       true,
       "functools.cached_property.__get__.__qualname__.__eq__('cached_property.__get__') == True — cached_property.__get__ implements the descriptor get protocol; on the first access it calls the wrapped function and stores the result on the instance dict under the attribute name; its __qualname__ is 'cached_property.__get__'; str.__eq__('cached_property.__get__') returns True; new to extra165"]

# ---------------------------------------------------------------------------
# Table 2: functools.lru_cache and functools.cache code attributes
#
# Wave 289 theme: functools.lru_cache and functools.cache __code__ attributes.
#
# functools.lru_cache.__code__.co_argcount == 2
# functools.lru_cache.__code__.co_name == 'lru_cache'
# functools.cache.__code__.co_argcount == 1
# functools.cache.__code__.co_name == 'cache'
#
# functools.lru_cache(maxsize=128, typed=False) is a decorator factory
# implemented as a Python function in Lib/functools.py. It takes 2
# positional-or-keyword arguments (maxsize and typed); co_argcount is 2.
# functools.cache(user_function) is a simpler unbounded cache decorator that
# takes 1 positional-or-keyword argument (user_function); co_argcount is 1.
# Both are Python functions so their __code__.co_name matches their Python
# name. New to extra165.
# ---------------------------------------------------------------------------

table functools_extra165.lru_cache_and_cache_code_attrs:
  description: "functools.lru_cache: co_argcount 2, co_name 'lru_cache'; functools.cache: co_argcount 1, co_name 'cache'; wave 289; new to extra165"
  kind: python_call_eq
  category: identity
  id_prefix: functoolslcca165

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_co_argcount_eq_2,
       "lru_cache.__code__.co_argcount.__eq__",
       [2],
       true,
       "functools.lru_cache.__code__.co_argcount.__eq__(2) == True — lru_cache(maxsize=128, typed=False) takes 2 positional-or-keyword arguments: maxsize and typed; co_argcount is 2; int.__eq__(2) returns True; new to extra165"]
    - [lru_cache_co_name_eq,
       "lru_cache.__code__.co_name.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__code__.co_name.__eq__('lru_cache') == True — lru_cache is a Python function in Lib/functools.py that returns a least-recently-used cache decorator; its code object co_name is 'lru_cache'; str.__eq__('lru_cache') returns True; new to extra165"]
    - [cache_co_argcount_eq_1,
       "cache.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.cache.__code__.co_argcount.__eq__(1) == True — cache(user_function) is the unbounded cache decorator in Lib/functools.py; it takes 1 positional-or-keyword argument (user_function); co_argcount is 1; int.__eq__(1) returns True; new to extra165"]
    - [cache_co_name_eq,
       "cache.__code__.co_name.__eq__",
       ["cache"],
       true,
       "functools.cache.__code__.co_name.__eq__('cache') == True — cache is a Python function in Lib/functools.py implementing an unbounded cache equivalent to lru_cache(maxsize=None); its code object co_name is 'cache'; str.__eq__('cache') returns True; new to extra165"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra165
# ---------------------------------------------------------------------------

invariant functools_extra165.cprop_set_name_qualname:
  description: "functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__' — __set_name__ is called when descriptor is assigned to a class attr; wave 289; new to extra165"
  kind: python_call_eq
  function: cached_property.__set_name__.__qualname__.__eq__
  args: ["cached_property.__set_name__"]
  expected: true

invariant functools_extra165.cprop_doc_nonetype:
  description: "functools.cached_property.__doc__.__class__.__name__ == 'NoneType' — cached_property has no docstring; __doc__ is None; wave 289; new to extra165"
  kind: python_call_eq
  function: cached_property.__doc__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant functools_extra165.cprop_init_qualname:
  description: "functools.cached_property.__init__.__qualname__ == 'cached_property.__init__' — __init__ stores the wrapped callable; wave 289; new to extra165"
  kind: python_call_eq
  function: cached_property.__init__.__qualname__.__eq__
  args: ["cached_property.__init__"]
  expected: true

invariant functools_extra165.cprop_get_qualname:
  description: "functools.cached_property.__get__.__qualname__ == 'cached_property.__get__' — __get__ computes and caches the value on the instance dict; wave 289; new to extra165"
  kind: python_call_eq
  function: cached_property.__get__.__qualname__.__eq__
  args: ["cached_property.__get__"]
  expected: true

invariant functools_extra165.lru_cache_co_argcount_2:
  description: "functools.lru_cache.__code__.co_argcount == 2 — lru_cache(maxsize, typed) takes 2 args; wave 289; new to extra165"
  kind: python_call_eq
  function: lru_cache.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant functools_extra165.cache_co_argcount_1:
  description: "functools.cache.__code__.co_argcount == 1 — cache(user_function) takes 1 arg; unbounded cache decorator; wave 289; new to extra165"
  kind: python_call_eq
  function: cache.__code__.co_argcount.__eq__
  args: [1]
  expected: true
