spec: traceback_extra15
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends traceback.zspec.zsdl through traceback_extra14.zspec.zsdl."
    - "traceback_extra14 covers: format_exc/print_exc/format_tb/extract_tb __qualname__ as standalone invariants; TracebackException/StackSummary/FrameSummary __class__.__name__ == 'type' via table."
    - "Prior specs cover: __name__/__qualname__/__module__ for all 16 module-level functions; __bases__/__mro__ lengths for TracebackException/StackSummary/FrameSummary."
    - "NOT yet covered in any prior spec: __bases__.__len__ == 1 for TracebackException/StackSummary/FrameSummary as standalone invariants."
    - "NOT yet covered in any prior spec: MRO lengths for TracebackException (2) and FrameSummary (2) as standalone invariants."
    - "NOT yet covered in any prior spec: StackSummary MRO length (3) as a standalone invariant."
    - "NOT yet covered in any prior spec: print_tb/__qualname__, format_list/__qualname__, extract_stack/__qualname__ as standalone invariants."
    - "TracebackException.__mro__ == [TracebackException, object] — length 2."
    - "StackSummary.__mro__ == [StackSummary, list, object] — length 3; inherits from list."
    - "FrameSummary.__mro__ == [FrameSummary, object] — length 2."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __bases__ length — all three major traceback classes have exactly one
# direct base class
#
# No prior spec records __bases__.__len__() for any of these classes as a
# standalone invariant. Each has exactly one base: TracebackException inherits
# from object; StackSummary inherits from list; FrameSummary inherits from object.
# ---------------------------------------------------------------------------

invariant traceback_extra15.TracebackException.bases_len:
  description: "traceback.TracebackException.__bases__.__len__() == 1 — exactly one direct base"
  category: class_hierarchy
  kind: python_call_eq
  function: TracebackException.__bases__.__len__
  args: []
  expected: 1

invariant traceback_extra15.StackSummary.bases_len:
  description: "traceback.StackSummary.__bases__.__len__() == 1 — exactly one direct base (list)"
  category: class_hierarchy
  kind: python_call_eq
  function: StackSummary.__bases__.__len__
  args: []
  expected: 1

invariant traceback_extra15.FrameSummary.bases_len:
  description: "traceback.FrameSummary.__bases__.__len__() == 1 — exactly one direct base"
  category: class_hierarchy
  kind: python_call_eq
  function: FrameSummary.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# MRO lengths — TracebackException, StackSummary, FrameSummary
#
# No prior spec records mro() length as a standalone invariant for any of
# these three classes. TracebackException and FrameSummary have MRO length 2
# (class + object). StackSummary has MRO length 3 (class + list + object).
# ---------------------------------------------------------------------------

table traceback_extra15.mro_lengths:
  description: "MRO lengths for TracebackException (2), StackSummary (3), FrameSummary (2)"
  kind: python_call_eq
  category: class_hierarchy

  columns: [id, function, args, expected]
  rows:
    - [TracebackException, TracebackException.mro, [], 2]
    - [StackSummary,       StackSummary.mro,       [], 3]
    - [FrameSummary,       FrameSummary.mro,       [], 2]

# ---------------------------------------------------------------------------
# Module-level functions — __qualname__ as standalone invariants
#
# traceback_extra14 covers __qualname__ for format_exc, print_exc, format_tb,
# and extract_tb as standalone invariants. The remaining prominent functions
# — print_tb, format_list, and extract_stack — have not yet been recorded
# as standalone qualname invariants. For top-level functions, __qualname__
# == __name__ in all cases.
# ---------------------------------------------------------------------------

invariant traceback_extra15.print_tb.qualname:
  description: "traceback.print_tb.__qualname__ == 'print_tb'"
  category: function_identity
  kind: python_call_eq
  function: print_tb.__qualname__.__eq__
  args: ["print_tb"]
  expected: true

invariant traceback_extra15.format_list.qualname:
  description: "traceback.format_list.__qualname__ == 'format_list'"
  category: function_identity
  kind: python_call_eq
  function: format_list.__qualname__.__eq__
  args: ["format_list"]
  expected: true

invariant traceback_extra15.extract_stack.qualname:
  description: "traceback.extract_stack.__qualname__ == 'extract_stack'"
  category: function_identity
  kind: python_call_eq
  function: extract_stack.__qualname__.__eq__
  args: ["extract_stack"]
  expected: true
