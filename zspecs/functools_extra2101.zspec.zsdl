spec: functools_extra2101
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2101 (_extra2101): __class_getitem__, __init_subclass__, __subclasshook__, __mro_entries__ dict-presence checks for functools types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "functools.partial defines __class_getitem__ in its own __dict__ (True) — it is a C extension type that explicitly supports generic alias syntax (e.g. partial[int])."
    - "functools.partialmethod defines __class_getitem__ in its own __dict__ (True) — the pure-Python partialmethod class explicitly defines __class_getitem__ for generic alias support."
    - "functools.cached_property defines __class_getitem__ in its own __dict__ (True) — cached_property explicitly defines __class_getitem__ to support subscript syntax."
    - "functools._lru_cache_wrapper does NOT define __class_getitem__ in its own __dict__ (False) — the wrapper type is an internal C type and has not been given explicit generic alias support."
    - "functools.singledispatchmethod does NOT define __class_getitem__ in its own __dict__ (False)."
    - "None of the functools types define __init_subclass__ in their own __dict__ — they rely on the inherited object.__init_subclass__ classmethod."
    - "None of the functools types define __subclasshook__ in their own __dict__ — __subclasshook__ is exclusively used by ABCMeta virtual subclass machinery."
    - "None of the functools types define __mro_entries__ in their own __dict__ — __mro_entries__ is used by typing generics, not by functools wrapper types."
    - "_CacheInfo namedtuple and _PlaceholderType do not define any of the four protocol dunders in their own __dict__."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __class_getitem__ dict-presence for functools types
#
# partial, partialmethod, cached_property: True
# _lru_cache_wrapper, singledispatchmethod, _CacheInfo, _PlaceholderType: False
# ---------------------------------------------------------------------------

table functools_extra2101.class_getitem_protocol:
  description: "functools types __class_getitem__ dict-presence checks — partial/partialmethod/cached_property True, others False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2101

  columns: [id, function, args, expected]
  rows:
    - ["ft2101001", "functools.partial.__dict__.__contains__", ["__class_getitem__"], true]
    - ["ft2101002", "functools.partialmethod.__dict__.__contains__", ["__class_getitem__"], true]
    - ["ft2101003", "functools.cached_property.__dict__.__contains__", ["__class_getitem__"], true]
    - ["ft2101004", "functools._lru_cache_wrapper.__dict__.__contains__", ["__class_getitem__"], false]
    - ["ft2101005", "functools.singledispatchmethod.__dict__.__contains__", ["__class_getitem__"], false]
    - ["ft2101006", "functools._CacheInfo.__dict__.__contains__", ["__class_getitem__"], false]
    - ["ft2101007", "functools._PlaceholderType.__dict__.__contains__", ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Table 2: __init_subclass__ dict-presence for functools types
#
# None of the functools types define __init_subclass__ in their own __dict__.
# They all inherit object.__init_subclass__ through the normal MRO.
# ---------------------------------------------------------------------------

table functools_extra2101.init_subclass_protocol:
  description: "functools types __init_subclass__ dict-presence checks — all False (inherited from object)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2101

  columns: [id, function, args, expected]
  rows:
    - ["ft2101008", "functools.partial.__dict__.__contains__", ["__init_subclass__"], false]
    - ["ft2101009", "functools.partialmethod.__dict__.__contains__", ["__init_subclass__"], false]
    - ["ft2101010", "functools.cached_property.__dict__.__contains__", ["__init_subclass__"], false]
    - ["ft2101011", "functools._lru_cache_wrapper.__dict__.__contains__", ["__init_subclass__"], false]
    - ["ft2101012", "functools.singledispatchmethod.__dict__.__contains__", ["__init_subclass__"], false]
    - ["ft2101013", "functools._CacheInfo.__dict__.__contains__", ["__init_subclass__"], false]
    - ["ft2101014", "functools._PlaceholderType.__dict__.__contains__", ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Table 3: __subclasshook__ dict-presence for functools types
#
# __subclasshook__ is the ABCMeta virtual subclass protocol.
# None of the functools types define it in their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra2101.subclasshook_protocol:
  description: "functools types __subclasshook__ dict-presence checks — all False (not ABC-based)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2101

  columns: [id, function, args, expected]
  rows:
    - ["ft2101015", "functools.partial.__dict__.__contains__", ["__subclasshook__"], false]
    - ["ft2101016", "functools.partialmethod.__dict__.__contains__", ["__subclasshook__"], false]
    - ["ft2101017", "functools.cached_property.__dict__.__contains__", ["__subclasshook__"], false]
    - ["ft2101018", "functools._lru_cache_wrapper.__dict__.__contains__", ["__subclasshook__"], false]
    - ["ft2101019", "functools.singledispatchmethod.__dict__.__contains__", ["__subclasshook__"], false]
    - ["ft2101020", "functools._CacheInfo.__dict__.__contains__", ["__subclasshook__"], false]
    - ["ft2101021", "functools._PlaceholderType.__dict__.__contains__", ["__subclasshook__"], false]

# ---------------------------------------------------------------------------
# Table 4: __mro_entries__ dict-presence for functools types
#
# __mro_entries__ is used by types that act as generic aliases in base-class
# position (e.g. list[int] in a class bases tuple). None of the functools
# wrapper types define it in their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra2101.mro_entries_protocol:
  description: "functools types __mro_entries__ dict-presence checks — all False (not MRO-entry types)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2101

  columns: [id, function, args, expected]
  rows:
    - ["ft2101022", "functools.partial.__dict__.__contains__", ["__mro_entries__"], false]
    - ["ft2101023", "functools.partialmethod.__dict__.__contains__", ["__mro_entries__"], false]
    - ["ft2101024", "functools.cached_property.__dict__.__contains__", ["__mro_entries__"], false]
    - ["ft2101025", "functools._lru_cache_wrapper.__dict__.__contains__", ["__mro_entries__"], false]
    - ["ft2101026", "functools.singledispatchmethod.__dict__.__contains__", ["__mro_entries__"], false]
    - ["ft2101027", "functools._CacheInfo.__dict__.__contains__", ["__mro_entries__"], false]
    - ["ft2101028", "functools._PlaceholderType.__dict__.__contains__", ["__mro_entries__"], false]
