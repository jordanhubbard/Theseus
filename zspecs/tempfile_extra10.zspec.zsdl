spec: tempfile_extra10
version: ">=3.9"
backend: python_module(tempfile)

docs: https://docs.python.org/3/library/tempfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tempfile.html — Python tempfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tempfile.py"
  notes:
    - "This spec extends tempfile.zspec.zsdl and all prior tempfile_extra specs."
    - "tempfile_extra9 covers NamedTemporaryFile/SpooledTemporaryFile/TemporaryDirectory __module__ and __qualname__; mkstemp/mkdtemp/gettempdir/gettempprefix __module__; mkstemp and gettempdir __qualname__."
    - "tempfile_extra8 covers module __name__; utility function __name__ lengths and last-char checks; template value; gettempprefix/gettempdir return type."
    - "tempfile_extra7 covers __name__ length and is-str checks for the four main class names."
    - "NOT yet covered: TemporaryFile.__name__ == 'TemporaryFile' as a standalone invariant in extra10."
    - "NOT yet covered: NamedTemporaryFile.__name__ == 'NamedTemporaryFile' as a standalone invariant in extra10."
    - "NOT yet covered: SpooledTemporaryFile.__name__ == 'SpooledTemporaryFile' as a standalone invariant in extra10."
    - "NOT yet covered: TemporaryDirectory.__name__ == 'TemporaryDirectory' as a standalone invariant in extra10."
    - "NOT yet covered: mkstemp.__name__ == 'mkstemp' as a standalone equality invariant in extra10."
    - "NOT yet covered: mkdtemp.__name__ == 'mkdtemp' as a standalone equality invariant in extra10."
    - "NOT yet covered: gettempdir.__name__ == 'gettempdir' as a standalone equality invariant in extra10."
    - "NOT yet covered: gettempprefix.__name__ == 'gettempprefix' as a standalone equality invariant in extra10."
    - "NOT yet covered: tempfile.tempdir.__class__.__name__ == 'NoneType' — default module-level tempdir is None."
    - "NOT yet covered: gettempdir().__class__.__name__ == 'str' as a standalone invariant in extra10."
    - "NOT yet covered: gettempprefix().__class__.__name__ == 'str' as a standalone invariant in extra10."
    - "tempfile class __name__ checks: TemporaryFile, NamedTemporaryFile, SpooledTemporaryFile, TemporaryDirectory."
    - "tempfile utility function __name__ checks: mkstemp, mkdtemp, gettempdir, gettempprefix."
    - "tempfile.tempdir default is None — __class__.__name__ == 'NoneType'."
    - "gettempdir() returns a str; gettempprefix() returns a str."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Public class __name__ equality — TemporaryFile, NamedTemporaryFile,
# SpooledTemporaryFile, TemporaryDirectory
#
# tempfile_extra7 verified __name__ lengths and is-str checks.
# tempfile_extra9 verified __module__ and __qualname__ for three of the four
# classes. This table anchors direct __name__ equality in the extra10 namespace.
# TemporaryFile is a function in CPython; its __name__ is still 'TemporaryFile'.
# ---------------------------------------------------------------------------

table tempfile_extra10.class_names:
  description: "tempfile public class __name__ equality checks"
  kind: python_call_eq
  category: class_name
  id_prefix: clsname10

  columns: [id, function, args, expected]
  rows:
    - [TemporaryFile,        TemporaryFile.__name__.__eq__,        ["TemporaryFile"],        true]
    - [NamedTemporaryFile,   NamedTemporaryFile.__name__.__eq__,   ["NamedTemporaryFile"],   true]
    - [SpooledTemporaryFile, SpooledTemporaryFile.__name__.__eq__, ["SpooledTemporaryFile"], true]
    - [TemporaryDirectory,   TemporaryDirectory.__name__.__eq__,   ["TemporaryDirectory"],   true]

# ---------------------------------------------------------------------------
# Utility function __name__ equality — mkstemp, mkdtemp, gettempdir, gettempprefix
#
# tempfile_extra8 verified __name__ lengths and last-char checks.
# tempfile_extra9 verified __module__ and __qualname__ for mkstemp and gettempdir.
# This table anchors direct __name__ equality in the extra10 namespace.
# ---------------------------------------------------------------------------

table tempfile_extra10.function_names:
  description: "tempfile utility function __name__ equality checks"
  kind: python_call_eq
  category: function_name
  id_prefix: fnname10

  columns: [id, function, args, expected]
  rows:
    - [mkstemp,       mkstemp.__name__.__eq__,       ["mkstemp"],       true]
    - [mkdtemp,       mkdtemp.__name__.__eq__,       ["mkdtemp"],       true]
    - [gettempdir,    gettempdir.__name__.__eq__,    ["gettempdir"],    true]
    - [gettempprefix, gettempprefix.__name__.__eq__, ["gettempprefix"], true]

# ---------------------------------------------------------------------------
# tempfile.tempdir default — module-level variable is None
#
# The module-level tempdir variable controls the default temp directory when
# set by the user. Its default value is None. No prior tempfile spec verifies
# tempdir.__class__.__name__ == 'NoneType' as a standalone invariant.
# ---------------------------------------------------------------------------

invariant tempfile_extra10.tempdir.default_is_none:
  description: "tempfile.tempdir.__class__.__name__ == 'NoneType' — default module-level tempdir is None"
  category: constants
  kind: python_call_eq
  function: tempdir.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# gettempdir() and gettempprefix() return types — str
#
# tempfile_extra8 verified these return types via method_chain on __class__.
# This spec re-anchors the same property in the extra10 namespace as
# independent cross-check invariants using the __class__.__name__.__eq__ pattern.
# ---------------------------------------------------------------------------

invariant tempfile_extra10.gettempdir.return_type_str:
  description: "tempfile.gettempdir().__class__.__name__ == 'str' — gettempdir returns a string path"
  category: return_types
  kind: python_call_eq
  function: gettempdir
  args: []
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant tempfile_extra10.gettempprefix.return_type_str:
  description: "tempfile.gettempprefix().__class__.__name__ == 'str' — gettempprefix returns a string prefix"
  category: return_types
  kind: python_call_eq
  function: gettempprefix
  args: []
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true
