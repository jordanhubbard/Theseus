spec: pathlib_extra1771
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath name/stem/suffix/parts/parent/joinpath/str/as_posix/relative_to"
    - "pathlib_extra.zspec.zsdl — covers Path/PurePosixPath class names, components, joining, parts"
  notes:
    - "Wave 565, theme: async protocol. All five async dunder methods are absent from pathlib types."
    - "PurePath.__dict__ directly defines parts, parent, parents, name, stem, suffix as properties."
    - "PurePath is the abstract base for all pure path types; PurePosixPath and PureWindowsPath inherit from it."
    - "All expected values verified by running Python 3.14 pathlib module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Async protocol — pathlib types do NOT define any async dunder in their own __dict__
# Wave 565 theme: __aenter__, __aexit__, __aiter__, __anext__, __await__
# ---------------------------------------------------------------------------

table pathlib_extra1771.async_protocol:
  kind: python_call_eq
  category: async_protocol
  id_prefix: pl1771

  columns: [id, function, args, expected]
  rows:
    - ["pl1771001", PurePath.__dict__.__contains__,      ["__aenter__"], false]
    - ["pl1771002", PurePath.__dict__.__contains__,      ["__aexit__"],  false]
    - ["pl1771003", PurePath.__dict__.__contains__,      ["__aiter__"],  false]
    - ["pl1771004", PurePath.__dict__.__contains__,      ["__anext__"],  false]
    - ["pl1771005", PurePath.__dict__.__contains__,      ["__await__"],  false]
    - ["pl1771006", PurePosixPath.__dict__.__contains__, ["__aenter__"], false]
    - ["pl1771007", PurePosixPath.__dict__.__contains__, ["__aexit__"],  false]
    - ["pl1771008", PurePosixPath.__dict__.__contains__, ["__aiter__"],  false]
    - ["pl1771009", PurePosixPath.__dict__.__contains__, ["__anext__"],  false]
    - ["pl1771010", PurePosixPath.__dict__.__contains__, ["__await__"],  false]

# ---------------------------------------------------------------------------
# Complementary: PurePath.__dict__ defines path component properties directly
# parts, parent, parents, name, stem, suffix are all on PurePath itself
# ---------------------------------------------------------------------------

table pathlib_extra1771.purepath_dict_properties:
  kind: python_call_eq
  category: dict_membership
  id_prefix: pl1771

  columns: [id, function, args, expected]
  rows:
    - ["pl1771011", PurePath.__dict__.__contains__, ["parts"],   true]
    - ["pl1771012", PurePath.__dict__.__contains__, ["parent"],  true]
    - ["pl1771013", PurePath.__dict__.__contains__, ["parents"], true]
    - ["pl1771014", PurePath.__dict__.__contains__, ["name"],    true]
    - ["pl1771015", PurePath.__dict__.__contains__, ["stem"],    true]
    - ["pl1771016", PurePath.__dict__.__contains__, ["suffix"],  true]

# ---------------------------------------------------------------------------
# Class identity
# ---------------------------------------------------------------------------

invariant pathlib_extra1771.PurePath.class_name:
  description: "pathlib.PurePath.__name__ == 'PurePath'"
  category: class_metadata
  kind: python_call_eq
  function: PurePath.__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra1771.PurePath.module:
  description: "pathlib.PurePath.__module__ == 'pathlib'"
  category: class_metadata
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra1771.PurePosixPath.class_name:
  description: "pathlib.PurePosixPath.__name__ == 'PurePosixPath'"
  category: class_metadata
  kind: python_call_eq
  function: PurePosixPath.__name__.__eq__
  args: ["PurePosixPath"]
  expected: true

invariant pathlib_extra1771.PureWindowsPath.class_name:
  description: "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath'"
  category: class_metadata
  kind: python_call_eq
  function: PureWindowsPath.__name__.__eq__
  args: ["PureWindowsPath"]
  expected: true

invariant pathlib_extra1771.Path.class_name:
  description: "pathlib.Path.__name__ == 'Path'"
  category: class_metadata
  kind: python_call_eq
  function: Path.__name__.__eq__
  args: ["Path"]
  expected: true

invariant pathlib_extra1771.Path.module:
  description: "pathlib.Path.__module__ == 'pathlib'"
  category: class_metadata
  kind: python_call_eq
  function: Path.__module__.__eq__
  args: ["pathlib"]
  expected: true
