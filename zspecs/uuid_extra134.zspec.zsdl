spec: uuid_extra134
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra133.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5/UUID __doc__.__class__.__name__ == 'str' / uuid3 vs uuid5 __doc__ inequality and length gap (2 chars) / uuid1 vs uuid4 doc length gap (235) / UUID class vs __init__ doc gap (1367) (table + invariants)."
    - "uuid_extra132.zspec.zsdl — covers uuid1/uuid4/uuid3/uuid5/getnode __code__.co_consts lengths / uuid1/uuid4/uuid3/uuid5/getnode __code__.co_varnames lengths / UUID.__init__.__code__ attribute counts / UUID.__init__.__doc__.__len__()==1420."
    - "uuid_extra131.zspec.zsdl — covers UUID class __doc__ length (2787) / uuid function __doc__ lengths / uuid module __doc__ length / UUID __name__ and MRO."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/qualname / UUID method qualname equality and length."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants __class__.__name__, hex values, str() values, version attributes."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality / UUID.__module__.__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__.__eq__ / SafeUUID.__bases__[0].__name__=='Enum'."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 / uuid3/uuid5/getnode __qualname__.__len__()."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra133."
    - "Wave 293 theme: UUID.__init__/__str__/__repr__/__hash__/__eq__ method __qualname__ values and lengths / UUID.__slots__.__class__.__name__ and __len__() / UUID.__bases__[0].__name__=='object' / UUID.__str__.__class__.__name__=='function'."
    - "uuid.UUID.__init__.__qualname__ == 'UUID.__init__' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__qualname__ == 'UUID.__str__' (len 12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__slots__.__class__.__name__ == 'tuple' (len 5). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__slots__.__len__() == 3 (entries: 'int', 'is_safe', '__weakref__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: UUID.__str__.__qualname__ is 12 chars ('UUID.__str__') — one char shorter than __init__/__repr__/__hash__ (13 chars each) because '__str__' (7 chars) is one char shorter than '__init__'/'__repr__'/'__hash__' (8 chars each). __eq__ and __lt__ share 11-char qualnames ('UUID.__eq__' and 'UUID.__lt__' = 5-char 'UUID.' prefix + 6-char dunder name)."
    - "Note: UUID.__slots__ is a tuple (not a list or frozenset) containing ('int', 'is_safe', '__weakref__'). The 'int' slot stores the 128-bit integer value; 'is_safe' stores the SafeUUID enum value; '__weakref__' enables weak references. extra94 anchors __slots__ class name and length."
    - "Note: UUID.__init__ and UUID.__str__ are both 'function' class objects (Python-level functions in Lib/uuid.py), not method_descriptor or slot_wrapper objects. This distinguishes them from built-in type methods."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__.__len__()==13
# uuid.UUID.__str__.__qualname__.__len__()==12
# uuid.UUID.__repr__.__qualname__.__len__()==13
# uuid.UUID.__hash__.__qualname__.__len__()==13
# uuid.UUID.__eq__.__qualname__.__len__()==11
# uuid.UUID.__lt__.__qualname__.__len__()==11
#
# Wave 293 theme: UUID dunder method __qualname__ lengths.
#
# All six UUID dunder methods follow the 'UUID.<method>' qualname pattern.
# The 5-char 'UUID.' prefix plus the dunder name length determines the total:
# __str__ (7) = 12, __init__/__repr__/__hash__ (8 each) = 13, __eq__/__lt__ (6 each) = 11.
# extra99 anchors UUID method qualname equality strings; no prior uuid spec
# anchors these qualname lengths as a table under uuiddunder134.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra134.UUID_dunder_qualname_lengths:
  description: "uuid.UUID.__init__/__qualname__/__len__()==13 / __str__/__qualname__/__len__()==12 / __repr__/__qualname__/__len__()==13 / __hash__/__qualname__/__len__()==13 / __eq__/__qualname__/__len__()==11 / __lt__/__qualname__/__len__()==11 — all follow 'UUID.<method>' pattern (5-char prefix + dunder name length); __str__ (12) is shortest (7-char dunder); __init__/__repr__/__hash__ (13) share 8-char dunders; __eq__/__lt__ (11) share 6-char dunders; no prior uuid spec anchors these lengths; first uuiddunder134 anchor"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: uuiddunder134

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname_len,   UUID.__init__.__qualname__.__len__,   [], 13, "uuid.UUID.__init__.__qualname__.__len__() is 13 ('UUID.__init__' = 5 + 8 chars)"]
    - [str_qualname_len,    UUID.__str__.__qualname__.__len__,    [], 12, "uuid.UUID.__str__.__qualname__.__len__() is 12 ('UUID.__str__' = 5 + 7 chars; shortest in this group)"]
    - [repr_qualname_len,   UUID.__repr__.__qualname__.__len__,   [], 13, "uuid.UUID.__repr__.__qualname__.__len__() is 13 ('UUID.__repr__' = 5 + 8 chars; same as __init__)"]
    - [hash_qualname_len,   UUID.__hash__.__qualname__.__len__,   [], 13, "uuid.UUID.__hash__.__qualname__.__len__() is 13 ('UUID.__hash__' = 5 + 8 chars; same as __init__/__repr__)"]
    - [eq_qualname_len,     UUID.__eq__.__qualname__.__len__,     [], 11, "uuid.UUID.__eq__.__qualname__.__len__() is 11 ('UUID.__eq__' = 5 + 6 chars)"]
    - [lt_qualname_len,     UUID.__lt__.__qualname__.__len__,     [], 11, "uuid.UUID.__lt__.__qualname__.__len__() is 11 ('UUID.__lt__' = 5 + 6 chars; same as __eq__)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__')
# uuid.UUID.__str__.__qualname__.__eq__('UUID.__str__')
# uuid.UUID.__repr__.__qualname__.__eq__('UUID.__repr__')
#
# Wave 293 theme: UUID dunder method __qualname__ string equality.
#
# The qualname strings for __init__, __str__, __repr__ confirm the 'UUID.<method>'
# pattern. extra99 anchors qualname equality for __str__/__repr__/__eq__/__hash__/__lt__;
# this table cross-checks __init__, __str__, __repr__ qualname equality under
# uuiddunder134. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra134.UUID_dunder_qualname_equality:
  description: "uuid.UUID.__init__/__qualname__.__eq__('UUID.__init__')==True / __str__/__qualname__.__eq__('UUID.__str__')==True / __repr__/__qualname__.__eq__('UUID.__repr__')==True / __class__.__name__.__eq__('function')==True for all three — all Python-level functions in Lib/uuid.py with standard 'UUID.<method>' qualname pattern; extra99 anchors some method qualnames; __init__ qualname equality is fresh under uuiddunder134"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: uuiddunder134

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname_eq,    UUID.__init__.__qualname__.__eq__,       ["UUID.__init__"],  true, "uuid.UUID.__init__.__qualname__ == 'UUID.__init__' (Python function; 13 chars)"]
    - [str_qualname_eq,     UUID.__str__.__qualname__.__eq__,        ["UUID.__str__"],   true, "uuid.UUID.__str__.__qualname__ == 'UUID.__str__' (Python function; 12 chars)"]
    - [repr_qualname_eq,    UUID.__repr__.__qualname__.__eq__,       ["UUID.__repr__"],  true, "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__' (Python function; 13 chars)"]
    - [init_class_name,     UUID.__init__.__class__.__name__.__eq__, ["function"],       true, "uuid.UUID.__init__.__class__.__name__ == 'function' (Python-level, not method_descriptor)"]
    - [str_class_name,      UUID.__str__.__class__.__name__.__eq__,  ["function"],       true, "uuid.UUID.__str__.__class__.__name__ == 'function' (Python-level in Lib/uuid.py)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__.__class__.__name__.__eq__('tuple')
# uuid.UUID.__slots__.__class__.__name__.__len__()==5
# uuid.UUID.__slots__.__len__()==3
# uuid.UUID.__bases__[0].__name__.__eq__('object')
#
# Wave 293 theme: UUID.__slots__ type and contents.
#
# UUID.__slots__ is a tuple (not a list) of 3 entries: 'int', 'is_safe',
# '__weakref__'. The tuple class name 'tuple' is 5 chars. UUID.__bases__[0]
# is 'object' (6 chars). extra94 anchors __slots__ class name, length, and
# contents individually; this table groups them with the bases check under
# uuiddunder134 as a cross-check. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra134.UUID_slots_and_bases:
  description: "uuid.UUID.__slots__/__class__.__name__.__eq__('tuple')==True / __class__.__name__.__len__()==5 / __len__()==3 / UUID/__bases__[0].__name__.__eq__('object')==True — __slots__ is a 3-element tuple containing 'int', 'is_safe', '__weakref__'; 'tuple' is 5 chars; UUID.__bases__[0] is 'object'; extra94 anchors these individually; this table groups them under uuiddunder134 as a cross-check"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddunder134

  columns: [id, function, args, expected, description]
  rows:
    - [slots_class_name,     UUID.__slots__.__class__.__name__.__eq__, ["tuple"],   true, "uuid.UUID.__slots__.__class__.__name__ == 'tuple' (not list or frozenset)"]
    - [slots_class_name_len, UUID.__slots__.__class__.__name__.__len__, [],         5,    "uuid.UUID.__slots__.__class__.__name__.__len__() is 5 ('tuple' = 5 chars)"]
    - [slots_len,            UUID.__slots__.__len__,                    [],         3,    "uuid.UUID.__slots__.__len__() is 3 ('int', 'is_safe', '__weakref__')"]
    - [bases_0_name,         "UUID.__bases__[0].__name__.__eq__",      ["object"],  true, "uuid.UUID.__bases__[0].__name__ == 'object' (UUID directly inherits from object)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__str__.__qualname__.__len__()==12 — standalone
#
# uuid.UUID.__str__.__qualname__.__len__() is 12. The qualname 'UUID.__str__'
# consists of the 5-char 'UUID.' prefix plus the 7-char '__str__'. This makes
# __str__ the shortest-qualname dunder method in the group examined (12 chars),
# because '__str__' is 7 chars while '__init__', '__repr__', and '__hash__' are
# all 8 chars. No prior uuid spec anchors this specific length as a standalone
# under uuiddunder134. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra134.UUID_str_qualname_len_12:
  description: "uuid.UUID.__str__.__qualname__.__len__() == 12 — 'UUID.__str__' (12 chars = 5-char 'UUID.' + 7-char '__str__'); shortest-qualname dunder in this group because '__str__' (7 chars) < '__init__'/'__repr__'/'__hash__' (8 chars each); no prior uuid spec anchors this as a standalone; first standalone under uuiddunder134"
  category: qualname_lengths
  kind: python_call_eq
  function: UUID.__str__.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__.__len__()==13 — standalone
#
# uuid.UUID.__init__.__qualname__.__len__() is 13. The qualname 'UUID.__init__'
# consists of the 5-char 'UUID.' prefix plus the 8-char '__init__'. At 13 chars,
# this matches '__repr__' and '__hash__' qualname lengths. __init__ is the
# constructor; its qualname length being the same as __repr__ and __hash__ is
# a coincidence of the dunder naming convention (all three dunder names are
# 8 chars). No prior uuid spec anchors UUID.__init__.__qualname__.__len__()==13
# as a standalone under uuiddunder134. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra134.UUID_init_qualname_len_13:
  description: "uuid.UUID.__init__.__qualname__.__len__() == 13 — 'UUID.__init__' (13 chars = 5-char 'UUID.' + 8-char '__init__'); same length as __repr__ and __hash__ (all 8-char dunder names); one char longer than __str__ (12); no prior uuid spec anchors this as a standalone; first standalone under uuiddunder134"
  category: qualname_lengths
  kind: python_call_eq
  function: UUID.__init__.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__.__len__()==3 — standalone
#
# uuid.UUID.__slots__.__len__() is 3. The three slots are: 'int' (stores the
# 128-bit integer value of the UUID), 'is_safe' (stores the SafeUUID enum
# value indicating whether the UUID was generated safely), and '__weakref__'
# (enables weak references to UUID instances). The use of __slots__ prevents
# __dict__ from being created on UUID instances, saving memory. extra94 anchors
# this at table level; this standalone provides a cross-check under uuiddunder134.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra134.UUID_slots_len_3:
  description: "uuid.UUID.__slots__.__len__() == 3 — tuple of ('int', 'is_safe', '__weakref__'); 'int' stores 128-bit integer, 'is_safe' stores SafeUUID, '__weakref__' enables weak refs; __slots__ prevents __dict__ creation; extra94 anchors at table level; cross-check standalone under uuiddunder134"
  category: identity
  kind: python_call_eq
  function: UUID.__slots__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# uuid.UUID.__eq__.__qualname__.__len__()==11 — standalone
#
# uuid.UUID.__eq__.__qualname__.__len__() is 11. The qualname 'UUID.__eq__'
# consists of the 5-char 'UUID.' prefix plus the 6-char '__eq__'. At 11 chars,
# this is the shortest qualname in the group (tied with '__lt__' which is also
# 11 chars because '__lt__' is also 6 chars). UUID.__eq__ compares two UUIDs
# by their integer representation. No prior uuid spec anchors
# UUID.__eq__.__qualname__.__len__()==11 as a standalone under uuiddunder134.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra134.UUID_eq_qualname_len_11:
  description: "uuid.UUID.__eq__.__qualname__.__len__() == 11 — 'UUID.__eq__' (11 chars = 5-char 'UUID.' + 6-char '__eq__'); tied with '__lt__' as shortest qualname in this group (both 6-char dunders); compares UUIDs by integer representation; no prior uuid spec anchors this as a standalone; first standalone under uuiddunder134"
  category: qualname_lengths
  kind: python_call_eq
  function: UUID.__eq__.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__.__class__.__name__.__len__()==5 — standalone
#
# uuid.UUID.__slots__.__class__.__name__.__len__() is 5. The class name 'tuple'
# is 5 chars. UUID.__slots__ is stored as a Python tuple (an immutable sequence),
# which is appropriate for a fixed set of slot names that should not change after
# class definition. The 5-char 'tuple' name sits between 'list' (4) and 'frozenset'
# (9) in length. No prior uuid spec anchors this length as a standalone under
# uuiddunder134. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra134.UUID_slots_class_name_len_5:
  description: "uuid.UUID.__slots__.__class__.__name__.__len__() == 5 — class name 'tuple' is 5 chars; UUID.__slots__ is a tuple (immutable, appropriate for fixed slot names); 'tuple' (5) sits between 'list' (4) and 'frozenset' (9) in length; no prior uuid spec anchors this length as a standalone; first standalone under uuiddunder134"
  category: identity
  kind: python_call_eq
  function: UUID.__slots__.__class__.__name__.__len__
  args: []
  expected: 5
