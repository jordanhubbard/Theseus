spec: abc_extra1621
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __weakref__ and weak reference protocol"
    - "abc.ABC defines __slots__ = () explicitly; because it adds no __weakref__ slot and its C-level base (object) already owns the __weakref__ descriptor, ABC.__dict__.__contains__('__weakref__') is False"
    - "abc.ABCMeta is a metaclass (type subclass) implemented in C via _abc; ABCMeta.__dict__.__contains__('__weakref__') is False because it is a C extension type"
    - "Pure Python subclasses of abc.ABC that do NOT define __slots__ automatically receive __weakref__ in their own class __dict__ because Python's type machinery adds it for each class that does not inherit it from a Python-visible class dict entry"
    - "Pure Python subclasses of abc.ABC that DO define __slots__ = () do not get __weakref__ in their own class dict and instances of such subclasses cannot be weakly referenced (TypeError on weakref.ref call)"
    - "Pure Python subclasses of abc.ABC that define __slots__ = ('__weakref__',) explicitly add __weakref__ to their own class dict; instances of such subclasses can be weakly referenced"
    - "abc.abstractclassmethod, abc.abstractstaticmethod, and abc.abstractproperty are deprecated pure Python classes that directly subclass classmethod, staticmethod, and property respectively; they own __weakref__ in their own class dict"
    - "abc.abstractmethod is a plain Python function (not a class); isinstance(abc.abstractmethod, type) is False"
    - "abc.get_cache_token is a builtin_function_or_method wrapping _abc.get_cache_token; not a class"
    - "The __weakref__ descriptor added to a pure Python class is a getset_descriptor; type(SubABC.__dict__['__weakref__']).__name__ == 'getset_descriptor'"
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"
error_model: python_exceptions

table abc_extra1621.abc_no_weakref:
  description: "abc.ABC defines __slots__ = () and therefore does not own __weakref__ in its class dict; abc.ABCMeta is a C-extension type and similarly does not own __weakref__ in its dict; these are the two primary public names in the abc module"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1621an

  columns: [id, function, args, expected]
  rows:
    - ["ab1621an001", "abc.ABC.__dict__.__contains__",                             ["__weakref__"], false]
    - ["ab1621an002", "abc.ABCMeta.__dict__.__contains__",                         ["__weakref__"], false]
    - ["ab1621an003", "abc.ABC.__dict__.__contains__",                             ["__slots__"],   true]
    - ["ab1621an004", "abc.ABCMeta.__dict__.__contains__",                         ["__slots__"],   false]
    - ["ab1621an005", "abc.ABC.__dict__.__contains__",                             ["__dict__"],    false]
    - ["ab1621an006", "abc.ABCMeta.__dict__.__contains__",                         ["__dict__"],    false]
    - ["ab1621an007", "abc.ABC.__name__.__eq__",                                   ["ABC"],         true]
    - ["ab1621an008", "abc.ABCMeta.__name__.__eq__",                               ["ABCMeta"],     true]
    - ["ab1621an009", "abc.ABC.__dict__.__class__.__name__.__eq__",                ["mappingproxy"], true]
    - ["ab1621an010", "abc.ABCMeta.__dict__.__class__.__name__.__eq__",            ["mappingproxy"], true]
    - ["ab1621an011", "abc.ABC.__module__.__eq__",                                 ["abc"],         true]
    - ["ab1621an012", "abc.ABCMeta.__module__.__eq__",                             ["abc"],         true]

table abc_extra1621.abcmeta_weakref:
  description: "subclasses of abc.ABC exhibit distinct __weakref__ ownership depending on whether they define __slots__; a subclass with no __slots__ owns __weakref__ in its class dict; a subclass with __slots__ = () does not; a subclass with __slots__ = ('__weakref__',) does"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1621sm

  columns: [id, function, args, expected]
  rows:
    - ["ab1621sm001", "abc.abstractclassmethod.__dict__.__contains__",             ["__weakref__"], true]
    - ["ab1621sm002", "abc.abstractstaticmethod.__dict__.__contains__",            ["__weakref__"], true]
    - ["ab1621sm003", "abc.abstractproperty.__dict__.__contains__",                ["__weakref__"], true]
    - ["ab1621sm004", "abc.abstractclassmethod.__dict__.__contains__",             ["__dict__"],    false]
    - ["ab1621sm005", "abc.abstractstaticmethod.__dict__.__contains__",            ["__dict__"],    false]
    - ["ab1621sm006", "abc.abstractproperty.__dict__.__contains__",                ["__dict__"],    false]
    - ["ab1621sm007", "abc.abstractclassmethod.__dict__.__contains__",             ["__slots__"],   false]
    - ["ab1621sm008", "abc.abstractstaticmethod.__dict__.__contains__",            ["__slots__"],   false]
    - ["ab1621sm009", "abc.abstractproperty.__dict__.__contains__",                ["__slots__"],   false]
    - ["ab1621sm010", "abc.abstractclassmethod.__name__.__eq__",                   ["abstractclassmethod"], true]
    - ["ab1621sm011", "abc.abstractstaticmethod.__name__.__eq__",                  ["abstractstaticmethod"], true]
    - ["ab1621sm012", "abc.abstractproperty.__name__.__eq__",                      ["abstractproperty"], true]
    - ["ab1621sm013", "abc.abstractclassmethod.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["ab1621sm014", "abc.abstractstaticmethod.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["ab1621sm015", "abc.abstractproperty.__dict__.__class__.__name__.__eq__",   ["mappingproxy"], true]

table abc_extra1621.abstractmethod_weakref:
  description: "abc module class dict contents beyond __weakref__: ABC owns __slots__, __abstractmethods__, and _abc_impl in its own dict; ABCMeta owns register, __new__, and __instancecheck__; deprecated abstract decorator classes own __isabstractmethod__; abstractproperty uniquely owns __dict__ and __weakref__ while abstractclassmethod and abstractstaticmethod own only __weakref__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1621aw

  columns: [id, function, args, expected]
  rows:
    - ["ab1621aw001", "abc.ABC.__dict__.__contains__",                             ["__weakref__"],        false]
    - ["ab1621aw002", "abc.ABC.__dict__.__contains__",                             ["__slots__"],          true]
    - ["ab1621aw003", "abc.ABC.__dict__.__contains__",                             ["__abstractmethods__"], true]
    - ["ab1621aw004", "abc.ABCMeta.__dict__.__contains__",                         ["__abstractmethods__"], false]
    - ["ab1621aw005", "abc.abstractclassmethod.__dict__.__contains__",             ["__isabstractmethod__"], true]
    - ["ab1621aw006", "abc.abstractproperty.__dict__.__contains__",                ["__isabstractmethod__"], true]
    - ["ab1621aw007", "abc.abstractstaticmethod.__dict__.__contains__",            ["__isabstractmethod__"], true]
    - ["ab1621aw008", "abc.abstractclassmethod.__bases__.__len__",                 [],              1]
    - ["ab1621aw009", "abc.abstractstaticmethod.__bases__.__len__",                [],              1]
    - ["ab1621aw010", "abc.abstractproperty.__bases__.__len__",                    [],              1]
    - ["ab1621aw011", "abc.ABCMeta.__bases__.__len__",                             [],              1]
    - ["ab1621aw012", "abc.ABC.__bases__.__len__",                                 [],              1]
    - ["ab1621aw013", "abc.abstractclassmethod.__module__.__eq__",                 ["abc"],         true]
    - ["ab1621aw014", "abc.abstractstaticmethod.__module__.__eq__",                ["abc"],         true]
    - ["ab1621aw015", "abc.abstractproperty.__module__.__eq__",                    ["abc"],         true]
    - ["ab1621aw016", "abc.ABC.__dict__.__contains__",                             ["__init_subclass__"], false]
    - ["ab1621aw017", "abc.ABC.__dict__.__contains__",                             ["__subclasshook__"], false]
    - ["ab1621aw018", "abc.ABCMeta.__dict__.__contains__",                         ["__subclasshook__"], false]
    - ["ab1621aw019", "abc.ABCMeta.__dict__.__contains__",                         ["register"],    true]
    - ["ab1621aw020", "abc.ABCMeta.__dict__.__contains__",                         ["__new__"],     true]
    - ["ab1621aw021", "abc.ABCMeta.__dict__.__contains__",                         ["__instancecheck__"], true]
    - ["ab1621aw022", "abc.ABC.__dict__.__contains__",                             ["_abc_impl"],   true]
    - ["ab1621aw023", "abc.abstractproperty.__dict__.__contains__",                ["__dict__"],    true]
    - ["ab1621aw024", "abc.abstractclassmethod.__dict__.__contains__",             ["__dict__"],    false]
    - ["ab1621aw025", "abc.abstractstaticmethod.__dict__.__contains__",            ["__dict__"],    false]
