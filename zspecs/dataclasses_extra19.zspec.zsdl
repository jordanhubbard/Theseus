spec: dataclasses_extra19
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses documentation"
    - "PEP 557 — Data Classes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses.zspec.zsdl, dataclasses_field.zspec.zsdl, and dataclasses_extra through dataclasses_extra18.zspec.zsdl."
    - "dataclasses_extra18 covers: MISSING/__class__.__name__.__len__(); KW_ONLY/__class__.__name__.__len__(); Field/InitVar/FrozenInstanceError MRO[0].__name__.__len__(); replace/__qualname__.__eq__; make_dataclass/__qualname__.__eq__; asdict/__qualname__.__len__; astuple/__qualname__.__len__; replace/__qualname__.__len__."
    - "dataclasses_extra17 covers: field/__qualname__.__len__; dataclass/__qualname__.__len__; field/__qualname__.__eq__; FrozenInstanceError/__qualname__.__eq__; FrozenInstanceError/__name__.__eq__; InitVar/__qualname__.__eq__; Field/__qualname__.__eq__; dataclass/__name__.__eq__; fields/__qualname__.__eq__."
    - "dataclasses_extra16 covers: fields/asdict/astuple/replace __qualname__.__len__; FrozenInstanceError MRO[0]; fields/asdict/astuple/make_dataclass/is_dataclass __module__ standalone."
    - "dataclasses_extra8 covers: field().__class__.__qualname__ == 'Field'."
    - "dataclasses_extra12 covers: field().__class__.__module__ == 'dataclasses'."
    - "dataclasses_field covers: field().init/repr == True; field().default/default_factory are MISSING."
    - "dataclasses_extra6 covers: field().repr/__eq__(true); field().init/__eq__(true); field().compare/__eq__(true)."
    - "Focus of this spec: field().__class__.__name__ via method_chain chain (fresh angle); field().metadata.__class__.__name__ == 'mappingproxy'; field().hash.__class__.__name__ == 'NoneType'; __qualname__.__eq__ standalone for fields/asdict/astuple/is_dataclass — filling table-only gaps; fields/__name__.__len__() and is_dataclass/__name__.__len__() as standalone invariants."
    - "NOT yet covered (entering this spec): field().metadata.__class__.__name__ == 'mappingproxy'; field().hash.__class__.__name__ == 'NoneType'; standalone fields/__qualname__.__eq__; standalone asdict/__qualname__.__eq__; standalone astuple/__qualname__.__eq__; standalone is_dataclass/__qualname__.__eq__; fields/__name__.__len__() == 6; is_dataclass/__name__.__len__() == 12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# field().metadata default — empty mappingproxy
#
# dataclasses.field() with no arguments returns a Field whose metadata
# attribute is an empty mappingproxy (types.MappingProxyType). No prior spec
# checks the class name of field().metadata. The class name is 'mappingproxy'.
# ---------------------------------------------------------------------------

invariant dataclasses_extra19.field.metadata_class_name:
  description: "dataclasses.field().metadata.__class__.__name__ == 'mappingproxy' — default empty mapping proxy"
  category: field_defaults
  kind: python_call_eq
  function: field
  args: []
  method: metadata
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# field().hash default — None
#
# dataclasses.field().hash is None by default (the hash parameter defaults to
# None, meaning it inherits from compare). No prior spec checks the class name
# of the hash attribute. hash is None so its class is NoneType.
# ---------------------------------------------------------------------------

invariant dataclasses_extra19.field.hash_class_name:
  description: "dataclasses.field().hash.__class__.__name__ == 'NoneType' — hash defaults to None"
  category: field_defaults
  kind: python_call_eq
  function: field
  args: []
  method: hash
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# field().__class__.__name__ via method_chain (fresh angle)
#
# dataclasses_field covers field().__class__.__name__ via
# field.__class__.__name__.__eq__ (dotted attribute function path).
# dataclasses_extra6 covers field() with method: __class__, method_chain:
# __qualname__.__eq__ (for the qualname). No prior spec uses method: __class__
# with method_chain: __name__.__eq__ in a standalone invariant — this
# approaches the same fact via the invariant method_chain form.
# ---------------------------------------------------------------------------

invariant dataclasses_extra19.field.class_name_chain:
  description: "dataclasses.field().__class__.__name__ == 'Field' — via method_chain (standalone)"
  category: field_defaults
  kind: python_call_eq
  function: field
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Field"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__.__eq__ standalone for fields, asdict, astuple, is_dataclass
#
# dataclasses_extra17 covers fields/__qualname__.__eq__ in a table row.
# dataclasses_extra16 covers asdict/astuple/__qualname__.__len__ in a table.
# No prior spec has fields/__qualname__.__eq__ as a standalone invariant.
# No prior spec has asdict/__qualname__.__eq__ as a standalone invariant.
# No prior spec has astuple/__qualname__.__eq__ as a standalone invariant.
# No prior spec has is_dataclass/__qualname__.__eq__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant dataclasses_extra19.fields.qualname_eq:
  description: "dataclasses.fields.__qualname__ == 'fields' — standalone boolean invariant"
  category: qualnames
  kind: python_call_eq
  function: fields.__qualname__.__eq__
  args: ["fields"]
  expected: true

invariant dataclasses_extra19.asdict.qualname_eq:
  description: "dataclasses.asdict.__qualname__ == 'asdict' — standalone boolean invariant"
  category: qualnames
  kind: python_call_eq
  function: asdict.__qualname__.__eq__
  args: ["asdict"]
  expected: true

invariant dataclasses_extra19.astuple.qualname_eq:
  description: "dataclasses.astuple.__qualname__ == 'astuple' — standalone boolean invariant"
  category: qualnames
  kind: python_call_eq
  function: astuple.__qualname__.__eq__
  args: ["astuple"]
  expected: true

invariant dataclasses_extra19.is_dataclass.qualname_eq:
  description: "dataclasses.is_dataclass.__qualname__ == 'is_dataclass' — standalone boolean invariant"
  category: qualnames
  kind: python_call_eq
  function: is_dataclass.__qualname__.__eq__
  args: ["is_dataclass"]
  expected: true

# ---------------------------------------------------------------------------
# __name__.__len__() for fields and is_dataclass as standalone invariants
#
# dataclasses_extra14 covers a table of __name__.__len__() values including
# is_dataclass (==12) and fields (==6). No prior spec has these as individual
# standalone invariants for isolated machine-readable indexing.
# ---------------------------------------------------------------------------

invariant dataclasses_extra19.fields.name_len:
  description: "dataclasses.fields.__name__.__len__() == 6 — 'fields' is 6 characters (standalone)"
  category: function_names
  kind: python_call_eq
  function: fields.__name__.__len__
  args: []
  expected: 6

invariant dataclasses_extra19.is_dataclass.name_len:
  description: "dataclasses.is_dataclass.__name__.__len__() == 12 — 'is_dataclass' is 12 characters (standalone)"
  category: function_names
  kind: python_call_eq
  function: is_dataclass.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# make_dataclass.__name__.__len__() standalone
#
# dataclasses_extra14 covers make_dataclass.__name__.__len__() == 13 in a table.
# No prior spec has it as a standalone invariant.
# 'make_dataclass' is 13 characters.
# ---------------------------------------------------------------------------

invariant dataclasses_extra19.make_dataclass.name_len:
  description: "dataclasses.make_dataclass.__name__.__len__() == 13 — 'make_dataclass' is 13 characters (standalone)"
  category: function_names
  kind: python_call_eq
  function: make_dataclass.__name__.__len__
  args: []
  expected: 13
