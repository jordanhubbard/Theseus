spec: playwright_rust
version: ">=3.9"
backend: rust_module(playwright_rust)

docs: https://playwright.dev/python/docs/api/class-playwright

provenance:
  derived_from:
    - "https://playwright.dev/python/docs/api/class-playwright — Playwright Python API"
  not_derived_from:
    - "playwright source: playwright/sync_api/_generated.py"
  notes:
    - "Playwright provides browser automation for Python."
    - "playwright.sync_api is available."
    - "playwright.__version__ is a non-empty string."
    - "from playwright.sync_api import sync_playwright — importable."
    - "Expose playwright_version_nonempty() -> bool: len(playwright.__version__) > 0."
    - "Expose playwright_has_sync_api() -> bool: hasattr(playwright, 'sync_api')."
    - "Expose playwright_has_async_api() -> bool: hasattr(playwright, 'async_api')."
    - "All test vectors verified against playwright 1.50.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# playwright_version_nonempty — version non-empty
invariant playwright_rust.version.nonempty:
  description: "playwright.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: playwright_version_nonempty
  args: []
  expected: true

# playwright_has_sync_api — sync_api module present
invariant playwright_rust.module.has_sync_api:
  description: "playwright.sync_api is available"
  category: module
  kind: python_call_eq
  function: playwright_has_sync_api
  args: []
  expected: true

# playwright_has_async_api — async_api module present
invariant playwright_rust.module.has_async_api:
  description: "playwright.async_api is available"
  category: module
  kind: python_call_eq
  function: playwright_has_async_api
  args: []
  expected: true

