spec: concurrent_futures_extra2011
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 581 (_extra2011): __add__/__radd__/__iadd__, __mul__/__rmul__/__imul__, __sub__/__rsub__/__isub__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures.Future, ThreadPoolExecutor, ProcessPoolExecutor, Executor do not define arithmetic operators; all checks return False."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __add__ / __radd__ / __iadd__ dict-presence for concurrent.futures types
#
# None of Future, ThreadPoolExecutor, ProcessPoolExecutor, Executor define
# addition operators. All checks return False.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2011.add_protocol:
  description: "concurrent.futures types __add__/__radd__/__iadd__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2011

  columns: [id, function, args, expected]
  rows:
    - ["cf2011001", "concurrent.futures.Future.__dict__.__contains__",              ["__add__"],  false]
    - ["cf2011002", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__add__"],  false]
    - ["cf2011003", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__add__"],  false]
    - ["cf2011004", "concurrent.futures.Executor.__dict__.__contains__",            ["__add__"],  false]
    - ["cf2011005", "concurrent.futures.Future.__dict__.__contains__",              ["__radd__"], false]
    - ["cf2011006", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__radd__"], false]
    - ["cf2011007", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__radd__"], false]
    - ["cf2011008", "concurrent.futures.Executor.__dict__.__contains__",            ["__radd__"], false]
    - ["cf2011009", "concurrent.futures.Future.__dict__.__contains__",              ["__iadd__"], false]
    - ["cf2011010", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__iadd__"], false]
    - ["cf2011011", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__iadd__"], false]
    - ["cf2011012", "concurrent.futures.Executor.__dict__.__contains__",            ["__iadd__"], false]

