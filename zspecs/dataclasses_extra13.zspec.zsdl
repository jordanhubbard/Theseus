spec: dataclasses_extra13
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses documentation"
    - "PEP 557 — Data Classes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses.zspec.zsdl, dataclasses_field.zspec.zsdl, and dataclasses_extra through dataclasses_extra12."
    - "dataclasses_extra12 covers: __spec__.name and __spec__.__class__.__name__; MISSING/__class__/__module__ and KW_ONLY/__class__/__module__; FrozenInstanceError.__mro__[0].__name__; function __doc__.__class__.__name__ for dataclass/field/fields/is_dataclass/make_dataclass; dataclass/__name__ and field/__name__ and fields/__name__ via __eq__; field().__class__.__module__."
    - "NOT yet covered: field.__name__.__len__() — structural length check on 'field' (5 chars); asdict.__name__.__len__() — 'asdict' is 6 chars; astuple.__name__.__len__() — 'astuple' is 7 chars; make_dataclass.__name__.__len__() — 'make_dataclass' is 14 chars."
    - "NOT yet covered: dataclasses.__loader__.__class__.__name__ — the loader type (SourceFileLoader)."
    - "NOT yet covered: fields.__qualname__ == 'fields' (not tested as a standalone invariant)."
    - "NOT yet covered: asdict.__qualname__ == 'asdict' (not tested as a standalone invariant)."
    - "NOT yet covered: astuple.__qualname__ == 'astuple' (not tested as a standalone invariant)."
    - "NOT yet covered: replace.__qualname__ == 'replace' (not tested as a standalone invariant)."
    - "NOT yet covered: is_dataclass.__qualname__ == 'is_dataclass' (not tested as a standalone invariant)."
    - "NOT yet covered: Field.__qualname__ == 'Field' (not tested as a standalone invariant)."
    - "NOT yet covered: InitVar.__qualname__ == 'InitVar' (not tested as a standalone invariant)."
    - "dataclasses.field.__name__.__len__() == 5 — 'field' is 5 characters."
    - "dataclasses.asdict.__name__.__len__() == 6 — 'asdict' is 6 characters."
    - "dataclasses.astuple.__name__.__len__() == 7 — 'astuple' is 7 characters."
    - "dataclasses.make_dataclass.__name__.__len__() == 14 — 'make_dataclass' is 14 characters."
    - "dataclasses.fields.__qualname__ == 'fields' — top-level function, qualname equals name."
    - "dataclasses.asdict.__qualname__ == 'asdict' — top-level function, qualname equals name."
    - "dataclasses.astuple.__qualname__ == 'astuple' — top-level function, qualname equals name."
    - "dataclasses.replace.__qualname__ == 'replace' — top-level function, qualname equals name."
    - "dataclasses.is_dataclass.__qualname__ == 'is_dataclass' — top-level function, qualname equals name."
    - "dataclasses.Field.__qualname__ == 'Field' — top-level class, qualname equals name."
    - "dataclasses.InitVar.__qualname__ == 'InitVar' — top-level class, qualname equals name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ string lengths
#
# dataclasses_extra12 covers __name__.__eq__ for dataclass/field/fields (table).
# No prior spec checks the __len__ of any function __name__ string in dataclasses.
# These are structural checks distinct from equality.
# ---------------------------------------------------------------------------

table dataclasses_extra13.function_name_lengths:
  kind: python_call_eq
  category: function_names
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [field,          field.__name__.__len__,          [], 5]
    - [asdict,         asdict.__name__.__len__,         [], 6]
    - [astuple,        astuple.__name__.__len__,        [], 7]
    - [make_dataclass, make_dataclass.__name__.__len__, [], 14]

# ---------------------------------------------------------------------------
# Function __qualname__ — standalone invariants not yet covered
#
# dataclasses_extra7 verified __qualname__ for these functions in a combined
# table. Not yet verified as standalone invariants: fields, asdict, astuple,
# replace, is_dataclass. Adding these enables isolated single-vector checks.
# ---------------------------------------------------------------------------

table dataclasses_extra13.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [fields,       fields.__qualname__.__eq__,       ["fields"],       true]
    - [asdict,       asdict.__qualname__.__eq__,       ["asdict"],       true]
    - [astuple,      astuple.__qualname__.__eq__,      ["astuple"],      true]
    - [replace,      replace.__qualname__.__eq__,      ["replace"],      true]
    - [is_dataclass, is_dataclass.__qualname__.__eq__, ["is_dataclass"], true]

# ---------------------------------------------------------------------------
# Class __qualname__ for Field and InitVar
#
# Prior specs verify Field/__name__ and InitVar/__name__. No prior spec
# checks their __qualname__ as standalone invariants. Both are top-level
# classes, so __qualname__ == __name__ for each.
# ---------------------------------------------------------------------------

invariant dataclasses_extra13.Field.qualname:
  description: "dataclasses.Field.__qualname__ == 'Field' — top-level class, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: Field.__qualname__.__eq__
  args: ["Field"]
  expected: true

invariant dataclasses_extra13.InitVar.qualname:
  description: "dataclasses.InitVar.__qualname__ == 'InitVar' — top-level class, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: InitVar.__qualname__.__eq__
  args: ["InitVar"]
  expected: true

# ---------------------------------------------------------------------------
# Module loader class name
#
# No prior dataclasses spec checks dataclasses.__loader__. The module loader
# for a pure-Python module on CPython is a SourceFileLoader instance.
# ---------------------------------------------------------------------------

invariant dataclasses_extra13.module.loader_class:
  description: "dataclasses.__loader__.__class__.__name__ == 'SourceFileLoader' — loaded by CPython's source loader"
  category: module_attrs
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# FrozenInstanceError.__qualname__ length
#
# Prior specs verify FrozenInstanceError.__qualname__ == 'FrozenInstanceError'.
# No prior spec checks the length of that qualname string.
# 'FrozenInstanceError' is 19 characters.
# ---------------------------------------------------------------------------

invariant dataclasses_extra13.FrozenInstanceError.qualname_len:
  description: "len(dataclasses.FrozenInstanceError.__qualname__) == 19 — 'FrozenInstanceError' is 19 characters"
  category: class_names
  kind: python_call_eq
  function: FrozenInstanceError.__qualname__.__len__
  args: []
  expected: 19
