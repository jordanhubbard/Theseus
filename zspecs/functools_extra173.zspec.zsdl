spec: functools_extra173
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.partial.__name__ 'partial'; functools.partial.__module__ 'functools'; functools.partial.__bases__[0].__name__ 'object'; functools.partialmethod.__name__ 'partialmethod'; functools.partialmethod.__module__ 'functools'; functools.partialmethod.__bases__[0].__name__ 'object'; functools.partial.__name__.__len__() 7; functools.partialmethod.__name__.__len__() 13 (Wave 297)."
    - "functools.partial.__name__ == 'partial' — functools.partial is a C extension type defined in Modules/_functoolsmodule.c that returns a new partial object that behaves like a callable with some arguments pre-filled; its type __name__ is 'partial'. Verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools' — partial is exposed in the functools namespace; its __module__ attribute is 'functools'. Verified with Python 3.14.3."
    - "functools.partial.__bases__[0].__name__ == 'object' — functools.partial is a C extension type that inherits directly from object; its __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "functools.partialmethod.__name__ == 'partialmethod' — functools.partialmethod is a Python class defined in Lib/functools.py; it is a descriptor version of partial for use in class bodies; its class __name__ is 'partialmethod'. Verified with Python 3.14.3."
    - "functools.partialmethod.__module__ == 'functools' — partialmethod is defined in Lib/functools.py; its __module__ attribute is 'functools'. Verified with Python 3.14.3."
    - "functools.partialmethod.__bases__[0].__name__ == 'object' — functools.partialmethod inherits directly from object; its __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "functools.partial.__name__.__len__() == 7 — the string 'partial' has 7 characters; str.__len__() returns 7. Verified with Python 3.14.3."
    - "functools.partialmethod.__name__.__len__() == 13 — the string 'partialmethod' has 13 characters; str.__len__() returns 13. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial C extension type identity — __name__, __module__,
# __bases__[0], and __class__.__name__
#
# Wave 297 theme: functools.partial C extension type identity — __name__,
# __module__, __bases__[0].__name__, and __class__.__name__.
#
# functools.partial.__name__ == 'partial'
# functools.partial.__module__ == 'functools'
# functools.partial.__bases__[0].__name__ == 'object'
# functools.partial.__class__.__name__ == 'type'
#
# functools.partial(func, /, *args, **keywords) is a C extension type defined
# in Modules/_functoolsmodule.c. It returns a new partial object that behaves
# like func called with the positional args and keyword keywords pre-filled.
# It is implemented as a C type (not a Python class), so its __class__.__name__
# is 'type'. Its __bases__[0] is object (direct inheritance). New to extra173.
# ---------------------------------------------------------------------------

table functools_extra173.partial_c_type_identity:
  description: "functools.partial: __name__ 'partial', __module__ 'functools', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 297; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: functoolspcti173

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_partial,
       "partial.__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — functools.partial is a C extension type defined in Modules/_functoolsmodule.c that returns a callable with pre-filled positional and keyword arguments; its type __name__ attribute is 'partial'; str.__eq__('partial') returns True; new to extra173"]
    - [partial_module_functools,
       "partial.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — functools.partial is exposed via the functools module namespace; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra173"]
    - ["partial_bases_0_object",
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — functools.partial is a C extension type that inherits directly from object; its __bases__ tuple has one element whose __name__ is 'object'; str.__eq__('object') returns True; new to extra173"]
    - [partial_class_name_type,
       "partial.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — functools.partial is a class object (C extension type); its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra173"]

# ---------------------------------------------------------------------------
# Table 2: functools.partialmethod Python class identity — __name__, __module__,
# __bases__[0], and __class__.__name__
#
# Wave 297 theme: functools.partialmethod Python class identity — __name__,
# __module__, __bases__[0].__name__, and __class__.__name__.
#
# functools.partialmethod.__name__ == 'partialmethod'
# functools.partialmethod.__module__ == 'functools'
# functools.partialmethod.__bases__[0].__name__ == 'object'
# functools.partialmethod.__class__.__name__ == 'type'
#
# functools.partialmethod(func, /, *args, **keywords) is a Python class defined
# in Lib/functools.py. It is a descriptor analogue of partial for use inside
# class bodies; when accessed as an instance attribute it returns a bound partial
# object. Unlike partial (which is a C extension type), partialmethod is a pure
# Python class. Both inherit from object. New to extra173.
# ---------------------------------------------------------------------------

table functools_extra173.partialmethod_class_identity:
  description: "functools.partialmethod: __name__ 'partialmethod', __module__ 'functools', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 297; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: functoolspmci173

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_name_partialmethod,
       "partialmethod.__name__.__eq__",
       ["partialmethod"],
       true,
       "functools.partialmethod.__name__.__eq__('partialmethod') == True — functools.partialmethod is a Python class defined in Lib/functools.py that acts as a descriptor analogue of partial for class bodies; its class __name__ attribute is 'partialmethod'; str.__eq__('partialmethod') returns True; new to extra173"]
    - [partialmethod_module_functools,
       "partialmethod.__module__.__eq__",
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — functools.partialmethod is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra173"]
    - ["partialmethod_bases_0_object",
       "partialmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__bases__[0].__name__.__eq__('object') == True — functools.partialmethod is a Python class that inherits directly from object; its __bases__ tuple has one element whose __name__ is 'object'; str.__eq__('object') returns True; new to extra173"]
    - [partialmethod_class_name_type,
       "partialmethod.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.partialmethod.__class__.__name__.__eq__('type') == True — functools.partialmethod is a Python class object; its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra173"]

# ---------------------------------------------------------------------------
# Table 3: functools.partial and partialmethod __name__ string length checks
#
# Wave 297 theme: length of the __name__ strings for partial and partialmethod.
#
# functools.partial.__name__.__len__() == 7
# functools.partialmethod.__name__.__len__() == 13
# functools.partial.__name__.__len__() != 13
# functools.partialmethod.__name__.__len__() != 7
#
# 'partial' is 7 characters long (p-a-r-t-i-a-l).
# 'partialmethod' is 13 characters long (p-a-r-t-i-a-l-m-e-t-h-o-d).
# These lengths are distinct: 7 != 13. The name length cross-checks confirm
# that partial and partialmethod are distinct types with different-length names.
# New to extra173.
# ---------------------------------------------------------------------------

table functools_extra173.partial_partialmethod_name_lengths:
  description: "functools: partial.__name__.__len__() 7, partialmethod.__name__.__len__() 13; cross-checks; wave 297; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: functoolspnl173

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_len_7,
       "partial.__name__.__len__",
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — the string 'partial' has exactly 7 characters: p-a-r-t-i-a-l; str.__len__() returns 7; new to extra173"]
    - [partialmethod_name_len_13,
       "partialmethod.__name__.__len__",
       [],
       13,
       "functools.partialmethod.__name__.__len__() == 13 — the string 'partialmethod' has exactly 13 characters: p-a-r-t-i-a-l-m-e-t-h-o-d; str.__len__() returns 13; new to extra173"]
    - [partial_name_len_ne_13,
       "partial.__name__.__len__",
       [],
       7,
       "functools.partial.__name__.__len__() == 7 (not 13) — 'partial' is 7 characters, not 13 (which is the length of 'partialmethod'); confirming the two names are distinct in length; str.__len__() returns 7; new to extra173"]
    - [partialmethod_name_len_ne_7,
       "partialmethod.__name__.__len__",
       [],
       13,
       "functools.partialmethod.__name__.__len__() == 13 (not 7) — 'partialmethod' is 13 characters, not 7 (which is the length of 'partial'); confirming the two names are distinct in length; str.__len__() returns 13; new to extra173"]

# ---------------------------------------------------------------------------
# Table 4: functools.partial vs partialmethod cross-checks — distinct names,
# shared module
#
# Wave 297 theme: cross-checks between functools.partial and
# functools.partialmethod — their __name__ values are distinct; both have
# __module__ 'functools'; partial inherits from object like partialmethod.
#
# functools.partial.__name__ != 'partialmethod'
# functools.partialmethod.__name__ != 'partial'
# functools.partial.__module__ == functools.partialmethod.__module__
#   (both 'functools', cross-checked via __eq__)
# functools.partial.__bases__[0].__name__ == functools.partialmethod.__bases__[0].__name__
#   (both 'object')
#
# Despite both being in the functools module and serving related purposes,
# partial and partialmethod are entirely distinct types with distinct names.
# partial is a C extension type; partialmethod is a Python class. New to extra173.
# ---------------------------------------------------------------------------

table functools_extra173.partial_partialmethod_cross_checks:
  description: "functools: partial.__name__ != 'partialmethod', partialmethod.__name__ != 'partial', both module 'functools', both base 'object'; wave 297; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsppmcc173

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_ne_partialmethod,
       "partial.__name__.__eq__",
       ["partialmethod"],
       false,
       "functools.partial.__name__.__eq__('partialmethod') == False — partial.__name__ is 'partial', not 'partialmethod'; they are distinct types serving related but different purposes; str.__eq__('partialmethod') returns False; new to extra173"]
    - [partialmethod_name_ne_partial,
       "partialmethod.__name__.__eq__",
       ["partial"],
       false,
       "functools.partialmethod.__name__.__eq__('partial') == False — partialmethod.__name__ is 'partialmethod', not 'partial'; they are distinct types; str.__eq__('partial') returns False; new to extra173"]
    - [partial_module_functools_xcheck,
       "partial.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial.__module__ is 'functools', same as partialmethod.__module__; both are exposed via the functools namespace; cross-check confirming shared module; str.__eq__('functools') returns True; new to extra173"]
    - [partialmethod_module_functools_xcheck,
       "partialmethod.__module__.__eq__",
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod.__module__ is 'functools', same as partial.__module__; both are exposed via the functools namespace; cross-check confirming shared module; str.__eq__('functools') returns True; new to extra173"]

# ---------------------------------------------------------------------------
# Table 5: functools.partial and partialmethod negative identity checks —
# not builtin, not Python function
#
# Wave 297 theme: cross-checks confirming that partial is not a Python function
# and not a builtin_function_or_method (it is a C type/class); and that
# partialmethod is not a builtin_function_or_method.
#
# functools.partial.__class__.__name__ != 'function'
# functools.partial.__class__.__name__ != 'builtin_function_or_method'
# functools.partialmethod.__class__.__name__ != 'builtin_function_or_method'
# functools.partialmethod.__class__.__name__ != 'function'
#
# Both partial and partialmethod are classes (not function objects or C builtins),
# so their __class__.__name__ is 'type', not 'function' or
# 'builtin_function_or_method'. New to extra173.
# ---------------------------------------------------------------------------

table functools_extra173.partial_partialmethod_negative_class_checks:
  description: "functools: partial and partialmethod __class__.__name__ not 'function' or 'builtin_function_or_method'; wave 297; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsppmncx173

  columns: [id, function, args, expected, description]
  rows:
    - [partial_not_function,
       "partial.__class__.__name__.__eq__",
       ["function"],
       false,
       "functools.partial.__class__.__name__.__eq__('function') == False — functools.partial is a class object (C extension type), NOT a Python function; its __class__.__name__ is 'type', not 'function'; str.__eq__('function') returns False; new to extra173"]
    - [partial_not_builtin,
       "partial.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       false,
       "functools.partial.__class__.__name__.__eq__('builtin_function_or_method') == False — functools.partial is a class (C extension type), not a builtin callable; its __class__.__name__ is 'type', not 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns False; new to extra173"]
    - [partialmethod_not_function,
       "partialmethod.__class__.__name__.__eq__",
       ["function"],
       false,
       "functools.partialmethod.__class__.__name__.__eq__('function') == False — functools.partialmethod is a Python class object, NOT a plain Python function; its __class__.__name__ is 'type', not 'function'; str.__eq__('function') returns False; new to extra173"]
    - [partialmethod_not_builtin,
       "partialmethod.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       false,
       "functools.partialmethod.__class__.__name__.__eq__('builtin_function_or_method') == False — functools.partialmethod is a Python class object, not a C builtin callable; its __class__.__name__ is 'type', not 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns False; new to extra173"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra173
# ---------------------------------------------------------------------------

invariant functools_extra173.partial_name_partial:
  description: "functools.partial.__name__ == 'partial' — C extension type for callables with pre-filled arguments; wave 297; new to extra173"
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra173.partial_module_functools:
  description: "functools.partial.__module__ == 'functools' — partial is exposed in the functools module namespace; wave 297; new to extra173"
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra173.partial_bases_0_object:
  description: "functools.partial.__bases__[0].__name__ == 'object' — partial C extension type inherits directly from object; wave 297; new to extra173"
  kind: python_call_eq
  function: "partial.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra173.partialmethod_name_partialmethod:
  description: "functools.partialmethod.__name__ == 'partialmethod' — Python class descriptor analogue of partial for class bodies; wave 297; new to extra173"
  kind: python_call_eq
  function: partialmethod.__name__.__eq__
  args: ["partialmethod"]
  expected: true

invariant functools_extra173.partialmethod_module_functools:
  description: "functools.partialmethod.__module__ == 'functools' — partialmethod is defined in Lib/functools.py; wave 297; new to extra173"
  kind: python_call_eq
  function: partialmethod.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra173.partialmethod_bases_0_object:
  description: "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod Python class inherits directly from object; wave 297; new to extra173"
  kind: python_call_eq
  function: "partialmethod.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra173.partial_name_len_7:
  description: "functools.partial.__name__.__len__() == 7 — 'partial' is 7 characters long; wave 297; new to extra173"
  kind: python_call_eq
  function: partial.__name__.__len__
  args: []
  expected: 7

invariant functools_extra173.partialmethod_name_len_13:
  description: "functools.partialmethod.__name__.__len__() == 13 — 'partialmethod' is 13 characters long; wave 297; new to extra173"
  kind: python_call_eq
  function: partialmethod.__name__.__len__
  args: []
  expected: 13
