spec: gc_extra25
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
    - "gc_extra24.zspec.zsdl — covers __qualname__ for collect/enable/disable/isenabled/get_count/get_threshold/set_threshold/get_objects and garbage.__class__.__name__."
    - "gc_extra21.zspec.zsdl — covers get_stats.__qualname__/__module__/__class__.__name__ and DEBUG_* values."
    - "gc_extra23.zspec.zsdl — covers gc.get_stats() return structure."
  notes:
    - "This spec extends prior gc specs through gc_extra24.zspec.zsdl."
    - "Focus: __qualname__ values for gc built-in functions get_freeze_count/freeze/unfreeze/is_tracked/is_finalized/get_referrers/get_referents — none of these appear as __qualname__ invariants in any prior gc spec."
    - "gc.get_freeze_count.__qualname__ == 'get_freeze_count' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.freeze.__qualname__ == 'freeze' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.unfreeze.__qualname__ == 'unfreeze' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.is_tracked.__qualname__ == 'is_tracked' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.is_finalized.__qualname__ == 'is_finalized' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.get_referrers.__qualname__ == 'get_referrers' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.get_referents.__qualname__ == 'get_referents' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All seven are C-level built-in functions; their __qualname__ equals their simple name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# gc built-in function __qualname__ values — freeze family and referent tools
#
# gc functions are implemented in C (builtin_function_or_method).
# Their __qualname__ attribute equals the simple function name string.
# No prior gc spec records __qualname__ for get_freeze_count/freeze/unfreeze/
# is_tracked/is_finalized/get_referrers/get_referents.
# Prior specs record __name__ for these functions but not __qualname__.
# ---------------------------------------------------------------------------

invariant gc_extra25.get_freeze_count.qualname:
  description: "gc.get_freeze_count.__qualname__ == 'get_freeze_count' — C built-in; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: get_freeze_count.__qualname__.__eq__
  args: ["get_freeze_count"]
  expected: true

invariant gc_extra25.freeze.qualname:
  description: "gc.freeze.__qualname__ == 'freeze' — C built-in; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: freeze.__qualname__.__eq__
  args: ["freeze"]
  expected: true

invariant gc_extra25.unfreeze.qualname:
  description: "gc.unfreeze.__qualname__ == 'unfreeze' — C built-in; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: unfreeze.__qualname__.__eq__
  args: ["unfreeze"]
  expected: true

invariant gc_extra25.is_tracked.qualname:
  description: "gc.is_tracked.__qualname__ == 'is_tracked' — C built-in; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: is_tracked.__qualname__.__eq__
  args: ["is_tracked"]
  expected: true

invariant gc_extra25.is_finalized.qualname:
  description: "gc.is_finalized.__qualname__ == 'is_finalized' — C built-in; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: is_finalized.__qualname__.__eq__
  args: ["is_finalized"]
  expected: true

invariant gc_extra25.get_referrers.qualname:
  description: "gc.get_referrers.__qualname__ == 'get_referrers' — C built-in; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: get_referrers.__qualname__.__eq__
  args: ["get_referrers"]
  expected: true

invariant gc_extra25.get_referents.qualname:
  description: "gc.get_referents.__qualname__ == 'get_referents' — C built-in; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: get_referents.__qualname__.__eq__
  args: ["get_referents"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — __qualname__ for all seven gc built-in functions
# (extra25 namespace)
# ---------------------------------------------------------------------------

table gc_extra25.function_qualnames:
  description: "__qualname__ values for gc freeze-family and referent built-in functions"
  kind: python_call_eq
  category: function_qualname

  columns: [id, function, args, expected]
  rows:
    - [get_freeze_count, get_freeze_count.__qualname__.__eq__, ["get_freeze_count"], true]
    - [freeze,           freeze.__qualname__.__eq__,           ["freeze"],           true]
    - [unfreeze,         unfreeze.__qualname__.__eq__,         ["unfreeze"],         true]
    - [is_tracked,       is_tracked.__qualname__.__eq__,       ["is_tracked"],       true]
    - [is_finalized,     is_finalized.__qualname__.__eq__,     ["is_finalized"],     true]
    - [get_referrers,    get_referrers.__qualname__.__eq__,    ["get_referrers"],    true]
    - [get_referents,    get_referents.__qualname__.__eq__,    ["get_referents"],    true]
