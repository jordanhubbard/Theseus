spec: telnetlib
version: ">=3.9,<3.13"
backend: python_module(telnetlib)

docs: https://docs.python.org/3.12/library/telnetlib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3.12/library/telnetlib.html"
    - "RFC 854 — TELNET PROTOCOL SPECIFICATION"
    - "RFC 855 — TELNET OPTION SPECIFICATIONS"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/telnetlib.py internal socket handling"
  notes:
    - "telnetlib was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13. This spec targets Python >=3.9,<3.13 only."
    - "TELNET_PORT is the well-known Telnet port: 23."
    - "IAC (Interpret As Command) is byte 255 (0xff); it signals the start of a Telnet command sequence."
    - "DO (253), DONT (254), WILL (251), WONT (252) are the four option negotiation commands defined in RFC 854."
    - "SB (250) begins subnegotiation; SE (240) ends subnegotiation (RFC 854 Section 5)."
    - "telnetlib byte constants are stored as bytes objects of length 1; __eq__ comparison uses the integer value."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name check
# ---------------------------------------------------------------------------

invariant telnetlib.class_names.Telnet:
  description: "telnetlib.Telnet.__name__ == 'Telnet'"
  category: class_names
  kind: python_call_eq
  function: Telnet.__name__.__eq__
  args: ["Telnet"]
  expected: true

# ---------------------------------------------------------------------------
# Module check
# ---------------------------------------------------------------------------

invariant telnetlib.module.Telnet:
  description: "telnetlib.Telnet.__module__ == 'telnetlib'"
  category: module
  kind: python_call_eq
  function: Telnet.__module__.__eq__
  args: ["telnetlib"]
  expected: true

# ---------------------------------------------------------------------------
# Constants: port and Telnet protocol bytes (RFC 854)
# ---------------------------------------------------------------------------

invariant telnetlib.constants.TELNET_PORT:
  description: "telnetlib.TELNET_PORT == 23 — well-known Telnet port"
  category: constants
  kind: python_call_eq
  function: TELNET_PORT.__eq__
  args: [23]
  expected: true

table telnetlib.protocol_bytes:
  kind: python_call_eq
  category: constants
  id_prefix: proto

  columns: [id, function, args, expected]
  rows:
    - [IAC,  IAC.__eq__,  [255], true]
    - [DO,   DO.__eq__,   [253], true]
    - [DONT, DONT.__eq__, [254], true]
    - [WILL, WILL.__eq__, [251], true]
    - [WONT, WONT.__eq__, [252], true]
    - [SB,   SB.__eq__,   [250], true]
    - [SE,   SE.__eq__,   [240], true]

# ---------------------------------------------------------------------------
# Telnet method name checks
# ---------------------------------------------------------------------------

table telnetlib.method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [read_until, Telnet.read_until.__name__.__eq__, ["read_until"], true]
    - [write,      Telnet.write.__name__.__eq__,      ["write"],      true]
    - [interact,   Telnet.interact.__name__.__eq__,   ["interact"],   true]
    - [open,       Telnet.open.__name__.__eq__,       ["open"],       true]
    - [close,      Telnet.close.__name__.__eq__,      ["close"],      true]
