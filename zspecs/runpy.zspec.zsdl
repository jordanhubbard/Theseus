spec: runpy
version: ">=3.1"
backend: python_module(runpy)

docs: https://docs.python.org/3/library/runpy.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/runpy.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/runpy.py"
  notes:
    - "runpy.run_module(mod_name) executes a module and returns its global namespace as a dict."
    - "runpy.run_path(path) executes a file at the given path and returns its global namespace as a dict."
    - "Both run_module and run_path are Python functions; type(f).__name__ == 'function'."
    - "run_module('runpy') runs the runpy module itself; the returned dict's class is always dict."
    - "run_module('os') runs the os module; the returned dict's class is always dict."
    - "The internal runpy._Error class is not part of the public API and is not tested here."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks — run_module and run_path
# ---------------------------------------------------------------------------

invariant runpy.run_module.function_name:
  description: "runpy.run_module.__name__ == 'run_module'"
  category: functions
  kind: python_call_eq
  function: run_module.__name__.__eq__
  args: ["run_module"]
  expected: true

invariant runpy.run_path.function_name:
  description: "runpy.run_path.__name__ == 'run_path'"
  category: functions
  kind: python_call_eq
  function: run_path.__name__.__eq__
  args: ["run_path"]
  expected: true

# ---------------------------------------------------------------------------
# Module checks — run_module and run_path belong to runpy
# ---------------------------------------------------------------------------

invariant runpy.run_module.module_name:
  description: "runpy.run_module.__module__ == 'runpy'"
  category: functions
  kind: python_call_eq
  function: run_module.__module__.__eq__
  args: ["runpy"]
  expected: true

invariant runpy.run_path.module_name:
  description: "runpy.run_path.__module__ == 'runpy'"
  category: functions
  kind: python_call_eq
  function: run_path.__module__.__eq__
  args: ["runpy"]
  expected: true

# ---------------------------------------------------------------------------
# Callable type checks — both are Python functions
# ---------------------------------------------------------------------------

invariant runpy.run_module.is_function:
  description: "type(runpy.run_module).__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: run_module.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant runpy.run_path.is_function:
  description: "type(runpy.run_path).__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: run_path.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# Runtime behavior — run_module returns a dict of globals
# ---------------------------------------------------------------------------

invariant runpy.run_module.returns_dict_for_runpy:
  description: "runpy.run_module('runpy').__class__.__name__ == 'dict' — run_module always returns a globals dict"
  category: runtime
  kind: python_call_eq
  function: run_module
  args: ["runpy"]
  method: __class__
  method_chain: __name__
  expected: "dict"

invariant runpy.run_module.returns_dict_for_os:
  description: "runpy.run_module('os').__class__.__name__ == 'dict' — run_module returns a globals dict for any module"
  category: runtime
  kind: python_call_eq
  function: run_module
  args: ["os"]
  method: __class__
  method_chain: __name__
  expected: "dict"

# ---------------------------------------------------------------------------
# run_module result contains expected keys
# ---------------------------------------------------------------------------

invariant runpy.run_module.result_contains_name_key:
  description: "runpy.run_module('runpy') result contains '__name__' key"
  category: runtime
  kind: python_call_eq
  function: run_module
  args: ["runpy"]
  method: __contains__
  method_args: ["__name__"]
  expected: true

invariant runpy.run_module.result_contains_spec_key:
  description: "runpy.run_module('runpy') result contains '__spec__' key"
  category: runtime
  kind: python_call_eq
  function: run_module
  args: ["runpy"]
  method: __contains__
  method_args: ["__spec__"]
  expected: true

