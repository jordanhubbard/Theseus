# ---------------------------------------------------------------------------
# Table 3: compress and dropwhile __name__ and slot __class__.__name__
#
# Wave 261 theme: compress/dropwhile __name__ and slot descriptor class names.
#
# itertools.compress.__name__ == 'compress'
# itertools.dropwhile.__name__ == 'dropwhile'
# itertools.compress.__iter__.__class__.__name__ == 'wrapper_descriptor'
# itertools.compress.__new__.__class__.__name__ == 'builtin_function_or_method'
# itertools.dropwhile.__iter__.__class__.__name__ == 'wrapper_descriptor'
# itertools.dropwhile.__new__.__class__.__name__ == 'builtin_function_or_method'
#
# The __name__ attribute on C extension types matches the type name string.
# Slot descriptors __iter__/__next__ are wrapper_descriptors; __new__ is builtin_function_or_method.
# New to extra131.
# ---------------------------------------------------------------------------

table itertools_extra131.compress_dropwhile_name_and_slot_classes:
  description: "itertools.compress/__name__=='compress'; dropwhile/__name__=='dropwhile'; __iter__/__next__ are wrapper_descriptor; __new__ is builtin_function_or_method; wave 261; new to extra131"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscd131

  columns: [id, function, args, expected, description]
  rows:
    - [compress_name_eq_compress,
       "compress.__name__.__eq__",
       ["compress"],
       true,
       "itertools.compress.__name__.__eq__('compress') == True — the __name__ attribute of a C extension type is set from the PyTypeObject tp_name field; for itertools.compress the name is 'compress'; str.__eq__('compress') returns True; new to extra131"]
    - [dropwhile_name_eq_dropwhile,
       "dropwhile.__name__.__eq__",
       ["dropwhile"],
       true,
       "itertools.dropwhile.__name__.__eq__('dropwhile') == True — the __name__ attribute of itertools.dropwhile is set from the PyTypeObject tp_name field; the name is 'dropwhile'; str.__eq__('dropwhile') returns True; new to extra131"]
    - [compress_iter_class_name_eq_wrapper_descriptor,
       "compress.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.compress.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — when a C extension type defines the tp_iter slot, accessing __iter__ on the type object yields a wrapper_descriptor; __class__.__name__ is 'wrapper_descriptor'; str.__eq__ returns True; new to extra131"]
    - [compress_new_class_name_eq_builtin_function_or_method,
       "compress.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.compress.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — __new__ on a C extension type is exposed as a builtin_function_or_method (PyCFunction); __class__.__name__ is 'builtin_function_or_method'; str.__eq__ returns True; new to extra131"]
    - [dropwhile_iter_class_name_eq_wrapper_descriptor,
       "dropwhile.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.dropwhile.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — accessing __iter__ on the itertools.dropwhile type object yields a wrapper_descriptor (tp_iter slot); __class__.__name__ is 'wrapper_descriptor'; str.__eq__ returns True; new to extra131"]
    - [dropwhile_new_class_name_eq_builtin_function_or_method,
       "dropwhile.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.dropwhile.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — __new__ on itertools.dropwhile is exposed as a builtin_function_or_method when accessed on the type; __class__.__name__ is 'builtin_function_or_method'; str.__eq__ returns True; new to extra131"]

