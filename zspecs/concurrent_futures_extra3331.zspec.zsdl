    - ["cf3331012", operator.contains, [concurrent.futures.Future.__dict__,              "__ixor__"], false]
    - ["cf3331013", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__iand__"], false]
    - ["cf3331014", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__ior__"], false]
    - ["cf3331015", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__ixor__"], false]
    - ["cf3331016", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__iand__"], false]
