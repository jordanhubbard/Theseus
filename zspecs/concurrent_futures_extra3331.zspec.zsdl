spec: cf3331
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 669 (cf3331): __iand__, __ior__, __ixor__ dict-presence (in-place &=, |=, ^=) for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor."
    - "Key finding (__iand__): all 3 concurrent.futures classes return false for __iand__. In-place bitwise AND (__iand__, &=) is the augmented assignment variant of __and__. concurrent.futures types define no __and__ (confirmed false in wave 661), so __iand__ is equally absent. concurrent.futures.Future is a result handle with a PENDING/RUNNING/CANCELLED/FINISHED state machine — not a numeric or set type; future &= n is not a defined Python expression. ThreadPoolExecutor and ProcessPoolExecutor manage worker pools via submit()/map()/shutdown(); in-place bitwise AND is not defined for executor objects."
    - "Key finding (__ior__): all 3 concurrent.futures classes return false for __ior__. In-place bitwise OR (__ior__, |=) is the augmented assignment variant of __or__. concurrent.futures types define no __or__ (confirmed false in wave 661), so __ior__ is equally absent. Note: Python 3.9 introduced __ior__ on the built-in dict type for in-place merging, but concurrent.futures types are parallel execution handles and pool managers — not dict-like types. concurrent.futures.Future: a state-machine result handle; future |= n is not a valid Python expression. ThreadPoolExecutor/ProcessPoolExecutor: worker-pool managers with an entirely method-based API; |= is not defined for executor objects."
    - "Key finding (__ixor__): all 3 concurrent.futures classes return false for __ixor__. In-place bitwise XOR (__ixor__, ^=) is the augmented assignment variant of __xor__. concurrent.futures types define no __xor__ (confirmed false in wave 661), so __ixor__ is equally absent. concurrent.futures.Future is a state-machine result handle, not a set or integer type; future ^= n is not a valid Python expression. ThreadPoolExecutor/ProcessPoolExecutor: executor types with no in-place XOR semantics."
    - "All 9 values in this wave are false. concurrent.futures is a high-level parallel execution API operating entirely through method calls — submit(), map(), result(), cancel(), add_done_callback(), shutdown() — with no arithmetic, bitwise, in-place augmented assignment, or operator overloading of any kind."
    - "Cross-wave summary for cf subjects:"
    - "  Wave 658 (cf3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (cf3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (cf3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (cf3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (cf3226): __radd__/__rsub__/__rmul__ — all false for all 3."
    - "  Wave 663 (cf3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 3."
    - "  Wave 664 (cf3256): __rpow__/__rlshift__/__rrshift__ — all false for all 3."
    - "  Wave 665 (cf3271): __rand__/__ror__/__rxor__ — all false for all 3."
    - "  Wave 666 (cf3286): __iadd__/__isub__/__imul__ — all false for all 3."
    - "  Wave 667 (cf3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 3."
    - "  Wave 668 (cf3316): __ipow__/__ilshift__/__irshift__ — all false for all 3."
    - "  Wave 669 (cf3331): __iand__/__ior__/__ixor__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iand__ dict-presence — operator.contains(Cls.__dict__, '__iand__')
#
# All 3 concurrent.futures classes return false for __iand__.
# In-place bitwise AND (__iand__, &=) is the augmented assignment variant
#   of __and__. concurrent.futures types define no __and__ (wave 661), so
#   __iand__ is equally absent.
# concurrent.futures.Future: a result-handle with PENDING/RUNNING/CANCELLED/
#   FINISHED states; future &= n is not a valid Python expression.
# ThreadPoolExecutor/ProcessPoolExecutor: worker-pool managers with an
#   entirely method-based API; in-place bitwise AND is not defined for pools.
# ---------------------------------------------------------------------------

table cf3331.iand:
  description: "concurrent.futures types __iand__ dict-presence checks; wave 669"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3331

  columns: [id, function, args, expected]
  rows:
    - ["cf3331001", operator.contains, [concurrent.futures.Future.__dict__,              "__iand__"], false]
    - ["cf3331002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__iand__"], false]
    - ["cf3331003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__iand__"], false]

# ---------------------------------------------------------------------------
# __ior__ dict-presence — operator.contains(Cls.__dict__, '__ior__')
#
# All 3 concurrent.futures classes return false for __ior__.
# In-place bitwise OR (__ior__, |=) is the augmented assignment variant
#   of __or__. concurrent.futures types define no __or__ (wave 661), so
#   __ior__ is equally absent.
# Note: Python 3.9 introduced __ior__ on the built-in dict type for
#   in-place dict merging (d |= other). concurrent.futures types are parallel
#   execution handles and pool managers — not dict-like types. This
#   dict-specific __ior__ is entirely irrelevant here.
# concurrent.futures.Future: a state-machine result handle; future |= n is
#   not a valid Python expression. Future manages asynchronous results through
#   callbacks and state transitions, not bitwise operators.
# ThreadPoolExecutor/ProcessPoolExecutor: worker-pool lifecycle managers;
#   in-place bitwise OR is entirely absent from their API.
# ---------------------------------------------------------------------------

table cf3331.ior:
  description: "concurrent.futures types __ior__ dict-presence checks; wave 669"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3331

  columns: [id, function, args, expected]
  rows:
    - ["cf3331004", operator.contains, [concurrent.futures.Future.__dict__,              "__ior__"], false]
    - ["cf3331005", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__ior__"], false]
    - ["cf3331006", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__ior__"], false]

# ---------------------------------------------------------------------------
# __ixor__ dict-presence — operator.contains(Cls.__dict__, '__ixor__')
#
# All 3 concurrent.futures classes return false for __ixor__.
# In-place bitwise XOR (__ixor__, ^=) is the augmented assignment variant
#   of __xor__. concurrent.futures types define no __xor__ (wave 661), so
#   __ixor__ is equally absent.
# concurrent.futures.Future: a state-machine result handle, not a set or
#   integer type; future ^= n is not a valid Python expression.
# ThreadPoolExecutor/ProcessPoolExecutor: pool managers; executor ^= n is
#   not a defined Python operation.
# ---------------------------------------------------------------------------

table cf3331.ixor:
  description: "concurrent.futures types __ixor__ dict-presence checks; wave 669"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3331

  columns: [id, function, args, expected]
  rows:
    - ["cf3331007", operator.contains, [concurrent.futures.Future.__dict__,              "__ixor__"], false]
    - ["cf3331008", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__ixor__"], false]
    - ["cf3331009", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__ixor__"], false]

# ---------------------------------------------------------------------------
# combined — __iand__, __ior__, __ixor__ across all 3 cf subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __iand__: false for all 3 — no in-place bitwise AND defined.
# __ior__:  false for all 3 — no in-place bitwise OR defined.
# __ixor__: false for all 3 — no in-place bitwise XOR defined.
# All 9 values are false.
# concurrent.futures is a high-level parallel execution API. Its entire
#   public surface is method-based: submit(), map(), result(), cancel(),
#   done(), running(), cancelled(), add_done_callback(), shutdown().
#   Neither the forward bitwise logical operators (wave 661: all false)
#   nor the reflected variants (wave 665: all false) appear anywhere in
#   the concurrent.futures type hierarchy. The in-place variants follow
#   the same pattern.
# concurrent.futures.Future note: despite the name, Future is a state-machine
#   result handle — not a numeric, set, or dict-like type. __iand__, __ior__,
#   and __ixor__ are all absent from its __dict__.
# ThreadPoolExecutor/ProcessPoolExecutor note: executor types encapsulate
#   a pool of worker threads or processes; they expose only lifecycle and
#   dispatch methods. No in-place augmented assignment operator overloads
#   are defined.
# ---------------------------------------------------------------------------

table cf3331.combined:
  description: "concurrent.futures types combined __iand__/__ior__/__ixor__; wave 669"
