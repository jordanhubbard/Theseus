spec: abc_extra12
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc.zspec.zsdl through abc_extra11.zspec.zsdl."
    - "abc_extra11 covers: ABCMeta.__instancecheck__.__qualname__; ABCMeta.__bases__[0].__name__; ABC.__abstractmethods__ type and length; abstractmethod.__class__.__name__; get_cache_token/__doc__ and update_abstractmethods/__doc__ nonempty; ABCMeta.__mro__[0].__name__."
    - "abc_extra10 covers: update_abstractmethods __module__/__qualname__/__class__.__name__; ABCMeta.__subclasscheck__.__qualname__; ABC.__subclasshook__.__qualname__."
    - "abc_extra8 covers: ABCMeta.__qualname__ as a standalone boolean __eq__ invariant."
    - "NOT yet covered: abc.ABC.__qualname__ == 'ABC' as a standalone boolean __eq__ invariant."
    - "NOT yet covered: abc.abstractmethod.__qualname__ == 'abstractmethod' as a standalone boolean __eq__ invariant."
    - "NOT yet covered: abc.abstractclassmethod/__qualname__, abc.abstractstaticmethod/__qualname__, abc.abstractproperty/__qualname__."
    - "NOT yet covered: abc.ABC.__module__ == 'abc'; abc.ABCMeta.__module__ == 'abc'; abc.abstractmethod.__module__ == 'abc'."
    - "abc.abstractclassmethod.__qualname__ == 'abstractclassmethod' — deprecated since 3.3, still present in 3.12."
    - "abc.abstractstaticmethod.__qualname__ == 'abstractstaticmethod' — deprecated since 3.3, still present in 3.12."
    - "abc.abstractproperty.__qualname__ == 'abstractproperty' — deprecated since 3.3, still present in 3.12."
    - "abc.get_cache_token.__module__ == '_abc' — implemented in the C extension _abc, not pure Python abc."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for ABC, ABCMeta, abstractmethod
#
# abc_extra8 records ABCMeta.__qualname__ as a standalone boolean invariant.
# No prior spec records ABC.__qualname__ or abstractmethod.__qualname__ as
# standalone boolean __eq__ invariants.
# ---------------------------------------------------------------------------

invariant abc_extra12.ABC.qualname:
  description: "abc.ABC.__qualname__ == 'ABC'"
  category: abc_qualnames
  kind: python_call_eq
  function: ABC.__qualname__.__eq__
  args: ["ABC"]
  expected: true

invariant abc_extra12.ABCMeta.qualname:
  description: "abc.ABCMeta.__qualname__ == 'ABCMeta'"
  category: abc_qualnames
  kind: python_call_eq
  function: ABCMeta.__qualname__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra12.abstractmethod.qualname:
  description: "abc.abstractmethod.__qualname__ == 'abstractmethod'"
  category: abc_qualnames
  kind: python_call_eq
  function: abstractmethod.__qualname__.__eq__
  args: ["abstractmethod"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for deprecated abstract decorators
#
# abstractclassmethod, abstractstaticmethod, and abstractproperty were
# deprecated in Python 3.3 but remain present through 3.12. No prior spec
# records their __qualname__ attributes as standalone invariants.
# ---------------------------------------------------------------------------

invariant abc_extra12.abstractclassmethod.qualname:
  description: "abc.abstractclassmethod.__qualname__ == 'abstractclassmethod' — deprecated but present"
  category: deprecated_qualnames
  kind: python_call_eq
  function: abstractclassmethod.__qualname__.__eq__
  args: ["abstractclassmethod"]
  expected: true

invariant abc_extra12.abstractstaticmethod.qualname:
  description: "abc.abstractstaticmethod.__qualname__ == 'abstractstaticmethod' — deprecated but present"
  category: deprecated_qualnames
  kind: python_call_eq
  function: abstractstaticmethod.__qualname__.__eq__
  args: ["abstractstaticmethod"]
  expected: true

invariant abc_extra12.abstractproperty.qualname:
  description: "abc.abstractproperty.__qualname__ == 'abstractproperty' — deprecated but present"
  category: deprecated_qualnames
  kind: python_call_eq
  function: abstractproperty.__qualname__.__eq__
  args: ["abstractproperty"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for ABC, ABCMeta, abstractmethod
#
# No prior spec records ABC.__module__, ABCMeta.__module__, or
# abstractmethod.__module__ as standalone boolean __eq__ invariants.
# All three are defined in the abc module itself.
# ---------------------------------------------------------------------------

invariant abc_extra12.ABC.module:
  description: "abc.ABC.__module__ == 'abc'"
  category: abc_modules
  kind: python_call_eq
  function: ABC.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra12.ABCMeta.module:
  description: "abc.ABCMeta.__module__ == 'abc'"
  category: abc_modules
  kind: python_call_eq
  function: ABCMeta.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra12.abstractmethod.module:
  description: "abc.abstractmethod.__module__ == 'abc'"
  category: abc_modules
  kind: python_call_eq
  function: abstractmethod.__module__.__eq__
  args: ["abc"]
  expected: true

# ---------------------------------------------------------------------------
# get_cache_token.__module__ — implemented in C extension _abc
#
# abc_extra9 confirms get_cache_token.__class__.__name__ == 'builtin_function_or_method'.
# No prior spec checks get_cache_token.__module__. Because get_cache_token is
# a C builtin from _abc, its __module__ is '_abc', not 'abc'.
# ---------------------------------------------------------------------------

invariant abc_extra12.get_cache_token.module:
  description: "abc.get_cache_token.__module__ == '_abc' — C builtin from the _abc extension"
  category: abc_modules
  kind: python_call_eq
  function: get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true
