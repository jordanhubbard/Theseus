invariant tempfile_extra_rust.has_named_temporary_file:
  description: "tempfile.NamedTemporaryFile is a class"
  category: presence
  kind: python_call_eq
  function: tempfile_extra_has_named_temp_file
  args: []
  expected: true

invariant tempfile_extra_rust.has_mkstemp:
  description: "tempfile.mkstemp is callable"
  category: presence
  kind: python_call_eq
  function: tempfile_extra_has_mkstemp
  args: []
  expected: true

