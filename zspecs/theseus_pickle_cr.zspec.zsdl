spec: theseus_pickle_cr
version: ">=3.8"
backend: python_cleanroom(theseus_pickle_cr)
blocks: pickle

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pickle.html"
  not_derived_from:
    - "CPython source: Lib/pickle.py (internal implementation)"
  notes:
    - "Clean-room pickle module. Do NOT import pickle."
    - "Uses Python's _pickle C extension directly."
    - "dumps(obj): serialize obj to bytes."
    - "loads(data): deserialize obj from bytes."
    - "dump(obj, f): write serialized obj to file."
    - "load(f): read and deserialize obj from file."

error_model: python_exceptions

invariant theseus_pickle_cr.pickle2_roundtrip:
  description: "loads(dumps(obj)) == obj for a simple dict"
  category: dumps
  kind: python_call_eq
  function: pickle2_roundtrip
  args: []
  expected: true

invariant theseus_pickle_cr.pickle2_list:
  description: "loads(dumps([1,2,3])) == [1,2,3]"
  category: dumps
  kind: python_call_eq
  function: pickle2_list
  args: []
  expected: true

invariant theseus_pickle_cr.pickle2_protocol:
  description: "dumps with protocol=4 returns bytes starting with pickle magic"
  category: dumps
  kind: python_call_eq
  function: pickle2_protocol
  args: []
  expected: true
