spec: struct_extra1576
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __str__/__repr__/__bytes__ protocol"
    - "struct.pack() returns a bytes object; its __repr__ and __str__ use the bytes literal form."
    - "struct.unpack() returns a tuple; str(tuple) gives the standard Python tuple repr."
    - "Network byte order (!) and big-endian (>) are identical for struct format strings."
    - "Little-endian (<) reverses byte order relative to big-endian."
    - "struct.calcsize() returns the number of bytes needed for the format string."
    - "struct.Struct pre-compiles a format string; .size is equivalent to calcsize(fmt)."
    - "Format 'H' = unsigned short (2 bytes), 'I' = unsigned int (4 bytes), 'Q' = unsigned long long (8 bytes)."
    - "Format 'B' = unsigned char (1 byte), 'f' = float (4 bytes), 'd' = double (8 bytes)."
    - "Format '3s' = 3-byte bytes object (char[3])."
    - "IP address 192.168.1.1 packs to b'\\xc0\\xa8\\x01\\x01' as four unsigned bytes."
    - "All expected values verified by running Python 3.12 struct on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# pack() — bytes representation of packed values (big-endian / network order)
# ---------------------------------------------------------------------------

table struct_extra1576.pack_bigendian:
  kind: python_call_eq
  category: bytes_repr
  id_prefix: st1576

  columns: [id, function, args, expected]
  rows:
    - ["st1576_001", "struct.pack", [">I", 0],   b"\x00\x00\x00\x00"]
    - ["st1576_002", "struct.pack", [">H", 1],   b"\x00\x01"]
    - ["st1576_003", "struct.pack", [">H", 256], b"\x01\x00"]
    - ["st1576_004", "struct.pack", ["!I", 1],   b"\x00\x00\x00\x01"]
    - ["st1576_005", "struct.pack", ["!H", 256], b"\x01\x00"]
    - ["st1576_006", "struct.pack", [">H", 0],   b"\x00\x00"]
    - ["st1576_007", "struct.pack", [">B", 255], b"\xff"]
    - ["st1576_008", "struct.pack", [">B", 0],   b"\x00"]

# ---------------------------------------------------------------------------
# pack() — little-endian byte order reversal
# ---------------------------------------------------------------------------

table struct_extra1576.pack_littleendian:
  kind: python_call_eq
  category: bytes_repr
  id_prefix: st1576

  columns: [id, function, args, expected]
  rows:
    - ["st1576_010", "struct.pack", ["<H", 256], b"\x00\x01"]
    - ["st1576_011", "struct.pack", ["<H", 1],   b"\x01\x00"]
    - ["st1576_012", "struct.pack", ["<I", 1],   b"\x01\x00\x00\x00"]

# ---------------------------------------------------------------------------
# pack() — multi-byte and composite formats
# ---------------------------------------------------------------------------

table struct_extra1576.pack_composite:
  kind: python_call_eq
  category: bytes_repr
  id_prefix: st1576

  columns: [id, function, args, expected]
  rows:
    - ["st1576_020", "struct.pack", ["!BBBB", 192, 168, 1, 1],  b"\xc0\xa8\x01\x01"]
    - ["st1576_021", "struct.pack", ["!BBBB", 127, 0, 0, 1],    b"\x7f\x00\x00\x01"]
    - ["st1576_022", "struct.pack", ["!BBBB", 255, 255, 255, 255], b"\xff\xff\xff\xff"]
    - ["st1576_023", "struct.pack", ["3s", b"abc"],              b"abc"]
    - ["st1576_024", "struct.pack", ["3s", b"abc"],              b"abc"]

# ---------------------------------------------------------------------------
# pack() length checks
# ---------------------------------------------------------------------------

table struct_extra1576.pack_lengths:
  kind: python_call_eq
  category: bytes_repr
  id_prefix: st1576

  columns: [id, function, args, expected]
  rows:
    - ["st1576_030", "struct.pack.__len__", [">I", 0],   4]
    - ["st1576_031", "struct.pack.__len__", [">H", 1],   2]
    - ["st1576_032", "struct.pack.__len__", [">B", 0],   1]
    - ["st1576_033", "struct.pack.__len__", [">f", 1.0], 4]
    - ["st1576_034", "struct.pack.__len__", [">d", 1.0], 8]
    - ["st1576_035", "struct.pack.__len__", ["3s", b"abc"], 3]

# ---------------------------------------------------------------------------
# unpack() — bytes back to Python values (tuple representation)
# ---------------------------------------------------------------------------

table struct_extra1576.unpack_values:
  kind: python_call_eq
  category: str_repr
  id_prefix: st1576

  columns: [id, function, args, expected]
  rows:
    - ["st1576_040", "struct.unpack", [">H",  b"\x01\x00"], [256]]
    - ["st1576_041", "struct.unpack", ["<H",  b"\x00\x01"], [256]]
    - ["st1576_042", "struct.unpack", [">I",  b"\x00\x00\x00\x00"], [0]]
    - ["st1576_043", "struct.unpack", ["!BBBB", b"\xc0\xa8\x01\x01"], [192, 168, 1, 1]]
    - ["st1576_044", "struct.unpack", ["!BBBB", b"\x7f\x00\x00\x01"], [127, 0, 0, 1]]
    - ["st1576_045", "struct.unpack", ["3s",  b"abc"], [b"abc"]]

# ---------------------------------------------------------------------------
# str() of unpack result — tuple.__str__
# ---------------------------------------------------------------------------

table struct_extra1576.unpack_str:
  kind: python_call_eq
  category: str_repr
  id_prefix: st1576

  columns: [id, function, args, expected]
  rows:
    - ["st1576_050", "struct.unpack.__str__", [">H", b"\x01\x00"], "(256,)"]
    - ["st1576_051", "struct.unpack.__str__", [">I", b"\x00\x00\x00\x00"], "(0,)"]

# ---------------------------------------------------------------------------
# calcsize() — format string size in bytes
# ---------------------------------------------------------------------------

table struct_extra1576.calcsize:
  kind: python_call_eq
  category: properties
  id_prefix: st1576

  columns: [id, function, args, expected]
  rows:
    - ["st1576_060", "struct.calcsize", [">B"], 1]
    - ["st1576_061", "struct.calcsize", [">H"], 2]
    - ["st1576_062", "struct.calcsize", [">I"], 4]
    - ["st1576_063", "struct.calcsize", [">Q"], 8]
    - ["st1576_064", "struct.calcsize", [">f"], 4]
    - ["st1576_065", "struct.calcsize", [">d"], 8]
    - ["st1576_066", "struct.calcsize.__str__", [">H"], "2"]
    - ["st1576_067", "struct.calcsize.__str__", [">I"], "4"]

# ---------------------------------------------------------------------------
# struct.Struct — pre-compiled format object
# ---------------------------------------------------------------------------

table struct_extra1576.struct_object:
  kind: python_call_eq
  category: properties
  id_prefix: st1576

  columns: [id, function, args, expected]
  rows:
    - ["st1576_070", "struct.Struct.size", [">H"], 2]
    - ["st1576_071", "struct.Struct.size", [">I"], 4]
    - ["st1576_072", "struct.Struct.size", [">Q"], 8]
    - ["st1576_073", "struct.Struct.size", [">B"], 1]
    - ["st1576_074", "struct.Struct.format", [">H"], ">H"]
