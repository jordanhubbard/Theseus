spec: abc_extra43
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra42.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all five, abstractproperty lengths, ABCMeta.register qualname lengths, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__(), various qualname length tables, ABCMeta MRO entries, ABC/__abstractmethods__/__class__/__name__=='frozenset', ABC/__abstractmethods__/__len__()==0, ABCMeta.__call__/__qualname__=='type.__call__', class qualname string equality, abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta', abstractproperty/__mro__.__len__()==3, abstractclassmethod/__mro__.__len__()==3, abstractstaticmethod/__mro__.__len__()==3, abstractproperty/__bases__[0].__name__.__len__()==8, abstractclassmethod/__bases__[0].__name__.__len__()==11, abstractstaticmethod/__bases__[0].__name__.__len__()==12 (extra40), __class__.__qualname__ string equality and __len__() for abstractproperty/ABC/ABCMeta/abstractmethod/get_cache_token, ABCMeta.__abstractmethods__ raises AttributeError (extra41), abstractmethod/__class__.__module__=='builtins', abstractproperty/__class__.__module__=='builtins', ABC/__class__.__module__=='abc', ABCMeta/__class__.__module__=='builtins', get_cache_token/__class__.__module__=='builtins', abstractclassmethod/__class__.__module__=='builtins', abstractstaticmethod/__class__.__module__=='builtins', __class__.__module__.__len__() for all (extra42)."
    - "This spec covers: abstractmethod/__class__.__qualname__=='function'; abstractproperty/__class__.__qualname__=='type'; ABCMeta/__class__.__qualname__=='type'; ABC/__class__.__qualname__=='ABCMeta'; get_cache_token/__class__.__qualname__=='builtin_function_or_method'; abstractclassmethod/__class__.__qualname__=='type'; abstractstaticmethod/__class__.__qualname__=='type'; update_abstractmethods/__class__.__qualname__=='function'; __class__.__qualname__.__len__() for all eight objects."
    - "abc.abstractmethod.__class__.__qualname__ == 'function'. abstractmethod is a plain Python function; its __class__ is the built-in 'function' type, whose __qualname__ == 'function' (8 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__class__.__qualname__ == 'type'. abstractproperty is a class (subclass of property); its metaclass is the built-in 'type', whose __qualname__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__class__.__qualname__ == 'type'. ABCMeta is itself a class; its metaclass is the built-in 'type', whose __qualname__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__class__.__qualname__ == 'ABCMeta'. ABC is an instance of ABCMeta (the metaclass); therefore ABC.__class__ is ABCMeta, and ABCMeta.__qualname__ == 'ABCMeta' (7 chars). This is the only abc export whose __class__.__qualname__ is not a built-in type name. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token.__class__.__qualname__ == 'builtin_function_or_method'. get_cache_token is a C-extension function from _abc; its __class__ is builtin_function_or_method. Since this is a built-in type, its __qualname__ == __name__ == 'builtin_function_or_method' (26 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractclassmethod.__class__.__qualname__ == 'type'. abstractclassmethod is a class (subclass of classmethod); its metaclass is the built-in 'type', whose __qualname__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractstaticmethod.__class__.__qualname__ == 'type'. abstractstaticmethod is a class (subclass of staticmethod); its metaclass is the built-in 'type', whose __qualname__ == 'type' (4 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__class__.__qualname__ == 'function'. update_abstractmethods is a plain Python function added in Python 3.10; its __class__ is the built-in 'function' type, whose __qualname__ == 'function' (8 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "The __class__.__qualname__ dimension reveals an interesting hierarchy: 'type' (4 chars) for plain classes, 'function' (8 chars) for Python functions, 'ABCMeta' (7 chars) for ABC, and 'builtin_function_or_method' (26 chars) for get_cache_token. The latter is notably longer than all other __class__.__qualname__ values seen across the abc specs. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc object __class__.__qualname__ string equality — extra43
#
# Five abc exports have __class__.__qualname__ == 'type' (plain classes):
#   abstractproperty.__class__.__qualname__    == 'type'
#   ABCMeta.__class__.__qualname__             == 'type'
#   abstractclassmethod.__class__.__qualname__ == 'type'
#   abstractstaticmethod.__class__.__qualname__== 'type'
# Two abc exports have __class__.__qualname__ == 'function' (Python functions):
#   abstractmethod.__class__.__qualname__       == 'function'
#   update_abstractmethods.__class__.__qualname__== 'function'
# ABC is the metaclass-instance outlier:
#   ABC.__class__.__qualname__                 == 'ABCMeta'
# get_cache_token is the C-extension outlier:
#   get_cache_token.__class__.__qualname__     == 'builtin_function_or_method'
# Prior specs captured __class__.__name__ (extra40) and __class__.__module__ (extra42).
# Extra43 captures __class__.__qualname__ for the first time across all eight abc exports.
# ---------------------------------------------------------------------------

table abc_extra43.class_qualname_eq:
  description: "abc object __class__.__qualname__ string equality in extra43 namespace — four classes == 'type', two functions == 'function', ABC == 'ABCMeta', get_cache_token == 'builtin_function_or_method'"
  kind: python_call_eq
  category: class_names
  id_prefix: abcclsqual43

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod,        abstractmethod.__class__.__qualname__.__eq__,        ["function"],                   true, "abstractmethod.__class__.__qualname__ == 'function' — plain Python function; built-in 'function' type has __qualname__ == 'function' (8 chars)"]
    - [abstractproperty,      abstractproperty.__class__.__qualname__.__eq__,      ["type"],                       true, "abstractproperty.__class__.__qualname__ == 'type' — class (subclass of property); built-in 'type' metaclass has __qualname__ == 'type' (4 chars)"]
    - [ABCMeta,               ABCMeta.__class__.__qualname__.__eq__,               ["type"],                       true, "ABCMeta.__class__.__qualname__ == 'type' — class whose metaclass is the built-in 'type'; __class__.__qualname__ == 'type' (4 chars)"]
    - [ABC,                   ABC.__class__.__qualname__.__eq__,                   ["ABCMeta"],                    true, "ABC.__class__.__qualname__ == 'ABCMeta' — ABC is an instance of ABCMeta; ABCMeta.__qualname__ == 'ABCMeta' (7 chars)"]
    - [get_cache_token,       get_cache_token.__class__.__qualname__.__eq__,       ["builtin_function_or_method"], true, "get_cache_token.__class__.__qualname__ == 'builtin_function_or_method' — C-extension from _abc; __class__.__qualname__ == 'builtin_function_or_method' (26 chars)"]
    - [abstractclassmethod,   abstractclassmethod.__class__.__qualname__.__eq__,   ["type"],                       true, "abstractclassmethod.__class__.__qualname__ == 'type' — class (subclass of classmethod); built-in 'type' metaclass has __qualname__ == 'type' (4 chars)"]
    - [abstractstaticmethod,  abstractstaticmethod.__class__.__qualname__.__eq__,  ["type"],                       true, "abstractstaticmethod.__class__.__qualname__ == 'type' — class (subclass of staticmethod); built-in 'type' metaclass has __qualname__ == 'type' (4 chars)"]
    - [update_abstractmethods, update_abstractmethods.__class__.__qualname__.__eq__, ["function"],                 true, "update_abstractmethods.__class__.__qualname__ == 'function' — plain Python function added in 3.10; built-in 'function' type has __qualname__ == 'function' (8 chars)"]

# ---------------------------------------------------------------------------
# abc object __class__.__qualname__.__len__() — extra43
#
# Classes (__class__.__qualname__ == 'type'): 4 chars
#   abstractproperty/ABCMeta/abstractclassmethod/abstractstaticmethod == 4
# Python functions (__class__.__qualname__ == 'function'): 8 chars
#   abstractmethod/update_abstractmethods == 8
# ABC metaclass-instance (__class__.__qualname__ == 'ABCMeta'): 7 chars
#   ABC == 7
# C-extension (__class__.__qualname__ == 'builtin_function_or_method'): 26 chars
#   get_cache_token == 26
# ---------------------------------------------------------------------------

table abc_extra43.class_qualname_lengths:
  description: "abc object __class__.__qualname__.__len__() in extra43 namespace — classes==4, functions==8, ABC==7, get_cache_token==26"
  kind: python_call_eq
  category: class_names
  id_prefix: abcclsquallen43

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod,        abstractmethod.__class__.__qualname__.__len__,        [], 8,  "abstractmethod.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"]
    - [abstractproperty,      abstractproperty.__class__.__qualname__.__len__,      [], 4,  "abstractproperty.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [ABCMeta,               ABCMeta.__class__.__qualname__.__len__,               [], 4,  "ABCMeta.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [ABC,                   ABC.__class__.__qualname__.__len__,                   [], 7,  "ABC.__class__.__qualname__.__len__() == 7 — 'ABCMeta' has 7 characters"]
    - [get_cache_token,       get_cache_token.__class__.__qualname__.__len__,       [], 26, "get_cache_token.__class__.__qualname__.__len__() == 26 — 'builtin_function_or_method' has 26 characters"]
    - [abstractclassmethod,   abstractclassmethod.__class__.__qualname__.__len__,   [], 4,  "abstractclassmethod.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [abstractstaticmethod,  abstractstaticmethod.__class__.__qualname__.__len__,  [], 4,  "abstractstaticmethod.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [update_abstractmethods, update_abstractmethods.__class__.__qualname__.__len__, [], 8, "update_abstractmethods.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra43
# ---------------------------------------------------------------------------

invariant abc_extra43.abstractmethod_class_qualname_eq:
  description: "abc.abstractmethod.__class__.__qualname__ == 'function' — plain Python function; built-in 'function' type has __qualname__ == 'function' (8 chars)"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__class__.__qualname__.__eq__
  args: ["function"]
  expected: true

invariant abc_extra43.abstractproperty_class_qualname_eq:
  description: "abc.abstractproperty.__class__.__qualname__ == 'type' — class (subclass of property); built-in 'type' metaclass has __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: abstractproperty.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra43.ABCMeta_class_qualname_eq:
  description: "abc.ABCMeta.__class__.__qualname__ == 'type' — ABCMeta is a class whose metaclass is the built-in 'type'; __class__.__qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra43.ABC_class_qualname_eq:
  description: "abc.ABC.__class__.__qualname__ == 'ABCMeta' — ABC is an instance of ABCMeta; ABCMeta.__qualname__ == 'ABCMeta' (7 chars); only non-type/function __class__.__qualname__ among abc exports"
  category: class_names
  kind: python_call_eq
  function: ABC.__class__.__qualname__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra43.get_cache_token_class_qualname_eq:
  description: "abc.get_cache_token.__class__.__qualname__ == 'builtin_function_or_method' — C-extension function from _abc; __class__.__qualname__ == 'builtin_function_or_method' (26 chars)"
  category: class_names
  kind: python_call_eq
  function: get_cache_token.__class__.__qualname__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra43.abstractclassmethod_class_qualname_eq:
  description: "abc.abstractclassmethod.__class__.__qualname__ == 'type' — class (subclass of classmethod); built-in 'type' metaclass has __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: abstractclassmethod.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra43.abstractstaticmethod_class_qualname_eq:
  description: "abc.abstractstaticmethod.__class__.__qualname__ == 'type' — class (subclass of staticmethod); built-in 'type' metaclass has __qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: abstractstaticmethod.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra43.update_abstractmethods_class_qualname_eq:
  description: "abc.update_abstractmethods.__class__.__qualname__ == 'function' — plain Python function added in 3.10; built-in 'function' type has __qualname__ == 'function' (8 chars)"
  category: class_names
  kind: python_call_eq
  function: update_abstractmethods.__class__.__qualname__.__eq__
  args: ["function"]
  expected: true

invariant abc_extra43.abstractmethod_class_qualname_len:
  description: "abc.abstractmethod.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__class__.__qualname__.__len__
  args: []
  expected: 8

invariant abc_extra43.ABC_class_qualname_len:
  description: "abc.ABC.__class__.__qualname__.__len__() == 7 — 'ABCMeta' has 7 characters; ABC's metaclass is user-defined ABCMeta"
  category: class_names
  kind: python_call_eq
  function: ABC.__class__.__qualname__.__len__
  args: []
  expected: 7

invariant abc_extra43.get_cache_token_class_qualname_len:
  description: "abc.get_cache_token.__class__.__qualname__.__len__() == 26 — 'builtin_function_or_method' has 26 characters; longest __class__.__qualname__ among abc exports"
  category: class_names
  kind: python_call_eq
  function: get_cache_token.__class__.__qualname__.__len__
  args: []
  expected: 26

invariant abc_extra43.ABCMeta_class_qualname_len:
  description: "abc.ABCMeta.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__class__.__qualname__.__len__
  args: []
  expected: 4
