spec: itertools_extra66
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra65.zspec.zsdl."
    - "Wave 232 theme: docstring content for accumulate/cycle/repeat/count/filterfalse (all C extension types with no __code__)."
    - "All itertools types are C extension types (Modules/itertoolsmodule.c) and have no __code__ attribute. This spec extends __doc__ content checks to accumulate, cycle, repeat, count, and filterfalse."
    - "accumulate.__doc__.__contains__('accumulate') == True — the type name appears in the accumulate docstring. Verified with Python 3.14.3."
    - "accumulate.__doc__.__contains__('iterable') == True — accumulate(iterable, func=operator.add, *, initial=None) takes an iterable; 'iterable' appears in the docstring. Verified with Python 3.14.3."
    - "cycle.__doc__.__contains__('cycle') == True — the type name 'cycle' appears in the cycle docstring. Verified with Python 3.14.3."
    - "cycle.__doc__.__contains__('element') == True — cycle returns each element of the iterable in succession; 'element' appears in the docstring. Verified with Python 3.14.3."
    - "repeat.__doc__.__contains__('object') == True — repeat(object, times=None) uses 'object' as the first parameter name in the docstring. Verified with Python 3.14.3."
    - "repeat.__doc__.__contains__('times') == True — repeat(object, times=None); 'times' appears as a parameter name in the docstring. Verified with Python 3.14.3."
    - "count.__doc__.__contains__('count') == True — the type name 'count' appears in the count docstring. Verified with Python 3.14.3."
    - "count.__doc__.__contains__('step') == True — count(start=0, step=1); 'step' appears as a parameter name in the docstring. Verified with Python 3.14.3."
    - "filterfalse.__doc__.__contains__('predicate') == True — filterfalse(predicate, iterable); 'predicate' appears as the first parameter name. Verified with Python 3.14.3."
    - "Prior itertools_extra64 covered combinations/permutations/product/compress docstring content."
    - "Prior itertools_extra65 covered chain/islice/dropwhile/takewhile/groupby/starmap/zip_longest docstring content."
    - "No prior itertools spec checks accumulate.__doc__, cycle.__doc__, repeat.__doc__, count.__doc__, or filterfalse.__doc__ content. All checks in this spec are new to extra66."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# accumulate.__doc__.__contains__ — extra66
#
# Wave 232 theme: __doc__ content checks for itertools C extension types.
#
# itertools.accumulate is a C extension type (Modules/itertoolsmodule.c).
# Its docstring opens with:
#   'accumulate(iterable[, func, *, initial=None]) --> accumulate object\n\n
#    Return series of accumulated sums (or other binary function results).'
#
# Key findings:
#   accumulate.__doc__.__contains__('accumulate') == True
#     (the type name appears in the signature line)
#   accumulate.__doc__.__contains__('iterable') == True
#     ('iterable' is the first parameter name in the signature)
#
# No prior itertools spec checks accumulate.__doc__. New to extra66.
# ---------------------------------------------------------------------------

table itertools_extra66.accumulate_doc_contains:
  description: "accumulate.__doc__.__contains__ checks — 'accumulate' and 'iterable' in docstring; wave 232 __doc__ content; new to extra66"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc5_66

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_doc_contains_accumulate,
       accumulate.__doc__.__contains__,
       ["accumulate"],
       true,
       "itertools.accumulate.__doc__.__contains__('accumulate') == True — accumulate is a C extension type (Modules/itertoolsmodule.c) that returns accumulated sums (or results of a binary function) from an iterable; its docstring opens with 'accumulate(iterable[, func, *, initial=None]) --> accumulate object'; the word 'accumulate' appears both as the type name in the call signature and as part of 'accumulate object' in the return description; str.__contains__ returns True at the first occurrence; no prior itertools spec checks accumulate.__doc__.__contains__('accumulate'); new to extra66"]
    - [accumulate_doc_contains_iterable,
       accumulate.__doc__.__contains__,
       ["iterable"],
       true,
       "itertools.accumulate.__doc__.__contains__('iterable') == True — accumulate.__doc__ opens with 'accumulate(iterable[, func, *, initial=None]) --> accumulate object'; the word 'iterable' appears as the first parameter name in the signature line; str.__contains__ returns True at the first occurrence; no prior itertools spec checks accumulate.__doc__.__contains__('iterable'); new to extra66"]

# ---------------------------------------------------------------------------
# cycle.__doc__.__contains__ — extra66
#
# Wave 232 theme: __doc__ content checks for itertools C extension types.
#
# itertools.cycle is a C extension type (Modules/itertoolsmodule.c).
# Its docstring opens with:
#   'cycle(iterable) --> cycle object\n\n
#    Return elements from the iterable until it is exhausted. Then repeat
#    the sequence indefinitely.'
#
# Key findings:
#   cycle.__doc__.__contains__('cycle') == True
#     (the type name 'cycle' appears in the signature line)
#   cycle.__doc__.__contains__('element') == True
#     ('elements' in the body — 'Return elements from the iterable';
#      'element' is a substring of 'elements')
#
# No prior itertools spec checks cycle.__doc__. New to extra66.
# ---------------------------------------------------------------------------

table itertools_extra66.cycle_doc_contains:
  description: "cycle.__doc__.__contains__ checks — 'cycle' and 'element' in docstring; wave 232 __doc__ content; new to extra66"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc5_66

  columns: [id, function, args, expected, description]
  rows:
    - [cycle_doc_contains_cycle,
       cycle.__doc__.__contains__,
       ["cycle"],
       true,
       "itertools.cycle.__doc__.__contains__('cycle') == True — cycle is a C extension type (Modules/itertoolsmodule.c) that cycles endlessly through an iterable; its docstring opens with 'cycle(iterable) --> cycle object'; the word 'cycle' appears both as the type name in the call signature and as part of 'cycle object' in the return type; str.__contains__ returns True at the first occurrence; no prior itertools spec checks cycle.__doc__.__contains__('cycle'); new to extra66"]
    - [cycle_doc_contains_element,
       cycle.__doc__.__contains__,
       ["element"],
       true,
       "itertools.cycle.__doc__.__contains__('element') == True — cycle.__doc__ includes the body text 'Return elements from the iterable until it is exhausted'; the word 'elements' (plural) contains 'element' as a substring; str.__contains__ returns True when searching for 'element' within 'elements'; no prior itertools spec checks cycle.__doc__.__contains__('element'); new to extra66"]

# ---------------------------------------------------------------------------
# repeat.__doc__.__contains__ — extra66
#
# Wave 232 theme: __doc__ content checks for itertools C extension types.
#
# itertools.repeat is a C extension type (Modules/itertoolsmodule.c).
# Its docstring opens with:
#   'repeat(object[, times]) --> repeat object\n\n
#    Return a repeat object whose __next__() method returns object for
#    times times or infinitely if not specified.'
#
# Key findings:
#   repeat.__doc__.__contains__('object') == True
#     ('object' is the first parameter name in the signature line)
#   repeat.__doc__.__contains__('times') == True
#     ('times' appears as the optional second parameter name)
#
# No prior itertools spec checks repeat.__doc__. New to extra66.
# ---------------------------------------------------------------------------

table itertools_extra66.repeat_doc_contains:
  description: "repeat.__doc__.__contains__ checks — 'object' and 'times' in docstring; wave 232 __doc__ content; new to extra66"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc5_66

  columns: [id, function, args, expected, description]
  rows:
    - [repeat_doc_contains_object,
       repeat.__doc__.__contains__,
       ["object"],
       true,
       "itertools.repeat.__doc__.__contains__('object') == True — repeat is a C extension type (Modules/itertoolsmodule.c) that returns a single object repeatedly; its docstring opens with 'repeat(object[, times]) --> repeat object'; the word 'object' appears as the first parameter name in the signature line and again as part of 'repeat object'; str.__contains__ returns True at the first occurrence; no prior itertools spec checks repeat.__doc__.__contains__('object'); new to extra66"]
    - [repeat_doc_contains_times,
       repeat.__doc__.__contains__,
       ["times"],
       true,
       "itertools.repeat.__doc__.__contains__('times') == True — repeat.__doc__ opens with 'repeat(object[, times]) --> repeat object'; the word 'times' appears as the optional second parameter name in the signature line and again in the body ('returns object for times times'); str.__contains__ returns True at the first occurrence in the signature; no prior itertools spec checks repeat.__doc__.__contains__('times'); new to extra66"]

# ---------------------------------------------------------------------------
# count.__doc__ and filterfalse.__doc__.__contains__ — extra66
#
# Wave 232 theme: __doc__ content checks for itertools C extension types.
#
# itertools.count is a C extension type (Modules/itertoolsmodule.c).
# Its docstring opens with:
#   'count(start=0, step=1) --> count object\n\n
#    Return a count object whose __next__() method returns consecutive values.'
#
# itertools.filterfalse is a C extension type (Modules/itertoolsmodule.c).
# Its docstring opens with:
#   'filterfalse(predicate, iterable) --> filterfalse object\n\n
#    Return those items of iterable for which function(item) is false.'
#
# Key findings:
#   count.__doc__.__contains__('count') == True
#   count.__doc__.__contains__('step')  == True
#   filterfalse.__doc__.__contains__('predicate') == True
#
# No prior itertools spec checks count.__doc__ or filterfalse.__doc__. New to extra66.
# ---------------------------------------------------------------------------

table itertools_extra66.count_filterfalse_doc_contains:
  description: "count/filterfalse __doc__.__contains__ checks — key words in docstrings; wave 232 __doc__ content; new to extra66"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc5_66

  columns: [id, function, args, expected, description]
  rows:
    - [count_doc_contains_count,
       count.__doc__.__contains__,
       ["count"],
       true,
       "itertools.count.__doc__.__contains__('count') == True — count is a C extension type (Modules/itertoolsmodule.c) that returns evenly spaced values starting from a number; its docstring opens with 'count(start=0, step=1) --> count object'; the word 'count' appears both as the type name in the call signature and as part of 'count object' in the return description; str.__contains__ returns True at the first occurrence; no prior itertools spec checks count.__doc__.__contains__('count'); new to extra66"]
    - [count_doc_contains_step,
       count.__doc__.__contains__,
       ["step"],
       true,
       "itertools.count.__doc__.__contains__('step') == True — count.__doc__ opens with 'count(start=0, step=1) --> count object'; the word 'step' appears as the second parameter name in the signature line; str.__contains__ returns True at the first occurrence; no prior itertools spec checks count.__doc__.__contains__('step'); new to extra66"]
    - [filterfalse_doc_contains_predicate,
       filterfalse.__doc__.__contains__,
       ["predicate"],
       true,
       "itertools.filterfalse.__doc__.__contains__('predicate') == True — filterfalse is a C extension type (Modules/itertoolsmodule.c) that returns those items of an iterable for which a predicate is false; its docstring opens with 'filterfalse(predicate, iterable) --> filterfalse object'; the word 'predicate' appears as the first parameter name in the signature line; str.__contains__ returns True at the first occurrence; no prior itertools spec checks filterfalse.__doc__.__contains__('predicate'); new to extra66"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra66
# ---------------------------------------------------------------------------

invariant itertools_extra66.accumulate_doc_accumulate:
  description: "itertools.accumulate.__doc__.__contains__('accumulate') == True — type name in accumulate docstring; wave 232 __doc__ content; new to extra66"
  kind: python_call_eq
  function: accumulate.__doc__.__contains__
  args: ["accumulate"]
  expected: true

invariant itertools_extra66.cycle_doc_cycle:
  description: "itertools.cycle.__doc__.__contains__('cycle') == True — type name in cycle docstring; wave 232 __doc__ content; new to extra66"
  kind: python_call_eq
  function: cycle.__doc__.__contains__
  args: ["cycle"]
  expected: true

invariant itertools_extra66.repeat_doc_times:
  description: "itertools.repeat.__doc__.__contains__('times') == True — 'times' is the optional second parameter in repeat docstring; wave 232 __doc__ content; new to extra66"
  kind: python_call_eq
  function: repeat.__doc__.__contains__
  args: ["times"]
  expected: true

invariant itertools_extra66.count_doc_step:
  description: "itertools.count.__doc__.__contains__('step') == True — 'step' is the second parameter in count docstring; wave 232 __doc__ content; new to extra66"
  kind: python_call_eq
  function: count.__doc__.__contains__
  args: ["step"]
  expected: true
