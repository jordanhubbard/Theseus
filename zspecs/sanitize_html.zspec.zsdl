spec: sanitize_html
version: ">=2.0.0"
backend: node(sanitize-html)

docs: https://www.npmjs.com/package/sanitize-html

provenance:
  derived_from:
    - "sanitize-html README — https://www.npmjs.com/package/sanitize-html"
    - "Test vectors verified with sanitize-html via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "sanitize-html source"
  notes:
    - "sanitize-html is an npm package. Install: npm install sanitize-html"
    - "sanitizeHtml(str) removes unsafe HTML by default (keeps a safe subset of tags)."
    - "sanitizeHtml(str, {allowedTags: []}) strips all HTML tags."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns sanitized HTML string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table sanitize_html.sanitize:
  kind: node_module_call_eq
  function: ~
  category: sanitize
  id_prefix: sanh

  columns: [id, args, expected]
  rows:
    - [safe_tag,    ["<p>Hello</p>"],                        "<p>Hello</p>"]
    - [strip_script,["<script>alert(1)</script>Hello"],      "Hello"]
    - [strip_all,   ["<b>bold</b> text", {"allowedTags": []}], "bold text"]
