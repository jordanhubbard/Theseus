spec: hashlib_extra146
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra145.zspec.zsdl — covers hashlib.algorithms_guaranteed/__class__.__name__.__eq__('set') / algorithms_available/__class__.__name__.__eq__('set') / __class__.__name__.__len__()==3 / algorithms_guaranteed membership (sha256/md5/sha1/sha512/blake2b) / sha256/__name__.__eq__('openssl_sha256').__len__()==14 / md5/__name__.__eq__('openssl_md5').__len__()==11 (table + invariants)."
    - "hashlib_extra144.zspec.zsdl — covers hashlib._hashlib.HASH/__doc__/__len__()==442 / HASH.update/digest/hexdigest/copy __doc__ lengths / HASH method __qualname__ lengths / sha256 vs sha512/sha224 __doc__ inequality / new.__qualname__.__len__()==10."
    - "hashlib_extra143.zspec.zsdl — covers hashlib.md5/sha1/sha224/sha256/sha384/sha512 __doc__ lengths and qualname lengths / pbkdf2_hmac/scrypt __doc__ lengths / __module__ equality."
    - "hashlib_extra142.zspec.zsdl — covers hashlib.blake2b and blake2s class constants / blake2b/blake2s __doc__ identity and length / sha3/shake constructor __doc__ lengths."
    - "hashlib_extra141.zspec.zsdl — covers hashlib SHA constructor __doc__.__class__.__name__ / __spec__ attribute identity / new.__doc__.__len__()==147 / file_digest.__doc__.__len__()==417."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ equality / blake2b/blake2s class identity / new/__class__.__name__=='function' / algorithms_guaranteed.__len__()==14."
    - "hashlib_extra98.zspec.zsdl — covers hashlib.sha3_*/shake_* constructor __qualname__ and __module__ equality."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership / algorithms_available membership / new/__qualname__/__len__()."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra145."
    - "Wave 298 theme: hashlib.pbkdf2_hmac and hashlib.scrypt function identity / pbkdf2_hmac/__qualname__/__len__()==11 / pbkdf2_hmac/__module__.__eq__('_hashlib') / scrypt/__module__.__eq__('_hashlib') / blake2b/__module__.__eq__('_blake2') / blake2s/__module__.__eq__('_blake2') / pbkdf2_hmac vs scrypt __module__ equality / blake2b vs blake2s __module__ equality."
    - "hashlib.pbkdf2_hmac.__doc__.__len__() == 91. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib' (len 8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__doc__.__len__() == 46. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__qualname__ == 'scrypt' (len 6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__module__ == '_hashlib' (len 8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__module__ == hashlib.pbkdf2_hmac.__module__ (both '_hashlib'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__ == '_blake2' (len 7). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__module__ == '_blake2' (len 7). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__ == hashlib.blake2s.__module__ (both '_blake2'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__doc__ == 'Password based key derivation function 2 (PKCS #5 v2.0) with HMAC as pseudorandom function.' (91 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__doc__ == 'scrypt password-based key derivation function.' (46 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.pbkdf2_hmac and hashlib.scrypt are both C-level builtin_function_or_method objects from the _hashlib C extension (_hashlib module). Their __module__ is '_hashlib' (with underscore prefix indicating a private C extension), not 'hashlib'. The public hashlib module re-exports them."
    - "Note: hashlib.blake2b and hashlib.blake2s both come from a separate C extension named '_blake2' (7 chars, one char shorter than '_hashlib' at 8 chars). This reflects the separate blake2 implementation in CPython's Modules/_blake2/ directory."
    - "Note: hashlib.pbkdf2_hmac.__qualname__ is 'pbkdf2_hmac' (11 chars), same as its __name__. scrypt.__qualname__ is 'scrypt' (6 chars). These KDF functions have simple (non-qualified) qualnames because they are module-level C functions not nested within any class."
    - "Note: pbkdf2_hmac.__doc__ (91 chars) is the longer KDF docstring because PKCS #5 v2.0 acronym expansion takes more space. scrypt.__doc__ (46 chars) is shorter — just names the algorithm."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__qualname__.__len__()==11
# hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac')
# hashlib.scrypt.__qualname__.__len__()==6
# hashlib.scrypt.__qualname__.__eq__('scrypt')
#
# Wave 298 theme: pbkdf2_hmac and scrypt qualname identity.
#
# Both pbkdf2_hmac and scrypt are module-level C functions with simple (non-qualified)
# qualnames equal to their __name__. pbkdf2_hmac (11 chars) is the longer qualname;
# scrypt (6 chars) is the shorter. extra143 anchors pbkdf2_hmac/scrypt __doc__ lengths
# and __qualname__ lengths; no prior hashlib spec anchors the equality strings together
# as a table under hashdoc146. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra146.kdf_function_qualname_identity:
  description: "hashlib.pbkdf2_hmac/__qualname__.__len__()==11 / __qualname__.__eq__('pbkdf2_hmac')==True / scrypt/__qualname__.__len__()==6 / __qualname__.__eq__('scrypt')==True — both KDF functions are C-level builtin_function_or_method with simple qualnames equal to __name__; pbkdf2_hmac (11) is longer than scrypt (6); extra143 anchors lengths; first hashdoc146 anchor for equality strings"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: hashdoc146

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_hmac_qualname_eq,  pbkdf2_hmac.__qualname__.__eq__, ["pbkdf2_hmac"], true, "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac' (11 chars; module-level C function; qualname equals __name__)"]
    - [pbkdf2_hmac_qualname_len, pbkdf2_hmac.__qualname__.__len__, [],             11,   "hashlib.pbkdf2_hmac.__qualname__.__len__() is 11 ('pbkdf2_hmac' — the standard PKCS #5 v2.0 key derivation function name)"]
    - [scrypt_qualname_eq,       scrypt.__qualname__.__eq__,       ["scrypt"],     true, "hashlib.scrypt.__qualname__ == 'scrypt' (6 chars; module-level C function; qualname equals __name__)"]
    - [scrypt_qualname_len,      scrypt.__qualname__.__len__,      [],             6,    "hashlib.scrypt.__qualname__.__len__() is 6 ('scrypt' — 6-char algorithm name; shorter than pbkdf2_hmac's 11)"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib')
# hashlib.scrypt.__module__.__eq__('_hashlib')
# hashlib.pbkdf2_hmac.__module__.__eq__(hashlib.scrypt.__module__)
# hashlib.pbkdf2_hmac.__module__.__len__()==8
#
# Wave 298 theme: pbkdf2_hmac and scrypt both come from _hashlib C extension.
#
# Both KDF functions have __module__ == '_hashlib' (8 chars, with underscore prefix).
# This contrasts with blake2b/blake2s which come from '_blake2' (7 chars).
# extra143 anchors pbkdf2_hmac.__module__ equality; no prior hashlib spec anchors
# scrypt.__module__ equality or the co-module equality check under hashdoc146.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra146.kdf_module_identity:
  description: "hashlib.pbkdf2_hmac/__module__.__eq__('_hashlib')==True / __module__.__len__()==8 / scrypt/__module__.__eq__('_hashlib')==True / pbkdf2_hmac.__module__.__eq__(scrypt.__module__)==True — both KDF functions come from the _hashlib C extension (underscore prefix); '_hashlib' is 8 chars; blake2b/blake2s come from '_blake2' (7 chars) instead; extra143 anchors pbkdf2_hmac module; first hashdoc146 anchor for scrypt module and shared-module equality"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc146

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_hmac_module_eq,  pbkdf2_hmac.__module__.__eq__,   ["_hashlib"], true, "hashlib.pbkdf2_hmac.__module__ == '_hashlib' (C extension with underscore prefix; 8 chars)"]
    - [pbkdf2_hmac_module_len, pbkdf2_hmac.__module__.__len__,  [],           8,    "hashlib.pbkdf2_hmac.__module__.__len__() is 8 ('_hashlib' = underscore + 7-char 'hashlib')"]
    - [scrypt_module_eq,       scrypt.__module__.__eq__,        ["_hashlib"], true, "hashlib.scrypt.__module__ == '_hashlib' (same C extension as pbkdf2_hmac)"]
    - [scrypt_module_len,      scrypt.__module__.__len__,       [],           8,    "hashlib.scrypt.__module__.__len__() is 8 (same as pbkdf2_hmac; both come from _hashlib)"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__module__.__eq__('_blake2')
# hashlib.blake2s.__module__.__eq__('_blake2')
# hashlib.blake2b.__module__.__len__()==7
# hashlib.blake2b.__module__.__eq__(hashlib.blake2s.__module__)
#
# Wave 298 theme: blake2b and blake2s both come from _blake2 C extension.
#
# blake2b and blake2s have __module__ == '_blake2' (7 chars), which is 1 char
# shorter than '_hashlib' (8 chars). The separate _blake2 extension reflects
# the distinct Blake2 implementation in CPython's Modules/_blake2/ directory.
# extra142 anchors blake2b/blake2s class constants; no prior hashlib spec anchors
# blake2b/blake2s __module__ equality or length under hashdoc146.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra146.blake2_module_identity:
  description: "hashlib.blake2b/__module__.__eq__('_blake2')==True / __module__.__len__()==7 / blake2s/__module__.__eq__('_blake2')==True / blake2b.__module__.__eq__(blake2s.__module__)==True — both blake2 variants come from the _blake2 C extension (7 chars); 1 char shorter than '_hashlib' (8 chars); separate extension reflects Modules/_blake2/ directory; extra142 anchors blake2 class constants; first hashdoc146 anchor for _blake2 module equality and length"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc146

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_module_eq,  blake2b.__module__.__eq__,   ["_blake2"], true, "hashlib.blake2b.__module__ == '_blake2' (7 chars; separate _blake2 C extension)"]
    - [blake2b_module_len, blake2b.__module__.__len__,  [],          7,    "hashlib.blake2b.__module__.__len__() is 7 ('_blake2' = underscore + 6-char 'blake2'; 1 char shorter than '_hashlib')"]
    - [blake2s_module_eq,  blake2s.__module__.__eq__,   ["_blake2"], true, "hashlib.blake2s.__module__ == '_blake2' (same _blake2 C extension as blake2b)"]
    - [blake2s_module_len, blake2s.__module__.__len__,  [],          7,    "hashlib.blake2s.__module__.__len__() is 7 (same as blake2b; both come from _blake2)"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__qualname__.__len__()==11 — standalone
#
# hashlib.pbkdf2_hmac.__qualname__.__len__() is 11. The qualname 'pbkdf2_hmac' is
# 11 chars. It equals the __name__ because pbkdf2_hmac is a module-level C function
# (not a class method). The name 'pbkdf2_hmac' encodes the standard PKCS #5 v2.0
# algorithm name: PBKDF2 (Password-Based Key Derivation Function 2) with HMAC as
# the pseudorandom function. extra143 anchors this length; this standalone provides
# a cross-check under hashdoc146. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra146.pbkdf2_hmac_qualname_len_11:
  description: "hashlib.pbkdf2_hmac.__qualname__.__len__() == 11 — 'pbkdf2_hmac' (11 chars); qualname equals __name__ (module-level C function); encodes PBKDF2 + HMAC in name; extra143 anchors this length; cross-check standalone under hashdoc146"
  category: qualname_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__module__.__len__()==8 — standalone
#
# hashlib.pbkdf2_hmac.__module__.__len__() is 8. The module name '_hashlib' (8 chars)
# uses the standard CPython private-extension naming convention: underscore prefix +
# the public module name. '_hashlib' (8) is one char longer than '_blake2' (7)
# because 'hashlib' (7 chars) is one char longer than 'blake2' (6 chars).
# No prior hashlib spec anchors pbkdf2_hmac.__module__.__len__()==8 as a standalone
# under hashdoc146. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra146.pbkdf2_hmac_module_len_8:
  description: "hashlib.pbkdf2_hmac.__module__.__len__() == 8 — '_hashlib' (8 chars = underscore + 7-char 'hashlib'); 1 char longer than '_blake2' (7 chars = underscore + 6-char 'blake2'); standard CPython private-extension naming; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc146"
  category: identity
  kind: python_call_eq
  function: pbkdf2_hmac.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# hashlib.blake2b.__module__.__len__()==7 — standalone
#
# hashlib.blake2b.__module__.__len__() is 7. The module name '_blake2' (7 chars)
# is the private C extension backing the blake2b and blake2s constructors. At 7
# chars it is one char shorter than '_hashlib' (8 chars). blake2b and blake2s both
# share this module, reflecting that the two Blake2 variants (b=64-byte output,
# s=32-byte output) are implemented together in a single Modules/_blake2/ directory.
# No prior hashlib spec anchors blake2b.__module__.__len__()==7 as a standalone
# under hashdoc146. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra146.blake2b_module_len_7:
  description: "hashlib.blake2b.__module__.__len__() == 7 — '_blake2' (7 chars = underscore + 6-char 'blake2'); 1 char shorter than '_hashlib' (8 chars); blake2b and blake2s share this module (both variants in Modules/_blake2/); no prior hashlib spec anchors this as a standalone; first standalone under hashdoc146"
  category: identity
  kind: python_call_eq
  function: blake2b.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# hashlib.scrypt.__qualname__.__len__()==6 — standalone
#
# hashlib.scrypt.__qualname__.__len__() is 6. The qualname 'scrypt' is 6 chars —
# the same as the algorithm name. scrypt (memory-hard key derivation) has a shorter
# qualname than pbkdf2_hmac (11 chars) because its name is a single word rather
# than a compound name. scrypt is accessed via hashlib.scrypt but its __module__
# is '_hashlib', revealing it is a C-level function from the same extension as
# pbkdf2_hmac. No prior hashlib spec anchors scrypt.__qualname__.__len__()==6
# as a standalone under hashdoc146. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra146.scrypt_qualname_len_6:
  description: "hashlib.scrypt.__qualname__.__len__() == 6 — 'scrypt' (6 chars); shorter than pbkdf2_hmac (11) because 'scrypt' is a single word; memory-hard KDF; __module__ == '_hashlib' (same extension as pbkdf2_hmac); no prior hashlib spec anchors this as a standalone; first standalone under hashdoc146"
  category: qualname_identity
  kind: python_call_eq
  function: scrypt.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# hashlib.blake2s.__module__.__len__()==7 — standalone
#
# hashlib.blake2s.__module__.__len__() is 7. Both blake2b and blake2s share the
# '_blake2' module (7 chars). blake2s (the 32-byte output variant) is implemented
# in the same _blake2 C extension as blake2b (64-byte output variant). The shared
# module means changes to the blake2 C extension affect both variants equally.
# extra142 anchors blake2s class constants; no prior hashlib spec anchors
# blake2s.__module__.__len__()==7 as a standalone under hashdoc146.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra146.blake2s_module_len_7:
  description: "hashlib.blake2s.__module__.__len__() == 7 — '_blake2' (7 chars); same as blake2b.__module__ (both share the _blake2 C extension); blake2s produces 32-byte output while blake2b produces 64-byte output; extra142 anchors blake2s class constants; first standalone under hashdoc146"
  category: identity
  kind: python_call_eq
  function: blake2s.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__doc__.__class__.__name__.__eq__('str') — standalone
#
# hashlib.pbkdf2_hmac.__doc__.__class__.__name__ == 'str'. Even though pbkdf2_hmac
# is a C-level builtin_function_or_method, its docstring is a Python str. The
# 91-char docstring 'Password based key derivation function 2 (PKCS #5 v2.0) with
# HMAC as pseudorandom function.' describes the algorithm using its standard
# PKCS #5 v2.0 specification reference. No prior hashlib spec anchors
# pbkdf2_hmac.__doc__.__class__.__name__ == 'str' as a standalone under hashdoc146.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra146.pbkdf2_hmac_doc_class_str:
  description: "hashlib.pbkdf2_hmac.__doc__.__class__.__name__.__eq__('str') == True — C-level builtin_function_or_method with str docstring (91 chars); 'Password based key derivation function 2 (PKCS #5 v2.0) with HMAC as pseudorandom function.'; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc146"
  category: doc_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
