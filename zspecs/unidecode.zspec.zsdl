spec: unidecode
version: ">=1.0.0"
backend: node(unidecode)

docs: https://github.com/FGRibreau/node-unidecode#readme

provenance:
  derived_from:
    - "node-unidecode README — https://github.com/FGRibreau/node-unidecode#readme"
    - "Sean M. Burke's Text::Unidecode (Perl, the original implementation)"
    - "Test vectors verified with unidecode via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "unidecode source"
  notes:
    - "unidecode is a port of Sean M. Burke's Text::Unidecode that maps any Unicode string to its closest ASCII representation (lossy transliteration)."
    - "Install: npm install unidecode"
    - "Module export IS the function. Common applications: URL slug generation, filename sanitization."
    - "Emoji and most pictographs map to empty string; Latin diacritics drop accents; CJK characters use Mandarin pinyin transliterations with trailing space."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table unidecode.transliterate:
  kind: node_module_call_eq
  category: transliterate
  function: ~
  id_prefix: tr

  columns: [id, args, expected]
  rows:
    - [latin_diacritic,    ["Café"],         "Cafe"]
    - [umlaut,             ["Müller"],       "Muller"]
    - [cjk_japanese,       ["日本語"],         "Ri Ben Yu "]
    - [cyrillic_moscow,    ["Москва"],       "Moskva"]
    - [emoji_drops,        ["🎉"],            ""]
    - [pure_ascii_passthrough, ["plain"],     "plain"]
    - [empty_string,       [""],              ""]
    - [mixed,              ["Café 🎉 plain"],  "Cafe  plain"]
    - [german_eszett,      ["straße"],       "strasse"]
    - [single_emoji_then_text, ["🎉 yay"],    " yay"]
