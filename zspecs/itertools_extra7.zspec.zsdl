spec: itertools_extra7
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools.zspec.zsdl and prior extras through itertools_extra6.zspec.zsdl."
    - "Prior specs cover: __name__ for all 16 public C types (base spec + extras); __module__ for all types (extra3/extra4); __qualname__ for all 16 types (extra5); __class__.__name__ == 'type' for all 16 types (extra6); chain.from_iterable.__qualname__ and __name__ (extra6)."
    - "NEW in this spec: __bases__[0].__name__ == 'object' for all 16 public C types (every itertools type inherits directly from object — not tested in any prior spec); __bases__.__len__() == 1 for a representative subset."
    - "All 16 public itertools types are C-level single-inheritance types whose sole base is object."
    - "itertools.chain.__bases__[0].__name__ == 'object' — chain is a C type with one base."
    - "chain.from_iterable.__module__ is None — the classmethod descriptor has no __module__ attribute."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__name__ == 'object' for all 16 public itertools types
#
# Every public symbol in itertools is a C-level type that inherits directly from
# object (no intermediate ABC or mixin). Prior specs verified __name__,
# __module__, __qualname__, and __class__.__name__ == 'type' for each type, but
# none checked __bases__[0].__name__. This table fills that gap.
# ---------------------------------------------------------------------------

table itertools_extra7.bases_infinite:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base

  columns: [id, function, method, args, expected]
  rows:
    - [count,  count.__bases__.__getitem__,  __name__, [0], "object"]
    - [cycle,  cycle.__bases__.__getitem__,  __name__, [0], "object"]
    - [repeat, repeat.__bases__.__getitem__, __name__, [0], "object"]

table itertools_extra7.bases_terminating:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base

  columns: [id, function, method, args, expected]
  rows:
    - [chain,       chain.__bases__.__getitem__,       __name__, [0], "object"]
    - [islice,      islice.__bases__.__getitem__,      __name__, [0], "object"]
    - [accumulate,  accumulate.__bases__.__getitem__,  __name__, [0], "object"]
    - [zip_longest, zip_longest.__bases__.__getitem__, __name__, [0], "object"]

table itertools_extra7.bases_combinatoric:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base

  columns: [id, function, method, args, expected]
  rows:
    - [combinations,                  combinations.__bases__.__getitem__,                  __name__, [0], "object"]
    - [combinations_with_replacement, combinations_with_replacement.__bases__.__getitem__, __name__, [0], "object"]
    - [permutations,                  permutations.__bases__.__getitem__,                  __name__, [0], "object"]
    - [product,                       product.__bases__.__getitem__,                       __name__, [0], "object"]

# ---------------------------------------------------------------------------
# __bases__.__len__() == 1 for a representative set of itertools types
#
# Confirms that each type has exactly one direct base (no multiple inheritance).
# Tested for one type from each functional group.
# ---------------------------------------------------------------------------

table itertools_extra7.bases_len:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: bases_len

  columns: [id, function, args, expected]
  rows:
    - [count,        count.__bases__.__len__,        [], 1]
    - [combinations, combinations.__bases__.__len__, [], 1]
