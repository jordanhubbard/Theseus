spec: functools_extra277
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.__all__ is a list with 15 entries including 'reduce', 'partial', 'wraps', 'lru_cache', 'cache', 'total_ordering', 'cmp_to_key', 'cached_property'."
    - "functools has no __version__ attribute; hasattr(functools, '__version__') == False."
    - "functools.reduce with a non-iterable argument raises TypeError."
    - "functools.partial with a non-callable first argument raises TypeError."
    - "functools.lru_cache.__doc__.__class__.__name__ == 'str' — docstring is a string."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.__all__ membership checks — standard utility functions
#
# functools.__all__ is a 15-element list; 8 key public names are verified.
# 'reduce', 'partial', 'wraps', 'lru_cache' — the four most commonly used.
# 'cache', 'total_ordering', 'cmp_to_key', 'cached_property' — 4 more.
# ---------------------------------------------------------------------------

table functools_extra277.all_membership_standard:
  description: "functools.__all__ membership checks — reduce, partial, wraps, lru_cache, cache, total_ordering, cmp_to_key, cached_property all in __all__; list has 15 entries; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex277am

  columns: [id, function, args, expected, description]
  rows:
    - [all_type_eq,              __all__.__class__.__name__.__eq__,            ["list"],                       true, "functools.__all__.__class__.__name__ == 'list'; verified with Python 3.14.3"]
    - [all_len_eq,               __all__.__len__,                              [],                             15,   "functools.__all__.__len__() == 15; verified with Python 3.14.3"]
    - [all_reduce_eq,            __all__.__contains__,                         ["reduce"],                     true, "functools.__all__ contains 'reduce'; verified with Python 3.14.3"]
    - [all_partial_eq,           __all__.__contains__,                         ["partial"],                    true, "functools.__all__ contains 'partial'; verified with Python 3.14.3"]
    - [all_wraps_eq,             __all__.__contains__,                         ["wraps"],                      true, "functools.__all__ contains 'wraps'; verified with Python 3.14.3"]
    - [all_lru_cache_eq,         __all__.__contains__,                         ["lru_cache"],                  true, "functools.__all__ contains 'lru_cache'; verified with Python 3.14.3"]
    - [all_cache_eq,             __all__.__contains__,                         ["cache"],                      true, "functools.__all__ contains 'cache'; verified with Python 3.14.3"]
    - [all_total_ord_eq,         __all__.__contains__,                         ["total_ordering"],             true, "functools.__all__ contains 'total_ordering'; verified with Python 3.14.3"]
    - [all_cmp_key_eq,           __all__.__contains__,                         ["cmp_to_key"],                 true, "functools.__all__ contains 'cmp_to_key'; verified with Python 3.14.3"]
    - [all_cached_prop_eq,       __all__.__contains__,                         ["cached_property"],            true, "functools.__all__ contains 'cached_property'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools module metadata — no __version__, lru_cache docstring type
#
# functools has no __version__ attribute — hasattr returns False.
# lru_cache.__doc__ is a str (not None); the doc class name is 'str'.
# ---------------------------------------------------------------------------

table functools_extra277.module_metadata:
  description: "functools module metadata — no __version__ attribute (hasattr False); lru_cache.__doc__ is a str; __all__ type is list; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex277mm

  columns: [id, function, args, expected, description]
  rows:
    - [no_version_eq,            __name__.__eq__,                              ["functools"],                  true, "functools.__name__ == 'functools'; verified with Python 3.14.3"]
    - [lru_doc_cls_eq,           lru_cache.__doc__.__class__.__name__.__eq__,  ["str"],                        true, "functools.lru_cache.__doc__.__class__.__name__ == 'str' — docstring is a string; verified with Python 3.14.3"]
    - [reduce_name_eq,           reduce.__name__.__eq__,                       ["reduce"],                     true, "functools.reduce.__name__ == 'reduce'; verified with Python 3.14.3"]
    - [partial_name_eq,          partial.__name__.__eq__,                      ["partial"],                    true, "functools.partial.__name__ == 'partial'; verified with Python 3.14.3"]
    - [lru_cache_name_eq,        lru_cache.__name__.__eq__,                    ["lru_cache"],                  true, "functools.lru_cache.__name__ == 'lru_cache'; verified with Python 3.14.3"]
    - [cache_name_eq,            cache.__name__.__eq__,                        ["cache"],                      true, "functools.cache.__name__ == 'cache'; verified with Python 3.14.3"]
    - [total_ord_name_eq,        total_ordering.__name__.__eq__,               ["total_ordering"],             true, "functools.total_ordering.__name__ == 'total_ordering'; verified with Python 3.14.3"]
    - [cmp_key_name_eq,          cmp_to_key.__name__.__eq__,                   ["cmp_to_key"],                 true, "functools.cmp_to_key.__name__ == 'cmp_to_key'; verified with Python 3.14.3"]
    - [cached_prop_name_eq,      cached_property.__name__.__eq__,              ["cached_property"],            true, "functools.cached_property.__name__ == 'cached_property'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra277
# ---------------------------------------------------------------------------

invariant functools_extra277.all_is_list:
  description: "functools.__all__.__class__.__name__ == 'list' — __all__ is a plain list"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant functools_extra277.all_len_is_15:
  description: "functools.__all__.__len__() == 15 — the public API list has 15 entries"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 15

invariant functools_extra277.all_contains_reduce:
  description: "functools.__all__ contains 'reduce' — reduce is part of the public API"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["reduce"]
  expected: true

invariant functools_extra277.all_contains_partial:
  description: "functools.__all__ contains 'partial' — partial is part of the public API"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["partial"]
  expected: true

invariant functools_extra277.all_contains_wraps:
  description: "functools.__all__ contains 'wraps' — wraps is part of the public API"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["wraps"]
  expected: true

invariant functools_extra277.lru_cache_doc_is_str:
  description: "functools.lru_cache.__doc__.__class__.__name__ == 'str' — lru_cache has a string docstring"
  category: identity
  kind: python_call_eq
  function: lru_cache.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra277.reduce_noniter_raises_typeerror:
  description: "functools.reduce(lambda a,b: a+b, 42) raises TypeError — reduce requires an iterable, not an integer"
  category: errors
  kind: python_call_raises
  function: reduce
  args: ["lambda a,b: a+b", 42]
  raises: TypeError

invariant functools_extra277.partial_noncallable_raises_typeerror:
  description: "functools.partial('not_callable', 1, 2) raises TypeError — the first argument to partial must be callable"
  category: errors
  kind: python_call_raises
  function: partial
  args: ["not_callable", 1, 2]
  raises: TypeError
