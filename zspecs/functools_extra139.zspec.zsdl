spec: functools_extra139
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.cached_property class identity and method qualnames (__init__, __get__, __set_name__) plus code attributes (Wave 262)."
    - "functools.cached_property.__class__.__name__ == 'type' — cached_property is a Python class (type) defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.cached_property.__name__ == 'cached_property' (len 15). Verified with Python 3.14.3."
    - "functools.cached_property.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.cached_property.__qualname__ == 'cached_property' (len 15). Verified with Python 3.14.3."
    - "len(functools.cached_property.__mro__) == 2 — MRO is [cached_property, object]. Verified with Python 3.14.3."
    - "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property inherits only from object. Verified with Python 3.14.3."
    - "functools.cached_property.__init__.__qualname__ == 'cached_property.__init__' (len 24). Verified with Python 3.14.3."
    - "functools.cached_property.__init__.__code__.co_argcount == 2 — takes self and func. Verified with Python 3.14.3."
    - "len(functools.cached_property.__init__.__code__.co_varnames) == 2. Verified with Python 3.14.3."
    - "functools.cached_property.__get__.__qualname__ == 'cached_property.__get__' (len 23). Verified with Python 3.14.3."
    - "functools.cached_property.__get__.__code__.co_argcount == 3 — takes self, instance, owner. Verified with Python 3.14.3."
    - "len(functools.cached_property.__get__.__code__.co_varnames) == 6 — self, instance, owner, cache, msg, val. Verified with Python 3.14.3."
    - "functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__' (len 28). Verified with Python 3.14.3."
    - "functools.cached_property.__set_name__.__code__.co_argcount == 3 — takes self, owner, name. Verified with Python 3.14.3."
    - "len(functools.cached_property.__set_name__.__code__.co_varnames) == 3. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
