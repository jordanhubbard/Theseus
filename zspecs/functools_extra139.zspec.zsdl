       true,
       "functools.cached_property.__name__.__eq__('cached_property') == True — cached_property is a Python class whose __name__ is 'cached_property'; str.__eq__('cached_property') returns True; new to extra139"]
    - [cached_prop_name_len_eq_15,
       "cached_property.__name__.__len__",
       [],
       15,
       "functools.cached_property.__name__.__len__() == 15 — __name__ is 'cached_property' which has 15 characters; len('cached_property') == 15; new to extra139"]
    - [cached_prop_module_eq_functools,
       "cached_property.__module__.__eq__",
       ["functools"],
       true,
       "functools.cached_property.__module__.__eq__('functools') == True — cached_property is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra139"]
    - [cached_prop_qualname_eq,
       "cached_property.__qualname__.__eq__",
       ["cached_property"],
       true,
       "functools.cached_property.__qualname__.__eq__('cached_property') == True — cached_property is defined at module scope in Lib/functools.py; its __qualname__ is 'cached_property'; str.__eq__('cached_property') returns True; new to extra139"]
    - [cached_prop_qualname_len_eq_15,
       "cached_property.__qualname__.__len__",
       [],
       15,
       "functools.cached_property.__qualname__.__len__() == 15 — __qualname__ is 'cached_property' which has 15 characters; len('cached_property') == 15; new to extra139"]
    - [cached_prop_mro_len_eq_2,
       "cached_property.__mro__.__len__",
       [],
       2,
       "functools.cached_property.__mro__.__len__() == 2 — cached_property's MRO is [cached_property, object]; it inherits only from object; len(__mro__) is 2; new to extra139"]
    - [cached_prop_bases_first_eq_object,
       "cached_property.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — cached_property inherits only from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra139"]

