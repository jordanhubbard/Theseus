table functools_extra139.cached_property_identity:
  description: "functools.cached_property class identity: __class__.__name__=='type', __name__ len 15, __module__=='functools', MRO len 2; wave 262; new to extra139"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolscachedprop139

  columns: [id, function, args, expected, description]
  rows:
    - [cached_prop_class_name_eq_type,
       "cached_property.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.cached_property.__class__.__name__.__eq__('type') == True — cached_property is a Python class (type) defined in Lib/functools.py; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra139"]
    - [cached_prop_name_eq,
