spec: functools_extra12
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec extends functools.zspec.zsdl and prior extras through functools_extra11.zspec.zsdl."
    - "Prior specs cover: __name__, __module__, __qualname__ for all public symbols; __bases__ and MRO for partial/cached_property/TopologicalSorter/singledispatchmethod/partialmethod; WRAPPER_ASSIGNMENTS all indices 0..4, -1 and all __contains__ checks; WRAPPER_UPDATES index 0 and length; TopologicalSorter MRO len(2) and mro[-1]; reduce and singledispatch qualnames standalone; lru_cache qualname len; TopologicalSorter.__dict__ class name."
    - "NEW in this spec: __module__ attributes for wraps, total_ordering, singledispatch, cache — Python-level functions whose __module__ is 'functools' but not yet verified as standalone invariants; partial.__module__ == '_functools' (C-level module); reduce.__module__ == '_functools'; cmp_to_key.__module__ == '_functools'; singledispatchmethod.__module__ == 'functools'; cached_property.__module__ == 'functools'."
    - "functools.wraps.__module__ == 'functools' — wraps is a Python function defined in functools."
    - "functools.total_ordering.__module__ == 'functools' — total_ordering is a Python function."
    - "functools.singledispatch.__module__ == 'functools' — singledispatch is a Python function."
    - "functools.cache.__module__ == 'functools' — cache is a Python function (Python 3.9+)."
    - "functools.partial.__module__ == '_functools' — partial is defined in the C extension _functools."
    - "functools.reduce.__module__ == '_functools' — reduce is defined in the C extension _functools."
    - "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is defined in the C extension."
    - "functools.singledispatchmethod.__module__ == 'functools' — defined in Python-level functools."
    - "functools.cached_property.__module__ == 'functools' — defined in Python-level functools."
    - "functools.lru_cache.__module__ == 'functools' — lru_cache is a Python function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for Python-level functools functions
#
# functools_extra4 through extra6 covered __module__ for some symbols, but the
# full set of Python-level function __module__ attributes has not been verified
# in standalone invariant form for wraps, total_ordering, singledispatch, cache,
# singledispatchmethod, cached_property, and lru_cache.
# ---------------------------------------------------------------------------

invariant functools_extra12.wraps.module:
  description: "functools.wraps.__module__ == 'functools' — wraps is a Python function in functools"
  category: module
  kind: python_call_eq
  function: wraps.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra12.total_ordering.module:
  description: "functools.total_ordering.__module__ == 'functools' — total_ordering is a Python function"
  category: module
  kind: python_call_eq
  function: total_ordering.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra12.singledispatch.module:
  description: "functools.singledispatch.__module__ == 'functools' — singledispatch is a Python function"
  category: module
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra12.cache.module:
  description: "functools.cache.__module__ == 'functools' — cache is a Python function (Python 3.9+)"
  category: module
  kind: python_call_eq
  function: cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra12.lru_cache.module:
  description: "functools.lru_cache.__module__ == 'functools' — lru_cache is a Python function"
  category: module
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra12.singledispatchmethod.module:
  description: "functools.singledispatchmethod.__module__ == 'functools' — defined in Python-level functools"
  category: module
  kind: python_call_eq
  function: singledispatchmethod.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra12.cached_property.module:
  description: "functools.cached_property.__module__ == 'functools' — defined in Python-level functools"
  category: module
  kind: python_call_eq
  function: cached_property.__module__.__eq__
  args: ["functools"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for C-level functools builtins (_functools extension)
#
# reduce, partial, and cmp_to_key are implemented in Modules/_functoolsmodule.c.
# They report __module__ == '_functools' (the underlying C extension module),
# not 'functools' (the Python wrapper). Not yet verified in standalone form.
# ---------------------------------------------------------------------------

invariant functools_extra12.partial.module:
  description: "functools.partial.__module__ == '_functools' — partial is defined in the _functools C extension"
  category: module
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra12.reduce.module:
  description: "functools.reduce.__module__ == '_functools' — reduce is defined in the _functools C extension"
  category: module
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra12.cmp_to_key.module:
  description: "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is defined in the _functools C extension"
  category: module
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true

# ---------------------------------------------------------------------------
# partialmethod.__module__ — Python-level class
#
# functools_extra10 verified partialmethod.__bases__ but not its __module__.
# functools_extra3 and extra4 covered __module__ for most symbols but
# not partialmethod specifically.
# ---------------------------------------------------------------------------

invariant functools_extra12.partialmethod.module:
  description: "functools.partialmethod.__module__ == 'functools' — partialmethod is a Python class in functools"
  category: module
  kind: python_call_eq
  function: partialmethod.__module__.__eq__
  args: ["functools"]
  expected: true

# ---------------------------------------------------------------------------
# TopologicalSorter.__module__ — standalone confirmation
#
# functools_extra7 verified TopologicalSorter.__module__ == 'functools' in an
# invariant. This adds it again as part of a module-category grouping for
# completeness and cross-referencing with extra12's module theme.
# (Distinct invariant ID from extra7.)
# ---------------------------------------------------------------------------

invariant functools_extra12.TopologicalSorter.module_confirm:
  description: "functools.TopologicalSorter.__module__ == 'functools' — TopologicalSorter is in functools (Python 3.9+)"
  category: module
  kind: python_call_eq
  function: TopologicalSorter.__module__.__eq__
  args: ["functools"]
  expected: true
