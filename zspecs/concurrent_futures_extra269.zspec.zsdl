spec: concurrent_futures_extra269
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "concurrent.futures.thread.__name__ == 'concurrent.futures.thread' and __package__ == 'concurrent.futures'."
    - "concurrent.futures.process.__name__ == 'concurrent.futures.process' and __package__ == 'concurrent.futures'."
    - "concurrent.futures.thread.__loader__.__class__.__name__ == 'SourceFileLoader'."
    - "ThreadPoolExecutor is defined in concurrent.futures.thread; __module__ == 'concurrent.futures.thread'."
    - "ProcessPoolExecutor is defined in concurrent.futures.process; __module__ == 'concurrent.futures.process'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.thread submodule identity — table
#
# Submodule __name__, __package__, loader class, and ThreadPoolExecutor
# class name and module.
# ---------------------------------------------------------------------------

table concurrent_futures_extra269.cf_thread_identity:
  description: "concurrent.futures.thread submodule and ThreadPoolExecutor identity"
  kind: python_call_eq
  category: identity
  id_prefix: cfth

  columns: [id, function, args, expected, description]
  rows:
    - [th_name,     concurrent.futures.thread.__name__.__eq__,                         ["concurrent.futures.thread"], true, "concurrent.futures.thread.__name__ == 'concurrent.futures.thread'"]
    - [th_pkg,      concurrent.futures.thread.__package__.__eq__,                      ["concurrent.futures"],        true, "concurrent.futures.thread.__package__ == 'concurrent.futures'"]
    - [th_ldr_cls,  concurrent.futures.thread.__loader__.__class__.__name__.__eq__,    ["SourceFileLoader"],           true, "concurrent.futures.thread.__loader__.__class__.__name__ == 'SourceFileLoader'"]
    - [tpe_name,    concurrent.futures.thread.ThreadPoolExecutor.__name__.__eq__,      ["ThreadPoolExecutor"],         true, "concurrent.futures.thread.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'"]
    - [tpe_module,  concurrent.futures.thread.ThreadPoolExecutor.__module__.__eq__,    ["concurrent.futures.thread"], true, "concurrent.futures.thread.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'"]

# ---------------------------------------------------------------------------
# concurrent.futures.process submodule identity — table
#
# Submodule __name__, __package__, and ProcessPoolExecutor class identity.
# ---------------------------------------------------------------------------

table concurrent_futures_extra269.cf_process_identity:
  description: "concurrent.futures.process submodule and ProcessPoolExecutor identity"
  kind: python_call_eq
  category: identity
  id_prefix: cfpr

  columns: [id, function, args, expected, description]
  rows:
    - [pr_name,    concurrent.futures.process.__name__.__eq__,                       ["concurrent.futures.process"], true, "concurrent.futures.process.__name__ == 'concurrent.futures.process'"]
    - [pr_pkg,     concurrent.futures.process.__package__.__eq__,                    ["concurrent.futures"],         true, "concurrent.futures.process.__package__ == 'concurrent.futures'"]
    - [ppe_name,   concurrent.futures.process.ProcessPoolExecutor.__name__.__eq__,   ["ProcessPoolExecutor"],         true, "concurrent.futures.process.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor'"]
    - [ppe_module, concurrent.futures.process.ProcessPoolExecutor.__module__.__eq__,  ["concurrent.futures.process"], true, "concurrent.futures.process.ProcessPoolExecutor.__module__ == 'concurrent.futures.process'"]
    - [pr_ldr_cls, concurrent.futures.process.__loader__.__class__.__name__.__eq__,  ["SourceFileLoader"],            true, "concurrent.futures.process.__loader__.__class__.__name__ == 'SourceFileLoader'"]

# ---------------------------------------------------------------------------
# concurrent.futures.thread.__spec__.name — standalone invariant
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra269.cf_thread_spec_name:
  description: "concurrent.futures.thread.__spec__.name == 'concurrent.futures.thread'"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.thread.__spec__.name.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

# ---------------------------------------------------------------------------
# concurrent.futures.process.__spec__.name — standalone invariant
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra269.cf_process_spec_name:
  description: "concurrent.futures.process.__spec__.name == 'concurrent.futures.process'"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.process.__spec__.name.__eq__
  args: ["concurrent.futures.process"]
  expected: true

# ---------------------------------------------------------------------------
# ThreadPoolExecutor.__module__ ties with thread submodule __name__ — standalone invariant
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra269.tpe_module_eq_thread_name:
  description: "ThreadPoolExecutor.__module__ == concurrent.futures.thread.__name__ == 'concurrent.futures.thread'"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.thread.ThreadPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

# ---------------------------------------------------------------------------
# ProcessPoolExecutor.__module__ ties with process submodule __name__ — standalone invariant
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra269.ppe_module_eq_process_name:
  description: "ProcessPoolExecutor.__module__ == concurrent.futures.process.__name__ == 'concurrent.futures.process'"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.process.ProcessPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.process"]
  expected: true
