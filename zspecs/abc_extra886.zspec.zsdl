spec: abc_extra886
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - abc stdlib documentation
    - CPython Lib/abc.py
    - CPython Modules/_abc.c
  not_derived_from:
    - any third-party ABC implementations
    - zope.interface or similar ABCs
  notes:
    - Covers abc module file/cached attrs and ABC/ABCMeta/abstractmethod qualname and doc class names
    - __weakref__ descriptor checks confirm getset_descriptor type on class objects
    - All 12 rows use only safe, stable attributes present in CPython 3.9+
  created_at: "2026-04-12"

table abc_extra886.abc_module_attrs:
  description: Verify __file__, __cached__, __qualname__, __doc__.__class__.__name__, and __weakref__ class names for abc module objects
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: ab886xx
  columns: [id, function, args, expected]
  rows:
    - [ab886xx001, abc.__file__.__class__.__name__.__eq__, ["str"], true]
    - [ab886xx002, abc.__cached__.__class__.__name__.__eq__, ["str"], true]
    - [ab886xx003, abc.ABC.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab886xx004, abc.ABC.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [ab886xx005, abc.ABCMeta.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [ab886xx006, abc.ABCMeta.__abstractmethods__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [ab886xx007, abc.abstractmethod.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab886xx008, abc.ABC.__qualname__.__eq__, ["ABC"], true]
    - [ab886xx009, abc.abstractmethod.__qualname__.__eq__, ["abstractmethod"], true]
    - [ab886xx010, abc.get_cache_token.__qualname__.__eq__, ["get_cache_token"], true]
    - [ab886xx011, abc.ABCMeta.__qualname__.__eq__, ["ABCMeta"], true]
    - [ab886xx012, abc.ABCMeta.__doc__.__class__.__name__.__eq__, ["str"], true]
