spec: log_symbols
version: ">=7.0.0"
backend: node(log-symbols)

docs: https://github.com/sindresorhus/log-symbols#readme

provenance:
  derived_from:
    - "log-symbols README — https://github.com/sindresorhus/log-symbols#readme"
    - "Test vectors verified with log-symbols via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "log-symbols source"
  notes:
    - "ANSI-coloured status glyphs (✔/✖/⚠/ℹ) for CLI output."
    - "Install: npm install log-symbols"
    - "v7 ESM with CJS shim; default export is the symbols object."
    - "Each symbol embeds SGR open/close codes around the Unicode glyph (e.g. success = '\\x1b[32m✔\\x1b[39m')."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Static data lookup; never throws."
  stderr: "null"
  stickiness: "N/A — pure data."
  codes: {}

# Length contracts (deterministic across versions, unlike exact ANSI bytes)
invariant log_symbols.success_length:
  description: "log-symbols.success is 11 chars (5+5 SGR codes + 1 glyph)"
  category: length
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: success}
    - {get: length}
  expected: 11

invariant log_symbols.error_length:
  description: "log-symbols.error has same wrap length as .success"
  category: length
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: error}
    - {get: length}
  expected: 11

# Includes the right Unicode glyph
invariant log_symbols.success_includes_check:
  description: "success contains the ✔ heavy check mark"
  category: glyph
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: success}
    - {method: includes, args: ["✔"]}
  expected: true

invariant log_symbols.error_includes_x:
  description: "error contains the ✖ heavy multiplication mark"
  category: glyph
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: error}
    - {method: includes, args: ["✖"]}
  expected: true

invariant log_symbols.warning_includes_warning_glyph:
  description: "warning contains the ⚠ warning sign"
  category: glyph
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: warning}
    - {method: includes, args: ["⚠"]}
  expected: true

invariant log_symbols.info_includes_info_glyph:
  description: "info contains the ℹ information source"
  category: glyph
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: info}
    - {method: includes, args: ["ℹ"]}
  expected: true

# All symbols start with ANSI ESC byte sequence \x1b[
invariant log_symbols.success_starts_with_esc:
  description: "Symbols start with the ESC byte (0x1b)"
  category: ansi
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {get: success}
    - {method: charCodeAt, args: [0]}
  expected: 27
