spec: reprlib_extra12
version: ">=3.9"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html — Python reprlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec extends reprlib_extra11.zspec.zsdl."
    - "reprlib_extra11 covers: repr.__name__/Repr.__name__ standalone invariants; repr.__module__/Repr.__module__ standalone invariants; repr_values table (42/'hello'/[]/{}); repr([1..8]) truncation; repr of 30-element list class name."
    - "reprlib_extra10 covers: repr(-1)/repr(1.0); repr(list(range(100))).__len__()==23; Repr.__mro__.__len__()==2; Repr.__mro__[0].__name__=='Repr'; Repr.__mro__[-1].__name__=='object'; Repr.__bases__.__len__()==1; string length checks for recursive_repr/__name__/repr/__name__/Repr.__name__."
    - "reprlib_extra9 covers: repr('hello')/repr(42)/repr((1,2,3)); Repr().__class__.__name__=='Repr'; Repr.__bases__[0].__name__=='object'; recursive_repr.__qualname__; aRepr.maxarray==5."
    - "reprlib_extra8 covers: identity_names table; Repr().maxstring type; repr(-3.14)/repr([])/repr(99)."
    - "reprlib_extra7 covers: class_function_names table; Repr().maxlevel/maxlong; aRepr.maxother; repr(3.14)/repr(True/False)/repr({})/repr([1,2,3])."
    - "This spec covers: repr.__name__ standalone; Repr.__qualname__ standalone; Repr.__module__ standalone; Repr.__bases__[0].__name__=='object'; repr([1,2,3])=='[1, 2, 3]'; repr('hello')==\"'hello'\"; Repr.__init__.__name__=='__init__'; __module__ table for repr."
    - "reprlib.repr.__name__ == 'repr' — note: reprlib.repr is a bound method of the module-level aRepr instance; its __module__ is 'reprlib'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# reprlib.repr.__name__ standalone invariant
#
# reprlib_extra11 covers repr.__name__ == 'repr' as a standalone invariant.
# Re-anchored here under the extra12 namespace.
# ---------------------------------------------------------------------------

invariant reprlib_extra12.repr.name:
  description: "reprlib.repr.__name__ == 'repr' — module-level repr callable name"
  category: function_attrs
  kind: python_call_eq
  function: repr.__name__.__eq__
  args: ["repr"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.__qualname__ standalone invariant
#
# reprlib_extra2/extra3 cover Repr.__name__ and Repr.__module__.
# reprlib_extra11 covers Repr.__name__ as a standalone invariant.
# No prior spec verifies Repr.__qualname__ as a standalone invariant.
# For a top-level class, __qualname__ == __name__ == 'Repr'.
# ---------------------------------------------------------------------------

invariant reprlib_extra12.Repr.qualname:
  description: "reprlib.Repr.__qualname__ == 'Repr' — top-level class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: Repr.__qualname__.__eq__
  args: ["Repr"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.__module__ standalone invariant
#
# reprlib_extra11 covers Repr.__module__ == 'reprlib' as a standalone invariant.
# Re-anchored here under the extra12 namespace.
# ---------------------------------------------------------------------------

invariant reprlib_extra12.Repr.module:
  description: "reprlib.Repr.__module__ == 'reprlib' — Repr class defined in reprlib module"
  category: class_attrs
  kind: python_call_eq
  function: Repr.__module__.__eq__
  args: ["reprlib"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.__bases__[0].__name__ == 'object'
#
# reprlib_extra9 covers Repr.__bases__[0].__name__ == 'object' as a standalone
# invariant. Re-anchored here under the extra12 namespace.
# ---------------------------------------------------------------------------

invariant reprlib_extra12.Repr.base_is_object:
  description: "reprlib.Repr.__bases__[0].__name__ == 'object' — Repr inherits directly from object"
  category: bases_attrs
  kind: python_call_eq
  function: Repr.__bases__.__getitem__(0).__name__.__eq__
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# reprlib.repr — value checks for [1,2,3] and 'hello'
#
# reprlib_extra7 covers repr([1,2,3]). reprlib_extra9 covers repr('hello').
# These re-anchor both under the extra12 namespace as standalone invariants.
# ---------------------------------------------------------------------------

invariant reprlib_extra12.repr.list_123:
  description: "reprlib.repr([1,2,3]) == '[1, 2, 3]' — short list within maxlist limit"
  category: repr_values
  kind: python_call_eq
  function: repr
  args: [[1, 2, 3]]
  expected: "[1, 2, 3]"

invariant reprlib_extra12.repr.str_hello:
  description: "reprlib.repr('hello') == \"'hello'\" — short string within maxstring limit"
  category: repr_values
  kind: python_call_eq
  function: repr
  args: ["hello"]
  expected: "'hello'"

# ---------------------------------------------------------------------------
# Repr.__init__.__name__ == '__init__'
#
# No prior reprlib spec checks any method name on Repr. Repr.__init__ is the
# standard class constructor; its __name__ == '__init__'.
# ---------------------------------------------------------------------------

invariant reprlib_extra12.Repr.init_name:
  description: "reprlib.Repr.__init__.__name__ == '__init__' — constructor method name"
  category: method_attrs
  kind: python_call_eq
  function: Repr.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table for repr
#
# reprlib_extra11 covers repr.__module__ as a standalone invariant.
# This single-row table re-anchors the check under the extra12 namespace
# as a structured table entry for consistency with other specs.
# ---------------------------------------------------------------------------

table reprlib_extra12.modules:
  kind: python_call_eq
  category: module_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [reprlib_extra12.modules.repr_module,
       repr.__module__.__eq__,
       ["reprlib"],
       true,
       "reprlib.repr.__module__ == 'reprlib'"]
