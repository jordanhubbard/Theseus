spec: functools_extra204
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools module-level attributes — __name__, __package__, __spec__.name, __file__.__class__.__name__, and __name__.__len__() for partial, reduce, lru_cache, wraps."
    - "functools.__name__ == 'functools' — the module's __name__ attribute is its fully-qualified import name. Verified with Python 3.14.3."
    - "functools.__package__ == '' — functools is a top-level module with no package prefix; __package__ is the empty string. Verified with Python 3.14.3."
    - "functools.__spec__.name == 'functools' — the ModuleSpec object's .name attribute equals the module name. Verified with Python 3.14.3."
    - "functools.__file__.__class__.__name__ == 'str' — __file__ is a plain Python string path; its __class__.__name__ is 'str'. Verified with Python 3.14.3."
    - "functools.partial.__name__.__len__() == 7 — 'partial' has 7 characters. Verified with Python 3.14.3."
    - "functools.reduce.__name__.__len__() == 6 — 'reduce' has 6 characters. Verified with Python 3.14.3."
    - "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters. Verified with Python 3.14.3."
    - "functools.wraps.__name__.__len__() == 5 — 'wraps' has 5 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools module identity — __name__, __package__, __spec__.name
#
# functools.__name__.__eq__('functools') == True
# functools.__package__.__eq__('') == True
# functools.__spec__.name.__eq__('functools') == True
#
# functools is a top-level stdlib module; __package__ is the empty string
# and __spec__.name matches __name__. New to extra204.
# ---------------------------------------------------------------------------

table functools_extra204.module_identity:
  description: "functools module __name__, __package__, __spec__.name; top-level stdlib module; __package__ is empty string; __spec__.name matches __name__; new to extra204"
  kind: python_call_eq
  category: string_identity
  id_prefix: functmodule204

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq_functools,
       __name__.__eq__,
       ["functools"],
       true,
       "functools.__name__.__eq__('functools') == True — the module's __name__ attribute is its fully-qualified import name 'functools'; str.__eq__('functools') returns True; new to extra204"]
    - [module_package_eq_empty,
       __package__.__eq__,
       [""],
       true,
       "functools.__package__.__eq__('') == True — functools is a top-level module with no package prefix; __package__ is the empty string; str.__eq__('') returns True; new to extra204"]
    - [module_spec_name_eq_functools,
       __spec__.name.__eq__,
       ["functools"],
       true,
       "functools.__spec__.name.__eq__('functools') == True — __spec__ is a ModuleSpec object; its .name attribute equals the module name 'functools'; str.__eq__('functools') returns True; new to extra204"]

# ---------------------------------------------------------------------------
# Table 2: functools module __file__ class and partial/reduce name lengths
#
# functools.__file__.__class__.__name__.__eq__('str') == True
# functools.partial.__name__.__len__() == 7
# functools.reduce.__name__.__len__() == 6
#
# __file__ is a plain str path; partial.__name__ is 'partial' (7 chars);
# reduce.__name__ is 'reduce' (6 chars). New to extra204.
# ---------------------------------------------------------------------------

table functools_extra204.file_class_and_partial_reduce_lens:
  description: "functools __file__.__class__.__name__=='str'; partial.__name__.__len__()==7; reduce.__name__.__len__()==6; new to extra204"
  kind: python_call_eq
  category: identity
  id_prefix: functmodule204

  columns: [id, function, args, expected, description]
  rows:
    - [file_class_name_eq_str,
       __file__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.__file__.__class__.__name__.__eq__('str') == True — __file__ is a plain Python string path to functools.py; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra204"]
    - [partial_name_len_7,
       partial.__name__.__len__,
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — partial.__name__ is 'partial' which has 7 characters; str.__len__() returns 7; new to extra204"]
    - [reduce_name_len_6,
       reduce.__name__.__len__,
       [],
       6,
       "functools.reduce.__name__.__len__() == 6 — reduce.__name__ is 'reduce' which has 6 characters; str.__len__() returns 6; new to extra204"]

# ---------------------------------------------------------------------------
# Table 3: functools lru_cache and wraps name lengths
#
# functools.lru_cache.__name__.__len__() == 9
# functools.wraps.__name__.__len__() == 5
#
# lru_cache is a decorator factory; 'lru_cache' has 9 chars.
# wraps is a decorator helper; 'wraps' has 5 chars. New to extra204.
# ---------------------------------------------------------------------------

table functools_extra204.lru_cache_wraps_name_lens:
  description: "functools lru_cache.__name__.__len__()==9; wraps.__name__.__len__()==5; new to extra204"
  kind: python_call_eq
  category: identity
  id_prefix: functmodule204

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_name_len_9,
       lru_cache.__name__.__len__,
       [],
       9,
       "functools.lru_cache.__name__.__len__() == 9 — lru_cache.__name__ is 'lru_cache' which has 9 characters; str.__len__() returns 9; new to extra204"]
    - [wraps_name_len_5,
       wraps.__name__.__len__,
       [],
       5,
       "functools.wraps.__name__.__len__() == 5 — wraps.__name__ is 'wraps' which has 5 characters; str.__len__() returns 5; new to extra204"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra204
# ---------------------------------------------------------------------------

invariant functools_extra204.module_name:
  description: "functools.__name__ == 'functools' — top-level stdlib module name; new to extra204"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra204.module_package:
  description: "functools.__package__ == '' — top-level module; __package__ is empty string; new to extra204"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant functools_extra204.module_spec_name:
  description: "functools.__spec__.name == 'functools' — ModuleSpec.name matches module __name__; new to extra204"
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra204.file_class_name:
  description: "functools.__file__.__class__.__name__ == 'str' — __file__ is a plain Python string path; new to extra204"
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra204.partial_name_len:
  description: "functools.partial.__name__.__len__() == 7 — 'partial' has 7 characters; new to extra204"
  kind: python_call_eq
  function: partial.__name__.__len__
  args: []
  expected: 7

invariant functools_extra204.reduce_name_len:
  description: "functools.reduce.__name__.__len__() == 6 — 'reduce' has 6 characters; new to extra204"
  kind: python_call_eq
  function: reduce.__name__.__len__
  args: []
  expected: 6

invariant functools_extra204.lru_cache_name_len:
  description: "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters; new to extra204"
  kind: python_call_eq
  function: lru_cache.__name__.__len__
  args: []
  expected: 9

invariant functools_extra204.wraps_name_len:
  description: "functools.wraps.__name__.__len__() == 5 — 'wraps' has 5 characters; new to extra204"
  kind: python_call_eq
  function: wraps.__name__.__len__
  args: []
  expected: 5
