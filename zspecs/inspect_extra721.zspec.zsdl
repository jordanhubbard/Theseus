spec: inspect_extra721
version: ">=3.9"
backend: python_module(inspect)
docs: "Behavioral specs for inspect module predicate function identity"
error_model: python_exceptions
provenance:
  derived_from: "python stdlib inspect module"
  not_derived_from: "any third-party library"
  notes: "Covers inspect predicate functions qualname/module identity: ismodule, isclass, isfunction, ismethod, isbuiltin, isgenerator, iscoroutine, isawaitable"
  created_at: "2026-04-12"

table inspect_extra721.type_predicates:
  description: "Identity checks for inspect type-testing predicate functions"
  kind: python_call_eq
  category: identity
  id_prefix: in721tp
  columns: [id, function, args, expected]
  rows:
    - [in721tp001, inspect.ismodule.__qualname__.__eq__, ["ismodule"], true]
    - [in721tp002, inspect.ismodule.__module__.__eq__, ["inspect"], true]
    - [in721tp003, inspect.isclass.__qualname__.__eq__, ["isclass"], true]
    - [in721tp004, inspect.isclass.__module__.__eq__, ["inspect"], true]
    - [in721tp005, inspect.isfunction.__qualname__.__eq__, ["isfunction"], true]
    - [in721tp006, inspect.isfunction.__module__.__eq__, ["inspect"], true]
    - [in721tp007, inspect.ismethod.__qualname__.__eq__, ["ismethod"], true]
    - [in721tp008, inspect.ismethod.__module__.__eq__, ["inspect"], true]

table inspect_extra721.callable_predicates:
  description: "Identity checks for inspect callable and async predicate functions"
  kind: python_call_eq
  category: identity
  id_prefix: in721cp
  columns: [id, function, args, expected]
  rows:
    - [in721cp001, inspect.isbuiltin.__qualname__.__eq__, ["isbuiltin"], true]
    - [in721cp002, inspect.isgenerator.__qualname__.__eq__, ["isgenerator"], true]
    - [in721cp003, inspect.iscoroutine.__qualname__.__eq__, ["iscoroutine"], true]
    - [in721cp004, inspect.isawaitable.__qualname__.__eq__, ["isawaitable"], true]
