spec: phonenumbers_rust
version: ">=3.9"
backend: rust_module(phonenumbers_rust)

docs: https://github.com/daviddrysdale/python-phonenumbers

provenance:
  derived_from:
    - "https://github.com/daviddrysdale/python-phonenumbers — phonenumbers"
  notes:
    - "phonenumbers parses and formats phone numbers."
    - "phonenumbers.parse('+14155552671', None).country_code == 1."
    - "phonenumbers.is_valid_number(phonenumbers.parse('+14155552671')) is True."
    - "phonenumbers.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant phonenumbers_rust.country_code_us:
  description: "parse('+14155552671').country_code == 1"
  category: parse
  kind: python_call_eq
  function: phonenumbers_country_code
  args: ["+14155552671"]
  expected: 1

invariant phonenumbers_rust.is_valid_us:
  description: "is_valid_number(parse('+14155552671')) is True"
  category: validate
  kind: python_call_eq
  function: phonenumbers_is_valid
  args: ["+14155552671"]
  expected: true

invariant phonenumbers_rust.version_nonempty:
  description: "phonenumbers.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: phonenumbers_version_nonempty
  args: []
  expected: true

