spec: struct_extra1411
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 541 (_extra1411): focuses on __sizeof__ and __reduce_ex__ method type checks for struct.Struct and struct.error."
    - "struct.Struct.__sizeof__.__class__.__name__ == 'method_descriptor' — notable: '__sizeof__' IS present in struct.Struct.__dict__ (True), unlike most C types where it is not explicitly stored."
    - "struct.Struct.__reduce_ex__.__class__.__name__ == 'method_descriptor' — __reduce_ex__ is inherited; '__reduce_ex__' is NOT in struct.Struct.__dict__."
    - "struct.error is a subclass of Exception. struct.error.__sizeof__.__class__.__name__ == 'method_descriptor' — inherited; NOT in struct.error.__dict__."
    - "struct.error.__reduce_ex__.__class__.__name__ == 'method_descriptor' — also inherited; NOT in struct.error.__dict__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1411.struct_sizeof_type_checks:
  description: "struct.Struct __sizeof__ method type and dict-presence checks — __sizeof__ is a method_descriptor and is explicitly present in struct.Struct.__dict__ (a C-level optimization)"
  kind: python_call_eq
  category: sizeof_checks
  id_prefix: st1411sw
  columns: [id, function, args, expected]
  rows:
    - [st1411sw001, struct.Struct.__sizeof__.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [st1411sw002, struct.Struct.__dict__.__contains__,                     ["__sizeof__"],        true]
    - [st1411sw003, struct.error.__sizeof__.__class__.__name__.__eq__,      ["method_descriptor"], true]
    - [st1411sw004, struct.error.__dict__.__contains__,                      ["__sizeof__"],        false]
    - [st1411sw005, struct.Struct.__sizeof__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
    - [st1411sw006, struct.error.__sizeof__.__class__.__name__.__class__.__name__.__eq__, ["str"],  true]

table struct_extra1411.struct_reduce_ex_type_checks:
  description: "struct.Struct and struct.error __reduce_ex__ method type and dict-presence checks — __reduce_ex__ is a method_descriptor inherited from object for both types and absent from their __dict__s"
  kind: python_call_eq
  category: reduce_ex_checks
  id_prefix: st1411rx
  columns: [id, function, args, expected]
  rows:
    - [st1411rx001, struct.Struct.__reduce_ex__.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [st1411rx002, struct.error.__reduce_ex__.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [st1411rx003, struct.Struct.__dict__.__contains__,                     ["__reduce_ex__"],     false]
    - [st1411rx004, struct.error.__dict__.__contains__,                      ["__reduce_ex__"],     false]
    - [st1411rx005, struct.Struct.__reduce_ex__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
    - [st1411rx006, struct.error.__reduce_ex__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]

table struct_extra1411.struct_class_identity_checks:
  description: "struct.Struct and struct.error class identity checks — Struct is a C-extension type, error is a Python exception subclass; both are plain 'type' metaclass"
  kind: python_call_eq
  category: class_identity_checks
  id_prefix: st1411ci
  columns: [id, function, args, expected]
  rows:
    - [st1411ci001, struct.Struct.__name__.__eq__,               ["Struct"],    true]
    - [st1411ci002, struct.error.__name__.__eq__,                ["error"],     true]
    - [st1411ci003, struct.Struct.__class__.__name__.__eq__,     ["type"],      true]
    - [st1411ci004, struct.error.__class__.__name__.__eq__,      ["type"],      true]
    - [st1411ci005, struct.Struct.__module__.__eq__,             ["struct"],    true]
    - [st1411ci006, struct.error.__module__.__eq__,              ["struct"],    true]
