spec: math_extra6
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl, math_extra.zspec.zsdl, math_extra2.zspec.zsdl, math_extra3.zspec.zsdl, math_extra4.zspec.zsdl, and math_extra5.zspec.zsdl."
    - "math_extra5 covers __qualname__ for comb/perm/dist/prod/isqrt."
    - "This spec adds __qualname__ for sqrt/floor/ceil/trunc/fabs/factorial/gcd/lcm/isnan/isinf/isfinite/isclose/log/log2/log10/exp/pow/sin/cos/tan — none previously covered."
    - "For module-level builtins the __qualname__ always equals __name__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — arithmetic / rounding group
# math_extra5 qualname table covers comb/perm/dist/prod/isqrt.
# None of sqrt/floor/ceil/trunc/fabs/factorial/gcd/lcm appear in any prior spec
# under __qualname__.
# ---------------------------------------------------------------------------

table math_extra6.qualnames_arithmetic:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [sqrt,      sqrt.__qualname__.__eq__,      ["sqrt"],      true]
    - [floor,     floor.__qualname__.__eq__,     ["floor"],     true]
    - [ceil,      ceil.__qualname__.__eq__,      ["ceil"],      true]
    - [trunc,     trunc.__qualname__.__eq__,     ["trunc"],     true]
    - [fabs,      fabs.__qualname__.__eq__,      ["fabs"],      true]
    - [factorial, factorial.__qualname__.__eq__, ["factorial"], true]
    - [gcd,       gcd.__qualname__.__eq__,       ["gcd"],       true]
    - [lcm,       lcm.__qualname__.__eq__,       ["lcm"],       true]

# ---------------------------------------------------------------------------
# __qualname__ checks — predicate group
# isnan/isinf covered by __name__ in prior specs; __qualname__ is new.
# ---------------------------------------------------------------------------

table math_extra6.qualnames_predicates:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [isnan,    isnan.__qualname__.__eq__,    ["isnan"],    true]
    - [isinf,    isinf.__qualname__.__eq__,    ["isinf"],    true]
    - [isfinite, isfinite.__qualname__.__eq__, ["isfinite"], true]
    - [isclose,  isclose.__qualname__.__eq__,  ["isclose"],  true]

# ---------------------------------------------------------------------------
# __qualname__ checks — transcendental / trig group
# log/log2/log10/exp/pow/sin/cos/tan all had __name__ in prior specs;
# __qualname__ vectors are new here.
# ---------------------------------------------------------------------------

table math_extra6.qualnames_transcendental:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [log,   log.__qualname__.__eq__,   ["log"],   true]
    - [log2,  log2.__qualname__.__eq__,  ["log2"],  true]
    - [log10, log10.__qualname__.__eq__, ["log10"], true]
    - [exp,   exp.__qualname__.__eq__,   ["exp"],   true]
    - [pow,   pow.__qualname__.__eq__,   ["pow"],   true]
    - [sin,   sin.__qualname__.__eq__,   ["sin"],   true]
    - [cos,   cos.__qualname__.__eq__,   ["cos"],   true]
    - [tan,   tan.__qualname__.__eq__,   ["tan"],   true]
