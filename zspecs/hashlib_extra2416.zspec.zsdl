spec: hashlib_extra2416
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/hashlib.html"
    - "CPython source — Modules/_hashopenssl.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 608 (_extra2416): __iter__ and __next__ dict-presence and type classification."
    - "hashlib exposes three hash-related types via its internal _hashlib sub-module: HASH, HASHXOF, and HMAC."
    - "None of these types define __iter__ or __next__ in their class __dict__ — hash objects are not iterable."
    - "hashlib.md5, hashlib.sha256, etc. are builtin_function_or_method objects (factory functions), not classes."
    - "The builtin_function_or_method class also lacks __iter__ and __next__ in its __dict__."
    - "hashlib.algorithms_available and hashlib.algorithms_guaranteed are plain set objects."
    - "set defines __iter__ in its __dict__ (wrapper_descriptor), but NOT __next__ — sets are iterable but not iterators."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
# Table 1: __iter__ in class __dict__ — hash type objects (all False)
# ===

table hashlib_extra2416.iter_in_dict:
  description: "Hash types HASH, HASHXOF, HMAC do not define __iter__ in their class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2416
  columns: [id, function, args, expected]
  rows:
    - ["hl2416001", "hashlib._hashlib.HASH.__dict__.__contains__", ["__iter__"], false]
    - ["hl2416002", "hashlib._hashlib.HASHXOF.__dict__.__contains__", ["__iter__"], false]
    - ["hl2416003", "hashlib._hashlib.HMAC.__dict__.__contains__", ["__iter__"], false]
    - ["hl2416004", "hashlib.md5.__class__.__dict__.__contains__", ["__iter__"], false]
    - ["hl2416005", "hashlib.algorithms_available.__class__.__dict__.__contains__", ["__iter__"], true]

# ===
# Table 2: __next__ in class __dict__ — hash type objects (all False)
# ===

table hashlib_extra2416.next_in_dict:
  description: "Hash types HASH, HASHXOF, HMAC do not define __next__ in their class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2416
  columns: [id, function, args, expected]
  rows:
    - ["hl2416006", "hashlib._hashlib.HASH.__dict__.__contains__", ["__next__"], false]
    - ["hl2416007", "hashlib._hashlib.HASHXOF.__dict__.__contains__", ["__next__"], false]
    - ["hl2416008", "hashlib._hashlib.HMAC.__dict__.__contains__", ["__next__"], false]
    - ["hl2416009", "hashlib.md5.__class__.__dict__.__contains__", ["__next__"], false]
    - ["hl2416010", "hashlib.algorithms_available.__class__.__dict__.__contains__", ["__next__"], false]

# ===
# Table 3: class name identity for hash-related types
# ===

table hashlib_extra2416.type_names:
  description: "Class __name__ for HASH, HASHXOF, HMAC and the factory function type"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl2416
  columns: [id, function, args, expected]
  rows:
    - ["hl2416011", "hashlib._hashlib.HASH.__name__", [], "HASH"]
    - ["hl2416012", "hashlib._hashlib.HASHXOF.__name__", [], "HASHXOF"]
    - ["hl2416013", "hashlib._hashlib.HMAC.__name__", [], "HMAC"]
    - ["hl2416014", "hashlib.md5.__class__.__name__", [], "builtin_function_or_method"]
    - ["hl2416015", "hashlib.algorithms_available.__class__.__name__", [], "set"]
    - ["hl2416016", "hashlib.algorithms_guaranteed.__class__.__name__", [], "set"]
