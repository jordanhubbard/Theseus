spec: uuid_extra1516
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra15.zspec.zsdl — covers NAMESPACE_DNS/URL/OID __class__.__qualname__; UUID.__module__.__eq__; uuid3/uuid5.__qualname__ standalone."
    - "uuid_extra14.zspec.zsdl — covers uuid1/3/4/5 __qualname__.__len__==5; SafeUUID.__qualname__.__len__==8; UUID.__bases__[0].__name__.__len__==6."
    - "uuid_extra13.zspec.zsdl — covers UUID.__name__.__eq__('UUID') standalone; NAMESPACE_DNS/URL __class__.__name__.__eq__('UUID') table."
    - "uuid_extra12.zspec.zsdl — covers UUID.__qualname__.__len__==4; uuid1/3/4/5 __name__/__module__ string lengths."
  notes:
    - "This spec is wave 548 / suffix _extra1516. Theme: arithmetic/numeric operator dict-presence checks."
    - "uuid.UUID is not a numeric type. None of __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__ appear in UUID.__dict__."
    - "uuid.SafeUUID is an Enum (not IntEnum). It inherits from Enum only; no arithmetic operators in its own __dict__."
    - "Verified: uuid.UUID.__dict__.__contains__('__add__') == False."
    - "Verified: uuid.UUID.__dict__.__contains__('__mul__') == False."
    - "Verified: uuid.UUID.__dict__.__contains__('__sub__') == False."
    - "Verified: uuid.UUID.__dict__.__contains__('__truediv__') == False."
    - "Verified: uuid.UUID.__dict__.__contains__('__floordiv__') == False."
    - "Verified: uuid.UUID.__dict__.__contains__('__mod__') == False."
    - "Verified: uuid.UUID.__dict__.__contains__('__pow__') == False."
    - "Verified: uuid.UUID.__dict__.__contains__('__str__') == True; '__repr__' == True; '__int__' == True; '__eq__' == True; '__lt__' == True; '__hash__' == True."
    - "Verified: uuid.SafeUUID.__dict__.__contains__('__add__') == False (through '__pow__') == False."
    - "Verified: uuid.SafeUUID.__dict__.__contains__('safe') == True; 'unsafe' == True; 'unknown' == True; '__new__' == True."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID — arithmetic operator absence checks
#
# uuid.UUID is an immutable value-type wrapping a 128-bit integer. It
# supports comparison and hashing but deliberately exposes NO arithmetic
# operators in its own __dict__. The seven standard arithmetic dunders are
# each absent.  Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table uuid_extra1516.UUID_arith_absent:
  description: "Arithmetic operator dunders absent from uuid.UUID.__dict__ — UUID is not a numeric type"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu1516aa

  columns: [id, function, args, expected]
  rows:
    - ["uu1516aa001", "UUID.__dict__.__contains__", ["__add__"],      false]
    - ["uu1516aa002", "UUID.__dict__.__contains__", ["__mul__"],      false]
    - ["uu1516aa003", "UUID.__dict__.__contains__", ["__sub__"],      false]
    - ["uu1516aa004", "UUID.__dict__.__contains__", ["__truediv__"],  false]
    - ["uu1516aa005", "UUID.__dict__.__contains__", ["__floordiv__"], false]
    - ["uu1516aa006", "UUID.__dict__.__contains__", ["__mod__"],      false]
    - ["uu1516aa007", "UUID.__dict__.__contains__", ["__pow__"],      false]

# ---------------------------------------------------------------------------
# uuid.UUID — comparison and string operator presence checks
#
# UUID does implement comparison operators (__eq__, __lt__, __gt__, __le__,
# __ge__) and string protocol (__str__, __repr__), as well as __int__ for
# integer coercion and __hash__ for use as dict keys. These are all present
# in UUID.__dict__, confirming the dict-presence mechanism is correct.
# ---------------------------------------------------------------------------

table uuid_extra1516.UUID_present_ops:
  description: "Comparison and string dunders present in uuid.UUID.__dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu1516po

  columns: [id, function, args, expected]
  rows:
    - ["uu1516po001", "UUID.__dict__.__contains__", ["__str__"],   true]
    - ["uu1516po002", "UUID.__dict__.__contains__", ["__repr__"],  true]
    - ["uu1516po003", "UUID.__dict__.__contains__", ["__int__"],   true]
    - ["uu1516po004", "UUID.__dict__.__contains__", ["__eq__"],    true]
    - ["uu1516po005", "UUID.__dict__.__contains__", ["__lt__"],    true]
    - ["uu1516po006", "UUID.__dict__.__contains__", ["__hash__"],  true]
    - ["uu1516po007", "UUID.__dict__.__contains__", ["hex"],       true]
    - ["uu1516po008", "UUID.__dict__.__contains__", ["bytes"],     true]
    - ["uu1516po009", "UUID.__dict__.__contains__", ["urn"],       true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID — arithmetic operator absence checks
#
# SafeUUID is defined as class SafeUUID(enum.Enum), not IntEnum. Its MRO is
# [SafeUUID, Enum, object]. It has no numeric ancestors and therefore no
# arithmetic operators in its own __dict__. The four member slots ('safe',
# 'unsafe', 'unknown', '__new__') that ARE present confirm lookups work.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table uuid_extra1516.SafeUUID_arith_absent:
  description: "Arithmetic operator dunders absent from uuid.SafeUUID.__dict__ — Enum, not IntEnum"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu1516su

  columns: [id, function, args, expected]
  rows:
    - ["uu1516su001", "SafeUUID.__dict__.__contains__", ["__add__"],      false]
    - ["uu1516su002", "SafeUUID.__dict__.__contains__", ["__mul__"],      false]
    - ["uu1516su003", "SafeUUID.__dict__.__contains__", ["__sub__"],      false]
    - ["uu1516su004", "SafeUUID.__dict__.__contains__", ["__truediv__"],  false]
    - ["uu1516su005", "SafeUUID.__dict__.__contains__", ["__floordiv__"], false]
    - ["uu1516su006", "SafeUUID.__dict__.__contains__", ["__mod__"],      false]
    - ["uu1516su007", "SafeUUID.__dict__.__contains__", ["__pow__"],      false]
    - ["uu1516su008", "SafeUUID.__dict__.__contains__", ["safe"],         true]
    - ["uu1516su009", "SafeUUID.__dict__.__contains__", ["unsafe"],       true]
    - ["uu1516su010", "SafeUUID.__dict__.__contains__", ["unknown"],      true]
