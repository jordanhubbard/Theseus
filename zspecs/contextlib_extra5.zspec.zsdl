spec: contextlib_extra5
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "Python contextlib documentation — https://docs.python.org/3/library/contextlib.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "Extends contextlib.zspec.zsdl through contextlib_extra4.zspec.zsdl."
    - "contextlib.zspec.zsdl covers __name__ for contextmanager/suppress/ExitStack/closing/redirect_stdout/redirect_stderr/nullcontext/AsyncExitStack/AbstractContextManager/asynccontextmanager; nullcontext __enter__/__exit__ behavior."
    - "contextlib_extra.zspec.zsdl covers __module__ for contextmanager/asynccontextmanager/closing/nullcontext; aclosing name/module; is_function/is_type checks."
    - "contextlib_extra2.zspec.zsdl covers consolidated __name__ table for 10 symbols; ABCMeta metaclass checks."
    - "contextlib_extra3.zspec.zsdl covers __qualname__ for AsyncExitStack/asynccontextmanager/aclosing/AbstractAsyncContextManager/nullcontext/ExitStack/suppress/closing/contextmanager/AbstractContextManager/redirect_stdout/redirect_stderr; AsyncContextDecorator name/module/qualname."
    - "contextlib_extra4.zspec.zsdl covers __name__ spot-checks for suppress/closing/nullcontext/redirect_stdout/redirect_stderr/ExitStack/AsyncExitStack/AbstractContextManager/AbstractAsyncContextManager; __module__ for suppress/ExitStack/AsyncExitStack/contextmanager/AbstractContextManager/AbstractAsyncContextManager."
    - "This spec focuses on: __bases__[0].__name__ checks for suppress/closing/redirect_stdout/redirect_stderr/ExitStack/AbstractContextManager/AbstractAsyncContextManager/nullcontext; contextmanager/__class__.__name__; instance __class__.__name__ for suppress/closing/ExitStack/nullcontext."
    - "contextlib.suppress.__bases__[0].__name__ == 'AbstractContextManager' — suppress inherits from AbstractContextManager."
    - "contextlib.closing.__bases__[0].__name__ == 'AbstractContextManager' — closing inherits from AbstractContextManager."
    - "contextlib.redirect_stdout.__bases__[0].__name__ == 'AbstractContextManager' — redirect_stdout inherits from AbstractContextManager."
    - "contextlib.redirect_stderr.__bases__[0].__name__ == 'AbstractContextManager' — redirect_stderr inherits from AbstractContextManager."
    - "contextlib.ExitStack.__bases__[0].__name__ == 'AbstractContextManager' — ExitStack inherits from AbstractContextManager."
    - "contextlib.AbstractContextManager.__bases__[0].__name__ == 'ABC' — AbstractContextManager inherits from ABC."
    - "contextlib.AbstractAsyncContextManager.__bases__[0].__name__ == 'ABC' — AbstractAsyncContextManager inherits from ABC."
    - "contextlib.nullcontext.__bases__[0].__name__ == 'AbstractContextManager' — nullcontext inherits from AbstractContextManager."
    - "contextlib.contextmanager.__class__.__name__ == 'function' — contextmanager is a plain function."
    - "contextlib.asynccontextmanager.__class__.__name__ == 'function' — asynccontextmanager is a plain function."
    - "contextlib.suppress(Exception).__class__.__name__ == 'suppress' — instance is of type suppress."
    - "contextlib.closing(iter([])).__class__.__name__ == 'closing' — instance is of type closing."
    - "contextlib.ExitStack().__class__.__name__ == 'ExitStack' — instance is of type ExitStack."
    - "contextlib.nullcontext().__class__.__name__ == 'nullcontext' — instance is of type nullcontext."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__name__ checks — inheritance hierarchy
#
# suppress, closing, redirect_stdout, redirect_stderr, ExitStack, and
# nullcontext all directly inherit from AbstractContextManager.
# AbstractContextManager and AbstractAsyncContextManager inherit from ABC.
# ---------------------------------------------------------------------------

table contextlib_extra5.base_class_names:
  description: "contextlib classes have correct direct base class"
  kind: python_call_eq
  category: base_classes
  id_prefix: base

  columns: [id, function, args, expected]
  rows:
    - [suppress,        suppress.__bases__.__getitem__,        [0], "AbstractContextManager"]
    - [closing,         closing.__bases__.__getitem__,         [0], "AbstractContextManager"]
    - [redirect_stdout, redirect_stdout.__bases__.__getitem__, [0], "AbstractContextManager"]
    - [redirect_stderr, redirect_stderr.__bases__.__getitem__, [0], "AbstractContextManager"]
    - [ExitStack,       ExitStack.__bases__.__getitem__,       [0], "AbstractContextManager"]
    - [nullcontext,     nullcontext.__bases__.__getitem__,     [0], "AbstractContextManager"]

# Note: table rows use method chain on the getitem result — the __name__ is
# accessed via the method field in the invariant form. For tables we store
# the __name__ string directly since the result of __bases__.__getitem__(0)
# is the class object and we want its __name__. These are expressed as
# individual invariants below for correctness.

# ---------------------------------------------------------------------------
# Individual invariants for base class __name__ checks
# (tables cannot chain method calls; invariants use method_chain)
# ---------------------------------------------------------------------------

invariant contextlib_extra5.suppress.base_name:
  description: "contextlib.suppress.__bases__[0].__name__ == 'AbstractContextManager'"
  category: base_classes
  kind: python_call_eq
  function: suppress.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "AbstractContextManager"

invariant contextlib_extra5.closing.base_name:
  description: "contextlib.closing.__bases__[0].__name__ == 'AbstractContextManager'"
  category: base_classes
  kind: python_call_eq
  function: closing.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "AbstractContextManager"

invariant contextlib_extra5.redirect_stdout.base_name:
  description: "contextlib.redirect_stdout.__bases__[0].__name__ == 'AbstractContextManager'"
  category: base_classes
  kind: python_call_eq
  function: redirect_stdout.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "AbstractContextManager"

invariant contextlib_extra5.redirect_stderr.base_name:
  description: "contextlib.redirect_stderr.__bases__[0].__name__ == 'AbstractContextManager'"
  category: base_classes
  kind: python_call_eq
  function: redirect_stderr.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "AbstractContextManager"

invariant contextlib_extra5.ExitStack.base_name:
  description: "contextlib.ExitStack.__bases__[0].__name__ == 'AbstractContextManager'"
  category: base_classes
  kind: python_call_eq
  function: ExitStack.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "AbstractContextManager"

invariant contextlib_extra5.AbstractContextManager.base_name:
  description: "contextlib.AbstractContextManager.__bases__[0].__name__ == 'ABC'"
  category: base_classes
  kind: python_call_eq
  function: AbstractContextManager.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ABC"

invariant contextlib_extra5.AbstractAsyncContextManager.base_name:
  description: "contextlib.AbstractAsyncContextManager.__bases__[0].__name__ == 'ABC'"
  category: base_classes
  kind: python_call_eq
  function: AbstractAsyncContextManager.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ABC"

invariant contextlib_extra5.nullcontext.base_name:
  description: "contextlib.nullcontext.__bases__[0].__name__ == 'AbstractContextManager'"
  category: base_classes
  kind: python_call_eq
  function: nullcontext.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "AbstractContextManager"

# ---------------------------------------------------------------------------
# contextmanager and asynccontextmanager — are plain functions (not classes)
# contextlib_extra also covers this; here as standalone invariants with
# distinct IDs in the contextlib_extra5 namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra5.contextmanager.class_name:
  description: "contextlib.contextmanager.__class__.__name__ == 'function'"
  category: callable_kind
  kind: python_call_eq
  function: contextmanager.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant contextlib_extra5.asynccontextmanager.class_name:
  description: "contextlib.asynccontextmanager.__class__.__name__ == 'function'"
  category: callable_kind
  kind: python_call_eq
  function: asynccontextmanager.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# Instance __class__.__name__ checks — constructing instances
# ---------------------------------------------------------------------------

invariant contextlib_extra5.suppress_instance.class_name:
  description: "contextlib.suppress(Exception).__class__.__name__ == 'suppress'"
  category: instance_types
  kind: python_call_eq
  function: suppress
  args: [{type: type_ref, value: "Exception"}]
  method: __class__.__name__.__eq__
  method_args: ["suppress"]
  expected: true

invariant contextlib_extra5.ExitStack_instance.class_name:
  description: "contextlib.ExitStack().__class__.__name__ == 'ExitStack'"
  category: instance_types
  kind: python_call_eq
  function: ExitStack().__class__.__name__.__eq__
  args: ["ExitStack"]
  expected: true

invariant contextlib_extra5.nullcontext_instance.class_name:
  description: "contextlib.nullcontext().__class__.__name__ == 'nullcontext'"
  category: instance_types
  kind: python_call_eq
  function: nullcontext().__class__.__name__.__eq__
  args: ["nullcontext"]
  expected: true
