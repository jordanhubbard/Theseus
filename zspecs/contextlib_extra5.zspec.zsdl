spec: contextlib_extra5
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends prior contextlib specs."
    - "Focus: __module__ and __name__ for contextlib classes and functions not yet covered."
    - "contextlib.contextmanager.__name__ == 'contextmanager'."
    - "contextlib.asynccontextmanager.__name__ == 'asynccontextmanager'."
    - "contextlib.closing.__name__ == 'closing'."
    - "contextlib.suppress.__name__ == 'suppress'."
    - "contextlib.ExitStack.__name__ == 'ExitStack'."
    - "contextlib.AsyncExitStack.__name__ == 'AsyncExitStack'."
    - "contextlib.nullcontext.__name__ == 'nullcontext'."
    - "contextlib.AbstractContextManager.__name__ == 'AbstractContextManager'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table contextlib_extra5.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [closing,                  closing.__name__.__eq__,                  ["closing"],                  true]
    - [suppress,                 suppress.__name__.__eq__,                 ["suppress"],                 true]
    - [ExitStack,                ExitStack.__name__.__eq__,                ["ExitStack"],                true]
    - [AsyncExitStack,           AsyncExitStack.__name__.__eq__,           ["AsyncExitStack"],           true]
    - [nullcontext,              nullcontext.__name__.__eq__,              ["nullcontext"],              true]
    - [AbstractContextManager,   AbstractContextManager.__name__.__eq__,   ["AbstractContextManager"],   true]
    - [AbstractAsyncContextManager, AbstractAsyncContextManager.__name__.__eq__, ["AbstractAsyncContextManager"], true]

table contextlib_extra5.class_modules:
  kind: python_call_eq
  category: module
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [closing,       closing.__module__.__eq__,       ["contextlib"], true]
    - [suppress,      suppress.__module__.__eq__,      ["contextlib"], true]
    - [ExitStack,     ExitStack.__module__.__eq__,     ["contextlib"], true]
    - [AsyncExitStack, AsyncExitStack.__module__.__eq__, ["contextlib"], true]
    - [nullcontext,   nullcontext.__module__.__eq__,   ["contextlib"], true]

table contextlib_extra5.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [contextmanager,      contextmanager.__name__.__eq__,      ["contextmanager"],      true]
    - [asynccontextmanager, asynccontextmanager.__name__.__eq__, ["asynccontextmanager"], true]

invariant contextlib_extra5.ExitStack.instance_class:
  description: "contextlib.ExitStack().__class__.__name__ == 'ExitStack'"
  category: ExitStack
  kind: python_call_eq
  function: ExitStack
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["ExitStack"]
  expected: true

invariant contextlib_extra5.suppress.class_name_attr:
  description: "contextlib.suppress.__name__ == 'suppress'"
  category: suppress
  kind: python_call_eq
  function: suppress.__name__.__eq__
  args: ["suppress"]
  expected: true

invariant contextlib_extra5.nullcontext.instance_class:
  description: "contextlib.nullcontext().__class__.__name__ == 'nullcontext'"
  category: nullcontext
  kind: python_call_eq
  function: nullcontext
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["nullcontext"]
  expected: true

invariant contextlib_extra5.AbstractContextManager.module:
  description: "contextlib.AbstractContextManager.__module__ == 'contextlib'"
  category: module
  kind: python_call_eq
  function: AbstractContextManager.__module__.__eq__
  args: ["contextlib"]
  expected: true
