spec: uuid_extra248
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "Wave 248 theme: uuid.UUID class method identity — uuid1/uuid3/uuid4/uuid5 function __qualname__ and __class__.__name__; UUID instance property types hex/int/bytes/version/variant."
    - "uuid.uuid1.__qualname__ == 'uuid1'. Top-level module functions have qualname equal to their __name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__class__.__name__ == 'function'. Module-level functions are plain Python 'function' objects. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__qualname__ == 'uuid3'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__qualname__ == 'uuid4'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__qualname__ == 'uuid5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4().hex.__class__.__name__ == 'str'. .hex is a 32-character lowercase hex string. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4().int.__class__.__name__ == 'int'. .int is a 128-bit Python int. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4().bytes.__class__.__name__ == 'bytes'. .bytes is a 16-byte bytes object. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4().version.__class__.__name__ == 'int'. .version is 4 for uuid4(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4().variant.__class__.__name__ == 'str'. .variant is a string describing the UUID variant (e.g., 'specified in RFC 4122'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(uuid.uuid4().hex) == 32. UUID hex representation is always 32 lowercase hex characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__name__ == 'UUID' and uuid.UUID.__module__ == 'uuid' are covered in uuid_extra.zspec.zsdl. This spec adds qualname and __class__.__name__ for uuid1/3/4/5, plus UUID instance property types."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid1/uuid3/uuid4/uuid5 function __qualname__ and __class__.__name__
#
# Wave 248 theme: uuid generator function qualname and class identity.
#
# uuid_extra.zspec.zsdl covers uuid1/3/4/5 __name__ (via table) and uuid4
# __class__.__name__=='UUID' for return type. This spec adds the qualname
# (equal to __name__ for top-level functions) and __class__.__name__ == 'function'
# for all four generators under uuidfn248.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra248.function_qualnames:
  description: "uuid generator function __qualname__ identity — uuid1/__qualname__.__eq__('uuid1')==True / uuid3/__qualname__.__eq__('uuid3')==True / uuid4/__qualname__.__eq__('uuid4')==True / uuid5/__qualname__.__eq__('uuid5')==True — top-level module functions have __qualname__ equal to __name__ (no enclosing class or function scope); uuid_extra covers __name__; wave 248 theme; first uuidfn248 anchor for function qualnames"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidfn248

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_qualname, uuid1.__qualname__.__eq__, ["uuid1"], true, "uuid.uuid1.__qualname__ == 'uuid1'; top-level function qualname equals __name__"]
    - [uuid3_qualname, uuid3.__qualname__.__eq__, ["uuid3"], true, "uuid.uuid3.__qualname__ == 'uuid3'; top-level function qualname equals __name__"]
    - [uuid4_qualname, uuid4.__qualname__.__eq__, ["uuid4"], true, "uuid.uuid4.__qualname__ == 'uuid4'; top-level function qualname equals __name__"]
    - [uuid5_qualname, uuid5.__qualname__.__eq__, ["uuid5"], true, "uuid.uuid5.__qualname__ == 'uuid5'; top-level function qualname equals __name__"]

table uuid_extra248.function_class_names:
  description: "uuid generator function __class__.__name__ identity — uuid1/__class__.__name__.__eq__('function')==True / uuid3/__class__.__name__.__eq__('function')==True / uuid4/__class__.__name__.__eq__('function')==True / uuid5/__class__.__name__.__eq__('function')==True — all four uuid generator functions are plain Python 'function' objects (not builtin_function_or_method); uuid_extra covers return type and version; wave 248 theme; first uuidfn248 anchor for function type identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidfn248

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_class, uuid1.__class__.__name__.__eq__, ["function"], true, "uuid.uuid1.__class__.__name__ == 'function'; plain Python function (not C builtin)"]
    - [uuid3_class, uuid3.__class__.__name__.__eq__, ["function"], true, "uuid.uuid3.__class__.__name__ == 'function'; plain Python function (not C builtin)"]
    - [uuid4_class, uuid4.__class__.__name__.__eq__, ["function"], true, "uuid.uuid4.__class__.__name__ == 'function'; plain Python function (not C builtin)"]
    - [uuid5_class, uuid5.__class__.__name__.__eq__, ["function"], true, "uuid.uuid5.__class__.__name__ == 'function'; plain Python function (not C builtin)"]

# ---------------------------------------------------------------------------
# UUID instance property types — hex, int, bytes, version, variant
#
# Wave 248 theme: UUID instance property value types.
#
# uuid4() returns a UUID instance. Its properties have well-defined types:
# .hex is str (32 lowercase hex chars), .int is int (128-bit),
# .bytes is bytes (16 bytes), .version is int (4 for uuid4),
# .variant is str (RFC 4122 variant description).
# uuid_extra covers .int.__class__.__name__ and .hex.__class__.__name__ for
# a fixed UUID constructed from a string; this spec covers the same for uuid4()
# plus .bytes, .version, and .variant types. Also verifies len(hex)==32.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra248.uuid4.hex_type:
  description: "uuid.uuid4().hex.__class__.__name__ == 'str' — .hex is a 32-character lowercase hex string representation of the UUID without hyphens; wave 248 theme; first standalone for uuid4 hex type under uuidfn248; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: instance_attributes
  kind: python_call_eq
  function: uuid4
  args: []
  method: hex.__class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant uuid_extra248.uuid4.int_type:
  description: "uuid.uuid4().int.__class__.__name__ == 'int' — .int is a 128-bit Python int representing the UUID's integer value; wave 248 theme; first standalone for uuid4 int type under uuidfn248; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: instance_attributes
  kind: python_call_eq
  function: uuid4
  args: []
  method: int.__class__.__name__.__eq__
  method_args: ["int"]
  expected: true

invariant uuid_extra248.uuid4.bytes_type:
  description: "uuid.uuid4().bytes.__class__.__name__ == 'bytes' — .bytes is a 16-byte bytes object (big-endian byte order); wave 248 theme; first standalone for uuid4 bytes type under uuidfn248; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: instance_attributes
  kind: python_call_eq
  function: uuid4
  args: []
  method: bytes.__class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant uuid_extra248.uuid4.version_type:
  description: "uuid.uuid4().version.__class__.__name__ == 'int' — .version is the UUID version number as a Python int; uuid4 always produces version 4; wave 248 theme; first standalone for uuid4 version type under uuidfn248; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: instance_attributes
  kind: python_call_eq
  function: uuid4
  args: []
  method: version.__class__.__name__.__eq__
  method_args: ["int"]
  expected: true

invariant uuid_extra248.uuid4.variant_type:
  description: "uuid.uuid4().variant.__class__.__name__ == 'str' — .variant is a string describing the UUID variant (e.g., RFC 4122 variant string); wave 248 theme; first standalone for uuid4 variant type under uuidfn248; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: instance_attributes
  kind: python_call_eq
  function: uuid4
  args: []
  method: variant.__class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant uuid_extra248.uuid4.hex_length:
  description: "len(uuid.uuid4().hex) == 32 — UUID hex is always exactly 32 lowercase hex characters (128 bits = 32 nibbles, no hyphens); wave 248 theme; first standalone for uuid4 hex length under uuidfn248; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: instance_attributes
  kind: python_call_eq
  function: uuid4
  args: []
  method: hex.__len__
  method_args: []
  expected: 32

invariant uuid_extra248.UUID.bases_object:
  description: "uuid.UUID.__bases__[0].__name__ == 'object' — UUID directly inherits from object (no intermediate base classes in the stdlib implementation); wave 248 theme; first standalone for UUID base class name under uuidfn248; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_metadata
  kind: python_call_eq
  function: UUID.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
