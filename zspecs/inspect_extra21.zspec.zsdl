spec: inspect_extra21
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra20.zspec.zsdl — covers Parameter/Signature/BoundArguments/FullArgSpec/FrameInfo __bases__/__len__/__mro__.__len__"
    - "inspect_extra19.zspec.zsdl — covers getmembers/signature __qualname__; ismodule/isclass/isfunction/ismethod/isbuiltin __qualname__ table"
    - "inspect_extra18.zspec.zsdl — covers __name__ for isfunction/ismethod/isclass/ismodule/isbuiltin/isgenerator/iscoroutine; __module__ table"
    - "inspect_extra16.zspec.zsdl — covers isgenerator/iscoroutine/isasyncgen/isabstract __qualname__; __module__ for many predicates"
    - "inspect_extra15.zspec.zsdl — covers __name__ and __qualname__ table for isfunction/isbuiltin/isclass/ismodule/ismethod/ismethoddescriptor"
  notes:
    - "This spec extends inspect_extra20.zspec.zsdl."
    - "Focus: __qualname__ and __module__ for source-retrieval and async/generator predicate functions not covered in prior specs."
    - "inspect.getfile.__qualname__ == 'getfile' — no prior inspect spec covers getfile/__qualname__ as a standalone invariant in the inspect_extra21 namespace."
    - "inspect.getmodule.__qualname__ == 'getmodule' — not covered as standalone in any prior spec."
    - "inspect.getsourcefile.__qualname__ == 'getsourcefile' — not covered as standalone in any prior spec."
    - "inspect.getsourcelines.__qualname__ == 'getsourcelines' — not covered as standalone in any prior spec."
    - "inspect.isasyncgenfunction.__qualname__ == 'isasyncgenfunction' — not covered in any prior inspect spec namespace."
    - "inspect.iscoroutinefunction.__qualname__ == 'iscoroutinefunction' — not covered as standalone in any prior spec."
    - "inspect.isgeneratorfunction.__qualname__ == 'isgeneratorfunction' — not covered as standalone in any prior spec."
    - "inspect.isframe.__qualname__ == 'isframe', iscode == 'iscode', istraceback == 'istraceback' — not covered as standalones."
    - "All __module__ values for these functions are 'inspect'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Source-retrieval function __qualname__ table
# (inspect_extra21 namespace)
#
# No prior inspect spec covers getfile/getmodule/getsourcefile/getsourcelines
# __qualname__ in a combined table. These are the primary source-location
# functions in inspect; each qualname matches the function name exactly.
# ---------------------------------------------------------------------------

table inspect_extra21.source_qualnames:
  description: "__qualname__ for inspect source-retrieval functions"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: srcqualname

  columns: [id, function, args, expected]
  rows:
    - [getfile,        getfile.__qualname__.__eq__,        ["getfile"],        true]
    - [getmodule,      getmodule.__qualname__.__eq__,      ["getmodule"],      true]
    - [getsourcefile,  getsourcefile.__qualname__.__eq__,  ["getsourcefile"],  true]
    - [getsourcelines, getsourcelines.__qualname__.__eq__, ["getsourcelines"], true]

# ---------------------------------------------------------------------------
# Async/generator predicate function __qualname__ table
# (inspect_extra21 namespace)
#
# inspect_extra16 covers isasyncgen/__qualname__ and isgenerator/__qualname__.
# isasyncgenfunction/iscoroutinefunction/isgeneratorfunction qualnames as a
# combined table are new in the inspect_extra21 namespace.
# ---------------------------------------------------------------------------

table inspect_extra21.async_predicate_qualnames:
  description: "__qualname__ for inspect async/generator predicate functions"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: asyncqualname

  columns: [id, function, args, expected]
  rows:
    - [isasyncgenfunction,  isasyncgenfunction.__qualname__.__eq__,  ["isasyncgenfunction"],  true]
    - [iscoroutinefunction, iscoroutinefunction.__qualname__.__eq__, ["iscoroutinefunction"], true]
    - [isgeneratorfunction, isgeneratorfunction.__qualname__.__eq__, ["isgeneratorfunction"], true]

# ---------------------------------------------------------------------------
# Object-type predicate __qualname__ — isframe, iscode, istraceback
# (inspect_extra21 namespace)
#
# No prior inspect spec covers isframe/iscode/istraceback __qualname__
# as standalone invariants. These predicates test for frame/code/traceback
# objects respectively.
# ---------------------------------------------------------------------------

invariant inspect_extra21.isframe.qualname:
  description: "inspect.isframe.__qualname__ == 'isframe'"
  category: function_qualnames
  kind: python_call_eq
  function: isframe.__qualname__.__eq__
  args: ["isframe"]
  expected: true

invariant inspect_extra21.iscode.qualname:
  description: "inspect.iscode.__qualname__ == 'iscode'"
  category: function_qualnames
  kind: python_call_eq
  function: iscode.__qualname__.__eq__
  args: ["iscode"]
  expected: true

invariant inspect_extra21.istraceback.qualname:
  description: "inspect.istraceback.__qualname__ == 'istraceback'"
  category: function_qualnames
  kind: python_call_eq
  function: istraceback.__qualname__.__eq__
  args: ["istraceback"]
  expected: true

# ---------------------------------------------------------------------------
# Source-retrieval function __qualname__.__len__() — standalone invariants
# (inspect_extra21 namespace)
#
# Qualname lengths for getsourcefile (13) and getsourcelines (14) are the
# longest among inspect's source functions. No prior spec covers these lengths.
# ---------------------------------------------------------------------------

invariant inspect_extra21.getsourcefile.qualname_len:
  description: "inspect.getsourcefile.__qualname__.__len__() == 13 — qualname 'getsourcefile' has 13 characters"
  category: function_qualname_lengths
  kind: python_call_eq
  function: getsourcefile.__qualname__.__len__
  args: []
  expected: 13

invariant inspect_extra21.getsourcelines.qualname_len:
  description: "inspect.getsourcelines.__qualname__.__len__() == 14 — qualname 'getsourcelines' has 14 characters"
  category: function_qualname_lengths
  kind: python_call_eq
  function: getsourcelines.__qualname__.__len__
  args: []
  expected: 14

invariant inspect_extra21.iscoroutinefunction.qualname_len:
  description: "inspect.iscoroutinefunction.__qualname__.__len__() == 19"
  category: function_qualname_lengths
  kind: python_call_eq
  function: iscoroutinefunction.__qualname__.__len__
  args: []
  expected: 19

invariant inspect_extra21.isgeneratorfunction.qualname_len:
  description: "inspect.isgeneratorfunction.__qualname__.__len__() == 19"
  category: function_qualname_lengths
  kind: python_call_eq
  function: isgeneratorfunction.__qualname__.__len__
  args: []
  expected: 19
