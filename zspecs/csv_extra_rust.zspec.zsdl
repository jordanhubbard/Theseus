spec: csv_extra_rust
version: ">=3.9"
backend: rust_module(csv_extra_rust)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv documentation"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
  notes:
    - "Clean-room Rust reimplementation of Python csv constants and helpers, exposed via PyO3."
    - "QUOTE_MINIMAL == 0 — only quote fields that require it."
    - "QUOTE_ALL == 1 — quote all fields."
    - "QUOTE_NONNUMERIC == 2 — quote all non-numeric fields."
    - "QUOTE_NONE == 3 — never quote fields."
    - "get_dialect('excel').delimiter == ',' — default Excel dialect."
    - "get_dialect('excel').lineterminator == '\\r\\n'."
    - "All test vectors verified against Python 3.14.3 csv module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# Quote mode constants
table csv_extra_rust.quote_constants.vectors:
  kind: python_call_eq
  category: constants
  id_prefix: csv_qc

  columns: [id, function, args, expected]
  rows:
    - [minimal,    QUOTE_MINIMAL.__eq__,    [0], true]
    - [all,        QUOTE_ALL.__eq__,        [1], true]
    - [nonnumeric, QUOTE_NONNUMERIC.__eq__, [2], true]
    - [none,       QUOTE_NONE.__eq__,       [3], true]

# get_dialect — Excel dialect properties
invariant csv_extra_rust.dialect.excel_delimiter:
  description: "get_dialect('excel').delimiter == ','"
  category: dialect
  kind: python_call_eq
  function: get_dialect
  args: ["excel"]
  method: delimiter
  expected: ","

invariant csv_extra_rust.dialect.excel_quotechar:
  description: "get_dialect('excel').quotechar == '\"'"
  category: dialect
  kind: python_call_eq
  function: get_dialect
  args: ["excel"]
  method: quotechar
  expected: "\""

invariant csv_extra_rust.dialect.excel_skipinitialspace:
  description: "get_dialect('excel').skipinitialspace == False"
  category: dialect
  kind: python_call_eq
  function: get_dialect
  args: ["excel"]
  method: skipinitialspace
  expected: false

invariant csv_extra_rust.dialect.excel_strict:
  description: "get_dialect('excel').strict == False"
  category: dialect
  kind: python_call_eq
  function: get_dialect
  args: ["excel"]
  method: strict
  expected: false

