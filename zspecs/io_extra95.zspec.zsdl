spec: io_extra95
version: ">=3.9"
backend: python_module(io)
extends: io_extra94

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra94."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths; FileIO/BytesIO/StringIO __dict__/__class__.__name__ and membership; BufferedReader/BufferedWriter/TextIOWrapper identity and MRO; BufferedRandom/__name__/__module__/bases/MRO; BufferedRWPair identity and hierarchy; IncrementalNewlineDecoder identity; TextIOWrapper/__name__/__module__/bases/MRO; StringIO/__name__/__module__/bases/MRO; FileIO/__name__/__module__/bases/MRO; BytesIO/__name__/__module__/bases/MRO; __mro__.__len__() for all classes; __name__ and __module__ string equality for all io classes."
    - "This spec covers: io.BytesIO and io.StringIO __dict__ membership for read/write/readable/writable/seekable/truncate/readline methods."
    - "io.BytesIO.__dict__.__contains__('read') == True — BytesIO implements read directly as a C-level method."
    - "io.BytesIO.__dict__.__contains__('write') == True — BytesIO implements write directly."
    - "io.BytesIO.__dict__.__contains__('readable') == True — BytesIO implements readable directly."
    - "io.BytesIO.__dict__.__contains__('writable') == True — BytesIO implements writable directly."
    - "io.BytesIO.__dict__.__contains__('seekable') == True — BytesIO implements seekable directly."
    - "io.BytesIO.__dict__.__contains__('truncate') == True — BytesIO implements truncate directly."
    - "io.BytesIO.__dict__.__contains__('readline') == True — BytesIO implements readline directly."
    - "io.StringIO.__dict__.__contains__('read') == True — StringIO implements read directly as a C-level method."
    - "io.StringIO.__dict__.__contains__('write') == True — StringIO implements write directly."
    - "io.StringIO.__dict__.__contains__('readable') == True — StringIO implements readable directly."
    - "io.StringIO.__dict__.__contains__('writable') == True — StringIO implements writable directly."
    - "io.StringIO.__dict__.__contains__('seekable') == True — StringIO implements seekable directly."
    - "io.StringIO.__dict__.__contains__('truncate') == True — StringIO implements truncate directly."
    - "io.StringIO.__dict__.__contains__('readline') == True — StringIO implements readline directly."
    - "io.StringIO.__dict__.__contains__('readlines') == False — readlines is inherited from IOBase, not defined on StringIO."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO __dict__ membership: read/write/readable/writable
# BytesIO is a C-extension class from _io; these methods are defined directly
# on BytesIO itself, not inherited from a base class.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra95.BytesIO_dict_group1:
  description: "io.BytesIO.__dict__.__contains__ for read/write/readable/writable (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iodictmem95

  columns: [id, function, args, expected]
  rows:
    - [bytesio_has_read,     BytesIO.__dict__.__contains__, ["read"],     true]
    - [bytesio_has_write,    BytesIO.__dict__.__contains__, ["write"],    true]
    - [bytesio_has_readable, BytesIO.__dict__.__contains__, ["readable"], true]
    - [bytesio_has_writable, BytesIO.__dict__.__contains__, ["writable"], true]

# ---------------------------------------------------------------------------
# io.BytesIO __dict__ membership: seekable/truncate/readline
# seekable, truncate, and readline are also defined directly on BytesIO.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra95.BytesIO_dict_group2:
  description: "io.BytesIO.__dict__.__contains__ for seekable/truncate/readline (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iodictmem95

  columns: [id, function, args, expected]
  rows:
    - [bytesio_has_seekable, BytesIO.__dict__.__contains__, ["seekable"], true]
    - [bytesio_has_truncate, BytesIO.__dict__.__contains__, ["truncate"], true]
    - [bytesio_has_readline, BytesIO.__dict__.__contains__, ["readline"], true]

# ---------------------------------------------------------------------------
# io.StringIO __dict__ membership: read/write/readable/writable
# StringIO is a C-extension class from _io; these methods are defined directly
# on StringIO itself, not inherited from a base class.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra95.StringIO_dict_group1:
  description: "io.StringIO.__dict__.__contains__ for read/write/readable/writable (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iodictmem95

  columns: [id, function, args, expected]
  rows:
    - [stringio_has_read,     StringIO.__dict__.__contains__, ["read"],     true]
    - [stringio_has_write,    StringIO.__dict__.__contains__, ["write"],    true]
    - [stringio_has_readable, StringIO.__dict__.__contains__, ["readable"], true]
    - [stringio_has_writable, StringIO.__dict__.__contains__, ["writable"], true]

# ---------------------------------------------------------------------------
# io.StringIO __dict__ membership: seekable/truncate/readline/readlines
# seekable, truncate, readline are defined directly on StringIO.
# readlines is NOT in StringIO.__dict__; it is inherited from IOBase.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra95.StringIO_dict_group2:
  description: "io.StringIO.__dict__.__contains__ for seekable/truncate/readline (True) and readlines (False)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iodictmem95

  columns: [id, function, args, expected]
  rows:
    - [stringio_has_seekable,  StringIO.__dict__.__contains__, ["seekable"],  true]
    - [stringio_has_truncate,  StringIO.__dict__.__contains__, ["truncate"],  true]
    - [stringio_has_readline,  StringIO.__dict__.__contains__, ["readline"],  true]
    - [stringio_no_readlines,  StringIO.__dict__.__contains__, ["readlines"], false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra95.BytesIO.dict_read:
  description: "io.BytesIO.__dict__.__contains__('read') == True (read is a C-level method defined directly on BytesIO)"
  category: dict_membership
  kind: python_call_eq
  function: BytesIO.__dict__.__contains__
  args: ["read"]
  expected: true

invariant io_extra95.BytesIO.dict_write:
  description: "io.BytesIO.__dict__.__contains__('write') == True (write is a C-level method defined directly on BytesIO)"
  category: dict_membership
  kind: python_call_eq
  function: BytesIO.__dict__.__contains__
  args: ["write"]
  expected: true

invariant io_extra95.BytesIO.dict_seekable:
  description: "io.BytesIO.__dict__.__contains__('seekable') == True (seekable is a C-level method defined directly on BytesIO)"
  category: dict_membership
  kind: python_call_eq
  function: BytesIO.__dict__.__contains__
  args: ["seekable"]
  expected: true

invariant io_extra95.StringIO.dict_read:
  description: "io.StringIO.__dict__.__contains__('read') == True (read is a C-level method defined directly on StringIO)"
  category: dict_membership
  kind: python_call_eq
  function: StringIO.__dict__.__contains__
  args: ["read"]
  expected: true

invariant io_extra95.StringIO.dict_no_readlines:
  description: "io.StringIO.__dict__.__contains__('readlines') == False (readlines is inherited from IOBase, not defined on StringIO)"
  category: dict_membership
  kind: python_call_eq
  function: StringIO.__dict__.__contains__
  args: ["readlines"]
  expected: false
