spec: hashlib_extra2521
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "hashlib_extra306.zspec.zsdl — covers hashlib.new() error/hexdigest/digest/update/algorithms_available (table + invariants)."
    - "hashlib_extra2.zspec.zsdl — covers md5/sha1/sha256/sha512 hexdigest vectors, digest_size, algorithms_guaranteed type, new() return type."
    - "hashlib_extra.zspec.zsdl — covers blake2b/blake2s/sha3 attrs, algorithms_available type and sha256 membership, pbkdf2_hmac."
    - "hashlib.zspec.zsdl — covers sha256/sha1/md5/sha512/sha3/blake2b/blake2s known vectors, digest_size/block_size, algorithms_guaranteed core set."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib.zspec.zsdl, hashlib_extra.zspec.zsdl, hashlib_extra2.zspec.zsdl, or hashlib_extra306.zspec.zsdl."
    - "Theme: __bool__, __index__, and __int__ dict-presence for hashlib constructor functions and their underlying C types."
    - "The tables in this spec test sha256.__class__ and shake_256.__class__. These are the type of the hashlib module-level constructor functions (sha256, shake_256). hashlib.sha256.__class__.__name__ == 'builtin_function_or_method'. Neither __bool__, __int__, nor __index__ is present in builtin_function_or_method.__dict__."
    - "The standalone invariants test the HASH and HASHXOF C extension types via method chaining: sha256().__class__.__dict__.__contains__('__bool__') accesses type(sha256()) == HASH type, where HASH is the _hashlib.HASH C extension class for sha256/md5/sha1/sha512 instances."
    - "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "builtin_function_or_method.__dict__.__contains__('__bool__') == False. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "builtin_function_or_method.__dict__.__contains__('__int__') == False. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "builtin_function_or_method.__dict__.__contains__('__index__') == False. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "HASH (type(hashlib.sha256())) does not define __bool__, __int__, or __index__ in its own __dict__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "HASHXOF (type(hashlib.shake_256())) does not define __bool__, __int__, or __index__ in its own __dict__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sha256 constructor function class: __bool__ / __int__ / __index__ dict-presence
#
# hashlib.sha256 is a module-level builtin_function_or_method.
# sha256.__class__ is the 'builtin_function_or_method' type.
# builtin_function_or_method.__dict__ does not contain __bool__, __int__, or __index__.
# All hashlib constructor functions (sha256, md5, sha1, sha512, shake_256, etc.)
# share the same 'builtin_function_or_method' type and the same absent coercion dunders.
# Verified Python 3.14 macOS/Darwin 25.4.0, 2026-04-13.
# ---------------------------------------------------------------------------

table hashlib_extra2521.sha256_constructor_class_bool_int_index:
  description: "hashlib.sha256.__class__.__dict__.__contains__('__bool__')==False / sha256.__class__.__dict__.__contains__('__int__')==False / sha256.__class__.__dict__.__contains__('__index__')==False — hashlib.sha256 is a module-level builtin_function_or_method (hashlib.sha256.__class__.__name__=='builtin_function_or_method'); sha256.__class__ is the 'builtin_function_or_method' type; builtin_function_or_method.__dict__ does not contain __bool__ (the constructor function type defines no truthiness protocol); does not contain __int__ (builtin_function_or_method is not integer-coercible); does not contain __index__ (cannot serve as sequence index); all hashlib hash constructor functions (sha256/md5/sha1/sha512/blake2b/blake2s) share this 'builtin_function_or_method' type with no coercion dunders in the type's own __dict__; first hl2521 anchor for sha256 constructor class coercion-dunder absence"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2521

  columns: [id, function, args, expected]
  rows:
    - ["hl2521_sha256_cls_no_bool",  "sha256.__class__.__dict__.__contains__",  ["__bool__"],  false]
    - ["hl2521_sha256_cls_no_int",   "sha256.__class__.__dict__.__contains__",  ["__int__"],   false]
    - ["hl2521_sha256_cls_no_index", "sha256.__class__.__dict__.__contains__",  ["__index__"], false]

# ---------------------------------------------------------------------------
# shake_256 constructor function class: __bool__ / __int__ / __index__ dict-presence
#
# hashlib.shake_256 is also a builtin_function_or_method.
# shake_256.__class__ is the same 'builtin_function_or_method' type as sha256.
# This table confirms the pattern holds for XOF constructors as well.
# Verified Python 3.14 macOS/Darwin 25.4.0, 2026-04-13.
# ---------------------------------------------------------------------------

table hashlib_extra2521.shake256_constructor_class_bool_int_index:
  description: "hashlib.shake_256.__class__.__dict__.__contains__('__bool__')==False / shake_256.__class__.__dict__.__contains__('__int__')==False / shake_256.__class__.__dict__.__contains__('__index__')==False — hashlib.shake_256 is a module-level builtin_function_or_method (shake_256.__class__.__name__=='builtin_function_or_method'); shake_256.__class__ is the same 'builtin_function_or_method' type as sha256.__class__; the shake_256 constructor for the HASHXOF type also has no coercion dunders in its class dict; the shake (XOF) constructors (shake_128/shake_256) share the same function type as the fixed-length constructors (sha256/md5 etc.); first hl2521 anchor for shake_256 constructor class coercion-dunder absence"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2521

  columns: [id, function, args, expected]
  rows:
    - ["hl2521_shake256_cls_no_bool",  "shake_256.__class__.__dict__.__contains__",  ["__bool__"],  false]
    - ["hl2521_shake256_cls_no_int",   "shake_256.__class__.__dict__.__contains__",  ["__int__"],   false]
    - ["hl2521_shake256_cls_no_index", "shake_256.__class__.__dict__.__contains__",  ["__index__"], false]
    - ["hl2521_md5_cls_no_bool",       "md5.__class__.__dict__.__contains__",        ["__bool__"],  false]
    - ["hl2521_sha512_cls_no_int",     "sha512.__class__.__dict__.__contains__",     ["__int__"],   false]

# ---------------------------------------------------------------------------
# Standalone: sha256().__class__.__dict__.__contains__('__bool__') == False
#
# These standalones test the HASH C extension type directly (not the constructor).
# sha256() calls the sha256 constructor with no args -> returns a HASH instance.
# .__class__ is the HASH type (_hashlib.HASH, the C extension type for all fixed-size hash objects).
# HASH.__dict__.__contains__('__bool__') is False — HASH defines no own __bool__.
# Truthiness of HASH instances falls through to object.__bool__ (always True).
# Verified Python 3.14 macOS/Darwin 25.4.0, 2026-04-13.
# ---------------------------------------------------------------------------

invariant hashlib_extra2521.HASH_instance_no_bool:
  description: "hashlib.sha256().__class__.__dict__.__contains__('__bool__') == False — sha256() returns a HASH instance; .__class__ is the _hashlib.HASH C extension type (type of all fixed-length hash objects: sha256/md5/sha1/sha512/blake2b/blake2s instances); HASH.__dict__.__contains__('__bool__') is False — HASH defines no own __bool__; bool(sha256_obj) delegates to object.__bool__ (always True); '__bool__'=8 chars = '__'=2 + 'bool'=4 + '__'=2; HASH is a hash-computation type with no truthiness semantics; contrasts with the sha256 CONSTRUCTOR (builtin_function_or_method) which is also False via a different path (tables above); first hl2521 standalone for HASH instance class no-__bool__"
  category: dict_presence
  kind: python_call_eq
  function: sha256
  args: []
  method: __class__.__dict__.__contains__
  method_args: ["__bool__"]
  expected: false

# ---------------------------------------------------------------------------
# Standalone: sha256().__class__.__dict__.__contains__('__int__') == False
#
# HASH defines no __int__. int(hashlib.sha256()) raises TypeError.
# SHA-256 produces 32 bytes; to get an integer from the digest, use
# int.from_bytes(sha256_obj.digest(), 'big'), but __int__ is not a shortcut.
# Verified Python 3.14 macOS/Darwin 25.4.0, 2026-04-13.
# ---------------------------------------------------------------------------

invariant hashlib_extra2521.HASH_instance_no_int:
  description: "hashlib.sha256().__class__.__dict__.__contains__('__int__') == False — HASH C extension type defines no own __int__; int(hashlib.sha256()) raises TypeError; SHA-256 digest (32 bytes) can be obtained as an integer via int.from_bytes(sha256_obj.digest(), 'big') but no __int__ shortcut is defined on HASH; '__int__'=7 chars; absence of __int__ is consistent with HASH being a hash-computation type, not a numeric type; contrasts with uuid.UUID which DOES define __int__ (to return the 128-bit UUID integer); first hl2521 standalone for HASH instance class no-__int__"
  category: dict_presence
  kind: python_call_eq
  function: sha256
  args: []
  method: __class__.__dict__.__contains__
  method_args: ["__int__"]
  expected: false

# ---------------------------------------------------------------------------
# Standalone: sha256().__class__.__dict__.__contains__('__index__') == False
# ---------------------------------------------------------------------------

invariant hashlib_extra2521.HASH_instance_no_index:
  description: "hashlib.sha256().__class__.__dict__.__contains__('__index__') == False — HASH C extension type defines no own __index__; HASH objects cannot be used as sequence indices (list[sha256_obj] raises TypeError); __index__ is the integer-index protocol for use in slice operations and sequence subscripts; its absence from HASH.__dict__ is expected — HASH has no integer-index semantics; '__index__'=9 chars = '__'=2 + 'index'=5 + '__'=2; dunder length ordering: '__int__'(7) < '__bool__'(8) < '__index__'(9); first hl2521 standalone for HASH instance class no-__index__"
  category: dict_presence
  kind: python_call_eq
  function: sha256
  args: []
  method: __class__.__dict__.__contains__
  method_args: ["__index__"]
  expected: false

# ---------------------------------------------------------------------------
# Standalone: shake_256().__class__.__dict__.__contains__('__bool__') == False
#
# The HASHXOF C type also lacks __bool__/__int__/__index__ in its own __dict__.
# shake_256() creates a HASHXOF instance; its class is _hashlib.HASHXOF,
# distinct from HASH. HASHXOF handles variable-length output functions.
# Verified Python 3.14 macOS/Darwin 25.4.0, 2026-04-13.
# ---------------------------------------------------------------------------

invariant hashlib_extra2521.HASHXOF_instance_no_bool:
  description: "hashlib.shake_256().__class__.__dict__.__contains__('__bool__') == False — shake_256() returns a HASHXOF instance; .__class__ is the _hashlib.HASHXOF C extension type (type of shake_128/shake_256 instances); HASHXOF differs from HASH in that digests have variable length (specified at digest-time via digest(n)); HASHXOF does not define __bool__ in its own __dict__; bool(shake_256_obj) delegates to object.__bool__ (always True); first hl2521 standalone for HASHXOF instance class no-__bool__"
  category: dict_presence
  kind: python_call_eq
  function: shake_256
  args: []
  method: __class__.__dict__.__contains__
  method_args: ["__bool__"]
  expected: false

invariant hashlib_extra2521.HASHXOF_instance_no_int:
  description: "hashlib.shake_256().__class__.__dict__.__contains__('__int__') == False — HASHXOF C extension type defines no own __int__; XOF (extendable-output function) objects are not integer-coercible; shake_256 produces variable-length output — there is no single canonical integer representation; '__int__'=7 chars; first hl2521 standalone for HASHXOF instance class no-__int__"
  category: dict_presence
  kind: python_call_eq
  function: shake_256
  args: []
  method: __class__.__dict__.__contains__
  method_args: ["__int__"]
  expected: false

invariant hashlib_extra2521.HASHXOF_instance_no_index:
  description: "hashlib.shake_256().__class__.__dict__.__contains__('__index__') == False — HASHXOF C extension type defines no own __index__; HASHXOF objects cannot be used as sequence indices; absence of __index__ mirrors HASH; XOF objects have no integer-index semantics; '__index__'=9 chars is the longest coercion dunder in this spec; dunder length ordering: '__int__'(7) < '__bool__'(8) < '__index__'(9); both HASH and HASHXOF lack all three coercion dunders; first hl2521 standalone for HASHXOF instance class no-__index__"
  category: dict_presence
  kind: python_call_eq
  function: shake_256
  args: []
  method: __class__.__dict__.__contains__
  method_args: ["__index__"]
  expected: false

# ---------------------------------------------------------------------------
# Standalone: md5().__class__.__dict__.__contains__('__bool__') == False
#
# md5() creates a HASH instance (same type as sha256()). HASH.__dict__ has
# no __bool__. This standalone uses md5 to confirm the same HASH type is
# shared by all fixed-length hash constructors (sha256, md5, sha1, sha512).
# Verified Python 3.14 macOS/Darwin 25.4.0, 2026-04-13.
# ---------------------------------------------------------------------------

invariant hashlib_extra2521.HASH_md5_instance_no_bool:
  description: "hashlib.md5().__class__.__dict__.__contains__('__bool__') == False — md5() returns a HASH instance (same _hashlib.HASH C extension type as sha256()); type(hashlib.md5()) is type(hashlib.sha256()) — all fixed-length hash constructors produce HASH instances; HASH.__dict__.__contains__('__bool__') is False; md5().__class__.__dict__.__contains__('__bool__') confirms the same absence applies when accessed via md5 rather than sha256; first hl2521 standalone for md5 HASH instance no-__bool__"
  category: dict_presence
  kind: python_call_eq
  function: md5
  args: []
  method: __class__.__dict__.__contains__
  method_args: ["__bool__"]
  expected: false
