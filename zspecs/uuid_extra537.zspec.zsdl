table uuid_extra537.uuid_dunder_qualnames:
  description: "uuid.UUID dunder method __qualname__ identity checks"
  kind: python_call_eq
  category: method_identity
  id_prefix: uuidq
  columns: [id, function, args, expected]
  rows:
    - [uuidq001, uuid.UUID.__str__.__qualname__.__eq__, ["UUID.__str__"], true]
    - [uuidq002, uuid.UUID.__repr__.__qualname__.__eq__, ["UUID.__repr__"], true]
    - [uuidq003, uuid.UUID.__eq__.__qualname__.__eq__, ["UUID.__eq__"], true]
    - [uuidq004, uuid.UUID.__lt__.__qualname__.__eq__, ["UUID.__lt__"], true]
    - [uuidq005, uuid.UUID.__gt__.__qualname__.__eq__, ["UUID.__gt__"], true]
    - [uuidq006, uuid.UUID.__hash__.__qualname__.__eq__, ["UUID.__hash__"], true]
    - [uuidq007, uuid.UUID.__init__.__qualname__.__eq__, ["UUID.__init__"], true]
    - [uuidq008, uuid.UUID.__setattr__.__qualname__.__eq__, ["UUID.__setattr__"], true]
    - [uuidq009, uuid.UUID.__int__.__qualname__.__eq__, ["UUID.__int__"], true]
