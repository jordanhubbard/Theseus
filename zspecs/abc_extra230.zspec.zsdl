spec: abc_extra230
version: ">=3.10"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html#abc.update_abstractmethods

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html#abc.update_abstractmethods — abc.update_abstractmethods documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "abc.update_abstractmethods.__name__ == 'update_abstractmethods' — 22 characters; verified with Python 3.14.3."
    - "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods' — module-level function, qualname equals name; verified with Python 3.14.3."
    - "abc.update_abstractmethods.__module__ == 'abc'; verified with Python 3.14.3."
    - "abc.update_abstractmethods.__class__.__name__ == 'function' — a plain Python function; verified with Python 3.14.3."
    - "callable(abc.update_abstractmethods) == True; verified with Python 3.14.3."
    - "abc.update_abstractmethods was added in Python 3.10 (PEP 3119 refinement); version constraint set to >=3.10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.update_abstractmethods function identity contracts — extra230 namespace
#
# update_abstractmethods.__name__ == 'update_abstractmethods' (22 chars).
# update_abstractmethods.__qualname__ == 'update_abstractmethods'.
# update_abstractmethods.__module__ == 'abc'.
# update_abstractmethods.__class__.__name__ == 'function'.
# ---------------------------------------------------------------------------

table abc_extra230.update_abstractmethods_identity:
  description: "abc.update_abstractmethods function identity contracts in abc230uai namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc230uai

  columns: [id, function, args, expected, description]
  rows:
    - [uam_name_eq,           update_abstractmethods.__name__.__eq__,              ["update_abstractmethods"], true, "abc.update_abstractmethods.__name__ == 'update_abstractmethods'; verified with Python 3.14.3"]
    - [uam_name_len_22,       update_abstractmethods.__name__.__len__,             [],                         22,   "abc.update_abstractmethods.__name__.__len__() == 22 — 'update_abstractmethods' has 22 characters; verified with Python 3.14.3"]
    - [uam_qualname_eq,       update_abstractmethods.__qualname__.__eq__,          ["update_abstractmethods"], true, "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods'; verified with Python 3.14.3"]
    - [uam_qualname_len_22,   update_abstractmethods.__qualname__.__len__,         [],                         22,   "abc.update_abstractmethods.__qualname__.__len__() == 22 — qualname has 22 characters; verified with Python 3.14.3"]
    - [uam_module_eq,         update_abstractmethods.__module__.__eq__,            ["abc"],                    true, "abc.update_abstractmethods.__module__ == 'abc'; verified with Python 3.14.3"]
    - [uam_module_len_3,      update_abstractmethods.__module__.__len__,           [],                         3,    "abc.update_abstractmethods.__module__.__len__() == 3 — 'abc' has 3 characters; verified with Python 3.14.3"]
    - [uam_class_name_eq,     update_abstractmethods.__class__.__name__.__eq__,    ["function"],               true, "abc.update_abstractmethods.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [uam_name_eq_qualname,  update_abstractmethods.__name__.__eq__,              ["update_abstractmethods"], true, "abc.update_abstractmethods.__name__ equals __qualname__ — module-level function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.update_abstractmethods name/qualname agreement contracts — extra230 namespace
#
# For a module-level function, __name__ and __qualname__ are identical strings.
# Their __eq__ with each other returns True (confirmed via Python 3.14.3).
# ---------------------------------------------------------------------------

table abc_extra230.update_abstractmethods_name_module:
  description: "abc.update_abstractmethods __name__ startswith and __module__ identity contracts in abc230unm namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc230unm

  columns: [id, function, args, expected, description]
  rows:
    - [uam_name_startswith_update, update_abstractmethods.__name__.startswith,    ["update"],   true, "abc.update_abstractmethods.__name__.startswith('update') == True; verified with Python 3.14.3"]
    - [uam_name_endswith_methods,  update_abstractmethods.__name__.endswith,      ["methods"],  true, "abc.update_abstractmethods.__name__.endswith('methods') == True; verified with Python 3.14.3"]
    - [uam_module_startswith_abc,  update_abstractmethods.__module__.startswith,  ["abc"],      true, "abc.update_abstractmethods.__module__.startswith('abc') == True; verified with Python 3.14.3"]
    - [uam_name_contains_abstract, update_abstractmethods.__name__.__contains__,  ["abstract"], true, "abc.update_abstractmethods.__name__.__contains__('abstract') == True; verified with Python 3.14.3"]
    - [uam_qualname_startswith_u,  update_abstractmethods.__qualname__.startswith, ["update"],  true, "abc.update_abstractmethods.__qualname__.startswith('update') == True; verified with Python 3.14.3"]
