spec: builtins_extra20
version: ">=3.9"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/functions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functions.html — Python built-in functions documentation"
    - "https://docs.python.org/3/library/stdtypes.html — Python standard type hierarchy"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Objects/typeobject.c"
  notes:
    - "This spec extends prior builtins specs (builtins through builtins_extra19)."
    - "builtins_extra11 covers: int/float/complex/bool __name__ via table rows."
    - "builtins_extra3 covers: int.__module__/float.__module__/complex.__module__/bool.__module__ == 'builtins'."
    - "builtins_extra4 covers: float/complex/bool __qualname__ via table rows."
    - "builtins_extra5 covers: int __qualname__ via table row."
    - "builtins_extra8/extra9/extra11 cover: int/float/complex/bool __mro__.__len__() values."
    - "builtins_extra3 covers: int.__bases__[0].__name__ == 'object'; bool.__bases__[0].__name__ == 'int'."
    - "builtins_extra12 covers: float.__bases__[0].__name__ == 'object'; complex.__bases__[0].__name__ == 'object'."
    - "builtins_extra12 covers: bool.__mro__[1].__name__ == 'int'; bool.__mro__[2].__name__ == 'object'."
    - "No prior spec covers int.__mro__[0].__name__ == 'int' or int.__mro__[1].__name__ == 'object' via getitem+method."
    - "No prior spec covers float.__mro__[0].__name__ == 'float' or float.__mro__[1].__name__ == 'object' via getitem+method."
    - "No prior spec covers complex.__mro__[0].__name__ == 'complex' or complex.__mro__[1].__name__ == 'object' via getitem+method."
    - "No prior spec covers bool.__mro__[0].__name__ == 'bool' via getitem+method."
    - "int.__mro__[0].__name__ == 'int' — MRO[0] is always the class itself."
    - "int.__mro__[1].__name__ == 'object' — int inherits directly from object."
    - "float.__mro__[0].__name__ == 'float' — MRO[0] is always the class itself."
    - "float.__mro__[1].__name__ == 'object' — float inherits directly from object."
    - "complex.__mro__[0].__name__ == 'complex' — MRO[0] is always the class itself."
    - "complex.__mro__[1].__name__ == 'object' — complex inherits directly from object."
    - "bool.__mro__[0].__name__ == 'bool' — MRO[0] is always the class itself."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# MRO[0].__name__ for int, float, complex, bool
#
# For any class C, C.__mro__[0] is always C itself. This table verifies
# that MRO[0].__name__ equals the class name for each numeric built-in type.
# builtins_extra12 covers MRO[0] for list/tuple/dict/set but not numeric types.
# ---------------------------------------------------------------------------

table builtins_extra20.numeric_mro_self:
  description: "__mro__[0].__name__ equals the class name for int/float/complex/bool"
  kind: python_call_eq
  category: mro
  id_prefix: mro0

  columns: [id, function, args, method, expected]
  rows:
    - [int,     int.__mro__.__getitem__,     [0], __name__, "int"]
    - [float,   float.__mro__.__getitem__,   [0], __name__, "float"]
    - [complex, complex.__mro__.__getitem__, [0], __name__, "complex"]
    - [bool,    bool.__mro__.__getitem__,    [0], __name__, "bool"]

# ---------------------------------------------------------------------------
# MRO[1].__name__ for int, float, and complex
#
# int, float, and complex each have MRO length 2 (builtins_extra8/extra9).
# Their MRO[1] is always 'object'. No prior spec covers these via
# __mro__.__getitem__ + __name__ for numeric types.
# bool.__mro__[1].__name__ == 'int' is already covered in builtins_extra12.
# ---------------------------------------------------------------------------

table builtins_extra20.numeric_mro_base:
  description: "__mro__[1].__name__ == 'object' for int/float/complex (direct object children)"
  kind: python_call_eq
  category: mro
  id_prefix: mro1

  columns: [id, function, args, method, expected]
  rows:
    - [int,     int.__mro__.__getitem__,     [1], __name__, "object"]
    - [float,   float.__mro__.__getitem__,   [1], __name__, "object"]
    - [complex, complex.__mro__.__getitem__, [1], __name__, "object"]
