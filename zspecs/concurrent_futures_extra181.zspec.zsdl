invariant concurrent_futures_extra181.first_completed_eq:
  description: "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED' — string constant for wait() return_when; len=15; new to concurrent_futures_extra181"
  category: identity
  kind: python_call_eq
  function: FIRST_COMPLETED.__eq__
  args: ["FIRST_COMPLETED"]
  expected: true

invariant concurrent_futures_extra181.first_exception_eq:
  description: "concurrent.futures.FIRST_EXCEPTION == 'FIRST_EXCEPTION' — string constant signaling wait() returns on first exception; len=15; new to concurrent_futures_extra181"
  category: identity
  kind: python_call_eq
  function: FIRST_EXCEPTION.__eq__
  args: ["FIRST_EXCEPTION"]
  expected: true

invariant concurrent_futures_extra181.all_completed_eq:
  description: "concurrent.futures.ALL_COMPLETED == 'ALL_COMPLETED' — string constant signaling wait() returns when all complete; len=13; new to concurrent_futures_extra181"
  category: identity
  kind: python_call_eq
  function: ALL_COMPLETED.__eq__
  args: ["ALL_COMPLETED"]
  expected: true

invariant concurrent_futures_extra181.first_completed_len_15:
  description: "concurrent.futures.FIRST_COMPLETED.__len__() == 15 — 'FIRST_COMPLETED' has 15 chars; new to concurrent_futures_extra181"
  category: identity
  kind: python_call_eq
  function: FIRST_COMPLETED.__len__
  args: []
  expected: 15

invariant concurrent_futures_extra181.first_exception_len_15:
  description: "concurrent.futures.FIRST_EXCEPTION.__len__() == 15 — 'FIRST_EXCEPTION' has 15 chars; same length as FIRST_COMPLETED; new to concurrent_futures_extra181"
  category: identity
  kind: python_call_eq
  function: FIRST_EXCEPTION.__len__
  args: []
  expected: 15

invariant concurrent_futures_extra181.all_completed_len_13:
  description: "concurrent.futures.ALL_COMPLETED.__len__() == 13 — 'ALL_COMPLETED' has 13 chars; shortest of the three wait constants; new to concurrent_futures_extra181"
  category: identity
  kind: python_call_eq
  function: ALL_COMPLETED.__len__
  args: []
  expected: 13

invariant concurrent_futures_extra181.future_module_eq:
  description: "concurrent.futures.Future.__module__ == 'concurrent.futures._base' — Future class is defined in the internal _base submodule; len=24; new to concurrent_futures_extra181"
  category: identity
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra181.executor_module_eq:
  description: "concurrent.futures.Executor.__module__ == 'concurrent.futures._base' — Executor abstract base class is defined in the internal _base submodule; len=24; new to concurrent_futures_extra181"
  category: identity
  kind: python_call_eq
  function: Executor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

