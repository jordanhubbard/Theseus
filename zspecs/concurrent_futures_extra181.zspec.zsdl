spec: concurrent_futures_extra181
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers concurrent.futures state string constants (FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED) and class module identity (Future, Executor). FIRST_COMPLETED='FIRST_COMPLETED'(len=15); FIRST_EXCEPTION='FIRST_EXCEPTION'(len=15); ALL_COMPLETED='ALL_COMPLETED'(len=13). Both Future and Executor have __module__=='concurrent.futures._base'(len=24)."
    - "concurrent.futures.FIRST_COMPLETED has len=15, not 14. The string 'FIRST_COMPLETED' counts as: F-I-R-S-T-_-C-O-M-P-L-E-T-E-D = 15 characters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.FIRST_EXCEPTION has len=15: F-I-R-S-T-_-E-X-C-E-P-T-I-O-N = 15 characters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ALL_COMPLETED has len=13: A-L-L-_-C-O-M-P-L-E-T-E-D = 13 characters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.__module__ == 'concurrent.futures._base' (len=24). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures string constants — value equality
#
# concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED') == True
# concurrent.futures.FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION') == True
# concurrent.futures.ALL_COMPLETED.__eq__('ALL_COMPLETED') == True
#
# These are plain string constants used as return_when values in wait().
# ---------------------------------------------------------------------------

table concurrent_futures_extra181.constants_eq:
  description: "concurrent.futures string constants equality: FIRST_COMPLETED=='FIRST_COMPLETED', FIRST_EXCEPTION=='FIRST_EXCEPTION', ALL_COMPLETED=='ALL_COMPLETED'; new to concurrent_futures_extra181"
  kind: python_call_eq
  category: identity
  id_prefix: cfconstants181

  columns: [id, function, args, expected, description]
  rows:
    - [fc_eq,
       FIRST_COMPLETED.__eq__,
       ["FIRST_COMPLETED"],
       true,
       "concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED') == True — FIRST_COMPLETED is the string constant used to indicate the wait() should return when any future completes; str.__eq__('FIRST_COMPLETED') returns True; new to concurrent_futures_extra181"]
    - [fe_eq,
       FIRST_EXCEPTION.__eq__,
       ["FIRST_EXCEPTION"],
       true,
       "concurrent.futures.FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION') == True — FIRST_EXCEPTION is the string constant used to indicate wait() should return when any future raises an exception; str.__eq__('FIRST_EXCEPTION') returns True; new to concurrent_futures_extra181"]
    - [ac_eq,
       ALL_COMPLETED.__eq__,
       ["ALL_COMPLETED"],
       true,
       "concurrent.futures.ALL_COMPLETED.__eq__('ALL_COMPLETED') == True — ALL_COMPLETED is the string constant used to indicate wait() should return when all futures complete; str.__eq__('ALL_COMPLETED') returns True; new to concurrent_futures_extra181"]
    - [fc_len_15,
       FIRST_COMPLETED.__len__,
       [],
       15,
       "concurrent.futures.FIRST_COMPLETED.__len__() == 15 — 'FIRST_COMPLETED' has 15 characters: F-I-R-S-T-_-C-O-M-P-L-E-T-E-D; NAME LENGTHS: ALL_COMPLETED=13 < FIRST_COMPLETED=15 == FIRST_EXCEPTION=15; str.__len__() returns 15; new to concurrent_futures_extra181"]
    - [fe_len_15,
       FIRST_EXCEPTION.__len__,
       [],
       15,
       "concurrent.futures.FIRST_EXCEPTION.__len__() == 15 — 'FIRST_EXCEPTION' has 15 characters: F-I-R-S-T-_-E-X-C-E-P-T-I-O-N; same length as FIRST_COMPLETED; str.__len__() returns 15; new to concurrent_futures_extra181"]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures string constants — length equality via __eq__
#
# FIRST_COMPLETED.__len__().__eq__(15) == True
# FIRST_EXCEPTION.__len__().__eq__(15) == True
# ALL_COMPLETED.__len__().__eq__(13) == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra181.constants_len_eq:
  description: "concurrent.futures string constants length checks: FIRST_COMPLETED len==15, FIRST_EXCEPTION len==15, ALL_COMPLETED len==13; new to concurrent_futures_extra181"
  kind: python_call_eq
  category: identity
  id_prefix: cfconstants181

  columns: [id, function, args, expected, description]
  rows:
    - [fc_len_eq_15,
       FIRST_COMPLETED.__len__,
       [],
       15,
       "concurrent.futures.FIRST_COMPLETED.__len__() == 15 — verifying length of FIRST_COMPLETED string constant; 'FIRST_COMPLETED' has 15 chars; str.__len__() returns 15; new to concurrent_futures_extra181"]
    - [fe_len_eq_15,
       FIRST_EXCEPTION.__len__,
       [],
       15,
       "concurrent.futures.FIRST_EXCEPTION.__len__() == 15 — verifying length of FIRST_EXCEPTION string constant; 'FIRST_EXCEPTION' has 15 chars; str.__len__() returns 15; new to concurrent_futures_extra181"]
    - [ac_len_eq_13,
       ALL_COMPLETED.__len__,
       [],
       13,
       "concurrent.futures.ALL_COMPLETED.__len__() == 13 — verifying length of ALL_COMPLETED string constant; 'ALL_COMPLETED' has 13 chars; NAME LENGTHS: ALL_COMPLETED=13 < FIRST_COMPLETED=15 == FIRST_EXCEPTION=15; str.__len__() returns 13; new to concurrent_futures_extra181"]
    - [ac_len_15,
       ALL_COMPLETED.__len__,
       [],
       13,
       "concurrent.futures.ALL_COMPLETED.__len__() == 13 — ALL_COMPLETED is the shortest of the three wait constants at 13 chars; str.__len__() returns 13; new to concurrent_futures_extra181"]
    - [fc_ne_ac,
       FIRST_COMPLETED.__len__,
       [],
       15,
       "concurrent.futures.FIRST_COMPLETED.__len__() == 15 — FIRST_COMPLETED (15) is longer than ALL_COMPLETED (13); length comparison anchor; str.__len__() returns 15; new to concurrent_futures_extra181"]

# ---------------------------------------------------------------------------
# Table 3: concurrent.futures.Future and Executor class module identity
#
# concurrent.futures.Future.__module__ == 'concurrent.futures._base' (len=24)
# concurrent.futures.Executor.__module__ == 'concurrent.futures._base' (len=24)
# ---------------------------------------------------------------------------

table concurrent_futures_extra181.class_module_identity:
  description: "concurrent.futures.Future and Executor __module__=='concurrent.futures._base'(len=24); new to concurrent_futures_extra181"
  kind: python_call_eq
  category: identity
  id_prefix: cfconstants181

  columns: [id, function, args, expected, description]
  rows:
    - [fut_module_eq,
       Future.__module__.__eq__,
       ["concurrent.futures._base"],
       true,
       "concurrent.futures.Future.__module__.__eq__('concurrent.futures._base') == True — Future is defined in concurrent.futures._base (len=24); str.__eq__('concurrent.futures._base') returns True; new to concurrent_futures_extra181"]
    - [exe_module_eq,
       Executor.__module__.__eq__,
       ["concurrent.futures._base"],
       true,
       "concurrent.futures.Executor.__module__.__eq__('concurrent.futures._base') == True — Executor is defined in concurrent.futures._base (len=24); str.__eq__('concurrent.futures._base') returns True; new to concurrent_futures_extra181"]
    - [fut_module_len_24,
       Future.__module__.__len__,
       [],
       24,
       "concurrent.futures.Future.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 characters; str.__len__() returns 24; new to concurrent_futures_extra181"]
    - [exe_module_len_24,
       Executor.__module__.__len__,
       [],
       24,
       "concurrent.futures.Executor.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 characters; same module as Future; str.__len__() returns 24; new to concurrent_futures_extra181"]
    - [fut_name_eq,
       Future.__name__.__eq__,
       ["Future"],
       true,
       "concurrent.futures.Future.__name__.__eq__('Future') == True — Future represents an asynchronous computation result; __name__ is 'Future'; str.__eq__('Future') returns True; new to concurrent_futures_extra181"]

