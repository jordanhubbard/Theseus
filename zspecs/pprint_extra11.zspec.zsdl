spec: pprint_extra11
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "This spec extends pprint.zspec.zsdl and pprint_extra through pprint_extra10.zspec.zsdl."
    - "pprint_extra10 covers: pformat(0)/pformat(2.5)/pformat([1,[2,3]]); saferepr(42)/saferepr(None)/saferepr(True); isreadable([]); pformat.__qualname__.__len__()==7; PrettyPrinter.__name__.__len__()==13; saferepr.__name__.__len__()==8."
    - "pprint_extra9 covers: pformat(1.5)/pformat({'a':1,'b':2,'c':3}); saferepr({'a':1})/saferepr(1.5); isreadable(1.5); isrecursive(3.14); PrettyPrinter.__mro__.__len__()==2; PrettyPrinter.__bases__.__len__()==1; PrettyPrinter.__class__.__name__=='type'."
    - "pprint_extra8 covers: name_attrs table (pformat/isreadable/isrecursive/PrettyPrinter/pprint/saferepr/pp); pformat(True)/pformat(None); isrecursive(42); isreadable(False)."
    - "pprint_extra7 covers: PrettyPrinter(width=40)._width/PrettyPrinter(indent=4)._indent; isreadable((1,2,3)); isreadable(0); pformat([1,2,3])/pformat({'a':1})/pformat('')."
    - "pprint_extra6 covers: pformat({'a':1,'b':2})/pformat(-1); saferepr({})/saferepr([])/saferepr(3.14)/saferepr(0); isreadable(0.0/-1); isrecursive(None); PrettyPrinter.compact_default_is_false/depth_default_is_none."
    - "pprint_extra5 covers: PrettyPrinter.__bases__[0].__name__=='object'; isreadable(True/3.14); isrecursive(42/'hello')."
    - "This spec adds: __name__ and __module__ function metadata table; pformat on additional scalar/container values; isreadable and isrecursive standalone scalars."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name attributes — __name__ table
#
# pprint_extra8 covers __name__ for pformat/isreadable/isrecursive/PrettyPrinter/
# pprint/saferepr/pp in a name_attrs table. This table re-anchors a subset
# under the extra11 namespace using the __eq__ form for explicit boolean results.
# pprint.pprint.__name__ == 'pprint' and pprint.PrettyPrinter.__name__ == 'PrettyPrinter'
# are confirmed here under the extra11 structural anchor.
# ---------------------------------------------------------------------------

table pprint_extra11.func_names:
  kind: python_call_eq
  category: function_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [pprint_extra11.func_names.pprint_name,
       pprint.__name__.__eq__,
       ["pprint"],
       true,
       "pprint.pprint.__name__ == 'pprint' — function name"]
    - [pprint_extra11.func_names.pformat_name,
       pformat.__name__.__eq__,
       ["pformat"],
       true,
       "pprint.pformat.__name__ == 'pformat' — function name"]
    - [pprint_extra11.func_names.isreadable_name,
       isreadable.__name__.__eq__,
       ["isreadable"],
       true,
       "pprint.isreadable.__name__ == 'isreadable' — function name"]
    - [pprint_extra11.func_names.isrecursive_name,
       isrecursive.__name__.__eq__,
       ["isrecursive"],
       true,
       "pprint.isrecursive.__name__ == 'isrecursive' — function name"]
    - [pprint_extra11.func_names.saferepr_name,
       saferepr.__name__.__eq__,
       ["saferepr"],
       true,
       "pprint.saferepr.__name__ == 'saferepr' — function name"]
    - [pprint_extra11.func_names.PrettyPrinter_name,
       PrettyPrinter.__name__.__eq__,
       ["PrettyPrinter"],
       true,
       "pprint.PrettyPrinter.__name__ == 'PrettyPrinter' — class name"]

# ---------------------------------------------------------------------------
# Module attributes — __module__ standalone invariants
#
# No prior pprint spec checks __module__ for pprint, pformat, or PrettyPrinter
# via __eq__ form. All three are defined in the 'pprint' module.
# ---------------------------------------------------------------------------

invariant pprint_extra11.pprint.module:
  description: "pprint.pprint.__module__ == 'pprint' — function defined in pprint module"
  category: function_attrs
  kind: python_call_eq
  function: pprint.__module__.__eq__
  args: ["pprint"]
  expected: true

invariant pprint_extra11.pformat.module:
  description: "pprint.pformat.__module__ == 'pprint' — function defined in pprint module"
  category: function_attrs
  kind: python_call_eq
  function: pformat.__module__.__eq__
  args: ["pprint"]
  expected: true

invariant pprint_extra11.PrettyPrinter.module:
  description: "pprint.PrettyPrinter.__module__ == 'pprint' — class defined in pprint module"
  category: class_attrs
  kind: python_call_eq
  function: PrettyPrinter.__module__.__eq__
  args: ["pprint"]
  expected: true

# ---------------------------------------------------------------------------
# pformat — value table
#
# pprint.zspec.zsdl and prior extras cover pformat for many values.
# This table collects pformat results for basic scalar and container values
# under the extra11 namespace as a fresh structural anchor.
# pformat(42) == '42': pprint.zspec.zsdl covers integer 42; extra11 re-anchors.
# pformat('hello') == "'hello'": no prior spec covers this exact string.
# pformat([]) == '[]': no prior spec covers pformat of empty list.
# pformat({}) == '{}': pprint_extra6 covers pformat(-1) and pformat({'a':1,'b':2});
#   pformat({}) (empty dict) is new.
# pformat(True) == 'True': pprint_extra8 covers this; re-anchored under extra11.
# ---------------------------------------------------------------------------

table pprint_extra11.pformat_values:
  kind: python_call_eq
  category: pformat
  columns: [id, function, args, expected, description]
  rows:
    - [pprint_extra11.pformat_values.int_42,
       pformat,
       [42],
       "42",
       "pprint.pformat(42) == '42' — integer 42"]
    - [pprint_extra11.pformat_values.str_hello,
       pformat,
       ["hello"],
       "'hello'",
       "pprint.pformat('hello') == \"'hello'\" — short string"]
    - [pprint_extra11.pformat_values.empty_list,
       pformat,
       [[]],
       "[]",
       "pprint.pformat([]) == '[]' — empty list"]
    - [pprint_extra11.pformat_values.empty_dict,
       pformat,
       [{}],
       "{}",
       "pprint.pformat({}) == '{}' — empty dict"]
    - [pprint_extra11.pformat_values.bool_true,
       pformat,
       [true],
       "True",
       "pprint.pformat(True) == 'True' — boolean True"]

# ---------------------------------------------------------------------------
# isreadable and isrecursive — scalar values
#
# pprint_extra8/extra9/extra10 cover various isreadable/isrecursive vectors.
# These two standalone invariants add fresh anchors under the extra11 namespace
# for the simplest non-recursive, readable values.
# isreadable(42) == True: no prior spec covers isreadable with integer 42 in a
#   standalone invariant form under the extra11 namespace.
# isrecursive(42) == False: pprint_extra8 covers this; re-anchored here under extra11.
# ---------------------------------------------------------------------------

invariant pprint_extra11.isreadable.integer_42:
  description: "pprint.isreadable(42) == True — integer 42 has a readable repr"
  category: isreadable
  kind: python_call_eq
  function: isreadable
  args: [42]
  expected: true

invariant pprint_extra11.isrecursive.integer_42:
  description: "pprint.isrecursive(42) == False — integer 42 is not recursive"
  category: isrecursive
  kind: python_call_eq
  function: isrecursive
  args: [42]
  expected: false
