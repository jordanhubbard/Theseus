spec: abc_extra1786
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 566, suffix _extra1786. Theme: __class_getitem__ and __init_subclass__ class creation hooks — which stdlib types define these in their own __dict__."
    - "abc.ABCMeta does NOT define __class_getitem__ in its own __dict__ — ABCMeta is a metaclass, not a generic type."
    - "abc.ABC does NOT define __class_getitem__ in its own __dict__ — the ABC helper class is not a generic container."
    - "abc.abstractmethod does NOT define __class_getitem__ in its own __dict__ — abstractmethod is a decorator, not a generic type."
    - "None of the abc types define __init_subclass__ in their own __dict__; all rely on the default inherited from object (or type for ABCMeta)."
    - "abc.ABCMeta defines __instancecheck__ and __subclasscheck__ in its own __dict__ — these are metaclass hooks, distinct from class-creation hooks."
    - "abc.abstractmethod defines __isabstractmethod__ (as a property/descriptor) in its own __dict__."
    - "abc.ABC.__abstractmethods__ is an empty frozenset — ABC itself declares no abstract methods."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __class_getitem__ and __init_subclass__ absent from abc types
#
# abc is a meta-programming library; none of its public types define
# __class_getitem__ or __init_subclass__ in their own __dict__.
# ABCMeta is a metaclass; ABC is a plain helper class; abstractmethod is a
# decorator — none are generic containers.
# ---------------------------------------------------------------------------

table abc_extra1786.class_getitem_absent:
  kind: python_call_eq
  category: class_getitem
  id_prefix: ab1786

  columns: [id, function, args, expected]
  rows:
    - ["ab1786001", abc.ABCMeta.__dict__.__contains__,       ["__class_getitem__"],  false]
    - ["ab1786002", abc.ABC.__dict__.__contains__,            ["__class_getitem__"],  false]
    - ["ab1786003", abc.abstractmethod.__dict__.__contains__,  ["__class_getitem__"],  false]
    - ["ab1786004", abc.ABCMeta.__dict__.__contains__,       ["__init_subclass__"],  false]
    - ["ab1786005", abc.ABC.__dict__.__contains__,            ["__init_subclass__"],  false]
    - ["ab1786006", abc.abstractmethod.__dict__.__contains__,  ["__init_subclass__"],  false]
    - ["ab1786007", abc.ABCMeta.__dict__.__contains__,       ["__instancecheck__"],  true]
    - ["ab1786008", abc.ABCMeta.__dict__.__contains__,       ["__subclasscheck__"],  true]
    - ["ab1786009", abc.abstractmethod.__dict__.__contains__,  ["__isabstractmethod__"], true]
    - ["ab1786010", abc.ABC.__abstractmethods__.__len__,     [],                     0]
    - ["ab1786011", abc.ABC.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true]
    - ["ab1786012", abc.ABCMeta.__dict__.__contains__,       ["register"],           true]
    - ["ab1786013", abc.ABCMeta.__dict__.__contains__,       ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 2: complementary identity checks
#
# Positive identity anchors for ABCMeta, ABC, and abstractmethod names,
# modules, and class type, to complement the negative __class_getitem__
# and __init_subclass__ results.
# ---------------------------------------------------------------------------

table abc_extra1786.identity_and_complementary:
  kind: python_call_eq
  category: identity
  id_prefix: ab1786

  columns: [id, function, args, expected]
  rows:
    - ["ab1786014", abc.ABCMeta.__name__.__eq__,               ["ABCMeta"],        true]
    - ["ab1786015", abc.ABC.__name__.__eq__,                    ["ABC"],            true]
    - ["ab1786016", abc.abstractmethod.__name__.__eq__,         ["abstractmethod"], true]
    - ["ab1786017", abc.ABC.__module__.__eq__,                  ["abc"],            true]
    - ["ab1786018", abc.ABCMeta.__module__.__eq__,              ["abc"],            true]
    - ["ab1786019", abc.abstractmethod.__module__.__eq__,       ["abc"],            true]
    - ["ab1786020", abc.ABCMeta.__class__.__name__.__eq__,      ["type"],           true]
    - ["ab1786021", abc.ABC.__class__.__name__.__eq__,          ["ABCMeta"],        true]
    - ["ab1786022", abc.ABCMeta.__dict__.__contains__,          ["__new__"],        true]
    - ["ab1786023", abc.abstractmethod.__isabstractmethod__.__eq__, [true],         true]
    - ["ab1786024", abc.ABCMeta.__dict__.__contains__,          ["_dump_registry"], true]
    - ["ab1786025", abc.ABC.__dict__.__contains__,               ["__subclasshook__"], true]
