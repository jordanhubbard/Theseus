spec: threading_extra73
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra72.zspec.zsdl."
    - "Wave 238 theme: threading Barrier/Timer class identity and Thread.__init__ __annotations__."
    - "Barrier.__name__ == 'Barrier' — Barrier is a pure-Python class in Lib/threading.py. Verified with Python 3.14.3."
    - "Barrier.__module__ == 'threading' — Barrier is defined in the threading module. Verified with Python 3.14.3."
    - "Barrier.__qualname__ == 'Barrier' — Barrier is a top-level class (not nested). Verified with Python 3.14.3."
    - "Barrier.__bases__[0].__name__ == 'object' — Barrier inherits directly from object; MRO is [Barrier, object]. Verified with Python 3.14.3."
    - "Barrier.__mro__.__len__() == 2 — Barrier MRO has exactly 2 entries (Barrier and object). Verified with Python 3.14.3."
    - "Timer.__name__ == 'Timer' — Timer is a pure-Python class in Lib/threading.py. Verified with Python 3.14.3."
    - "Timer.__module__ == 'threading' — Timer is defined in the threading module. Verified with Python 3.14.3."
    - "Timer.__bases__[0].__name__ == 'Thread' — Timer inherits from Thread; MRO is [Timer, Thread, object]. Verified with Python 3.14.3."
    - "Timer.__mro__.__len__() == 3 — Timer MRO has exactly 3 entries (Timer, Thread, object). Verified with Python 3.14.3."
    - "Thread.__init__.__annotations__.__class__.__name__ == 'dict' — Thread.__init__ is a pure-Python method with an empty __annotations__ dict. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Barrier class identity — extra73
#
# Wave 238 theme: Barrier class identity attributes.
#
# threading.Barrier is a pure-Python class defined in Lib/threading.py.
# It inherits directly from object (no intermediate base classes).
#
# Barrier.__name__              == 'Barrier'
# Barrier.__module__            == 'threading'
# Barrier.__qualname__          == 'Barrier'
# Barrier.__bases__[0].__name__ == 'object'
# Barrier.__mro__.__len__()     == 2
#
# No prior threading spec checks Barrier identity via thrdann73. New to extra73.
# ---------------------------------------------------------------------------

table threading_extra73.Barrier_identity:
  description: "Barrier.__name__=='Barrier', __module__=='threading', __qualname__=='Barrier'; wave 238 Barrier class identity; new to extra73"
  kind: python_call_eq
  category: type_identity
  id_prefix: thrdann73

  columns: [id, function, args, expected, description]
  rows:
    - [Barrier_name_eq_Barrier,
       Barrier.__name__.__eq__,
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — Barrier is a pure-Python class in Lib/threading.py that implements a synchronization primitive; __name__ stores the class name as a str 'Barrier' (7 chars); str.__eq__('Barrier') returns True; no prior threading spec checks Barrier.__name__ via thrdann73; new to extra73"]
    - [Barrier_module_eq_threading,
       Barrier.__module__.__eq__,
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — Barrier is defined in Lib/threading.py and its __module__ attribute records the module name as the str 'threading' (9 chars); str.__eq__('threading') returns True; no prior threading spec checks Barrier.__module__ via thrdann73; new to extra73"]
    - [Barrier_qualname_eq_Barrier,
       Barrier.__qualname__.__eq__,
       ["Barrier"],
       true,
       "threading.Barrier.__qualname__.__eq__('Barrier') == True — Barrier is a top-level class in Lib/threading.py (not nested inside another class or function); __qualname__ for a top-level class equals its simple name 'Barrier' (7 chars); str.__eq__('Barrier') returns True; no prior threading spec checks Barrier.__qualname__ via thrdann73; new to extra73"]

# ---------------------------------------------------------------------------
# Barrier base class and MRO — extra73
#
# Wave 238 theme: Barrier inherits from object; MRO length is 2.
#
# Barrier.__bases__[0].__name__ == 'object'
# Barrier.__mro__.__len__()     == 2
#
# No prior threading spec checks Barrier.__bases__ or __mro__ via thrdann73. New to extra73.
# ---------------------------------------------------------------------------

table threading_extra73.Barrier_mro:
  description: "Barrier.__bases__[0].__name__=='object', Barrier.__mro__.__len__()==2; wave 238 Barrier MRO; new to extra73"
  kind: python_call_eq
  category: type_identity
  id_prefix: thrdann73

  columns: [id, function, args, expected, description]
  rows:
    - [Barrier_bases0_name_eq_object,
       "Barrier.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Barrier.__bases__[0].__name__.__eq__('object') == True — Barrier is defined as 'class Barrier:' which in Python 3 implicitly inherits from object; __bases__ is a tuple of direct base classes and __bases__[0] is object; object.__name__ == 'object' (6 chars); str.__eq__('object') returns True; no prior threading spec checks Barrier.__bases__[0].__name__ via thrdann73; new to extra73"]
    - [Barrier_mro_len_eq_2,
       Barrier.__mro__.__len__,
       [],
       2,
       "threading.Barrier.__mro__.__len__() == 2 — Barrier inherits directly from object with no intermediate base classes; the MRO is therefore [Barrier, object] with exactly 2 entries; tuple.__len__() returns 2; no prior threading spec checks Barrier.__mro__.__len__ via thrdann73; new to extra73"]

# ---------------------------------------------------------------------------
# Timer class identity — extra73
#
# Wave 238 theme: Timer class identity and MRO.
#
# threading.Timer is defined in Lib/threading.py as:
#   class Timer(Thread):
#
# Timer.__name__              == 'Timer'
# Timer.__module__            == 'threading'
# Timer.__bases__[0].__name__ == 'Thread'
# Timer.__mro__.__len__()     == 3
#
# No prior threading spec checks Timer identity via thrdann73. New to extra73.
# ---------------------------------------------------------------------------

table threading_extra73.Timer_identity:
  description: "Timer.__name__=='Timer', __module__=='threading', __bases__[0].__name__=='Thread', __mro__.__len__()==3; wave 238 Timer class identity; new to extra73"
  kind: python_call_eq
  category: type_identity
  id_prefix: thrdann73

  columns: [id, function, args, expected, description]
  rows:
    - [Timer_name_eq_Timer,
       Timer.__name__.__eq__,
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — Timer is a pure-Python class in Lib/threading.py that represents a thread that runs a function after a specified interval; __name__ stores the class name as a str 'Timer' (5 chars); str.__eq__('Timer') returns True; no prior threading spec checks Timer.__name__ via thrdann73; new to extra73"]
    - [Timer_module_eq_threading,
       Timer.__module__.__eq__,
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — Timer is defined in Lib/threading.py and its __module__ attribute records the module name as the str 'threading' (9 chars); str.__eq__('threading') returns True; no prior threading spec checks Timer.__module__ via thrdann73; new to extra73"]
    - [Timer_bases0_name_eq_Thread,
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer is defined as 'class Timer(Thread):' so it inherits directly from Thread; __bases__[0] is Thread and Thread.__name__ == 'Thread' (6 chars); str.__eq__('Thread') returns True; no prior threading spec checks Timer.__bases__[0].__name__ via thrdann73; new to extra73"]
    - [Timer_mro_len_eq_3,
       Timer.__mro__.__len__,
       [],
       3,
       "threading.Timer.__mro__.__len__() == 3 — Timer inherits from Thread which inherits from object; the MRO is therefore [Timer, Thread, object] with exactly 3 entries; tuple.__len__() returns 3; no prior threading spec checks Timer.__mro__.__len__ via thrdann73; new to extra73"]

# ---------------------------------------------------------------------------
# Thread.__init__ __annotations__ — extra73
#
# Wave 238 theme: Thread.__init__ __annotations__ is an empty dict.
#
# threading.Thread.__init__ is a pure-Python method in Lib/threading.py.
# Its __annotations__ attribute is a dict with no entries.
#
# Thread.__init__.__annotations__.__class__.__name__ == 'dict'
# Thread.__init__.__annotations__.__len__()          == 0
#
# No prior threading spec checks Thread.__init__.__annotations__ via thrdann73. New to extra73.
# ---------------------------------------------------------------------------

table threading_extra73.Thread_init_annotations:
  description: "Thread.__init__.__annotations__.__class__.__name__=='dict', __len__()==0; wave 238 Thread.__init__ __annotations__; new to extra73"
  kind: python_call_eq
  category: annotations
  id_prefix: thrdann73

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_init_ann_class_name_eq_dict,
       Thread.__init__.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "threading.Thread.__init__.__annotations__.__class__.__name__.__eq__('dict') == True — Thread.__init__ is a pure-Python method in Lib/threading.py that initializes a new Thread; it carries an __annotations__ dict that is empty (no type annotations in the CPython implementation); __class__.__name__ for a dict is 'dict' (4 chars); str.__eq__('dict') returns True; no prior threading spec checks Thread.__init__.__annotations__.__class__.__name__ via thrdann73; new to extra73"]
    - [Thread_init_ann_len_eq_0,
       Thread.__init__.__annotations__.__len__,
       [],
       0,
       "threading.Thread.__init__.__annotations__.__len__() == 0 — Thread.__init__ is defined in Lib/threading.py with no type annotations on any parameter or on the return value; the __annotations__ dict is therefore empty and its len is 0; no prior threading spec checks Thread.__init__.__annotations__.__len__ via thrdann73; new to extra73"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra73
# ---------------------------------------------------------------------------

invariant threading_extra73.Barrier_name:
  description: "threading.Barrier.__name__.__eq__('Barrier') == True — Barrier class name is 'Barrier'; wave 238 Barrier class identity; new to extra73"
  kind: python_call_eq
  function: Barrier.__name__.__eq__
  args: ["Barrier"]
  expected: true

invariant threading_extra73.Barrier_mro_len:
  description: "threading.Barrier.__mro__.__len__() == 2 — Barrier MRO is [Barrier, object] with 2 entries; wave 238 Barrier MRO; new to extra73"
  kind: python_call_eq
  function: Barrier.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra73.Timer_name:
  description: "threading.Timer.__name__.__eq__('Timer') == True — Timer class name is 'Timer'; wave 238 Timer class identity; new to extra73"
  kind: python_call_eq
  function: Timer.__name__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra73.Timer_mro_len:
  description: "threading.Timer.__mro__.__len__() == 3 — Timer MRO is [Timer, Thread, object] with 3 entries; wave 238 Timer MRO; new to extra73"
  kind: python_call_eq
  function: Timer.__mro__.__len__
  args: []
  expected: 3

invariant threading_extra73.Thread_init_ann_len_zero:
  description: "threading.Thread.__init__.__annotations__.__len__() == 0 — no annotations in Thread.__init__ definition; wave 238 Thread.__init__ __annotations__; new to extra73"
  kind: python_call_eq
  function: Thread.__init__.__annotations__.__len__
  args: []
  expected: 0
