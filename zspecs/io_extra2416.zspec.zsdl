spec: io_extra2416
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/io.html"
    - "CPython source — Modules/_io/_iomodule.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 608 (_extra2416): __iter__ and __next__ dict-presence and type classification."
    - "io.BytesIO is the only io class that defines both __iter__ and __next__ in its own __dict__."
    - "io.StringIO, io.BufferedReader, io.BufferedRandom, and io.TextIOWrapper define only __next__ in their __dict__."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, and io.FileIO define neither __iter__ nor __next__ in their class __dict__."
    - "Iteration for IOBase-hierarchy classes flows from the C-level _io._IOBase; the Python io.IOBase wrapper does not redeclare them."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
# Table 1: __iter__ in class __dict__ — all seven core io classes
# ===

table io_extra2416.iter_in_dict:
  description: "__iter__ dict-presence across IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, FileIO"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2416
  columns: [id, function, args, expected]
  rows:
    - ["io2416001", "io.IOBase.__dict__.__contains__", ["__iter__"], false]
    - ["io2416002", "io.RawIOBase.__dict__.__contains__", ["__iter__"], false]
    - ["io2416003", "io.BufferedIOBase.__dict__.__contains__", ["__iter__"], false]
    - ["io2416004", "io.TextIOBase.__dict__.__contains__", ["__iter__"], false]
    - ["io2416005", "io.BytesIO.__dict__.__contains__", ["__iter__"], true]
    - ["io2416006", "io.StringIO.__dict__.__contains__", ["__iter__"], false]
    - ["io2416007", "io.FileIO.__dict__.__contains__", ["__iter__"], false]

# ===
# Table 2: __next__ in class __dict__ — all seven core io classes plus concrete subclasses
# ===

table io_extra2416.next_in_dict:
  description: "__next__ dict-presence across IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, FileIO, BufferedReader, BufferedRandom, TextIOWrapper"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2416
  columns: [id, function, args, expected]
  rows:
    - ["io2416008", "io.IOBase.__dict__.__contains__", ["__next__"], false]
    - ["io2416009", "io.RawIOBase.__dict__.__contains__", ["__next__"], false]
    - ["io2416010", "io.BufferedIOBase.__dict__.__contains__", ["__next__"], false]
    - ["io2416011", "io.TextIOBase.__dict__.__contains__", ["__next__"], false]
    - ["io2416012", "io.BytesIO.__dict__.__contains__", ["__next__"], true]
    - ["io2416013", "io.StringIO.__dict__.__contains__", ["__next__"], true]
    - ["io2416014", "io.FileIO.__dict__.__contains__", ["__next__"], false]
    - ["io2416015", "io.BufferedReader.__dict__.__contains__", ["__next__"], true]
    - ["io2416016", "io.BufferedRandom.__dict__.__contains__", ["__next__"], true]
    - ["io2416017", "io.TextIOWrapper.__dict__.__contains__", ["__next__"], true]

# ===
# Table 3: __iter__ descriptor type — BytesIO (only class with __iter__ in __dict__)
# ===

table io_extra2416.iter_descriptor_class:
  description: "io.BytesIO.__iter__ is a wrapper_descriptor (C-slot exposed at Python level)"
  kind: python_call_eq
  category: type_identity
  id_prefix: io2416
  columns: [id, function, args, expected]
  rows:
    - ["io2416018", "io.BytesIO.__iter__.__class__.__name__", [], "wrapper_descriptor"]

# ===
# Table 4: __next__ descriptor type — classes that define __next__ directly
# ===

table io_extra2416.next_descriptor_class:
  description: "__next__ is exposed as a wrapper_descriptor for all concrete io C-extension classes that define it"
  kind: python_call_eq
  category: type_identity
  id_prefix: io2416
  columns: [id, function, args, expected]
  rows:
    - ["io2416019", "io.BytesIO.__next__.__class__.__name__", [], "wrapper_descriptor"]
    - ["io2416020", "io.StringIO.__next__.__class__.__name__", [], "wrapper_descriptor"]
    - ["io2416021", "io.BufferedReader.__next__.__class__.__name__", [], "wrapper_descriptor"]
    - ["io2416022", "io.BufferedRandom.__next__.__class__.__name__", [], "wrapper_descriptor"]
    - ["io2416023", "io.TextIOWrapper.__next__.__class__.__name__", [], "wrapper_descriptor"]
