spec: pathlib_extra143
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path method __qualname__ values and __code__.co_argcount for __fspath__, __truediv__, __rtruediv__, __str__, __repr__, __eq__, __hash__, __lt__, __le__, __init__, __new__."
    - "All dunder methods except __new__ are defined on PurePath and inherited by Path, so their __qualname__ values carry the 'PurePath.' prefix."
    - "Path.__new__.__qualname__ == 'Path.__new__' (length 12) — __new__ is defined directly on Path."
    - "Path.__fspath__.__qualname__ == 'PurePath.__fspath__' (length 19) — defined on PurePath."
    - "Path.__truediv__.__qualname__ == 'PurePath.__truediv__' (length 20) — the / operator, defined on PurePath."
    - "Path.__rtruediv__.__qualname__ == 'PurePath.__rtruediv__' (length 21) — the reflected / operator, defined on PurePath."
    - "Path.__str__.__qualname__ == 'PurePath.__str__' (length 16) — defined on PurePath."
    - "Path.__repr__.__qualname__ == 'PurePath.__repr__' (length 17) — defined on PurePath."
    - "Path.__eq__.__qualname__ == 'PurePath.__eq__' (length 15) — equality defined on PurePath."
    - "Path.__hash__.__qualname__ == 'PurePath.__hash__' (length 17) — defined on PurePath."
    - "Path.__lt__.__qualname__ == 'PurePath.__lt__' (length 15) — defined on PurePath."
    - "Path.__le__.__qualname__ == 'PurePath.__le__' (length 15) — defined on PurePath."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path dunder method __qualname__ values — string equality
# All methods except __new__ are defined on PurePath and inherited by Path.
# __fspath__: 'PurePath.__fspath__' (19)
# __truediv__: 'PurePath.__truediv__' (20)
# __rtruediv__: 'PurePath.__rtruediv__' (21)
# __str__: 'PurePath.__str__' (16)
# __repr__: 'PurePath.__repr__' (17)
# __eq__: 'PurePath.__eq__' (15)
# __hash__: 'PurePath.__hash__' (17)
# __lt__: 'PurePath.__lt__' (15)
# __le__: 'PurePath.__le__' (15)
# __init__: 'PurePath.__init__' (17)
# __new__: 'Path.__new__' (12)
# ---------------------------------------------------------------------------

table pathlib_extra143.Path_dunder_qualnames:
  description: "pathlib.Path dunder method __qualname__ string values: all inherited from PurePath except __new__ which is defined on Path itself"
  kind: python_call_eq
  category: method_qualname
  id_prefix: pathlibdq143

  columns: [id, function, args, expected]
  rows:
    - [fspath_qn_eq,    "Path.__fspath__.__qualname__.__eq__",    ["PurePath.__fspath__"],    true]
    - [truediv_qn_eq,   "Path.__truediv__.__qualname__.__eq__",   ["PurePath.__truediv__"],   true]
    - [rtruediv_qn_eq,  "Path.__rtruediv__.__qualname__.__eq__",  ["PurePath.__rtruediv__"],  true]
    - [str_qn_eq,       "Path.__str__.__qualname__.__eq__",       ["PurePath.__str__"],       true]
    - [repr_qn_eq,      "Path.__repr__.__qualname__.__eq__",      ["PurePath.__repr__"],      true]
    - [eq_qn_eq,        "Path.__eq__.__qualname__.__eq__",        ["PurePath.__eq__"],        true]
    - [hash_qn_eq,      "Path.__hash__.__qualname__.__eq__",      ["PurePath.__hash__"],      true]
    - [lt_qn_eq,        "Path.__lt__.__qualname__.__eq__",        ["PurePath.__lt__"],        true]
    - [le_qn_eq,        "Path.__le__.__qualname__.__eq__",        ["PurePath.__le__"],        true]
    - [init_qn_eq,      "Path.__init__.__qualname__.__eq__",      ["PurePath.__init__"],      true]
    - [new_qn_eq,       "Path.__new__.__qualname__.__eq__",       ["Path.__new__"],           true]

# ---------------------------------------------------------------------------
# pathlib.Path dunder method __qualname__ lengths
# __fspath__: 19, __truediv__: 20, __rtruediv__: 21, __str__: 16,
# __repr__: 17, __eq__: 15, __hash__: 17, __lt__: 15, __le__: 15,
# __init__: 17, __new__: 12.
# ---------------------------------------------------------------------------

table pathlib_extra143.Path_dunder_qualname_lengths:
  description: "pathlib.Path dunder method __qualname__ lengths: __fspath__=19, __truediv__=20, __rtruediv__=21, __str__=16, __repr__=17, __eq__=15, __hash__=17, __lt__=15, __le__=15, __init__=17, __new__=12"
  kind: python_call_eq
  category: method_qualname
  id_prefix: pathlibdq143

  columns: [id, function, args, expected]
  rows:
    - [fspath_qn_len,   "Path.__fspath__.__qualname__.__len__",   [], 19]
    - [truediv_qn_len,  "Path.__truediv__.__qualname__.__len__",  [], 20]
    - [rtruediv_qn_len, "Path.__rtruediv__.__qualname__.__len__", [], 21]
    - [str_qn_len,      "Path.__str__.__qualname__.__len__",      [], 16]
    - [repr_qn_len,     "Path.__repr__.__qualname__.__len__",     [], 17]
    - [eq_qn_len,       "Path.__eq__.__qualname__.__len__",       [], 15]
    - [hash_qn_len,     "Path.__hash__.__qualname__.__len__",     [], 17]
    - [lt_qn_len,       "Path.__lt__.__qualname__.__len__",       [], 15]
    - [le_qn_len,       "Path.__le__.__qualname__.__len__",       [], 15]
    - [init_qn_len,     "Path.__init__.__qualname__.__len__",     [], 17]
    - [new_qn_len,      "Path.__new__.__qualname__.__len__",      [], 12]

# ---------------------------------------------------------------------------
# pathlib.Path dunder method __code__.co_argcount
# Unary operations (self only): __fspath__, __str__, __repr__, __hash__, __init__, __new__ == 1
# Binary operations (self + other): __truediv__, __rtruediv__, __eq__, __lt__, __le__ == 2
# ---------------------------------------------------------------------------

table pathlib_extra143.Path_dunder_co_argcount:
  description: "pathlib.Path dunder method __code__.co_argcount: unary methods have 1 arg (self), binary methods have 2 args (self, other)"
  kind: python_call_eq
  category: method_signature
  id_prefix: pathlibdq143

  columns: [id, function, args, expected]
  rows:
    - [fspath_argc,   "Path.__fspath__.__code__.co_argcount.__eq__",   [1], true]
    - [str_argc,      "Path.__str__.__code__.co_argcount.__eq__",      [1], true]
    - [repr_argc,     "Path.__repr__.__code__.co_argcount.__eq__",     [1], true]
    - [hash_argc,     "Path.__hash__.__code__.co_argcount.__eq__",     [1], true]
    - [init_argc,     "Path.__init__.__code__.co_argcount.__eq__",     [1], true]
    - [new_argc,      "Path.__new__.__code__.co_argcount.__eq__",      [1], true]
    - [truediv_argc,  "Path.__truediv__.__code__.co_argcount.__eq__",  [2], true]
    - [rtruediv_argc, "Path.__rtruediv__.__code__.co_argcount.__eq__", [2], true]
    - [eq_argc,       "Path.__eq__.__code__.co_argcount.__eq__",       [2], true]
    - [lt_argc,       "Path.__lt__.__code__.co_argcount.__eq__",       [2], true]
    - [le_argc,       "Path.__le__.__code__.co_argcount.__eq__",       [2], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra143.Path.__fspath__.qualname_is_PurePath:
  description: "pathlib.Path.__fspath__.__qualname__ == 'PurePath.__fspath__' (length 19; __fspath__ is defined on PurePath and inherited by Path, so its qualname carries the PurePath prefix)"
  category: method_qualname
  kind: python_call_eq
  function: "Path.__fspath__.__qualname__.__eq__"
  args: ["PurePath.__fspath__"]
  expected: true

invariant pathlib_extra143.Path.__truediv__.qualname_len_20:
  description: "pathlib.Path.__truediv__.__qualname__.__len__() == 20 ('PurePath.__truediv__' has 20 characters; the / path-joining operator is defined on PurePath)"
  category: method_qualname
  kind: python_call_eq
  function: "Path.__truediv__.__qualname__.__len__"
  args: []
  expected: 20

invariant pathlib_extra143.Path.__new__.qualname_is_Path:
  description: "pathlib.Path.__new__.__qualname__ == 'Path.__new__' (length 12; unlike the other dunders, __new__ is defined directly on Path, not on PurePath)"
  category: method_qualname
  kind: python_call_eq
  function: "Path.__new__.__qualname__.__eq__"
  args: ["Path.__new__"]
  expected: true

invariant pathlib_extra143.Path.__rtruediv__.qualname_len_21:
  description: "pathlib.Path.__rtruediv__.__qualname__.__len__() == 21 ('PurePath.__rtruediv__' has 21 characters; the reflected / operator allowing str / Path constructions)"
  category: method_qualname
  kind: python_call_eq
  function: "Path.__rtruediv__.__qualname__.__len__"
  args: []
  expected: 21

invariant pathlib_extra143.Path.__truediv__.co_argcount_2:
  description: "pathlib.Path.__truediv__.__code__.co_argcount == 2 (self + other; the / operator takes a second operand)"
  category: method_signature
  kind: python_call_eq
  function: "Path.__truediv__.__code__.co_argcount.__eq__"
  args: [2]
  expected: true
