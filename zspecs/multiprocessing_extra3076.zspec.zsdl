spec: mp3076
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 652 (mp3076): __get__, __set__, __delete__ dict-presence for multiprocessing types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: multiprocessing.Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.BaseListProxy, managers._BaseDictProxy, managers._BaseSetProxy."
    - "All eight classes return false for __get__, __set__, and __delete__ in their own __dict__."
    - "multiprocessing is a process-based concurrency library; none of its classes serve as descriptors for attribute mediation."
    - "pool.Pool defines __enter__/__exit__ (wave 650) for synchronous context management but implements no descriptor protocol."
    - "managers proxy classes (BaseListProxy, _BaseDictProxy, _BaseSetProxy) forward operations to managed server-side objects; they do not implement descriptor protocol hooks."
    - "pool.AsyncResult and pool.MapResult are result-holder types for non-blocking pool operations; descriptor protocol is not relevant to either."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
#
# No multiprocessing class defines __get__ in its own __dict__; all false.
# multiprocessing classes are process management, pool, and IPC abstractions;
# none act as descriptors mediating attribute lookup on other objects.
# ---------------------------------------------------------------------------

table mp3076.get:
  description: "multiprocessing types __get__ dict-presence checks; wave 652"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3076

  columns: [id, function, args, expected]
  rows:
    - ["mp3076001", operator.contains, [multiprocessing.Process.__dict__,                 "__get__"], false]
    - ["mp3076002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__get__"], false]
    - ["mp3076003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__get__"], false]
    - ["mp3076004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__get__"], false]
    - ["mp3076005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__get__"], false]
    - ["mp3076006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__get__"], false]
    - ["mp3076007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__get__"], false]
    - ["mp3076008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__get__"], false]

# ---------------------------------------------------------------------------
# __set__ dict-presence — operator.contains(Cls.__dict__, '__set__')
#
# No multiprocessing class defines __set__ in its own __dict__; all false.
# __set__ is the data-descriptor attribute-write hook; it is not applicable to
# any multiprocessing process-management, pool, or manager-proxy class.
# ---------------------------------------------------------------------------

