# ---------------------------------------------------------------------------
# __delete__ dict-presence — operator.contains(Cls.__dict__, '__delete__')
#
# No multiprocessing class defines __delete__ in its own __dict__; all false.
# __delete__ is the data-descriptor attribute-deletion hook; none of these
# multiprocessing classes define or need it.
# ---------------------------------------------------------------------------

