spec: theseus_heapq_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_heapq_cr2)
blocks: heapq

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html"
  notes:
    - "Clean-room extended heapq utilities. Do NOT import heapq."
    - "heapreplace(heap, item): pop and return smallest, then push new item."
    - "nlargest(n, iterable): return n largest elements in descending order."
    - "nsmallest(n, iterable): return n smallest elements in ascending order."
    - "heapq2_heapreplace(): h=[1,3,5]; heapreplace(h, 2); h[0] == 1 — True since 1 stays root."
    - "heapq2_nlargest(): nlargest(2, [3,1,4,1,5]) == [5, 4]."
    - "heapq2_nsmallest(): nsmallest(2, [3,1,4,1,5]) == [1, 1]."
    - "Zero-arg invariant signatures — def heapq2_heapreplace(): return hardcoded_result"
    - "heapreplace: pop min item (1), push 2, heap now has {2,3,5} so h[0]==2 after re-heap."
    - "Actually: after heapreplace([1,3,5], 2): heap becomes [2,3,5], h[0]==2. Return True."
    - "Export: heappush, heappop, heapreplace, heapify, nlargest, nsmallest."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_heapq_cr2.heapreplace:
  description: "heapreplace([1,3,5], 2) -> heap root is still min (2)"
  category: heapreplace
  kind: python_call_eq
  function: heapq2_heapreplace
  args: []
  expected: true

invariant theseus_heapq_cr2.nlargest:
  description: "nlargest(2, [3,1,4,1,5]) == [5, 4]"
  category: nlargest
  kind: python_call_eq
  function: heapq2_nlargest
  args: []
  expected: [5, 4]

invariant theseus_heapq_cr2.nsmallest:
  description: "nsmallest(2, [3,1,4,1,5]) == [1, 1]"
  category: nsmallest
  kind: python_call_eq
  function: heapq2_nsmallest
  args: []
  expected: [1, 1]
