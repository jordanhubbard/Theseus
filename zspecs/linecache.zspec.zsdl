spec: linecache
version: ">=3.2"
backend: python_module(linecache)

docs: https://docs.python.org/3/library/linecache.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/linecache.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/linecache.py (internal implementation)"
  notes:
    - "linecache.getline(filename, lineno) returns the line as a string (including newline), or '' if not found."
    - "linecache.getlines(filename) returns a list of all lines in the file, or [] if the file cannot be read."
    - "Line numbers are 1-based; lineno=0 is invalid and returns ''."
    - "For non-existent files, getline returns '' and getlines returns []."
    - "linecache.clearcache() clears the module-level cache and returns None."
    - "linecache.checkcache() validates existing cache entries and returns None."
    - "linecache.updatecache(filename) re-reads a file into the cache."
    - "linecache.lazycache(filename, module_globals) supports lazy loading from module __loader__."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name metadata
# ---------------------------------------------------------------------------

table linecache.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [getline,    getline.__name__.__eq__,    ["getline"],    true]
    - [getlines,   getlines.__name__.__eq__,   ["getlines"],   true]
    - [clearcache, clearcache.__name__.__eq__,  ["clearcache"], true]
    - [checkcache, checkcache.__name__.__eq__,  ["checkcache"], true]
    - [updatecache, updatecache.__name__.__eq__, ["updatecache"], true]
    - [lazycache,  lazycache.__name__.__eq__,   ["lazycache"],  true]

invariant linecache.getline_module:
  description: "linecache.getline.__module__ == 'linecache'"
  category: functions
  kind: python_call_eq
  function: getline.__module__.__eq__
  args: ["linecache"]
  expected: true

# ---------------------------------------------------------------------------
# getline — non-existent file returns empty string
# ---------------------------------------------------------------------------

invariant linecache.getline_nonexistent_line1:
  description: "getline('/nonexistent_path/file.py', 1) returns '' for missing file"
  category: missing_file
  kind: python_call_eq
  function: getline
  args: ["/nonexistent_path_xyz/file.py", 1]
  expected: ""

invariant linecache.getline_nonexistent_line2:
  description: "getline('/nonexistent_path/file.py', 2) returns '' for missing file"
  category: missing_file
  kind: python_call_eq
  function: getline
  args: ["/nonexistent_path_xyz/file.py", 2]
  expected: ""

invariant linecache.getline_invalid_lineno:
  description: "getline('/nonexistent_path/file.py', 0) returns '' — line 0 is invalid"
  category: edge_cases
  kind: python_call_eq
  function: getline
  args: ["/nonexistent_path_xyz/file.py", 0]
  expected: ""

invariant linecache.getline_negative_lineno:
  description: "getline('/nonexistent_path/file.py', -1) returns '' — negative line invalid"
  category: edge_cases
  kind: python_call_eq
  function: getline
  args: ["/nonexistent_path_xyz/file.py", -1]
  expected: ""

# ---------------------------------------------------------------------------
# getlines — non-existent file returns empty list
# ---------------------------------------------------------------------------

invariant linecache.getlines_nonexistent:
  description: "getlines('/nonexistent_path/file.py') returns [] for missing file"
  category: missing_file
  kind: python_call_eq
  function: getlines
  args: ["/nonexistent_path_xyz/file.py"]
  expected: []

# ---------------------------------------------------------------------------
# clearcache — returns None
# ---------------------------------------------------------------------------

invariant linecache.clearcache_returns_none:
  description: "clearcache() returns None"
  category: cache_ops
  kind: python_call_eq
  function: clearcache
  args: []
  expected: null

# ---------------------------------------------------------------------------
# checkcache — returns None
# ---------------------------------------------------------------------------

invariant linecache.checkcache_returns_none:
  description: "checkcache() called with no args returns None"
  category: cache_ops
  kind: python_call_eq
  function: checkcache
  args: []
  expected: null
