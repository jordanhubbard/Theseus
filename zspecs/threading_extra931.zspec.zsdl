spec: threading_extra931
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __doc__.__class__.__name__ for core threading classes to confirm docstring type is str"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra931.thread_and_lock_doc:
  description: "threading.Thread, Lock, and RLock __doc__ class name"
  kind: python_call_eq
  category: doc_class_name
  id_prefix: th931a
  columns: [id, function, args, expected]
  rows:
    - [th931x001, threading.Thread.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th931x002, threading.Lock.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [th931x003, threading.RLock.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [th931x004, threading.Event.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [th931x005, threading.Condition.__doc__.__class__.__name__.__eq__, ["str"], true]

table threading_extra931.semaphore_and_barrier_doc:
  description: "threading.Semaphore, BoundedSemaphore, and Barrier __doc__ class name"
  kind: python_call_eq
  category: doc_class_name
  id_prefix: th931b
  columns: [id, function, args, expected]
  rows:
    - [th931x006, threading.Semaphore.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [th931x007, threading.BoundedSemaphore.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th931x008, threading.Barrier.__doc__.__class__.__name__.__eq__,          ["str"], true]
    - [th931x009, threading.Timer.__doc__.__class__.__name__.__eq__,            ["str"], true]

table threading_extra931.module_identity:
  description: "threading module __name__, __package__, and doc class identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: th931c
  columns: [id, function, args, expected]
  rows:
    - [th931x010, threading.__name__.__eq__,                    ["threading"], true]
    - [th931x011, threading.__package__.__eq__,                 [""],          true]
    - [th931x012, threading.__doc__.__class__.__name__.__eq__,  ["str"],       true]
    - [th931x013, threading.__name__.__class__.__name__.__eq__, ["str"],       true]

table threading_extra931.local_and_exceptional_doc:
  description: "threading.local, current_thread, active_count, main_thread __doc__ class name"
  kind: python_call_eq
  category: doc_class_name
  id_prefix: th931d
  columns: [id, function, args, expected]
  rows:
    - [th931x014, threading.local.__doc__.__class__.__name__.__eq__,          ["str"], true]
    - [th931x015, threading.current_thread.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th931x016, threading.active_count.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [th931x017, threading.main_thread.__doc__.__class__.__name__.__eq__,    ["str"], true]
