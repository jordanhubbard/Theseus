spec: on_headers
version: ">=1.0.0"
backend: node(on-headers)

docs: https://github.com/jshttp/on-headers#readme

provenance:
  derived_from:
    - "on-headers README — https://github.com/jshttp/on-headers#readme"
    - "Test vectors verified with on-headers via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "on-headers source"
  notes:
    - "Register a callback to run just before HTTP response headers are sent — used to defer Content-Type / Set-Cookie patches."
    - "Install: npm install on-headers"
    - "v1 CJS; module export IS the helper (res, listener)."
    - "Spec covers shape only — registering against a real ServerResponse is integration territory."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws TypeError if listener is not a function or res is not a ServerResponse."
  stderr: "null"
  stickiness: "Patches res.writeHead to invoke the listener once."
  codes: {}

invariant on_headers.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant on_headers.module_name:
  description: "Function name is 'onHeaders'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: name}
  expected: "onHeaders"

invariant on_headers.module_arity:
  description: "Module function takes 2 args (res, listener)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 2
