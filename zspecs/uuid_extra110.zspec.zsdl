spec: uuid_extra110
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra109.zspec.zsdl — covers UUID.__init__/__str__/__repr__/__hash__/__eq__ dunder __name__ equality, __name__ lengths, and __module__ equality (table + invariants)."
    - "uuid_extra107.zspec.zsdl — covers UUID.time/node/bytes_le/fields/cshv fget __name__ equality / cshv fget name len / time/node/cshv/fields fget __module__ equality (table + invariants)."
    - "uuid_extra100.zspec.zsdl — covers UUID property and member_descriptor types including UUID.int.__class__.__name__=='member_descriptor' (table + invariants)."
    - "uuid_extra92.zspec.zsdl — covers UUID.hex/urn/bytes/clock_seq fget co_argcount==1 and co_name lengths (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra109; it does NOT duplicate invariants present in those files."
    - "Wave 278 theme: UUID property fget __name__ lengths and variant/version/fields fget co_argcount equality not yet covered — extra92 anchors hex/urn/bytes/clock_seq fget co_argcount; extra107 anchors time/node fget name eq; NOT YET covered: variant/version/fields fget co_argcount eq; bytes/hex fget __name__.__len__; bytes/hex fget __module__.__eq__; UUID.int.__class__.__name__ length."
    - "uuid.UUID.variant.fget.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__name__.__len__() == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__name__.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__name__.__len__() == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__name__.__len__() == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__name__.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__module__.__eq__('uuid') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__module__.__eq__('uuid') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.int.__class__.__name__.__len__() == 17 ('member_descriptor'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: UUID property fget functions are Python-level functions defined in Lib/uuid.py. All take 1 argument (self). Their bare __name__ is the property name without the 'UUID.' class prefix. UUID.int is a member_descriptor (declared in __slots__), not a property — it does not have fget. UUID.variant/version are @property objects whose fget.co_argcount is 1. UUID.fields returns a 6-tuple of UUID integer fields. UUID.bytes returns the raw 16-byte representation. UUID.hex returns the 32-character hexadecimal string without hyphens."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.variant.fget.__code__.co_argcount == 1
# uuid.UUID.version.fget.__code__.co_argcount == 1
# uuid.UUID.fields.fget.__code__.co_argcount == 1
# uuid.UUID.bytes.fget.__code__.co_argcount == 1
# uuid.UUID.hex.fget.__code__.co_argcount == 1
#
# Wave 278 theme: UUID property fget co_argcount for variant/version/fields.
#
# uuid_extra92 anchors hex/urn/bytes/clock_seq fget co_argcount==1 as a grouped
# table. No prior spec anchors variant/version/fields fget co_argcount in a grouped
# table. All UUID property fget functions take exactly 1 argument (self), since they
# are unary property getters. variant returns a SafeUUID.UNKNOWN, RFC_4122, etc.
# value; version returns 1, 3, 4, or 5; fields returns a 6-tuple of UUID components.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra110.UUID_property_fget_co_argcount:
  description: "UUID.variant.fget.__code__.co_argcount==1 / UUID.version.fget.__code__.co_argcount==1 / UUID.fields.fget.__code__.co_argcount==1 / UUID.bytes.fget.__code__.co_argcount==1 / UUID.hex.fget.__code__.co_argcount==1 — all UUID property fget functions take 1 arg (self only; unary property getter pattern); extra92 anchors hex/urn/bytes/clock_seq; no prior spec anchors variant/version/fields co_argcount as grouped table; first uuidfget110 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidfget110

  columns: [id, function, args, expected, description]
  rows:
    - [variant_fget_argc,  "UUID.variant.fget.__code__.co_argcount",  [], 1, "UUID.variant.fget takes 1 arg (self only; returns RFC variant: RFC_4122, RESERVED_NCS, etc.)"]
    - [version_fget_argc,  "UUID.version.fget.__code__.co_argcount",  [], 1, "UUID.version.fget takes 1 arg (self only; returns UUID version 1/3/4/5 or raises ValueError)"]
    - [fields_fget_argc,   "UUID.fields.fget.__code__.co_argcount",   [], 1, "UUID.fields.fget takes 1 arg (self only; returns 6-tuple of UUID integer components)"]
    - [bytes_fget_argc2,   "UUID.bytes.fget.__code__.co_argcount",    [], 1, "UUID.bytes.fget takes 1 arg (self only; returns 16-byte big-endian representation; cross-check with extra92)"]
    - [hex_fget_argc2,     "UUID.hex.fget.__code__.co_argcount",      [], 1, "UUID.hex.fget takes 1 arg (self only; returns 32-char hex without hyphens; cross-check with extra92)"]

# ---------------------------------------------------------------------------
# uuid.UUID.bytes.fget.__name__.__len__() == 5
# uuid.UUID.hex.fget.__name__.__len__() == 3
# uuid.UUID.variant.fget.__name__.__len__() == 7
# uuid.UUID.version.fget.__name__.__len__() == 7
# uuid.UUID.fields.fget.__name__.__len__() == 6
#
# Wave 278 theme: UUID property fget bare __name__ lengths.
#
# extra107 anchors node/cshv fget name lengths but NOT bytes/hex/variant/version/fields.
# The fget bare __name__ is the property name itself (no 'UUID.' prefix). 'hex' is
# the shortest at 3 chars; 'bytes' is 5; 'fields' is 6; 'variant' and 'version' are
# both 7 chars (tied). This set of lengths covers a wide range (3 to 7) not yet in
# a single grouped table. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra110.UUID_property_fget_name_lengths:
  description: "UUID.bytes.fget.__name__.__len__()==5 / UUID.hex.fget.__name__.__len__()==3 / UUID.variant.fget.__name__.__len__()==7 / UUID.version.fget.__name__.__len__()==7 / UUID.fields.fget.__name__.__len__()==6 — fget bare __name__ lengths span 3-to-7 chars; 'hex'=3 (shortest); 'bytes'=5; 'fields'=6; 'variant'/'version'=7 (tied longest in this set); extra107 anchors node/cshv lengths; no prior spec anchors these 5 lengths as grouped table; first uuidfget110 anchor for name lengths"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidfget110

  columns: [id, function, args, expected, description]
  rows:
    - [bytes_fget_name_len,   "UUID.bytes.fget.__name__.__len__",   [], 5, "UUID.bytes.fget.__name__.__len__() is 5 (len('bytes')==5; raw 16-byte big-endian UUID representation)"]
    - [hex_fget_name_len,     "UUID.hex.fget.__name__.__len__",     [], 3, "UUID.hex.fget.__name__.__len__() is 3 (len('hex')==3; shortest UUID property bare name in this set; 32-char hex without hyphens)"]
    - [variant_fget_name_len, "UUID.variant.fget.__name__.__len__", [], 7, "UUID.variant.fget.__name__.__len__() is 7 (len('variant')==7; tied with version for longest in this set)"]
    - [version_fget_name_len, "UUID.version.fget.__name__.__len__", [], 7, "UUID.version.fget.__name__.__len__() is 7 (len('version')==7; tied with variant; returns 1/3/4/5 or raises ValueError)"]
    - [fields_fget_name_len,  "UUID.fields.fget.__name__.__len__",  [], 6, "UUID.fields.fget.__name__.__len__() is 6 (len('fields')==6; returns 6-tuple of UUID integer fields)"]

# ---------------------------------------------------------------------------
# uuid.UUID.bytes.fget.__module__.__eq__('uuid') == True
# uuid.UUID.hex.fget.__module__.__eq__('uuid') == True
# uuid.UUID.variant.fget.__code__.co_argcount == 1
# uuid.UUID.version.fget.__code__.co_argcount == 1
# uuid.UUID.int.__class__.__name__.__len__() == 17
#
# Wave 278 theme: bytes/hex fget __module__ and UUID.int member_descriptor name len.
#
# extra107 anchors time/node/cshv/fields fget __module__=='uuid' but NOT bytes/hex.
# bytes and hex are among the most commonly used UUID property getters. uuid.UUID.hex
# returns the UUID as a compact 32-char hex string; uuid.UUID.bytes returns the 16-byte
# raw representation for binary protocols. Both fget functions have __module__=='uuid'
# (they are defined in Lib/uuid.py). UUID.int is a member_descriptor (slot-based),
# not a property — its class name 'member_descriptor' has 17 chars. No prior spec
# anchors bytes/hex fget __module__ or member_descriptor name length as grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra110.UUID_fget_module_and_int_class_len:
  description: "UUID.bytes.fget.__module__.__eq__('uuid')==True / UUID.hex.fget.__module__.__eq__('uuid')==True / UUID.variant.fget.__code__.co_argcount==1 (cross-check) / UUID.version.fget.__code__.co_argcount==1 (cross-check) / UUID.int.__class__.__name__.__len__()==17 — bytes/hex fget are from Lib/uuid.py (__module__=='uuid', 4 chars); UUID.int is a slot-based member_descriptor (not @property; 'member_descriptor'=17 chars); extra107 anchors time/node/cshv/fields fget module; no prior spec anchors bytes/hex module as grouped table; first uuidfget110 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidfget110

  columns: [id, function, args, expected, description]
  rows:
    - [bytes_fget_module_eq,   "UUID.bytes.fget.__module__.__eq__",          ["uuid"], true, "UUID.bytes.fget.__module__ is 'uuid' (Python function from Lib/uuid.py; 16-byte big-endian representation)"]
    - [hex_fget_module_eq,     "UUID.hex.fget.__module__.__eq__",            ["uuid"], true, "UUID.hex.fget.__module__ is 'uuid' (Python function from Lib/uuid.py; 32-char compact hex string without hyphens)"]
    - [variant_fget_argc3,     "UUID.variant.fget.__code__.co_argcount",     [],       1,    "UUID.variant.fget co_argcount is 1 (self only; cross-check for consistency across all property fgets)"]
    - [version_fget_argc3,     "UUID.version.fget.__code__.co_argcount",     [],       1,    "UUID.version.fget co_argcount is 1 (self only; same pattern as all UUID property fgets)"]
    - [int_class_name_len,     "UUID.int.__class__.__name__.__len__",        [],       17,   "UUID.int.__class__.__name__.__len__() is 17 (len('member_descriptor')==17; slot-based attribute not @property)"]

# ---------------------------------------------------------------------------
# uuid.UUID.variant.fget.__code__.co_argcount == 1 — standalone
#
# uuid.UUID.variant.fget.__code__.co_argcount is 1. UUID.variant is a @property
# defined in Lib/uuid.py that returns one of the RFC 4122 variant constants:
# RESERVED_NCS (0), RFC_4122 (1), RESERVED_MICROSOFT (2), or RESERVED_FUTURE (3).
# All UUID property getters follow the unary function pattern (self only, co_argcount==1).
# uuid_extra92 anchors hex/urn/bytes/clock_seq fget co_argcount as a grouped table;
# no prior spec anchors uuid.UUID.variant.fget.__code__.co_argcount as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra110.UUID_variant_fget_co_argcount_1:
  description: "uuid.UUID.variant.fget.__code__.co_argcount == 1 — variant is a @property (returns RFC 4122 variant constant: RESERVED_NCS/RFC_4122/RESERVED_MICROSOFT/RESERVED_FUTURE); fget takes self only (unary pattern shared by all UUID property getters); extra92 anchors hex/urn/bytes/clock_seq fget co_argcount as group; no prior spec anchors variant fget co_argcount as standalone; first standalone under uuidfget110"
  category: function_identity
  kind: python_call_eq
  function: "UUID.variant.fget.__code__.co_argcount"
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# uuid.UUID.version.fget.__code__.co_argcount == 1 — standalone
#
# uuid.UUID.version.fget.__code__.co_argcount is 1. UUID.version is a @property
# defined in Lib/uuid.py that returns the UUID version number (1, 3, 4, or 5)
# for RFC 4122 UUIDs, or raises ValueError for UUIDs with variant != RFC_4122.
# UUID version 4 (random) is the most widely used; version 1 is time-based;
# versions 3 and 5 are name-based (MD5 and SHA-1 respectively). All UUID property
# getters follow the unary pattern (co_argcount==1). No prior spec anchors
# uuid.UUID.version.fget.__code__.co_argcount as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant uuid_extra110.UUID_version_fget_co_argcount_1:
  description: "uuid.UUID.version.fget.__code__.co_argcount == 1 — version @property returns UUID version number (1=time-based, 3=MD5 name-based, 4=random, 5=SHA-1 name-based); raises ValueError for non-RFC_4122 UUIDs; fget takes self only; no prior spec anchors version fget co_argcount as standalone; first standalone under uuidfget110"
  category: function_identity
  kind: python_call_eq
  function: "UUID.version.fget.__code__.co_argcount"
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__name__.__len__() == 3 — standalone
#
# uuid.UUID.hex.fget.__name__.__len__() is 3. 'hex' is the shortest bare property
# name among commonly used UUID properties — just 3 chars. UUID.hex returns the
# UUID as a 32-character hexadecimal string without hyphens (e.g.,
# '550e8400e29b41d4a716446655440000'). This is useful when the standard
# hyphenated form (36 chars) is not needed. extra107 anchors the node fget name
# length (4 chars) and cshv fget name length (20 chars); no prior spec anchors
# UUID.hex.fget.__name__.__len__() as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant uuid_extra110.UUID_hex_fget_name_len_3:
  description: "uuid.UUID.hex.fget.__name__.__len__() == 3 — len('hex')==3 (shortest UUID property name in common use; UUID.hex returns 32-char hex without hyphens, e.g. '550e8400e29b41d4a716446655440000'); extra107 anchors node=4 and cshv=20; no prior spec anchors hex fget name length as standalone; first standalone under uuidfget110"
  category: function_identity
  kind: python_call_eq
  function: "UUID.hex.fget.__name__.__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# uuid.UUID.bytes.fget.__module__.__eq__('uuid') — standalone
#
# uuid.UUID.bytes.fget.__module__ is 'uuid'. UUID.bytes returns the 16-byte
# binary representation of the UUID in big-endian byte order. This is used
# in binary protocols (e.g., database storage, network transmission) where
# a compact 16-byte form is preferred over the 36-character hyphenated string.
# uuid_extra107 anchors time/node/cshv/fields fget __module__=='uuid'; no prior
# spec anchors UUID.bytes.fget.__module__ as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant uuid_extra110.UUID_bytes_fget_module_uuid:
  description: "uuid.UUID.bytes.fget.__module__.__eq__('uuid') == True — bytes @property fget is from Lib/uuid.py (module 'uuid', 4 chars); returns 16-byte big-endian UUID binary (compact form for binary protocols and database storage); extra107 anchors time/node/cshv/fields fget module; no prior spec anchors bytes fget module as standalone; first standalone under uuidfget110"
  category: function_identity
  kind: python_call_eq
  function: "UUID.bytes.fget.__module__.__eq__"
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.int.__class__.__name__.__len__() == 17 — standalone
#
# uuid.UUID.int.__class__.__name__.__len__() is 17. 'member_descriptor' has 17
# chars. UUID.int is not a @property but a slot-based member_descriptor (declared
# in __slots__ = ('int', 'is_safe', '__weakref__')). Its class is the C-level
# member_descriptor type (Objects/descrobject.c). The name 'member_descriptor'
# (17 chars) is the same length as 'getset_descriptor' (also 17 chars, anchored
# for uuid.__weakref__ in earlier specs) — a coincidence in naming length.
# uuid_extra100 anchors UUID.int.__class__.__name__=='member_descriptor'; no prior
# spec anchors the length 17 for UUID.int.__class__.__name__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra110.UUID_int_class_name_len_17:
  description: "uuid.UUID.int.__class__.__name__.__len__() == 17 — len('member_descriptor')==17 (UUID.int is a slot-based member_descriptor, not @property; 'member_descriptor' and 'getset_descriptor' both happen to be 17 chars; extra100 anchors UUID.int class name equality; no prior spec anchors UUID.int class name length as standalone; first standalone under uuidfget110)"
  category: type_identity
  kind: python_call_eq
  function: "UUID.int.__class__.__name__.__len__"
  args: []
  expected: 17

