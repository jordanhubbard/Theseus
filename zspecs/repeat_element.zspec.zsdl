spec: repeat_element
version: ">=1.1.4"
backend: node(repeat-element)

docs: https://www.npmjs.com/package/repeat-element

provenance:
  derived_from:
    - "repeat-element README — https://www.npmjs.com/package/repeat-element"
    - "Test vectors verified with repeat-element via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "repeat-element source"
  notes:
    - "repeat-element is an npm package. Install: npm install repeat-element"
    - "Creates an array with an element repeated n times."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table repeat_element.repeat:
  kind: node_module_call_eq
  function: ~
  category: arrays
  id_prefix: repel

  columns: [id, args, expected]
  rows:
    - [string_3, ["x", 3],  ["x", "x", "x"]]
    - [int_4,    [1, 4],    [1, 1, 1, 1]]
    - [zero,     ["a", 0],  []]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:21:02Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
