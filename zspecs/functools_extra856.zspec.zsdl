    - [ft856cn005, "functools.cached_property.__class__.__name__.__eq__", ["type"], true]
    - [ft856cn006, "functools.lru_cache.__class__.__name__.__eq__", ["function"], true]
    - [ft856cn007, "functools.cache.__class__.__name__.__eq__", ["function"], true]
    - [ft856cn008, "functools.wraps.__class__.__name__.__eq__", ["function"], true]
    - [ft856cn009, "functools.update_wrapper.__class__.__name__.__eq__", ["function"], true]
    - [ft856cn010, "functools.total_ordering.__class__.__name__.__eq__", ["function"], true]
    - [ft856cn011, "functools.cmp_to_key.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
