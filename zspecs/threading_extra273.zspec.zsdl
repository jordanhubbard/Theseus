spec: threading_extra273
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.__name__ == 'threading'; threading.__package__ == '' (empty string, not None)."
    - "threading.__spec__.name == 'threading'; __spec__.__class__.__name__ == 'ModuleSpec'."
    - "threading.__loader__.__class__.__name__ == 'SourceFileLoader' — threading is a source-based module."
    - "threading.__spec__.origin.__class__.__name__ == 'str' — origin is the file path string."
    - "threading.__all__ is a list with 28 entries; Thread, Lock, RLock, Condition, Semaphore, BoundedSemaphore all present."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading module __spec__ and metadata
#
# threading.__name__ == 'threading'; __package__ == '' (empty string).
# __spec__.name == 'threading'; __spec__.__class__.__name__ == 'ModuleSpec'.
# __loader__.__class__.__name__ == 'SourceFileLoader'.
# __spec__.origin.__class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

table threading_extra273.module_spec_identity:
  description: "threading module __spec__ metadata — name='threading', package='', spec class='ModuleSpec', loader class='SourceFileLoader', origin is str; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex273sp

  columns: [id, function, args, expected, description]
  rows:
    - [tn_name_eq,               __name__.__eq__,                             ["threading"],                  true, "threading.__name__ == 'threading'; verified with Python 3.14.3"]
    - [tn_pkg_eq,                __package__.__eq__,                          [""],                           true, "threading.__package__ == '' (empty string, not None); verified with Python 3.14.3"]
    - [tn_pkg_len,               __package__.__len__,                         [],                             0,    "threading.__package__.__len__() == 0 — empty string; verified with Python 3.14.3"]
    - [sp_name_eq,               __spec__.name.__eq__,                        ["threading"],                  true, "threading.__spec__.name == 'threading'; verified with Python 3.14.3"]
    - [sp_cls_eq,                __spec__.__class__.__name__.__eq__,          ["ModuleSpec"],                 true, "threading.__spec__.__class__.__name__ == 'ModuleSpec'; verified with Python 3.14.3"]
    - [ld_cls_eq,                __loader__.__class__.__name__.__eq__,        ["SourceFileLoader"],           true, "threading.__loader__.__class__.__name__ == 'SourceFileLoader'; verified with Python 3.14.3"]
    - [or_cls_eq,                __spec__.origin.__class__.__name__.__eq__,   ["str"],                        true, "threading.__spec__.origin.__class__.__name__ == 'str' — origin is the .py file path; verified with Python 3.14.3"]
    - [al_type_eq,               __all__.__class__.__name__.__eq__,           ["list"],                       true, "threading.__all__.__class__.__name__ == 'list'; verified with Python 3.14.3"]
    - [al_len_eq,                __all__.__len__,                             [],                             28,   "threading.__all__.__len__() == 28; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# threading.__all__ membership checks — key synchronization primitives
#
# Thread, Lock, RLock, Condition, Semaphore, BoundedSemaphore all in __all__.
# Also Barrier, Event, Timer are in __all__.
# ---------------------------------------------------------------------------

table threading_extra273.all_membership:
  description: "threading.__all__ membership — Thread, Lock, RLock, Condition, Semaphore, BoundedSemaphore, Barrier, Event, Timer all in __all__ (28 entries total); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex273am

  columns: [id, function, args, expected, description]
  rows:
    - [al_thread_eq,             __all__.__contains__,                        ["Thread"],                     true, "threading.__all__ contains 'Thread'; verified with Python 3.14.3"]
    - [al_lock_eq,               __all__.__contains__,                        ["Lock"],                       true, "threading.__all__ contains 'Lock'; verified with Python 3.14.3"]
    - [al_rlock_eq,              __all__.__contains__,                        ["RLock"],                      true, "threading.__all__ contains 'RLock'; verified with Python 3.14.3"]
    - [al_cond_eq,               __all__.__contains__,                        ["Condition"],                  true, "threading.__all__ contains 'Condition'; verified with Python 3.14.3"]
    - [al_sema_eq,               __all__.__contains__,                        ["Semaphore"],                  true, "threading.__all__ contains 'Semaphore'; verified with Python 3.14.3"]
    - [al_bsema_eq,              __all__.__contains__,                        ["BoundedSemaphore"],           true, "threading.__all__ contains 'BoundedSemaphore'; verified with Python 3.14.3"]
    - [al_barr_eq,               __all__.__contains__,                        ["Barrier"],                    true, "threading.__all__ contains 'Barrier'; verified with Python 3.14.3"]
    - [al_event_eq,              __all__.__contains__,                        ["Event"],                      true, "threading.__all__ contains 'Event'; verified with Python 3.14.3"]
    - [al_timer_eq,              __all__.__contains__,                        ["Timer"],                      true, "threading.__all__ contains 'Timer'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra273
# ---------------------------------------------------------------------------

invariant threading_extra273.module_name_is_threading:
  description: "threading.__name__ == 'threading'"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra273.package_is_empty_string:
  description: "threading.__package__ == '' (empty string, not None) — threading is a top-level module"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant threading_extra273.spec_name_is_threading:
  description: "threading.__spec__.name == 'threading'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra273.spec_class_is_modulespec:
  description: "threading.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant threading_extra273.loader_class_is_sourcefileloader:
  description: "threading.__loader__.__class__.__name__ == 'SourceFileLoader' — threading is loaded from source"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant threading_extra273.spec_origin_is_str:
  description: "threading.__spec__.origin.__class__.__name__ == 'str' — origin is the file path as a string"
  category: identity
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant threading_extra273.all_len_is_28:
  description: "threading.__all__.__len__() == 28"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 28

invariant threading_extra273.all_contains_thread:
  description: "threading.__all__ contains 'Thread'"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Thread"]
  expected: true

invariant threading_extra273.all_contains_lock:
  description: "threading.__all__ contains 'Lock'"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Lock"]
  expected: true

invariant threading_extra273.all_contains_rlock:
  description: "threading.__all__ contains 'RLock'"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["RLock"]
  expected: true
