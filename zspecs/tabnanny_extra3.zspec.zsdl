spec: tabnanny_extra3
version: ">=3.9"
backend: python_module(tabnanny)

docs: https://docs.python.org/3/library/tabnanny.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tabnanny.html — Python tabnanny documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tabnanny.py"
  notes:
    - "This spec extends tabnanny.zspec.zsdl and prior extras."
    - "tabnanny covers: check.__name__, process_tokens.__name__, NannyNag.__name__, NannyNag.__module__, NannyNag.__bases__[0].__name__, NannyNag method names (get_lineno/get_line/get_msg), verbose/filename_only type+value."
    - "tabnanny_extra covers: check.__name__, process_tokens.__name__, NannyNag.__name__, NannyNag.__module__, NannyNag.__bases__[0].__name__, NannyNag methods (get_lineno/get_msg/get_filename), verbose/filename_only type+value, NannyNag is type."
    - "tabnanny_extra2 covers: check.__module__, check.__qualname__, process_tokens.__module__, NannyNag.__qualname__, function_names table (check/process_tokens __name__)."
    - "This spec adds: process_tokens.__qualname__, NannyNag.__bases__.__len__, NannyNag.__module__.__class__.__name__, check.__name__ type check, NannyNag method __qualname__ checks."
    - "tabnanny.process_tokens.__qualname__ == 'process_tokens' — top-level function; qualname equals name. Not in any prior tabnanny spec."
    - "len(tabnanny.NannyNag.__bases__) == 1 — NannyNag has exactly one base class (Exception)."
    - "tabnanny.NannyNag.__module__.__class__.__name__ == 'str' — the __module__ attribute is a string."
    - "tabnanny.NannyNag.get_lineno.__qualname__ == 'NannyNag.get_lineno' — method qualname includes the class scope."
    - "tabnanny.NannyNag.get_msg.__qualname__ == 'NannyNag.get_msg' — method qualname includes the class scope."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# process_tokens.__qualname__ — not covered in any prior tabnanny spec
# tabnanny_extra2 covers check.__qualname__; process_tokens.__qualname__ is new.
# ---------------------------------------------------------------------------

invariant tabnanny_extra3.qualnames.process_tokens:
  description: "tabnanny.process_tokens.__qualname__ == 'process_tokens' — top-level function qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: process_tokens.__qualname__.__eq__
  args: ["process_tokens"]
  expected: true

# ---------------------------------------------------------------------------
# NannyNag.__bases__ length — has exactly one base class
# tabnanny and tabnanny_extra cover __bases__[0].__name__; length is new.
# ---------------------------------------------------------------------------

invariant tabnanny_extra3.hierarchy.NannyNag_bases_len:
  description: "len(tabnanny.NannyNag.__bases__) == 1 — NannyNag has exactly one base class"
  category: hierarchy
  kind: python_call_eq
  function: NannyNag.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# NannyNag.__module__ type check — __module__ is a string
# Not covered in any prior tabnanny spec.
# ---------------------------------------------------------------------------

invariant tabnanny_extra3.types.NannyNag_module_is_str:
  description: "tabnanny.NannyNag.__module__.__class__.__name__ == 'str' — __module__ attribute is a string"
  category: types
  kind: python_call_eq
  function: NannyNag.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# NannyNag method __qualname__ checks
# Prior specs cover method __name__ only; __qualname__ is new here.
# NannyNag methods are defined inside the class body, so their qualnames
# include the class prefix: 'NannyNag.get_lineno', etc.
# ---------------------------------------------------------------------------

invariant tabnanny_extra3.method_qualnames.get_lineno:
  description: "tabnanny.NannyNag.get_lineno.__qualname__ == 'NannyNag.get_lineno'"
  category: method_qualnames
  kind: python_call_eq
  function: NannyNag.get_lineno.__qualname__.__eq__
  args: ["NannyNag.get_lineno"]
  expected: true

invariant tabnanny_extra3.method_qualnames.get_msg:
  description: "tabnanny.NannyNag.get_msg.__qualname__ == 'NannyNag.get_msg'"
  category: method_qualnames
  kind: python_call_eq
  function: NannyNag.get_msg.__qualname__.__eq__
  args: ["NannyNag.get_msg"]
  expected: true

# ---------------------------------------------------------------------------
# check.__name__ type check — the __name__ attribute of check is a string
# Novel type-level check; not in any prior tabnanny spec.
# ---------------------------------------------------------------------------

invariant tabnanny_extra3.types.check_name_is_str:
  description: "tabnanny.check.__name__.__class__.__name__ == 'str' — check.__name__ is a string"
  category: types
  kind: python_call_eq
  function: check.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
