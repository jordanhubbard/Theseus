spec: concurrent_futures_extra176
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
  notes:
    - "This spec covers: concurrent.futures module-level attributes — concurrent.futures.__name__=='concurrent.futures' (len=18); concurrent.futures.__package__=='concurrent.futures' (len=18; same as __name__); concurrent.futures.__spec__.__class__.__name__=='ModuleSpec'; concurrent.futures.__path__.__class__.__name__=='list' (it's a package so has __path__); concurrent.futures.__path__.__len__()==1 (one path entry)."
    - "concurrent.futures.__name__ == 'concurrent.futures' (len=18: c-o-n-c-u-r-r-e-n-t-.-f-u-t-u-r-e-s = 18 chars). concurrent.futures.__package__ == 'concurrent.futures' (len=18; identical to __name__). Both attributes hold the same 18-character dotted module name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.__spec__.__class__.__name__ == 'ModuleSpec' — the module's import spec is a ModuleSpec object from importlib.machinery. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.__path__.__class__.__name__ == 'list' — concurrent.futures is a package (has __init__.py) so it has a __path__ attribute that is a list of directory paths. __path__.__len__() == 1 because there is exactly one directory in the search path. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.__name__ and __package__ identity
#
# concurrent.futures.__name__ == 'concurrent.futures' (len=18)
# concurrent.futures.__package__ == 'concurrent.futures' (len=18; same as __name__)
#
# For a top-level package, __name__ and __package__ are identical.
# New to extra176.
# ---------------------------------------------------------------------------

table concurrent_futures_extra176.module_name_package:
  description: "concurrent.futures.__name__ 'concurrent.futures' len 18; __package__ 'concurrent.futures' len 18 (same); new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: cfmodule176

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,
       __name__.__eq__,
       ["concurrent.futures"],
       true,
       "concurrent.futures.__name__.__eq__('concurrent.futures') == True — the module's fully qualified name is 'concurrent.futures' (18 chars: c-o-n-c-u-r-r-e-n-t-.-f-u-t-u-r-e-s = 18); __name__ is the canonical module identifier; str.__eq__('concurrent.futures') returns True; new to extra176"]
    - [name_len_18,
       __name__.__len__,
       [],
       18,
       "concurrent.futures.__name__.__len__() == 18 — 'concurrent.futures' has 18 characters: concurrent=10 + '.'=1 + futures=7 = 18; str.__len__() returns 18; new to extra176"]
    - [package_eq,
       __package__.__eq__,
       ["concurrent.futures"],
       true,
       "concurrent.futures.__package__.__eq__('concurrent.futures') == True — for a package module, __package__ equals __name__ ('concurrent.futures'); __package__ identifies the package to which the module belongs; str.__eq__('concurrent.futures') returns True; new to extra176"]
    - [package_len_eq_name_len,
       __package__.__len__,
       [],
       18,
       "concurrent.futures.__package__.__len__() == 18 — 'concurrent.futures' has 18 characters (concurrent=10 + '.'=1 + futures=7 = 18); __package__ and __name__ are identical strings so they share the same length; str.__len__() returns 18; new to extra176"]
    - [name_package_same_class,
       __name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "concurrent.futures.__name__.__class__.__name__.__eq__('str') == True — __name__ is a str object; str.__class__.__name__ is 'str'; both __name__ and __package__ are str instances; new to extra176"]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures.__spec__ and __path__ class identity
#
# concurrent.futures.__spec__.__class__.__name__ == 'ModuleSpec'
# concurrent.futures.__path__.__class__.__name__ == 'list'
# concurrent.futures.__path__.__len__() == 1
#
# As a package, concurrent.futures has both __spec__ and __path__.
# New to extra176.
# ---------------------------------------------------------------------------

table concurrent_futures_extra176.spec_and_path:
  description: "concurrent.futures.__spec__.__class__.__name__=='ModuleSpec'; __path__.__class__.__name__=='list'; __path__.__len__()==1; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: cfmodule176

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name_eq,
       __spec__.__class__.__name__.__eq__,
       ["ModuleSpec"],
       true,
       "concurrent.futures.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — __spec__ is a ModuleSpec instance from importlib.machinery; it holds the module's name, loader, and origin; its class is named 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra176"]
    - [spec_class_name_len,
       __spec__.__class__.__name__.__len__,
       [],
       10,
       "concurrent.futures.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters: M-o-d-u-l-e-S-p-e-c; str.__len__() returns 10; new to extra176"]
    - [path_class_name_eq,
       __path__.__class__.__name__.__eq__,
       ["list"],
       true,
       "concurrent.futures.__path__.__class__.__name__.__eq__('list') == True — concurrent.futures is a package so it has a __path__ attribute; __path__ is a list of filesystem paths where submodules are searched; its class is 'list'; str.__eq__('list') returns True; new to extra176"]
    - [path_len_1,
       __path__.__len__,
       [],
       1,
       "concurrent.futures.__path__.__len__() == 1 — the package has exactly one directory in its search path (the single installation directory); __path__ is a one-element list; list.__len__() returns 1; new to extra176"]
    - [path_class_name_len,
       __path__.__class__.__name__.__len__,
       [],
       4,
       "concurrent.futures.__path__.__class__.__name__.__len__() == 4 — 'list' has 4 characters: l-i-s-t; the class name of __path__ is 'list'; str.__len__() returns 4; new to extra176"]

# ---------------------------------------------------------------------------
# Table 3: concurrent.futures.__spec__ name and origin identity
#
# concurrent.futures.__spec__.name == 'concurrent.futures'
# concurrent.futures.__spec__.submodule_search_locations.__class__.__name__ is a str
#
# ModuleSpec.name holds the fully qualified module name.
# New to extra176.
# ---------------------------------------------------------------------------

table concurrent_futures_extra176.spec_name_attrs:
  description: "concurrent.futures.__spec__.name 'concurrent.futures'; __spec__.__class__.__name__ 'ModuleSpec' len 10; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: cfmodule176

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,
       __spec__.name.__eq__,
       ["concurrent.futures"],
       true,
       "concurrent.futures.__spec__.name.__eq__('concurrent.futures') == True — ModuleSpec.name holds the fully qualified module name 'concurrent.futures'; this matches concurrent.futures.__name__; str.__eq__('concurrent.futures') returns True; new to extra176"]
    - [spec_name_len,
       __spec__.name.__len__,
       [],
       18,
       "concurrent.futures.__spec__.name.__len__() == 18 — ModuleSpec.name is 'concurrent.futures' with 18 characters (concurrent=10+'.'=1+futures=7=18); same length as __name__ and __package__; str.__len__() returns 18; new to extra176"]
    - [spec_name_class_eq,
       __spec__.name.__class__.__name__.__eq__,
       ["str"],
       true,
       "concurrent.futures.__spec__.name.__class__.__name__.__eq__('str') == True — ModuleSpec.name is a str; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra176"]
    - [package_is_str,
       __package__.__class__.__name__.__eq__,
       ["str"],
       true,
       "concurrent.futures.__package__.__class__.__name__.__eq__('str') == True — __package__ is a str object; its class name is 'str'; str.__eq__('str') returns True; new to extra176"]
    - [spec_class_modulespec,
       __spec__.__class__.__name__.__eq__,
       ["ModuleSpec"],
       true,
       "concurrent.futures.__spec__.__class__.__name__.__eq__('ModuleSpec') == True confirming the module spec class; __spec__ is always a ModuleSpec for importlib-loaded modules; new to extra176"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra176
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra176.name_eq:
  description: "concurrent.futures.__name__ == 'concurrent.futures' — module's fully qualified name; len=18 (concurrent=10 + '.'=1 + futures=7 = 18); new to extra176"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra176.package_eq:
  description: "concurrent.futures.__package__ == 'concurrent.futures' — package attribute equals __name__ for a package module; new to extra176"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra176.spec_class_name_eq:
  description: "concurrent.futures.__spec__.__class__.__name__ == 'ModuleSpec' — importlib.machinery.ModuleSpec holds import metadata; new to extra176"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant concurrent_futures_extra176.path_class_name_eq:
  description: "concurrent.futures.__path__.__class__.__name__ == 'list' — concurrent.futures is a package so __path__ is a list of search directories; new to extra176"
  category: identity
  kind: python_call_eq
  function: __path__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant concurrent_futures_extra176.path_len_1:
  description: "concurrent.futures.__path__.__len__() == 1 — exactly one directory in the package search path; new to extra176"
  category: identity
  kind: python_call_eq
  function: __path__.__len__
  args: []
  expected: 1

invariant concurrent_futures_extra176.spec_name_eq:
  description: "concurrent.futures.__spec__.name == 'concurrent.futures' — ModuleSpec.name matches __name__; len=18; new to extra176"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["concurrent.futures"]
  expected: true
