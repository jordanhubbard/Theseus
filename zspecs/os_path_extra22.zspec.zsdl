spec: os_path_extra22
version: ">=3.9"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python os.path module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py, Lib/genericpath.py"
    - "os_path_extra6.zspec.zsdl — covers __qualname__ equality for join/split/basename/dirname/normpath/abspath/exists/isfile/isdir/isabs."
    - "os_path_extra8.zspec.zsdl — covers expanduser.__qualname__ equality."
    - "os_path_extra16.zspec.zsdl — covers __qualname__ equality for join/split/exists/isfile/isdir/basename/dirname."
    - "os_path_extra17.zspec.zsdl — covers __qualname__.__len__() for join/split/basename/dirname/exists/isfile/isdir/abspath/expanduser."
    - "os_path_extra18.zspec.zsdl — covers __qualname__ equality and __module__ for splitext and normpath; abspath and expanduser qualname equalities restated."
    - "os_path_extra20.zspec.zsdl — covers isabs.__qualname__.__len__() == 5."
    - "os_path_extra21.zspec.zsdl — covers __qualname__ for getsize/getatime/getmtime/getctime/lexists."
  notes:
    - "This spec extends os_path_extra21.zspec.zsdl."
    - "Prior specs covered: qualname equality for join/split/splitext/basename/dirname/normpath/abspath/isabs/isfile/isdir/exists/expanduser; qualname lengths for join/split/basename/dirname/exists/isfile/isdir/abspath/expanduser/isabs."
    - "This spec covers: __qualname__.__class__.__name__ == 'str' for join/split/splitext/basename/dirname/normpath/abspath/isabs/isfile/isdir/exists/expanduser (no prior os.path spec checks this attribute on function qualnames); plus __qualname__.__len__() for splitext and normpath (the two gaps left after extra17 and extra20)."
    - "normpath.__qualname__ == '_path_normpath' on Python 3.12 (C extension; qualname reflects the internal C-level name). len('_path_normpath') == 14. Verified."
    - "splitext.__qualname__ == 'splitext', len == 8. Verified."
    - "All __qualname__.__class__.__name__ values == 'str'. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__.__class__.__name__ == 'str' for all 12 functions
#
# Prior os.path specs check __qualname__ equality (extra6/8/16/18) and
# __qualname__.__len__() (extra17/20). No prior os.path spec checks that the
# __qualname__ attribute is itself a str object. This table provides that
# orthogonal type-check axis for all 12 functions in scope.
# Verified: all twelve yield 'str'.
# ---------------------------------------------------------------------------

table os_path_extra22.qualname_class_names:
  description: "__qualname__.__class__.__name__ == 'str' for join/split/splitext/basename/dirname/normpath/abspath/isabs/isfile/isdir/exists/expanduser"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqcn22

  columns: [id, function, args, expected]
  rows:
    - [join,       join.__qualname__.__class__.__name__.__eq__,       ["str"], true]
    - [split,      split.__qualname__.__class__.__name__.__eq__,      ["str"], true]
    - [splitext,   splitext.__qualname__.__class__.__name__.__eq__,   ["str"], true]
    - [basename,   basename.__qualname__.__class__.__name__.__eq__,   ["str"], true]
    - [dirname,    dirname.__qualname__.__class__.__name__.__eq__,    ["str"], true]
    - [normpath,   normpath.__qualname__.__class__.__name__.__eq__,   ["str"], true]
    - [abspath,    abspath.__qualname__.__class__.__name__.__eq__,    ["str"], true]
    - [isabs,      isabs.__qualname__.__class__.__name__.__eq__,      ["str"], true]
    - [isfile,     isfile.__qualname__.__class__.__name__.__eq__,     ["str"], true]
    - [isdir,      isdir.__qualname__.__class__.__name__.__eq__,      ["str"], true]
    - [exists,     exists.__qualname__.__class__.__name__.__eq__,     ["str"], true]
    - [expanduser, expanduser.__qualname__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for splitext and normpath
#
# os_path_extra17 covers __qualname__.__len__() for join/split/basename/dirname/
# exists/isfile/isdir/abspath/expanduser. os_path_extra20 adds isabs.
# The two remaining gaps are splitext and normpath.
# splitext.__qualname__ == 'splitext' so len == 8.
# normpath.__qualname__ == '_path_normpath' (C extension name) so len == 14.
# Verified: splitext=8, normpath=14.
# ---------------------------------------------------------------------------

table os_path_extra22.remaining_qualname_lengths:
  description: "__qualname__.__len__() for splitext and normpath — the two gaps not covered by extra17 or extra20"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqlen22

  columns: [id, function, args, expected]
  rows:
    - [splitext, splitext.__qualname__.__len__, [], 8]
    - [normpath, normpath.__qualname__.__len__, [], 14]

# ---------------------------------------------------------------------------
# Standalone: os.path.normpath.__qualname__.__class__.__name__ == 'str'
#
# normpath is a C extension function whose qualname is '_path_normpath' rather
# than the simple function name. Despite this internal name, the qualname
# attribute is still a Python str object. No prior spec checks the class of
# normpath.__qualname__. This standalone highlights the C-extension case
# where qualname diverges from the function's public name.
# Verified: os.path.normpath.__qualname__.__class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

invariant os_path_extra22.normpath.qualname_is_str:
  description: "os.path.normpath.__qualname__.__class__.__name__ == 'str' — C extension qualname '_path_normpath' is still a Python str"
  category: function_qualnames
  kind: python_call_eq
  function: normpath.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: os.path.normpath.__qualname__.__len__() == 14
#
# normpath.__qualname__ == '_path_normpath' which is 14 characters long.
# This is notably longer than the public function name 'normpath' (8 chars)
# because the qualname reflects the C-level internal function name.
# No prior os.path spec covers normpath.__qualname__.__len__().
# Verified: len('_path_normpath') == 14.
# ---------------------------------------------------------------------------

invariant os_path_extra22.normpath.qualname_length:
  description: "os.path.normpath.__qualname__.__len__() == 14 — '_path_normpath' has 14 chars; longer than public name 'normpath' (8 chars)"
  category: function_qualnames
  kind: python_call_eq
  function: normpath.__qualname__.__len__
  args: []
  expected: 14
