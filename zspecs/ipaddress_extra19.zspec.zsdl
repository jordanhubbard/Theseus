spec: ipaddress_extra19
version: ">=3.9"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html — Python ipaddress module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
    - "ipaddress_extra5.zspec.zsdl — covers __qualname__.__eq__ for IPv4Address/IPv6Address/IPv4Network/IPv6Network/IPv4Interface/IPv6Interface and ip_address/ip_network/ip_interface factories, plus AddressValueError/NetmaskValueError."
    - "ipaddress_extra16.zspec.zsdl — covers __qualname__.__len__() for IPv4Address/IPv6Address/IPv4Network/IPv6Network (all == 11); standalone __qualname__.__eq__ for IPv4Address and IPv6Network."
    - "ipaddress_extra17.zspec.zsdl — covers __qualname__.__len__() for AddressValueError/NetmaskValueError/summarize_address_range/collapse_addresses/get_mixed_type_key; __name__.__eq__ for utility functions; module __name__ and __package__."
    - "ipaddress_extra18.zspec.zsdl — covers __qualname__.__eq__ for IPv4Network.subnets/supernet/overlaps (all defined on _BaseNetwork mixin); cross-namespace anchors for ip_network and ip_interface."
  notes:
    - "This spec extends the ipaddress chain through ipaddress_extra18; it does NOT duplicate invariants in any prior spec."
    - "Focus: __qualname__.__eq__ for IPv4Address dunder methods (__str__, __repr__, __int__, __eq__, __hash__) and IPv4Network dunder methods (__contains__, __iter__). These are all defined on the private _BaseAddress or _BaseNetwork mixin, so their qualnames reflect the mixin, not the concrete class."
    - "IPv4Address.__str__.__qualname__ == '_BaseAddress.__str__' — inherited from _BaseAddress. len == 20. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "IPv4Address.__repr__.__qualname__ == '_BaseAddress.__repr__' — inherited from _BaseAddress. len == 21. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "IPv4Address.__int__.__qualname__ == '_BaseAddress.__int__' — inherited from _BaseAddress. len == 20. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "IPv4Address.__eq__.__qualname__ == '_BaseAddress.__eq__' — inherited from _BaseAddress. len == 19. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "IPv4Address.__hash__.__qualname__ == '_BaseAddress.__hash__' — inherited from _BaseAddress. len == 21. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "IPv4Network.__contains__.__qualname__ == '_BaseNetwork.__contains__' — inherited from _BaseNetwork. len == 25. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "IPv4Network.__iter__.__qualname__ == '_BaseNetwork.__iter__' — inherited from _BaseNetwork. len == 21. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IPv4Address dunder method __qualname__.__eq__ checks
#
# __str__, __repr__, __int__, __eq__, __hash__ are all defined on the
# internal _BaseAddress mixin class. Their __qualname__ values reflect this:
# '_BaseAddress.__str__', '_BaseAddress.__repr__', '_BaseAddress.__int__',
# '_BaseAddress.__eq__', '_BaseAddress.__hash__'.
# No prior ipaddress spec checks the __qualname__ of any IPv4Address dunder.
# ipaddress_extra18 checks _BaseNetwork methods (subnets/supernet/overlaps)
# but not _BaseAddress methods.
# ---------------------------------------------------------------------------

table ipaddress_extra19.ipv4address_dunder_qualnames:
  description: "__qualname__.__eq__ for IPv4Address dunder methods (defined on _BaseAddress)"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: a4dqn19

  columns: [id, function, args, expected]
  rows:
    - [str,   "IPv4Address.__str__.__qualname__.__eq__",   ["_BaseAddress.__str__"],   true]
    - [repr,  "IPv4Address.__repr__.__qualname__.__eq__",  ["_BaseAddress.__repr__"],  true]
    - [int,   "IPv4Address.__int__.__qualname__.__eq__",   ["_BaseAddress.__int__"],   true]
    - [eq,    "IPv4Address.__eq__.__qualname__.__eq__",    ["_BaseAddress.__eq__"],    true]
    - [hash,  "IPv4Address.__hash__.__qualname__.__eq__",  ["_BaseAddress.__hash__"],  true]

# ---------------------------------------------------------------------------
# IPv4Network dunder method __qualname__.__eq__ checks
#
# __contains__ and __iter__ are defined on the internal _BaseNetwork mixin.
# Their qualnames: '_BaseNetwork.__contains__' (len 25), '_BaseNetwork.__iter__' (len 21).
# ipaddress_extra18 checks _BaseNetwork.subnets/supernet/overlaps but not
# __contains__ or __iter__. No prior spec checks these dunder qualnames.
# ---------------------------------------------------------------------------

table ipaddress_extra19.ipv4network_dunder_qualnames:
  description: "__qualname__.__eq__ for IPv4Network dunder methods (defined on _BaseNetwork)"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: n4dqn19

  columns: [id, function, args, expected]
  rows:
    - [contains, "IPv4Network.__contains__.__qualname__.__eq__", ["_BaseNetwork.__contains__"], true]
    - [iter,     "IPv4Network.__iter__.__qualname__.__eq__",     ["_BaseNetwork.__iter__"],     true]

# ---------------------------------------------------------------------------
# __qualname__.__len__() checks for the above dunder methods
#
# No prior spec checks __qualname__.__len__() for any _BaseAddress or
# _BaseNetwork dunder method. ipaddress_extra18 checks lengths for
# subnets/supernet/overlaps only.
# '_BaseAddress.__str__'==20, '_BaseAddress.__repr__'==21,
# '_BaseAddress.__int__'==20, '_BaseAddress.__eq__'==19,
# '_BaseAddress.__hash__'==21, '_BaseNetwork.__contains__'==25,
# '_BaseNetwork.__iter__'==21.
# ---------------------------------------------------------------------------

table ipaddress_extra19.dunder_qualname_lengths:
  description: "Length of __qualname__ strings for _BaseAddress and _BaseNetwork dunder methods"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: dqlen19

  columns: [id, function, args, expected]
  rows:
    - [addr_str,      "IPv4Address.__str__.__qualname__.__len__",      [], 20]
    - [addr_repr,     "IPv4Address.__repr__.__qualname__.__len__",     [], 21]
    - [addr_int,      "IPv4Address.__int__.__qualname__.__len__",      [], 20]
    - [addr_eq,       "IPv4Address.__eq__.__qualname__.__len__",       [], 19]
    - [addr_hash,     "IPv4Address.__hash__.__qualname__.__len__",     [], 21]
    - [net_contains,  "IPv4Network.__contains__.__qualname__.__len__", [], 25]
    - [net_iter,      "IPv4Network.__iter__.__qualname__.__len__",     [], 21]
