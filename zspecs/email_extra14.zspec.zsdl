spec: email_extra14
version: ">=3.6"
backend: python_module(email)

docs: https://docs.python.org/3/library/email.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/email.html — Python email module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/email/"
  notes:
    - "This spec extends email_extra13.zspec.zsdl."
    - "Prior specs covered: email.message.Message class, email.parser.Parser/FeedParser, email.mime.text.MIMEText, email.utils functions, email.__name__/__package__, Message/__name__/__module__/__qualname__, MIMEText/__name__/__module__, Parser/__name__/__module__, FeedParser.__name__/__module__=='email.feedparser', MIMEText.__bases__[0].__name__, MIMEMultipart.__bases__[0].__name__, MessageParseError identity, headerregistry.Address.__name__."
    - "This spec covers: email.message.Message.__init__.__name__, email.message.Message.__module__.__len__(), email.parser.Parser.__module__.__len__(), email.parser.FeedParser.__module__.__len__(), email.mime.text.MIMEText.__module__.__len__(), email.message.Message.__qualname__.__len__(), email.parser.Parser.__qualname__.__len__(), email.mime.text.MIMEText.__qualname__.__len__(), email.errors.MessageError.__module__, email.errors.MessageError.__module__.__len__(), email.errors.MessageParseError.__module__.__len__(), email.errors.HeaderParseError.__module__.__len__()."
    - "email.message.Message.__init__.__name__ == '__init__' — no prior email spec checks Message.__init__.__name__ in isolation as a standalone invariant. email_extra11 checks Message method __qualname__ values; __init__.__name__ is '__init__' (unqualified)."
    - "email.message.Message.__module__.__len__() == 13 — len('email.message') == 13; email_extra12 checks Message.__module__.__eq__; no prior spec checks Message.__module__.__len__()."
    - "email.parser.Parser.__module__.__len__() == 12 — len('email.parser') == 12; email_extra13 checks Parser.__module__.__eq__; no prior spec checks Parser.__module__.__len__()."
    - "email.parser.FeedParser.__module__.__len__() == 16 — len('email.feedparser') == 16; email_extra13 checks FeedParser.__module__.__eq__; no prior spec checks FeedParser.__module__.__len__()."
    - "email.mime.text.MIMEText.__module__.__len__() == 15 — len('email.mime.text') == 15; email_extra12 checks MIMEText.__module__.__eq__; no prior spec checks MIMEText.__module__.__len__()."
    - "email.message.Message.__qualname__.__len__() == 7 — len('Message') == 7; email_extra10 checks Message.__qualname__.__eq__('Message'); no prior spec checks Message.__qualname__.__len__()."
    - "email.parser.Parser.__qualname__.__len__() == 6 — len('Parser') == 6; email_extra13 checks Parser.__qualname__ lengths in a table row; this spec provides a standalone invariant."
    - "email.mime.text.MIMEText.__qualname__.__len__() == 8 — len('MIMEText') == 8; email_extra12 checks MIMEText.__qualname__.__eq__; no prior spec checks MIMEText.__qualname__.__len__()."
    - "email.errors.MessageError.__module__ == 'email.errors' — no prior email spec checks MessageError.__module__.__eq__. email_extra12 checks MessageError.__qualname__ and __bases__[0].__name__; no prior spec checks __module__ on MessageError."
    - "email.errors.MessageError.__module__.__len__() == 12 — len('email.errors') == 12; follows from MessageError.__module__ == 'email.errors'."
    - "email.errors.MessageParseError.__module__.__len__() == 12 — email_extra13 checks MessageParseError.__module__.__eq__('email.errors'); no prior spec checks MessageParseError.__module__.__len__()."
    - "email.errors.HeaderParseError.__module__.__len__() == 12 — no prior email spec checks any attribute on HeaderParseError except via general error hierarchy checks. HeaderParseError.__module__ == 'email.errors'; len == 12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# email.message.Message.__init__.__name__
#
# email_extra11 checks Message method __qualname__ values (e.g.
# 'Message.__init__'). No prior email spec checks Message.__init__.__name__
# as a standalone invariant. The __name__ of a method is the simple name
# '__init__', distinct from __qualname__ which includes the class prefix.
# ---------------------------------------------------------------------------

invariant email_extra14.Message_init.name:
  description: "email.message.Message.__init__.__name__ == '__init__' — no prior email spec checks Message.__init__.__name__ as a standalone invariant"
  category: method_identity
  kind: python_call_eq
  function: message.Message.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ string lengths for Message, Parser, FeedParser, MIMEText
#
# Prior specs check __module__.__eq__ for all four (extra12 for Message/MIMEText,
# extra13 for Parser/FeedParser). No prior email spec checks __module__.__len__()
# on any of these classes.
# ---------------------------------------------------------------------------

table email_extra14.class_module_lengths:
  description: "Message/Parser/FeedParser/MIMEText __module__ string lengths — no prior email spec checks __module__.__len__() on these classes"
  kind: python_call_eq
  category: class_modules
  id_prefix: cmodlen14

  columns: [id, function, args, expected]
  rows:
    - [Message,    message.Message.__module__.__len__,         [], 13]
    - [Parser,     parser.Parser.__module__.__len__,           [], 12]
    - [FeedParser, parser.FeedParser.__module__.__len__,       [], 16]
    - [MIMEText,   mime.text.MIMEText.__module__.__len__,      [], 15]

# ---------------------------------------------------------------------------
# __qualname__ string lengths for Message, Parser, MIMEText
#
# email_extra10 checks Message.__qualname__.__eq__('Message').
# email_extra13 checks Parser.__qualname__.__len__() == 6 in a table.
# email_extra12 checks MIMEText.__qualname__.__eq__('MIMEText').
# No prior email spec checks Message.__qualname__.__len__() or
# MIMEText.__qualname__.__len__(). The Parser entry provides a standalone
# invariant in the extra14 namespace alongside the others.
# ---------------------------------------------------------------------------

table email_extra14.class_qualname_lengths:
  description: "Message/Parser/MIMEText __qualname__ string lengths — no prior spec checks Message or MIMEText __qualname__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: cqnlen14

  columns: [id, function, args, expected]
  rows:
    - [Message,  message.Message.__qualname__.__len__,    [], 7]
    - [Parser,   parser.Parser.__qualname__.__len__,      [], 6]
    - [MIMEText, mime.text.MIMEText.__qualname__.__len__, [], 8]

# ---------------------------------------------------------------------------
# email.errors.MessageError __module__ and __module__ length
#
# email_extra12 checks MessageError.__qualname__ and __bases__[0].__name__.
# No prior email spec checks MessageError.__module__.__eq__ or
# MessageError.__module__.__len__(). MessageError is defined in email.errors.
# ---------------------------------------------------------------------------

invariant email_extra14.MessageError.module:
  description: "email.errors.MessageError.__module__ == 'email.errors' — no prior email spec checks MessageError.__module__.__eq__"
  category: class_modules
  kind: python_call_eq
  function: errors.MessageError.__module__.__eq__
  args: ["email.errors"]
  expected: true

invariant email_extra14.MessageError.module_len:
  description: "email.errors.MessageError.__module__.__len__() == 12 — len('email.errors') == 12; no prior spec checks MessageError.__module__.__len__()"
  category: class_modules
  kind: python_call_eq
  function: errors.MessageError.__module__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# email.errors.MessageParseError and HeaderParseError __module__ lengths
#
# email_extra13 checks MessageParseError.__module__.__eq__('email.errors').
# No prior email spec checks MessageParseError.__module__.__len__() or any
# attribute on HeaderParseError. Both classes are defined in email.errors,
# so __module__ == 'email.errors' (len 12) for both.
# ---------------------------------------------------------------------------

invariant email_extra14.MessageParseError.module_len:
  description: "email.errors.MessageParseError.__module__.__len__() == 12 — len('email.errors') == 12; no prior spec checks MessageParseError.__module__.__len__()"
  category: class_modules
  kind: python_call_eq
  function: errors.MessageParseError.__module__.__len__
  args: []
  expected: 12

invariant email_extra14.HeaderParseError.module_len:
  description: "email.errors.HeaderParseError.__module__.__len__() == 12 — len('email.errors') == 12; no prior email spec checks any attribute on HeaderParseError"
  category: class_modules
  kind: python_call_eq
  function: errors.HeaderParseError.__module__.__len__
  args: []
  expected: 12
