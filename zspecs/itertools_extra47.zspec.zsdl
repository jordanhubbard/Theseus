spec: itertools_extra47
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra46.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for all major itertools types; __qualname__.__len__() for groupby/islice/zip_longest/accumulate/chain.from_iterable/combinations_with_replacement/count/cycle/repeat/starmap/compress/dropwhile/takewhile/filterfalse; __mro__.__len__()==2 for all major types; __bases__[0].__name__.__len__()==6 for all types; __name__/__qualname__ string equality for all major types; __bases__[0].__name__=='object' string equality for all major types; __bases__[0].__qualname__=='object' for all major types (extra45 + extra46 completing full coverage)."
    - "This spec covers: itertools.groupby.__class__.__name__ == 'type'; itertools.chain.__class__.__name__ == 'type'; itertools.compress.__class__.__name__ == 'type'; itertools.islice.__class__.__name__ == 'type'; itertools.zip_longest.__class__.__name__ == 'type'; itertools.product.__class__.__name__ == 'type'; itertools.count.__class__.__name__ == 'type'; itertools.cycle.__class__.__name__ == 'type'; itertools.repeat.__class__.__name__ == 'type'."
    - "Key findings: All itertools objects exposed at module level are C-extension types defined in Modules/itertoolsmodule.c. Every one of them has __class__.__name__ == 'type' (4 chars) — the built-in type metaclass. This is consistent with the general Python invariant that class objects (regardless of whether they are C-extension types or pure-Python classes) are instances of the 'type' metaclass, so __class__.__name__ is always 'type'. The itertools module exports no functions — only classes — so every module-level callable has __class__.__name__ == 'type'. This contrasts with functools (extra51), which has a mix of 'builtin_function_or_method', 'function', and 'type' values. No prior spec recorded __class__.__name__ string equality for any itertools type; prior specs only recorded __name__/__qualname__ (the type's own name attributes), not the metaclass __class__.__name__. All nine invariants are new to extra47."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools combinatoric and grouping types __class__.__name__ — extra47
#
# itertools.groupby, chain, compress, islice, zip_longest, and product are all
# C-extension types defined in Modules/itertoolsmodule.c. Their __class__.__name__
# is 'type' — the built-in metaclass name for all class objects. Prior specs
# recorded __name__/__qualname__ string equality and __bases__[0].__qualname__
# for all six, but no prior spec recorded __class__.__name__ for any of them.
# All six are new to extra47.
# ---------------------------------------------------------------------------

table itertools_extra47.groupby_chain_compress_islice_zip_product_class_names:
  description: "itertools groupby/chain/compress/islice/zip_longest/product __class__.__name__ == 'type' — all are C-extension types in itertoolsmodule.c; __class__ is the built-in 'type' metaclass; 4-char metaclass name"
  kind: python_call_eq
  category: identity
  id_prefix: gccizp47

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_class_name,
       groupby.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.groupby.__class__.__name__ == 'type' — C-extension type in Modules/itertoolsmodule.c; groups consecutive elements with equal key function output; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
    - [chain_class_name,
       chain.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.chain.__class__.__name__ == 'type' — C-extension type in Modules/itertoolsmodule.c; chains multiple iterables into a single iterable; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
    - [compress_class_name,
       compress.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.compress.__class__.__name__ == 'type' — C-extension type in Modules/itertoolsmodule.c; filters elements based on a boolean selector iterable; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
    - [islice_class_name,
       islice.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.islice.__class__.__name__ == 'type' — C-extension type in Modules/itertoolsmodule.c; slices an iterator like a sequence slice; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
    - [zip_longest_class_name,
       zip_longest.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.zip_longest.__class__.__name__ == 'type' — C-extension type in Modules/itertoolsmodule.c; zips iterables filling missing values with a fill value; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
    - [product_class_name,
       product.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.product.__class__.__name__ == 'type' — C-extension type in Modules/itertoolsmodule.c; yields Cartesian product of input iterables; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]

# ---------------------------------------------------------------------------
# itertools infinite iterator types __class__.__name__ — extra47 namespace
#
# itertools.count, cycle, and repeat are C-extension types defined in
# Modules/itertoolsmodule.c that produce infinite (or bounded for repeat with
# a times argument) sequences. Their __class__.__name__ is 'type' — consistent
# with all other itertools types. Prior specs recorded __name__/__qualname__
# string equality and __bases__[0].__qualname__ for all three, but no prior
# spec recorded __class__.__name__ for any of them. All three are new to extra47.
# ---------------------------------------------------------------------------

table itertools_extra47.count_cycle_repeat_class_names:
  description: "itertools count/cycle/repeat __class__.__name__ == 'type' — C-extension infinite iterator types in itertoolsmodule.c; __class__ is the built-in 'type' metaclass; 4-char metaclass name"
  kind: python_call_eq
  category: identity
  id_prefix: ccr47

  columns: [id, function, args, expected, description]
  rows:
    - [count_class_name,
       count.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.count.__class__.__name__ == 'type' — C-extension type in Modules/itertoolsmodule.c; infinite counter starting from a given value with optional step; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
    - [cycle_class_name,
       cycle.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.cycle.__class__.__name__ == 'type' — C-extension type in Modules/itertoolsmodule.c; cycles through an iterable indefinitely saving a copy internally; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
    - [repeat_class_name,
       repeat.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.repeat.__class__.__name__ == 'type' — C-extension type in Modules/itertoolsmodule.c; yields the same object indefinitely or n times; class objects are instances of the 'type' metaclass; __class__.__name__ is 'type' (4 chars)"]
