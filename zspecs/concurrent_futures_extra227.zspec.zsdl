    - [tpe_name_eq,        ThreadPoolExecutor.__name__.__eq__,     ["ThreadPoolExecutor"],        true, "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'; verified with Python 3.14.3"]
    - [tpe_name_len_18,    ThreadPoolExecutor.__name__.__len__,    [],                            18,   "concurrent.futures.ThreadPoolExecutor.__name__.__len__() == 18 — 'ThreadPoolExecutor' has 18 characters; verified with Python 3.14.3"]
    - [tpe_qualname_eq,    ThreadPoolExecutor.__qualname__.__eq__, ["ThreadPoolExecutor"],        true, "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor'; verified with Python 3.14.3"]
    - [tpe_module_eq,      ThreadPoolExecutor.__module__.__eq__,   ["concurrent.futures.thread"], true, "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'; verified with Python 3.14.3"]

