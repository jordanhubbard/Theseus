spec: concurrent_futures_extra227
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' — 18 characters; module is concurrent.futures.thread; verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' — 19 characters; module is concurrent.futures.process; verified with Python 3.14.3."
    - "concurrent.futures.Executor.__qualname__ == 'Executor' — 8 characters; module is concurrent.futures._base; verified with Python 3.14.3."
    - "concurrent.futures.Future.__qualname__ == 'Future' — 6 characters; module is concurrent.futures._base; verified with Python 3.14.3."
    - "ThreadPoolExecutor and ProcessPoolExecutor live in their respective submodules, not _base; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

