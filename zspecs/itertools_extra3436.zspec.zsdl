spec: it3436
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 676 (it3436): __le__, __gt__, __ge__ dict-presence checks for itertools types."
    - "Theme: __le__/__gt__/__ge__ dict-presence (x<=y, x>y, x>=y)."
    - "All values False — itertools iterator types implement the iterator protocol only, not identity/comparison protocols in their own __dict__."
    - "None of the itertools iterator types define __le__, __gt__, or __ge__ in their own __dict__."
    - "All 18 itertools iterator types are C-level types; they implement iterator protocol (__iter__/__next__), not le/gt/ge comparison protocols."
    - "itertools.pairwise requires Python >= 3.10."
    - "All 18 itertools iterator types are checked."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

