spec: decimal_extra114
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra113.zspec.zsdl."
    - "This spec covers: decimal.Decimal arithmetic and conversion method qualnames not yet covered by equality assertions."
    - "decimal.Decimal.exp.__qualname__ == 'Decimal.exp' (len 11); prior specs covered __len__ only."
    - "decimal.Decimal.ln.__qualname__ == 'Decimal.ln' (len 10); prior specs covered __len__ and __name__.__eq__ only."
    - "decimal.Decimal.log10.__qualname__ == 'Decimal.log10' (len 13); prior specs covered __len__ and __name__.__eq__ only."
    - "decimal.Decimal.normalize.__qualname__ == 'Decimal.normalize' (len 17); prior specs covered __len__ and __name__.__eq__ only."
    - "decimal.Decimal.same_quantum.__qualname__ == 'Decimal.same_quantum' (len 20); no prior equality assertion."
    - "decimal.Decimal.remainder_near.__qualname__ == 'Decimal.remainder_near' (len 22); no prior equality assertion."
    - "decimal.Decimal.to_integral_value.__qualname__ == 'Decimal.to_integral_value' (len 25); prior specs covered __len__ only."
    - "decimal.Decimal.to_integral_exact.__qualname__ == 'Decimal.to_integral_exact' (len 25); no prior equality assertion."
    - "All methods are method_descriptor objects (C extension methods from Modules/_decimal/_decimal.c)."
    - "Length ordering: to_integral_value(25)==to_integral_exact(25) > remainder_near(22) > same_quantum(20) > normalize(17) > log10(13) > exp(11)==fma(11) > ln(10)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.exp, ln, and log10 qualnames (equality assertions)
# Decimal.exp.__qualname__ == 'Decimal.exp' (11 chars).
# Decimal.ln.__qualname__ == 'Decimal.ln' (10 chars).
# Decimal.log10.__qualname__ == 'Decimal.log10' (13 chars).
# Prior specs covered exp.__qualname__.__len__, ln.__qualname__.__len__,
# and log10.__qualname__.__len__, as well as ln.__name__.__eq__ and log10.__name__.__eq__.
# But NO prior spec asserted exp.__qualname__.__eq__, ln.__qualname__.__eq__,
# or log10.__qualname__.__eq__ (equality against the full string).
# exp returns e ** self; ln returns the natural logarithm; log10 returns log base 10.
# All are C method_descriptors in Modules/_decimal/_decimal.c.
# log10(13) > exp(11) == fma(11) > ln(10).
# ---------------------------------------------------------------------------

table decimal_extra114.exp_ln_log10_qualnames:
  description: "decimal.Decimal.exp.__qualname__='Decimal.exp'(11); ln.__qualname__='Decimal.ln'(10); log10.__qualname__='Decimal.log10'(13); equality assertions novel; prior specs covered len and name only"
  kind: python_call_eq
  category: method_identity
  id_prefix: decexpln114a

  columns: [id, function, args, expected, description]
  rows:
    - [exp_qn_eq,      "Decimal.exp.__qualname__.__eq__",          ["Decimal.exp"],    true,  "decimal.Decimal.exp.__qualname__ == 'Decimal.exp' (11 chars; exp() returns e**self; the natural exponential function for decimal arithmetic)"]
    - [exp_qn_len,     "Decimal.exp.__qualname__.__len__",         [],                 11,    "decimal.Decimal.exp.__qualname__.__len__() == 11 ('Decimal.exp': 'Decimal.'(8)+'exp'(3)==11; same length as 'Decimal.fma')"]
    - [ln_qn_eq,       "Decimal.ln.__qualname__.__eq__",           ["Decimal.ln"],     true,  "decimal.Decimal.ln.__qualname__ == 'Decimal.ln' (10 chars; ln() returns the natural logarithm of self; prior specs covered __len__ and __name__.__eq__ but not __qualname__.__eq__)"]
    - [ln_qn_len,      "Decimal.ln.__qualname__.__len__",          [],                 10,    "decimal.Decimal.ln.__qualname__.__len__() == 10 ('Decimal.ln': 'Decimal.'(8)+'ln'(2)==10; shortest qualname among the transcendental math methods)"]
    - [log10_qn_eq,    "Decimal.log10.__qualname__.__eq__",        ["Decimal.log10"],  true,  "decimal.Decimal.log10.__qualname__ == 'Decimal.log10' (13 chars; log10() returns the base-ten logarithm of self; prior specs covered __len__ and __name__.__eq__ but not __qualname__.__eq__)"]
    - [log10_qn_len,   "Decimal.log10.__qualname__.__len__",       [],                 13,    "decimal.Decimal.log10.__qualname__.__len__() == 13 ('Decimal.log10': 'Decimal.'(8)+'log10'(5)==13)"]
    - [log10_gt_exp,   "Decimal.log10.__qualname__.__len__.__gt__", [11],              true,  "len('Decimal.log10') > len('Decimal.exp') (13 > 11; 'log10'(5) is 2 chars longer than 'exp'(3))"]
    - [exp_gt_ln,      "Decimal.exp.__qualname__.__len__.__gt__",   [10],              true,  "len('Decimal.exp') > len('Decimal.ln') (11 > 10; 'exp'(3) is 1 char longer than 'ln'(2))"]

# ---------------------------------------------------------------------------
# decimal.Decimal.normalize and same_quantum qualnames (equality assertions)
# Decimal.normalize.__qualname__ == 'Decimal.normalize' (17 chars).
# Decimal.same_quantum.__qualname__ == 'Decimal.same_quantum' (20 chars).
# Prior specs covered normalize.__qualname__.__len__, normalize.__name__.__eq__,
# and normalize.__doc__.__class__.__name__.__eq__, but NOT normalize.__qualname__.__eq__.
# No prior spec covered same_quantum at all.
# normalize reduces the number to its shortest equivalent form.
# same_quantum tests whether two Decimal values have the same exponent.
# same_quantum(20) > normalize(17): 'same_quantum'(12) > 'normalize'(9).
# ---------------------------------------------------------------------------

table decimal_extra114.normalize_same_quantum_qualnames:
  description: "decimal.Decimal.normalize.__qualname__='Decimal.normalize'(17); same_quantum.__qualname__='Decimal.same_quantum'(20); equality assertions novel; prior specs covered normalize len/name but not qualname eq; same_quantum entirely novel"
  kind: python_call_eq
  category: method_identity
  id_prefix: decnormsq114b

  columns: [id, function, args, expected, description]
  rows:
    - [norm_qn_eq,     "Decimal.normalize.__qualname__.__eq__",          ["Decimal.normalize"],     true,  "decimal.Decimal.normalize.__qualname__ == 'Decimal.normalize' (17 chars; normalize reduces to shortest form; prior specs covered __len__ and __name__.__eq__ but not __qualname__.__eq__)"]
    - [norm_qn_len,    "Decimal.normalize.__qualname__.__len__",         [],                        17,    "decimal.Decimal.normalize.__qualname__.__len__() == 17 ('Decimal.normalize': 'Decimal.'(8)+'normalize'(9)==17)"]
    - [sq_qn_eq,       "Decimal.same_quantum.__qualname__.__eq__",       ["Decimal.same_quantum"],  true,  "decimal.Decimal.same_quantum.__qualname__ == 'Decimal.same_quantum' (20 chars; same_quantum returns True if self and other have the same exponent; no prior decimal spec covered same_quantum)"]
    - [sq_qn_len,      "Decimal.same_quantum.__qualname__.__len__",      [],                        20,    "decimal.Decimal.same_quantum.__qualname__.__len__() == 20 ('Decimal.same_quantum': 'Decimal.'(8)+'same_quantum'(12)==20)"]
    - [sq_gt_norm,     "Decimal.same_quantum.__qualname__.__len__.__gt__", [17],                    true,  "len('Decimal.same_quantum') > len('Decimal.normalize') (20 > 17; 'same_quantum'(12) is 3 chars longer than 'normalize'(9))"]
    - [norm_type,      "Decimal.normalize.__class__.__name__.__eq__",    ["method_descriptor"],     true,  "type(decimal.Decimal.normalize).__name__ == 'method_descriptor' (C extension method from Modules/_decimal/_decimal.c)"]
    - [sq_type,        "Decimal.same_quantum.__class__.__name__.__eq__", ["method_descriptor"],     true,  "type(decimal.Decimal.same_quantum).__name__ == 'method_descriptor' (C extension method; same type as normalize and all Decimal arithmetic methods)"]
    - [norm_gt_log10,  "Decimal.normalize.__qualname__.__len__.__gt__",  [13],                      true,  "len('Decimal.normalize') > len('Decimal.log10') (17 > 13; normalize is 4 chars longer than log10 in qualname length)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.remainder_near and to_integral_value/to_integral_exact qualnames
# Decimal.remainder_near.__qualname__ == 'Decimal.remainder_near' (22 chars).
# Decimal.to_integral_value.__qualname__ == 'Decimal.to_integral_value' (25 chars).
# Decimal.to_integral_exact.__qualname__ == 'Decimal.to_integral_exact' (25 chars).
# Prior specs covered to_integral_value.__qualname__.__len__ only.
# No prior spec covered remainder_near or to_integral_exact with equality.
# to_integral_value and to_integral_exact both have length 25.
# remainder_near returns the remainder closest to zero; it follows the IEEE 754 semantics.
# to_integral_value rounds to an integer using current rounding mode.
# to_integral_exact does the same but signals if rounding occurs (Inexact).
# ---------------------------------------------------------------------------

table decimal_extra114.remainder_near_to_integral_qualnames:
  description: "decimal.Decimal.remainder_near.__qualname__='Decimal.remainder_near'(22); to_integral_value='Decimal.to_integral_value'(25); to_integral_exact='Decimal.to_integral_exact'(25); equality assertions novel"
  kind: python_call_eq
  category: method_identity
  id_prefix: decrnti114c

  columns: [id, function, args, expected, description]
  rows:
    - [rn_qn_eq,      "Decimal.remainder_near.__qualname__.__eq__",          ["Decimal.remainder_near"],   true,  "decimal.Decimal.remainder_near.__qualname__ == 'Decimal.remainder_near' (22 chars; returns the remainder closest to zero following IEEE 754; no prior spec covered remainder_near with equality)"]
    - [rn_qn_len,     "Decimal.remainder_near.__qualname__.__len__",         [],                           22,    "decimal.Decimal.remainder_near.__qualname__.__len__() == 22 ('Decimal.remainder_near': 'Decimal.'(8)+'remainder_near'(14)==22; same length as compare_signal)"]
    - [tiv_qn_eq,     "Decimal.to_integral_value.__qualname__.__eq__",       ["Decimal.to_integral_value"], true, "decimal.Decimal.to_integral_value.__qualname__ == 'Decimal.to_integral_value' (25 chars; rounds to integer using current rounding mode; prior specs covered __len__ only)"]
    - [tiv_qn_len,    "Decimal.to_integral_value.__qualname__.__len__",      [],                           25,    "decimal.Decimal.to_integral_value.__qualname__.__len__() == 25 ('Decimal.to_integral_value': 'Decimal.'(8)+'to_integral_value'(17)==25)"]
    - [tie_qn_eq,     "Decimal.to_integral_exact.__qualname__.__eq__",       ["Decimal.to_integral_exact"], true, "decimal.Decimal.to_integral_exact.__qualname__ == 'Decimal.to_integral_exact' (25 chars; like to_integral_value but signals Inexact if rounding occurs; no prior spec covered equality)"]
    - [tie_qn_len,    "Decimal.to_integral_exact.__qualname__.__len__",      [],                           25,    "decimal.Decimal.to_integral_exact.__qualname__.__len__() == 25 ('Decimal.to_integral_exact': 'Decimal.'(8)+'to_integral_exact'(17)==25; same length as to_integral_value)"]
    - [tiv_eq_tie,    "Decimal.to_integral_value.__qualname__.__len__.__eq__", [25],                       true,  "len('Decimal.to_integral_value') == len('Decimal.to_integral_exact') == 25 (both use 'Decimal.' prefix and a 17-char method name)"]
    - [tiv_gt_rn,     "Decimal.to_integral_value.__qualname__.__len__.__gt__", [22],                       true,  "len('Decimal.to_integral_value') > len('Decimal.remainder_near') (25 > 22; to_integral_value is 3 chars longer)"]
    - [rn_gt_sq,      "Decimal.remainder_near.__qualname__.__len__.__gt__",  [20],                         true,  "len('Decimal.remainder_near') > len('Decimal.same_quantum') (22 > 20; remainder_near is 2 chars longer than same_quantum)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra114.Decimal.exp_qualname_eq:
  description: "decimal.Decimal.exp.__qualname__ == 'Decimal.exp' (length 11; exp(context=None) returns the value of the natural exponential function e**self; this is the decimal-arithmetic equivalent of math.exp() but operates on Decimal values and respects the current context's precision and rounding; exp is a C method_descriptor from Modules/_decimal/_decimal.c; its qualname uses the 'Decimal.' prefix (8 chars) followed by 'exp' (3 chars) totalling 11 — the same length as 'Decimal.fma' (11); prior decimal_extra specs covered Decimal.exp.__qualname__.__len__()==11 but never asserted the equality string 'Decimal.exp'; this is the first qualname equality assertion for Decimal.exp)"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.exp.__qualname__.__eq__"
  args: ["Decimal.exp"]
  expected: true

invariant decimal_extra114.Decimal.ln_qualname_eq:
  description: "decimal.Decimal.ln.__qualname__ == 'Decimal.ln' (length 10; ln(context=None) returns the natural (base e) logarithm of self; it is the decimal-arithmetic equivalent of math.log() with no base argument; ln is a C method_descriptor from Modules/_decimal/_decimal.c; its qualname uses the 'Decimal.' prefix (8 chars) followed by 'ln' (2 chars) totalling 10; 'Decimal.ln' (10) is the shortest qualname among Decimal's transcendental math methods: ln(10) < exp(11) < log10(13); prior decimal_extra specs covered ln.__qualname__.__len__()==10 and ln.__name__.__eq__=='ln' but never asserted the full qualname equality 'Decimal.ln')"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.ln.__qualname__.__eq__"
  args: ["Decimal.ln"]
  expected: true

invariant decimal_extra114.Decimal.normalize_qualname_eq:
  description: "decimal.Decimal.normalize.__qualname__ == 'Decimal.normalize' (length 17; normalize(context=None) reduces a decimal to its shortest equivalent form by removing trailing zeros; for example, Decimal('2.10').normalize() == Decimal('2.1') and Decimal('2.00').normalize() == Decimal('2'); normalize is a C method_descriptor from Modules/_decimal/_decimal.c; its qualname uses the 'Decimal.' prefix (8 chars) followed by 'normalize' (9 chars) totalling 17; prior decimal_extra specs covered normalize.__qualname__.__len__()==17, normalize.__name__.__eq__, and normalize.__doc__.__class__.__name__.__eq__ but never asserted the full qualname equality 'Decimal.normalize')"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.normalize.__qualname__.__eq__"
  args: ["Decimal.normalize"]
  expected: true

invariant decimal_extra114.Decimal.same_quantum_qualname_eq:
  description: "decimal.Decimal.same_quantum.__qualname__ == 'Decimal.same_quantum' (length 20; same_quantum(other, context=None) returns True if self and other have the same exponent (i.e., the same number of decimal places), or if both are NaN; for example, Decimal('2.1').same_quantum(Decimal('0.3')) is True because both have exponent -1; same_quantum follows the General Decimal Arithmetic specification; it is a C method_descriptor from Modules/_decimal/_decimal.c; its qualname uses the 'Decimal.' prefix (8 chars) followed by 'same_quantum' (12 chars) totalling 20; no prior decimal_extra spec has covered same_quantum in any form)"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.same_quantum.__qualname__.__eq__"
  args: ["Decimal.same_quantum"]
  expected: true

invariant decimal_extra114.Decimal.remainder_near_qualname_eq:
  description: "decimal.Decimal.remainder_near.__qualname__ == 'Decimal.remainder_near' (length 22; remainder_near(other, context=None) returns self - n * other where n is the nearest integer to the exact value of self / other; if two integers are equally near then the even one is chosen; if the result is zero its sign is that of self; this follows the IEEE 754 remainder operation, which differs from Python's % operator; remainder_near is a C method_descriptor from Modules/_decimal/_decimal.c; its qualname 'Decimal.remainder_near' (22 chars) equals the length of 'Decimal.compare_signal' (22); no prior decimal_extra spec has covered remainder_near with a qualname equality assertion)"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.remainder_near.__qualname__.__eq__"
  args: ["Decimal.remainder_near"]
  expected: true

