spec: uuid_extra991
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module UUID class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid.UUID method __qualname__ attributes across lifecycle, comparison, and conversion methods"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra991.lifecycle_method_qualnames:
  description: "uuid.UUID lifecycle method __qualname__ identity"
  kind: python_call_eq
  category: lifecycle_method_qualnames
  id_prefix: uu991lm
  columns: [id, function, args, expected]
  rows:
    - [uu991lm001, uuid.UUID.__init__.__qualname__.__eq__,      ["UUID.__init__"],      true]
    - [uu991lm002, uuid.UUID.__setattr__.__qualname__.__eq__,   ["UUID.__setattr__"],   true]
    - [uu991lm003, uuid.UUID.__str__.__qualname__.__eq__,       ["UUID.__str__"],       true]
    - [uu991lm004, uuid.UUID.__repr__.__qualname__.__eq__,      ["UUID.__repr__"],      true]
    - [uu991lm005, uuid.UUID.__hash__.__qualname__.__eq__,      ["UUID.__hash__"],      true]

table uuid_extra991.comparison_method_qualnames:
  description: "uuid.UUID comparison method __qualname__ identity"
  kind: python_call_eq
  category: comparison_method_qualnames
  id_prefix: uu991cm
  columns: [id, function, args, expected]
  rows:
    - [uu991cm001, uuid.UUID.__eq__.__qualname__.__eq__,        ["UUID.__eq__"],        true]
    - [uu991cm002, uuid.UUID.__lt__.__qualname__.__eq__,        ["UUID.__lt__"],        true]
    - [uu991cm003, uuid.UUID.__le__.__qualname__.__eq__,        ["UUID.__le__"],        true]
    - [uu991cm004, uuid.UUID.__gt__.__qualname__.__eq__,        ["UUID.__gt__"],        true]
    - [uu991cm005, uuid.UUID.__ge__.__qualname__.__eq__,        ["UUID.__ge__"],        true]

table uuid_extra991.conversion_method_qualnames:
  description: "uuid.UUID conversion and access method __qualname__ identity"
  kind: python_call_eq
  category: conversion_method_qualnames
  id_prefix: uu991cv
  columns: [id, function, args, expected]
  rows:
    - [uu991cv001, uuid.UUID.__int__.__qualname__.__eq__,       ["UUID.__int__"],       true]
    - [uu991cv002, uuid.UUID.__bytes__.__qualname__.__eq__,     ["UUID.__bytes__"],     true]
    - [uu991cv003, uuid.UUID.__getattr__.__qualname__.__eq__,   ["UUID.__getattr__"],   true]
    - [uu991cv004, uuid.UUID.__class__.__name__.__eq__,         ["type"],               true]
    - [uu991cv005, uuid.UUID.__module__.__eq__,                 ["uuid"],               true]
