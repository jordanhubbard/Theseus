spec: decimal_extra151
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal exception class identity — InvalidOperation, DivisionByZero, Overflow, Underflow, DecimalException."
    - "decimal.InvalidOperation.__name__ == 'InvalidOperation'; __module__ == 'decimal'. decimal.DivisionByZero.__name__ == 'DivisionByZero'; __module__ == 'decimal'."
    - "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — DecimalException inherits from the Python built-in ArithmeticError."
    - "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' — the signal exceptions (InvalidOperation, DivisionByZero, etc.) all inherit from DecimalException."
    - "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException' — DivisionByZero is a direct subclass of DecimalException (NOT Python's built-in ZeroDivisionError)."
    - "decimal.Overflow.__bases__[0].__name__ == 'Inexact' — Overflow inherits from Inexact (not directly from DecimalException). decimal.Underflow.__bases__[0].__name__ == 'Inexact' — Underflow also inherits from Inexact."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal exception class identity: __name__ and __module__
# InvalidOperation.__name__ == 'InvalidOperation', __module__ == 'decimal'
# DivisionByZero.__name__ == 'DivisionByZero', __module__ == 'decimal'
# Overflow.__name__ == 'Overflow', Underflow.__name__ == 'Underflow'
# DecimalException.__name__ == 'DecimalException'
# All __module__ == 'decimal' (not '_decimal').
# ---------------------------------------------------------------------------

table decimal_extra151.decimal_exception_identity:
  description: "decimal exception class __name__ values: InvalidOperation, DivisionByZero, Overflow, Underflow, DecimalException — all have __module__=='decimal'"
  kind: python_call_eq
  category: identity
  id_prefix: decexc151

  columns: [id, function, args, expected, description]
  rows:
    - [invalop_name_eq,    InvalidOperation.__name__.__eq__,    ["InvalidOperation"], true, "decimal.InvalidOperation.__name__ == 'InvalidOperation' (the signal raised when an invalid operation is attempted, such as 0/0 or sqrt of a negative number; it is the most commonly trapped decimal exception; __name__ matches the class name exactly; 'InvalidOperation' has 16 characters — the longest of the five decimal exception names covered here)"]
    - [invalop_module_eq,  InvalidOperation.__module__.__eq__,  ["decimal"],          true, "decimal.InvalidOperation.__module__ == 'decimal' (the public 'decimal' module, not '_decimal'; even though the C accelerator _decimal provides the implementation, all decimal exception classes report __module__=='decimal' for correct public attribution; same pattern as decimal.Decimal.__module__ == 'decimal' and decimal.Context.__module__ == 'decimal')"]
    - [divbyz_name_eq,     DivisionByZero.__name__.__eq__,      ["DivisionByZero"],   true, "decimal.DivisionByZero.__name__ == 'DivisionByZero' (the signal raised when division by zero occurs on a finite nonzero number; NOTE: this is NOT the same as Python's built-in ZeroDivisionError — DivisionByZero inherits from DecimalException (not ZeroDivisionError); 'DivisionByZero' has 15 characters)"]
    - [divbyz_module_eq,   DivisionByZero.__module__.__eq__,    ["decimal"],          true, "decimal.DivisionByZero.__module__ == 'decimal' (DivisionByZero's __module__ is 'decimal' — consistent with all other decimal exception classes and the Decimal/Context classes; __module__=='decimal' (not '_decimal') for all decimal public API classes)"]
    - [overflow_name_eq,   Overflow.__name__.__eq__,            ["Overflow"],         true, "decimal.Overflow.__name__ == 'Overflow' (the signal raised when the result exponent is larger than the maximum allowed after rounding; 'Overflow' has 8 characters; decimal.Overflow inherits from Inexact (not directly from DecimalException), making it a grandchild of DecimalException)"]
    - [underflow_name_eq,  Underflow.__name__.__eq__,           ["Underflow"],        true, "decimal.Underflow.__name__ == 'Underflow' (the signal raised when the result is subnormal — the exponent is below the minimum allowed — and is also inexact; 'Underflow' has 9 characters; like Overflow, Underflow inherits from Inexact (not directly from DecimalException))"]

# ---------------------------------------------------------------------------
# decimal exception class inheritance chains
# DecimalException.__bases__[0].__name__ == 'ArithmeticError' (Python built-in)
# InvalidOperation.__bases__[0].__name__ == 'DecimalException'
# DivisionByZero.__bases__[0].__name__ == 'DecimalException'
# Overflow.__bases__[0].__name__ == 'Inexact' (via Inexact -> DecimalException)
# Underflow.__bases__[0].__name__ == 'Inexact'
# ---------------------------------------------------------------------------

table decimal_extra151.decimal_exception_bases:
  description: "decimal exception class inheritance: DecimalException inherits ArithmeticError; InvalidOperation and DivisionByZero inherit DecimalException; Overflow and Underflow inherit Inexact"
  kind: python_call_eq
  category: identity
  id_prefix: decexc151

  columns: [id, function, args, expected, description]
  rows:
    - [decexc_name_eq,     DecimalException.__name__.__eq__,                   ["DecimalException"],  true, "decimal.DecimalException.__name__ == 'DecimalException' (the root class for all decimal arithmetic signals; 'DecimalException' has 16 characters — tied with 'InvalidOperation' as the longest of the decimal exception class names; all decimal signals are subclasses of DecimalException)"]
    - [decexc_base_eq,     "DecimalException.__bases__[0].__name__.__eq__",    ["ArithmeticError"],   true, "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' (DecimalException inherits from Python's built-in ArithmeticError; this connects decimal signals to the standard exception hierarchy — catching ArithmeticError will also catch all decimal exceptions; ArithmeticError is also the base of ZeroDivisionError, OverflowError, and FloatingPointError)"]
    - [invalop_base_eq,    "InvalidOperation.__bases__[0].__name__.__eq__",    ["DecimalException"],  true, "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' (InvalidOperation is a direct subclass of DecimalException; it is NOT a subclass of Python's ValueError or TypeError even though invalid operations might suggest those; decimal.InvalidOperation can be caught with 'except decimal.DecimalException' or 'except decimal.InvalidOperation')"]
    - [divbyz_base_eq,     "DivisionByZero.__bases__[0].__name__.__eq__",      ["DecimalException"],  true, "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException' (DivisionByZero is a direct subclass of DecimalException — NOT a subclass of Python's built-in ZeroDivisionError; this is a notable distinction: decimal.DivisionByZero and the built-in ZeroDivisionError are in different inheritance hierarchies; decimal division by zero raises decimal.DivisionByZero, not the built-in ZeroDivisionError)"]
    - [overflow_base_eq,   "Overflow.__bases__[0].__name__.__eq__",            ["Inexact"],           true, "decimal.Overflow.__bases__[0].__name__ == 'Inexact' (Overflow inherits from Inexact, not directly from DecimalException; the hierarchy is: ArithmeticError -> DecimalException -> Inexact -> Overflow; this makes Overflow a grandchild of DecimalException; Inexact is also the parent of Rounded and Underflow)"]
    - [underflow_base_eq,  "Underflow.__bases__[0].__name__.__eq__",           ["Inexact"],           true, "decimal.Underflow.__bases__[0].__name__ == 'Inexact' (Underflow inherits from Inexact, same as Overflow; the hierarchy is: ArithmeticError -> DecimalException -> Inexact -> Underflow; Underflow occurs when a result is subnormal (tiny exponent) and inexact after rounding; both Overflow and Underflow share Inexact as their direct parent)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra151.DecimalException_base_is_ArithmeticError:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — DecimalException is the root of all decimal signals and inherits from Python's built-in ArithmeticError (not Exception directly); this means 'except ArithmeticError' will catch all decimal exceptions; the full hierarchy from Python's built-in exceptions: BaseException -> Exception -> ArithmeticError -> decimal.DecimalException -> all decimal signals; ArithmeticError is also the base of ZeroDivisionError (but decimal.DivisionByZero does NOT inherit from ZeroDivisionError)"
  category: identity
  kind: python_call_eq
  function: "DecimalException.__bases__[0].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true

invariant decimal_extra151.InvalidOperation_base_is_DecimalException:
  description: "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' — InvalidOperation is a direct subclass of DecimalException; this is the signal raised for invalid operations like sqrt of a negative number, conversion of a NaN to integer, or arithmetic on signaling NaN; InvalidOperation is the most commonly trapped decimal signal in production code; its direct inheritance from DecimalException (not Inexact) distinguishes it from Overflow and Underflow which both go through Inexact"
  category: identity
  kind: python_call_eq
  function: "InvalidOperation.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra151.DivisionByZero_base_is_DecimalException:
  description: "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException' — DivisionByZero is a direct subclass of DecimalException and is NOT related to Python's built-in ZeroDivisionError; decimal division by zero (e.g., Decimal('1') / Decimal('0')) raises decimal.DivisionByZero when the DivisionByZero signal is not trapped, or returns Infinity when it is trapped; this is different behavior from float division by zero which raises the built-in ZeroDivisionError"
  category: identity
  kind: python_call_eq
  function: "DivisionByZero.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra151.Overflow_base_is_Inexact:
  description: "decimal.Overflow.__bases__[0].__name__ == 'Inexact' — Overflow inherits from Inexact (not directly from DecimalException); this reveals the decimal exception hierarchy: DecimalException -> Inexact -> Overflow (and also Underflow); Overflow and Underflow are both classified as Inexact because they represent cases where the mathematical result cannot be represented exactly in the context's precision; the Inexact signal itself is raised whenever a result is rounded"
  category: identity
  kind: python_call_eq
  function: "Overflow.__bases__[0].__name__.__eq__"
  args: ["Inexact"]
  expected: true

invariant decimal_extra151.InvalidOperation_module_is_decimal:
  description: "decimal.InvalidOperation.__module__ == 'decimal' — like all decimal public API classes (Decimal, Context, DecimalException, and all signal classes), InvalidOperation reports __module__=='decimal' (the public module) rather than '_decimal' (the C extension); this consistent attribution means repr(e) for a caught decimal.InvalidOperation shows 'decimal.InvalidOperation' and type annotations work correctly; all five exception classes covered in this spec share __module__=='decimal'"
  category: identity
  kind: python_call_eq
  function: InvalidOperation.__module__.__eq__
  args: ["decimal"]
  expected: true

