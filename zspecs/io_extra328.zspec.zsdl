spec: io_extra328
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io module-level seek constants and open/open_code function attributes
# All test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0.
# io.SEEK_SET == 0; io.SEEK_CUR == 1; io.SEEK_END == 2
# io.SEEK_SET.__class__.__name__ == 'int'
# io.open.__name__ == 'open'; io.open.__module__ == '_io'
# io.open_code.__name__ == 'open_code'; io.open_code.__module__ == '_io'
# io.__version__ does not exist in CPython 3.14.3
# ---------------------------------------------------------------------------

invariant io_extra328.SEEK_SET.eq_zero:
  description: "io.SEEK_SET.__eq__(0) == True — SEEK_SET is the integer constant 0 used for absolute file positioning; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra328.SEEK_CUR.eq_one:
  description: "io.SEEK_CUR.__eq__(1) == True — SEEK_CUR is the integer constant 1 used for relative-to-current positioning; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: SEEK_CUR.__eq__
  args: [1]
  expected: true

invariant io_extra328.SEEK_END.eq_two:
  description: "io.SEEK_END.__eq__(2) == True — SEEK_END is the integer constant 2 used for end-relative positioning; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true

invariant io_extra328.SEEK_SET.class_name:
  description: "io.SEEK_SET.__class__.__name__ == 'int' — seek constants are plain int values; verified Python 3.14.3"
  category: classnames
  kind: python_call_eq
  function: SEEK_SET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra328.open.name:
  description: "io.open.__name__ == 'open' — the built-in open function exposed via io has __name__ 'open'; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

invariant io_extra328.open.module:
  description: "io.open.__module__ == '_io' — io.open is implemented in the C extension _io, not the pure-Python io wrapper; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra328.open_code.name:
  description: "io.open_code.__name__ == 'open_code' — the open_code function name attribute; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: open_code.__name__.__eq__
  args: ["open_code"]
  expected: true

invariant io_extra328.open_code.module:
  description: "io.open_code.__module__ == '_io' — open_code is implemented in the C extension _io; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: open_code.__module__.__eq__
  args: ["_io"]
  expected: true

# ---------------------------------------------------------------------------
# io seek constants — table form
# ---------------------------------------------------------------------------

table io_extra328.seek_constants:
  description: "io seek constant integer values: SEEK_SET (0), SEEK_CUR (1), SEEK_END (2)"
  kind: python_call_eq
  category: behavioral
  id_prefix: ioseek328

  columns: [id, function, args, expected]
  rows:
    - [seek_set_eq, SEEK_SET.__eq__, [0], true]
    - [seek_cur_eq, SEEK_CUR.__eq__, [1], true]
    - [seek_end_eq, SEEK_END.__eq__, [2], true]

# ---------------------------------------------------------------------------
# io.open and io.open_code function attributes — table form
# ---------------------------------------------------------------------------

table io_extra328.open_func_attrs:
  description: "io.open and io.open_code __name__ and __module__ attributes"
  kind: python_call_eq
  category: behavioral
  id_prefix: ioopen328

  columns: [id, function, args, expected]
  rows:
    - [open_name,      open.__name__.__eq__,      ["open"],      true]
    - [open_mod,       open.__module__.__eq__,     ["_io"],       true]
    - [opencode_name,  open_code.__name__.__eq__,  ["open_code"], true]
    - [opencode_mod,   open_code.__module__.__eq__, ["_io"],      true]
