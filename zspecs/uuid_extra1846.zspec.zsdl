spec: uuid_extra1846
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from: []
  not_derived_from: []
  notes:
    - "Arithmetic and comparison operator protocol checks for uuid module"
    - "Wave 570: __add__/__sub__/__mul__/__truediv__ and __gt__/__ge__/__le__/__ne__/__lt__/__eq__"
    - "UUID defines __eq__ and __lt__ for ordering but not the full complement"
  created_at: "2026-04-12"

table uuid_extra1846.arithmetic_operators:
  columns: [id, function, args, expected]
  rows:
    - ["uu1846-arith-001", "uuid.UUID.__dict__.__contains__", ["__add__"], false]
    - ["uu1846-arith-002", "uuid.UUID.__dict__.__contains__", ["__sub__"], false]
    - ["uu1846-arith-003", "uuid.UUID.__dict__.__contains__", ["__mul__"], false]
    - ["uu1846-arith-004", "uuid.UUID.__dict__.__contains__", ["__truediv__"], false]
    - ["uu1846-arith-005", "uuid.UUID.__dict__.__contains__", ["__floordiv__"], false]
    - ["uu1846-arith-006", "uuid.UUID.__dict__.__contains__", ["__mod__"], false]
    - ["uu1846-arith-007", "uuid.SafeUUID.__dict__.__contains__", ["__add__"], false]
    - ["uu1846-arith-008", "uuid.SafeUUID.__dict__.__contains__", ["__mul__"], false]

table uuid_extra1846.comparison_operators:
  columns: [id, function, args, expected]
  rows:
    - ["uu1846-cmp-001", "uuid.UUID.__dict__.__contains__", ["__eq__"], true]
    - ["uu1846-cmp-002", "uuid.UUID.__dict__.__contains__", ["__lt__"], true]
    - ["uu1846-cmp-003", "uuid.UUID.__dict__.__contains__", ["__gt__"], false]
    - ["uu1846-cmp-004", "uuid.UUID.__dict__.__contains__", ["__le__"], false]
    - ["uu1846-cmp-005", "uuid.UUID.__dict__.__contains__", ["__ge__"], false]
    - ["uu1846-cmp-006", "uuid.UUID.__dict__.__contains__", ["__ne__"], false]
    - ["uu1846-cmp-007", "uuid.UUID.__dict__.__contains__", ["__hash__"], true]
    - ["uu1846-cmp-008", "uuid.SafeUUID.__dict__.__contains__", ["__eq__"], false]

table uuid_extra1846.uuid_module_attrs:
  columns: [id, function, args, expected]
  rows:
    - ["uu1846-attr-001", "uuid.__dict__.__contains__", ["UUID"], true]
    - ["uu1846-attr-002", "uuid.__dict__.__contains__", ["SafeUUID"], true]
