spec: asyncio_extra94
version: ">=3.9"
backend: python_module(asyncio)
extends: asyncio_extra93

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
    - "CPython source: Lib/asyncio/exceptions.py"
  notes:
    - "This spec extends asyncio_extra93.zspec.zsdl."
    - "This spec covers: wave 254 theme — asyncio module identity (__name__, __package__, __loader__, __spec__) + asyncio exception classes (CancelledError, TimeoutError, InvalidStateError, SendfileNotAvailableError). NEW in extra94: asyncio.__name__=='asyncio'; asyncio.__package__=='asyncio'; asyncio.__loader__.__class__.__name__=='SourceFileLoader'; asyncio.__spec__.__class__.__name__=='ModuleSpec'; CancelledError.__name__=='CancelledError'; CancelledError.__module__=='asyncio.exceptions'; CancelledError.__bases__[0].__name__=='BaseException'; CancelledError.__mro__.__len__()==3; TimeoutError.__module__=='builtins'; TimeoutError.__bases__[0].__name__=='OSError'; TimeoutError.__mro__.__len__()==5; InvalidStateError.__module__=='asyncio.exceptions'; InvalidStateError.__bases__[0].__name__=='Exception'; InvalidStateError.__mro__.__len__()==4; SendfileNotAvailableError.__module__=='asyncio.exceptions'; SendfileNotAvailableError.__bases__[0].__name__=='RuntimeError'; SendfileNotAvailableError.__mro__.__len__()==5. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__name__ == 'asyncio'. The module's __name__ attribute is 'asyncio'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__package__ == 'asyncio'. The module's __package__ attribute is 'asyncio' (it is a package). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__loader__.__class__.__name__ == 'SourceFileLoader'. asyncio is loaded as a Python source package. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__spec__.__class__.__name__ == 'ModuleSpec'. The module spec is a ModuleSpec instance. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.CancelledError.__module__ == 'asyncio.exceptions'. CancelledError is defined in Lib/asyncio/exceptions.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.CancelledError.__bases__[0].__name__ == 'BaseException'. CancelledError inherits directly from BaseException (not Exception). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.CancelledError.__mro__.__len__() == 3. MRO is [CancelledError, BaseException, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TimeoutError.__module__ == 'builtins'. asyncio.TimeoutError is the built-in TimeoutError (re-exported from asyncio). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TimeoutError.__bases__[0].__name__ == 'OSError'. TimeoutError inherits from OSError (builtin hierarchy). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TimeoutError.__mro__.__len__() == 5. MRO is [TimeoutError, OSError, Exception, BaseException, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.InvalidStateError.__module__ == 'asyncio.exceptions'. InvalidStateError is defined in Lib/asyncio/exceptions.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.InvalidStateError.__bases__[0].__name__ == 'Exception'. InvalidStateError inherits from Exception. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.InvalidStateError.__mro__.__len__() == 4. MRO is [InvalidStateError, Exception, BaseException, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.SendfileNotAvailableError.__module__ == 'asyncio.exceptions'. SendfileNotAvailableError is defined in Lib/asyncio/exceptions.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.SendfileNotAvailableError.__bases__[0].__name__ == 'RuntimeError'. SendfileNotAvailableError inherits from RuntimeError. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.SendfileNotAvailableError.__mro__.__len__() == 5. MRO is [SendfileNotAvailableError, RuntimeError, Exception, BaseException, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio module string identity — extra94
#
# Wave 254 theme: asyncio module identity + exception classes.
#
# asyncio.__name__ == 'asyncio'
# asyncio.__package__ == 'asyncio'
# ---------------------------------------------------------------------------

table asyncio_extra94.module_string_identity:
  description: "asyncio module string identity checks in asynciomodule94 namespace — wave 254 theme: asyncio module identity and exception classes; __name__.__eq__('asyncio')==True; __package__.__eq__('asyncio')==True; asyncio is a package so __name__ and __package__ are identical; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciomodule94

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name,    __name__.__eq__,    ["asyncio"], true, "__name__ == 'asyncio' — module name; verified with Python 3.14.3"]
    - [mod_package, __package__.__eq__, ["asyncio"], true, "__package__ == 'asyncio' — module is a package, __package__ equals __name__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio __spec__ and __loader__ class names — extra94
#
# asyncio.__spec__.__class__.__name__ == 'ModuleSpec'
# asyncio.__loader__.__class__.__name__ == 'SourceFileLoader'
# asyncio.__doc__.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table asyncio_extra94.spec_and_loader_class_names:
  description: "asyncio __spec__ and __loader__ class name checks in asynciomodule94 namespace — wave 254 theme: asyncio module identity; __spec__.__class__.__name__.__eq__('ModuleSpec')==True; __loader__.__class__.__name__.__eq__('SourceFileLoader')==True (asyncio is a source package); __doc__.__class__.__name__.__eq__('str')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciomodule94a

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name,   "__spec__.__class__.__name__.__eq__",   ["ModuleSpec"],      true, "__spec__.__class__.__name__ == 'ModuleSpec' — module spec is a ModuleSpec instance; verified with Python 3.14.3"]
    - [loader_class_name, "__loader__.__class__.__name__.__eq__", ["SourceFileLoader"], true, "__loader__.__class__.__name__ == 'SourceFileLoader' — asyncio is loaded as a Python source package; verified with Python 3.14.3"]
    - [doc_class_name,    "__doc__.__class__.__name__.__eq__",    ["str"],             true, "__doc__.__class__.__name__ == 'str' — module docstring is a str; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio exception __name__ and __module__ equality — extra94
#
# CancelledError.__name__ == 'CancelledError', __module__ == 'asyncio.exceptions'
# TimeoutError.__name__ == 'TimeoutError', __module__ == 'builtins'
# InvalidStateError.__name__ == 'InvalidStateError', __module__ == 'asyncio.exceptions'
# SendfileNotAvailableError.__name__ == 'SendfileNotAvailableError', __module__ == 'asyncio.exceptions'
# ---------------------------------------------------------------------------

table asyncio_extra94.exception_name_and_module:
  description: "asyncio exception __name__ and __module__ equality checks in asynciomodule94 namespace — wave 254 theme: asyncio exception classes; CancelledError.__name__.__eq__('CancelledError')==True; CancelledError.__module__.__eq__('asyncio.exceptions')==True; TimeoutError.__name__.__eq__('TimeoutError')==True; TimeoutError.__module__.__eq__('builtins')==True (builtin TimeoutError re-exported); InvalidStateError.__module__.__eq__('asyncio.exceptions')==True; SendfileNotAvailableError.__module__.__eq__('asyncio.exceptions')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciomodule94b

  columns: [id, function, args, expected, description]
  rows:
    - [cancelled_name,     CancelledError.__name__.__eq__,                  ["CancelledError"],              true, "CancelledError.__name__ == 'CancelledError' — exception class name; verified with Python 3.14.3"]
    - [cancelled_module,   CancelledError.__module__.__eq__,                ["asyncio.exceptions"],          true, "CancelledError.__module__ == 'asyncio.exceptions' — defined in Lib/asyncio/exceptions.py; verified with Python 3.14.3"]
    - [timeout_name,       TimeoutError.__name__.__eq__,                    ["TimeoutError"],                true, "TimeoutError.__name__ == 'TimeoutError' — builtin TimeoutError re-exported by asyncio; verified with Python 3.14.3"]
    - [timeout_module,     TimeoutError.__module__.__eq__,                  ["builtins"],                   true, "TimeoutError.__module__ == 'builtins' — asyncio.TimeoutError is the builtin TimeoutError; verified with Python 3.14.3"]
    - [invalid_name,       InvalidStateError.__name__.__eq__,               ["InvalidStateError"],           true, "InvalidStateError.__name__ == 'InvalidStateError' — exception class name; verified with Python 3.14.3"]
    - [invalid_module,     InvalidStateError.__module__.__eq__,             ["asyncio.exceptions"],          true, "InvalidStateError.__module__ == 'asyncio.exceptions' — defined in Lib/asyncio/exceptions.py; verified with Python 3.14.3"]
    - [sendfile_name,      SendfileNotAvailableError.__name__.__eq__,       ["SendfileNotAvailableError"],   true, "SendfileNotAvailableError.__name__ == 'SendfileNotAvailableError' — exception class name; verified with Python 3.14.3"]
    - [sendfile_module,    SendfileNotAvailableError.__module__.__eq__,     ["asyncio.exceptions"],          true, "SendfileNotAvailableError.__module__ == 'asyncio.exceptions' — defined in Lib/asyncio/exceptions.py; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio exception __bases__[0].__name__ and __mro__.__len__() values — extra94
#
# CancelledError.__bases__[0].__name__ == 'BaseException', __mro__.__len__() == 3
# TimeoutError.__bases__[0].__name__ == 'OSError', __mro__.__len__() == 5
# InvalidStateError.__bases__[0].__name__ == 'Exception', __mro__.__len__() == 4
# SendfileNotAvailableError.__bases__[0].__name__ == 'RuntimeError', __mro__.__len__() == 5
# ---------------------------------------------------------------------------

table asyncio_extra94.exception_bases_and_mro:
  description: "asyncio exception __bases__[0].__name__ and __mro__.__len__() checks in asynciomodule94 namespace — wave 254 theme: asyncio exception classes; CancelledError.__bases__[0].__name__.__eq__('BaseException')==True (inherits directly from BaseException, not Exception); CancelledError.__mro__.__len__()==3; TimeoutError.__bases__[0].__name__.__eq__('OSError')==True; TimeoutError.__mro__.__len__()==5; InvalidStateError.__bases__[0].__name__.__eq__('Exception')==True; InvalidStateError.__mro__.__len__()==4; SendfileNotAvailableError.__bases__[0].__name__.__eq__('RuntimeError')==True; SendfileNotAvailableError.__mro__.__len__()==5; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciomodule94c

  columns: [id, function, args, expected, description]
  rows:
    - [cancelled_bases0,   "CancelledError.__bases__[0].__name__.__eq__",            ["BaseException"],   true, "CancelledError.__bases__[0].__name__ == 'BaseException' — inherits directly from BaseException; verified with Python 3.14.3"]
    - [cancelled_mro_len,  CancelledError.__mro__.__len__,                           [],                  3,    "CancelledError.__mro__.__len__() == 3 — MRO is [CancelledError, BaseException, object]; verified with Python 3.14.3"]
    - [timeout_bases0,     "TimeoutError.__bases__[0].__name__.__eq__",              ["OSError"],         true, "TimeoutError.__bases__[0].__name__ == 'OSError' — builtin TimeoutError inherits from OSError; verified with Python 3.14.3"]
    - [timeout_mro_len,    TimeoutError.__mro__.__len__,                             [],                  5,    "TimeoutError.__mro__.__len__() == 5 — MRO is [TimeoutError, OSError, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [invalid_bases0,     "InvalidStateError.__bases__[0].__name__.__eq__",         ["Exception"],       true, "InvalidStateError.__bases__[0].__name__ == 'Exception' — inherits from Exception; verified with Python 3.14.3"]
    - [invalid_mro_len,    InvalidStateError.__mro__.__len__,                        [],                  4,    "InvalidStateError.__mro__.__len__() == 4 — MRO is [InvalidStateError, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [sendfile_bases0,    "SendfileNotAvailableError.__bases__[0].__name__.__eq__", ["RuntimeError"],    true, "SendfileNotAvailableError.__bases__[0].__name__ == 'RuntimeError' — inherits from RuntimeError; verified with Python 3.14.3"]
    - [sendfile_mro_len,   SendfileNotAvailableError.__mro__.__len__,                [],                  5,    "SendfileNotAvailableError.__mro__.__len__() == 5 — MRO is [SendfileNotAvailableError, RuntimeError, Exception, BaseException, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra94
# ---------------------------------------------------------------------------

invariant asyncio_extra94.module_name_is_asyncio:
  description: "asyncio.__name__.__eq__('asyncio') returns True — the module's __name__ attribute is 'asyncio'; asyncio is a package so __name__ and __package__ are both 'asyncio'; this is the canonical identity check for the asyncio module; NEW in extra94: first standalone __name__ invariant for asyncio module in asynciomodule94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra94.loader_is_SourceFileLoader:
  description: "asyncio.__loader__.__class__.__name__.__eq__('SourceFileLoader') returns True — asyncio is a Python source package loaded by importlib.machinery.SourceFileLoader; this contrasts with frozen modules (which use FrozenImporter) or C extension modules; NEW in extra94: first standalone __loader__ class name invariant for asyncio in asynciomodule94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "__loader__.__class__.__name__.__eq__"
  args: ["SourceFileLoader"]
  expected: true

invariant asyncio_extra94.CancelledError_base_is_BaseException:
  description: "asyncio.CancelledError.__bases__[0].__name__.__eq__('BaseException') returns True — CancelledError inherits directly from BaseException (not Exception); this is notable because most application exceptions inherit from Exception; making CancelledError a BaseException subclass means it won't be caught by bare 'except Exception' handlers; NEW in extra94: first standalone __bases__ invariant for CancelledError in asynciomodule94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "CancelledError.__bases__[0].__name__.__eq__"
  args: ["BaseException"]
  expected: true

invariant asyncio_extra94.TimeoutError_module_is_builtins:
  description: "asyncio.TimeoutError.__module__.__eq__('builtins') returns True — asyncio.TimeoutError is simply the Python builtin TimeoutError re-exported by the asyncio namespace; its __module__ is 'builtins', not 'asyncio.exceptions'; this contrasts with CancelledError, InvalidStateError, and SendfileNotAvailableError which are defined in asyncio.exceptions; NEW in extra94: first standalone __module__ invariant for TimeoutError in asynciomodule94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant asyncio_extra94.SendfileNotAvailableError_base_is_RuntimeError:
  description: "asyncio.SendfileNotAvailableError.__bases__[0].__name__.__eq__('RuntimeError') returns True — SendfileNotAvailableError inherits from RuntimeError; it is raised when the sendfile syscall is not available on the platform or transport; its __mro__.__len__() is 5 (same as TimeoutError); NEW in extra94: first standalone __bases__ invariant for SendfileNotAvailableError in asynciomodule94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "SendfileNotAvailableError.__bases__[0].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true
