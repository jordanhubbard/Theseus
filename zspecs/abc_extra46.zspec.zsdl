spec: abc_extra46
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra45.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all five, abstractproperty lengths, ABCMeta.register qualname lengths, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2), various qualname length tables, ABCMeta MRO entries, ABC/__abstractmethods__/__class__/__name__=='frozenset', ABC/__abstractmethods__/__len__()==0, ABCMeta/__call__/__qualname__=='type.__call__', class qualname string equality, abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta', abstractproperty/__mro__.__len__()==3, abstractclassmethod/__mro__.__len__()==3, abstractstaticmethod/__mro__.__len__()==3 (extra40), __class__.__qualname__ string equality and __len__() for all abc exports (extra41–extra43), abstractmethod/__doc__/__class__/__name__=='str', ABCMeta/__doc__/__class__.__name__=='str', ABC/__doc__/__class__.__name__=='str', get_cache_token/__doc__/__class__.__name__=='str', abstractproperty/__doc__/__class__.__name__=='str', abc module/__doc__/__class__.__name__=='str', abc/__doc__/__class__.__qualname__=='str', abstractmethod/__doc__/__class__.__qualname__=='str', ABCMeta/__doc__/__class__.__module__=='builtins', abstractmethod/__doc__/__class__.__module__=='builtins' (extra44), ABCMeta/__subclasshook__/__qualname__.__eq__('ABCMeta.__subclasshook__'), ABC/__subclasshook__/__qualname__.__eq__('ABC.__subclasshook__'), ABCMeta/__instancecheck__/__qualname__.__len__()==25, ABCMeta/__subclasscheck__/__qualname__.__len__()==25, ABCMeta/__instancecheck__/__qualname__.__eq__('ABCMeta.__instancecheck__'), ABCMeta/__subclasscheck__/__qualname__.__eq__('ABCMeta.__subclasscheck__'), abstractclassmethod/__doc__/__class__/__name__=='str', abstractstaticmethod/__doc__/__class__/__name__=='str', update_abstractmethods/__doc__/__class__/__name__=='str' (extra45). abstractmethod/__code__/__class__/__name__.__len__()==4 (extra31 — length only, not string equality)."
    - "This spec covers: ABCMeta.register/__doc__/__class__/__name__=='str'; ABCMeta.__subclasshook__/__doc__/__class__/__name__=='str'; ABCMeta.__instancecheck__/__doc__/__class__/__name__=='str'; ABCMeta.__subclasscheck__/__doc__/__class__/__name__=='str'; ABC.__subclasshook__/__doc__/__class__/__name__=='str'; ABC.__init_subclass__/__doc__/__class__/__name__=='str'; abstractmethod/__code__/__class__/__name__=='code' (string equality, complementing the length check in extra31)."
    - "abc.ABCMeta.register.__doc__.__class__.__name__ == 'str'. ABCMeta.register is a Python method defined in Lib/abc.py that registers a virtual subclass. Its docstring is a plain Python string; __doc__.__class__.__name__ == 'str'. This extends the __doc__ survey begun in extra44 (which covered ABCMeta as a class) to ABCMeta's individual methods. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasshook__.__doc__.__class__.__name__ == 'str'. ABCMeta.__subclasshook__ is a classmethod defined in Lib/abc.py; its docstring describes the issubclass() customization hook. The docstring is a plain Python string; __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__doc__.__class__.__name__ == 'str'. ABCMeta.__instancecheck__ is defined in the _abc C extension; its docstring is exposed as a plain Python string accessible via __doc__. __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__doc__.__class__.__name__ == 'str'. ABCMeta.__subclasscheck__ is defined in the _abc C extension; its docstring is exposed as a plain Python string. __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__subclasshook__.__doc__.__class__.__name__ == 'str'. ABC inherits __subclasshook__ from ABCMeta. The method's docstring is a plain Python string; __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__init_subclass__.__doc__.__class__.__name__ == 'str'. ABC.__init_subclass__ is a classmethod that ABC inherits from object (or defines on ABC); its docstring is a plain Python string. __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.__class__.__name__ == 'code'. abstractmethod is callable; its __code__ attribute is the code object for the abstractmethod function body. Python's code object type has __class__.__name__ == 'code'. Prior spec extra31 captured the length (4 chars: 'code'); this spec captures the full string equality. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta method __doc__.__class__.__name__ string equality — extra46
#
# Prior specs extra44 and extra45 surveyed __doc__.__class__.__name__ for
# all abc module-level exports (ABC, ABCMeta, abstractmethod, etc.) as class
# objects. Extra46 extends the __doc__ survey into the method dimension:
# individual methods on ABCMeta and ABC have docstrings that are plain Python
# str instances, giving __doc__.__class__.__name__ == 'str' for each.
#
# The six methods covered here are:
#   ABCMeta.register        — registers a virtual subclass (Lib/abc.py)
#   ABCMeta.__subclasshook__ — classmethod for issubclass() customization (Lib/abc.py)
#   ABCMeta.__instancecheck__ — hook for isinstance() (Modules/_abc.c)
#   ABCMeta.__subclasscheck__ — hook for issubclass() (Modules/_abc.c)
#   ABC.__subclasshook__    — ABC's own binding of the subclasshook classmethod
#   ABC.__init_subclass__   — classmethod inherited from object or defined on ABC
# ---------------------------------------------------------------------------

table abc_extra46.abcmeta_method_doc_class_name_eq:
  description: "abc.ABCMeta and ABC method __doc__.__class__.__name__ string equality in extra46 namespace — all method docstrings are str instances"
  kind: python_call_eq
  category: class_names
  id_prefix: abcdoc46methdocname

  columns: [id, function, args, expected, description]
  rows:
    - [ABCMeta_register,        ABCMeta.register.__doc__.__class__.__name__.__eq__,        ["str"], true, "ABCMeta.register.__doc__.__class__.__name__ == 'str' — register() is defined in Lib/abc.py; its docstring is a plain Python string"]
    - [ABCMeta_subclasshook,    ABCMeta.__subclasshook__.__doc__.__class__.__name__.__eq__, ["str"], true, "ABCMeta.__subclasshook__.__doc__.__class__.__name__ == 'str' — classmethod for issubclass() customization; docstring is a plain Python string"]
    - [ABCMeta_instancecheck,   ABCMeta.__instancecheck__.__doc__.__class__.__name__.__eq__, ["str"], true, "ABCMeta.__instancecheck__.__doc__.__class__.__name__ == 'str' — isinstance() hook defined in _abc C extension; docstring exposed as plain Python string"]
    - [ABCMeta_subclasscheck,   ABCMeta.__subclasscheck__.__doc__.__class__.__name__.__eq__, ["str"], true, "ABCMeta.__subclasscheck__.__doc__.__class__.__name__ == 'str' — issubclass() hook defined in _abc C extension; docstring exposed as plain Python string"]
    - [ABC_subclasshook,        ABC.__subclasshook__.__doc__.__class__.__name__.__eq__,     ["str"], true, "ABC.__subclasshook__.__doc__.__class__.__name__ == 'str' — ABC inherits __subclasshook__ from ABCMeta; docstring is a plain Python string"]
    - [ABC_init_subclass,       ABC.__init_subclass__.__doc__.__class__.__name__.__eq__,    ["str"], true, "ABC.__init_subclass__.__doc__.__class__.__name__ == 'str' — classmethod inherited by ABC; docstring is a plain Python string"]

# ---------------------------------------------------------------------------
# abc.abstractmethod.__code__.__class__.__name__ string equality — extra46
#
# abstractmethod is a callable whose __code__ attribute is the Python code
# object for the abstractmethod function body. The code object type has
# __class__.__name__ == 'code'. Prior spec extra31 captured the length of
# this string (4 chars via __len__()), but not the full string equality.
# Extra46 supplies the complementary string equality check:
#   abstractmethod.__code__.__class__.__name__.__eq__('code') → True
# This is an important behavioral contract: the presence of a __code__
# attribute on abstractmethod and its type ('code') confirm that
# abstractmethod is implemented as a Python-level function, not a C builtin.
# ---------------------------------------------------------------------------

invariant abc_extra46.abstractmethod_code_class_name_eq:
  description: "abc.abstractmethod.__code__.__class__.__name__ == 'code' — abstractmethod's __code__ attribute is a Python code object; the code type has __class__.__name__ == 'code' (4 chars; length captured in extra31, string equality first captured here)"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__code__.__class__.__name__.__eq__
  args: ["code"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — extra46
# ---------------------------------------------------------------------------

invariant abc_extra46.ABCMeta_register_doc_class_name_eq:
  description: "abc.ABCMeta.register.__doc__.__class__.__name__ == 'str' — register() method has a docstring; Python stores it as a plain str; __class__.__name__ == 'str'"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.register.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra46.ABCMeta_subclasshook_doc_class_name_eq:
  description: "abc.ABCMeta.__subclasshook__.__doc__.__class__.__name__ == 'str' — classmethod for customizing issubclass(); docstring is a plain Python string; __class__.__name__ == 'str'"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__subclasshook__.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra46.ABCMeta_instancecheck_doc_class_name_eq:
  description: "abc.ABCMeta.__instancecheck__.__doc__.__class__.__name__ == 'str' — isinstance() hook defined in _abc C extension; C-level docstring exposed as plain Python string"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra46.ABCMeta_subclasscheck_doc_class_name_eq:
  description: "abc.ABCMeta.__subclasscheck__.__doc__.__class__.__name__ == 'str' — issubclass() hook defined in _abc C extension; C-level docstring exposed as plain Python string"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__subclasscheck__.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra46.ABC_subclasshook_doc_class_name_eq:
  description: "abc.ABC.__subclasshook__.__doc__.__class__.__name__ == 'str' — ABC's binding of the __subclasshook__ classmethod has a docstring; it is a plain Python string"
  category: class_names
  kind: python_call_eq
  function: ABC.__subclasshook__.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra46.ABC_init_subclass_doc_class_name_eq:
  description: "abc.ABC.__init_subclass__.__doc__.__class__.__name__ == 'str' — ABC.__init_subclass__ is a classmethod with a docstring stored as a plain Python string"
  category: class_names
  kind: python_call_eq
  function: ABC.__init_subclass__.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
