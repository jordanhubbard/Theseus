spec: hashlib_extra871
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - hashlib
  not_derived_from:
    - hmac
    - secrets
  notes:
    - Covers sha224, sha384, sha512 method qualnames via attribute chain inspection
  created_at: "2026-04-12"

table hashlib_extra871.sha512_qualnames:
  description: Verify qualnames of sha512 hash object methods
  kind: python_call_eq
  category: qualname
  id_prefix: hl871sh
  columns: [id, function, args, expected]
  rows:
    - [hl871sh001, hashlib.sha512.update.__qualname__.__eq__, ["sha512.update"], true]
    - [hl871sh002, hashlib.sha512.digest.__qualname__.__eq__, ["sha512.digest"], true]
    - [hl871sh003, hashlib.sha512.hexdigest.__qualname__.__eq__, ["sha512.hexdigest"], true]
    - [hl871sh004, hashlib.sha512.copy.__qualname__.__eq__, ["sha512.copy"], true]

table hashlib_extra871.sha384_qualnames:
  description: Verify qualnames of sha384 hash object methods
  kind: python_call_eq
  category: qualname
  id_prefix: hl871s3
  columns: [id, function, args, expected]
  rows:
    - [hl871s3001, hashlib.sha384.update.__qualname__.__eq__, ["sha384.update"], true]
    - [hl871s3002, hashlib.sha384.digest.__qualname__.__eq__, ["sha384.digest"], true]
    - [hl871s3003, hashlib.sha384.hexdigest.__qualname__.__eq__, ["sha384.hexdigest"], true]
    - [hl871s3004, hashlib.sha384.copy.__qualname__.__eq__, ["sha384.copy"], true]

table hashlib_extra871.sha224_qualnames:
  description: Verify qualnames of sha224 hash object methods
  kind: python_call_eq
  category: qualname
  id_prefix: hl871s2
  columns: [id, function, args, expected]
  rows:
    - [hl871s2001, hashlib.sha224.update.__qualname__.__eq__, ["sha224.update"], true]
    - [hl871s2002, hashlib.sha224.digest.__qualname__.__eq__, ["sha224.digest"], true]
    - [hl871s2003, hashlib.sha224.hexdigest.__qualname__.__eq__, ["sha224.hexdigest"], true]
    - [hl871s2004, hashlib.sha224.copy.__qualname__.__eq__, ["sha224.copy"], true]
