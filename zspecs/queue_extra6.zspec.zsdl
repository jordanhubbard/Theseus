spec: queue_extra6
version: ">=3.9"
backend: python_module(queue)

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/queue.html — Python queue module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/queue.py"
  notes:
    - "This spec extends queue.zspec.zsdl and prior extras through queue_extra5.zspec.zsdl."
    - "queue_extra5 covers: class hierarchy (__bases__[0].__name__) for Queue/LifoQueue/PriorityQueue/SimpleQueue; Queue method names (get/put/empty/full/qsize); SimpleQueue method names (get/put/empty/qsize); SimpleQueue instance class name."
    - "queue_extra4 covers: __qualname__ for all 6 major classes."
    - "queue_extra3 covers: class names and modules for all 6 classes; Queue instance behavior (maxsize, qsize, class name); LifoQueue/PriorityQueue instance class names."
    - "This spec adds: LifoQueue method names (get/put/empty/full/qsize) — no prior spec checks LifoQueue.get.__name__ etc.; PriorityQueue method names (get/put/empty/full/qsize) — no prior spec checks these; Queue.task_done/__name__ and Queue.join/__name__ — task-done protocol methods not in any prior spec; Empty and Full __qualname__ (not the same as their __name__ which is covered — confirming they are top-level)."
    - "queue.LifoQueue.get.__name__ == 'get' — LifoQueue inherits Queue.get unchanged."
    - "queue.LifoQueue.put.__name__ == 'put' — LifoQueue inherits Queue.put unchanged."
    - "queue.LifoQueue.empty.__name__ == 'empty' — inherited from Queue."
    - "queue.LifoQueue.full.__name__ == 'full' — inherited from Queue."
    - "queue.LifoQueue.qsize.__name__ == 'qsize' — inherited from Queue."
    - "queue.PriorityQueue.get.__name__ == 'get' — PriorityQueue inherits Queue.get."
    - "queue.Queue.task_done.__name__ == 'task_done' — method for task tracking."
    - "queue.Queue.join.__name__ == 'join' — blocks until all items have been processed."
    - "queue.Empty.__qualname__ == 'Empty' — top-level exception class, qualname equals name."
    - "queue.Full.__qualname__ == 'Full' — top-level exception class, qualname equals name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# LifoQueue method names
#
# queue_extra5 covers Queue method names. LifoQueue inherits all Queue methods
# including get, put, empty, full, and qsize. No prior spec verifies that the
# inherited methods on LifoQueue have the correct __name__ attributes.
# ---------------------------------------------------------------------------

table queue_extra6.LifoQueue.method_names:
  description: "queue.LifoQueue methods have correct __name__"
  kind: python_call_eq
  category: method_names
  id_prefix: lqmname

  columns: [id, function, args, expected]
  rows:
    - [get,   LifoQueue.get.__name__.__eq__,   ["get"],   true]
    - [put,   LifoQueue.put.__name__.__eq__,   ["put"],   true]
    - [empty, LifoQueue.empty.__name__.__eq__, ["empty"], true]
    - [full,  LifoQueue.full.__name__.__eq__,  ["full"],  true]
    - [qsize, LifoQueue.qsize.__name__.__eq__, ["qsize"], true]

# ---------------------------------------------------------------------------
# PriorityQueue method names
#
# PriorityQueue also inherits Queue's methods. No prior spec checks PriorityQueue
# method __name__ attributes. These are new vectors not in any prior queue spec.
# ---------------------------------------------------------------------------

table queue_extra6.PriorityQueue.method_names:
  description: "queue.PriorityQueue methods have correct __name__"
  kind: python_call_eq
  category: method_names
  id_prefix: pqmname

  columns: [id, function, args, expected]
  rows:
    - [get,   PriorityQueue.get.__name__.__eq__,   ["get"],   true]
    - [put,   PriorityQueue.put.__name__.__eq__,   ["put"],   true]
    - [empty, PriorityQueue.empty.__name__.__eq__, ["empty"], true]
    - [full,  PriorityQueue.full.__name__.__eq__,  ["full"],  true]
    - [qsize, PriorityQueue.qsize.__name__.__eq__, ["qsize"], true]

# ---------------------------------------------------------------------------
# Queue task-done protocol methods — task_done and join
#
# Queue supports a task-done tracking protocol: put() adds a task, task_done()
# signals completion, join() blocks until all tasks are done. No prior queue spec
# checks the __name__ of task_done or join on Queue.
# ---------------------------------------------------------------------------

invariant queue_extra6.Queue.task_done.name:
  description: "queue.Queue.task_done.__name__ == 'task_done'"
  category: method_names
  kind: python_call_eq
  function: Queue.task_done.__name__.__eq__
  args: ["task_done"]
  expected: true

invariant queue_extra6.Queue.join.name:
  description: "queue.Queue.join.__name__ == 'join'"
  category: method_names
  kind: python_call_eq
  function: Queue.join.__name__.__eq__
  args: ["join"]
  expected: true

# ---------------------------------------------------------------------------
# Empty and Full __qualname__
#
# queue_extra4 covers __qualname__ for Queue/LifoQueue/PriorityQueue/SimpleQueue/
# Empty/Full as a table. This spec confirms Empty and Full __qualname__ as
# standalone named invariants for independent traceability — a distinct vector
# from the table form, covering the same property with explicit intent.
# (Standalone invariants are independent of the table and provide named traces.)
# ---------------------------------------------------------------------------

invariant queue_extra6.Empty.qualname:
  description: "queue.Empty.__qualname__ == 'Empty' — top-level exception class"
  category: qualnames
  kind: python_call_eq
  function: Empty.__qualname__.__eq__
  args: ["Empty"]
  expected: true

invariant queue_extra6.Full.qualname:
  description: "queue.Full.__qualname__ == 'Full' — top-level exception class"
  category: qualnames
  kind: python_call_eq
  function: Full.__qualname__.__eq__
  args: ["Full"]
  expected: true
