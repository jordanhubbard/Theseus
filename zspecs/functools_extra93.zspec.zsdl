spec: functools_extra93
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra92

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra92.zspec.zsdl."
    - "This spec covers: functools callable __qualname__ string equality — whether each export has the expected qualified name string (Wave 250)."
    - "functools.reduce.__qualname__ == 'reduce' — C builtin in _functoolsmodule.c; __qualname__ is 'reduce'. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__qualname__ == 'cmp_to_key' — C builtin in _functoolsmodule.c; __qualname__ is 'cmp_to_key'. Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache' — pure-Python function in Lib/functools.py; __qualname__ is 'lru_cache'. Verified with Python 3.14.3."
    - "functools.partial.__qualname__ == 'partial' — C extension type in _functoolsmodule.c; __qualname__ is 'partial'. Verified with Python 3.14.3."
    - "functools.partialmethod.__qualname__ == 'partialmethod' — pure-Python class in Lib/functools.py; __qualname__ is 'partialmethod'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__qualname__ == 'update_wrapper' — pure-Python function in Lib/functools.py; __qualname__ is 'update_wrapper'. Verified with Python 3.14.3."
    - "functools.wraps.__qualname__ == 'wraps' — pure-Python function in Lib/functools.py; __qualname__ is 'wraps'. Verified with Python 3.14.3."
    - "functools.total_ordering.__qualname__ == 'total_ordering' — pure-Python function in Lib/functools.py; __qualname__ is 'total_ordering'. Verified with Python 3.14.3."
    - "functools.singledispatch.__qualname__ == 'singledispatch' — pure-Python function in Lib/functools.py; __qualname__ is 'singledispatch'. Verified with Python 3.14.3."
    - "functools.cached_property.__qualname__ == 'cached_property' — pure-Python class in Lib/functools.py; __qualname__ is 'cached_property'. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a module-level tuple constant; __class__.__name__ is 'tuple'. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' — WRAPPER_UPDATES is a module-level tuple constant; __class__.__name__ is 'tuple'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# C builtin qualnames: reduce and cmp_to_key __qualname__ strings
#
# Wave 250 theme: functools callable __qualname__ string equality — C builtins.
#
# functools.reduce.__qualname__.__eq__('reduce')           == True
# functools.cmp_to_key.__qualname__.__eq__('cmp_to_key')   == True
#
# Prior spec extra92 checked __class__.__name__. This spec (extra93) checks __qualname__. New to extra93.
# ---------------------------------------------------------------------------

table functools_extra93.c_builtin_qualnames:
  description: "reduce/cmp_to_key __qualname__==reduce/cmp_to_key; C builtins from _functoolsmodule.c; wave 250; new to extra93"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsqualstr93

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_qualname_eq_reduce,
       reduce.__qualname__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — reduce is a C builtin function in Modules/_functoolsmodule.c; for C builtins __qualname__ is identical to __name__; __qualname__ is 'reduce' (6 chars); str.__eq__('reduce') returns True; prior spec extra92 checked reduce.__class__.__name__; this spec (extra93) checks __qualname__; new to extra93"]
    - [cmp_to_key_qualname_eq_cmp_to_key,
       cmp_to_key.__qualname__.__eq__,
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__qualname__.__eq__('cmp_to_key') == True — cmp_to_key is a C builtin function in Modules/_functoolsmodule.c; for C builtins __qualname__ is identical to __name__; __qualname__ is 'cmp_to_key' (10 chars); str.__eq__('cmp_to_key') returns True; prior spec extra92 checked cmp_to_key.__class__.__name__; this spec (extra93) checks __qualname__; new to extra93"]
    - [reduce_qualname_ne_cmp_to_key,
       reduce.__qualname__.__eq__,
       ["cmp_to_key"],
       false,
       "functools.reduce.__qualname__.__eq__('cmp_to_key') == False — reduce.__qualname__ is 'reduce', not 'cmp_to_key'; each callable has a unique __qualname__; str.__eq__('cmp_to_key') returns False; confirms __qualname__ distinguishes reduce from cmp_to_key; new to extra93"]
    - [lru_cache_qualname_eq_lru_cache,
       lru_cache.__qualname__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — lru_cache is a pure-Python function defined in Lib/functools.py; as a module-level function __qualname__ equals __name__; __qualname__ is 'lru_cache' (9 chars); str.__eq__('lru_cache') returns True; new to extra93"]

# ---------------------------------------------------------------------------
# Type class qualnames: partial, partialmethod, cached_property __qualname__ strings
#
# Wave 250 theme: functools callable __qualname__ string equality — type classes.
#
# functools.partial.__qualname__.__eq__('partial')               == True
# functools.partialmethod.__qualname__.__eq__('partialmethod')   == True
# functools.cached_property.__qualname__.__eq__('cached_property') == True
#
# No prior functools spec checks __qualname__ for type classes via functoolsqualstr93. New to extra93.
# ---------------------------------------------------------------------------

table functools_extra93.type_class_qualnames:
  description: "partial/partialmethod/cached_property __qualname__==partial/partialmethod/cached_property; type classes; wave 250; new to extra93"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsqualstr93

  columns: [id, function, args, expected, description]
  rows:
    - [partial_qualname_eq_partial,
       partial.__qualname__.__eq__,
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — partial is a C extension type defined in Modules/_functoolsmodule.c; as a module-level class __qualname__ equals __name__; __qualname__ is 'partial' (7 chars); str.__eq__('partial') returns True; prior spec extra92 checked partial.__class__.__name__; this spec (extra93) checks __qualname__; new to extra93"]
    - [partialmethod_qualname_eq_partialmethod,
       partialmethod.__qualname__.__eq__,
       ["partialmethod"],
       true,
       "functools.partialmethod.__qualname__.__eq__('partialmethod') == True — partialmethod is a pure-Python class defined in Lib/functools.py; as a module-level class __qualname__ equals __name__; __qualname__ is 'partialmethod' (13 chars); str.__eq__('partialmethod') returns True; prior spec extra92 checked partialmethod.__class__.__name__; this spec (extra93) checks __qualname__; new to extra93"]
    - [cached_property_qualname_eq_cached_property,
       cached_property.__qualname__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__qualname__.__eq__('cached_property') == True — cached_property is a pure-Python class defined in Lib/functools.py; as a module-level class __qualname__ equals __name__; __qualname__ is 'cached_property' (15 chars); str.__eq__('cached_property') returns True; prior spec extra92 checked cached_property.__class__.__name__; this spec (extra93) checks __qualname__; new to extra93"]
    - [partial_qualname_ne_partialmethod,
       partial.__qualname__.__eq__,
       ["partialmethod"],
       false,
       "functools.partial.__qualname__.__eq__('partialmethod') == False — partial.__qualname__ is 'partial', not 'partialmethod'; each callable has a unique __qualname__; str.__eq__('partialmethod') returns False; confirms __qualname__ distinguishes partial from partialmethod; new to extra93"]

# ---------------------------------------------------------------------------
# Python function qualnames group 1: update_wrapper, wraps, total_ordering, singledispatch
#
# Wave 250 theme: functools callable __qualname__ string equality — pure-Python functions group 1.
#
# functools.update_wrapper.__qualname__.__eq__('update_wrapper')  == True
# functools.wraps.__qualname__.__eq__('wraps')                    == True
# functools.total_ordering.__qualname__.__eq__('total_ordering')  == True
# functools.singledispatch.__qualname__.__eq__('singledispatch')  == True
#
# No prior functools spec checks __qualname__ for these functions via functoolsqualstr93. New to extra93.
# ---------------------------------------------------------------------------

table functools_extra93.python_fn_qualnames_group1:
  description: "update_wrapper/wraps/total_ordering/singledispatch __qualname__ strings; pure-Python functions; wave 250; new to extra93"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsqualstr93

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_qualname_eq_update_wrapper,
       update_wrapper.__qualname__.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__qualname__.__eq__('update_wrapper') == True — update_wrapper is a pure-Python function defined in Lib/functools.py that copies attributes from a wrapper to a wrapped function; as a module-level function __qualname__ equals __name__; __qualname__ is 'update_wrapper' (14 chars); str.__eq__('update_wrapper') returns True; new to extra93"]
    - [wraps_qualname_eq_wraps,
       wraps.__qualname__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__qualname__.__eq__('wraps') == True — wraps is a pure-Python function defined in Lib/functools.py that is a decorator factory calling update_wrapper; as a module-level function __qualname__ equals __name__; __qualname__ is 'wraps' (5 chars); str.__eq__('wraps') returns True; new to extra93"]
    - [total_ordering_qualname_eq_total_ordering,
       total_ordering.__qualname__.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__.__eq__('total_ordering') == True — total_ordering is a pure-Python class decorator function defined in Lib/functools.py; as a module-level function __qualname__ equals __name__; __qualname__ is 'total_ordering' (13 chars); str.__eq__('total_ordering') returns True; new to extra93"]
    - [singledispatch_qualname_eq_singledispatch,
       singledispatch.__qualname__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__qualname__.__eq__('singledispatch') == True — singledispatch is a pure-Python function defined in Lib/functools.py that transforms a function into a single-dispatch generic function; as a module-level function __qualname__ equals __name__; __qualname__ is 'singledispatch' (14 chars); str.__eq__('singledispatch') returns True; new to extra93"]

# ---------------------------------------------------------------------------
# Python function qualnames group 2 + WRAPPER constants class names
#
# Wave 250 theme: functools callable __qualname__ group 2 + constant type checks.
#
# functools.wraps.__qualname__.__eq__('wraps')                               == True (double-confirm)
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple')           == True
# functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple')               == True
# functools.update_wrapper.__qualname__.__eq__('total_ordering')             == False (cross-check)
#
# No prior functools spec checks WRAPPER_ASSIGNMENTS/__class__.__name__ via functoolsqualstr93. New to extra93.
# ---------------------------------------------------------------------------

table functools_extra93.qualnames_group2_and_wrapper_consts:
  description: "wraps qualname double-confirm; WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES __class__.__name__==tuple; wave 250; new to extra93"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsqualstr93

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_qualname_eq_wraps_confirm,
       wraps.__qualname__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__qualname__.__eq__('wraps') == True — double-confirms wraps.__qualname__ is 'wraps'; wraps is a pure-Python function in Lib/functools.py; as a module-level function __qualname__ equals __name__; str.__eq__('wraps') returns True; new to extra93"]
    - [WRAPPER_ASSIGNMENTS_class_name_eq_tuple,
       WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level tuple constant in Lib/functools.py containing attribute names copied by update_wrapper; its __class__ is <class 'tuple'>; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; no prior functools spec checks WRAPPER_ASSIGNMENTS.__class__.__name__ via functoolsqualstr93; new to extra93"]
    - [WRAPPER_UPDATES_class_name_eq_tuple,
       WRAPPER_UPDATES.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a module-level tuple constant in Lib/functools.py containing attribute names updated (merged) by update_wrapper; its __class__ is <class 'tuple'>; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; no prior functools spec checks WRAPPER_UPDATES.__class__.__name__ via functoolsqualstr93; new to extra93"]
    - [update_wrapper_qualname_ne_total_ordering,
       update_wrapper.__qualname__.__eq__,
       ["total_ordering"],
       false,
       "functools.update_wrapper.__qualname__.__eq__('total_ordering') == False — update_wrapper.__qualname__ is 'update_wrapper', not 'total_ordering'; each callable has a unique __qualname__; str.__eq__('total_ordering') returns False; confirms __qualname__ distinguishes update_wrapper from total_ordering; new to extra93"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra93
# ---------------------------------------------------------------------------

invariant functools_extra93.reduce_qualname_eq_reduce:
  description: "functools.reduce.__qualname__.__eq__('reduce') == True — reduce C builtin __qualname__ is 'reduce'; wave 250; new to extra93"
  kind: python_call_eq
  function: reduce.__qualname__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra93.partial_qualname_eq_partial:
  description: "functools.partial.__qualname__.__eq__('partial') == True — partial C extension type __qualname__ is 'partial'; wave 250; new to extra93"
  kind: python_call_eq
  function: partial.__qualname__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra93.wraps_qualname_eq_wraps:
  description: "functools.wraps.__qualname__.__eq__('wraps') == True — wraps pure-Python function __qualname__ is 'wraps'; wave 250; new to extra93"
  kind: python_call_eq
  function: wraps.__qualname__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra93.WRAPPER_ASSIGNMENTS_class_name_eq_tuple:
  description: "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a tuple constant; wave 250; new to extra93"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra93.cached_property_qualname_eq_cached_property:
  description: "functools.cached_property.__qualname__.__eq__('cached_property') == True — cached_property pure-Python class __qualname__ is 'cached_property'; wave 250; new to extra93"
  kind: python_call_eq
  function: cached_property.__qualname__.__eq__
  args: ["cached_property"]
  expected: true
