spec: to_no_case
version: ">=1.0.2"
backend: node(to-no-case)

docs: https://www.npmjs.com/package/to-no-case

provenance:
  derived_from:
    - "to-no-case README — https://www.npmjs.com/package/to-no-case"
    - "Test vectors verified with to-no-case via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "to-no-case source"
  notes:
    - "to-no-case is an npm package. Install: npm install to-no-case"
    - "Strips any case formatting from a string, returning space-separated lowercase words."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table to_no_case.toNoCase:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: nocase

  columns: [id, args, expected]
  rows:
    - [hyphen,  ["hello-world"],  "hello world"]
    - [camel,   ["fooBar"],       "foo bar"]
    - [snake,   ["foo_bar"],      "foo bar"]

