spec: hashlib_extra11
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"
  - "RFC 7693 — The BLAKE2 Cryptographic Hash and Message Authentication Code (MAC)"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "FIPS 202 — SHA-3 Standard, NIST, August 2015"
    - "RFC 7693 — The BLAKE2 Cryptographic Hash and MAC, November 2015"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "CPython source: Modules/_sha3/sha3module.c"
  notes:
    - "This spec extends hashlib through hashlib_extra10; it does NOT duplicate invariants present in those files."
    - "hashlib_extra10 covers sha3_224/sha3_384/sha3_256/sha3_512 __name__/__module__/__qualname__ and sha3_224/sha3_384 via new()."
    - "hashlib_extra9 covers constructor __name__ for md5/sha1/sha256 (openssl_ prefix), new.__name__ == '__hash_new'."
    - "hashlib_extra8 covers sha256/sha512/sha1/md5 __qualname__; algorithms_guaranteed len >= 8 and sha3_512/blake2s membership."
    - "hashlib_extra7 covers sha384/sha224 digest_size; algorithms_guaranteed sha384/sha224."
    - "No prior spec covers: blake2b.__name__ == 'blake2b' (it is not openssl-prefixed; BLAKE2 uses its own C extension)."
    - "No prior spec covers: blake2b.__module__ == '_blake2'."
    - "No prior spec covers: blake2s.__name__ == 'blake2s'."
    - "No prior spec covers: blake2s.__module__ == '_blake2'."
    - "No prior spec covers: blake2b.__qualname__ == 'blake2b'."
    - "No prior spec covers: blake2s.__qualname__ == 'blake2s'."
    - "No prior spec covers: blake2b().digest_size == 64 (standalone, not as part of hexdigest check)."
    - "No prior spec covers: blake2s().digest_size == 32."
    - "No prior spec covers: blake2b().block_size == 128."
    - "No prior spec covers: blake2s().block_size == 64."
    - "No prior spec covers: hashlib.new('blake2b').digest_size == 64 via factory."
    - "No prior spec covers: hashlib.new('blake2b').name == 'blake2b' via factory."
    - "No prior spec covers: hashlib.new('sha3_512').digest_size == 64 via factory."
    - "No prior spec covers: hashlib.new('sha3_512').name == 'sha3_512' via factory."
    - "hashlib_extra8/9 cover algorithms_guaranteed membership for sha3_512/blake2s/blake2b; extra11 anchors shake_256 membership."
    - "No prior spec covers: algorithms_guaranteed.__contains__('shake_256') or sha3_384."
    - "sha3_512.__name__ == 'openssl_sha3_512' on OpenSSL-backed builds (Python 3.12/macOS)."
    - "sha3_512.__module__ == '_hashlib' on OpenSSL-backed builds."
    - "blake2b/blake2s use the _blake2 C extension, not OpenSSL — their __name__ has no openssl_ prefix."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BLAKE2 constructor identity — __name__, __module__, __qualname__
#
# hashlib_extra8 covers sha256/sha512/sha1/md5 __qualname__ (all openssl_xxx).
# hashlib_extra10 covers sha3_224/sha3_384/sha3_256/sha3_512 __name__/__module__
# (module is '_sha3' or '_hashlib').
# blake2b and blake2s live in the _blake2 C extension; their __name__ has no
# openssl_ prefix. No prior spec checks any of these attributes.
# ---------------------------------------------------------------------------

table hashlib_extra11.blake2_identity:
  kind: python_call_eq
  category: identity
  id_prefix: blake2id

  columns: [id, function, args, expected]
  rows:
    - [blake2b_name,     blake2b.__name__.__eq__,     ["blake2b"],  true]
    - [blake2b_module,   blake2b.__module__.__eq__,   ["_blake2"],  true]
    - [blake2b_qualname, blake2b.__qualname__.__eq__,  ["blake2b"],  true]
    - [blake2s_name,     blake2s.__name__.__eq__,     ["blake2s"],  true]
    - [blake2s_module,   blake2s.__module__.__eq__,   ["_blake2"],  true]
    - [blake2s_qualname, blake2s.__qualname__.__eq__,  ["blake2s"],  true]

# ---------------------------------------------------------------------------
# BLAKE2 digest_size and block_size
#
# hashlib_extra8 covers blake2s membership in algorithms_guaranteed.
# No prior spec checks the digest_size or block_size of blake2b or blake2s
# hash objects (the constructors accept no positional args in the probe form
# used here; default digest_size for blake2b is 64, blake2s is 32).
# ---------------------------------------------------------------------------

invariant hashlib_extra11.blake2b.digest_size:
  description: "hashlib.blake2b().digest_size == 64 — BLAKE2b default output is 64 bytes"
  category: properties
  kind: python_call_eq
  function: blake2b
  args: []
  method: digest_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra11.blake2s.digest_size:
  description: "hashlib.blake2s().digest_size == 32 — BLAKE2s default output is 32 bytes"
  category: properties
  kind: python_call_eq
  function: blake2s
  args: []
  method: digest_size.__eq__
  method_args: [32]
  expected: true

invariant hashlib_extra11.blake2b.block_size:
  description: "hashlib.blake2b().block_size == 128 — BLAKE2b uses 128-byte blocks"
  category: properties
  kind: python_call_eq
  function: blake2b
  args: []
  method: block_size.__eq__
  method_args: [128]
  expected: true

invariant hashlib_extra11.blake2s.block_size:
  description: "hashlib.blake2s().block_size == 64 — BLAKE2s uses 64-byte blocks"
  category: properties
  kind: python_call_eq
  function: blake2s
  args: []
  method: block_size.__eq__
  method_args: [64]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new() with blake2b and blake2s — via factory
#
# hashlib_extra10 covers new('sha3_224') and new('sha3_384').
# No prior spec covers blake2b or blake2s via the new() factory.
# ---------------------------------------------------------------------------

invariant hashlib_extra11.new.blake2b.digest_size:
  description: "hashlib.new('blake2b').digest_size == 64 — BLAKE2b via new() factory"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["blake2b"]
  method: digest_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra11.new.blake2b.name_attr:
  description: "hashlib.new('blake2b').name == 'blake2b'"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["blake2b"]
  method: name.__eq__
  method_args: ["blake2b"]
  expected: true

invariant hashlib_extra11.new.blake2s.digest_size:
  description: "hashlib.new('blake2s').digest_size == 32 — BLAKE2s via new() factory"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["blake2s"]
  method: digest_size.__eq__
  method_args: [32]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new() with sha3_512 — via factory
#
# hashlib_extra10 covers new('sha3_224') and new('sha3_384').
# hashlib_extra7 covers new('sha3_256').
# new('sha3_512') digest_size and name are not in any prior spec.
# ---------------------------------------------------------------------------

invariant hashlib_extra11.new.sha3_512.digest_size:
  description: "hashlib.new('sha3_512').digest_size == 64 — SHA3-512 via new() produces 64 bytes"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha3_512"]
  method: digest_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra11.new.sha3_512.name_attr:
  description: "hashlib.new('sha3_512').name == 'sha3_512'"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha3_512"]
  method: name.__eq__
  method_args: ["sha3_512"]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_guaranteed — shake_256 and sha3_384 membership
#
# hashlib_extra8 covers sha3_512/blake2s; hashlib_extra9 covers sha224.
# shake_256 and sha3_384 are guaranteed since Python 3.6+ and are new here.
# ---------------------------------------------------------------------------

invariant hashlib_extra11.algorithms_guaranteed.contains_shake_256:
  description: "hashlib.algorithms_guaranteed.__contains__('shake_256') == True — guaranteed since Python 3.6+"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["shake_256"]
  expected: true

invariant hashlib_extra11.algorithms_guaranteed.contains_sha3_384:
  description: "hashlib.algorithms_guaranteed.__contains__('sha3_384') == True"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha3_384"]
  expected: true
