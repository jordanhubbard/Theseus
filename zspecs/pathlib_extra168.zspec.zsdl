spec: pathlib_extra168
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.WindowsPath and pathlib.PosixPath class identity attributes."
    - "pathlib.WindowsPath.__name__ == 'WindowsPath' (len=11)."
    - "pathlib.WindowsPath.__module__ == 'pathlib' (len=7)."
    - "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' (len=4)."
    - "pathlib.PosixPath.__name__ == 'PosixPath' (len=9)."
    - "pathlib.PosixPath.__module__ == 'pathlib' (len=7)."
    - "pathlib.PosixPath.__bases__[0].__name__ == 'Path' (len=4)."
    - "Both WindowsPath and PosixPath share the same first base: Path (len=4)."
    - "Both classes have __module__ == 'pathlib' (len=7) — the public module, consistent across all concrete and pure path classes."
    - "WindowsPath.__name__ (11) is exactly 2 characters longer than PosixPath.__name__ (9) because 'Windows' (7 chars) > 'Posix' (5 chars) by 2 characters."
    - "These are the concrete path classes (performing I/O); compare with pure path classes from pathlib_extra167: PurePosixPath (13) and PureWindowsPath (15) are longer because of the 'Pure' (4-char) prefix."
    - "PosixPath (9) < WindowsPath (11) < PurePosixPath (13) < PureWindowsPath (15): all four concrete/pure path class names in ascending length order."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.WindowsPath class identity attributes
# __name__ = 'WindowsPath' (len=11), __module__ = 'pathlib' (len=7)
# __bases__[0].__name__ = 'Path' (len=4)
# WindowsPath is the concrete path class for Windows filesystem semantics.
# ---------------------------------------------------------------------------

table pathlib_extra168.WindowsPath_class_identity:
  description: "pathlib.WindowsPath class identity: __name__='WindowsPath' (len=11), __module__='pathlib' (len=7), __bases__[0].__name__='Path' (len=4); WindowsPath is the concrete Windows path class"
  kind: python_call_eq
  category: identity
  id_prefix: winpath168

  columns: [id, function, args, expected, description]
  rows:
    - [win_name,      WindowsPath.__name__.__eq__,                   ["WindowsPath"],  true, "pathlib.WindowsPath.__name__ == 'WindowsPath' (WindowsPath is the concrete path class for Windows filesystem semantics — it performs actual filesystem I/O with Windows-style path handling; 'WindowsPath' has 11 characters: 'Windows' (7) + 'Path' (4) = 11; note the absence of the 'Pure' prefix — this is a concrete class unlike PureWindowsPath (15 chars) from pathlib_extra167; WindowsPath (11) is 2 characters longer than PosixPath (9) because 'Windows' (7) is 2 longer than 'Posix' (5); WindowsPath performs I/O and can only be instantiated on Windows systems)"]
    - [win_mod,       WindowsPath.__module__.__eq__,                  ["pathlib"],      true, "pathlib.WindowsPath.__module__ == 'pathlib' (WindowsPath's module is the public 'pathlib' namespace; 'pathlib' has 7 characters; WindowsPath and PosixPath both have __module__ == 'pathlib', consistent with PurePosixPath and PureWindowsPath from pathlib_extra167 — all four pathlib concrete and pure path classes share the same public module name; this contrasts with io classes like BufferedWriter where __module__ == '_io' (3 chars), the private C-extension module)"]
    - [win_base0,     "WindowsPath.__bases__[0].__name__.__eq__",     ["Path"],         true, "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' (WindowsPath's first base class is Path — the abstract concrete path base that provides filesystem I/O methods; 'Path' has 4 characters: 'P-a-t-h'; both WindowsPath and PosixPath inherit directly from Path; Path in turn inherits from PurePath; the base class 'Path' (4 chars) is significantly shorter than 'WindowsPath' (11 chars) and 'PosixPath' (9 chars) — the subclasses add the OS-specific prefix; compare with pure classes from pathlib_extra167: both PurePosixPath and PureWindowsPath have 'PurePath' (8 chars) as their base, not the 4-char 'Path')"]
    - [win_name_len,  WindowsPath.__name__.__len__,                   [],              11,   "pathlib.WindowsPath.__name__.__len__() == 11 ('WindowsPath' has 11 characters: 'Windows' (7) + 'Path' (4) = 11; name length 11 places WindowsPath between PosixPath (9) and PurePosixPath (13) in the four-class length ranking: PosixPath=9, WindowsPath=11, PurePosixPath=13, PureWindowsPath=15; the 'Windows' OS infix (7 chars) determines the full class name length; WindowsPath (11) is exactly 4 characters shorter than PureWindowsPath (15) because the 'Pure' prefix (4 chars) is absent from the concrete class name)"]

# ---------------------------------------------------------------------------
# pathlib.PosixPath class identity attributes
# __name__ = 'PosixPath' (len=9), __module__ = 'pathlib' (len=7)
# __bases__[0].__name__ = 'Path' (len=4)
# PosixPath is the concrete path class for POSIX filesystem semantics.
# ---------------------------------------------------------------------------

table pathlib_extra168.PosixPath_class_identity:
  description: "pathlib.PosixPath class identity: __name__='PosixPath' (len=9), __module__='pathlib' (len=7), __bases__[0].__name__='Path' (len=4); PosixPath is the concrete POSIX path class"
  kind: python_call_eq
  category: identity
  id_prefix: posixpath168

  columns: [id, function, args, expected, description]
  rows:
    - [posix_name,      PosixPath.__name__.__eq__,                   ["PosixPath"],  true, "pathlib.PosixPath.__name__ == 'PosixPath' (PosixPath is the concrete path class for POSIX filesystem semantics — it performs actual filesystem I/O with Unix-style path handling, case-sensitive names, and forward-slash separators; 'PosixPath' has 9 characters: 'Posix' (5) + 'Path' (4) = 9; the absence of the 'Pure' prefix distinguishes PosixPath (9) from PurePosixPath (13, from pathlib_extra167); PosixPath (9) is the shortest of the four OS-specific path class names; PosixPath can only be instantiated on non-Windows systems)"]
    - [posix_mod,       PosixPath.__module__.__eq__,                  ["pathlib"],    true, "pathlib.PosixPath.__module__ == 'pathlib' (PosixPath's module is the public 'pathlib' namespace; 'pathlib' has 7 characters; PosixPath shares __module__ == 'pathlib' with WindowsPath, PurePosixPath, and PureWindowsPath — all four OS-specific pathlib classes have the same __module__; the 7-character public module name 'pathlib' is consistent across all pathlib classes; this uniformity contrasts with the io module where some classes have __module__ == '_io' (3 chars) rather than 'io' (2 chars))"]
    - [posix_base0,     "PosixPath.__bases__[0].__name__.__eq__",     ["Path"],       true, "pathlib.PosixPath.__bases__[0].__name__ == 'Path' (PosixPath's first base class is Path — the same base as WindowsPath; both PosixPath and WindowsPath inherit directly from Path, which provides the filesystem I/O interface; 'Path' has 4 characters; the base class 'Path' (4 chars) is shorter than both PosixPath (9) and WindowsPath (11); this inheritance from 'Path' (4 chars) contrasts with pure path classes from pathlib_extra167 which inherit from 'PurePath' (8 chars) — the concrete classes inherit from the shorter base)"]
    - [posix_name_len,  PosixPath.__name__.__len__,                   [],             9,   "pathlib.PosixPath.__name__.__len__() == 9 ('PosixPath' has 9 characters: 'Posix' (5) + 'Path' (4) = 9; PosixPath (9) is the shortest OS-specific path class name across all four pathlib OS-specific classes; four-class length ranking from shortest: PosixPath=9, WindowsPath=11, PurePosixPath=13, PureWindowsPath=15; PosixPath (9) is exactly 4 characters shorter than PurePosixPath (13) from pathlib_extra167 — the difference is the 'Pure' prefix (4 chars); the 'Posix' infix (5 chars) determines the total name length for concrete POSIX path class)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra168.WindowsPath_name_len_11:
  description: "pathlib.WindowsPath.__name__.__len__() == 11 — 'WindowsPath' has 11 characters: 'Windows' (7) + 'Path' (4) = 11; WindowsPath is the concrete Windows path class (performs I/O) unlike PureWindowsPath (15, from pathlib_extra167) which is pure (no I/O); the difference of 4 characters between WindowsPath (11) and PureWindowsPath (15) is exactly the length of the 'Pure' prefix; four-class length ranking: PosixPath=9, WindowsPath=11, PurePosixPath=13, PureWindowsPath=15; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: WindowsPath.__name__.__len__
  args: []
  expected: 11

invariant pathlib_extra168.PosixPath_name_len_9:
  description: "pathlib.PosixPath.__name__.__len__() == 9 — 'PosixPath' has 9 characters: 'Posix' (5) + 'Path' (4) = 9; PosixPath (9) is the shortest of all four OS-specific pathlib class names; PosixPath (9) is 4 characters shorter than PurePosixPath (13, from pathlib_extra167) — the 'Pure' prefix (4 chars) is the only difference; PosixPath (9) is also 2 characters shorter than WindowsPath (11) because 'Posix' (5) < 'Windows' (7) by 2; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PosixPath.__name__.__len__
  args: []
  expected: 9

invariant pathlib_extra168.both_concrete_paths_share_Path_base:
  description: "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' — WindowsPath and PosixPath both have 'Path' as their first base class name (len=4); this shared base 'Path' provides the concrete filesystem I/O interface; 'Path' (4 chars) is the shortest base class name across all pathlib path classes — shorter than 'PurePath' (8 chars) which is the base for PurePosixPath and PureWindowsPath from pathlib_extra167; the concrete classes (PosixPath, WindowsPath) inherit from 'Path' (4 chars) while the pure classes inherit from 'PurePath' (8 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "WindowsPath.__bases__[0].__name__.__eq__"
  args: ["Path"]
  expected: true

invariant pathlib_extra168.PosixPath_module_is_pathlib:
  description: "pathlib.PosixPath.__module__ == 'pathlib' — PosixPath's __module__ is 'pathlib' (7 chars), the same public module as WindowsPath; all four OS-specific pathlib classes (PosixPath, WindowsPath, PurePosixPath, PureWindowsPath) share __module__ == 'pathlib'; this 7-character public module name is longer than '_io' (3 chars, used by io classes like BufferedWriter) and longer than 're' (2 chars, used by re.RegexFlag); the uniformity of __module__ across all pathlib path classes reflects that they are all defined and exported from the single public 'pathlib' module; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

