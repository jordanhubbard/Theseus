spec: trace_extra
version: ">=3.3"
backend: python_module(trace)

docs: https://docs.python.org/3/library/trace.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/trace.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "trace source: Lib/trace.py (PSF; source inspection permitted)"
  not_derived_from:
    - "trace source: sys.settrace internals"
  notes:
    - "Complements trace.zspec.zsdl with additional coverage of class metadata and module-level constants."
    - "trace.Trace.__name__ == 'Trace' — primary class for execution tracing and coverage."
    - "trace.Trace.__module__ == 'trace' — Trace is defined in Lib/trace.py."
    - "trace.CoverageResults.__name__ == 'CoverageResults' — holds coverage data from Trace.results()."
    - "trace.Trace.__bases__[0].__name__ == 'object' — Trace inherits directly from object."
    - "trace.PRAGMA_NOCOVER is a str constant (value '#pragma NO COVER') used to mark lines excluded from coverage."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Trace raises ValueError on invalid constructor arguments."
  stderr: "null"
  stickiness: "N/A — Trace instances are independent."
  codes: {}

# ---------------------------------------------------------------------------
# Class __name__ checks
# ---------------------------------------------------------------------------

invariant trace_extra.Trace.name:
  description: "trace.Trace.__name__ == 'Trace'"
  category: class_names
  kind: python_call_eq
  function: Trace.__name__.__eq__
  args: ["Trace"]
  expected: true

invariant trace_extra.CoverageResults.name:
  description: "trace.CoverageResults.__name__ == 'CoverageResults'"
  category: class_names
  kind: python_call_eq
  function: CoverageResults.__name__.__eq__
  args: ["CoverageResults"]
  expected: true

# ---------------------------------------------------------------------------
# Class __module__ checks
# ---------------------------------------------------------------------------

invariant trace_extra.Trace.module:
  description: "trace.Trace.__module__ == 'trace'"
  category: class_modules
  kind: python_call_eq
  function: Trace.__module__.__eq__
  args: ["trace"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy
# ---------------------------------------------------------------------------

invariant trace_extra.Trace.base_is_object:
  description: "trace.Trace.__bases__[0].__name__ == 'object' — Trace inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: Trace.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# PRAGMA_NOCOVER — module-level string constant
# ---------------------------------------------------------------------------

invariant trace_extra.PRAGMA_NOCOVER.class_is_str:
  description: "trace.PRAGMA_NOCOVER.__class__.__name__ == 'str' — the no-cover pragma is a plain string"
  category: constants
  kind: python_call_eq
  function: PRAGMA_NOCOVER.__class__.__name__.__eq__
  args: ["str"]
  expected: true
