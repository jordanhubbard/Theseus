spec: inspect_extra361
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "inspect.Parameter.__name__ == 'Parameter' — pure-Python class in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter inherits directly from object. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY == 0 — integer enum member value. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD == 1 — integer enum member value. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_POSITIONAL == 2 — integer enum member value. Verified with Python 3.14.3."
    - "inspect.Parameter.KEYWORD_ONLY == 3 — integer enum member value. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_KEYWORD == 4 — integer enum member value. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is the class object used as a sentinel; its __class__ is the metaclass 'type'. Verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter class identity
#
# inspect.Parameter.__name__ == 'Parameter'
# inspect.Parameter.__module__ == 'inspect'
# inspect.Parameter.__bases__[0].__name__ == 'object'
#
# Parameter is a pure-Python class defined in Lib/inspect.py that represents
# a function parameter as returned by inspect.signature(). It inherits
# directly from object. Its __qualname__ also equals 'Parameter'.
# ---------------------------------------------------------------------------

table inspect_extra361.parameter_class_identity:
  description: "inspect.Parameter class identity: __name__, __module__, __bases__[0].__name__; Parameter is a pure-Python class in Lib/inspect.py inheriting from object; new to extra361"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparam361

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_name_eq,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter is a pure-Python class defined in Lib/inspect.py that represents a single parameter of a callable; its __name__ attribute is 'Parameter'; str.__eq__('Parameter') returns True; new to extra361"]
    - [parameter_module_eq,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra361"]
    - [parameter_bases_first_eq_object,
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter inherits directly from object with no intermediate base class; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra361"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter kind constants
#
# inspect.Parameter.POSITIONAL_ONLY == 0
# inspect.Parameter.POSITIONAL_OR_KEYWORD == 1
# inspect.Parameter.VAR_POSITIONAL == 2
# inspect.Parameter.KEYWORD_ONLY == 3
# inspect.Parameter.VAR_KEYWORD == 4
#
# These are _ParameterKind enum members. Their integer values are stable
# across Python versions and reflect the ordering in which parameter kinds
# appear in a function signature. POSITIONAL_ONLY (/) parameters can only
# be passed positionally; VAR_POSITIONAL is *args; VAR_KEYWORD is **kwargs.
# ---------------------------------------------------------------------------

table inspect_extra361.parameter_kind_constants:
  description: "inspect.Parameter kind constants: POSITIONAL_ONLY==0, POSITIONAL_OR_KEYWORD==1, VAR_POSITIONAL==2, KEYWORD_ONLY==3, VAR_KEYWORD==4; integer values of _ParameterKind enum; new to extra361"
  kind: python_call_eq
  category: numeric_identity
  id_prefix: inspectparam361

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_eq_0,
       "Parameter.POSITIONAL_ONLY.__eq__",
       [0],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__eq__(0) == True — POSITIONAL_ONLY is a _ParameterKind enum member with integer value 0; it represents parameters that can only be passed positionally (before a / separator); __eq__(0) returns True; new to extra361"]
    - [positional_or_keyword_eq_1,
       "Parameter.POSITIONAL_OR_KEYWORD.__eq__",
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__(1) == True — POSITIONAL_OR_KEYWORD is a _ParameterKind enum member with integer value 1; it is the default kind for most function parameters that can be passed either positionally or by keyword; __eq__(1) returns True; new to extra361"]
    - [var_positional_eq_2,
       "Parameter.VAR_POSITIONAL.__eq__",
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__eq__(2) == True — VAR_POSITIONAL is a _ParameterKind enum member with integer value 2; it represents *args parameters that collect extra positional arguments; __eq__(2) returns True; new to extra361"]
    - [keyword_only_eq_3,
       "Parameter.KEYWORD_ONLY.__eq__",
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__eq__(3) == True — KEYWORD_ONLY is a _ParameterKind enum member with integer value 3; it represents parameters that appear after a * or *args and must be passed by keyword; __eq__(3) returns True; new to extra361"]
    - [var_keyword_eq_4,
       "Parameter.VAR_KEYWORD.__eq__",
       [4],
       true,
       "inspect.Parameter.VAR_KEYWORD.__eq__(4) == True — VAR_KEYWORD is a _ParameterKind enum member with integer value 4; it represents **kwargs parameters that collect extra keyword arguments; __eq__(4) returns True; new to extra361"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra361
# ---------------------------------------------------------------------------

invariant inspect_extra361.parameter_name:
  description: "inspect.Parameter.__name__ == 'Parameter' — pure-Python class in Lib/inspect.py; new to extra361"
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra361.parameter_module:
  description: "inspect.Parameter.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra361"
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra361.parameter_bases_object:
  description: "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter inherits directly from object; new to extra361"
  kind: python_call_eq
  function: Parameter.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant inspect_extra361.parameter_positional_only:
  description: "inspect.Parameter.POSITIONAL_ONLY == 0 — _ParameterKind enum integer value for positional-only parameters; new to extra361"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__eq__
  args: [0]
  expected: true

invariant inspect_extra361.parameter_positional_or_keyword:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD == 1 — _ParameterKind enum integer value for standard parameters; new to extra361"
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.__eq__
  args: [1]
  expected: true

invariant inspect_extra361.parameter_var_positional:
  description: "inspect.Parameter.VAR_POSITIONAL == 2 — _ParameterKind enum integer value for *args parameters; new to extra361"
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.__eq__
  args: [2]
  expected: true

invariant inspect_extra361.parameter_keyword_only:
  description: "inspect.Parameter.KEYWORD_ONLY == 3 — _ParameterKind enum integer value for keyword-only parameters; new to extra361"
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.__eq__
  args: [3]
  expected: true

invariant inspect_extra361.parameter_var_keyword:
  description: "inspect.Parameter.VAR_KEYWORD == 4 — _ParameterKind enum integer value for **kwargs parameters; new to extra361"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.__eq__
  args: [4]
  expected: true

invariant inspect_extra361.parameter_empty_class_name:
  description: "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is itself a class object used as a sentinel; its __class__ is the metaclass 'type'; new to extra361"
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true
