spec: minimatch
version: ">=10.0.0"
backend: node(minimatch)

docs: https://github.com/isaacs/minimatch#readme

provenance:
  derived_from:
    - "minimatch README — https://github.com/isaacs/minimatch#readme"
    - "Test vectors verified with minimatch@10.2.5 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "minimatch source: dist/commonjs/index.js"
  notes:
    - "minimatch@10 exports { minimatch } as a named export."
    - "minimatch(file, pattern) returns true/false."
    - "Dot files are not matched by default unless the pattern explicitly includes a dot."
    - "Brace expansion and globstar ** are supported."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table minimatch.match:
  kind: node_module_call_eq
  function: minimatch
  category: match
  id_prefix: mm

  columns: [id, args, expected]
  rows:
    - [js_match,    ["foo.js",  "*.js"],       true]
    - [js_nomatch,  ["foo.txt", "*.js"],       false]
    - [exact,       ["foo",     "foo"],         true]
    - [dot_hidden,  [".hidden", "*.js"],        false]
