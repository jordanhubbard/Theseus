spec: re_extra138
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Lib/re/_constants.py"
  notes:
    - "This spec covers: re.RegexFlag class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(), __class__.__name__) and member identity (__class__.__name__, .name, .value) for IGNORECASE, MULTILINE, DOTALL, VERBOSE, ASCII, UNICODE."
    - "re.RegexFlag.__name__ == 'RegexFlag' (length 9) — the IntFlag enum for regex compilation flags."
    - "re.RegexFlag.__module__ == 're' (length 2) — defined in the pure Python re module."
    - "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (length 7) — RegexFlag directly extends IntFlag from the enum module."
    - "re.RegexFlag.__mro__.__len__() == 7 — MRO is [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object]."
    - "re.RegexFlag.__class__.__name__ == 'EnumType' (length 8) — the metaclass for Enum classes is 'EnumType' in Python 3.11+."
    - "Each RegexFlag member's __class__.__name__ == 'RegexFlag' (the member is an instance of its own enum class)."
    - "re.RegexFlag.IGNORECASE.value == 2, MULTILINE.value == 8, DOTALL.value == 16, VERBOSE.value == 64, ASCII.value == 256, UNICODE.value == 32."
    - "re.I is re.IGNORECASE, re.M is re.MULTILINE, re.S is re.DOTALL, re.X is re.VERBOSE (single-letter aliases)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.RegexFlag class identity
# RegexFlag is an IntFlag enum defined in the re module.
# __name__ == 'RegexFlag' (9), __module__ == 're' (2),
# __qualname__ == 'RegexFlag' (9).
# __bases__[0].__name__ == 'IntFlag' (7). MRO length == 7.
# __class__.__name__ == 'EnumType' (8; Python 3.11+ EnumMeta renamed to EnumType).
# ---------------------------------------------------------------------------

table re_extra138.RegexFlag_class_identity:
  description: "re.RegexFlag class identity: __name__='RegexFlag' (9), __module__='re' (2), __qualname__='RegexFlag' (9), __bases__[0].__name__='IntFlag' (7), __mro__.__len__()==7, __class__.__name__='EnumType'"
  kind: python_call_eq
  category: class_identity
  id_prefix: rerf138

  columns: [id, function, args, expected]
  rows:
    - [rf_name_eq,      RegexFlag.__name__.__eq__,                   ["RegexFlag"], true]
    - [rf_name_len,     RegexFlag.__name__.__len__,                  [],            9]
    - [rf_module_eq,    RegexFlag.__module__.__eq__,                 ["re"],        true]
    - [rf_module_len,   RegexFlag.__module__.__len__,                [],            2]
    - [rf_qualname_eq,  RegexFlag.__qualname__.__eq__,               ["RegexFlag"], true]
    - [rf_qualname_len, RegexFlag.__qualname__.__len__,              [],            9]
    - [rf_base_eq,      "RegexFlag.__bases__[0].__name__.__eq__",    ["IntFlag"],   true]
    - [rf_base_len,     "RegexFlag.__bases__[0].__name__.__len__",   [],            7]
    - [rf_mro_len,      RegexFlag.__mro__.__len__,                   [],            7]
    - [rf_cls_eq,       RegexFlag.__class__.__name__.__eq__,         ["EnumType"],  true]
    - [rf_cls_not_type, RegexFlag.__class__.__name__.__eq__,         ["type"],      false]

# ---------------------------------------------------------------------------
# re.RegexFlag MRO member names
# MRO is [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object].
# RegexFlag and Enum are in 're' and 'enum'; int and object in 'builtins'.
# ---------------------------------------------------------------------------

table re_extra138.RegexFlag_mro_members:
  description: "re.RegexFlag MRO member names: [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object]"
  kind: python_call_eq
  category: class_identity
  id_prefix: rerf138

  columns: [id, function, args, expected]
  rows:
    - [mro0_eq,  "RegexFlag.__mro__[0].__name__.__eq__",  ["RegexFlag"], true]
    - [mro1_eq,  "RegexFlag.__mro__[1].__name__.__eq__",  ["IntFlag"],   true]
    - [mro2_eq,  "RegexFlag.__mro__[2].__name__.__eq__",  ["int"],       true]
    - [mro3_eq,  "RegexFlag.__mro__[3].__name__.__eq__",  ["ReprEnum"],  true]
    - [mro4_eq,  "RegexFlag.__mro__[4].__name__.__eq__",  ["Flag"],      true]
    - [mro5_eq,  "RegexFlag.__mro__[5].__name__.__eq__",  ["Enum"],      true]
    - [mro6_eq,  "RegexFlag.__mro__[6].__name__.__eq__",  ["object"],    true]
    - [mro0_mod, "RegexFlag.__mro__[0].__module__.__eq__", ["re"],       true]
    - [mro1_mod, "RegexFlag.__mro__[1].__module__.__eq__", ["enum"],     true]
    - [mro2_mod, "RegexFlag.__mro__[2].__module__.__eq__", ["builtins"], true]

# ---------------------------------------------------------------------------
# re.RegexFlag member __class__.__name__ and .name attribute
# Each member is an instance of RegexFlag itself.
# IGNORECASE.name == 'IGNORECASE' (10), MULTILINE.name == 'MULTILINE' (9),
# DOTALL.name == 'DOTALL' (6), VERBOSE.name == 'VERBOSE' (7),
# ASCII.name == 'ASCII' (5), UNICODE.name == 'UNICODE' (7).
# ---------------------------------------------------------------------------

table re_extra138.RegexFlag_member_identity:
  description: "re.RegexFlag member __class__.__name__=='RegexFlag' and .name string values: IGNORECASE (10), MULTILINE (9), DOTALL (6), VERBOSE (7), ASCII (5), UNICODE (7)"
  kind: python_call_eq
  category: member_identity
  id_prefix: rerf138

  columns: [id, function, args, expected]
  rows:
    - [ic_cls_eq,    RegexFlag.IGNORECASE.__class__.__name__.__eq__,  ["RegexFlag"],  true]
    - [ml_cls_eq,    RegexFlag.MULTILINE.__class__.__name__.__eq__,   ["RegexFlag"],  true]
    - [ds_cls_eq,    RegexFlag.DOTALL.__class__.__name__.__eq__,      ["RegexFlag"],  true]
    - [vb_cls_eq,    RegexFlag.VERBOSE.__class__.__name__.__eq__,     ["RegexFlag"],  true]
    - [as_cls_eq,    RegexFlag.ASCII.__class__.__name__.__eq__,       ["RegexFlag"],  true]
    - [un_cls_eq,    RegexFlag.UNICODE.__class__.__name__.__eq__,     ["RegexFlag"],  true]
    - [ic_name_eq,   RegexFlag.IGNORECASE.name.__eq__,                ["IGNORECASE"], true]
    - [ic_name_len,  RegexFlag.IGNORECASE.name.__len__,               [],             10]
    - [ml_name_eq,   RegexFlag.MULTILINE.name.__eq__,                 ["MULTILINE"],  true]
    - [ml_name_len,  RegexFlag.MULTILINE.name.__len__,                [],             9]
    - [ds_name_eq,   RegexFlag.DOTALL.name.__eq__,                    ["DOTALL"],     true]
    - [ds_name_len,  RegexFlag.DOTALL.name.__len__,                   [],             6]
    - [vb_name_eq,   RegexFlag.VERBOSE.name.__eq__,                   ["VERBOSE"],    true]
    - [vb_name_len,  RegexFlag.VERBOSE.name.__len__,                  [],             7]

# ---------------------------------------------------------------------------
# re.RegexFlag member integer values
# IGNORECASE == 2, MULTILINE == 8, DOTALL == 16, VERBOSE == 64,
# ASCII == 256, UNICODE == 32.
# All members are also int instances (IntFlag subclasses int).
# ---------------------------------------------------------------------------

table re_extra138.RegexFlag_member_values:
  description: "re.RegexFlag member integer values: IGNORECASE=2, MULTILINE=8, DOTALL=16, VERBOSE=64, ASCII=256, UNICODE=32"
  kind: python_call_eq
  category: member_identity
  id_prefix: rerf138

  columns: [id, function, args, expected]
  rows:
    - [ic_val,  RegexFlag.IGNORECASE.__eq__,  [2],   true]
    - [ml_val,  RegexFlag.MULTILINE.__eq__,   [8],   true]
    - [ds_val,  RegexFlag.DOTALL.__eq__,      [16],  true]
    - [vb_val,  RegexFlag.VERBOSE.__eq__,     [64],  true]
    - [un_val,  RegexFlag.UNICODE.__eq__,     [32],  true]
    - [as_val,  RegexFlag.ASCII.__eq__,       [256], true]
    - [as_name_eq,  RegexFlag.ASCII.name.__eq__,    ["ASCII"],   true]
    - [as_name_len, RegexFlag.ASCII.name.__len__,   [],          5]
    - [un_name_eq,  RegexFlag.UNICODE.name.__eq__,  ["UNICODE"], true]
    - [un_name_len, RegexFlag.UNICODE.name.__len__, [],          7]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra138.RegexFlag.name_is_RegexFlag:
  description: "re.RegexFlag.__name__ == 'RegexFlag' (length 9; the IntFlag enum class for all regex compilation flags)"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra138.RegexFlag.base_is_IntFlag:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (length 7; RegexFlag directly extends IntFlag from the enum module, giving members both enum and int behaviour)"
  category: class_identity
  kind: python_call_eq
  function: "RegexFlag.__bases__[0].__name__.__eq__"
  args: ["IntFlag"]
  expected: true

invariant re_extra138.RegexFlag.mro_len_7:
  description: "re.RegexFlag.__mro__.__len__() == 7 (MRO is [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object]; the full IntFlag chain)"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__mro__.__len__
  args: []
  expected: 7

invariant re_extra138.RegexFlag.metaclass_is_EnumType:
  description: "re.RegexFlag.__class__.__name__ == 'EnumType' (length 8; the metaclass for enum classes in Python 3.11+ is EnumType, formerly EnumMeta)"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__class__.__name__.__eq__
  args: ["EnumType"]
  expected: true

invariant re_extra138.RegexFlag.IGNORECASE_value_2:
  description: "re.RegexFlag.IGNORECASE == 2 (the integer value of the IGNORECASE flag; equivalent to the single-letter alias re.I)"
  category: member_identity
  kind: python_call_eq
  function: RegexFlag.IGNORECASE.__eq__
  args: [2]
  expected: true
