spec: uppercamelcase
version: ">=3.0.0"
backend: node(uppercamelcase)

docs: https://www.npmjs.com/package/uppercamelcase

provenance:
  derived_from:
    - "uppercamelcase README — https://www.npmjs.com/package/uppercamelcase"
    - "Test vectors verified with uppercamelcase via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "uppercamelcase source"
  notes:
    - "uppercamelcase is an npm package. Install: npm install uppercamelcase"
    - "Converts a string to UpperCamelCase (PascalCase)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table uppercamelcase.upperCamelCase:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: ucc

  columns: [id, args, expected]
  rows:
    - [spaces,  ["hello world"],  "HelloWorld"]
    - [hyphen,  ["foo-bar"],      "FooBar"]
    - [snake,   ["foo_bar"],      "FooBar"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:09:45Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
