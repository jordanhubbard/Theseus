spec: uppercamelcase
version: ">=3.0.0"
backend: node(uppercamelcase)

docs: https://www.npmjs.com/package/uppercamelcase

provenance:
  derived_from:
    - "uppercamelcase README — https://www.npmjs.com/package/uppercamelcase"
    - "Test vectors verified with uppercamelcase via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "uppercamelcase source"
  notes:
    - "uppercamelcase is an npm package. Install: npm install uppercamelcase"
    - "Converts a string to UpperCamelCase (PascalCase)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table uppercamelcase.upperCamelCase:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: ucc

  columns: [id, args, expected]
  rows:
    - [spaces,  ["hello world"],  "HelloWorld"]
    - [hyphen,  ["foo-bar"],      "FooBar"]
    - [snake,   ["foo_bar"],      "FooBar"]
