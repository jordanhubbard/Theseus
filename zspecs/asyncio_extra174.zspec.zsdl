table asyncio_extra174.asyncio_cancelled_error_mro:
  description: "asyncio.CancelledError MRO length and entry name checks in asyncioexc174cemro namespace — asyncio.CancelledError.__mro__.__len__()==3 (MRO: [asyncio.exceptions.CancelledError, BaseException, object]; 3 entries: the exception itself, BaseException, and object; the 3-entry MRO directly encodes that CancelledError is a direct BaseException subclass with no intermediate exception layers); asyncio.CancelledError.__mro__[0].__name__.__eq__('CancelledError')==True (entry 0: the class itself); asyncio.CancelledError.__mro__[1].__name__.__eq__('BaseException')==True (entry 1: BaseException — the root of Python's exception hierarchy; CancelledError inherits from BaseException not Exception; this means a bare 'except Exception' will NOT catch CancelledError — only 'except BaseException' or 'except asyncio.CancelledError'); asyncio.CancelledError.__mro__[2].__name__.__eq__('object')==True (entry 2: universal base); COMPARISON: asyncio.TimeoutError.__mro__.__len__()==5 (5-entry exception chain via OSError > Exception > BaseException > object); asyncio.InvalidStateError.__mro__.__len__()==4 (4-entry chain via Exception > BaseException > object); MRO ORDERING: CancelledError(3) < InvalidStateError(4) < TimeoutError(5); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioexc174cemro

  columns: [id, function, args, expected, description]
  rows:
    - [ce_mro_len,    asyncio.CancelledError.__mro__.__len__,               [],               3,     "CancelledError.__mro__.__len__() == 3 (CancelledError > BaseException > object; shortest in spec); verified with Python 3.14.3"]
    - [ce_mro0_name,  "asyncio.CancelledError.__mro__[0].__name__.__eq__",    ["CancelledError"],  true,  "CancelledError.__mro__[0].__name__ == 'CancelledError' (the class itself at index 0 of 3); verified with Python 3.14.3"]
    - [ce_mro1_name,  "asyncio.CancelledError.__mro__[1].__name__.__eq__",    ["BaseException"],   true,  "CancelledError.__mro__[1].__name__ == 'BaseException' (direct base; 'except Exception' does NOT catch CancelledError); verified with Python 3.14.3"]
    - [ce_mro2_name,  "asyncio.CancelledError.__mro__[2].__name__.__eq__",    ["object"],          true,  "CancelledError.__mro__[2].__name__ == 'object' (universal base at index 2 of 3); verified with Python 3.14.3"]

