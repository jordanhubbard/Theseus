invariant asyncio_extra174.asyncio_CancelledError_name_eq:
  description: "asyncio.CancelledError.__name__.__eq__('CancelledError') returns True — asyncio.CancelledError.__name__=='CancelledError' (len=14: 'Cancelled'=9+'Error'=5=14); asyncio.CancelledError is the exception raised when a Task or Future is cancelled; in Python 3.8+, CancelledError was changed to inherit from BaseException (not Exception) so that a bare 'except Exception' does not accidentally swallow cancellation; asyncio.CancelledError is defined in Lib/asyncio/exceptions.py (its __module__=='asyncio.exceptions'); NAME LENGTH COMPARISON: 'CancelledError'=14 == abstractmethod=14 (from abc_extra168; coincidence); 'TimeoutError'=12 < 'CancelledError'=14 < 'InvalidStateError'=17; NEW in extra174: first standalone CancelledError.__name__ identity invariant in asyncioexc174ce namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.CancelledError.__name__.__eq__
  args: ["CancelledError"]
  expected: true

invariant asyncio_extra174.asyncio_CancelledError_module_eq:
  description: "asyncio.CancelledError.__module__.__eq__('asyncio.exceptions') returns True — asyncio.CancelledError.__module__=='asyncio.exceptions' (len=18: 'asyncio'=7+'.'=1+'exceptions'=10=18); asyncio.CancelledError is defined in Lib/asyncio/exceptions.py alongside asyncio.InvalidStateError; CONTRAST: asyncio.TimeoutError.__module__=='builtins' (IS the builtin TimeoutError); CancelledError.__module__=='asyncio.exceptions' confirms this is asyncio's own CancelledError class (not the same object as any builtin); 'asyncio.exceptions'=18 is 1 char shorter than 'asyncio.exceptions'=18... compare to 'multiprocessing.process'=23 (from extra171) and 'concurrent.futures._base'=24 (the longest module path seen); NEW in extra174: first standalone CancelledError.__module__ invariant in asyncioexc174ce namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.CancelledError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra174.asyncio_CancelledError_base_is_BaseException:
  description: "asyncio.CancelledError.__bases__[0].__name__.__eq__('BaseException') returns True — asyncio.CancelledError.__bases__[0].__name__=='BaseException'; CancelledError's direct base class is BaseException (not Exception); this means isinstance(CancelledError(), BaseException) is True but isinstance(CancelledError(), Exception) is False; the change from Exception to BaseException in Python 3.8 was intentional — cancellation is not a regular application error and should not be caught by broad 'except Exception' clauses in application code; only 'except BaseException' or 'except asyncio.CancelledError' will catch it; COMPARISON: asyncio.InvalidStateError.__bases__[0].__name__=='Exception' (InvalidStateError IS an Exception subclass — it is a programming error, not a control flow signal); asyncio.TimeoutError.__bases__[0].__name__=='OSError' (TimeoutError bases differ because it IS the builtin OSError subclass); the three asyncio exception bases are: CancelledError->BaseException, InvalidStateError->Exception, TimeoutError->OSError; NEW in extra174: first standalone CancelledError.__bases__[0].__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.CancelledError.__bases__[0].__name__.__eq__"
  args: ["BaseException"]
  expected: true

invariant asyncio_extra174.asyncio_TimeoutError_module_is_builtins:
  description: "asyncio.TimeoutError.__module__.__eq__('builtins') returns True — asyncio.TimeoutError.__module__=='builtins' (len=8: 'builtins'=8); asyncio.TimeoutError IS the builtin TimeoutError — they are the same Python object (asyncio.TimeoutError is builtins.TimeoutError evaluates to True); Python's asyncio module re-exports the builtin TimeoutError directly rather than defining its own; TimeoutError is a builtin OSError subclass (MRO: TimeoutError > OSError > Exception > BaseException > object; len=5); CONTRAST: asyncio.CancelledError.__module__=='asyncio.exceptions' (asyncio's own class; len=18) vs asyncio.TimeoutError.__module__=='builtins' (IS the builtin; len=8); asyncio.InvalidStateError.__module__=='asyncio.exceptions' (asyncio's own class; len=18); only TimeoutError has __module__=='builtins'; NEW in extra174: first standalone TimeoutError.__module__ identity invariant in asyncioexc174timeoutinv namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant asyncio_extra174.asyncio_InvalidStateError_name_eq:
  description: "asyncio.InvalidStateError.__name__.__eq__('InvalidStateError') returns True — asyncio.InvalidStateError.__name__=='InvalidStateError' (len=17: 'Invalid'=7+'State'=5+'Error'=5=17); asyncio.InvalidStateError is defined in Lib/asyncio/exceptions.py (__module__=='asyncio.exceptions'); it is raised when a method is called on a Future or Task in an invalid state — e.g., calling Future.set_result() when the future is already done, or calling Future.result() when the future was cancelled; InvalidStateError inherits from Exception (not BaseException — unlike CancelledError); MRO: [InvalidStateError, Exception, BaseException, object]; len=4; NAME LENGTH: 'InvalidStateError'=17 is the longest of the three asyncio exception names in this spec ('TimeoutError'=12 < 'CancelledError'=14 < 'InvalidStateError'=17); NEW in extra174: first standalone InvalidStateError.__name__ identity invariant in asyncioexc174timeoutinv namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.InvalidStateError.__name__.__eq__
  args: ["InvalidStateError"]
  expected: true

invariant asyncio_extra174.asyncio_InvalidStateError_module_eq:
  description: "asyncio.InvalidStateError.__module__.__eq__('asyncio.exceptions') returns True — asyncio.InvalidStateError.__module__=='asyncio.exceptions' (len=18: 'asyncio'=7+'.'=1+'exceptions'=10=18); both asyncio.CancelledError and asyncio.InvalidStateError share the same __module__=='asyncio.exceptions' — they are both defined in Lib/asyncio/exceptions.py; CONTRAST: asyncio.TimeoutError.__module__=='builtins' (IS the builtin; different from the other two); the two asyncio-specific exception classes (CancelledError and InvalidStateError) are co-located in asyncio.exceptions while TimeoutError is merely re-exported from builtins; MODULE PATH LENGTHS: 'asyncio.exceptions'=18 (shared by CancelledError and InvalidStateError) vs 'builtins'=8 (TimeoutError); NEW in extra174: first standalone InvalidStateError.__module__ invariant in asyncioexc174timeoutinv namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.InvalidStateError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

