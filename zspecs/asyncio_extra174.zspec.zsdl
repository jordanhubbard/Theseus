spec: asyncio_extra174
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-exceptions.html — asyncio exceptions documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/exceptions.py"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec covers: asyncio.CancelledError.__name__=='CancelledError' (len=14); asyncio.CancelledError.__module__=='asyncio.exceptions' (in Python 3.14 asyncio.CancelledError is defined in asyncio.exceptions, NOT the builtin CancelledError); asyncio.CancelledError.__bases__[0].__name__=='BaseException' (inherits from BaseException directly; MRO len=3: CancelledError > BaseException > object); asyncio.TimeoutError.__name__=='TimeoutError' (len=12); asyncio.TimeoutError.__module__=='builtins' (asyncio.TimeoutError IS the builtin TimeoutError — same object; TimeoutError is a builtin subclass of OSError; MRO len=5); asyncio.InvalidStateError.__name__=='InvalidStateError' (len=17); asyncio.InvalidStateError.__module__=='asyncio.exceptions' (defined in asyncio.exceptions; inherits from Exception; MRO len=4). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.CancelledError.__module__=='asyncio.exceptions': In Python 3.8+ asyncio.CancelledError was changed from inheriting Exception to inheriting BaseException. In Python 3.14, asyncio.CancelledError is defined in asyncio.exceptions (NOT as the builtin CancelledError). MRO: [asyncio.exceptions.CancelledError, BaseException, object]. Verified with Python 3.14.3."
    - "asyncio.TimeoutError is builtins.TimeoutError: True (same object). asyncio.TimeoutError.__module__=='builtins'. MRO: [TimeoutError, OSError, Exception, BaseException, object]. len=5. Verified with Python 3.14.3."
    - "asyncio.InvalidStateError.__module__=='asyncio.exceptions': defined in asyncio.exceptions. Inherits from Exception. MRO: [asyncio.exceptions.InvalidStateError, Exception, BaseException, object]. len=4. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.CancelledError class identity — extra174
#
# asyncio.CancelledError.__name__.__eq__('CancelledError')         == True (len=14)
# asyncio.CancelledError.__module__.__eq__('asyncio.exceptions')   == True
# asyncio.CancelledError.__bases__[0].__name__.__eq__('BaseException') == True
# ---------------------------------------------------------------------------

table asyncio_extra174.asyncio_cancelled_error_identity:
  description: "asyncio.CancelledError class identity checks in asyncioexc174ce namespace — asyncio.CancelledError.__name__.__eq__('CancelledError')==True (len=14: 'Cancelled'=9+'Error'=5=14; asyncio.CancelledError is defined in asyncio.exceptions in Python 3.14; it is NOT the same object as the builtin CancelledError — asyncio.CancelledError is asyncio's own exception class that changed its base from Exception to BaseException in Python 3.8+); asyncio.CancelledError.__name__.__len__()==14 ('CancelledError'=14: 14 = 9+5); asyncio.CancelledError.__module__.__eq__('asyncio.exceptions')==True ('asyncio.exceptions'=18: 'asyncio'=7+'.'=1+'exceptions'=10=18; asyncio.CancelledError is defined in Lib/asyncio/exceptions.py); asyncio.CancelledError.__bases__[0].__name__.__eq__('BaseException')==True (CancelledError inherits directly from BaseException — this is the key change from Python 3.7 to 3.8; prior to 3.8, CancelledError inherited from concurrent.futures.CancelledError which inherited from Exception; since 3.8 it inherits from BaseException directly); MRO: [CancelledError, BaseException, object]; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioexc174ce

  columns: [id, function, args, expected, description]
  rows:
    - [ce_name_eq,       asyncio.CancelledError.__name__.__eq__,                       ["CancelledError"],       true,  "CancelledError.__name__ == 'CancelledError' (len=14: 'Cancelled'=9+'Error'=5=14); verified with Python 3.14.3"]
    - [ce_name_len,      asyncio.CancelledError.__name__.__len__,                      [],                       14,    "CancelledError.__name__.__len__() == 14 ('CancelledError'=14); verified with Python 3.14.3"]
    - [ce_mod_eq,        asyncio.CancelledError.__module__.__eq__,                     ["asyncio.exceptions"],   true,  "CancelledError.__module__ == 'asyncio.exceptions' (len=18; defined in Lib/asyncio/exceptions.py); verified with Python 3.14.3"]
    - [ce_base0_name,    "asyncio.CancelledError.__bases__[0].__name__.__eq__",           ["BaseException"],        true,  "CancelledError.__bases__[0].__name__ == 'BaseException' (inherits from BaseException directly since Python 3.8+); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
