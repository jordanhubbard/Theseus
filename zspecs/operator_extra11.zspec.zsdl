spec: operator_extra11
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl through operator_extra10.zspec.zsdl."
    - "operator.zspec covers arithmetic: add/sub/mul/truediv/floordiv/mod/pow with specific args; neg/abs/and_/or_/xor with specific args; comparison/logical/sequence operators."
    - "operator_extra6 covers lshift(3,2)==12 and rshift(32,3)==4 (different args than we use here)."
    - "NEW axis in this spec: additional argument vectors for bitwise/arithmetic operators NOT yet used — and_(3,5)==1, or_(3,5)==7, xor(3,5)==6, lshift(1,3)==8, rshift(8,2)==2, mod(10,3)==1, floordiv(10,3)==3, neg(-5)==5, pos(-7)==-7, invert(3)==-4, pow(3,3)==27."
    - "These use distinct argument pairs from operator.zspec.zsdl — operator.zspec uses and_(10,12), or_(10,5), xor(10,12), lshift(3,2), rshift(32,3) — here we use smaller/simpler values to test orthogonal numeric vectors."
    - "operator.and_(3, 5) == 1 — 0b011 & 0b101 == 0b001."
    - "operator.or_(3, 5) == 7 — 0b011 | 0b101 == 0b111."
    - "operator.xor(3, 5) == 6 — 0b011 ^ 0b101 == 0b110."
    - "operator.lshift(1, 3) == 8 — 1 << 3."
    - "operator.rshift(8, 2) == 2 — 8 >> 2."
    - "operator.mod(10, 3) == 1 — remainder of 10/3; same args as operator.zspec which uses (10,3), but here we verify the contract independently."
    - "operator.floordiv(10, 3) == 3 — floor division; operator.zspec uses floordiv(7,2)==3, here 10//3==3."
    - "operator.neg(-5) == 5 — negate a negative number to get positive; operator.zspec tests neg(5)==-5 and neg(-3)==3."
    - "operator.pos(-7) == -7 — unary plus on a negative int returns the same value."
    - "operator.invert(3) == -4 — bitwise NOT: ~3 == -4 in two's complement."
    - "operator.pow(3, 3) == 27 — operator.zspec uses pow(2,10)==1024; here we test 3**3==27."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Bitwise operators with new argument vectors
#
# operator.zspec covers and_(10,12)==8, or_(10,5)==15, xor(10,12)==6.
# These invariants use different argument pairs (3,5) that exercise the same
# operators on distinct bit patterns, providing orthogonal coverage.
# and_(3,5): 0b011 & 0b101 = 0b001 = 1
# or_(3,5):  0b011 | 0b101 = 0b111 = 7
# xor(3,5):  0b011 ^ 0b101 = 0b110 = 6
# ---------------------------------------------------------------------------

invariant operator_extra11.and_.three_five:
  description: "operator.and_(3, 5) == 1 — 0b011 & 0b101 == 0b001"
  category: bitwise
  kind: python_call_eq
  function: and_
  args: [3, 5]
  expected: 1

invariant operator_extra11.or_.three_five:
  description: "operator.or_(3, 5) == 7 — 0b011 | 0b101 == 0b111"
  category: bitwise
  kind: python_call_eq
  function: or_
  args: [3, 5]
  expected: 7

invariant operator_extra11.xor.three_five:
  description: "operator.xor(3, 5) == 6 — 0b011 ^ 0b101 == 0b110"
  category: bitwise
  kind: python_call_eq
  function: xor
  args: [3, 5]
  expected: 6

# ---------------------------------------------------------------------------
# lshift / rshift with new argument vectors
#
# operator_extra6 covers lshift(3,2)==12 and rshift(32,3)==4.
# Here we use (1,3) and (8,2) — distinct, simpler argument pairs.
# 1 << 3 == 8; 8 >> 2 == 2.
# ---------------------------------------------------------------------------

invariant operator_extra11.lshift.one_by_three:
  description: "operator.lshift(1, 3) == 8 — 1 << 3 == 8"
  category: bitwise
  kind: python_call_eq
  function: lshift
  args: [1, 3]
  expected: 8

invariant operator_extra11.rshift.eight_by_two:
  description: "operator.rshift(8, 2) == 2 — 8 >> 2 == 2"
  category: bitwise
  kind: python_call_eq
  function: rshift
  args: [8, 2]
  expected: 2

# ---------------------------------------------------------------------------
# invert — bitwise NOT on a positive integer
#
# operator.zspec does not include invert call results (only __qualname__ is
# covered in operator_extra10). operator.invert(x) == ~x; for a 32-bit
# two's complement integer, ~3 == -4. This is the first behavioral test for
# operator.invert.
# ---------------------------------------------------------------------------

invariant operator_extra11.invert.three:
  description: "operator.invert(3) == -4 — bitwise NOT: ~3 == -4 in two's complement"
  category: bitwise
  kind: python_call_eq
  function: invert
  args: [3]
  expected: -4

invariant operator_extra11.invert.zero:
  description: "operator.invert(0) == -1 — bitwise NOT: ~0 == -1 in two's complement"
  category: bitwise
  kind: python_call_eq
  function: invert
  args: [0]
  expected: -1

# ---------------------------------------------------------------------------
# pos — unary plus on a negative integer
#
# operator.zspec does not include pos call results (only __module__ is covered
# in operator_extra6). operator.pos(x) == +x; for negative integers this
# returns the same value (unary plus is a no-op on numeric types).
# operator_extra2 covers pos.__name__/__qualname__ metadata only.
# ---------------------------------------------------------------------------

invariant operator_extra11.pos.negative_input:
  description: "operator.pos(-7) == -7 — unary plus on a negative int returns the same value"
  category: unary
  kind: python_call_eq
  function: pos
  args: [-7]
  expected: -7

invariant operator_extra11.pos.positive_input:
  description: "operator.pos(4) == 4 — unary plus on a positive int returns the same value"
  category: unary
  kind: python_call_eq
  function: pos
  args: [4]
  expected: 4

# ---------------------------------------------------------------------------
# pow with a new argument vector
#
# operator.zspec covers pow(2, 10) == 1024. No prior spec tests operator.pow
# with other arguments. pow(3, 3) == 27 is a new orthogonal vector.
# ---------------------------------------------------------------------------

invariant operator_extra11.pow.cube:
  description: "operator.pow(3, 3) == 27 — 3**3 == 27"
  category: arithmetic
  kind: python_call_eq
  function: pow
  args: [3, 3]
  expected: 27

# ---------------------------------------------------------------------------
# floordiv / mod with a new argument vector
#
# operator.zspec covers floordiv(7,2)==3 and mod(10,3)==1.
# These invariants use (10,3) for floordiv (operator.zspec uses (7,2)) and
# (7,3) for mod (operator.zspec uses (10,3)) — providing orthogonal coverage.
# ---------------------------------------------------------------------------

invariant operator_extra11.floordiv.ten_by_three:
  description: "operator.floordiv(10, 3) == 3 — 10 // 3 == 3 (floor division)"
  category: arithmetic
  kind: python_call_eq
  function: floordiv
  args: [10, 3]
  expected: 3

invariant operator_extra11.mod.seven_by_three:
  description: "operator.mod(7, 3) == 1 — 7 % 3 == 1 (remainder)"
  category: arithmetic
  kind: python_call_eq
  function: mod
  args: [7, 3]
  expected: 1
