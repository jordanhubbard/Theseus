spec: array_extra22
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
    - "array.zspec.zsdl — baseline typecode, itemsize, and instance vectors."
    - "array_extra.zspec.zsdl through array_extra21.zspec.zsdl — prior extras."
  notes:
    - "This spec extends array.zspec.zsdl through array_extra21.zspec.zsdl."
    - "array_extra21 covers __qualname__ for append/extend/pop/insert/remove/reverse/tolist/tobytes/frombytes."
    - "No prior array spec checks __qualname__ for buffer_info, byteswap, or index methods."
    - "array_extra4 covers array.array.__qualname__ == 'array' (class qualname)."
    - "array_extra5 covers array.ArrayType.__qualname__ == 'array'."
    - "array_extra19 covers array.ArrayType.__qualname__.__len__() == 5."
    - "Focus: __qualname__ for buffer_info/byteswap/index methods; standalone class qualname anchors; typecodes type check."
    - "array.array.buffer_info.__qualname__ == 'array.buffer_info' — Verified Python 3.12 macOS."
    - "array.array.byteswap.__qualname__ == 'array.byteswap' — Verified."
    - "array.array.index.__qualname__ == 'array.index' — Verified."
    - "array.array.__qualname__ == 'array' — class qualname is bare class name. Verified."
    - "array.ArrayType.__qualname__ == 'array' — ArrayType is an alias for array. Verified."
    - "type(array.typecodes).__name__ == 'str' — typecodes is a module-level string constant. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for buffer_info, byteswap, and index methods
#
# array_extra21 covered append/extend/pop/insert/remove/reverse/tolist/tobytes/
# frombytes. No prior spec checks buffer_info, byteswap, or index __qualname__.
# Under python_module(array), 'array.buffer_info.__qualname__.__eq__' resolves
# as array_module.array.buffer_info.__qualname__.__eq__.
# ---------------------------------------------------------------------------

table array_extra22.method_qualnames:
  description: "array.array method __qualname__ values for buffer_info, byteswap, and index"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: aqn22

  columns: [id, function, args, expected]
  rows:
    - [buffer_info, "array.buffer_info.__qualname__.__eq__", ["array.buffer_info"], true]
    - [byteswap,    "array.byteswap.__qualname__.__eq__",    ["array.byteswap"],    true]
    - [index,       "array.index.__qualname__.__eq__",       ["array.index"],       true]

# ---------------------------------------------------------------------------
# array.array class qualname standalone invariant — extra22 namespace
#
# array_extra4 covers array.array.__qualname__ == 'array'. This extra22
# standalone provides an independent anchor in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant array_extra22.array.class_qualname:
  description: "array.array.__qualname__ == 'array' — top-level class qualname is bare class name"
  category: class_qualnames
  kind: python_call_eq
  function: "array.__qualname__.__eq__"
  args: ["array"]
  expected: true

# ---------------------------------------------------------------------------
# array.ArrayType class qualname standalone invariant — extra22 namespace
#
# array_extra5 covers array.ArrayType.__qualname__ == 'array'. This extra22
# standalone anchor confirms the alias shares the same qualname in the extra22
# namespace.
# ---------------------------------------------------------------------------

invariant array_extra22.ArrayType.class_qualname:
  description: "array.ArrayType.__qualname__ == 'array' — ArrayType alias has same qualname as array class"
  category: class_qualnames
  kind: python_call_eq
  function: ArrayType.__qualname__.__eq__
  args: ["array"]
  expected: true

# ---------------------------------------------------------------------------
# array.typecodes type check — extra22 namespace
#
# array.typecodes is a module-level string constant containing all valid type
# codes. No prior spec checks the type of typecodes as a str via __name__.
# Under python_module(array), 'typecodes.__class__.__name__.__eq__' accesses
# the type name of the typecodes string.
# ---------------------------------------------------------------------------

invariant array_extra22.typecodes.type:
  description: "type(array.typecodes).__name__ == 'str' — typecodes is a module-level string constant"
  category: module_attributes
  kind: python_call_eq
  function: typecodes.__class__.__name__.__eq__
  args: ["str"]
  expected: true
