spec: socket_extra261
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec extends socket_extra260.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "socket.zspec.zsdl covers: AF_INET/AF_INET6/AF_UNIX constants; SOCK_STREAM/SOCK_DGRAM/SOCK_RAW; IPPROTO_IP/TCP/UDP; SOL_SOCKET; SHUT_RD/WR/RDWR constant values; socket/herror/gaierror class names; getdefaulttimeout()==None; inet_aton/htonl vectors."
    - "socket_extra2.zspec.zsdl covers: AddressFamily/SocketKind enum class names; AF_INET/SOCK_STREAM/SOCK_DGRAM integer values; socket.error.__name__=='OSError'; socket.timeout.__name__=='TimeoutError'."
    - "socket_extra260.zspec.zsdl covers: socket.socket __qualname__/__module__; socket.socket.__doc__ contains 'makefile'; timeout/error module identity."
    - "Theme: socket.socket instance attributes family/type/proto/timeout; SHUT_RDWR/SHUT_RD/SHUT_WR constant class names and values."
    - "socket.socket(AF_INET, SOCK_STREAM).family.__class__.__name__ == 'AddressFamily' — family is an AddressFamily IntEnum member."
    - "int(socket.socket(AF_INET, SOCK_STREAM).family) == 2 — AF_INET is universally 2 on all POSIX systems."
    - "socket.socket(AF_INET, SOCK_STREAM).type.__class__.__name__ == 'SocketKind' — type is a SocketKind IntEnum member."
    - "int(socket.socket(AF_INET, SOCK_STREAM).type) == 1 — SOCK_STREAM is universally 1 on all POSIX systems."
    - "socket.socket(AF_INET, SOCK_STREAM).proto == 0 — default protocol (auto-selected)."
    - "socket.socket(AF_INET, SOCK_STREAM).timeout is None — new socket starts in blocking mode."
    - "socket.SHUT_RDWR is a plain int (not an IntEnum member) on macOS/Darwin. int(socket.SHUT_RDWR) == 2."
    - "socket.SHUT_RD is a plain int. int(socket.SHUT_RD) == 0."
    - "socket.SHUT_WR is a plain int. int(socket.SHUT_WR) == 1."
    - "On macOS, SHUT_RDWR/__class__/__name__ == 'int' (plain Python int, not an enum member)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket instance — family attribute
# socket.socket(AF_INET, SOCK_STREAM).family == AF_INET == 2
# family.__class__.__name__ == 'AddressFamily' (IntEnum member)
# ---------------------------------------------------------------------------

invariant socket_extra261.socket_instance.family_class_name:
  description: "socket.socket(AF_INET, SOCK_STREAM).family.__class__.__name__ == 'AddressFamily'"
  category: instance_attributes
  kind: python_call_eq
  function: socket
  args: [2, 1]
  method: family.__class__.__name__.__eq__
  method_args: ["AddressFamily"]
  expected: true

invariant socket_extra261.socket_instance.family_int_value:
  description: "int(socket.socket(AF_INET, SOCK_STREAM).family) == 2 — AF_INET is universally 2"
  category: instance_attributes
  kind: python_call_eq
  function: socket
  args: [2, 1]
  method: family.__int__
  method_args: []
  expected: 2

# ---------------------------------------------------------------------------
# socket.socket instance — type attribute
# socket.socket(AF_INET, SOCK_STREAM).type.__class__.__name__ == 'SocketKind'
# int(type) == 1 (SOCK_STREAM)
# ---------------------------------------------------------------------------

invariant socket_extra261.socket_instance.type_class_name:
  description: "socket.socket(AF_INET, SOCK_STREAM).type.__class__.__name__ == 'SocketKind'"
  category: instance_attributes
  kind: python_call_eq
  function: socket
  args: [2, 1]
  method: type.__class__.__name__.__eq__
  method_args: ["SocketKind"]
  expected: true

invariant socket_extra261.socket_instance.type_int_value:
  description: "int(socket.socket(AF_INET, SOCK_STREAM).type) == 1 — SOCK_STREAM is universally 1"
  category: instance_attributes
  kind: python_call_eq
  function: socket
  args: [2, 1]
  method: type.__int__
  method_args: []
  expected: 1

# ---------------------------------------------------------------------------
# socket.socket instance — proto attribute
# New socket with default protocol: proto == 0
# ---------------------------------------------------------------------------

invariant socket_extra261.socket_instance.proto:
  description: "socket.socket(AF_INET, SOCK_STREAM).proto == 0 — default protocol is 0 (auto-selected)"
  category: instance_attributes
  kind: python_call_eq
  function: socket
  args: [2, 1]
  method: proto.__eq__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket instance — timeout attribute
# New socket starts in blocking mode; timeout is None.
# ---------------------------------------------------------------------------

invariant socket_extra261.socket_instance.timeout_is_none:
  description: "socket.socket(AF_INET, SOCK_STREAM).timeout is None — blocking mode, timeout == None"
  category: instance_attributes
  kind: python_call_eq
  function: socket
  args: [2, 1]
  method: timeout.__class__.__name__.__eq__
  method_args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# SHUT_RDWR, SHUT_RD, SHUT_WR — constant integer values
# socket.zspec.zsdl already covers SHUT_RD==0, SHUT_WR==1, SHUT_RDWR==2 via
# a different kind; this spec adds __class__.__name__ and __eq__ checks.
# ---------------------------------------------------------------------------

invariant socket_extra261.SHUT_RDWR.value:
  description: "socket.SHUT_RDWR == 2 — shutdown both read and write ends"
  category: constants
  kind: python_call_eq
  function: SHUT_RDWR.__eq__
  args: [2]
  expected: true

invariant socket_extra261.SHUT_RD.value:
  description: "socket.SHUT_RD == 0 — shutdown read end"
  category: constants
  kind: python_call_eq
  function: SHUT_RD.__eq__
  args: [0]
  expected: true

invariant socket_extra261.SHUT_WR.value:
  description: "socket.SHUT_WR == 1 — shutdown write end"
  category: constants
  kind: python_call_eq
  function: SHUT_WR.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# SHUT_RDWR, SHUT_RD, SHUT_WR — class name (plain int on macOS/Darwin)
# ---------------------------------------------------------------------------

table socket_extra261.SHUT_constants.class_names:
  description: "SHUT_RDWR, SHUT_RD, SHUT_WR are plain int constants on macOS/Darwin"
  kind: python_call_eq
  category: constants
  id_prefix: shut_class

  columns: [id, function, args, expected]
  rows:
    - [shut_rdwr, SHUT_RDWR.__class__.__name__.__eq__, ["int"], true]
    - [shut_rd,   SHUT_RD.__class__.__name__.__eq__,   ["int"], true]
    - [shut_wr,   SHUT_WR.__class__.__name__.__eq__,   ["int"], true]
