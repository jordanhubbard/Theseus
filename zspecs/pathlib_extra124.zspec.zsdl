spec: pathlib_extra124
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec extends pathlib_extra123.zspec.zsdl."
    - "This spec covers: pathlib.Path glob-related, traversal, and query method qualnames not yet covered by equality assertions."
    - "pathlib.Path.rglob.__qualname__ == 'Path.rglob' (len 10); prior specs covered name_eq and co_argcount only."
    - "pathlib.Path.walk.__qualname__ == 'Path.walk' (len 9); prior specs covered qualname_len and co_argcount only."
    - "pathlib.Path.expanduser.__qualname__ == 'Path.expanduser' (len 15); prior specs covered len and co_name only."
    - "pathlib.Path.is_symlink.__qualname__ == 'Path.is_symlink' (len 15); prior specs covered len and name_eq only."
    - "pathlib.Path.is_block_device.__qualname__ == 'Path.is_block_device' (len 20); no prior equality assertion."
    - "pathlib.Path.is_char_device.__qualname__ == 'Path.is_char_device' (len 19); no prior equality assertion."
    - "pathlib.Path.is_fifo.__qualname__ == 'Path.is_fifo' (len 12); no prior equality assertion."
    - "pathlib.Path.is_socket.__qualname__ == 'Path.is_socket' (len 14); no prior equality assertion."
    - "All methods are plain Python functions (type 'function') defined in Lib/pathlib/_local.py."
    - "Length ordering: is_block_device(20) > is_char_device(19) > expanduser(15)==is_symlink(15) > is_socket(14) > is_fifo(12) > rglob(10)==walk(9)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.rglob and walk qualnames (equality assertions)
# Path.rglob.__qualname__ == 'Path.rglob' (10 chars).
# Path.walk.__qualname__ == 'Path.walk' (9 chars).
# Path.glob.__qualname__.__eq__ was covered in a prior spec; rglob was only covered
# by __name__.__eq__ and code.co_argcount. walk.__qualname__ was only covered by __len__.
# Both rglob and walk are plain Python functions (not C method_descriptors).
# rglob(10) > walk(9): 'rglob'(5) is 1 char longer than 'walk'(4).
# ---------------------------------------------------------------------------

table pathlib_extra124.rglob_walk_qualnames:
  description: "pathlib.Path.rglob.__qualname__='Path.rglob'(10); walk.__qualname__='Path.walk'(9); glob-traversal methods; equality assertions novel; prior specs covered glob eq, rglob name only, walk len only"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlbrgwk124a

  columns: [id, function, args, expected, description]
  rows:
    - [rglob_qn_eq,    "Path.rglob.__qualname__.__eq__",          ["Path.rglob"],  true,  "pathlib.Path.rglob.__qualname__ == 'Path.rglob' (10 chars; rglob recursively yields all matching files under this path using the given pattern)"]
    - [rglob_qn_len,   "Path.rglob.__qualname__.__len__",         [],              10,    "pathlib.Path.rglob.__qualname__.__len__() == 10 ('Path.rglob': 'Path.'(5)+'rglob'(5)==10)"]
    - [walk_qn_eq,     "Path.walk.__qualname__.__eq__",           ["Path.walk"],   true,  "pathlib.Path.walk.__qualname__ == 'Path.walk' (9 chars; walk generates the file names in a directory tree; added in Python 3.12; prior specs covered __len__ only)"]
    - [walk_qn_len,    "Path.walk.__qualname__.__len__",          [],              9,     "pathlib.Path.walk.__qualname__.__len__() == 9 ('Path.walk': 'Path.'(5)+'walk'(4)==9)"]
    - [rglob_gt_walk,  "Path.rglob.__qualname__.__len__.__gt__",  [9],             true,  "len('Path.rglob') > len('Path.walk') (10 > 9; 'rglob'(5) is 1 char longer than 'walk'(4))"]
    - [rglob_type,     "Path.rglob.__class__.__name__.__eq__",    ["function"],    true,  "type(pathlib.Path.rglob).__name__ == 'function' (plain Python function in Lib/pathlib/_local.py; not a C method_descriptor)"]
    - [walk_type,      "Path.walk.__class__.__name__.__eq__",     ["function"],    true,  "type(pathlib.Path.walk).__name__ == 'function' (plain Python function; same type as rglob and all other Path traversal methods)"]
    - [rglob_ne_glob,  "Path.rglob.__qualname__.__eq__",          ["Path.glob"],   false, "pathlib.Path.rglob.__qualname__ != 'Path.glob' (distinct methods: rglob recurses, glob does not; rglob(10) vs glob(9))"]

# ---------------------------------------------------------------------------
# pathlib.Path.expanduser and is_symlink qualnames (equality assertions)
# Path.expanduser.__qualname__ == 'Path.expanduser' (15 chars).
# Path.is_symlink.__qualname__ == 'Path.is_symlink' (15 chars).
# Prior specs covered expanduser.__qualname__.__len__ and co_name, but NOT equality.
# Prior specs covered is_symlink.__qualname__.__len__ and name_eq, but NOT equality.
# Both have identical qualname length (15 chars): 'Path.'(5) + 'expanduser'(10) == 15
# and 'Path.'(5) + 'is_symlink'(10) == 15.
# expanduser expands ~ and ~user in the path; is_symlink returns True if the path
# points to a symbolic link.
# ---------------------------------------------------------------------------

table pathlib_extra124.expanduser_is_symlink_qualnames:
  description: "pathlib.Path.expanduser.__qualname__='Path.expanduser'(15); is_symlink.__qualname__='Path.is_symlink'(15); equality assertions novel; prior specs covered len and co_name/name only"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlbexsy124b

  columns: [id, function, args, expected, description]
  rows:
    - [exp_qn_eq,      "Path.expanduser.__qualname__.__eq__",         ["Path.expanduser"],  true,  "pathlib.Path.expanduser.__qualname__ == 'Path.expanduser' (15 chars; expanduser expands ~ and ~user constructs in the path; prior specs covered len and co_name but not equality)"]
    - [exp_qn_len,     "Path.expanduser.__qualname__.__len__",        [],                   15,    "pathlib.Path.expanduser.__qualname__.__len__() == 15 ('Path.expanduser': 'Path.'(5)+'expanduser'(10)==15)"]
    - [issym_qn_eq,    "Path.is_symlink.__qualname__.__eq__",         ["Path.is_symlink"],  true,  "pathlib.Path.is_symlink.__qualname__ == 'Path.is_symlink' (15 chars; is_symlink returns True if the path points to a symbolic link; prior specs covered len and name_eq but not equality)"]
    - [issym_qn_len,   "Path.is_symlink.__qualname__.__len__",        [],                   15,    "pathlib.Path.is_symlink.__qualname__.__len__() == 15 ('Path.is_symlink': 'Path.'(5)+'is_symlink'(10)==15)"]
    - [exp_eq_issym,   "Path.expanduser.__qualname__.__len__.__eq__", [15],                 true,  "len('Path.expanduser') == len('Path.is_symlink') == 15 (both use 10-char method names; same length as symlink_to and write_text)"]
    - [exp_type,       "Path.expanduser.__class__.__name__.__eq__",   ["function"],         true,  "type(pathlib.Path.expanduser).__name__ == 'function' (plain Python function in Lib/pathlib/_local.py)"]
    - [issym_type,     "Path.is_symlink.__class__.__name__.__eq__",   ["function"],         true,  "type(pathlib.Path.is_symlink).__name__ == 'function' (plain Python function; same type as expanduser and all Path query methods)"]

# ---------------------------------------------------------------------------
# pathlib.Path.is_block_device, is_char_device, is_fifo, is_socket qualnames
# Path.is_block_device.__qualname__ == 'Path.is_block_device' (20 chars).
# Path.is_char_device.__qualname__ == 'Path.is_char_device' (19 chars).
# Path.is_fifo.__qualname__ == 'Path.is_fifo' (12 chars).
# Path.is_socket.__qualname__ == 'Path.is_socket' (14 chars).
# None of these have been covered by any equality assertion in any prior pathlib_extra spec.
# is_block_device(20) is the longest of the four special file type predicates.
# is_char_device(19) > is_socket(14) > is_fifo(12).
# ---------------------------------------------------------------------------

table pathlib_extra124.is_block_char_fifo_socket_qualnames:
  description: "pathlib.Path.is_block_device.__qualname__='Path.is_block_device'(20); is_char_device.__qualname__='Path.is_char_device'(19); is_fifo='Path.is_fifo'(12); is_socket='Path.is_socket'(14); no prior equality assertions"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlbbd124c

  columns: [id, function, args, expected, description]
  rows:
    - [isbd_qn_eq,     "Path.is_block_device.__qualname__.__eq__",         ["Path.is_block_device"],  true,  "pathlib.Path.is_block_device.__qualname__ == 'Path.is_block_device' (20 chars; returns True if path is a block device; 'Path.'(5)+'is_block_device'(15)==20)"]
    - [isbd_qn_len,    "Path.is_block_device.__qualname__.__len__",        [],                        20,    "pathlib.Path.is_block_device.__qualname__.__len__() == 20 ('Path.is_block_device' has 20 characters)"]
    - [iscd_qn_eq,     "Path.is_char_device.__qualname__.__eq__",          ["Path.is_char_device"],   true,  "pathlib.Path.is_char_device.__qualname__ == 'Path.is_char_device' (19 chars; returns True if path is a character device; 'Path.'(5)+'is_char_device'(14)==19)"]
    - [iscd_qn_len,    "Path.is_char_device.__qualname__.__len__",         [],                        19,    "pathlib.Path.is_char_device.__qualname__.__len__() == 19 ('Path.is_char_device' has 19 characters)"]
    - [issk_qn_eq,     "Path.is_socket.__qualname__.__eq__",               ["Path.is_socket"],        true,  "pathlib.Path.is_socket.__qualname__ == 'Path.is_socket' (14 chars; returns True if path is a Unix socket; 'Path.'(5)+'is_socket'(9)==14)"]
    - [issk_qn_len,    "Path.is_socket.__qualname__.__len__",              [],                        14,    "pathlib.Path.is_socket.__qualname__.__len__() == 14 ('Path.is_socket' has 14 characters)"]
    - [isfi_qn_eq,     "Path.is_fifo.__qualname__.__eq__",                 ["Path.is_fifo"],          true,  "pathlib.Path.is_fifo.__qualname__ == 'Path.is_fifo' (12 chars; returns True if path is a FIFO (named pipe); 'Path.'(5)+'is_fifo'(7)==12)"]
    - [isfi_qn_len,    "Path.is_fifo.__qualname__.__len__",                [],                        12,    "pathlib.Path.is_fifo.__qualname__.__len__() == 12 ('Path.is_fifo' has 12 characters)"]
    - [isbd_gt_iscd,   "Path.is_block_device.__qualname__.__len__.__gt__", [19],                      true,  "len('Path.is_block_device') > len('Path.is_char_device') (20 > 19; 'is_block_device'(15) is 1 char longer than 'is_char_device'(14))"]
    - [issk_gt_isfi,   "Path.is_socket.__qualname__.__len__.__gt__",       [12],                      true,  "len('Path.is_socket') > len('Path.is_fifo') (14 > 12; 'is_socket'(9) is 2 chars longer than 'is_fifo'(7))"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra124.Path.rglob_qualname_eq:
  description: "pathlib.Path.rglob.__qualname__ == 'Path.rglob' (length 10; rglob is the recursive variant of glob: it yields all files in this path and all subdirectories that match the given pattern; rglob(pattern) is equivalent to glob('**/' + pattern); it is a plain Python function defined in Lib/pathlib/_local.py and its qualname uses the 'Path.' prefix (5 chars) followed by 'rglob' (5 chars) totalling 10; prior pathlib_extra specs covered rglob.__name__.__eq__ and rglob.__code__.co_argcount but never asserted rglob.__qualname__.__eq__ == 'Path.rglob'; this is the first equality assertion for rglob qualname)"
  category: method_identity
  kind: python_call_eq
  function: "Path.rglob.__qualname__.__eq__"
  args: ["Path.rglob"]
  expected: true

invariant pathlib_extra124.Path.walk_qualname_eq:
  description: "pathlib.Path.walk.__qualname__ == 'Path.walk' (length 9; walk generates the file names in a directory tree rooted at this path; it is similar to os.walk but returns Path objects; walk was added in Python 3.12 as a native pathlib alternative to os.walk; it is a plain Python function in Lib/pathlib/_local.py; its qualname uses the 'Path.' prefix (5 chars) followed by 'walk' (4 chars) totalling 9; 'Path.walk' (9) and 'Path.glob' (9) share the same qualname length — both are single-word traversal methods; prior pathlib_extra specs covered walk.__qualname__.__len__()==9 and walk.__code__.co_argcount but never asserted the equality string 'Path.walk')"
  category: method_identity
  kind: python_call_eq
  function: "Path.walk.__qualname__.__eq__"
  args: ["Path.walk"]
  expected: true

invariant pathlib_extra124.Path.expanduser_qualname_eq:
  description: "pathlib.Path.expanduser.__qualname__ == 'Path.expanduser' (length 15; expanduser returns a new Path with ~ and ~user constructs expanded; on POSIX systems, ~ is expanded using os.path.expanduser; it is a plain Python function defined in Lib/pathlib/_local.py; its qualname uses the 'Path.' prefix (5 chars) followed by 'expanduser' (10 chars) totalling 15; 'Path.expanduser' (15) shares its length with 'Path.is_symlink' (15), 'Path.symlink_to' (15), and 'Path.write_text' (15); prior pathlib_extra specs covered expanduser.__qualname__.__len__()==15 and expanduser.__code__.co_name but not the equality assertion 'Path.expanduser')"
  category: method_identity
  kind: python_call_eq
  function: "Path.expanduser.__qualname__.__eq__"
  args: ["Path.expanduser"]
  expected: true

invariant pathlib_extra124.Path.is_block_device_qualname_eq:
  description: "pathlib.Path.is_block_device.__qualname__ == 'Path.is_block_device' (length 20; is_block_device() returns True if the path points to a block device (such as a disk partition), False if not, and raises OSError if the path does not exist or is inaccessible; block devices are available on POSIX systems and include devices like /dev/sda; it is a plain Python function in Lib/pathlib/_local.py; its qualname 'Path.is_block_device' uses the 'Path.' prefix (5 chars) followed by 'is_block_device' (15 chars) totalling 20; is_block_device(20) is the longest qualname among the Path file-type predicate methods; no prior pathlib_extra spec has covered is_block_device in any form)"
  category: method_identity
  kind: python_call_eq
  function: "Path.is_block_device.__qualname__.__eq__"
  args: ["Path.is_block_device"]
  expected: true

invariant pathlib_extra124.Path.is_fifo_qualname_eq:
  description: "pathlib.Path.is_fifo.__qualname__ == 'Path.is_fifo' (length 12; is_fifo() returns True if the path points to a FIFO (named pipe), False if not, and raises OSError if the path does not exist or is inaccessible; FIFOs are special files used for inter-process communication on POSIX systems; is_fifo is a plain Python function in Lib/pathlib/_local.py; its qualname 'Path.is_fifo' uses the 'Path.' prefix (5 chars) followed by 'is_fifo' (7 chars) totalling 12; is_fifo(12) is the shortest of the four special file-type predicates covered in this spec: is_block_device(20) > is_char_device(19) > is_socket(14) > is_fifo(12); no prior pathlib_extra spec has covered is_fifo in any form)"
  category: method_identity
  kind: python_call_eq
  function: "Path.is_fifo.__qualname__.__eq__"
  args: ["Path.is_fifo"]
  expected: true

