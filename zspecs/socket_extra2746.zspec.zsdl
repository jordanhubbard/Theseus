spec: socket_extra2746
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/socket.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 630 theme: __round__, __divmod__, and __pow__ dict-presence checks."
    - "socket.socket is a network socket class; it does not implement __round__, __divmod__, or __pow__ in its own __dict__."
    - "socket.AddressFamily is an IntEnum representing address families (AF_INET, AF_UNIX, etc.); IntEnum provides arithmetic via the int MRO, but AddressFamily does NOT define __round__, __divmod__, or __pow__ in its own __dict__."
    - "socket.SocketKind is an IntEnum representing socket types (SOCK_STREAM, SOCK_DGRAM, etc.); same reasoning as AddressFamily — its own __dict__ does not contain __round__, __divmod__, or __pow__."
    - "None of the socket public classes define __round__, __divmod__, or __pow__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __round__ dict-presence — absent from all socket classes
# ---------------------------------------------------------------------------

table socket_extra2746.round_protocol:
  description: "__round__ is absent from all socket class __dict__s — none implement numeric rounding in their own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2746

  columns: [id, function, args, expected]
  rows:
    - ["sk2746001", "socket.socket.__dict__.__contains__",        ["__round__"], false]
    - ["sk2746002", "socket.AddressFamily.__dict__.__contains__", ["__round__"], false]
    - ["sk2746003", "socket.SocketKind.__dict__.__contains__",    ["__round__"], false]

