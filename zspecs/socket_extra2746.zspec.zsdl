# ---------------------------------------------------------------------------
# Combined view — AddressFamily and SocketKind vs. all three arithmetic protocols
# ---------------------------------------------------------------------------

table socket_extra2746.enum_arithmetic_combined:
  description: "socket.AddressFamily and socket.SocketKind define none of __round__, __divmod__, __pow__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2746

  columns: [id, function, args, expected]
  rows:
    - ["sk2746010", "socket.AddressFamily.__dict__.__contains__", ["__round__"],  false]
    - ["sk2746011", "socket.AddressFamily.__dict__.__contains__", ["__divmod__"], false]
    - ["sk2746012", "socket.AddressFamily.__dict__.__contains__", ["__pow__"],    false]
    - ["sk2746013", "socket.SocketKind.__dict__.__contains__",    ["__round__"],  false]
    - ["sk2746014", "socket.SocketKind.__dict__.__contains__",    ["__divmod__"], false]
    - ["sk2746015", "socket.SocketKind.__dict__.__contains__",    ["__pow__"],    false]
