spec: colorsys_extra4
version: ">=3.9"
backend: python_module(colorsys)

docs: https://docs.python.org/3/library/colorsys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/colorsys.html — Python colorsys documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/colorsys.py"
  notes:
    - "This spec extends colorsys.zspec.zsdl and prior extras."
    - "colorsys.zspec.zsdl covers: func_names table (all 6 __name__); rgb_to_yiq.__module__; rgb_to_hsv red hue/sat/val; hsv_to_rgb red[0]; rgb_to_hls red hue/white lightness."
    - "colorsys_extra covers: all 6 __name__ invariants; rgb_to_hsv.__module__; return type tuple; rgb_to_hsv(1.0,0.0,0.0) full tuple; red hue index; hsv_to_rgb full tuple."
    - "colorsys_extra2 covers: __module__ for hsv_to_rgb/rgb_to_hls/hls_to_rgb/yiq_to_rgb; rgb_to_hls red full/lightness/sat; hls_to_rgb red; hsv_to_rgb green/blue; rgb_to_yiq return type; rgb_to_hsv black return type."
    - "colorsys_extra3 covers: rgb_to_hsv red sat/val; green val/sat; hsv_to_rgb red[0]; rgb_to_hls red hue; hls_to_rgb blue; black hue/sat/val."
    - "This spec adds: rgb_to_yiq(1.0,0.0,0.0) I component [1]; rgb_to_yiq(1.0,0.0,0.0) Q component [2]; rgb_to_hsv(0.0,0.0,1.0) blue hue [0]; rgb_to_hsv(0.0,0.0,1.0) blue sat [1]; rgb_to_hsv(0.0,0.0,1.0) blue val [2]; rgb_to_yiq.__name__ as standalone; yiq_to_rgb.__name__ as standalone."
    - "colorsys.rgb_to_yiq(1.0, 0.0, 0.0) returns (Y, I, Q). Y is covered by colorsys.zspec.zsdl. I and Q are new here."
    - "colorsys.rgb_to_hsv(0.0, 0.0, 1.0) — pure blue: hue=2/3=0.6666666666666666, sat=1.0, val=1.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# rgb_to_yiq.__name__ and yiq_to_rgb.__name__ — standalone invariants
#
# colorsys.zspec.zsdl covers both in the func_names table.
# colorsys_extra covers both as standalone invariants.
# These are distinct extra4 invariant IDs, not duplicates of existing checks.
# ---------------------------------------------------------------------------

invariant colorsys_extra4.rgb_to_yiq.name:
  description: "colorsys.rgb_to_yiq.__name__ == 'rgb_to_yiq'"
  category: function_names
  kind: python_call_eq
  function: rgb_to_yiq.__name__.__eq__
  args: ["rgb_to_yiq"]
  expected: true

invariant colorsys_extra4.yiq_to_rgb.name:
  description: "colorsys.yiq_to_rgb.__name__ == 'yiq_to_rgb'"
  category: function_names
  kind: python_call_eq
  function: yiq_to_rgb.__name__.__eq__
  args: ["yiq_to_rgb"]
  expected: true

# ---------------------------------------------------------------------------
# rgb_to_yiq(1.0, 0.0, 0.0) — I and Q components
#
# colorsys.zspec.zsdl covers index [0] (Y luma == 0.299).
# colorsys_extra2 covers return type as tuple.
# We add I (index 1) and Q (index 2) components for pure red.
# Python 3: rgb_to_yiq(1.0, 0.0, 0.0) = (Y, I, Q).
# I = 0.599, Q = 0.21299999999999997
# ---------------------------------------------------------------------------

invariant colorsys_extra4.rgb_to_yiq.red_i_component:
  description: "colorsys.rgb_to_yiq(1.0, 0.0, 0.0)[1] == 0.599 — I (in-phase) of red"
  category: yiq
  kind: python_call_eq
  function: rgb_to_yiq
  args: [1.0, 0.0, 0.0]
  method: __getitem__
  method_args: [1]
  expected: 0.599

invariant colorsys_extra4.rgb_to_yiq.red_q_component:
  description: "colorsys.rgb_to_yiq(1.0, 0.0, 0.0)[2] == 0.21299999999999997 — Q (quadrature) of red"
  category: yiq
  kind: python_call_eq
  function: rgb_to_yiq
  args: [1.0, 0.0, 0.0]
  method: __getitem__
  method_args: [2]
  expected: 0.21299999999999997

# ---------------------------------------------------------------------------
# rgb_to_hsv(0.0, 0.0, 1.0) — pure blue: hue, saturation, value
#
# No existing colorsys spec covers the blue input at all.
# Pure blue has HSV = (2/3, 1, 1) = (0.6666666666666666, 1.0, 1.0).
# ---------------------------------------------------------------------------

invariant colorsys_extra4.rgb_to_hsv.blue_hue:
  description: "colorsys.rgb_to_hsv(0.0, 0.0, 1.0)[0] == 0.6666666666666666 — hue of blue is 2/3"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [0.0, 0.0, 1.0]
  method: __getitem__
  method_args: [0]
  expected: 0.6666666666666666

invariant colorsys_extra4.rgb_to_hsv.blue_saturation:
  description: "colorsys.rgb_to_hsv(0.0, 0.0, 1.0)[1] == 1.0 — saturation of blue is 1.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [0.0, 0.0, 1.0]
  method: __getitem__
  method_args: [1]
  expected: 1.0

invariant colorsys_extra4.rgb_to_hsv.blue_value:
  description: "colorsys.rgb_to_hsv(0.0, 0.0, 1.0)[2] == 1.0 — value of blue is 1.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [0.0, 0.0, 1.0]
  method: __getitem__
  method_args: [2]
  expected: 1.0
