spec: ctypes_extra7
version: ">=3.9"
backend: python_module(ctypes)

docs: https://docs.python.org/3/library/ctypes.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ctypes.html — Python ctypes module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ctypes/__init__.py"
    - "CPython source: Modules/_ctypes/"
    - "ctypes.zspec.zsdl — baseline type names and instance value round-trips."
    - "ctypes_extra.zspec.zsdl through ctypes_extra6.zspec.zsdl — prior extras."
  notes:
    - "This spec extends ctypes.zspec.zsdl through ctypes_extra6.zspec.zsdl."
    - "This spec adds NEW axes:"
    - "  (1) __bases__[0].__name__ for compound types Structure/Union/Array — all '_CData'."
    - "  (2) __bases__[0].__name__ for simple types c_int/c_char/c_double — all '_SimpleCData'."
    - "  (3) Table of base class names for 8 ctypes classes."
    - "ctypes.Structure.__bases__[0].__name__ == '_CData' — Verified Python 3.12 macOS."
    - "ctypes.Union.__bases__[0].__name__ == '_CData' — Verified."
    - "ctypes.Array.__bases__[0].__name__ == '_CData' — Verified."
    - "ctypes.c_int.__bases__[0].__name__ == '_SimpleCData' — Verified."
    - "ctypes.c_char.__bases__[0].__name__ == '_SimpleCData' — Verified."
    - "ctypes.c_double.__bases__[0].__name__ == '_SimpleCData' — Verified."
    - "ctypes.c_float.__bases__[0].__name__ == '_SimpleCData' — Verified."
    - "ctypes.c_long.__bases__[0].__name__ == '_SimpleCData' — Verified."
    - "ctypes.c_bool.__bases__[0].__name__ == '_SimpleCData' — Verified."
    - "ctypes.c_uint.__bases__[0].__name__ == '_SimpleCData' — Verified."
    - "ctypes.c_short.__bases__[0].__name__ == '_SimpleCData' — Verified."
    - "ctypes.c_byte.__bases__[0].__name__ == '_SimpleCData' — Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Compound type base class — Structure, Union, Array
#
# Structure, Union, and Array are the three compound ctypes classes. All
# inherit directly from _CData (the internal C base class). No prior ctypes
# spec checks this base class relationship. extra7 anchors it.
# ---------------------------------------------------------------------------

invariant ctypes_extra7.bases.structure:
  description: "ctypes.Structure.__bases__[0].__name__ == '_CData' — Structure inherits from _CData"
  category: class_hierarchy
  kind: python_call_eq
  "function": "Structure.__bases__[0].__name__.__eq__"
  args: ["_CData"]
  expected: true

invariant ctypes_extra7.bases.union:
  description: "ctypes.Union.__bases__[0].__name__ == '_CData' — Union inherits from _CData"
  category: class_hierarchy
  kind: python_call_eq
  "function": "Union.__bases__[0].__name__.__eq__"
  args: ["_CData"]
  expected: true

invariant ctypes_extra7.bases.array:
  description: "ctypes.Array.__bases__[0].__name__ == '_CData' — Array inherits from _CData"
  category: class_hierarchy
  kind: python_call_eq
  "function": "Array.__bases__[0].__name__.__eq__"
  args: ["_CData"]
  expected: true

# ---------------------------------------------------------------------------
# Simple type base class — c_int, c_char, c_double
#
# Simple scalar types (c_int, c_char, c_double, etc.) all inherit from
# _SimpleCData, which in turn inherits from _CData. The extra7 namespace
# anchors the intermediate _SimpleCData level for three representative types.
# ---------------------------------------------------------------------------

invariant ctypes_extra7.bases.c_int:
  description: "ctypes.c_int.__bases__[0].__name__ == '_SimpleCData' — c_int inherits from _SimpleCData"
  category: class_hierarchy
  kind: python_call_eq
  "function": "c_int.__bases__[0].__name__.__eq__"
  args: ["_SimpleCData"]
  expected: true

invariant ctypes_extra7.bases.c_char:
  description: "ctypes.c_char.__bases__[0].__name__ == '_SimpleCData' — c_char inherits from _SimpleCData"
  category: class_hierarchy
  kind: python_call_eq
  "function": "c_char.__bases__[0].__name__.__eq__"
  args: ["_SimpleCData"]
  expected: true

invariant ctypes_extra7.bases.c_double:
  description: "ctypes.c_double.__bases__[0].__name__ == '_SimpleCData' — c_double inherits from _SimpleCData"
  category: class_hierarchy
  kind: python_call_eq
  "function": "c_double.__bases__[0].__name__.__eq__"
  args: ["_SimpleCData"]
  expected: true

# ---------------------------------------------------------------------------
# Base class name table — 8 ctypes classes
#
# Compound types (Structure/Union/Array) inherit from _CData.
# Simple types (c_int/c_char/c_double/c_float/c_long) inherit from _SimpleCData.
# This table captures both tiers in a single view from the extra7 namespace.
# id_prefix ct7 does not conflict with any prior ctypes spec.
# ---------------------------------------------------------------------------

table ctypes_extra7.bases.all_types:
  description: "Direct base class name for 8 ctypes classes — _CData or _SimpleCData"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: ct7

  columns: [id, function, args, expected]
  rows:
    - [structure_base, "Structure.__bases__[0].__name__.__eq__", ["_CData"],       true]
    - [union_base,     "Union.__bases__[0].__name__.__eq__",     ["_CData"],       true]
    - [array_base,     "Array.__bases__[0].__name__.__eq__",     ["_CData"],       true]
    - [c_int_base,     "c_int.__bases__[0].__name__.__eq__",     ["_SimpleCData"], true]
    - [c_char_base,    "c_char.__bases__[0].__name__.__eq__",    ["_SimpleCData"], true]
    - [c_double_base,  "c_double.__bases__[0].__name__.__eq__",  ["_SimpleCData"], true]
    - [c_float_base,   "c_float.__bases__[0].__name__.__eq__",   ["_SimpleCData"], true]
    - [c_long_base,    "c_long.__bases__[0].__name__.__eq__",    ["_SimpleCData"], true]
