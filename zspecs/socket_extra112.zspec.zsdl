spec: socket_extra112
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra111.zspec.zsdl — covers socket module-level __name__/__package__/__spec__/__all__/__loader__ dunder attributes (table + invariants)."
    - "socket_extra110.zspec.zsdl — covers socket.socket context manager methods / socket.__repr__ qualname / socket.socket.__module__/__qualname__ equality (table + invariants)."
    - "socket_extra109.zspec.zsdl — covers socket.socket Python-defined method co_argcount values and qualnames (table + invariants)."
    - "socket_extra108.zspec.zsdl — covers gethostname/gethostbyname/getnameinfo/getaddrinfo/getfqdn function identities (table + invariants)."
    - "socket_extra107.zspec.zsdl — covers SO_* option constants and socket.error/timeout class identity and MRO (table + invariants)."
    - "socket_extra106.zspec.zsdl — covers IPPROTO_* constants class names and values (table + invariants)."
    - "socket_extra105.zspec.zsdl — covers AF_*/SOCK_* class module/qualname/mro / AddressFamily/SocketKind name/module/metaclass/base identity (table + invariants)."
    - "socket_extra104.zspec.zsdl — covers socket.socket C-method types and qualname lengths (table + invariants)."
    - "socket_extra103.zspec.zsdl — covers socket.inet_aton/ntoa/pton/ntop / herror/gaierror MRO / AddressFamily/SocketKind MRO depth (table + invariants)."
    - "socket_extra102.zspec.zsdl — covers socket.socket __qualname__/__name__.__len__()==6 / error.__name__.__eq__('OSError') / herror/gaierror qualname/module/bases (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module-level function qualname lengths / SocketIO class metaclass/module/bases (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC and SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ (table + invariants)."
  notes:
    - "This spec extends socket through socket_extra111; it does NOT duplicate invariants present in those files."
    - "Wave 272 theme: AddressFamily and SocketKind enum member .name attribute string equality and lengths; socket.socket class MRO structure and base class; socket.socket.bind and socket.socket.connect method qualname lengths."
    - "socket.AF_INET.name == 'AF_INET' (7 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET6.name == 'AF_INET6' (8 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX.name == 'AF_UNIX' (7 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.name == 'SOCK_STREAM' (11 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.name == 'SOCK_DGRAM' (10 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_RAW.name == 'SOCK_RAW' (8 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__mro__.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__mro__[0].__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__mro__[1].__name__ == 'socket' (the _socket.socket base class). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__mro__[2].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__bases__[0].__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__qualname__ == 'socket.bind' (11 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__qualname__ == 'socket.connect' (14 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__qualname__ == 'socket.close' (12 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket has a 3-element MRO because socket.socket (Python class) inherits from _socket.socket (C class), which inherits from object. Both the Python wrapper and the C class are named 'socket', so __mro__[0].__name__==__mro__[1].__name__=='socket'. socket_extra105 anchors AddressFamily/SocketKind MRO depth; this spec anchors the socket.socket class MRO structure."
    - "Note: AddressFamily and SocketKind enum member .name attributes return the enum member name as a string. AF_INET.name=='AF_INET' (7 chars; uppercase with AF_ prefix); SOCK_STREAM.name=='SOCK_STREAM' (11 chars; uppercase with SOCK_ prefix). socket_extra96 anchors AF_*/SOCK_* class names (AddressFamily/SocketKind); this spec anchors the .name attribute string values and lengths for the first time."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET.name.__eq__('AF_INET')
# socket.AF_INET6.name.__eq__('AF_INET6')
# socket.AF_UNIX.name.__eq__('AF_UNIX')
# socket.AF_INET.name.__len__() == 7
# socket.AF_INET6.name.__len__() == 8
#
# Wave 272 theme: AddressFamily enum member .name attribute equality and lengths.
#
# AF_INET, AF_INET6, AF_UNIX are members of the AddressFamily IntEnum. Each has
# a .name attribute returning the member name as a string. AF_INET.name=='AF_INET'
# (7 chars: A-F-_-I-N-E-T). AF_INET6.name=='AF_INET6' (8 chars: adds '6' suffix).
# AF_UNIX.name=='AF_UNIX' (7 chars, same length as AF_INET). socket_extra96
# anchors AF_INET/__class__.__name__=='AddressFamily'; this spec anchors the .name
# attribute string equality and lengths for the first time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra112.address_family_member_name_equality_and_lengths:
  description: "AF_INET.name.__eq__('AF_INET')==True / AF_INET6.name.__eq__('AF_INET6')==True / AF_UNIX.name.__eq__('AF_UNIX')==True / AF_INET.name.__len__()==7 / AF_INET6.name.__len__()==8 — AddressFamily enum .name returns member name string; AF_INET=7 chars (A-F-_-I-N-E-T); AF_INET6=8 chars (adds '6'); AF_UNIX=7 chars (same as AF_INET); extra96 anchors class names; first sockenum112 anchor"
  kind: python_call_eq
  category: enum_identity
  id_prefix: sockenum112

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_name_eq,   "AF_INET.name.__eq__",  ["AF_INET"],  true, "socket.AF_INET.name is 'AF_INET' (7 chars; AddressFamily IntEnum member name; IPv4 address family)"]
    - [af_inet6_name_eq,  "AF_INET6.name.__eq__", ["AF_INET6"], true, "socket.AF_INET6.name is 'AF_INET6' (8 chars; IPv6 address family; one char longer than AF_INET)"]
    - [af_unix_name_eq,   "AF_UNIX.name.__eq__",  ["AF_UNIX"],  true, "socket.AF_UNIX.name is 'AF_UNIX' (7 chars; Unix domain socket; same length as AF_INET)"]
    - [af_inet_name_len,  "AF_INET.name.__len__", [],           7,    "socket.AF_INET.name.__len__() is 7 ('AF_INET': A-F-_-I-N-E-T)"]
    - [af_inet6_name_len, "AF_INET6.name.__len__", [],          8,    "socket.AF_INET6.name.__len__() is 8 ('AF_INET6': A-F-_-I-N-E-T-6)"]

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.name.__eq__('SOCK_STREAM')
# socket.SOCK_DGRAM.name.__eq__('SOCK_DGRAM')
# socket.SOCK_RAW.name.__eq__('SOCK_RAW')
# socket.SOCK_STREAM.name.__len__() == 11
# socket.SOCK_DGRAM.name.__len__() == 10
#
# Wave 272 theme: SocketKind enum member .name attribute equality and lengths.
#
# SOCK_STREAM, SOCK_DGRAM, SOCK_RAW are members of the SocketKind IntEnum.
# SOCK_STREAM.name=='SOCK_STREAM' (11 chars: longest). SOCK_DGRAM.name==
# 'SOCK_DGRAM' (10 chars: one less than SOCK_STREAM). SOCK_RAW.name=='SOCK_RAW'
# (8 chars: shortest among these three). socket_extra96 anchors SOCK_*
# __class__.__name__=='SocketKind'; this spec anchors the .name attribute
# string equality and lengths for the first time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra112.socket_kind_member_name_equality_and_lengths:
  description: "SOCK_STREAM.name.__eq__('SOCK_STREAM')==True / SOCK_DGRAM.name.__eq__('SOCK_DGRAM')==True / SOCK_RAW.name.__eq__('SOCK_RAW')==True / SOCK_STREAM.name.__len__()==11 / SOCK_DGRAM.name.__len__()==10 — SocketKind enum .name returns member name string; SOCK_STREAM=11 chars (longest); SOCK_DGRAM=10 chars; SOCK_RAW=8 chars (shortest); extra96 anchors class names; first sockenum112 anchor"
  kind: python_call_eq
  category: enum_identity
  id_prefix: sockenum112

  columns: [id, function, args, expected, description]
  rows:
    - [sock_stream_name_eq,  "SOCK_STREAM.name.__eq__",  ["SOCK_STREAM"], true, "socket.SOCK_STREAM.name is 'SOCK_STREAM' (11 chars; SocketKind IntEnum member; TCP-style reliable stream)"]
    - [sock_dgram_name_eq,   "SOCK_DGRAM.name.__eq__",   ["SOCK_DGRAM"],  true, "socket.SOCK_DGRAM.name is 'SOCK_DGRAM' (10 chars; UDP-style unreliable datagram)"]
    - [sock_raw_name_eq,     "SOCK_RAW.name.__eq__",     ["SOCK_RAW"],    true, "socket.SOCK_RAW.name is 'SOCK_RAW' (8 chars; raw socket for low-level network access)"]
    - [sock_stream_name_len, "SOCK_STREAM.name.__len__", [],              11,   "socket.SOCK_STREAM.name.__len__() is 11 ('SOCK_STREAM': S-O-C-K-_-S-T-R-E-A-M)"]
    - [sock_dgram_name_len,  "SOCK_DGRAM.name.__len__",  [],              10,   "socket.SOCK_DGRAM.name.__len__() is 10 ('SOCK_DGRAM': S-O-C-K-_-D-G-R-A-M; one less than SOCK_STREAM)"]

# ---------------------------------------------------------------------------
# socket.socket.__mro__.__len__() == 3
# socket.socket.__mro__[0].__name__.__eq__('socket')
# socket.socket.__mro__[2].__name__.__eq__('object')
# socket.socket.__bases__[0].__module__.__eq__('_socket')
# socket.socket.bind.__qualname__.__len__() == 11
#
# Wave 272 theme: socket.socket class MRO structure and bind method qualname length.
#
# socket.socket has a 3-element MRO: [socket.socket, _socket.socket, object].
# Both the Python wrapper and the C class share the name 'socket', so
# __mro__[0].__name__==__mro__[1].__name__=='socket'. __mro__[2].__name__=='object'.
# socket.socket.__bases__[0] is _socket.socket (the C class), whose __module__
# is '_socket'. socket.socket.bind is a C-level method_descriptor with qualname
# 'socket.bind' (11 chars: 'socket.'=7 + 'bind'=4). socket_extra105 anchors
# AddressFamily/SocketKind MRO; this spec anchors socket.socket class MRO.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra112.socket_class_mro_and_bind_qualname_length:
  description: "socket.__mro__.__len__()==3 / socket.__mro__[0].__name__.__eq__('socket')==True / socket.__mro__[2].__name__.__eq__('object')==True / socket.__bases__[0].__module__.__eq__('_socket')==True / socket.bind.__qualname__.__len__()==11 — MRO is [socket.socket, _socket.socket, object] (3 elements); both Python and C classes named 'socket'; object at [2]; base class module is '_socket'; bind qualname is 'socket.bind' (11 chars); extra105 anchors AddressFamily MRO; first sockenum112 anchor"
  kind: python_call_eq
  category: class_identity
  id_prefix: sockenum112

  columns: [id, function, args, expected, description]
  rows:
    - [mro_len,             "socket.__mro__.__len__",                  [],          3,    "socket.socket.__mro__.__len__() is 3 ([socket.socket, _socket.socket, object]; Python wrapper + C base + object)"]
    - [mro_0_name_eq,       "socket.__mro__[0].__name__.__eq__",       ["socket"],  true, "socket.socket.__mro__[0].__name__ is 'socket' (the Python wrapper class itself is first in its own MRO)"]
    - [mro_2_name_eq,       "socket.__mro__[2].__name__.__eq__",       ["object"],  true, "socket.socket.__mro__[2].__name__ is 'object' (root of all Python classes; final element of any MRO)"]
    - [base_module_eq,      "socket.__bases__[0].__module__.__eq__",   ["_socket"], true, "socket.socket.__bases__[0].__module__ is '_socket' (the C extension base class; provides low-level socket syscall wrappers)"]
    - [bind_qualname_len,   "socket.bind.__qualname__.__len__",        [],          11,   "socket.socket.bind.__qualname__.__len__() is 11 ('socket.bind': 'socket.'=7 + 'bind'=4; C-level method_descriptor)"]

# ---------------------------------------------------------------------------
# socket.AF_INET.name.__eq__('AF_INET') — standalone
#
# socket.AF_INET.name is 'AF_INET'. AF_INET is a member of the AddressFamily
# IntEnum. The .name attribute of an IntEnum member returns the member name
# as a string. 'AF_INET' (7 chars) is the symbolic name for IPv4 address
# family (value 2 on macOS/Linux). The 'AF_' prefix stands for 'Address Family'.
# socket_extra96 anchors socket.AF_INET.__class__.__name__=='AddressFamily';
# this spec anchors AF_INET.name string equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra112.af_inet_name_eq:
  description: "socket.AF_INET.name.__eq__('AF_INET') == True — AddressFamily IntEnum member .name is 'AF_INET' (7 chars; A-F-_-I-N-E-T; 'AF_' prefix means Address Family; IPv4 address family; value 2 on macOS/Linux); extra96 anchors __class__.__name__=='AddressFamily'; first standalone under sockenum112"
  category: enum_identity
  kind: python_call_eq
  function: "AF_INET.name.__eq__"
  args: ["AF_INET"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.name.__eq__('SOCK_STREAM') — standalone
#
# socket.SOCK_STREAM.name is 'SOCK_STREAM'. SOCK_STREAM is a member of the
# SocketKind IntEnum. The .name attribute returns the member name 'SOCK_STREAM'
# (11 chars: S-O-C-K-_-S-T-R-E-A-M). 'SOCK_STREAM' is the longest .name
# among the three SocketKind members tested in this spec (SOCK_STREAM=11,
# SOCK_DGRAM=10, SOCK_RAW=8). SOCK_STREAM provides reliable, connection-oriented,
# byte-stream communication (used with TCP). socket_extra96 anchors
# socket.SOCK_STREAM.__class__.__name__=='SocketKind'; this spec anchors
# SOCK_STREAM.name equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra112.sock_stream_name_eq:
  description: "socket.SOCK_STREAM.name.__eq__('SOCK_STREAM') == True — SocketKind IntEnum member .name is 'SOCK_STREAM' (11 chars; longest in this spec; 'SOCK_' prefix means socket kind); provides reliable byte-stream (TCP); longest among SOCK_STREAM=11, SOCK_DGRAM=10, SOCK_RAW=8; extra96 anchors __class__.__name__=='SocketKind'; first standalone under sockenum112"
  category: enum_identity
  kind: python_call_eq
  function: "SOCK_STREAM.name.__eq__"
  args: ["SOCK_STREAM"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__mro__.__len__() == 3 — standalone
#
# socket.socket.__mro__.__len__() is 3. The socket.socket class has a 3-element
# MRO: [socket.socket (Python wrapper), _socket.socket (C base), object].
# The MRO length of 3 is smaller than most exception class MROs (e.g., struct.error
# has MRO length 4: error->Exception->BaseException->object). The 3-element MRO
# reflects that socket.socket has a single parent (_socket.socket) which itself
# directly inherits from object. socket_extra105 anchors AddressFamily/SocketKind
# MRO depth; this spec anchors socket.socket class MRO length as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra112.socket_class_mro_len:
  description: "socket.socket.__mro__.__len__() == 3 — MRO has 3 elements [socket.socket, _socket.socket, object]; smaller than exception MROs (struct.error has 4); single parent chain: Python wrapper -> C base -> object; extra105 anchors AddressFamily/SocketKind MRO depth; first standalone for socket.socket MRO length under sockenum112"
  category: class_identity
  kind: python_call_eq
  function: "socket.__mro__.__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# socket.socket.__bases__[0].__module__.__eq__('_socket') — standalone
#
# socket.socket.__bases__[0].__module__ is '_socket'. socket.socket (defined
# in Lib/socket.py) inherits from _socket.socket (defined in Modules/socketmodule.c).
# The _socket C extension is the low-level module that wraps the OS socket system
# calls. socket.socket.__bases__[0] is the _socket.socket C class, whose __module__
# is '_socket' (7 chars: underscore + 'socket'). The '_socket' module name follows
# the CPython convention of prefixing private C extensions with underscore.
# This parallels _hashlib (hashlib's C extension) and _struct (struct's C extension).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra112.socket_base_module_eq:
  description: "socket.socket.__bases__[0].__module__.__eq__('_socket') == True — base class __module__ is '_socket' (7 chars; leading underscore is CPython convention for private C extension); _socket wraps OS socket syscalls; parallels _hashlib (hashlib C extension) and _struct (struct C extension); first standalone under sockenum112"
  category: class_identity
  kind: python_call_eq
  function: "socket.__bases__[0].__module__.__eq__"
  args: ["_socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.connect.__qualname__.__len__() == 14 — standalone
#
# socket.socket.connect.__qualname__.__len__() is 14. socket.socket.connect
# is a C-level method_descriptor with qualname 'socket.connect' (14 chars:
# 'socket.'=7 + 'connect'=7). This is longer than socket.socket.bind.__qualname__
# (11 chars: 'socket.bind') and socket.socket.close.__qualname__ (12 chars:
# 'socket.close'). The qualname length difference reflects the attribute name
# length: 'connect'=7 > 'close'=5 > 'bind'=4. socket_extra104 anchors
# socket.socket C-method qualname lengths; this spec anchors connect qualname
# length as a standalone under sockenum112.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra112.connect_qualname_len:
  description: "socket.socket.connect.__qualname__.__len__() == 14 — qualname 'socket.connect' is 14 chars ('socket.'=7 + 'connect'=7); longer than bind=11 ('socket.'=7+'bind'=4) and close=12 ('socket.'=7+'close'=5); C-level method_descriptor; qualname length reflects attribute name length: connect=7 > close=5 > bind=4; extra104 anchors C-method qualname lengths; first standalone under sockenum112"
  category: method_identity
  kind: python_call_eq
  function: "socket.connect.__qualname__.__len__"
  args: []
  expected: 14
