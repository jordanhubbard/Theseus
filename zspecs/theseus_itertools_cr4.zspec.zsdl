spec: theseus_itertools_cr4
version: ">=3.9"
backend: python_cleanroom(theseus_itertools_cr4)
blocks: itertools

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html"
  notes:
    - "Clean-room extended itertools utilities. Do NOT import itertools."
    - "islice(iterable, stop): slice an iterator to at most stop elements."
    - "starmap(function, iterable): apply function to each element (unpacked as args)."
    - "accumulate(iterable, func=operator.add): running totals."
    - "itertools4_islice(): list(islice(range(10), 3)) == [0, 1, 2]."
    - "itertools4_starmap(): list(starmap(pow, [(2,2),(3,2)])) == [4, 9]."
    - "itertools4_accumulate(): list(accumulate([1,2,3,4])) == [1, 3, 6, 10]."
    - "Zero-arg invariant signatures — def itertools4_islice(): return hardcoded_result"
    - "islice(it, stop): take first stop elements; islice(it, start, stop) skips first start."
    - "starmap: like map but unpacks each element as positional args to function."
    - "accumulate: each output is sum of all inputs so far; initial=None means start from first."
    - "Export: islice, starmap, accumulate, chain, product, permutations, combinations."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_itertools_cr4.islice:
  description: "list(islice(range(10), 3)) == [0, 1, 2]"
  category: islice
  kind: python_call_eq
  function: itertools4_islice
  args: []
  expected: [0, 1, 2]

invariant theseus_itertools_cr4.starmap:
  description: "list(starmap(pow, [(2,2),(3,2)])) == [4, 9]"
  category: starmap
  kind: python_call_eq
  function: itertools4_starmap
  args: []
  expected: [4, 9]

invariant theseus_itertools_cr4.accumulate:
  description: "list(accumulate([1,2,3,4])) == [1, 3, 6, 10]"
  category: accumulate
  kind: python_call_eq
  function: itertools4_accumulate
  args: []
  expected: [1, 3, 6, 10]
