spec: clsx
version: ">=2.0.0"
backend: node(clsx)

docs: https://github.com/lukeed/clsx#readme

provenance:
  derived_from:
    - "clsx README — https://github.com/lukeed/clsx#readme"
    - "Test vectors verified with clsx via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "clsx source"
  notes:
    - "Conditional className builder — drop-in faster classnames replacement."
    - "Install: npm install clsx"
    - "v2 dual ESM/CJS; module export IS the function. Joins truthy strings, ignores falsy values, and reads truthy keys from object args."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant clsx.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant clsx.two_strings:
  description: "clsx('a', 'b') joins with a single space"
  category: build
  kind: node_chain_eq
  entry: module
  entry_args: ["a", "b"]
  chain: []
  expected: "a b"

invariant clsx.skips_null:
  description: "Falsy values (null) are skipped between two strings"
  category: build
  kind: node_chain_eq
  entry: module
  entry_args: ["a", null, "b"]
  chain: []
  expected: "a b"

invariant clsx.object_truthy_keys:
  description: "Object keys with truthy values are included; falsy are dropped"
  category: build
  kind: node_chain_eq
  entry: module
  entry_args: [{"a": true, "b": false, "c": 1}]
  chain: []
  expected: "a c"

invariant clsx.array_args:
  description: "Arrays of class strings are flattened"
  category: build
  kind: node_chain_eq
  entry: module
  entry_args: [["a", "b"]]
  chain: []
  expected: "a b"

invariant clsx.no_args_empty:
  description: "clsx() with no args returns empty string"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain: []
  expected: ""

invariant clsx.skips_undefined_and_false:
  description: "undefined and false are dropped"
  category: build
  kind: node_chain_eq
  entry: module
  entry_args: ["foo", false, null, "bar"]
  chain: []
  expected: "foo bar"

invariant clsx.has_named_clsx_export:
  description: "Module export also has a 'clsx' property pointing to itself (named-export form)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "clsx.constructor.name"}
  expected: "Function"
