spec: sys_extra7
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
  notes:
    - "This spec extends sys.zspec.zsdl, sys_extra.zspec.zsdl, sys_extra2.zspec.zsdl, sys_extra3.zspec.zsdl, sys_extra4.zspec.zsdl, sys_extra5.zspec.zsdl, sys_extra6.zspec.zsdl."
    - "sys.zspec.zsdl covers hexversion.__ge__(50397424) and version_info.major==3."
    - "sys_extra/extra2/extra4/extra5 cover byteorder.__class__.__name__=='str', version.__class__.__name__=='str', hexversion.__class__.__name__=='int', float_info/int_info/hash_info/thread_info class names."
    - "sys_extra/extra6 cover implementation.name=='cpython' and implementation.name class name."
    - "No prior spec covers __qualname__ for any sys function."
    - "No prior spec covers sys.implementation.__class__.__name__ == 'SimpleNamespace'."
    - "No prior spec covers sys.byteorder.__len__() >= 3 (the shortest valid value, 'big', has 3 chars)."
    - "sys.getdefaultencoding.__qualname__ == 'getdefaultencoding' — module-level C built-in."
    - "sys.getrecursionlimit.__qualname__ == 'getrecursionlimit' — module-level C built-in."
    - "sys.getsizeof.__qualname__ == 'getsizeof' — module-level C built-in."
    - "sys.exc_info.__qualname__ == 'exc_info' — module-level C built-in."
    - "sys.exit.__qualname__ == 'exit' — module-level C built-in."
    - "sys.implementation.__class__.__name__ == 'SimpleNamespace' — CPython uses types.SimpleNamespace."
    - "sys.byteorder.__len__() >= 3 — 'big' (3 chars) and 'little' (6 chars) are the only valid values."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for sys module-level functions
#
# No prior spec covers __qualname__ for any sys function.  For built-in
# C functions at module level, __qualname__ equals __name__.
# ---------------------------------------------------------------------------

table sys_extra7.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [getdefaultencoding,    getdefaultencoding.__qualname__.__eq__,    ["getdefaultencoding"],    true]
    - [getrecursionlimit,     getrecursionlimit.__qualname__.__eq__,     ["getrecursionlimit"],     true]
    - [setrecursionlimit,     setrecursionlimit.__qualname__.__eq__,     ["setrecursionlimit"],     true]
    - [getsizeof,             getsizeof.__qualname__.__eq__,             ["getsizeof"],             true]
    - [exc_info,              exc_info.__qualname__.__eq__,              ["exc_info"],              true]
    - [exit,                  exit.__qualname__.__eq__,                  ["exit"],                  true]
    - [intern,                intern.__qualname__.__eq__,                ["intern"],                true]
    - [getswitchinterval,     getswitchinterval.__qualname__.__eq__,     ["getswitchinterval"],     true]

# ---------------------------------------------------------------------------
# sys.implementation — class name
#
# No prior spec checks sys.implementation.__class__.__name__.
# On CPython, sys.implementation is a types.SimpleNamespace instance,
# so its __class__.__name__ == 'SimpleNamespace'.
# ---------------------------------------------------------------------------

invariant sys_extra7.implementation.class_name:
  description: "sys.implementation.__class__.__name__ == 'SimpleNamespace' — CPython uses types.SimpleNamespace"
  category: implementation
  kind: python_call_eq
  function: implementation.__class__.__name__.__eq__
  args: ["SimpleNamespace"]
  expected: true

# ---------------------------------------------------------------------------
# sys.byteorder — length bound
#
# Prior specs check only the class name of byteorder.  The only valid values
# are 'little' (6 chars) and 'big' (3 chars), so len(byteorder) >= 3
# holds unconditionally, regardless of platform endianness.
# ---------------------------------------------------------------------------

invariant sys_extra7.byteorder.len_ge_3:
  description: "sys.byteorder.__len__() >= 3 — 'big' (3 chars) and 'little' (6 chars) are the only valid values"
  category: byteorder
  kind: python_call_eq
  function: byteorder.__len__
  args: []
  method: __ge__
  method_args: [3]
  expected: true

# ---------------------------------------------------------------------------
# sys.float_info — __qualname__ check
#
# Prior specs check float_info.__class__.__name__; this adds __qualname__
# for the float_info named-tuple type itself.
# ---------------------------------------------------------------------------

invariant sys_extra7.float_info.qualname:
  description: "sys.float_info.__class__.__qualname__ == 'float_info'"
  category: info_structs
  kind: python_call_eq
  function: float_info.__class__.__qualname__.__eq__
  args: ["float_info"]
  expected: true

# ---------------------------------------------------------------------------
# sys.int_info — __qualname__ check
# ---------------------------------------------------------------------------

invariant sys_extra7.int_info.qualname:
  description: "sys.int_info.__class__.__qualname__ == 'int_info'"
  category: info_structs
  kind: python_call_eq
  function: int_info.__class__.__qualname__.__eq__
  args: ["int_info"]
  expected: true

# ---------------------------------------------------------------------------
# sys.hash_info — __qualname__ check
# ---------------------------------------------------------------------------

invariant sys_extra7.hash_info.qualname:
  description: "sys.hash_info.__class__.__qualname__ == 'hash_info'"
  category: info_structs
  kind: python_call_eq
  function: hash_info.__class__.__qualname__.__eq__
  args: ["hash_info"]
  expected: true

# ---------------------------------------------------------------------------
# sys.thread_info — __qualname__ check
#
# sys_extra4 covers thread_info.__class__.__name__; this adds __qualname__.
# ---------------------------------------------------------------------------

invariant sys_extra7.thread_info.qualname:
  description: "sys.thread_info.__class__.__qualname__ == 'thread_info'"
  category: thread_info
  kind: python_call_eq
  function: thread_info.__class__.__qualname__.__eq__
  args: ["thread_info"]
  expected: true
