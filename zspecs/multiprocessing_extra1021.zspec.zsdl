spec: multiprocessing_extra1021
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing Process, Pool, error classes weakref descriptors and cpu_count function identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1021.weakref_descriptors:
  description: "multiprocessing core classes __weakref__ class name identity"
  kind: python_call_eq
  category: weakref_descriptors
  id_prefix: mp1021x
  columns: [id, function, args, expected]
  rows:
    - [mp1021x001, multiprocessing.Process.__weakref__.__class__.__name__.__eq__,             ["getset_descriptor"], true]
    - [mp1021x002, multiprocessing.Pool.__weakref__.__class__.__name__.__eq__,                ["getset_descriptor"], true]
    - [mp1021x003, multiprocessing.AuthenticationError.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [mp1021x004, multiprocessing.ProcessError.__weakref__.__class__.__name__.__eq__,        ["getset_descriptor"], true]
    - [mp1021x005, multiprocessing.Process.__class__.__name__.__eq__,                         ["type"],              true]
    - [mp1021x006, multiprocessing.Pool.__class__.__name__.__eq__,                            ["type"],              true]
    - [mp1021x007, multiprocessing.AuthenticationError.__class__.__name__.__eq__,             ["type"],              true]

table multiprocessing_extra1021.module_attributes:
  description: "multiprocessing module-level attribute class identity"
  kind: python_call_eq
  category: module_attributes
  id_prefix: mp1021m
  columns: [id, function, args, expected]
  rows:
    - [mp1021m001, multiprocessing.__name__.__eq__,                              ["multiprocessing"], true]
    - [mp1021m002, multiprocessing.__package__.__eq__,                           ["multiprocessing"], true]
    - [mp1021m003, multiprocessing.__file__.__class__.__name__.__eq__,           ["str"],             true]
    - [mp1021m004, multiprocessing.__spec__.__class__.__name__.__eq__,           ["ModuleSpec"],      true]
    - [mp1021m005, multiprocessing.__loader__.__class__.__name__.__eq__,         ["SourceFileLoader"], true]

table multiprocessing_extra1021.callable_identity:
  description: "multiprocessing callable and function class identity"
  kind: python_call_eq
  category: callable_identity
  id_prefix: mp1021f
  columns: [id, function, args, expected]
  rows:
    - [mp1021f001, multiprocessing.cpu_count.__class__.__name__.__eq__,          ["builtin_function_or_method"], true]
    - [mp1021f002, multiprocessing.cpu_count.__module__.__eq__,                  ["multiprocessing"], true]
    - [mp1021f003, multiprocessing.current_process.__class__.__name__.__eq__,    ["function"],        true]
    - [mp1021f004, multiprocessing.active_children.__class__.__name__.__eq__,    ["function"],        true]
    - [mp1021f005, multiprocessing.ProcessError.__module__.__eq__,               ["multiprocessing"], true]
