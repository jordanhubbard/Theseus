spec: decimal_extra330
version: ">=3.7"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Decimal('sNaN') is a signaling NaN — is_snan() returns True, is_nan() also returns True."
    - "Decimal('NaN') is a quiet NaN — is_nan() returns True, is_snan() returns False."
    - "Decimal('Infinity') is positive infinity — is_infinite() returns True, is_finite() returns False."
    - "Decimal('1').is_finite() == True — a regular finite nonzero number."
    - "Decimal('1').is_zero() == False; Decimal('0').is_zero() == True."
    - "Decimal('1').is_normal() == True — a regular nonzero finite number in the normal range."
    - "Decimal('sNaN').__class__.__name__ == 'Decimal' — special values are still Decimal instances."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal('sNaN') — signaling NaN class membership and predicates
# ---------------------------------------------------------------------------

invariant decimal_extra330.sNaN.class_name:
  description: "Decimal('sNaN').__class__.__name__ == 'Decimal' — signaling NaN is a Decimal instance"
  category: special_values
  kind: python_call_eq
  function: "Decimal('sNaN').__class__.__name__.__eq__"
  args: ["Decimal"]
  expected: true

invariant decimal_extra330.sNaN.is_snan:
  description: "Decimal('sNaN').is_snan() == True — is_snan() identifies signaling NaN"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["sNaN"]
  method: is_snan
  expected: true

# ---------------------------------------------------------------------------
# Decimal('NaN') — quiet NaN predicates
# ---------------------------------------------------------------------------

invariant decimal_extra330.NaN.is_nan:
  description: "Decimal('NaN').is_nan() == True — quiet NaN is detected by is_nan()"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["NaN"]
  method: is_nan
  expected: true

invariant decimal_extra330.NaN.is_snan_false:
  description: "Decimal('NaN').is_snan() == False — quiet NaN is not a signaling NaN"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["NaN"]
  method: is_snan
  expected: false

# ---------------------------------------------------------------------------
# Decimal('Infinity') — infinity predicates
# ---------------------------------------------------------------------------

invariant decimal_extra330.Infinity.is_infinite:
  description: "Decimal('Infinity').is_infinite() == True — positive infinity is detected by is_infinite()"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["Infinity"]
  method: is_infinite
  expected: true

invariant decimal_extra330.Infinity.is_finite_false:
  description: "Decimal('Infinity').is_finite() == False — infinity is not a finite number"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["Infinity"]
  method: is_finite
  expected: false

# ---------------------------------------------------------------------------
# Decimal('1') — regular finite number predicates
# ---------------------------------------------------------------------------

invariant decimal_extra330.one.is_finite:
  description: "Decimal('1').is_finite() == True — a regular integer is finite"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: is_finite
  expected: true

invariant decimal_extra330.one.is_zero_false:
  description: "Decimal('1').is_zero() == False — the value 1 is not zero"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: is_zero
  expected: false

# ---------------------------------------------------------------------------
# Decimal('0') — zero predicates
# ---------------------------------------------------------------------------

invariant decimal_extra330.zero.is_zero:
  description: "Decimal('0').is_zero() == True — zero is detected by is_zero()"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: is_zero
  expected: true

# ---------------------------------------------------------------------------
# Decimal('1').is_normal() — normal number predicate
# ---------------------------------------------------------------------------

invariant decimal_extra330.one.is_normal:
  description: "Decimal('1').is_normal() == True — a regular nonzero finite number in the normal range is normal"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: is_normal
  expected: true
