spec: highlight_js
version: ">=11.0.0"
backend: node(highlight.js)

docs: https://highlightjs.org/

provenance:
  derived_from:
    - "highlight.js README — https://github.com/highlightjs/highlight.js#readme"
    - "highlight.js API docs — https://highlightjs.readthedocs.io/en/latest/api.html"
    - "Test vectors verified with highlight.js via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "highlight.js source"
  notes:
    - "highlight.js is the dominant standalone syntax-highlighter for the web, also widely used server-side via Node."
    - "Install: npm install highlight.js"
    - "Usage: const hljs = require('highlight.js'); hljs.highlight(code, {language: 'js'}).value -> HTML <span> markup"
    - "getLanguage(name) returns a definition object (with .name, .aliases, etc.) or undefined for unknown languages."
    - "listLanguages() returns the array of all registered language names."
    - "Spec name underscored per ZSDL convention; npm package name is highlight.js."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "highlight() returns {value, language, relevance, ...}; never throws on valid input."
  stderr: "null"
  stickiness: "N/A — each call is independent."
  codes: {}

# ── highlight(code, {language}).value — HTML markup ─────────────────────────

table highlight_js.highlight_value:
  kind: node_chain_eq
  category: highlight
  entry: named
  function: highlight
  id_prefix: highlight

  columns: [id, entry_args, chain, expected]
  rows:
    - [js_var_decl,
       ["var x = 1;", {language: "javascript"}],
       [{get: value}],
       "<span class=\"hljs-keyword\">var</span> x = <span class=\"hljs-number\">1</span>;"]

    - [py_def,
       ["def f(): pass", {language: "python"}],
       [{get: value}],
       "<span class=\"hljs-keyword\">def</span> <span class=\"hljs-title function_\">f</span>(): <span class=\"hljs-keyword\">pass</span>"]

# ── highlight().language — echo of the requested language ───────────────────

table highlight_js.highlight_language:
  kind: node_chain_eq
  category: highlight
  entry: named
  function: highlight
  id_prefix: lang

  columns: [id, entry_args, chain, expected]
  rows:
    - [js,
       ["x = 1", {language: "javascript"}],
       [{get: language}],
       "javascript"]

    - [py,
       ["x = 1", {language: "python"}],
       [{get: language}],
       "python"]

# ── getLanguage() — language definition lookup ──────────────────────────────

table highlight_js.get_language_name:
  kind: node_chain_eq
  category: registry
  entry: named
  function: getLanguage
  id_prefix: getlang

  columns: [id, entry_args, chain, expected]
  rows:
    - [javascript_name,
       ["javascript"],
       [{get: name}],
       "JavaScript"]

    - [python_name,
       ["python"],
       [{get: name}],
       "Python"]

invariant highlight_js.unknown_language_returns_undefined:
  description: "getLanguage() returns undefined for unregistered language names"
  category: registry
  kind: node_chain_eq
  entry: named
  function: getLanguage
  entry_args: ["definitely_not_a_language"]
  chain: []
  expected: ~

# ── listLanguages() — registry contents ─────────────────────────────────────

invariant highlight_js.list_includes_javascript:
  description: "listLanguages() includes 'javascript'"
  category: registry
  kind: node_chain_eq
  entry: named
  function: listLanguages
  entry_args: []
  chain:
    - {method: includes, args: ["javascript"]}
  expected: true

invariant highlight_js.list_includes_python:
  description: "listLanguages() includes 'python'"
  category: registry
  kind: node_chain_eq
  entry: named
  function: listLanguages
  entry_args: []
  chain:
    - {method: includes, args: ["python"]}
  expected: true
