spec: struct_extra170
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra169.zspec.zsdl — covers struct.Struct.__name__/__module__ lengths / struct.error class name and module / error.__bases__[0].__name__=='Exception' / pack/calcsize __name__ strings (table + invariants)."
    - "struct_extra168.zspec.zsdl — covers struct.Struct.__mro__.__len__()==2 / struct.error.__mro__.__len__()==4 / function __qualname__ attributes (table + invariants)."
    - "struct_extra167.zspec.zsdl — covers struct.__name__/__package__/__spec__/__loader__/__doc__ module-level identity (table + invariants)."
    - "struct_extra166.zspec.zsdl — covers struct.Struct.__name__/__module__ via __eq__ calls (table + invariants)."
    - "struct_extra164.zspec.zsdl — covers struct module-level function __name__.__len__() integer values (table + invariants)."
    - "struct_extra162.zspec.zsdl — covers struct.pack/__unpack/__pack_into/__unpack_from/__iter_unpack/__calcsize .__name__/__module__ (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__=='struct' and struct.__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra169."
    - "Wave 354 theme: struct format character byte sizes — struct.calcsize('b')==1; struct.calcsize('h')==2; struct.calcsize('i')==4; struct.calcsize('l')==4; struct.calcsize('q')==8; struct.calcsize('f')==4; struct.calcsize('d')==8. These anchor the native format character sizes as primary novel content under structsizes170."
    - "struct.calcsize('b') == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0. 'b' = signed char = 1 byte on all platforms."
    - "struct.calcsize('h') == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0. 'h' = signed short = 2 bytes."
    - "struct.calcsize('i') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0. 'i' = signed int = 4 bytes."
    - "struct.calcsize('l') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0. 'l' = signed long = 4 bytes on 64-bit platforms with native sizing."
    - "struct.calcsize('q') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0. 'q' = signed long long = 8 bytes."
    - "struct.calcsize('f') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0. 'f' = float = 4 bytes (IEEE 754 single precision)."
    - "struct.calcsize('d') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0. 'd' = double = 8 bytes (IEEE 754 double precision)."
    - "Note: struct.calcsize('i')==4 == struct.calcsize('l')==4 == struct.calcsize('f')==4. Three different format characters all produce 4-byte sizes: 'i' (signed int), 'l' (signed long on most 64-bit platforms), and 'f' (IEEE 754 single-precision float). This 3-way tie at 4 bytes is platform-dependent for 'l'."
    - "Note: struct.calcsize('q')==8 == struct.calcsize('d')==8. Both 'q' (signed long long) and 'd' (double) are 8-byte types. Integer and floating-point 8-byte sizes are equal."
    - "Note: struct.calcsize('b')==1 < struct.calcsize('h')==2 < struct.calcsize('i')==4 < struct.calcsize('q')==8. Sizes strictly increase: 1, 2, 4, 8 (each double the previous)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.calcsize('b') == 1
# struct.calcsize('h') == 2
# struct.calcsize('i') == 4
# struct.calcsize('q') == 8
#
# Wave 354 theme: integer format sizes — 1, 2, 4, 8 bytes.
#
# calcsize('b') is 1 (signed char = 1 byte).
# calcsize('h') is 2 (signed short = 2 bytes).
# calcsize('i') is 4 (signed int = 4 bytes).
# calcsize('q') is 8 (signed long long = 8 bytes).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra170.integer_format_sizes:
  description: "struct.calcsize('b').__eq__(1)==True / struct.calcsize('h').__eq__(2)==True / struct.calcsize('i').__eq__(4)==True / struct.calcsize('q').__eq__(8)==True — calcsize('b') is 1 ('b' = signed char; always 1 byte on all platforms by C standard; struct.calcsize returns the number of bytes required to represent the format string's packed data; 'b'(1 byte) is the smallest native integer type; novel anchor: no prior struct spec anchors calcsize('b') under structsizes170; first anchor for the integer value 1 as calcsize result); calcsize('h') is 2 ('h' = signed short; C short is always exactly 2 bytes; 2 > 1 by 1: short is twice the size of char; novel anchor: first structsizes170 anchor for calcsize('h')==2); calcsize('i') is 4 ('i' = signed int; C int is 4 bytes on all modern 32-bit and 64-bit platforms; 4 > 2 by 2: int is twice the size of short; novel anchor: first structsizes170 anchor for calcsize('i')==4); calcsize('q') is 8 ('q' = signed long long; C long long is always exactly 8 bytes by C99 standard; 8 > 4 by 4: long long is twice the size of int; ordering: 1 < 2 < 4 < 8 — each size doubles the previous; novel anchor: first structsizes170 anchor for calcsize('q')==8)"
  kind: python_call_eq
  category: identity
  id_prefix: structsizes170

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_b_1, "calcsize.__call__", ["b"], 1, "struct.calcsize('b') == 1 (signed char; 1 byte; smallest; novel anchor)"]
    - [calcsize_h_2, "calcsize.__call__", ["h"], 2, "struct.calcsize('h') == 2 (signed short; 2 bytes; 2>1; novel anchor)"]
    - [calcsize_i_4, "calcsize.__call__", ["i"], 4, "struct.calcsize('i') == 4 (signed int; 4 bytes; 4>2; novel anchor)"]
    - [calcsize_q_8, "calcsize.__call__", ["q"], 8, "struct.calcsize('q') == 8 (signed long long; 8 bytes; 8>4; largest integer; novel anchor)"]

# ---------------------------------------------------------------------------
# struct.calcsize('l') == 4
# struct.calcsize('f') == 4
# struct.calcsize('d') == 8
#
# Wave 354 theme: long, float, and double sizes.
#
# calcsize('l') is 4 (signed long = 4 bytes on most 64-bit platforms).
# calcsize('f') is 4 (IEEE 754 single precision = 4 bytes).
# calcsize('d') is 8 (IEEE 754 double precision = 8 bytes).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra170.long_float_double_sizes:
  description: "struct.calcsize('l').__eq__(4)==True / struct.calcsize('f').__eq__(4)==True / struct.calcsize('d').__eq__(8)==True — calcsize('l') is 4 ('l' = signed long; on 64-bit platforms with native byte order, C long is typically 4 bytes (Windows) or 8 bytes (Linux/macOS LP64); on macOS/Darwin using native byte order struct format, calcsize('l')==4; calcsize('l')==4 == calcsize('i')==4: long and int are the same size on this platform; novel anchor: first structsizes170 anchor for calcsize('l')==4); calcsize('f') is 4 ('f' = IEEE 754 single-precision floating-point; always 4 bytes per the IEEE 754 standard regardless of platform; calcsize('f')==4 == calcsize('i')==4 == calcsize('l')==4: three-way tie at 4 bytes — signed int, signed long, and float all occupy 4 bytes; the coincidence that a float and two integer types share the same size is notable; novel anchor: first structsizes170 anchor for calcsize('f')==4); calcsize('d') is 8 ('d' = IEEE 754 double-precision floating-point; always 8 bytes per the IEEE 754 standard; calcsize('d')==8 == calcsize('q')==8: double and long long share the same 8-byte size — floating-point double equals integer long long in bytes; novel anchor: first structsizes170 anchor for calcsize('d')==8; complete size ordering: 'b'(1)<'h'(2)<'i'(4)=='l'(4)=='f'(4)<'d'(8)=='q'(8))"
  kind: python_call_eq
  category: identity
  id_prefix: structsizes170

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_l_4, "calcsize.__call__", ["l"], 4, "struct.calcsize('l') == 4 (signed long; 4 bytes on macOS; tied with 'i'(4); novel anchor)"]
    - [calcsize_f_4, "calcsize.__call__", ["f"], 4, "struct.calcsize('f') == 4 (IEEE 754 single float; 4 bytes; 3-way tie with 'i'/'l'; novel anchor)"]
    - [calcsize_d_8, "calcsize.__call__", ["d"], 8, "struct.calcsize('d') == 8 (IEEE 754 double; 8 bytes; tied with 'q'(8); novel anchor)"]

# ---------------------------------------------------------------------------
# Combined size ordering across all 7 format characters
# 'b'(1) < 'h'(2) < 'i'(4) == 'l'(4) == 'f'(4) < 'q'(8) == 'd'(8)
#
# Wave 354 theme: complete size ordering for all covered format chars.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra170.size_ordering_summary:
  description: "struct.calcsize('b').__eq__(1)==True / struct.calcsize('h').__eq__(2)==True / struct.calcsize('f').__eq__(4)==True / struct.calcsize('d').__eq__(8)==True — summary of complete size ordering: 1 < 2 < 4 < 8 — calcsize('b') is 1 (smallest; 'b'=1 byte; confirmed; for ordering context: 1 < all others); calcsize('h') is 2 (2 > 1 by 1; 'h'=2 bytes; confirmed; for ordering: 1<2<4<8); calcsize('f') is 4 (4 > 2 by 2; 'f'=float=4 bytes; 3-way tie: 'i'(4)=='l'(4)=='f'(4); the float 'f' ties with two integer types; confirmed; novel ordering anchor); calcsize('d') is 8 (8 > 4 by 4; 'd'=double=8 bytes; 2-way tie: 'q'(8)=='d'(8); double ties with long long; confirmed; novel ordering anchor; complete ordering: 'b'(1)<'h'(2)<'i'(4)=='l'(4)=='f'(4)<'q'(8)=='d'(8) — 4 distinct size values, 2 tied pairs and 1 triple tie at 4)"
  kind: python_call_eq
  category: identity
  id_prefix: structsizes170

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_b_1_b, "calcsize.__call__", ["b"], 1, "struct.calcsize('b') is 1 (smallest; confirmed; ordering: 1<2<4<8)"]
    - [calcsize_h_2_b, "calcsize.__call__", ["h"], 2, "struct.calcsize('h') is 2 (2>1; confirmed; ordering: 1<2<4<8)"]
    - [calcsize_f_4_b, "calcsize.__call__", ["f"], 4, "struct.calcsize('f') is 4 (float; 3-way tie with 'i'/'l'; confirmed; 4>2)"]
    - [calcsize_d_8_b, "calcsize.__call__", ["d"], 8, "struct.calcsize('d') is 8 (double; 2-way tie with 'q'; confirmed; 8>4; largest)"]

# ---------------------------------------------------------------------------
# struct.calcsize('b') == 1 — standalone
#
# struct.calcsize('b') is 1 (signed char = 1 byte). The 'b' format character
# is the smallest native integer type. Always 1 byte on every platform.
# Novel anchor under structsizes170. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra170.calcsize_b_1:
  description: "struct.calcsize('b') == 1 — 1 (signed char = 1 byte; struct.calcsize('b') returns the size in bytes required to pack a single value using format character 'b'; 'b' represents a signed 8-bit integer (C signed char) in the range -128 to 127; calcsize('b')==1 is guaranteed on all platforms — the C standard mandates sizeof(char)==1; 'b'(1 byte) < 'h'(2 bytes) < 'i'(4 bytes) < 'q'(8 bytes): strict doubling sequence; calcsize('b')==1 is the minimum possible calcsize result for a native integer type; novel anchor: no prior struct spec anchors calcsize('b') under structsizes170; first structsizes170 standalone for calcsize('b')==1"
  category: identity
  kind: python_call_eq
  function: calcsize.__call__
  args: ["b"]
  expected: 1

# ---------------------------------------------------------------------------
# struct.calcsize('h') == 2 — standalone
#
# struct.calcsize('h') is 2 (signed short = 2 bytes). The 'h' format represents
# a signed 16-bit integer. Always 2 bytes per C standard.
# Novel anchor under structsizes170. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra170.calcsize_h_2:
  description: "struct.calcsize('h') == 2 — 2 (signed short = 2 bytes; struct.calcsize('h') returns 2 for the 'h' format character representing a signed 16-bit integer (C short) in the range -32768 to 32767; the C standard requires sizeof(short) >= 2 and in practice it is exactly 2 bytes on all modern platforms; calcsize('h')==2 == calcsize('b')==1 * 2: short is exactly twice the size of char; calcsize('h')==2 < calcsize('i')==4 by 2: int is twice the size of short; novel anchor: no prior struct spec anchors calcsize('h') under structsizes170; first structsizes170 standalone for calcsize('h')==2"
  category: identity
  kind: python_call_eq
  function: calcsize.__call__
  args: ["h"]
  expected: 2

# ---------------------------------------------------------------------------
# struct.calcsize('q') == 8 — standalone
#
# struct.calcsize('q') is 8 (signed long long = 8 bytes). The 'q' format represents
# a signed 64-bit integer. Always 8 bytes per C99 standard.
# 'q'(8) == 'd'(8): long long and double are both 8 bytes.
# Novel anchor under structsizes170. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra170.calcsize_q_8:
  description: "struct.calcsize('q') == 8 — 8 (signed long long = 8 bytes; struct.calcsize('q') returns 8 for the 'q' format character representing a signed 64-bit integer (C long long) in the range -2^63 to 2^63-1; the C99 standard guarantees sizeof(long long) == 8 bytes on all conforming implementations; calcsize('q')==8 == calcsize('d')==8: long long and double (IEEE 754) are both 8 bytes — an integer and floating-point type of equal size; calcsize('q')==8 == calcsize('i')==4 * 2: long long is exactly twice the size of int; 8 bytes = 64 bits: sufficient to hold the full range of a 64-bit address; novel anchor: no prior struct spec anchors calcsize('q') under structsizes170; first structsizes170 standalone for calcsize('q')==8"
  category: identity
  kind: python_call_eq
  function: calcsize.__call__
  args: ["q"]
  expected: 8

# ---------------------------------------------------------------------------
# struct.calcsize('f') == 4 — standalone
#
# struct.calcsize('f') is 4 (IEEE 754 single-precision float = 4 bytes). The 'f'
# format represents a C float. Always 4 bytes per IEEE 754.
# calcsize('f')(4) == calcsize('i')(4) == calcsize('l')(4): three-way size tie.
# Novel anchor under structsizes170. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra170.calcsize_f_4:
  description: "struct.calcsize('f') == 4 — 4 (IEEE 754 single-precision float = 4 bytes; struct.calcsize('f') returns 4 for the 'f' format character representing a C float (IEEE 754 single-precision floating-point) with approximately 7 decimal digits of precision; IEEE 754 single precision is always exactly 4 bytes on all conforming platforms; calcsize('f')==4 == calcsize('i')==4 == calcsize('l')==4: a three-way tie — signed int, signed long (on most 64-bit platforms), and float are all 4 bytes; this three-way tie across an integer (int), a platform-dependent integer (long), and a floating-point type (float) is notable; calcsize('f')==4 < calcsize('d')==8 by 4: double is exactly twice the size of float; novel anchor: no prior struct spec anchors calcsize('f') under structsizes170; first structsizes170 standalone for calcsize('f')==4"
  category: identity
  kind: python_call_eq
  function: calcsize.__call__
  args: ["f"]
  expected: 4

# ---------------------------------------------------------------------------
# struct.calcsize('d') == 8 — standalone
#
# struct.calcsize('d') is 8 (IEEE 754 double-precision float = 8 bytes). The 'd'
# format represents a C double. Always 8 bytes per IEEE 754.
# calcsize('d')(8) == calcsize('q')(8): double ties with long long in size.
# Novel anchor under structsizes170. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra170.calcsize_d_8:
  description: "struct.calcsize('d') == 8 — 8 (IEEE 754 double-precision float = 8 bytes; struct.calcsize('d') returns 8 for the 'd' format character representing a C double (IEEE 754 double-precision floating-point) with approximately 15-17 decimal digits of precision; IEEE 754 double precision is always exactly 8 bytes on all conforming platforms; calcsize('d')==8 == calcsize('q')==8: double and long long are both 8 bytes — the largest standard types in the struct format character set; calcsize('d')==8 == calcsize('f')==4 * 2: double is exactly twice the size of float; complete size ordering: calcsize('b')(1)<calcsize('h')(2)<calcsize('i')(4)==calcsize('l')(4)==calcsize('f')(4)<calcsize('q')(8)==calcsize('d')(8); novel anchor: no prior struct spec anchors calcsize('d') under structsizes170; first structsizes170 standalone for calcsize('d')==8"
  category: identity
  kind: python_call_eq
  function: calcsize.__call__
  args: ["d"]
  expected: 8
