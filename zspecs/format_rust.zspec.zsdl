spec: format_rust
version: ">=3.9"
backend: rust_module(format_rust)

docs: https://docs.python.org/3/library/functions.html#format

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functions.html#format — Python format() documentation"
    - "https://docs.python.org/3/library/string.html#format-specification-mini-language"
  not_derived_from:
    - "CPython source: Objects/typeobject.c"
  notes:
    - "Clean-room Rust reimplementation of Python format() built-in, exposed via PyO3."
    - "format(value, format_spec) applies a format specification to value."
    - "format(3.14159, '.2f') == '3.14' — fixed-point 2 decimal places."
    - "format(255, 'x') == 'ff' — hexadecimal lowercase."
    - "format(255, 'X') == 'FF' — hexadecimal uppercase."
    - "format(42, '08d') == '00000042' — zero-padded decimal."
    - "format('hello', '>10') == '     hello' — right-align in width 10."
    - "format('hello', '<10') == 'hello     ' — left-align in width 10."
    - "format('hello', '^10') == '  hello   ' — center in width 10."
    - "format(0.001234, '.2e') == '1.23e-03' — scientific notation 2 decimal places."
    - "format(1234567, ',') == '1,234,567' — thousands separator."
    - "All test vectors verified against Python 3.14.3 format() built-in."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# format() — floating-point formats
table format_rust.float.formats:
  kind: python_call_eq
  category: format
  id_prefix: fmt_float
  function: format

  columns: [id, args, expected]
  rows:
    - [fixed_2,  [3.14159, ".2f"], "3.14"]
    - [fixed_4,  [3.14159, ".4f"], "3.1416"]
    - [sci_2e,   [0.001234, ".2e"], "1.23e-03"]
    - [neg_float, [-3.14, ".1f"], "-3.1"]

# format() — integer formats
table format_rust.int.formats:
  kind: python_call_eq
  category: format
  id_prefix: fmt_int
  function: format

  columns: [id, args, expected]
  rows:
    - [decimal,   [42, "d"],     "42"]
    - [hex_lower, [255, "x"],    "ff"]
    - [hex_upper, [255, "X"],    "FF"]
    - [octal,     [8, "o"],      "10"]
    - [binary,    [10, "b"],     "1010"]
    - [zero_pad,  [42, "08d"],   "00000042"]
    - [comma_sep, [1234567, ","], "1,234,567"]

# format() — string alignment
table format_rust.str.alignment:
  kind: python_call_eq
  category: format
  id_prefix: fmt_str
  function: format

  columns: [id, args, expected]
  rows:
    - [right_align, ["hello", ">10"], "     hello"]
    - [left_align,  ["hello", "<10"], "hello     "]
    - [center,      ["hello", "^10"], "  hello   "]
    - [plain,       ["hello", ""],    "hello"]

