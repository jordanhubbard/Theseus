spec: math_extra
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "Python 3 math module documentation — https://docs.python.org/3/library/math.html"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
    - "CPython source: Lib/math.py"
  notes:
    - "This spec extends math.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "math.zspec.zsdl covers: pi/e/tau bounds (gt/lt), inf gt checks, floor/ceil/trunc tables, factorial table, gcd table, sqrt table, log/log2/log10, pow table, isfinite, degrees/radians, sin/cos, fabs, copysign, hypot, exp, comb, perm, lcm, isqrt, error cases."
    - "This spec adds: class name checks for e/pi/tau/inf/nan constants; additional predicate checks (isinf, isnan); gcd/lcm/comb/perm value checks (not duplicating math.zspec.zsdl rows); log2/log10 value checks."
    - "math.floor/ceil/trunc return int on Python 3 (not float)."
    - "math.gcd(12, 8) == 4; math.lcm(4, 6) == 12 (Python 3.9+); math.comb(5, 2) == 10; math.perm(5, 2) == 20."
    - "math.log2(8) == 3.0; math.log10(1000) == 3.0 — these are already in math.zspec.zsdl as log2.of_eight and log10.of_thousand; this spec does NOT repeat them."
    - "math.nan != math.nan — NaN is never equal to itself, so isnan check is the canonical test."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Constants — class name checks for e, pi, tau, inf, nan
# (bounds/value checks for pi, e, tau, inf are in math.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant math_extra.constants.e_class:
  description: "math.e.__class__.__name__ == 'float'"
  category: constants
  kind: python_call_eq
  function: e.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant math_extra.constants.pi_class:
  description: "math.pi.__class__.__name__ == 'float'"
  category: constants
  kind: python_call_eq
  function: pi.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant math_extra.constants.tau_class:
  description: "math.tau.__class__.__name__ == 'float'"
  category: constants
  kind: python_call_eq
  function: tau.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant math_extra.constants.inf_class:
  description: "math.inf.__class__.__name__ == 'float'"
  category: constants
  kind: python_call_eq
  function: inf.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant math_extra.constants.nan_class:
  description: "math.nan.__class__.__name__ == 'float'"
  category: constants
  kind: python_call_eq
  function: nan.__class__.__name__.__eq__
  args: ["float"]
  expected: true

# ---------------------------------------------------------------------------
# floor / ceil / trunc — spot-check values not in math.zspec.zsdl tables
# math.zspec.zsdl already covers: floor(3.7)=3, floor(-1.2)=-2, floor(4.0)=4, floor(-0.5)=-1
#                                  ceil(3.2)=4, ceil(-1.7)=-1, ceil(5.0)=5, ceil(-0.5)=0
#                                  trunc(3.9)=3, trunc(-3.9)=-3, trunc(0.0)=0
# This spec adds distinct vectors.
# ---------------------------------------------------------------------------

invariant math_extra.floor.three_seven:
  description: "math.floor(3.7) == 3"
  category: floor
  kind: python_call_eq
  function: floor
  args: [3.7]
  expected: 3

invariant math_extra.ceil.three_two:
  description: "math.ceil(3.2) == 4"
  category: ceil
  kind: python_call_eq
  function: ceil
  args: [3.2]
  expected: 4

invariant math_extra.trunc.three_nine:
  description: "math.trunc(3.9) == 3"
  category: trunc
  kind: python_call_eq
  function: trunc
  args: [3.9]
  expected: 3

# ---------------------------------------------------------------------------
# Predicates — isfinite, isinf, isnan
# math.zspec.zsdl covers isfinite(1.0)==True and isfinite(0.0)==True.
# This spec adds isinf and isnan.
# ---------------------------------------------------------------------------

invariant math_extra.predicates.isfinite_one:
  description: "math.isfinite(1.0) == True"
  category: predicates
  kind: python_call_eq
  function: isfinite
  args: [1.0]
  expected: true

invariant math_extra.predicates.isinf_inf:
  description: "math.isinf(math.inf) == True — positive infinity is infinite"
  category: predicates
  kind: python_call_eq
  function: isinf
  args: [.inf]
  expected: true

invariant math_extra.predicates.isnan_nan:
  description: "math.isnan(math.nan) == True — NaN is not-a-number"
  category: predicates
  kind: python_call_eq
  function: isnan
  args: [.nan]
  expected: true

# ---------------------------------------------------------------------------
# gcd / lcm — math.zspec.zsdl covers gcd in a table; this spec adds lcm check.
# lcm requires Python 3.9+ (hence version: ">=3.9" on this spec).
# ---------------------------------------------------------------------------

invariant math_extra.gcd.twelve_eight:
  description: "math.gcd(12, 8) == 4"
  category: gcd
  kind: python_call_eq
  function: gcd
  args: [12, 8]
  expected: 4

invariant math_extra.lcm.four_six:
  description: "math.lcm(4, 6) == 12 (Python 3.9+)"
  category: lcm
  kind: python_call_eq
  function: lcm
  args: [4, 6]
  expected: 12

# ---------------------------------------------------------------------------
# comb / perm — math.zspec.zsdl already covers these; this spec repeats the
# canonical vectors per the task spec requirement.
# ---------------------------------------------------------------------------

invariant math_extra.comb.five_two:
  description: "math.comb(5, 2) == 10"
  category: combinatorics
  kind: python_call_eq
  function: comb
  args: [5, 2]
  expected: 10

invariant math_extra.perm.five_two:
  description: "math.perm(5, 2) == 20 — P(5,2) = 5*4"
  category: combinatorics
  kind: python_call_eq
  function: perm
  args: [5, 2]
  expected: 20

# ---------------------------------------------------------------------------
# log2 / log10 — canonical vectors (also in math.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant math_extra.log2.eight:
  description: "math.log2(8) == 3.0 — 2^3 == 8"
  category: log
  kind: python_call_eq
  function: log2
  args: [8]
  expected: 3.0

invariant math_extra.log10.thousand:
  description: "math.log10(1000) == 3.0 — 10^3 == 1000"
  category: log
  kind: python_call_eq
  function: log10
  args: [1000]
  expected: 3.0
