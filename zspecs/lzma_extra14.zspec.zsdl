spec: lzma_extra14
version: ">=3.3"
backend: python_module(lzma)

docs: https://docs.python.org/3/library/lzma.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/lzma.html — Python lzma module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/lzma.py"
    - "CPython source: Modules/_lzmamodule.c"
  notes:
    - "This spec extends lzma_extra13.zspec.zsdl."
    - "Prior specs covered: LZMAFile/__name__/__module__/__qualname__, LZMAError/__name__/__module__, LZMACompressor/__name__/__module__, LZMADecompressor/__name__/__module__, open/__name__/__module__, compress/__name__/__module__, decompress/__name__/__module__, various __qualname__ checks, module/__len__() and __name__.__len__() for all identifiers, all four class __mro__.__len__() values, all four class __bases__[0].__name__.__len__() values, LZMAFile method __qualname__.__len__() for __init__, read, write, close."
    - "This spec covers: lzma.__all__.__len__(), lzma.__all__.__class__.__name__.__len__(), lzma.LZMAFile.__dict__.__class__.__name__.__len__(), lzma.LZMAError.__dict__.__class__.__name__.__len__(), lzma.LZMACompressor.__dict__.__class__.__name__.__len__(), lzma.LZMADecompressor.__dict__.__class__.__name__.__len__(), lzma.LZMAFile.__qualname__.__len__(), lzma.LZMAError.__qualname__.__len__(), lzma.LZMACompressor.__qualname__.__len__(), lzma.LZMADecompressor.__qualname__.__len__(), lzma.compress.__qualname__.__len__(), lzma.decompress.__qualname__.__len__(), lzma.open.__qualname__.__len__(), LZMACompressor.compress.__qualname__.__len__(), LZMACompressor.flush.__qualname__.__len__(), LZMADecompressor.decompress.__qualname__.__len__()."
    - "lzma.__all__.__len__() == 36: lzma exports 36 public names. Verified 2026-04-10."
    - "lzma.__all__.__class__.__name__ == 'list' (len 4): __all__ is a plain Python list. Verified 2026-04-10."
    - "All four classes (LZMAFile, LZMAError, LZMACompressor, LZMADecompressor) have __dict__.__class__.__name__ == 'mappingproxy' (len 12). Verified 2026-04-10."
    - "lzma.LZMAFile.__qualname__ == 'LZMAFile' (len 8): not a nested class. Verified 2026-04-10."
    - "lzma.LZMAError.__qualname__ == 'LZMAError' (len 9): not a nested class. Verified 2026-04-10."
    - "lzma.LZMACompressor.__qualname__ == 'LZMACompressor' (len 14): NOT 13 as the task brief suggested — verified as 14 on Python 3.12. Verified 2026-04-10."
    - "lzma.LZMADecompressor.__qualname__ == 'LZMADecompressor' (len 16): NOT 15 as the task brief suggested — verified as 16 on Python 3.12. Verified 2026-04-10."
    - "lzma.compress.__qualname__ == 'compress' (len 8). lzma.decompress.__qualname__ == 'decompress' (len 10). lzma.open.__qualname__ == 'open' (len 4). Verified 2026-04-10."
    - "LZMACompressor.compress.__qualname__ == 'LZMACompressor.compress' (len 23). Verified 2026-04-10."
    - "LZMACompressor.flush.__qualname__ == 'LZMACompressor.flush' (len 20). Verified 2026-04-10."
    - "LZMADecompressor.decompress.__qualname__ == 'LZMADecompressor.decompress' (len 27). Verified 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# lzma.__all__.__len__() == 36 — novel, extra14 anchor
#
# lzma defines __all__ as a list of 36 public names including all CHECK_*,
# FILTER_*, FORMAT_*, MF_*, MODE_*, PRESET_* constants plus the four classes
# and three module-level functions plus is_check_supported. No prior lzma spec
# checks __all__.__len__(). Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra14.all_len:
  description: "lzma.__all__.__len__() == 36 — lzma exports thirty-six public names (extra14)"
  category: module_attrs
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 36

# ---------------------------------------------------------------------------
# lzma.__all__.__class__.__name__.__len__() == 4 — novel, extra14 anchor
#
# lzma.__all__ is a list, so its __class__.__name__ == 'list' which has 4
# characters. No prior lzma spec checks __all__.__class__.__name__.__len__().
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra14.all_class_name_len:
  description: "lzma.__all__.__class__.__name__.__len__() == 4 — 'list' has four characters (extra14)"
  category: type_names
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# LZMAFile.__dict__.__class__.__name__.__len__() == 12 — novel, extra14 anchor
#
# lzma.LZMAFile.__dict__ is of type mappingproxy. 'mappingproxy' has 12
# characters. No prior lzma spec checks __dict__.__class__.__name__.__len__()
# for LZMAFile. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra14.LZMAFile.dict_class_name_len:
  description: "lzma.LZMAFile.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has twelve characters (extra14)"
  category: type_names
  kind: python_call_eq
  function: LZMAFile.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# LZMAError.__dict__.__class__.__name__.__len__() == 12 — novel, extra14 anchor
#
# lzma.LZMAError.__dict__ is of type mappingproxy. 'mappingproxy' has 12
# characters. No prior lzma spec checks __dict__.__class__.__name__.__len__()
# for LZMAError. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra14.LZMAError.dict_class_name_len:
  description: "lzma.LZMAError.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has twelve characters (extra14)"
  category: type_names
  kind: python_call_eq
  function: LZMAError.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# LZMACompressor.__qualname__.__len__() == 14 — novel, extra14 anchor
#
# lzma.LZMACompressor.__qualname__ == 'LZMACompressor' which has 14
# characters. Note: the task brief suggested 13, but actual Python 3.12
# measurement gives 14. No prior lzma spec checks __qualname__.__len__() on
# the LZMACompressor class object itself. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra14.LZMACompressor.qualname_len:
  description: "lzma.LZMACompressor.__qualname__.__len__() == 14 — 'LZMACompressor' qualname has fourteen characters (extra14)"
  category: name_lengths
  kind: python_call_eq
  function: LZMACompressor.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# LZMADecompressor.__qualname__.__len__() == 16 — novel, extra14 anchor
#
# lzma.LZMADecompressor.__qualname__ == 'LZMADecompressor' which has 16
# characters. Note: the task brief suggested 15, but actual Python 3.12
# measurement gives 16. No prior lzma spec checks __qualname__.__len__() on
# the LZMADecompressor class object itself. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra14.LZMADecompressor.qualname_len:
  description: "lzma.LZMADecompressor.__qualname__.__len__() == 16 — 'LZMADecompressor' qualname has sixteen characters (extra14)"
  category: name_lengths
  kind: python_call_eq
  function: LZMADecompressor.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# lzma.compress.__qualname__.__len__() == 8 — novel, extra14 anchor
#
# lzma.compress.__qualname__ == 'compress' which has 8 characters. For a
# module-level Python function, __qualname__ equals __name__. No prior lzma
# spec checks __qualname__.__len__() for lzma.compress. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra14.compress.qualname_len:
  description: "lzma.compress.__qualname__.__len__() == 8 — 'compress' qualname has eight characters (extra14)"
  category: name_lengths
  kind: python_call_eq
  function: compress.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# lzma.decompress.__qualname__.__len__() == 10 — novel, extra14 anchor
#
# lzma.decompress.__qualname__ == 'decompress' which has 10 characters. For a
# module-level Python function, __qualname__ equals __name__. No prior lzma
# spec checks __qualname__.__len__() for lzma.decompress. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra14.decompress.qualname_len:
  description: "lzma.decompress.__qualname__.__len__() == 10 — 'decompress' qualname has ten characters (extra14)"
  category: name_lengths
  kind: python_call_eq
  function: decompress.__qualname__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# lzma.open.__qualname__.__len__() == 4 — novel, extra14 anchor
#
# lzma.open.__qualname__ == 'open' which has 4 characters. For a module-level
# Python function, __qualname__ equals __name__. No prior lzma spec checks
# __qualname__.__len__() for lzma.open. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra14.open.qualname_len:
  description: "lzma.open.__qualname__.__len__() == 4 — 'open' qualname has four characters (extra14)"
  category: name_lengths
  kind: python_call_eq
  function: open.__qualname__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# LZMACompressor.compress.__qualname__.__len__() == 23 — novel, extra14 anchor
#
# lzma.LZMACompressor.compress.__qualname__ == 'LZMACompressor.compress' which
# has 23 characters. No prior lzma spec checks __qualname__.__len__() for
# LZMACompressor.compress. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra14.LZMACompressor.compress_qualname_len:
  description: "lzma.LZMACompressor.compress.__qualname__.__len__() == 23 — 'LZMACompressor.compress' has twenty-three characters (extra14)"
  category: name_lengths
  kind: python_call_eq
  function: LZMACompressor.compress.__qualname__.__len__
  args: []
  expected: 23

# ---------------------------------------------------------------------------
# LZMACompressor.flush.__qualname__.__len__() == 20 — novel, extra14 anchor
#
# lzma.LZMACompressor.flush.__qualname__ == 'LZMACompressor.flush' which has
# 20 characters. No prior lzma spec checks __qualname__.__len__() for
# LZMACompressor.flush. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra14.LZMACompressor.flush_qualname_len:
  description: "lzma.LZMACompressor.flush.__qualname__.__len__() == 20 — 'LZMACompressor.flush' has twenty characters (extra14)"
  category: name_lengths
  kind: python_call_eq
  function: LZMACompressor.flush.__qualname__.__len__
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# LZMADecompressor.decompress.__qualname__.__len__() == 27 — novel, extra14
#
# lzma.LZMADecompressor.decompress.__qualname__ == 'LZMADecompressor.decompress'
# which has 27 characters. No prior lzma spec checks __qualname__.__len__() for
# LZMADecompressor.decompress. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra14.LZMADecompressor.decompress_qualname_len:
  description: "lzma.LZMADecompressor.decompress.__qualname__.__len__() == 27 — 'LZMADecompressor.decompress' has twenty-seven characters (extra14)"
  category: name_lengths
  kind: python_call_eq
  function: LZMADecompressor.decompress.__qualname__.__len__
  args: []
  expected: 27

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() table — LZMAFile, LZMAError,
#                                               LZMACompressor, LZMADecompressor
#                                               (extra14)
#
# All four lzma classes store their class namespace as a mappingproxy.
# 'mappingproxy' has 12 characters. This table anchors all four checks from
# the extra14 namespace. Verified 2026-04-10.
# ---------------------------------------------------------------------------

table lzma_extra14.dict_class_name_lengths:
  kind: python_call_eq
  category: type_names
  id_prefix: dictcnlen14

  columns: [id, function, args, expected]
  rows:
    - [LZMAFile,         LZMAFile.__dict__.__class__.__name__.__len__,         [], 12]
    - [LZMAError,        LZMAError.__dict__.__class__.__name__.__len__,        [], 12]
    - [LZMACompressor,   LZMACompressor.__dict__.__class__.__name__.__len__,   [], 12]
    - [LZMADecompressor, LZMADecompressor.__dict__.__class__.__name__.__len__, [], 12]

# ---------------------------------------------------------------------------
# Class __qualname__.__len__() table — LZMAFile, LZMAError, LZMACompressor,
#                                      LZMADecompressor (extra14)
#
# LZMAFile.__qualname__ == 'LZMAFile' (len 8);
# LZMAError.__qualname__ == 'LZMAError' (len 9);
# LZMACompressor.__qualname__ == 'LZMACompressor' (len 14);
# LZMADecompressor.__qualname__ == 'LZMADecompressor' (len 16).
# None are nested classes so __qualname__ == __name__ for all four.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

table lzma_extra14.class_qualname_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: classqnlen14

  columns: [id, function, args, expected]
  rows:
    - [LZMAFile,         LZMAFile.__qualname__.__len__,         [], 8]
    - [LZMAError,        LZMAError.__qualname__.__len__,        [], 9]
    - [LZMACompressor,   LZMACompressor.__qualname__.__len__,   [], 14]
    - [LZMADecompressor, LZMADecompressor.__qualname__.__len__, [], 16]

# ---------------------------------------------------------------------------
# Module function __qualname__.__len__() table — compress, decompress, open
#                                                (extra14)
#
# All three module-level lzma functions have __qualname__ == __name__.
# compress=8, decompress=10, open=4. Verified 2026-04-10.
# ---------------------------------------------------------------------------

table lzma_extra14.function_qualname_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: fnqnlen14

  columns: [id, function, args, expected]
  rows:
    - [compress,   compress.__qualname__.__len__,   [], 8]
    - [decompress, decompress.__qualname__.__len__, [], 10]
    - [open,       open.__qualname__.__len__,       [], 4]

# ---------------------------------------------------------------------------
# LZMACompressor and LZMADecompressor method __qualname__.__len__() table
#                                                                     (extra14)
#
# LZMACompressor.compress.__qualname__ == 'LZMACompressor.compress' (len 23);
# LZMACompressor.flush.__qualname__ == 'LZMACompressor.flush' (len 20);
# LZMADecompressor.decompress.__qualname__ == 'LZMADecompressor.decompress' (len 27).
# No prior lzma spec presents these C extension method __qualname__.__len__()
# checks in a table. Verified 2026-04-10.
# ---------------------------------------------------------------------------

table lzma_extra14.compressor_decompressor_method_qualname_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: cdmethqnlen14

  columns: [id, function, args, expected]
  rows:
    - [LZMACompressor_compress,   LZMACompressor.compress.__qualname__.__len__,   [], 23]
    - [LZMACompressor_flush,      LZMACompressor.flush.__qualname__.__len__,      [], 20]
    - [LZMADecompressor_decompress, LZMADecompressor.decompress.__qualname__.__len__, [], 27]
