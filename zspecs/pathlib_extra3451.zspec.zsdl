spec: pp3451
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 677 (pp3451): __getitem__, __setitem__, __delitem__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __getitem__/__setitem__/__delitem__ dict-presence (subscript access)."
    - "No pathlib class defines __getitem__ in its own __dict__: path objects are not subscriptable; [] access is not defined on any pathlib class."
    - "No pathlib class defines __setitem__ in its own __dict__: path objects are immutable value types and do not implement item assignment."
    - "No pathlib class defines __delitem__ in its own __dict__: path objects do not implement item deletion."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __getitem__ dict-presence — operator.contains(Cls.__dict__, '__getitem__')
#
# No pathlib class defines __getitem__ in its own __dict__; all false.
# Path objects are value types representing filesystem paths; subscript
# access is not part of the pathlib protocol for any class.
# ---------------------------------------------------------------------------

table pp3451.getitem:
  description: "pathlib types __getitem__ dict-presence checks; wave 677"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3451

  columns: [id, function, args, expected]
  rows:
    - ["pp3451001", operator.contains, [pathlib.PurePath.__dict__,         "__getitem__"], false]
    - ["pp3451002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__getitem__"], false]
    - ["pp3451003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__getitem__"], false]
    - ["pp3451004", operator.contains, [pathlib.Path.__dict__,             "__getitem__"], false]
    - ["pp3451005", operator.contains, [pathlib.PosixPath.__dict__,        "__getitem__"], false]

