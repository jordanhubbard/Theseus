spec: compileall_extra7
version: ">=3.9"
backend: python_module(compileall)

docs: https://docs.python.org/3/library/compileall.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/compileall.html — Python compileall documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/compileall.py"
  notes:
    - "This spec extends compileall.zspec.zsdl through compileall_extra6.zspec.zsdl."
    - "compileall (base) covers: __name__, __module__, type, docstring, __qualname__ for compile_file/compile_dir."
    - "compileall_extra covers: __name__ and __module__ for compile_file, compile_dir, compile_path (as invariants)."
    - "compileall_extra2 covers: __name__, __module__, __qualname__, type, docstring for all three functions (as tables)."
    - "compileall_extra3 covers: __name__, __module__, __qualname__ for all three functions (as invariants and table)."
    - "compileall_extra4 covers: __code__.__class__.__name__ == 'code' and __code__.co_name for all three functions."
    - "compileall_extra5 covers: module __name__, module __spec__.name, module __loader__.__class__.__name__, __code__.co_firstlineno type for all three functions."
    - "compileall_extra6 covers: __code__.co_argcount type, __defaults__ type, module __file__ type, module __spec__.__class__.__name__."
    - "This spec adds: __code__.co_varnames.__class__.__name__ == 'tuple' for all three functions (not in any prior spec), __defaults__.__len__ for compile_file and compile_dir (actual default count, not in any prior spec), compile_path.__defaults__.__len__ (not in any prior spec)."
    - "All Python functions store their local variable names in __code__.co_varnames as a tuple."
    - "compile_file has 9 parameters with defaults in Python 3.12; compile_dir has 9 parameters with defaults."
    - "compile_path has 3 parameters with defaults in Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __code__.co_varnames type — the tuple holding local variable names.
# Every Python function has co_varnames as a tuple; compileall functions are
# pure-Python so this holds. Not covered in any prior compileall spec.
# ---------------------------------------------------------------------------

table compileall_extra7.co_varnames_types:
  kind: python_call_eq
  category: code_objects
  id_prefix: varnames_type

  columns: [id, function, args, expected]
  rows:
    - [compile_file, compile_file.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true]
    - [compile_dir,  compile_dir.__code__.co_varnames.__class__.__name__.__eq__,  ["tuple"], true]
    - [compile_path, compile_path.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true]

# ---------------------------------------------------------------------------
# __defaults__.__len__ — the number of positional default values.
# compileall_extra6 confirms __defaults__ is a tuple; this spec checks the
# length, exercising a different axis of the same attribute.
# Not covered in any prior compileall spec.
# ---------------------------------------------------------------------------

invariant compileall_extra7.compile_file.defaults_len:
  description: "len(compileall.compile_file.__defaults__) == 9 — compile_file has 9 positional default values in Python 3.12"
  category: introspection
  kind: python_call_eq
  function: compile_file.__defaults__.__len__
  args: []
  expected: 9

invariant compileall_extra7.compile_dir.defaults_len:
  description: "len(compileall.compile_dir.__defaults__) == 9 — compile_dir has 9 positional default values in Python 3.12"
  category: introspection
  kind: python_call_eq
  function: compile_dir.__defaults__.__len__
  args: []
  expected: 9

invariant compileall_extra7.compile_path.defaults_len:
  description: "len(compileall.compile_path.__defaults__) == 3 — compile_path has 3 positional default values in Python 3.12"
  category: introspection
  kind: python_call_eq
  function: compile_path.__defaults__.__len__
  args: []
  expected: 3
