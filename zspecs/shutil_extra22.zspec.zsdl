spec: shutil_extra22
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
    - "shutil_extra5.zspec.zsdl — covers __qualname__ equality for copy/copy2/copyfile/copytree/rmtree/move/make_archive/unpack_archive/disk_usage/which/get_terminal_size in a table"
    - "shutil_extra11.zspec.zsdl — covers copy.__qualname__ standalone; which/get_terminal_size in a table"
    - "shutil_extra16.zspec.zsdl — covers copy2/copyfile/copytree/rmtree/move/disk_usage/which as standalone qualname equality invariants"
    - "shutil_extra21.zspec.zsdl — covers qualname lengths for make_archive/unpack_archive/get_terminal_size as standalone length invariants"
  notes:
    - "This spec extends shutil.zspec.zsdl and all prior shutil_extra specs through shutil_extra21.zspec.zsdl."
    - "Focus: standalone __qualname__ equality invariants for make_archive, unpack_archive, and get_terminal_size."
    - "shutil_extra5 covers make_archive/unpack_archive in a table but provides no standalone equality invariant."
    - "shutil_extra11 covers get_terminal_size in a table but provides no standalone equality invariant."
    - "shutil_extra21 covers qualname lengths for make_archive/unpack_archive/get_terminal_size as standalone length invariants but not equality."
    - "shutil.make_archive.__qualname__ == 'make_archive' — standalone qualname equality invariant not previously written."
    - "shutil.unpack_archive.__qualname__ == 'unpack_archive' — standalone qualname equality invariant not previously written."
    - "shutil.get_terminal_size.__qualname__ == 'get_terminal_size' — standalone qualname equality invariant not previously written."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ equality table — make_archive, unpack_archive, get_terminal_size
#
# shutil_extra5 covers all three in a larger table alongside copy/copy2/etc.
# shutil_extra21 provides length standalone invariants for all three.
# No prior shutil spec provides standalone equality invariants for any of these
# three functions. This table groups them in the extra22 namespace as a compact
# anchor for the standalone invariants below.
# ---------------------------------------------------------------------------

table shutil_extra22.function_qualnames:
  description: "__qualname__ equality for archive and terminal-size shutil functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: qualname22

  columns: [id, function, args, expected]
  rows:
    - [make_archive,     make_archive.__qualname__.__eq__,     ["make_archive"],     true]
    - [unpack_archive,   unpack_archive.__qualname__.__eq__,   ["unpack_archive"],   true]
    - [get_terminal_size, get_terminal_size.__qualname__.__eq__, ["get_terminal_size"], true]

# ---------------------------------------------------------------------------
# Standalone __qualname__ equality invariants
#
# Each invariant below is individually addressable in the extra22 namespace.
# shutil_extra21 provides length invariants for the same three functions;
# these equality invariants form a complementary set.
# ---------------------------------------------------------------------------

invariant shutil_extra22.make_archive.qualname:
  description: "shutil.make_archive.__qualname__ == 'make_archive' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: make_archive.__qualname__.__eq__
  args: ["make_archive"]
  expected: true

invariant shutil_extra22.unpack_archive.qualname:
  description: "shutil.unpack_archive.__qualname__ == 'unpack_archive' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: unpack_archive.__qualname__.__eq__
  args: ["unpack_archive"]
  expected: true

invariant shutil_extra22.get_terminal_size.qualname:
  description: "shutil.get_terminal_size.__qualname__ == 'get_terminal_size' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: get_terminal_size.__qualname__.__eq__
  args: ["get_terminal_size"]
  expected: true
