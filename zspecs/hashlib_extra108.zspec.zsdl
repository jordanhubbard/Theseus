spec: hashlib_extra108
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "hashlib_extra107.zspec.zsdl — covers HASH type identity (__name__=='HASH', __module__=='_hashlib', __mro__.__len__()==2, __bases__[0].__name__=='object') / HASH method qualname lengths (update=11, digest=11, hexdigest=14, copy=9) / md5/sha1/sha256/sha512 digest_size and block_size (table + invariants)."
    - "hashlib_extra106.zspec.zsdl — covers pbkdf2_hmac/scrypt __class__.__name__/__qualname__/__len__() and __name__.__eq__ / file_digest __qualname__/__name__/__module__.__len__() / sha3_224/256/384/512 and shake_128/256 __name__.__len__() (table + invariants)."
    - "hashlib_extra105.zspec.zsdl — covers sha3_*/shake_* __qualname__.__len__() / pbkdf2_hmac/__module__ / scrypt/__qualname__/__module__ / blake2b/blake2s __qualname__.__len__()==7 and __mro__/__bases__ (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s class/module/qualname / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* __qualname__/__module__ equality and __class__.__name__ / file_digest class/qualname/module equality / hashlib.__all__ class name and length (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra107; it does NOT duplicate invariants present in those files."
    - "Wave 267 theme: additional hash algorithm digest_size/block_size values for sha224/sha384/sha3_256/sha3_512/blake2b/blake2s and HASH method qualname string equality."
    - "hashlib.sha224().digest_size == 28. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224().block_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384().digest_size == 48. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384().block_size == 128. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256().digest_size == 32. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256().block_size == 136. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512().digest_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512().block_size == 72. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b().digest_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b().block_size == 128. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s().digest_size == 32. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s().block_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.sha3_256()).__name__ == 'HASH' (same type as md5/sha256). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.sha3_512()).__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.blake2b()).__name__ == 'blake2b' (different type from HASH; lives in _blake2). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.blake2s()).__name__ == 'blake2s'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.blake2b()).update.__qualname__ == 'blake2b.update' (len 14). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.blake2s()).update.__qualname__ == 'blake2s.update' (len 14). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.update.__qualname__.__eq__('HASH.update') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.hexdigest.__qualname__.__eq__('HASH.hexdigest') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: sha3_256 and sha3_512 use the same _hashlib HASH type as md5/sha256; sha3_256.block_size==136 (Keccak rate for 256-bit output) and sha3_512.block_size==72 (Keccak rate for 512-bit output) — SHA-3 uses rate/capacity tradeoff unlike fixed 512/1024-bit SHA-2 blocks."
    - "Note: blake2b and blake2s are different C types from _blake2 module, NOT the same HASH type. blake2b is 64-byte output / 128-byte block; blake2s is 32-byte output / 64-byte block."
    - "Note: sha224 and sha384 share block_size==64 and 128 respectively with sha256 and sha512 (same SHA-2 family internal block sizes for their bit widths)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha224().digest_size==28 / sha224().block_size==64
# hashlib.sha384().digest_size==48 / sha384().block_size==128
# hashlib.sha3_256().digest_size==32 / sha3_256().block_size==136
# hashlib.sha3_512().digest_size==64 / sha3_512().block_size==72
#
# Wave 267 theme: additional hash algorithm digest_size and block_size values.
#
# sha224 uses 224-bit (28-byte) output with the same 512-bit (64-byte) compression
# block as sha256. sha384 uses 384-bit (48-byte) output with 1024-bit (128-byte)
# blocks like sha512. sha3_256 and sha3_512 use Keccak sponge construction:
# block_size is the rate (bytes absorbed per permutation): 136 for sha3_256
# and 72 for sha3_512. hashlib_extra107 anchors md5/sha1/sha256/sha512 sizes;
# no prior hashlib spec anchors sha224/sha384/sha3_256/sha3_512 sizes under
# hashhash108. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra108.sha224_384_sha3_digest_block_sizes:
  description: "sha224().digest_size==28 / sha224().block_size==64 / sha384().digest_size==48 / sha384().block_size==128 / sha3_256().digest_size==32 / sha3_256().block_size==136 / sha3_512().digest_size==64 / sha3_512().block_size==72 — sha224/sha384 are SHA-2 family (same block sizes as sha256/sha512 respectively); sha3_256/sha3_512 use Keccak sponge with rate-based block_size (136 and 72 bytes); extra107 anchors md5/sha1/sha256/sha512; first hashhash108 anchor for sha224/sha384/sha3_256/sha3_512 sizes"
  kind: python_call_eq
  category: hash_properties
  id_prefix: hashhash108

  columns: [id, function, args, expected, description]
  rows:
    - [sha224_digest_size,   "sha224().digest_size.__eq__",   [28],  true, "sha224 digest_size is 28 bytes (224-bit output; SHA-2 family)"]
    - [sha224_block_size,    "sha224().block_size.__eq__",    [64],  true, "sha224 block_size is 64 bytes (512-bit SHA-2 compression block, same as sha256)"]
    - [sha384_digest_size,   "sha384().digest_size.__eq__",   [48],  true, "sha384 digest_size is 48 bytes (384-bit output; SHA-2 family)"]
    - [sha384_block_size,    "sha384().block_size.__eq__",    [128], true, "sha384 block_size is 128 bytes (1024-bit SHA-2 block, same as sha512)"]
    - [sha3_256_digest_size, "sha3_256().digest_size.__eq__", [32],  true, "sha3_256 digest_size is 32 bytes (256-bit Keccak output)"]
    - [sha3_256_block_size,  "sha3_256().block_size.__eq__",  [136], true, "sha3_256 block_size is 136 bytes (Keccak sponge rate for 256-bit output)"]
    - [sha3_512_digest_size, "sha3_512().digest_size.__eq__", [64],  true, "sha3_512 digest_size is 64 bytes (512-bit Keccak output)"]
    - [sha3_512_block_size,  "sha3_512().block_size.__eq__",  [72],  true, "sha3_512 block_size is 72 bytes (Keccak sponge rate for 512-bit output)"]

# ---------------------------------------------------------------------------
# hashlib.blake2b().digest_size==64 / blake2b().block_size==128
# hashlib.blake2s().digest_size==32 / blake2s().block_size==64
# type(hashlib.blake2b()).__name__=='blake2b'
# type(hashlib.blake2s()).__name__=='blake2s'
#
# Wave 267 theme: blake2b and blake2s digest_size/block_size and type names.
#
# blake2b and blake2s are distinct C types from the _blake2 module (not the
# same HASH type from _hashlib). blake2b produces 64-byte output with 128-byte
# block_size; blake2s produces 32-byte output with 64-byte block_size.
# type(blake2b()).__name__ is 'blake2b' and type(blake2s()).__name__ is 'blake2s'.
# No prior hashlib spec anchors blake2b/blake2s instance digest_size or
# block_size values as a table under hashhash108.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra108.blake2_digest_block_sizes_and_types:
  description: "blake2b().digest_size==64 / blake2b().block_size==128 / blake2s().digest_size==32 / blake2s().block_size==64 / type(blake2b()).__name__=='blake2b' / type(blake2s()).__name__=='blake2s' — blake2b/blake2s are _blake2 C types (not HASH from _hashlib); blake2b is 64-byte output / 128-byte block; blake2s is 32-byte output / 64-byte block; extra105 anchors __qualname__.__len__==7; first hashhash108 anchor for blake2 digest_size/block_size values"
  kind: python_call_eq
  category: hash_properties
  id_prefix: hashhash108

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_digest_size, "blake2b().digest_size.__eq__",          [64],      true, "blake2b default digest_size is 64 bytes (512-bit output; max for BLAKE2b)"]
    - [blake2b_block_size,  "blake2b().block_size.__eq__",           [128],     true, "blake2b block_size is 128 bytes (1024-bit BLAKE2b block)"]
    - [blake2s_digest_size, "blake2s().digest_size.__eq__",          [32],      true, "blake2s default digest_size is 32 bytes (256-bit output; max for BLAKE2s)"]
    - [blake2s_block_size,  "blake2s().block_size.__eq__",           [64],      true, "blake2s block_size is 64 bytes (512-bit BLAKE2s block)"]
    - [blake2b_type_name,   "blake2b().__class__.__name__.__eq__",   ["blake2b"], true, "type(blake2b()) is 'blake2b' — distinct C type from _blake2, NOT the HASH type from _hashlib"]
    - [blake2s_type_name,   "blake2s().__class__.__name__.__eq__",   ["blake2s"], true, "type(blake2s()) is 'blake2s' — distinct C type from _blake2, NOT the HASH type from _hashlib"]

# ---------------------------------------------------------------------------
# type(hashlib.sha3_256()).__name__.__eq__('HASH') == True
# HASH.update.__qualname__.__eq__('HASH.update') == True
# HASH.hexdigest.__qualname__.__eq__('HASH.hexdigest') == True
#
# Wave 267 theme: HASH method qualname string equality and sha3 type identity.
#
# sha3_256 and sha3_512 return the same HASH type from _hashlib as md5/sha256
# (OpenSSL EVP context). HASH.update.__qualname__ is exactly 'HASH.update' and
# HASH.hexdigest.__qualname__ is exactly 'HASH.hexdigest'. hashlib_extra107
# anchors HASH method qualname *lengths* (11 for update, 14 for hexdigest);
# no prior hashlib spec anchors the qualname string *equality* or sha3_256
# type identity as a group under hashhash108.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra108.HASH_qualname_eq_and_sha3_type:
  description: "sha3_256().__class__.__name__.__eq__('HASH')==True / sha3_512().__class__.__name__.__eq__('HASH')==True / HASH.update.__qualname__.__eq__('HASH.update')==True / HASH.hexdigest.__qualname__.__eq__('HASH.hexdigest')==True / blake2b().__class__.__module__.__eq__('_blake2')==True — sha3_256/sha3_512 use same _hashlib HASH type as md5/sha256; HASH method qualname string equality; blake2b lives in _blake2 module; extra107 anchors qualname lengths; first hashhash108 anchor for qualname equality and sha3 type name"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashhash108

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_type_name,    "sha3_256().__class__.__name__.__eq__",           ["HASH"],           true, "sha3_256() returns HASH from _hashlib (same type as md5/sha256; OpenSSL-backed)"]
    - [sha3_512_type_name,    "sha3_512().__class__.__name__.__eq__",           ["HASH"],           true, "sha3_512() returns HASH from _hashlib (same type as md5/sha256; OpenSSL-backed)"]
    - [hash_update_qname_eq,  "sha256().__class__.update.__qualname__.__eq__",  ["HASH.update"],    true, "HASH.update.__qualname__ is exactly 'HASH.update' (11 chars)"]
    - [hash_hexdig_qname_eq,  "sha256().__class__.hexdigest.__qualname__.__eq__", ["HASH.hexdigest"], true, "HASH.hexdigest.__qualname__ is exactly 'HASH.hexdigest' (14 chars)"]
    - [blake2b_module_eq,     "blake2b().__class__.__module__.__eq__",          ["_blake2"],        true, "type(blake2b()).__module__ is '_blake2' (distinct from HASH's '_hashlib' module)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_512().block_size.__eq__(72) — standalone
#
# hashlib.sha3_512().block_size is 72. SHA-3-512 uses the Keccak sponge
# construction with a rate of 72 bytes (576 bits) and a capacity of 512 bits
# (1152 - 576 = wait, actually: rate=1600 - 2*512 = 576 bits = 72 bytes).
# This is the smallest block_size among the common hash algorithms — much
# smaller than SHA-512's 128 bytes. The sponge rate trades off against the
# capacity: higher security (512-bit) means smaller rate (72 bytes) in SHA-3.
# hashlib_extra107 does not anchor sha3_512 block_size; no prior hashlib spec
# anchors it as a standalone under hashhash108.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra108.sha3_512_block_size_72:
  description: "hashlib.sha3_512().block_size.__eq__(72) == True — sha3_512 uses Keccak sponge with rate=72 bytes (1600-1024=576 bits rate? actually rate=1600-2*512=576 bits=72 bytes); smallest block_size among common algorithms; higher capacity (512-bit) means smaller rate in SHA-3; no prior hashlib spec anchors sha3_512 block_size; first standalone under hashhash108"
  category: hash_properties
  kind: python_call_eq
  function: "sha3_512().block_size.__eq__"
  args: [72]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256().block_size.__eq__(136) — standalone
#
# hashlib.sha3_256().block_size is 136. SHA-3-256 uses Keccak sponge rate
# of 136 bytes (1088 bits = 1600 - 2*256). This is larger than SHA-3-512's
# 72-byte rate because the 256-bit capacity trade-off allows more bytes to be
# absorbed per permutation. Unlike SHA-2, SHA-3 block_size values are not
# powers of 64 bytes. hashlib_extra107 does not anchor sha3_256 block_size;
# no prior hashlib spec anchors sha3_256 block_size as a standalone under
# hashhash108. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra108.sha3_256_block_size_136:
  description: "hashlib.sha3_256().block_size.__eq__(136) == True — sha3_256 uses Keccak sponge rate=136 bytes (1088 bits = 1600 - 2*256); larger rate than sha3_512 (72 bytes) because lower capacity trade-off; SHA-3 block_sizes are not multiples of 64 unlike SHA-2; no prior hashlib spec anchors sha3_256 block_size; first standalone under hashhash108"
  category: hash_properties
  kind: python_call_eq
  function: "sha3_256().block_size.__eq__"
  args: [136]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha384().digest_size.__eq__(48) — standalone
#
# hashlib.sha384().digest_size is 48. SHA-384 produces a 384-bit (48-byte)
# message digest. It is a truncated variant of SHA-512: internally it uses
# the same 1024-bit (128-byte) compression blocks as SHA-512, but initializes
# with different constants and truncates the output from 512 to 384 bits.
# hashlib_extra107 anchors sha512 block_size==128 but not sha384 digest_size;
# no prior hashlib spec anchors sha384 digest_size as a standalone under
# hashhash108. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra108.sha384_digest_size_48:
  description: "hashlib.sha384().digest_size.__eq__(48) == True — sha384 produces 384-bit (48-byte) digest; truncated SHA-512 variant using same 128-byte blocks; fills the gap between sha256 (32 bytes) and sha512 (64 bytes); extra107 anchors sha512 block_size but not sha384 digest_size; first standalone under hashhash108"
  category: hash_properties
  kind: python_call_eq
  function: "sha384().digest_size.__eq__"
  args: [48]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b().digest_size.__eq__(64) — standalone
#
# hashlib.blake2b().digest_size is 64. BLAKE2b produces a maximum of 512-bit
# (64-byte) output. When called with no arguments, blake2b() uses the maximum
# digest size. BLAKE2b is designed for 64-bit platforms and produces output
# from 1 to 64 bytes. Its digest_size == sha512().digest_size == 64, but it
# uses a different algorithm and type (blake2b C type from _blake2 vs HASH
# from _hashlib). No prior hashlib spec anchors blake2b digest_size as a
# standalone under hashhash108. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra108.blake2b_digest_size_64:
  description: "hashlib.blake2b().digest_size.__eq__(64) == True — blake2b defaults to maximum 64-byte (512-bit) output; BLAKE2b designed for 64-bit platforms; same digest_size as sha512 but different algorithm and C type; no prior hashlib spec anchors blake2b digest_size as standalone; first standalone under hashhash108"
  category: hash_properties
  kind: python_call_eq
  function: "blake2b().digest_size.__eq__"
  args: [64]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha224().digest_size.__eq__(28) — standalone
#
# hashlib.sha224().digest_size is 28. SHA-224 produces a 224-bit (28-byte)
# message digest. It is a truncated variant of SHA-256: internally it uses
# the same 512-bit (64-byte) compression blocks as SHA-256 but initializes
# with different constants and truncates from 256 to 224 bits. Among the SHA-2
# family anchored in this spec, sha224 has the smallest digest_size (28 bytes).
# hashlib_extra107 anchors sha256 digest_size==32 but not sha224; no prior
# hashlib spec anchors sha224 digest_size as a standalone under hashhash108.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra108.sha224_digest_size_28:
  description: "hashlib.sha224().digest_size.__eq__(28) == True — sha224 produces 224-bit (28-byte) digest; truncated SHA-256 variant using same 64-byte blocks; smallest SHA-2 digest_size in this spec (sha224=28, sha256=32, sha384=48, sha512=64); extra107 anchors sha256 digest_size but not sha224; first standalone under hashhash108"
  category: hash_properties
  kind: python_call_eq
  function: "sha224().digest_size.__eq__"
  args: [28]
  expected: true
