error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Barrier class identity
#
# Wave 289 theme: threading.Barrier class identity — name, module, base class,
# and base count.
#
# threading.Barrier.__name__ == 'Barrier'
# threading.Barrier.__module__ == 'threading'
# threading.Barrier.__bases__[0].__name__ == 'object'
# threading.Barrier.__bases__.__len__() == 1
#
# threading.Barrier is a Python class defined in Lib/threading.py that
# implements a synchronization primitive for a fixed number of threads (called
# parties). All parties must call wait() before any are released. Unlike
# threading.Timer (which inherits from Thread), Barrier inherits directly from
# object. Its __module__ is 'threading', its __name__ is 'Barrier', and its
# __bases__ tuple contains exactly one element (object). New to extra161.
# ---------------------------------------------------------------------------

table threading_extra161.barrier_class_identity:
  description: "threading.Barrier: __name__ 'Barrier', __module__ 'threading', __bases__[0].__name__ 'object', __bases__.__len__() 1; wave 289; new to extra161"
  kind: python_call_eq
  category: identity
  id_prefix: threadingbarrci161

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_name_eq,
       "Barrier.__name__.__eq__",
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — Barrier is a Python class in Lib/threading.py implementing a synchronization barrier; all parties must call wait before any are released; its class name is 'Barrier'; str.__eq__('Barrier') returns True; new to extra161"]
    - [barrier_module_eq_threading,
       "Barrier.__module__.__eq__",
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — Barrier is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra161"]
    - ["barrier_bases_0_name_eq_object",
       "Barrier.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Barrier.__bases__[0].__name__.__eq__('object') == True — Barrier inherits directly from object; unlike Timer (which inherits from Thread), Barrier does not subclass any threading class; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra161"]
    - [barrier_bases_len_eq_1,
       "Barrier.__bases__.__len__",
       [],
       1,
       "threading.Barrier.__bases__.__len__() == 1 — Barrier has exactly one direct base class (object); its __bases__ tuple contains a single element; tuple.__len__() returns 1; new to extra161"]

# ---------------------------------------------------------------------------
# Table 2: threading.Barrier method qualnames
#
# Wave 289 theme: threading.Barrier method __qualname__ attributes.
#
# threading.Barrier.wait.__qualname__ == 'Barrier.wait'
# threading.Barrier.reset.__qualname__ == 'Barrier.reset'
# threading.Barrier.abort.__qualname__ == 'Barrier.abort'
# threading.Barrier.__init__.__qualname__ == 'Barrier.__init__'
#
# Barrier.wait(timeout=None) blocks until all parties have called wait, then
# releases all of them. It returns an integer in the range [0, parties) that
# is unique among all threads released. Barrier.reset() returns the barrier
# to its initial empty state; threads already waiting are notified of a
# BrokenBarrierError. Barrier.abort() puts the barrier into a broken state
# so that any current or future calls to wait() raise BrokenBarrierError.
# Barrier.__init__(parties, action=None, timeout=None) initializes the
# barrier. All methods are Python functions defined in the Barrier class body
# in Lib/threading.py with __qualnames__ following 'Barrier.<method>'.
# New to extra161.
# ---------------------------------------------------------------------------

table threading_extra161.barrier_method_qualnames:
  description: "threading.Barrier method qualnames: wait 'Barrier.wait', reset 'Barrier.reset', abort 'Barrier.abort', __init__ 'Barrier.__init__'; wave 289; new to extra161"
  kind: python_call_eq
  category: identity
  id_prefix: threadingbarrmq161

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_wait_qn_eq,
       "Barrier.wait.__qualname__.__eq__",
       ["Barrier.wait"],
       true,
       "threading.Barrier.wait.__qualname__.__eq__('Barrier.wait') == True — Barrier.wait blocks until all parties call wait and then releases them all; it is a Python method in Lib/threading.py; its __qualname__ is 'Barrier.wait'; str.__eq__('Barrier.wait') returns True; new to extra161"]
    - [barrier_reset_qn_eq,
       "Barrier.reset.__qualname__.__eq__",
       ["Barrier.reset"],
       true,
       "threading.Barrier.reset.__qualname__.__eq__('Barrier.reset') == True — Barrier.reset returns the barrier to its initial empty state and causes threads already waiting to raise BrokenBarrierError; it is a Python method in Lib/threading.py; its __qualname__ is 'Barrier.reset'; str.__eq__('Barrier.reset') returns True; new to extra161"]
    - [barrier_abort_qn_eq,
       "Barrier.abort.__qualname__.__eq__",
       ["Barrier.abort"],
       true,
       "threading.Barrier.abort.__qualname__.__eq__('Barrier.abort') == True — Barrier.abort puts the barrier into a broken state so all current and future calls to wait raise BrokenBarrierError; it is a Python method in Lib/threading.py; its __qualname__ is 'Barrier.abort'; str.__eq__('Barrier.abort') returns True; new to extra161"]
    - [barrier_init_qn_eq,
       "Barrier.__init__.__qualname__.__eq__",
       ["Barrier.__init__"],
       true,
       "threading.Barrier.__init__.__qualname__.__eq__('Barrier.__init__') == True — Barrier.__init__(parties, action=None, timeout=None) initializes the barrier for the given number of parties with an optional action callable and default timeout; its __qualname__ is 'Barrier.__init__'; str.__eq__('Barrier.__init__') returns True; new to extra161"]

