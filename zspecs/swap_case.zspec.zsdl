spec: swap_case
version: ">=2.0.0"
backend: node(swap-case)

docs: https://www.npmjs.com/package/swap-case

provenance:
  derived_from:
    - "swap-case README — https://www.npmjs.com/package/swap-case"
    - "Test vectors verified with swap-case@2.0.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "swap-case source"
  notes:
    - "swap-case exports {swapCase} named function."
    - "swapCase inverts the case of each character."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns string with each character's case inverted."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table swap_case.swap_case:
  kind: node_module_call_eq
  function: swapCase
  category: swapCase
  id_prefix: swcase

  columns: [id, args, expected]
  rows:
    - [mixed,  ["Hello World"],  "hELLO wORLD"]
    - [upper,  ["FOO"],          "foo"]
    - [lower,  ["foo"],          "FOO"]
    - [camel,  ["fooBar"],       "FOObAR"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:29:10Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
