spec: decimal_extra228
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Context method __name__ contracts."
    - "decimal.Context.clear_flags.__name__ == 'clear_flags' — Context.clear_flags method name; length 11; verified Python 3.14.3 macOS."
    - "decimal.Context.clear_traps.__name__ == 'clear_traps' — Context.clear_traps method name; length 11; verified Python 3.14.3 macOS."
    - "decimal.Context.copy.__name__ == 'copy' — Context.copy method name; length 4; verified Python 3.14.3 macOS."
    - "decimal.Context.create_decimal.__name__ == 'create_decimal' — Context.create_decimal method name; length 14; verified Python 3.14.3 macOS."
    - "decimal.Context.sqrt.__name__ == 'sqrt' — Context.sqrt method name; length 4; verified Python 3.14.3 macOS."
    - "decimal.Context.power.__name__ == 'power' — Context.power method name; length 5; verified Python 3.14.3 macOS."
    - "decimal.Context.clear_flags.__qualname__ == 'Context.clear_flags' — verified Python 3.14.3 macOS."
    - "decimal.Context.copy.__qualname__ == 'Context.copy' — verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context method __name__ contracts
# All standard Context methods carry their canonical name as __name__.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra228.Context_method_names:
  description: "decimal.Context method __name__ contracts — clear_flags, clear_traps, copy, create_decimal, sqrt, power; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_name
  id_prefix: decctxmnames228

  columns: [id, function, args, expected]
  rows:
    - [ctx_clear_flags_name,    Context.clear_flags.__name__.__eq__,    ["clear_flags"],    true]
    - [ctx_clear_traps_name,    Context.clear_traps.__name__.__eq__,    ["clear_traps"],    true]
    - [ctx_copy_name,           Context.copy.__name__.__eq__,           ["copy"],           true]
    - [ctx_create_decimal_name, Context.create_decimal.__name__.__eq__, ["create_decimal"], true]
    - [ctx_sqrt_name,           Context.sqrt.__name__.__eq__,           ["sqrt"],           true]
    - [ctx_power_name,          Context.power.__name__.__eq__,          ["power"],          true]

# ---------------------------------------------------------------------------
# decimal.Context qualname contracts
# Spot-check qualnames for clear_flags and copy.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra228.Context.clear_flags.qualname:
  description: "decimal.Context.clear_flags.__qualname__ == 'Context.clear_flags' — verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Context.clear_flags.__qualname__.__eq__
  args: ["Context.clear_flags"]
  expected: true

invariant decimal_extra228.Context.copy.qualname:
  description: "decimal.Context.copy.__qualname__ == 'Context.copy' — verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Context.copy.__qualname__.__eq__
  args: ["Context.copy"]
  expected: true

# ---------------------------------------------------------------------------
# decimal.Context method name length contracts
# Spot-check selected method name lengths.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra228.Context.clear_flags.name_length:
  description: "decimal.Context.clear_flags.__name__.__len__() == 11 — 'clear_flags' has 11 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Context.clear_flags.__name__.__len__
  args: []
  expected: 11

invariant decimal_extra228.Context.create_decimal.name_length:
  description: "decimal.Context.create_decimal.__name__.__len__() == 14 — 'create_decimal' has 14 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Context.create_decimal.__name__.__len__
  args: []
  expected: 14

invariant decimal_extra228.Context.copy.name_length:
  description: "decimal.Context.copy.__name__.__len__() == 4 — 'copy' has 4 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Context.copy.__name__.__len__
  args: []
  expected: 4

invariant decimal_extra228.Context.power.name_length:
  description: "decimal.Context.power.__name__.__len__() == 5 — 'power' has 5 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Context.power.__name__.__len__
  args: []
  expected: 5
