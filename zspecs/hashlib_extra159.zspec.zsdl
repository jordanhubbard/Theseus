spec: hashlib_extra159
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra158.zspec.zsdl — covers hashlib.sha256/__doc__/__class__.__name__.__eq__('str') / md5/__doc__/__class__.__name__.__eq__('str') / sha256/__qualname__.__len__()==14 / md5/__qualname__.__len__()==11 / sha1/__qualname__.__len__()==12 / sha512/__qualname__.__len__()==14 / sha3_256/__qualname__.__len__()==16 (table + invariants)."
    - "hashlib_extra157.zspec.zsdl — covers hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') / __spec__.name.__eq__('hashlib') / __all__.__class__.__name__.__eq__('tuple') / __all__.__contains__('md5'/'sha256'/'sha512') / new.__module__.__eq__('hashlib') / new.__class__.__name__.__eq__('function') (table + invariants)."
    - "hashlib_extra156.zspec.zsdl — covers hashlib.sha256/__qualname__/__eq__('openssl_sha256') / md5/__qualname__ / sha512/__qualname__ / sha256/__qualname__/__len__()==14 / blake2b/__name__/__qualname__ / sha3_256/__name__/__qualname__/__len__()==16 (table + invariants)."
    - "hashlib_extra155.zspec.zsdl — covers hashlib.sha256/__class__.__name__.__eq__('builtin_function_or_method') / sha256/__module__/__eq__('_hashlib') / sha256/__name__/__eq__('openssl_sha256') / md5/__name__ / sha1/__name__ / sha512/__name__ / pbkdf2_hmac/__module__ (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra158."
    - "Wave 338 theme: hashlib.scrypt and pbkdf2_hmac identity and hashlib.file_digest (Python 3.11+) module/code identity — scrypt.__class__.__name__.__eq__('builtin_function_or_method') / scrypt.__module__.__eq__('_hashlib') / scrypt.__name__.__eq__('scrypt') / pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method') / pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac') / file_digest.__module__.__eq__('hashlib') / file_digest.__code__.co_name.__eq__('file_digest')."
    - "hashlib.scrypt.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__name__ == 'scrypt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__module__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_name == 'file_digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.scrypt.__class__.__name__ == 'builtin_function_or_method' and __module__ == '_hashlib'. scrypt is the memory-hard key derivation function (RFC 7914). It is implemented in the _hashlib C extension (backed by OpenSSL), giving it __module__=='_hashlib'. Its __name__=='scrypt' (6 chars; bare name, no 'openssl_' prefix unlike hash constructors sha256/md5). scrypt takes password, salt, n, r, p as keyword arguments."
    - "Note: hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'. pbkdf2_hmac is the PBKDF2-HMAC key derivation function (PKCS#5). Like scrypt, it is a builtin_function_or_method from _hashlib with __module__=='_hashlib' (anchored by extra155). Its __name__=='pbkdf2_hmac' (10 chars). pbkdf2_hmac takes hash_name, password, salt, iterations as arguments."
    - "Note: hashlib.file_digest.__module__ == 'hashlib'. file_digest was added in Python 3.11 (bpo-45225). Unlike scrypt and pbkdf2_hmac which are C extension builtins from _hashlib, file_digest is a pure Python function defined in Lib/hashlib.py, hence __module__=='hashlib'. file_digest.__code__.co_name == 'file_digest' (11 chars) confirms it is the original function from the def statement. It computes the digest of a file object efficiently."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.scrypt.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.scrypt.__module__.__eq__('_hashlib')
# hashlib.scrypt.__name__.__eq__('scrypt')
# hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 338 theme: scrypt and pbkdf2_hmac are builtin_function_or_method from _hashlib.
#
# scrypt.__class__.__name__ == 'builtin_function_or_method' (26 chars; C extension callable).
# scrypt.__module__ == '_hashlib' (8 chars; same as sha256, md5, etc.).
# scrypt.__name__ == 'scrypt' (6 chars; no 'openssl_' prefix, unlike sha256='openssl_sha256').
# pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method' (26 chars).
# extra155 anchors pbkdf2_hmac.__module__=='_hashlib'; no prior hashlib spec anchors
# scrypt or pbkdf2_hmac identity as a combined table under hashkdf159.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra159.scrypt_pbkdf2_hmac_identity:
  description: "hashlib.scrypt.__class__.__name__.__eq__('builtin_function_or_method')==True / scrypt.__module__.__eq__('_hashlib')==True / scrypt.__name__.__eq__('scrypt')==True / pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method')==True — scrypt is a C extension callable (26 chars; OpenSSL-backed KDF from RFC 7914); scrypt.__module__ is '_hashlib' (8 chars; same module as sha256/md5; underscore-prefixed); scrypt.__name__ is 'scrypt' (6 chars; no 'openssl_' prefix, unlike openssl_sha256); pbkdf2_hmac is also 'builtin_function_or_method' (PKCS#5 PBKDF2-HMAC KDF; extra155 anchors pbkdf2_hmac.__module__=='_hashlib'); first hashkdf159 anchor for scrypt identity and pbkdf2_hmac class name"
  kind: python_call_eq
  category: identity
  id_prefix: hashkdf159

  columns: [id, function, args, expected, description]
  rows:
    - [scrypt_class_builtin,    "scrypt.__class__.__name__.__eq__",    ["builtin_function_or_method"], true, "hashlib.scrypt.__class__.__name__ == 'builtin_function_or_method' (26 chars; C extension from _hashlib; memory-hard KDF)"]
    - [scrypt_module_hashlib,   "scrypt.__module__.__eq__",            ["_hashlib"],                   true, "hashlib.scrypt.__module__ == '_hashlib' (8 chars; C extension; same module as sha256/md5; OpenSSL-backed scrypt)"]
    - [scrypt_name_scrypt,      "scrypt.__name__.__eq__",              ["scrypt"],                     true, "hashlib.scrypt.__name__ == 'scrypt' (6 chars; bare name; no 'openssl_' prefix unlike hash constructors sha256/md5)"]
    - [pbkdf2_class_builtin,    "pbkdf2_hmac.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method' (26 chars; PKCS#5 PBKDF2-HMAC from _hashlib)"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac')
# hashlib.file_digest.__module__.__eq__('hashlib')
# hashlib.file_digest.__code__.co_name.__eq__('file_digest')
#
# Wave 338 theme: pbkdf2_hmac name and file_digest (Python 3.11+) module/code identity.
#
# pbkdf2_hmac.__name__ == 'pbkdf2_hmac' (10 chars; underscore in name distinguishes from 'scrypt').
# file_digest.__module__ == 'hashlib' (7 chars; pure Python function, NOT '_hashlib' like scrypt).
# file_digest.__code__.co_name == 'file_digest' (11 chars; matches function name in def statement).
# No prior hashlib spec anchors pbkdf2_hmac.__name__ or file_digest identity as a combined
# table under hashkdf159. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra159.pbkdf2_name_and_file_digest_identity:
  description: "hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac')==True / file_digest.__module__.__eq__('hashlib')==True / file_digest.__code__.co_name.__eq__('file_digest')==True / scrypt.__name__.__eq__('scrypt')==True — pbkdf2_hmac.__name__ is 'pbkdf2_hmac' (10 chars; underscore separates algorithm name from HMAC mode; contrast with scrypt='scrypt'=6 chars); file_digest.__module__ is 'hashlib' (7 chars; pure Python in Lib/hashlib.py; added Python 3.11 bpo-45225; NOT '_hashlib' like scrypt/pbkdf2_hmac); file_digest.__code__.co_name is 'file_digest' (11 chars; confirms original function from def statement); first hashkdf159 anchor for pbkdf2_hmac.__name__ and file_digest identity"
  kind: python_call_eq
  category: identity
  id_prefix: hashkdf159

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_name_pbkdf2_hmac, "pbkdf2_hmac.__name__.__eq__",            ["pbkdf2_hmac"],   true, "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac' (10 chars; underscore in name; PKCS#5 password-based KDF using HMAC)"]
    - [file_digest_module,      "file_digest.__module__.__eq__",          ["hashlib"],       true, "hashlib.file_digest.__module__ == 'hashlib' (7 chars; pure Python Lib/hashlib.py; added Python 3.11; not '_hashlib')"]
    - [file_digest_co_name,     "file_digest.__code__.co_name.__eq__",    ["file_digest"],   true, "hashlib.file_digest.__code__.co_name == 'file_digest' (11 chars; matches def statement name; confirms original function)"]
    - [scrypt_name_scrypt_b,    "scrypt.__name__.__eq__",                 ["scrypt"],        true, "hashlib.scrypt.__name__ == 'scrypt' (6 chars; shorter than pbkdf2_hmac=10; both are OpenSSL-backed KDFs in _hashlib)"]

# ---------------------------------------------------------------------------
# hashlib.scrypt.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.scrypt.__class__.__name__ is 'builtin_function_or_method' (26 chars). scrypt
# is the memory-hard password hashing and key derivation function defined in RFC 7914.
# It is implemented in the _hashlib C extension (OpenSSL-backed), making it a
# builtin_function_or_method like hashlib.sha256 (extra155 anchors sha256's class name).
# scrypt is designed to be computationally expensive (CPU and memory intensive) to resist
# brute-force attacks. It requires the n, r, p cost parameters. Unlike the hash constructors
# (sha256, md5, etc.) whose __name__ starts with 'openssl_', scrypt.__name__ == 'scrypt'
# (bare name, 6 chars). No prior hashlib spec anchors scrypt.__class__.__name__ as a
# standalone under hashkdf159. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra159.scrypt_class_builtin_function:
  description: "hashlib.scrypt.__class__.__name__.__eq__('builtin_function_or_method') == True — 26 chars; C extension callable from _hashlib; memory-hard KDF (RFC 7914); OpenSSL-backed; scrypt.__module__=='_hashlib' (8 chars); scrypt.__name__=='scrypt' (6 chars; no 'openssl_' prefix); same class as hashlib.sha256 (extra155); resist brute-force via CPU and memory cost (n, r, p params); no prior hashlib spec anchors this as a standalone; first standalone under hashkdf159"
  category: identity
  kind: python_call_eq
  function: scrypt.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__module__.__eq__('hashlib') — standalone
#
# hashlib.file_digest.__module__ is 'hashlib' (7 chars). file_digest() was added in
# Python 3.11 (bpo-45225). Unlike scrypt and pbkdf2_hmac which are C extension callables
# from _hashlib (__module__=='_hashlib'), file_digest is a pure Python function defined
# in Lib/hashlib.py, so its __module__ is 'hashlib' (not '_hashlib'). file_digest()
# computes the hash digest of a file-like object efficiently, reading the file in chunks
# and updating the hash incrementally. It accepts a file object and a digest constructor
# (or string name). file_digest.__class__.__name__ == 'function' (regular Python function).
# No prior hashlib spec anchors file_digest.__module__ as a standalone under hashkdf159.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra159.file_digest_module_hashlib:
  description: "hashlib.file_digest.__module__.__eq__('hashlib') == True — 7 chars; pure Python function in Lib/hashlib.py; added Python 3.11 bpo-45225; computes digest of file-like object in chunks; NOT a C builtin (contrasts with scrypt/__module__=='_hashlib'); file_digest.__class__.__name__=='function' (not 'builtin_function_or_method'); file_digest.__code__.co_name=='file_digest' (11 chars); no prior hashlib spec anchors this as a standalone; first standalone under hashkdf159"
  category: identity
  kind: python_call_eq
  function: file_digest.__module__.__eq__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac') — standalone
#
# hashlib.pbkdf2_hmac.__name__ is 'pbkdf2_hmac' (10 chars). pbkdf2_hmac is the
# PBKDF2-HMAC key derivation function from PKCS#5 / RFC 2898. It is a builtin_function_or_method
# from the _hashlib C extension (extra155 anchors pbkdf2_hmac.__module__=='_hashlib').
# Its __name__ is 'pbkdf2_hmac' (10 chars = 'pbkdf2' + '_' + 'hmac'). The name encodes
# the algorithm: PBKDF2 (Password-Based Key Derivation Function 2) using HMAC as the
# pseudorandom function. The underscore separates the KDF name from the PRF name.
# pbkdf2_hmac is the longest KDF function name in the group: scrypt(6) < pbkdf2_hmac(10).
# No prior hashlib spec anchors pbkdf2_hmac.__name__ as a standalone under hashkdf159.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra159.pbkdf2_hmac_name_eq:
  description: "hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac') == True — 10 chars; PKCS#5/RFC 2898 PBKDF2 KDF using HMAC as PRF; name: 'pbkdf2'+'_'+'hmac'; extra155 anchors pbkdf2_hmac.__module__=='_hashlib'; pbkdf2_hmac.__class__.__name__=='builtin_function_or_method' (26 chars); name length ordering: scrypt(6) < pbkdf2_hmac(10); takes hash_name/password/salt/iterations args; no prior hashlib spec anchors this as a standalone; first standalone under hashkdf159"
  category: identity
  kind: python_call_eq
  function: pbkdf2_hmac.__name__.__eq__
  args: ["pbkdf2_hmac"]
  expected: true

