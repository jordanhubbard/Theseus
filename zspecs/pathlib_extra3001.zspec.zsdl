spec: pp3001
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module class hierarchy"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 647 (pp3001): __getitem__, __setitem__, __delitem__ dict-presence checks for pathlib types."
    - "pathlib path objects represent filesystem paths; they are not mappings or sequences and do not implement item access/mutation protocols."
    - "None of PurePath, PurePosixPath, PureWindowsPath, or Path define __getitem__, __setitem__, or __delitem__ in their own __dict__."
    - "Path components are accessed via attributes (.name, .parent, .parts tuple) rather than subscript syntax."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __getitem__ dict-presence — operator.contains(Cls.__dict__, '__getitem__')
#
# pathlib path types do not support subscript access; none define __getitem__; all false.
# ---------------------------------------------------------------------------

table pp3001.getitem:
  description: "pathlib types __getitem__ dict-presence checks; wave 647"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp3001
  columns: [id, function, args, expected]
  rows:
    - ["pp3001001", operator.contains, [pathlib.PurePath.__dict__,        "__getitem__"], false]
    - ["pp3001002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__getitem__"], false]
    - ["pp3001003", operator.contains, [pathlib.PureWindowsPath.__dict__, "__getitem__"], false]
    - ["pp3001004", operator.contains, [pathlib.Path.__dict__,            "__getitem__"], false]
    - ["pp3001005", operator.contains, [pathlib.PurePath.__dict__,        "__getitem__"], false]
    - ["pp3001006", operator.contains, [pathlib.Path.__dict__,            "__getitem__"], false]

