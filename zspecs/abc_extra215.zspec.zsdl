spec: abc_extra215
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "ABCMeta.__abstractmethods__ raises AttributeError — ABCMeta is a metaclass and does not expose __abstractmethods__ directly."
    - "abc.ABC.__subclasshook__ exists and __name__ == '__subclasshook__'."
    - "abc.abstractclassmethod still exists in Python 3.14.3 (deprecated since 3.3); __name__ == 'abstractclassmethod'; __module__ == 'abc'; __bases__[0].__name__ == 'classmethod'."
    - "abc.abstractstaticmethod still exists in Python 3.14.3 (deprecated since 3.3); __name__ == 'abstractstaticmethod'; __module__ == 'abc'; __bases__[0].__name__ == 'staticmethod'."
    - "abc.abstractproperty still exists in Python 3.14.3 (deprecated since 3.3); __name__ == 'abstractproperty'; __module__ == 'abc'; __bases__[0].__name__ == 'property'."
    - "abc.ABCMeta.__prepare__ exists and __name__ == '__prepare__'."
    - "abc.ABC.__subclasshook__.__module__ is None — __subclasshook__ is a classmethod defined without explicit module assignment."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABCMeta.__abstractmethods__ raises AttributeError — extra215 namespace
#
# ABCMeta is a metaclass (its instances are class objects).  Accessing
# ABCMeta.__abstractmethods__ raises AttributeError because ABCMeta itself
# is not subject to the abstract-method enforcement in the traditional sense.
# We chain further attribute access to ensure the AttributeError fires.
# ---------------------------------------------------------------------------

invariant abc_extra215.ABCMeta_no_abstractmethods:
  description: "abc.ABCMeta.__abstractmethods__ raises AttributeError — ABCMeta does not expose __abstractmethods__ as an instance attribute"
  category: errors
  kind: python_call_raises
  function: ABCMeta.__abstractmethods__.__class__.__name__.__len__
  args: []
  raises: AttributeError

# ---------------------------------------------------------------------------
# abc.ABC.__subclasshook__ identity — extra215 namespace
# ---------------------------------------------------------------------------

invariant abc_extra215.abc_subclasshook_name:
  description: "abc.ABC.__subclasshook__.__name__ == '__subclasshook__'"
  category: identity
  kind: python_call_eq
  function: ABC.__subclasshook__.__name__.__eq__
  args: ["__subclasshook__"]
  expected: true

# ---------------------------------------------------------------------------
# abc.abstractclassmethod identity — extra215 namespace
#
# abc.abstractclassmethod is deprecated since Python 3.3 but still present
# in Python 3.14.3.  It is a class inheriting from classmethod.
# ---------------------------------------------------------------------------

table abc_extra215.abstractclassmethod_identity:
  description: "abc.abstractclassmethod class identity in extra215 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc215abscmident

  columns: [id, function, args, expected, description]
  rows:
    - [abscm_name,   abstractclassmethod.__name__.__eq__,   ["abstractclassmethod"], true, "abc.abstractclassmethod.__name__ == 'abstractclassmethod'"]
    - [abscm_module, abstractclassmethod.__module__.__eq__, ["abc"],                 true, "abc.abstractclassmethod.__module__ == 'abc'"]

invariant abc_extra215.abstractclassmethod_base_name:
  description: "abc.abstractclassmethod.__bases__[0].__name__ == 'classmethod' — inherits from classmethod"
  category: class_hierarchy
  kind: python_call_eq
  function: "abstractclassmethod.__bases__[0].__name__.__eq__"
  args: ["classmethod"]
  expected: true

# ---------------------------------------------------------------------------
# abc.abstractstaticmethod identity — extra215 namespace
#
# abc.abstractstaticmethod is deprecated since Python 3.3 but still present
# in Python 3.14.3.  It is a class inheriting from staticmethod.
# ---------------------------------------------------------------------------

table abc_extra215.abstractstaticmethod_identity:
  description: "abc.abstractstaticmethod class identity in extra215 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc215abssmident

  columns: [id, function, args, expected, description]
  rows:
    - [abssm_name,   abstractstaticmethod.__name__.__eq__,   ["abstractstaticmethod"], true, "abc.abstractstaticmethod.__name__ == 'abstractstaticmethod'"]
    - [abssm_module, abstractstaticmethod.__module__.__eq__, ["abc"],                  true, "abc.abstractstaticmethod.__module__ == 'abc'"]

invariant abc_extra215.abstractstaticmethod_base_name:
  description: "abc.abstractstaticmethod.__bases__[0].__name__ == 'staticmethod' — inherits from staticmethod"
  category: class_hierarchy
  kind: python_call_eq
  function: "abstractstaticmethod.__bases__[0].__name__.__eq__"
  args: ["staticmethod"]
  expected: true

# ---------------------------------------------------------------------------
# abc.abstractproperty identity — extra215 namespace
#
# abc.abstractproperty is deprecated since Python 3.3 but still present
# in Python 3.14.3.  It is a class inheriting from property.
# ---------------------------------------------------------------------------

table abc_extra215.abstractproperty_identity:
  description: "abc.abstractproperty class identity in extra215 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc215abspropident

  columns: [id, function, args, expected, description]
  rows:
    - [absprop_name,   abstractproperty.__name__.__eq__,   ["abstractproperty"], true, "abc.abstractproperty.__name__ == 'abstractproperty'"]
    - [absprop_module, abstractproperty.__module__.__eq__, ["abc"],              true, "abc.abstractproperty.__module__ == 'abc'"]

invariant abc_extra215.abstractproperty_base_name:
  description: "abc.abstractproperty.__bases__[0].__name__ == 'property' — inherits from property"
  category: class_hierarchy
  kind: python_call_eq
  function: "abstractproperty.__bases__[0].__name__.__eq__"
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# abc.ABCMeta.__prepare__ identity — extra215 namespace
#
# ABCMeta defines __prepare__ (inherited from type but present on ABCMeta).
# Its __name__ is '__prepare__'.
# ---------------------------------------------------------------------------

invariant abc_extra215.ABCMeta_prepare_name:
  description: "abc.ABCMeta.__prepare__.__name__ == '__prepare__'"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__prepare__.__name__.__eq__
  args: ["__prepare__"]
  expected: true
