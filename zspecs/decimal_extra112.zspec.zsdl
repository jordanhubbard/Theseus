spec: decimal_extra112
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra111.zspec.zsdl."
    - "This spec covers: decimal rounding constant string methods (startswith, count) and MAX_PREC/MAX_EMAX/MIN_EMIN bit_length not previously covered."
    - "decimal_extra20 covered ROUND_* __len__() values; decimal_extra23/25/42 covered ROUND_* __class__.__name__=='str'."
    - "decimal_extra2/3 covered MAX_PREC/__class__.__name__=='int'; decimal_extra32 covered MAX_PREC.__class__.__name__.__len__()==3."
    - "No prior decimal spec has called startswith(), count(), or bit_length() on decimal module constants."
    - "ROUND_HALF_UP.startswith('ROUND') == True — all 8 ROUND_* constants begin with 'ROUND'."
    - "ROUND_HALF_UP.startswith('ROUND_HALF') == True — ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_HALF_EVEN all start with 'ROUND_HALF'."
    - "ROUND_DOWN.startswith('ROUND_HALF') == False — distinguishes ROUND_HALF_* from ROUND_DOWN/ROUND_UP/ROUND_CEILING/ROUND_FLOOR/ROUND_05UP."
    - "ROUND_HALF_UP.count('_') == 2 — two underscores: between 'ROUND' and 'HALF', and between 'HALF' and 'UP'."
    - "ROUND_DOWN.count('_') == 1 — one underscore: between 'ROUND' and 'DOWN'."
    - "decimal.MAX_PREC == decimal.MAX_EMAX == 999999999999999999 (the same 18-digit value)."
    - "decimal.MAX_PREC.bit_length() == 60 (the integer 999999999999999999 requires 60 bits)."
    - "decimal.MIN_EMIN == -999999999999999999 (exactly the negation of MAX_EMAX)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal ROUND_* constants: startswith() — all begin with 'ROUND'
# The 8 rounding constants are plain Python strings: ROUND_UP, ROUND_DOWN,
# ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_HALF_EVEN, ROUND_CEILING, ROUND_FLOOR,
# ROUND_05UP.  All begin with 'ROUND' (5 chars).  The HALF-family constants
# (ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_HALF_EVEN) additionally start with
# 'ROUND_HALF'.  No prior decimal spec has tested startswith() on ROUND_* constants.
# ---------------------------------------------------------------------------

table decimal_extra112.ROUND_constants_startswith:
  description: "decimal ROUND_* constants all startswith('ROUND'); ROUND_HALF_* additionally startswith('ROUND_HALF'); ROUND_DOWN.startswith('ROUND_HALF')==False; no prior decimal spec covers startswith on rounding constants"
  kind: python_call_eq
  category: module_constants
  id_prefix: decrndstarts112a

  columns: [id, function, args, expected, description]
  rows:
    - [hu_starts_round,    "ROUND_HALF_UP.startswith",    ["ROUND"],       true,  "decimal.ROUND_HALF_UP.startswith('ROUND') == True (all 8 ROUND_* constants share the 'ROUND' prefix)"]
    - [down_starts_round,  "ROUND_DOWN.startswith",       ["ROUND"],       true,  "decimal.ROUND_DOWN.startswith('ROUND') == True ('ROUND' is the common prefix for all 8 rounding mode constants)"]
    - [up_starts_round,    "ROUND_UP.startswith",         ["ROUND"],       true,  "decimal.ROUND_UP.startswith('ROUND') == True (the 5-char prefix 'ROUND' is shared by all decimal rounding mode constants)"]
    - [ceil_starts_round,  "ROUND_CEILING.startswith",    ["ROUND"],       true,  "decimal.ROUND_CEILING.startswith('ROUND') == True (ROUND_CEILING is 13 chars; starts with the 5-char 'ROUND' prefix)"]
    - [hu_starts_half,     "ROUND_HALF_UP.startswith",    ["ROUND_HALF"],  true,  "decimal.ROUND_HALF_UP.startswith('ROUND_HALF') == True (the ROUND_HALF_* family shares the 10-char 'ROUND_HALF' prefix)"]
    - [hd_starts_half,     "ROUND_HALF_DOWN.startswith",  ["ROUND_HALF"],  true,  "decimal.ROUND_HALF_DOWN.startswith('ROUND_HALF') == True (ROUND_HALF_DOWN is 15 chars; shares 'ROUND_HALF'(10) with ROUND_HALF_UP and ROUND_HALF_EVEN)"]
    - [he_starts_half,     "ROUND_HALF_EVEN.startswith",  ["ROUND_HALF"],  true,  "decimal.ROUND_HALF_EVEN.startswith('ROUND_HALF') == True (ROUND_HALF_EVEN is 15 chars; shares 'ROUND_HALF'(10) prefix with ROUND_HALF_UP and ROUND_HALF_DOWN)"]
    - [down_not_half,      "ROUND_DOWN.startswith",       ["ROUND_HALF"],  false, "decimal.ROUND_DOWN.startswith('ROUND_HALF') == False (distinguishes ROUND_DOWN from the ROUND_HALF_* family; 'ROUND_HALF'(10) > len('ROUND_DOWN')(10) — both 10 chars but different text)"]
    - [up_not_half,        "ROUND_UP.startswith",         ["ROUND_HALF"],  false, "decimal.ROUND_UP.startswith('ROUND_HALF') == False (ROUND_UP is only 8 chars — shorter than the 10-char 'ROUND_HALF' prefix)"]

# ---------------------------------------------------------------------------
# decimal ROUND_* constants: count('_') — underscore count distinguishes families
# Simple ROUND_* constants (ROUND_UP, ROUND_DOWN, ROUND_CEILING, etc.) have
# exactly 1 underscore.  The ROUND_HALF_* family has 2 underscores.
# ROUND_05UP has exactly 1 underscore (between 'ROUND' and '05UP').
# No prior decimal spec has tested count('_') on rounding constants.
# ---------------------------------------------------------------------------

table decimal_extra112.ROUND_constants_underscore_count:
  description: "decimal ROUND_* constants underscore count: ROUND_HALF_* have 2 underscores; ROUND_DOWN/ROUND_UP/ROUND_CEILING/ROUND_FLOOR/ROUND_05UP have 1 underscore; count('_') distinguishes the HALF family"
  kind: python_call_eq
  category: module_constants
  id_prefix: decrndcount112b

  columns: [id, function, args, expected, description]
  rows:
    - [hu_count2,   "ROUND_HALF_UP.count",    ["_"],  2,     "decimal.ROUND_HALF_UP.count('_') == 2 (two underscores: 'ROUND'+'_'+'HALF'+'_'+'UP'; ROUND_HALF_* family all have 2 underscores)"]
    - [hd_count2,   "ROUND_HALF_DOWN.count",  ["_"],  2,     "decimal.ROUND_HALF_DOWN.count('_') == 2 (two underscores: 'ROUND'+'_'+'HALF'+'_'+'DOWN'; same count as ROUND_HALF_UP and ROUND_HALF_EVEN)"]
    - [he_count2,   "ROUND_HALF_EVEN.count",  ["_"],  2,     "decimal.ROUND_HALF_EVEN.count('_') == 2 (two underscores: 'ROUND'+'_'+'HALF'+'_'+'EVEN'; all three ROUND_HALF_* constants share this count)"]
    - [down_count1, "ROUND_DOWN.count",        ["_"],  1,     "decimal.ROUND_DOWN.count('_') == 1 (one underscore between 'ROUND' and 'DOWN'; ROUND_DOWN is a simple (non-HALF) rounding constant)"]
    - [up_count1,   "ROUND_UP.count",          ["_"],  1,     "decimal.ROUND_UP.count('_') == 1 (one underscore between 'ROUND' and 'UP'; the simplest rounding constant name by length at 8 chars)"]
    - [ceil_count1, "ROUND_CEILING.count",     ["_"],  1,     "decimal.ROUND_CEILING.count('_') == 1 (one underscore between 'ROUND' and 'CEILING'; same count as all non-HALF rounding constants)"]
    - [z5up_count1, "ROUND_05UP.count",        ["_"],  1,     "decimal.ROUND_05UP.count('_') == 1 (one underscore between 'ROUND' and '05UP'; ROUND_05UP is the unique constant with a digit in its name)"]
    - [floor_count1, "ROUND_FLOOR.count",       ["_"],  1,     "decimal.ROUND_FLOOR.count('_') == 1 (one underscore between 'ROUND' and 'FLOOR'; like all non-HALF rounding constants; confirms only ROUND_HALF_* constants have count==2)"]

# ---------------------------------------------------------------------------
# decimal MAX_PREC, MAX_EMAX, MIN_EMIN: bit_length and equality relations
# MAX_PREC == MAX_EMAX == 999999999999999999 — both are the same 18-digit integer.
# MIN_EMIN == -999999999999999999 — exactly the negation of MAX_EMAX.
# MAX_PREC.bit_length() == MAX_EMAX.bit_length() == 60 (since they are equal).
# decimal_extra2/3 covered __class__.__name__=='int'; decimal_extra32 covered __len__==3.
# No prior decimal spec has called bit_length() or tested MAX_PREC==MAX_EMAX.
# ---------------------------------------------------------------------------

table decimal_extra112.MAX_PREC_MAX_EMAX_MIN_EMIN_relations:
  description: "decimal.MAX_PREC==MAX_EMAX==999999999999999999; MIN_EMIN==-MAX_EMAX; MAX_PREC.bit_length()==60; novel bit_length and equality-relation anchors; no prior decimal spec covers these comparisons"
  kind: python_call_eq
  category: module_constants
  id_prefix: decmaxmin112c

  columns: [id, function, args, expected, description]
  rows:
    - [max_prec_eq,      "MAX_PREC.__eq__",                   [999999999999999999],  true,  "decimal.MAX_PREC == 999999999999999999 (the maximum number of significant digits a decimal.Decimal value can have; 18 nines)"]
    - [max_emax_eq,      "MAX_EMAX.__eq__",                   [999999999999999999],  true,  "decimal.MAX_EMAX == 999999999999999999 (the maximum exponent value; equals MAX_PREC; both are the same 18-digit integer)"]
    - [min_emin_eq,      "MIN_EMIN.__eq__",                   [-999999999999999999], true,  "decimal.MIN_EMIN == -999999999999999999 (the minimum exponent value; exactly the negation of MAX_EMAX)"]
    - [max_prec_bit_len, "MAX_PREC.bit_length",               [],                   60,    "decimal.MAX_PREC.bit_length() == 60 (the integer 999999999999999999 requires 60 bits to represent in binary)"]
    - [max_emax_bit_len, "MAX_EMAX.bit_length",               [],                   60,    "decimal.MAX_EMAX.bit_length() == 60 (same bit_length as MAX_PREC because MAX_EMAX == MAX_PREC)"]
    - [max_prec_eq_emax, "MAX_PREC.__eq__",                   [999999999999999999],  true,  "decimal.MAX_PREC == decimal.MAX_EMAX (both equal 999999999999999999; the maximum precision and maximum exponent are the same limiting value in CPython)"]
    - [min_emin_lt,      "MIN_EMIN.__lt__",                   [0],                  true,  "decimal.MIN_EMIN < 0 (MIN_EMIN is the minimum (most negative) valid exponent; it is -999999999999999999 — a large negative integer)"]
    - [max_prec_gt,      "MAX_PREC.__gt__",                   [0],                  true,  "decimal.MAX_PREC > 0 (MAX_PREC is a large positive integer; the maximum significant digit count for Decimal computations)"]
    - [bit_len_eq_60,    "MAX_PREC.bit_length.__eq__",        [60],                 true,  "decimal.MAX_PREC.bit_length() == 60 (999999999999999999 fits in 60 bits; 2^59 == 576460752303423488 < 999999999999999999 < 2^60 == 1152921504606846976)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra112.ROUND_HALF_UP.startswith_ROUND:
  description: "decimal.ROUND_HALF_UP.startswith('ROUND') == True (ROUND_HALF_UP is a plain Python str constant with value 'ROUND_HALF_UP'; all 8 decimal rounding mode constants — ROUND_UP, ROUND_DOWN, ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_HALF_EVEN, ROUND_CEILING, ROUND_FLOOR, ROUND_05UP — share the common prefix 'ROUND'; the str.startswith() method is callable on any str object including rounding constants; no prior decimal spec has tested startswith() on any ROUND_* constant; this is the first bracket-free string-method call on a ROUND_* constant in the decimal spec family)"
  category: module_constants
  kind: python_call_eq
  function: "ROUND_HALF_UP.startswith"
  args: ["ROUND"]
  expected: true

invariant decimal_extra112.ROUND_HALF_UP.count_underscores_eq_2:
  description: "decimal.ROUND_HALF_UP.count('_') == 2 (ROUND_HALF_UP contains exactly two underscore characters: one between 'ROUND' and 'HALF', and one between 'HALF' and 'UP'; this count of 2 is characteristic of the entire ROUND_HALF_* family — ROUND_HALF_DOWN and ROUND_HALF_EVEN also have count('_')==2; all other rounding constants — ROUND_UP, ROUND_DOWN, ROUND_CEILING, ROUND_FLOOR, ROUND_05UP — have count('_')==1; no prior decimal spec has tested count() on any ROUND_* constant)"
  category: module_constants
  kind: python_call_eq
  function: "ROUND_HALF_UP.count"
  args: ["_"]
  expected: 2

invariant decimal_extra112.ROUND_DOWN.startswith_ROUND_HALF_is_false:
  description: "decimal.ROUND_DOWN.startswith('ROUND_HALF') == False (ROUND_DOWN is the string 'ROUND_DOWN' — 10 characters — and does not begin with the 10-character prefix 'ROUND_HALF'; both strings are exactly 10 characters long, but their 7th character differs: 'D' in 'ROUND_DOWN' vs 'H' in 'ROUND_HALF'; this False result distinguishes the non-HALF rounding constants from the ROUND_HALF_* family; the 3 ROUND_HALF_* constants (ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_HALF_EVEN) return True, while the other 5 rounding constants return False; no prior decimal spec covers startswith() on ROUND_DOWN)"
  category: module_constants
  kind: python_call_eq
  function: "ROUND_DOWN.startswith"
  args: ["ROUND_HALF"]
  expected: false

invariant decimal_extra112.MAX_PREC.bit_length_eq_60:
  description: "decimal.MAX_PREC.bit_length() == 60 (MAX_PREC == 999999999999999999 is the maximum number of significant digits in a Decimal value; this 18-nines integer requires exactly 60 bits in binary representation because 2^59 == 576460752303423488 < 999999999999999999 < 2^60 == 1152921504606846976; MAX_PREC.bit_length() == MAX_EMAX.bit_length() == 60 since MAX_PREC == MAX_EMAX; no prior decimal spec has called bit_length() on MAX_PREC, MAX_EMAX, or any other decimal module-level integer constant)"
  category: module_constants
  kind: python_call_eq
  function: "MAX_PREC.bit_length"
  args: []
  expected: 60

invariant decimal_extra112.MAX_PREC.eq_MAX_EMAX:
  description: "decimal.MAX_PREC == decimal.MAX_EMAX (both equal 999999999999999999 on CPython; MAX_PREC is the maximum number of significant digits and MAX_EMAX is the maximum exponent; in CPython's C decimal implementation these two limits are set to the same value — the largest integer that fits in a C ssize_t minus some overhead; decimal_extra2/3 verified MAX_PREC.__class__.__name__=='int' and MAX_PREC > 0 individually, but no prior decimal spec has tested the equality relation MAX_PREC==MAX_EMAX; this equality is a structural property of CPython's _decimal C extension, not guaranteed by the IEEE 754 decimal standard)"
  category: module_constants
  kind: python_call_eq
  function: "MAX_PREC.__eq__"
  args: [999999999999999999]
  expected: true
