spec: re_extra214
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers re module-level functions and constants"
    - "re_extra213.zspec.zsdl — covers re.error.__dict__ membership and re flag constant class names"
  notes:
    - "re.Pattern.__qualname__ == 'Pattern'; confirmed Python 3.14.3 macOS."
    - "re.Match.__qualname__ == 'Match'; confirmed Python 3.14.3 macOS."
    - "re.error.__qualname__ == 'PatternError' on Python 3.13+; re.error was renamed to PatternError in Python 3.13."
    - "re.RegexFlag.__qualname__ == 'RegexFlag'; confirmed Python 3.14.3 macOS."
    - "re.IGNORECASE.__class__.__qualname__ == 'RegexFlag'; IGNORECASE is an instance of the RegexFlag IntFlag enum; confirmed Python 3.14.3 macOS."
    - "__qualname__ is a plain str attribute; __qualname__.__class__.__name__ == 'str' for all re classes."
    - "re.error is an alias for re.PatternError since Python 3.13; the __qualname__ reflects the canonical name 'PatternError'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __qualname__ equality for re.Pattern, re.Match, re.RegexFlag
# Core re type objects and their __qualname__ attribute checks
# ---------------------------------------------------------------------------

table re_extra214.core_types_qualname:
  description: "re.Pattern, re.Match, re.RegexFlag __qualname__ attributes equal their class names"
  kind: python_call_eq
  category: class_metadata
  id_prefix: requalname214

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_qualname,      re.Pattern.__qualname__.__eq__,   ["Pattern"],   true,  "re.Pattern.__qualname__.__eq__('Pattern') == True; Pattern is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [match_qualname,        re.Match.__qualname__.__eq__,     ["Match"],     true,  "re.Match.__qualname__.__eq__('Match') == True; Match is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [regexflag_qualname,    re.RegexFlag.__qualname__.__eq__,  ["RegexFlag"],  true,  "re.RegexFlag.__qualname__.__eq__('RegexFlag') == True; RegexFlag is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [pattern_qualname_false, re.Pattern.__qualname__.__eq__,  ["re.Pattern"], false, "re.Pattern.__qualname__.__eq__('re.Pattern') == False; qualname does not include the module prefix; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.error __qualname__ — renamed to PatternError in Python 3.13+
# re.error.__qualname__ == 'PatternError' on Python 3.13+ (confirmed 3.14.3)
# ---------------------------------------------------------------------------

table re_extra214.error_qualname:
  description: "re.error.__qualname__ reflects the canonical class name PatternError (Python 3.13+)"
  kind: python_call_eq
  category: class_metadata
  id_prefix: requalname214

  columns: [id, function, args, expected, description]
  rows:
    - [error_qualname_patternerror,  re.error.__qualname__.__eq__,  ["PatternError"],  true,   "re.error.__qualname__.__eq__('PatternError') == True; re.error was renamed to PatternError in Python 3.13; confirmed Python 3.14.3 macOS"]
    - [error_qualname_not_error,     re.error.__qualname__.__eq__,  ["error"],         false,  "re.error.__qualname__.__eq__('error') == False; qualname reflects the canonical name PatternError not the alias 'error'; confirmed Python 3.14.3 macOS"]
    - [error_qualname_not_reerror,   re.error.__qualname__.__eq__,  ["re.error"],      false,  "re.error.__qualname__.__eq__('re.error') == False; qualname does not include module prefix; confirmed Python 3.14.3 macOS"]
    - [error_qualname_type,          re.error.__qualname__.__class__.__name__,  [],    "str",  "re.error.__qualname__.__class__.__name__ == 'str'; __qualname__ is a plain str on re.error; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re flag instance __class__.__qualname__ checks
# IGNORECASE, MULTILINE, DOTALL, UNICODE instances have __class__.__qualname__ == 'RegexFlag'
# ---------------------------------------------------------------------------

table re_extra214.flag_instance_class_qualname:
  description: "re flag constant instances have __class__.__qualname__ == 'RegexFlag'"
  kind: python_call_eq
  category: class_metadata
  id_prefix: requalname214

  columns: [id, function, args, expected, description]
  rows:
    - [ignorecase_class_qualname,  re.IGNORECASE.__class__.__qualname__.__eq__,  ["RegexFlag"],  true,  "re.IGNORECASE.__class__.__qualname__.__eq__('RegexFlag') == True; IGNORECASE instance __class__.__qualname__ is 'RegexFlag'; confirmed Python 3.14.3 macOS"]
    - [multiline_class_qualname,   re.MULTILINE.__class__.__qualname__.__eq__,   ["RegexFlag"],  true,  "re.MULTILINE.__class__.__qualname__.__eq__('RegexFlag') == True; MULTILINE instance __class__.__qualname__ is 'RegexFlag'; confirmed Python 3.14.3 macOS"]
    - [dotall_class_qualname,      re.DOTALL.__class__.__qualname__.__eq__,      ["RegexFlag"],  true,  "re.DOTALL.__class__.__qualname__.__eq__('RegexFlag') == True; DOTALL instance __class__.__qualname__ is 'RegexFlag'; confirmed Python 3.14.3 macOS"]
    - [unicode_class_qualname,     re.UNICODE.__class__.__qualname__.__eq__,     ["RegexFlag"],  true,  "re.UNICODE.__class__.__qualname__.__eq__('RegexFlag') == True; UNICODE instance __class__.__qualname__ is 'RegexFlag'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra214.pattern_qualname:
  description: "re.Pattern.__qualname__.__eq__('Pattern') == True — Pattern is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: re.Pattern.__qualname__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra214.match_qualname:
  description: "re.Match.__qualname__.__eq__('Match') == True — Match is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: re.Match.__qualname__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra214.error_qualname_patternerror:
  description: "re.error.__qualname__.__eq__('PatternError') == True — re.error was renamed to PatternError in Python 3.13; __qualname__ reflects the canonical name; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: re.error.__qualname__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra214.regexflag_qualname:
  description: "re.RegexFlag.__qualname__.__eq__('RegexFlag') == True — RegexFlag is a top-level IntFlag enum class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: re.RegexFlag.__qualname__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra214.ignorecase_class_qualname:
  description: "re.IGNORECASE.__class__.__qualname__.__eq__('RegexFlag') == True — IGNORECASE is an instance of the RegexFlag IntFlag enum; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: re.IGNORECASE.__class__.__qualname__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra214.pattern_qualname_type:
  description: "re.Pattern.__qualname__.__class__.__name__ == 'str' — __qualname__ is a plain str attribute on Pattern; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: re.Pattern.__qualname__.__class__.__name__
  args: []
  expected: "str"

invariant re_extra214.error_qualname_not_error_alias:
  description: "re.error.__qualname__.__eq__('error') == False — qualname reflects canonical name PatternError not the backward-compat alias 'error'; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: re.error.__qualname__.__eq__
  args: ["error"]
  expected: false

invariant re_extra214.regexflag_qualname_type:
  description: "re.RegexFlag.__qualname__.__class__.__name__ == 'str' — __qualname__ is a plain str attribute on RegexFlag; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: re.RegexFlag.__qualname__.__class__.__name__
  args: []
  expected: "str"

