spec: roman_numerals
version: ">=0.3.0"
backend: node(roman-numerals)

docs: https://www.npmjs.com/package/roman-numerals

provenance:
  derived_from:
    - "roman-numerals README — https://www.npmjs.com/package/roman-numerals"
    - "Test vectors verified with roman-numerals via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "roman-numerals source"
  notes:
    - "roman-numerals is an npm package. Install: npm install roman-numerals"
    - "toRoman(n) converts an integer to a Roman numeral string."
    - "toArabic(str) converts a Roman numeral string to an integer."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns Roman numeral string or integer."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table roman_numerals.toRoman:
  kind: node_module_call_eq
  function: toRoman
  category: encode
  id_prefix: rntoro

  columns: [id, args, expected]
  rows:
    - [one,       [1],    "I"]
    - [four,      [4],    "IV"]
    - [fourteen,  [14],   "XIV"]
    - [forty,     [40],   "XL"]
    - [year,      [2024], "MMXXIV"]

table roman_numerals.toArabic:
  kind: node_module_call_eq
  function: toArabic
  category: decode
  id_prefix: rntoar

  columns: [id, args, expected]
  rows:
    - [iv,     ["IV"],     4]
    - [xiv,    ["XIV"],    14]
    - [xl,     ["XL"],     40]
    - [mmxxiv, ["MMXXIV"], 2024]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:23:05Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
