spec: socket_extra126
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra99.zspec.zsdl — covers socket module function __qualname__.__len__() / SocketIO class identity (ABCMeta metaclass / RawIOBase base / __module__=='socket') (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket method __qualname__.__len__() values for connect/bind/listen/send/recv and __init__/accept/close/makefile (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__[0].__name__=='IntEnum' / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout builtin / getaddrinfo/create_connection Python function (table + invariants)."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length (table + invariants)."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names (table + invariants)."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names for bind/connect/recv/send (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra99."
    - "Wave 286 theme: socket.socket class hierarchy identity — __name__/__module__/__qualname__ equality / __bases__[0].__name__ equality / __mro__.__len__() / __class__.__name__ equality / socket.error and socket.timeout alias identity."
    - "socket.socket.__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__qualname__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__bases__[0].__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__mro__.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__name__ == 'TimeoutError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__bases__[0].__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket.__bases__[0].__name__ is 'socket' (not 'object'). The Python-level socket.socket inherits from _socket.socket (the C-extension class). Both classes are named 'socket' — the Python wrapper and the C base class."
    - "Note: socket.socket.__mro__ is (socket.socket, _socket.socket, object) — 3 entries (not 2). The C-extension _socket.socket is in between the Python wrapper and object."
    - "Note: socket.error is OSError (not a socket-specific class). socket.error is OSError. socket.error.__name__ is 'OSError', __module__ is 'builtins'."
    - "Note: socket.timeout is TimeoutError (a builtin). socket.timeout.__bases__[0].__name__ is 'OSError' (TimeoutError directly subclasses OSError, not socket.error)."
    - "Note: socket.socket.__qualname__ is 'socket' (6 chars) — same as __name__. The class name in both __name__ and __qualname__ is just 'socket', even though it lives in the 'socket' module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__name__.__eq__('socket')
# socket.socket.__module__.__eq__('socket')
# socket.socket.__qualname__.__eq__('socket')
# socket.socket.__bases__[0].__name__.__eq__('socket')
# socket.socket.__mro__.__len__()==3
# socket.socket.__class__.__name__.__eq__('type')
#
# Wave 286 theme: socket.socket class identity.
#
# socket.socket is the Python-level wrapper class for network sockets. Its __name__
# and __qualname__ are both 'socket' (same as the module name). Its single base
# class is _socket.socket (the C-extension class), also named 'socket', so
# __bases__[0].__name__ is 'socket'. The MRO has 3 entries:
# (socket.socket, _socket.socket, object). No prior socket spec anchors
# socket.socket.__name__/__module__/__qualname__ equality or __mro__.__len__()==3
# under sockhier126. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra126.socket_class_identity:
  description: "socket.socket/__name__.__eq__('socket')==True / socket.socket/__module__.__eq__('socket')==True / socket.socket/__qualname__.__eq__('socket')==True / socket.socket/__bases__[0]/__name__.__eq__('socket')==True / socket.socket/__mro__/__len__()==3 / socket.socket/__class__.__name__.__eq__('type')==True — Python-level socket wrapper; __bases__[0] is _socket.socket (also named 'socket'); MRO has 3 entries; no prior socket spec anchors these; first sockhier126 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockhier126

  columns: [id, function, args, expected, description]
  rows:
    - [socket_name_eq,    "socket.__name__.__eq__",              ["socket"],  true, "socket.socket.__name__ is 'socket' (same as module name; Python-level wrapper class)"]
    - [socket_module_eq,  "socket.__module__.__eq__",            ["socket"],  true, "socket.socket.__module__ is 'socket' (defined in Lib/socket.py, not socketmodule.c)"]
    - [socket_qname_eq,   "socket.__qualname__.__eq__",          ["socket"],  true, "socket.socket.__qualname__ is 'socket' (6 chars; same as __name__; no enclosing scope)"]
    - [socket_base_name,  "socket.__bases__[0].__name__.__eq__", ["socket"],  true, "socket.socket.__bases__[0].__name__ is 'socket' (inherits from _socket.socket, the C base)"]
    - [socket_mro_len,    "socket.__mro__.__len__",              [],          3,    "socket.socket.__mro__ has 3 entries: (socket.socket, _socket.socket, object)"]
    - [socket_class_type, "socket.__class__.__name__.__eq__",    ["type"],    true, "socket.socket.__class__.__name__ is 'type' (it is a class; metaclass is 'type')"]

# ---------------------------------------------------------------------------
# socket.error.__name__.__eq__('OSError')
# socket.error.__module__.__eq__('builtins')
# socket.error.__bases__[0].__name__.__eq__('Exception')
#
# Wave 286 theme: socket.error alias identity.
#
# socket.error is an alias for the builtin OSError (since Python 3.3). It is
# not a socket-specific class but the standard builtin OSError. Thus
# socket.error.__name__ is 'OSError' (not 'error'), __module__ is 'builtins',
# and __bases__[0].__name__ is 'Exception'. socket_extra93 covers socket-level
# method_descriptor class names; no prior socket spec anchors socket.error
# identity (as OSError alias) under sockhier126. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra126.socket_error_alias_identity:
  description: "socket.error/__name__.__eq__('OSError')==True / socket.error/__module__.__eq__('builtins')==True / socket.error/__bases__[0]/__name__.__eq__('Exception')==True — socket.error is an alias for builtin OSError (since Python 3.3); __name__=='OSError', __module__=='builtins'; direct base is Exception; no prior socket spec anchors socket.error identity as OSError alias; first sockhier126 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockhier126

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_eq,    "error.__name__.__eq__",              ["OSError"],   true, "socket.error is OSError alias; __name__ is 'OSError' (not 'error' or 'socket.error')"]
    - [error_module_eq,  "error.__module__.__eq__",            ["builtins"],  true, "socket.error.__module__ is 'builtins' (OSError is a builtin exception, not from socket)"]
    - [error_base_name,  "error.__bases__[0].__name__.__eq__", ["Exception"], true, "socket.error (OSError).__bases__[0].__name__ is 'Exception' (OSError directly subclasses Exception)"]

# ---------------------------------------------------------------------------
# socket.timeout.__name__.__eq__('TimeoutError')
# socket.timeout.__module__.__eq__('builtins')
# socket.timeout.__bases__[0].__name__.__eq__('OSError')
# socket.socket.__qualname__.__len__()==6
# socket.socket.__name__.__len__()==6
#
# Wave 286 theme: socket.timeout alias identity and socket.socket name lengths.
#
# socket.timeout is an alias for the builtin TimeoutError (since Python 3.3).
# TimeoutError directly subclasses OSError, so socket.timeout.__bases__[0].__name__
# is 'OSError'. socket.socket.__qualname__ and __name__ are both 'socket' (6 chars).
# No prior socket spec anchors socket.timeout identity or socket.socket name lengths
# under sockhier126. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra126.socket_timeout_and_name_lengths:
  description: "socket.timeout/__name__.__eq__('TimeoutError')==True / socket.timeout/__module__.__eq__('builtins')==True / socket.timeout/__bases__[0]/__name__.__eq__('OSError')==True / socket.socket/__qualname__/__len__()==6 / socket.socket/__name__/__len__()==6 — socket.timeout is TimeoutError alias; socket.socket qualname and name are both 6 chars ('socket'); no prior socket spec anchors these; first sockhier126 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockhier126

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_name_eq,   "timeout.__name__.__eq__",              ["TimeoutError"], true, "socket.timeout is TimeoutError alias; __name__ is 'TimeoutError' (not 'timeout')"]
    - [timeout_module_eq, "timeout.__module__.__eq__",            ["builtins"],     true, "socket.timeout.__module__ is 'builtins' (TimeoutError is a builtin exception)"]
    - [timeout_base_name, "timeout.__bases__[0].__name__.__eq__", ["OSError"],      true, "socket.timeout (TimeoutError).__bases__[0].__name__ is 'OSError' (TimeoutError subclasses OSError)"]
    - [socket_qname_len,  "socket.__qualname__.__len__",          [],               6,    "socket.socket.__qualname__.__len__() is 6 ('socket' is 6 chars)"]
    - [socket_name_len,   "socket.__name__.__len__",              [],               6,    "socket.socket.__name__.__len__() is 6 ('socket' is 6 chars; equals __qualname__ length)"]

# ---------------------------------------------------------------------------
# socket.socket.__name__.__eq__('socket') — standalone
#
# socket.socket.__name__ is 'socket'. The Python-level socket class has the same
# name as the module it lives in. This naming overlap ('socket' module contains
# 'socket' class named 'socket') is intentional — the module and its primary
# class share the name. socket_extra97 anchors socket.socket.__init__
# __class__.__name__; no prior socket spec anchors socket.socket.__name__ equality
# as a standalone under sockhier126. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra126.socket_class_name_eq:
  description: "socket.socket.__name__.__eq__('socket') == True — the socket.socket class name is 'socket', same as its module name; intentional naming overlap in the socket module; no prior socket spec anchors socket.socket.__name__ equality as standalone; first standalone under sockhier126"
  category: type_identity
  kind: python_call_eq
  function: "socket.__name__.__eq__"
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__mro__.__len__()==3 — standalone
#
# socket.socket.__mro__.__len__() is 3. The MRO is (socket.socket, _socket.socket,
# object). Unlike a simple class with no intermediate base (MRO length 2), socket.socket
# has an intermediate C-extension base _socket.socket in its MRO. This extra level
# enables the Python socket wrapper to override C-level methods while delegating
# to the C implementation. No prior socket spec anchors socket.socket.__mro__.__len__()
# as a standalone under sockhier126. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra126.socket_class_mro_len_3:
  description: "socket.socket.__mro__.__len__() == 3 — MRO is (socket.socket, _socket.socket, object); 3 entries because Python socket wrapper sits atop C-extension _socket.socket base; extra level enables Python-level method overrides over C implementation; no prior socket spec anchors this as standalone; first standalone under sockhier126"
  category: type_identity
  kind: python_call_eq
  function: "socket.__mro__.__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# socket.error.__name__.__eq__('OSError') — standalone
#
# socket.error.__name__ is 'OSError'. In Python 3.3+, socket.error was made
# an alias for the builtin OSError as part of the exception hierarchy
# rationalization (PEP 3151). Thus socket.error is not socket-specific: it is
# the same object as builtins.OSError. socket.error.__name__ reflects the true
# canonical name 'OSError', not 'error'. No prior socket spec anchors
# socket.error.__name__.__eq__('OSError') as a standalone under sockhier126.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra126.socket_error_name_OSError:
  description: "socket.error.__name__.__eq__('OSError') == True — socket.error is an alias for builtins.OSError (PEP 3151, Python 3.3+); its canonical __name__ is 'OSError' not 'error'; no prior socket spec anchors socket.error.__name__ as standalone; first standalone under sockhier126"
  category: type_identity
  kind: python_call_eq
  function: "error.__name__.__eq__"
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.timeout.__name__.__eq__('TimeoutError') — standalone
#
# socket.timeout.__name__ is 'TimeoutError'. In Python 3.3+, socket.timeout was
# made an alias for the builtin TimeoutError (PEP 3151). TimeoutError subclasses
# OSError directly (not socket.error). socket.timeout is used when a network
# operation exceeds the configured timeout. socket.timeout.__name__ is
# 'TimeoutError', reflecting the builtin class name, not 'timeout'.
# No prior socket spec anchors socket.timeout.__name__.__eq__('TimeoutError')
# as a standalone under sockhier126. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra126.socket_timeout_name_TimeoutError:
  description: "socket.timeout.__name__.__eq__('TimeoutError') == True — socket.timeout is an alias for builtins.TimeoutError (PEP 3151, Python 3.3+); raised when a network operation exceeds the configured timeout; canonical __name__ is 'TimeoutError' not 'timeout'; no prior socket spec anchors socket.timeout.__name__ as standalone; first standalone under sockhier126"
  category: type_identity
  kind: python_call_eq
  function: "timeout.__name__.__eq__"
  args: ["TimeoutError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__class__.__name__.__eq__('type') — standalone
#
# socket.socket.__class__.__name__ is 'type'. socket.socket is a class (defined
# in Lib/socket.py using the class statement). Its metaclass is the standard
# 'type'. This is distinct from SocketIO whose metaclass is 'ABCMeta' (anchored
# in socket_extra99). socket_extra99 covers SocketIO metaclass; no prior socket
# spec anchors socket.socket.__class__.__name__.__eq__('type') as a standalone
# under sockhier126. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra126.socket_class_metaclass_type:
  description: "socket.socket.__class__.__name__.__eq__('type') == True — socket.socket's metaclass is 'type' (standard metaclass for ordinary Python classes); distinct from SocketIO whose metaclass is 'ABCMeta' (anchored in extra99); no prior socket spec anchors socket.socket.__class__.__name__ as standalone; first standalone under sockhier126"
  category: type_identity
  kind: python_call_eq
  function: "socket.__class__.__name__.__eq__"
  args: ["type"]
  expected: true

