spec: concurrent_futures_extra2386
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec classifies __str__ and __repr__ implementation types for concurrent.futures classes."
    - "concurrent.futures.Future defines a custom Python __repr__; __str__ is inherited from object."
    - "Future.__str__.__class__.__name__ == 'wrapper_descriptor' — inherited slot from object."
    - "Future.__repr__.__class__.__name__ == 'function' — custom Python method defined on Future."
    - "ThreadPoolExecutor does not define __repr__; both __str__ and __repr__ are 'wrapper_descriptor' (inherited from object)."
    - "ProcessPoolExecutor does not define __repr__; both __str__ and __repr__ are 'wrapper_descriptor' (inherited from object)."
    - "Executor does not define __repr__; both __str__ and __repr__ are 'wrapper_descriptor' (inherited from object)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.Future __str__ and __repr__ implementation type
#
# Future is a pure-Python class with a custom __repr__. __str__ is inherited
# from object ('wrapper_descriptor'). __repr__ is 'function'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2386.future_str_repr:
  description: "concurrent.futures.Future __str__ and __repr__ implementation type classification; new to extra2386"
  kind: python_call_eq
  category: str_repr_type
  id_prefix: cf2386

  columns: [id, function, args, expected]
  rows:
    - ["cf2386001",
       Future.__str__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["cf2386002",
       Future.__repr__.__class__.__name__.__eq__,
       ["function"],
       true]
    - ["cf2386003",
       Future.__str__.__class__.__name__.__len__,
       [],
       18]
    - ["cf2386004",
       Future.__repr__.__class__.__name__.__len__,
       [],
       8]
    - ["cf2386005",
       Future.__str__.__class__.__name__.__contains__,
       ["wrapper"],
       true]
    - ["cf2386006",
       Future.__repr__.__class__.__name__.__contains__,
       ["function"],
       true]

