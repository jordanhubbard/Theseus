spec: threading_extra220
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading.Timer, threading.Barrier, threading.local, and threading.excepthook (wave 385)."
    - "Timer.__name__ == 'Timer'; Timer.__module__ == 'threading'. Verified with Python 3.14.3."
    - "Timer.__bases__[0].__name__ == 'Thread' — Timer subclasses Thread. Verified with Python 3.14.3."
    - "Timer.__init__.__code__.co_argcount == 5 — args are (self, interval, function, args, kwargs). Verified with Python 3.14.3."
    - "Barrier.__name__ == 'Barrier'; Barrier.__module__ == 'threading'. Verified with Python 3.14.3."
    - "Barrier.__bases__[0].__name__ == 'object' — Barrier directly subclasses object. Verified with Python 3.14.3."
    - "Barrier.__init__.__code__.co_argcount == 4 — args are (self, parties, action, timeout). Verified with Python 3.14.3."
    - "threading.local.__name__ == '_local'; threading.local.__module__ == '_thread' (C-level type). Verified with Python 3.14.3."
    - "threading.excepthook.__name__ == '_excepthook'; threading.excepthook.__module__ == '_thread' (C-level function). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Timer class identity checks
#
# Timer is a Python class in Lib/threading.py that subclasses Thread.
# It schedules a function to be called after a delay.
#
# Verified with Python 3.14.3:
#   threading.Timer.__name__ == 'Timer'
#   threading.Timer.__module__ == 'threading'
#   threading.Timer.__bases__[0].__name__ == 'Thread'
# ---------------------------------------------------------------------------

table threading_extra220.timer_identity:
  description: "threading.Timer class __name__, __module__, and base class checks; wave 385; new to extra220"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra220timer

  columns: [id, function, args, expected, description]
  rows:
    - [timer_name_eq,
       Timer.__name__.__eq__,
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — Timer is a Thread subclass that runs a function after a delay; its class __name__ is 'Timer'; str.__eq__('Timer') returns True; new to extra220"]
    - [timer_module_eq,
       Timer.__module__.__eq__,
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — Timer is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra220"]
    - [timer_base_name_eq,
       Timer.__bases__.__getitem__(0).__name__.__eq__,
       ["Thread"],
       true,
       "threading.Timer.__bases__.__getitem__(0).__name__.__eq__('Thread') == True — Timer subclasses Thread (the threading.Thread class); its first base class __name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra220"]
    - [timer_name_len,
       Timer.__name__.__len__,
       [],
       5,
       "threading.Timer.__name__.__len__() == 5 — 'Timer' has 5 characters; str.__len__() returns 5; new to extra220"]

# ---------------------------------------------------------------------------
# Table 2: threading.Timer.__init__ code object checks
#
# Timer.__init__ accepts self, interval, function, args, and kwargs —
# five arguments total. co_argcount counts positional parameters (not *args).
#
# Verified with Python 3.14.3:
#   Timer.__init__.__code__.co_argcount == 5
#   Timer.__init__.__code__.co_varnames[:5] == ('self','interval','function','args','kwargs')
# ---------------------------------------------------------------------------

table threading_extra220.timer_init_code:
  description: "threading.Timer.__init__ co_argcount checks; wave 385; new to extra220"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra220timerinit

  columns: [id, function, args, expected, description]
  rows:
    - [timer_init_argcount_5,
       Timer.__init__.__code__.co_argcount.__eq__,
       [5],
       true,
       "threading.Timer.__init__.__code__.co_argcount.__eq__(5) == True — Timer.__init__ takes 5 parameters: self, interval, function, args, kwargs; co_argcount counts positional args; int.__eq__(5) returns True; new to extra220"]
    - [timer_init_argcount_not_4,
       Timer.__init__.__code__.co_argcount.__ne__,
       [4],
       true,
       "threading.Timer.__init__.__code__.co_argcount.__ne__(4) == True — Timer.__init__ has 5 positional args (not 4); it includes kwargs as a parameter; int.__ne__(4) returns True; new to extra220"]

# ---------------------------------------------------------------------------
# Table 3: threading.Barrier class identity checks
#
# Barrier synchronizes a set of threads at a common rendezvous point.
# It directly subclasses object (no intermediate base class).
#
# Verified with Python 3.14.3:
#   threading.Barrier.__name__ == 'Barrier'
#   threading.Barrier.__module__ == 'threading'
#   threading.Barrier.__bases__[0].__name__ == 'object'
#   threading.Barrier.__init__.__code__.co_argcount == 4
# ---------------------------------------------------------------------------

table threading_extra220.barrier_identity:
  description: "threading.Barrier class identity and __init__ co_argcount checks; wave 385; new to extra220"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra220barrier

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_name_eq,
       Barrier.__name__.__eq__,
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — Barrier synchronizes n threads at a rendezvous point; its class __name__ is 'Barrier'; str.__eq__('Barrier') returns True; new to extra220"]
    - [barrier_module_eq,
       Barrier.__module__.__eq__,
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — Barrier is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra220"]
    - [barrier_base_name_eq,
       Barrier.__bases__.__getitem__(0).__name__.__eq__,
       ["object"],
       true,
       "threading.Barrier.__bases__.__getitem__(0).__name__.__eq__('object') == True — Barrier directly subclasses object (unlike Timer which subclasses Thread); its first base class __name__ is 'object'; str.__eq__('object') returns True; new to extra220"]
    - [barrier_init_argcount_4,
       Barrier.__init__.__code__.co_argcount.__eq__,
       [4],
       true,
       "threading.Barrier.__init__.__code__.co_argcount.__eq__(4) == True — Barrier.__init__ takes 4 parameters: self, parties, action, timeout; co_argcount counts positional args; int.__eq__(4) returns True; new to extra220"]

# ---------------------------------------------------------------------------
# Table 4: threading.local and threading.excepthook identity checks
#
# threading.local is actually the C-level _thread._local type re-exported
# from the threading module. Its __name__ is '_local' and __module__ is '_thread'.
#
# threading.excepthook is similarly a C-level function. Its __name__ is
# '_excepthook' and __module__ is '_thread'.
#
# Verified with Python 3.14.3:
#   threading.local.__name__ == '_local'
#   threading.local.__module__ == '_thread'
#   threading.excepthook.__name__ == '_excepthook'
#   threading.excepthook.__module__ == '_thread'
# ---------------------------------------------------------------------------

table threading_extra220.local_excepthook_identity:
  description: "threading.local and threading.excepthook __name__ and __module__ identity checks; wave 385; new to extra220"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra220localexcepthook

  columns: [id, function, args, expected, description]
  rows:
    - [local_name_eq,
       local.__name__.__eq__,
       ["_local"],
       true,
       "threading.local.__name__.__eq__('_local') == True — threading.local is the C-level _thread._local type; its __name__ is '_local' (with leading underscore); str.__eq__('_local') returns True; new to extra220"]
    - [local_module_eq,
       local.__module__.__eq__,
       ["_thread"],
       true,
       "threading.local.__module__.__eq__('_thread') == True — threading.local is implemented in the C-level _thread module (_threadmodule.c); its __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra220"]
    - [excepthook_name_eq,
       excepthook.__name__.__eq__,
       ["_excepthook"],
       true,
       "threading.excepthook.__name__.__eq__('_excepthook') == True — threading.excepthook is the C-level _thread._excepthook function; its __name__ is '_excepthook' (with leading underscore); str.__eq__('_excepthook') returns True; new to extra220"]
    - [excepthook_module_eq,
       excepthook.__module__.__eq__,
       ["_thread"],
       true,
       "threading.excepthook.__module__.__eq__('_thread') == True — threading.excepthook is implemented in the C-level _thread module; its __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra220"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra220
# ---------------------------------------------------------------------------

invariant threading_extra220.timer_name:
  description: "threading.Timer.__name__.__eq__('Timer') == True; wave 385; new to extra220"
  kind: python_call_eq
  function: Timer.__name__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra220.timer_module:
  description: "threading.Timer.__module__.__eq__('threading') == True; wave 385; new to extra220"
  kind: python_call_eq
  function: Timer.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra220.timer_base_thread:
  description: "threading.Timer.__bases__.__getitem__(0).__name__.__eq__('Thread') == True; wave 385; new to extra220"
  kind: python_call_eq
  function: Timer.__bases__.__getitem__(0).__name__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra220.timer_init_argcount:
  description: "threading.Timer.__init__.__code__.co_argcount.__eq__(5) == True — 5 params: self, interval, function, args, kwargs; wave 385; new to extra220"
  kind: python_call_eq
  function: Timer.__init__.__code__.co_argcount.__eq__
  args: [5]
  expected: true

invariant threading_extra220.barrier_name:
  description: "threading.Barrier.__name__.__eq__('Barrier') == True; wave 385; new to extra220"
  kind: python_call_eq
  function: Barrier.__name__.__eq__
  args: ["Barrier"]
  expected: true

invariant threading_extra220.barrier_module:
  description: "threading.Barrier.__module__.__eq__('threading') == True; wave 385; new to extra220"
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra220.barrier_base_object:
  description: "threading.Barrier.__bases__.__getitem__(0).__name__.__eq__('object') == True; wave 385; new to extra220"
  kind: python_call_eq
  function: Barrier.__bases__.__getitem__(0).__name__.__eq__
  args: ["object"]
  expected: true

invariant threading_extra220.barrier_init_argcount:
  description: "threading.Barrier.__init__.__code__.co_argcount.__eq__(4) == True — 4 params: self, parties, action, timeout; wave 385; new to extra220"
  kind: python_call_eq
  function: Barrier.__init__.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant threading_extra220.local_name:
  description: "threading.local.__name__.__eq__('_local') == True — C-level type with leading underscore; wave 385; new to extra220"
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra220.local_module:
  description: "threading.local.__module__.__eq__('_thread') == True — C-level _thread module; wave 385; new to extra220"
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra220.excepthook_name:
  description: "threading.excepthook.__name__.__eq__('_excepthook') == True — C-level function with leading underscore; wave 385; new to extra220"
  kind: python_call_eq
  function: excepthook.__name__.__eq__
  args: ["_excepthook"]
  expected: true

invariant threading_extra220.excepthook_module:
  description: "threading.excepthook.__module__.__eq__('_thread') == True — C-level _thread module; wave 385; new to extra220"
  kind: python_call_eq
  function: excepthook.__module__.__eq__
  args: ["_thread"]
  expected: true
