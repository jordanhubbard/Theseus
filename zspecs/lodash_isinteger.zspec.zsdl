spec: lodash_isinteger
version: ">=4.0.0"
backend: node(lodash.isinteger)

docs: https://lodash.com/docs/#isInteger

provenance:
  derived_from:
    - "lodash.isinteger README — https://www.npmjs.com/package/lodash.isinteger"
    - "Test vectors verified with lodash.isinteger@4.0.4 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.isinteger exports the _.isInteger function directly as module.exports."
    - "isInteger checks if value is an integer (no fractional part)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_isinteger.isinteger:
  kind: node_module_call_eq
  function: ~
  category: isinteger
  id_prefix: lisi

  columns: [id, args, expected]
  rows:
    - [yes_int,  [1],      true]
    - [zero,     [0],      true]
    - [neg,      [-5],     true]
    - [float,    [1.5],    false]
    - [string,   ["1"],    false]

