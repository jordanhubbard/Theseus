spec: itertools_extra240
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools_extra239.zspec.zsdl — covers prior itertools identity specs"
  notes:
    - "This spec covers itertools.combinations and itertools.combinations_with_replacement class identity contracts."
    - "itertools.combinations.__name__ == 'combinations' (len=12) — combinations is a C class in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.combinations.__module__ == 'itertools' (len=9) — combinations is exposed via the itertools module. Verified with Python 3.14.3."
    - "itertools.combinations.__bases__[0].__name__ == 'object' — combinations inherits directly from object. Verified with Python 3.14.3."
    - "itertools.combinations.__class__.__name__ == 'type' — combinations is a class; its metaclass is type. Verified with Python 3.14.3."
    - "itertools.combinations.__qualname__ == 'combinations' (len=12) — same as __name__ for top-level class. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' (len=29) — long name. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__module__ == 'itertools' (len=9). Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement' (len=29). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.combinations identity contracts
#
# itertools.combinations.__name__ == 'combinations' (len=12)
# itertools.combinations.__module__ == 'itertools' (len=9)
# itertools.combinations.__bases__[0].__name__ == 'object'
# itertools.combinations.__class__.__name__ == 'type'
# itertools.combinations.__qualname__ == 'combinations' (len=12)
#
# combinations is a C class in itertoolsmodule.c. New to extra240.
# ---------------------------------------------------------------------------

table itertools_extra240.combs240_identity:
  description: "itertools.combinations identity: name, module, bases, class, qualname; new to extra240"
  kind: python_call_eq
  category: identity
  id_prefix: combs240

  columns: [id, function, args, expected, description]
  rows:
    - [combs_name_eq,
       combinations.__name__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — combinations is a C class in itertoolsmodule.c; __name__ is 'combinations' (len=12); new to extra240"]
    - [combs_name_len_12,
       combinations.__name__.__len__,
       [],
       12,
       "itertools.combinations.__name__.__len__() == 12 — 'combinations' has exactly 12 characters; str.__len__() returns 12; new to extra240"]
    - [combs_module_eq,
       combinations.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.combinations.__module__.__eq__('itertools') == True — combinations is exposed via the itertools module; __module__ is 'itertools' (len=9); new to extra240"]
    - [combs_module_len_9,
       combinations.__module__.__len__,
       [],
       9,
       "itertools.combinations.__module__.__len__() == 9 — 'itertools' has exactly 9 characters; str.__len__() returns 9; new to extra240"]
    - [combs_bases_0_is_object,
       "combinations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations.__bases__[0].__name__.__eq__('object') == True — combinations inherits directly from object; __bases__[0] is object; new to extra240"]

# ---------------------------------------------------------------------------
# Table 2: itertools.combinations class and qualname contracts
#
# itertools.combinations.__class__.__name__ == 'type'
# itertools.combinations.__qualname__ == 'combinations' (len=12)
# itertools.combinations.__doc__ contains 'iterable' == True
#
# New to extra240.
# ---------------------------------------------------------------------------

table itertools_extra240.combs240_class:
  description: "itertools.combinations class, qualname, doc checks; new to extra240"
  kind: python_call_eq
  category: identity
  id_prefix: combs240cls

  columns: [id, function, args, expected, description]
  rows:
    - [combs_class_is_type,
       combinations.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.combinations.__class__.__name__.__eq__('type') == True — combinations is a class; its metaclass is the built-in type; new to extra240"]
    - [combs_qualname_eq,
       combinations.__qualname__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__qualname__.__eq__('combinations') == True — __qualname__ is 'combinations' (len=12); same as __name__ for top-level class; new to extra240"]
    - [combs_qualname_len_12,
       combinations.__qualname__.__len__,
       [],
       12,
       "itertools.combinations.__qualname__.__len__() == 12 — 'combinations' has exactly 12 characters; str.__len__() returns 12; new to extra240"]
    - [combs_doc_contains_iterable,
       combinations.__doc__.__contains__,
       ["iterable"],
       true,
       "itertools.combinations.__doc__.__contains__('iterable') == True — docstring says 'Return successive r-length combinations of elements in the iterable'; new to extra240"]
    - [combs_module_contains_itertools,
       combinations.__module__.__contains__,
       ["itertools"],
       true,
       "itertools.combinations.__module__.__contains__('itertools') == True — 'itertools' contains the substring 'itertools'; new to extra240"]

# ---------------------------------------------------------------------------
# Table 3: itertools.combinations_with_replacement identity contracts
#
# itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' (len=29)
# itertools.combinations_with_replacement.__module__ == 'itertools' (len=9)
# itertools.combinations_with_replacement.__bases__[0].__name__ == 'object'
# itertools.combinations_with_replacement.__class__.__name__ == 'type'
# itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement' (len=29)
#
# combinations_with_replacement is a C class in itertoolsmodule.c. New to extra240.
# ---------------------------------------------------------------------------

table itertools_extra240.combsr240_identity:
  description: "itertools.combinations_with_replacement identity: name, module, bases, class, qualname; new to extra240"
  kind: python_call_eq
  category: identity
  id_prefix: combsr240

  columns: [id, function, args, expected, description]
  rows:
    - [combsr_name_eq,
       combinations_with_replacement.__name__.__eq__,
       ["combinations_with_replacement"],
       true,
       "itertools.combinations_with_replacement.__name__.__eq__('combinations_with_replacement') == True — cwr is a C class in itertoolsmodule.c; __name__ is 'combinations_with_replacement' (len=29); new to extra240"]
    - [combsr_name_len_29,
       combinations_with_replacement.__name__.__len__,
       [],
       29,
       "itertools.combinations_with_replacement.__name__.__len__() == 29 — 'combinations_with_replacement' has exactly 29 characters; str.__len__() returns 29; new to extra240"]
    - [combsr_module_eq,
       combinations_with_replacement.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.combinations_with_replacement.__module__.__eq__('itertools') == True — cwr is exposed via the itertools module; __module__ is 'itertools' (len=9); new to extra240"]
    - [combsr_module_len_9,
       combinations_with_replacement.__module__.__len__,
       [],
       9,
       "itertools.combinations_with_replacement.__module__.__len__() == 9 — 'itertools' has exactly 9 characters; str.__len__() returns 9; new to extra240"]
    - [combsr_bases_0_is_object,
       "combinations_with_replacement.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations_with_replacement.__bases__[0].__name__.__eq__('object') == True — cwr inherits directly from object; __bases__[0] is object; new to extra240"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra240
# ---------------------------------------------------------------------------

invariant itertools_extra240.combs_name_eq:
  description: "itertools.combinations.__name__ == 'combinations' (len=12); new to extra240"
  kind: python_call_eq
  function: combinations.__name__.__eq__
  args: ["combinations"]
  expected: true

invariant itertools_extra240.combs_name_len_12:
  description: "itertools.combinations.__name__.__len__() == 12 — 'combinations' has 12 characters; new to extra240"
  kind: python_call_eq
  function: combinations.__name__.__len__
  args: []
  expected: 12

invariant itertools_extra240.combs_module_eq:
  description: "itertools.combinations.__module__ == 'itertools' — C class exposed via itertools; new to extra240"
  kind: python_call_eq
  function: combinations.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra240.combs_module_len_9:
  description: "itertools.combinations.__module__.__len__() == 9 — 'itertools' has 9 characters; new to extra240"
  kind: python_call_eq
  function: combinations.__module__.__len__
  args: []
  expected: 9

invariant itertools_extra240.combs_bases_0_is_object:
  description: "itertools.combinations.__bases__[0].__name__ == 'object'; new to extra240"
  kind: python_call_eq
  function: "combinations.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra240.combs_class_is_type:
  description: "itertools.combinations.__class__.__name__ == 'type'; new to extra240"
  kind: python_call_eq
  function: combinations.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra240.combs_qualname_eq:
  description: "itertools.combinations.__qualname__ == 'combinations' (len=12); new to extra240"
  kind: python_call_eq
  function: combinations.__qualname__.__eq__
  args: ["combinations"]
  expected: true

invariant itertools_extra240.combsr_name_eq:
  description: "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' (len=29); new to extra240"
  kind: python_call_eq
  function: combinations_with_replacement.__name__.__eq__
  args: ["combinations_with_replacement"]
  expected: true

invariant itertools_extra240.combsr_name_len_29:
  description: "itertools.combinations_with_replacement.__name__.__len__() == 29 — 'combinations_with_replacement' has 29 characters; new to extra240"
  kind: python_call_eq
  function: combinations_with_replacement.__name__.__len__
  args: []
  expected: 29

invariant itertools_extra240.combsr_module_eq:
  description: "itertools.combinations_with_replacement.__module__ == 'itertools'; new to extra240"
  kind: python_call_eq
  function: combinations_with_replacement.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra240.combsr_module_len_9:
  description: "itertools.combinations_with_replacement.__module__.__len__() == 9 — 'itertools' has 9 characters; new to extra240"
  kind: python_call_eq
  function: combinations_with_replacement.__module__.__len__
  args: []
  expected: 9

invariant itertools_extra240.combsr_bases_0_is_object:
  description: "itertools.combinations_with_replacement.__bases__[0].__name__ == 'object'; new to extra240"
  kind: python_call_eq
  function: "combinations_with_replacement.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra240.combsr_class_is_type:
  description: "itertools.combinations_with_replacement.__class__.__name__ == 'type'; new to extra240"
  kind: python_call_eq
  function: combinations_with_replacement.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra240.combsr_qualname_eq:
  description: "itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement' (len=29); new to extra240"
  kind: python_call_eq
