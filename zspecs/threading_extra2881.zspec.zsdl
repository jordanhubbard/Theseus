spec: th2881
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 639 (th2881): __iadd__, __isub__, __imul__ dict-presence checks for threading types."
    - "threading types are synchronization primitives and thread management classes — none define in-place add, subtract, or multiply operators."
    - "Verified types: threading.Thread, threading.Lock (type), threading.RLock (type), threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Event, threading.Timer, threading.Barrier, threading.local."
    - "threading.Lock and threading.RLock are factory functions; their types are accessed via type(threading.Lock()) and type(threading.RLock())."
    - "threading.Timer is a Thread subclass used for delayed execution."
    - "threading.local is the thread-local storage class."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th2881.iadd:
  description: "threading types __iadd__ dict-presence checks; wave 639"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2881
  columns: [id, function, args, expected]
  rows:
    - ["th2881001", operator.contains, [threading.Thread.__dict__,           "__iadd__"], false]
    - ["th2881002", operator.contains, [threading.Condition.__dict__,        "__iadd__"], false]
    - ["th2881003", operator.contains, [threading.Semaphore.__dict__,        "__iadd__"], false]
