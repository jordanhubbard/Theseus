spec: socket_extra142
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra141.zspec.zsdl — covers socket.socket/__doc__/__len__()==58 / gethostname/__doc__/__len__()==54 / gethostbyname/__doc__/__len__()==106 / getaddrinfo/__doc__/__len__()==658 / setdefaulttimeout/__doc__/__len__()==224 / getdefaulttimeout/__doc__/__len__()==232 / __doc__.__class__.__name__ checks (table + invariants)."
    - "socket_extra140.zspec.zsdl — covers socket.socket method_descriptor __doc__ lengths (recv/send/bind/connect/listen/setsockopt/getsockopt/sendall/recvfrom/accept) / socket.socket method __qualname__ lengths."
    - "socket_extra139.zspec.zsdl — covers socket.socket.__eq__/__hash__ qualnames / socket.socket.family and type as property descriptors / socket.socket class __name__/__module__/__mro__ / socket.getfqdn and create_connection __doc__ lengths."
    - "socket_extra138.zspec.zsdl — covers socket.socket.__doc__ identity and content / socket.__spec__ and __loader__ attribute identity / socket.herror and socket.gaierror exception class identity / socket.getfqdn and create_connection qualnames."
    - "socket_extra99.zspec.zsdl — covers socket.gethostname/gethostbyname/getaddrinfo/setdefaulttimeout/getdefaulttimeout __qualname__.__len__() / SocketIO class identity."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' / socket.socket.send/sendall/fileno __qualname__.__eq__."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout __class__.__name__=='builtin_function_or_method'."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra141."
    - "Wave 297 theme: AF_INET/AF_INET6 enum member .name values and lengths / SOCK_STREAM/SOCK_DGRAM .name values and lengths / AddressFamily.__name__/__len__()==13 / SocketKind.__name__/__len__()==10 / socket.error/__name__/__len__() / socket.timeout/__name__/__len__() / socket.timeout.__bases__[0].__name__=='OSError' / AF_INET.value==SOCK_DGRAM.value (both 2)."
    - "socket.AF_INET.name == 'AF_INET' (len 7). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET6.name == 'AF_INET6' (len 8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.name == 'SOCK_STREAM' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.name == 'SOCK_DGRAM' (len 10). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__name__ == 'AddressFamily' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__name__ == 'SocketKind' (len 10). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__name__ == 'OSError' (len 7). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__name__ == 'TimeoutError' (len 12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__bases__[0].__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.value == socket.SOCK_DGRAM.value == 2 (both numeric 2 despite being different enum members from different enums). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.AF_INET.name is 'AF_INET' (7 chars) and socket.AF_INET6.name is 'AF_INET6' (8 chars — one char longer due to the trailing '6'). Both are AddressFamily IntEnum members. extra95 covers member values and names; this spec anchors the name lengths."
    - "Note: socket.SOCK_STREAM.name is 'SOCK_STREAM' (11 chars) and socket.SOCK_DGRAM.name is 'SOCK_DGRAM' (10 chars — one char shorter because 'DGRAM' is 5 chars while 'STREAM' is 6 chars). Both are SocketKind IntEnum members."
    - "Note: socket.error is an alias for OSError (a builtin), so socket.error.__name__ == 'OSError' (7 chars) and socket.error.__module__ == 'builtins'. Similarly socket.timeout is TimeoutError with __module__ == 'builtins'."
    - "Note: socket.timeout.__bases__[0].__name__ is 'OSError' — TimeoutError inherits from OSError (not directly from Exception). This makes timeout a socket-related OS error. In contrast, socket.error.__bases__[0].__name__ is 'Exception' (OSError's immediate base is Exception)."
    - "Note: socket.AddressFamily.__name__ is 'AddressFamily' (13 chars) and socket.SocketKind.__name__ is 'SocketKind' (10 chars). AddressFamily is 3 chars longer than SocketKind. Both have 'IntEnum' as their base class."
    - "Note: AF_INET.value == 2 and SOCK_DGRAM.value == 2 on macOS/Darwin. This is a coincidence of the platform's C constants: AF_INET is address family 2, SOCK_DGRAM is socket type 2. They are from different enum types (AddressFamily vs SocketKind) and are not equal as enum members."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET.name.__eq__('AF_INET') / name.__len__()==7
# socket.AF_INET6.name.__eq__('AF_INET6') / name.__len__()==8
# socket.SOCK_STREAM.name.__eq__('SOCK_STREAM') / name.__len__()==11
# socket.SOCK_DGRAM.name.__eq__('SOCK_DGRAM') / name.__len__()==10
#
# Wave 297 theme: IntEnum member .name values and lengths.
#
# extra95 covers AddressFamily/SocketKind member values and names at a high level;
# this table anchors the .name equality strings and their __len__() values under
# sockdoc142. AF_INET6.name (8) is one char longer than AF_INET.name (7) due to
# the trailing '6'. SOCK_STREAM.name (11) is one char longer than SOCK_DGRAM.name
# (10) because 'STREAM' (6) is one char longer than 'DGRAM' (5).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra142.enum_member_name_values_and_lengths:
  description: "socket.AF_INET.name.__eq__('AF_INET')==True / .name.__len__()==7 / AF_INET6.name.__eq__('AF_INET6')==True / .name.__len__()==8 / SOCK_STREAM.name.__eq__('SOCK_STREAM')==True / .name.__len__()==11 / SOCK_DGRAM.name.__eq__('SOCK_DGRAM')==True / .name.__len__()==10 — AF_INET6 is 1 char longer than AF_INET (trailing '6'); SOCK_STREAM is 1 char longer than SOCK_DGRAM ('STREAM' vs 'DGRAM'); extra95 covers values/names broadly; first sockdoc142 anchor for name equality and length"
  kind: python_call_eq
  category: identity
  id_prefix: sockdoc142

  columns: [id, function, args, expected, description]
  rows:
    - [AF_INET_name_eq,       AF_INET.name.__eq__,       ["AF_INET"],     true, "socket.AF_INET.name == 'AF_INET' (7 chars; AddressFamily IntEnum member)"]
    - [AF_INET_name_len,      AF_INET.name.__len__,      [],              7,    "socket.AF_INET.name.__len__() is 7 ('AF_INET' = 7 chars)"]
    - [AF_INET6_name_eq,      AF_INET6.name.__eq__,      ["AF_INET6"],    true, "socket.AF_INET6.name == 'AF_INET6' (8 chars; one char longer than AF_INET due to trailing '6')"]
    - [AF_INET6_name_len,     AF_INET6.name.__len__,     [],              8,    "socket.AF_INET6.name.__len__() is 8 ('AF_INET6' = 8 chars)"]
    - [SOCK_STREAM_name_eq,   SOCK_STREAM.name.__eq__,   ["SOCK_STREAM"], true, "socket.SOCK_STREAM.name == 'SOCK_STREAM' (11 chars; SocketKind IntEnum member)"]
    - [SOCK_STREAM_name_len,  SOCK_STREAM.name.__len__,  [],              11,   "socket.SOCK_STREAM.name.__len__() is 11 ('SOCK_STREAM' = 11 chars)"]
    - [SOCK_DGRAM_name_eq,    SOCK_DGRAM.name.__eq__,    ["SOCK_DGRAM"],  true, "socket.SOCK_DGRAM.name == 'SOCK_DGRAM' (10 chars; 'DGRAM' is 5 chars vs 'STREAM' is 6 chars)"]
    - [SOCK_DGRAM_name_len,   SOCK_DGRAM.name.__len__,   [],              10,   "socket.SOCK_DGRAM.name.__len__() is 10 ('SOCK_DGRAM' = 10 chars)"]

# ---------------------------------------------------------------------------
# socket.AddressFamily.__name__.__eq__('AddressFamily') / __len__()==13
# socket.SocketKind.__name__.__eq__('SocketKind') / __len__()==10
# socket.AddressFamily.__bases__[0].__name__.__eq__('IntEnum')
# socket.SocketKind.__bases__[0].__name__.__eq__('IntEnum')
#
# Wave 297 theme: AddressFamily and SocketKind enum class names and bases.
#
# AddressFamily.__name__ is 'AddressFamily' (13 chars); SocketKind.__name__ is
# 'SocketKind' (10 chars). Both inherit from IntEnum. extra96 covers AF_INET/AF_INET6/
# SOCK_STREAM/SOCK_DGRAM member class names; no prior socket spec anchors
# AddressFamily/SocketKind class __name__ values and lengths together under sockdoc142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra142.AddressFamily_SocketKind_class_identity:
  description: "socket.AddressFamily/__name__.__eq__('AddressFamily')==True / __name__.__len__()==13 / SocketKind/__name__.__eq__('SocketKind')==True / __name__.__len__()==10 / AddressFamily/__bases__[0].__name__.__eq__('IntEnum')==True / SocketKind/__bases__[0].__name__.__eq__('IntEnum')==True — both enum classes inherit from IntEnum; AddressFamily (13) is 3 chars longer than SocketKind (10); extra96 anchors member class names; first sockdoc142 anchor for enum class name values and lengths"
  kind: python_call_eq
  category: identity
  id_prefix: sockdoc142

  columns: [id, function, args, expected, description]
  rows:
    - [AF_class_name_eq,         AddressFamily.__name__.__eq__,              ["AddressFamily"], true, "socket.AddressFamily.__name__ == 'AddressFamily' (13 chars; IntEnum subclass for address families)"]
    - [AF_class_name_len,        AddressFamily.__name__.__len__,             [],                13,   "socket.AddressFamily.__name__.__len__() is 13 ('AddressFamily' = 13 chars)"]
    - [SK_class_name_eq,         SocketKind.__name__.__eq__,                 ["SocketKind"],    true, "socket.SocketKind.__name__ == 'SocketKind' (10 chars; IntEnum subclass for socket kinds)"]
    - [SK_class_name_len,        SocketKind.__name__.__len__,                [],                10,   "socket.SocketKind.__name__.__len__() is 10 ('SocketKind' = 10 chars)"]
    - [AF_bases_IntEnum,         "AddressFamily.__bases__[0].__name__.__eq__", ["IntEnum"],    true, "socket.AddressFamily.__bases__[0].__name__ == 'IntEnum' (AddressFamily inherits from IntEnum)"]
    - [SK_bases_IntEnum,         "SocketKind.__bases__[0].__name__.__eq__",    ["IntEnum"],    true, "socket.SocketKind.__bases__[0].__name__ == 'IntEnum' (SocketKind inherits from IntEnum)"]

# ---------------------------------------------------------------------------
# socket.error.__name__.__eq__('OSError') / __name__.__len__()==7
# socket.timeout.__name__.__eq__('TimeoutError') / __name__.__len__()==12
# socket.timeout.__bases__[0].__name__.__eq__('OSError')
# socket.error.__module__.__eq__('builtins')
#
# Wave 297 theme: socket.error and socket.timeout exception name identity.
#
# socket.error is an alias for OSError (__name__=='OSError', 7 chars, module='builtins').
# socket.timeout is an alias for TimeoutError (__name__=='TimeoutError', 12 chars,
# module='builtins'). socket.timeout.__bases__[0].__name__ == 'OSError' because
# TimeoutError inherits from OSError. No prior socket spec anchors these exception
# name values, lengths, bases, and module identity under sockdoc142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra142.error_and_timeout_name_identity:
  description: "socket.error/__name__.__eq__('OSError')==True / __name__.__len__()==7 / socket.timeout/__name__.__eq__('TimeoutError')==True / __name__.__len__()==12 / socket.timeout/__bases__[0].__name__.__eq__('OSError')==True / socket.error/__module__.__eq__('builtins')==True / socket.timeout/__module__.__eq__('builtins')==True — error is OSError alias, timeout is TimeoutError alias; both are builtins; timeout inherits from OSError; first sockdoc142 anchor for exception name values and lengths"
  kind: python_call_eq
  category: identity
  id_prefix: sockdoc142

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_eq,         error.__name__.__eq__,              ["OSError"],       true, "socket.error.__name__ == 'OSError' (socket.error is an alias for the builtin OSError)"]
    - [error_name_len,        error.__name__.__len__,             [],                7,    "socket.error.__name__.__len__() is 7 ('OSError' = 7 chars)"]
    - [timeout_name_eq,       timeout.__name__.__eq__,            ["TimeoutError"],  true, "socket.timeout.__name__ == 'TimeoutError' (socket.timeout is an alias for builtin TimeoutError)"]
    - [timeout_name_len,      timeout.__name__.__len__,           [],                12,   "socket.timeout.__name__.__len__() is 12 ('TimeoutError' = 12 chars)"]
    - [timeout_base_OSError,  "timeout.__bases__[0].__name__.__eq__", ["OSError"],  true, "socket.timeout.__bases__[0].__name__ == 'OSError' (TimeoutError inherits from OSError)"]
    - [error_module_builtins, error.__module__.__eq__,            ["builtins"],      true, "socket.error.__module__ == 'builtins' (OSError is a builtin exception)"]
    - [timeout_module_builtins, timeout.__module__.__eq__,        ["builtins"],      true, "socket.timeout.__module__ == 'builtins' (TimeoutError is a builtin exception)"]

# ---------------------------------------------------------------------------
# socket.AF_INET.name.__eq__('AF_INET') — standalone
#
# socket.AF_INET.name is 'AF_INET'. The .name attribute of an IntEnum member
# returns the member's name as defined in the enum class body. For AF_INET, this
# is 'AF_INET' (7 chars) — the standard POSIX address family name. The prefix
# 'AF_' (3 chars) stands for 'address family'. extra95 covers AF_INET's integer
# value (2); no prior socket spec anchors AF_INET.name equality as a standalone
# under sockdoc142. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra142.AF_INET_name_AF_INET:
  description: "socket.AF_INET.name.__eq__('AF_INET') == True — 'AF_INET' (7 chars); IntEnum .name attribute returns the member name as defined in AddressFamily; 'AF_' (3 chars) prefix stands for 'address family'; extra95 anchors integer value (2); first standalone for AF_INET.name equality under sockdoc142"
  category: identity
  kind: python_call_eq
  function: AF_INET.name.__eq__
  args: ["AF_INET"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.name.__len__()==11 — standalone
#
# socket.SOCK_STREAM.name.__len__() is 11. The name 'SOCK_STREAM' consists of
# the 5-char 'SOCK_' prefix plus the 6-char 'STREAM'. This makes SOCK_STREAM
# the longest of the four member names in this spec's group (AF_INET=7, AF_INET6=8,
# SOCK_DGRAM=10, SOCK_STREAM=11). No prior socket spec anchors SOCK_STREAM.name
# .__len__()==11 as a standalone under sockdoc142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra142.SOCK_STREAM_name_len_11:
  description: "socket.SOCK_STREAM.name.__len__() == 11 — 'SOCK_STREAM' (11 chars = 5-char 'SOCK_' prefix + 6-char 'STREAM'); longest member name in this spec's group (SOCK_DGRAM=10, AF_INET6=8, AF_INET=7); no prior socket spec anchors this as a standalone; first standalone under sockdoc142"
  category: identity
  kind: python_call_eq
  function: SOCK_STREAM.name.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# socket.timeout.__name__.__len__()==12 — standalone
#
# socket.timeout.__name__.__len__() is 12. The name 'TimeoutError' is 12 chars.
# socket.timeout is an alias for the builtin TimeoutError, which inherits from
# OSError. TimeoutError was added in Python 3.3 as a subclass of OSError to
# replace the socket-specific timeout exception. No prior socket spec anchors
# socket.timeout.__name__.__len__()==12 as a standalone under sockdoc142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra142.timeout_name_len_12:
  description: "socket.timeout.__name__.__len__() == 12 — 'TimeoutError' (12 chars); socket.timeout is an alias for the builtin TimeoutError; inherits from OSError (not directly from Exception); added in Python 3.3; no prior socket spec anchors this as a standalone; first standalone under sockdoc142"
  category: identity
  kind: python_call_eq
  function: timeout.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# socket.AddressFamily.__name__.__len__()==13 — standalone
#
# socket.AddressFamily.__name__.__len__() is 13. 'AddressFamily' is 13 chars.
# It is the longer of the two socket enum class names (AddressFamily=13 vs
# SocketKind=10). AddressFamily contains all AF_* constants (AF_INET, AF_INET6,
# AF_UNIX, etc.) as IntEnum members. No prior socket spec anchors
# AddressFamily.__name__.__len__()==13 as a standalone under sockdoc142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra142.AddressFamily_name_len_13:
  description: "socket.AddressFamily.__name__.__len__() == 13 — 'AddressFamily' (13 chars); longer of the two socket enum class names (AddressFamily=13 > SocketKind=10); contains all AF_* IntEnum members; inherits from IntEnum; no prior socket spec anchors this as a standalone; first standalone under sockdoc142"
  category: identity
  kind: python_call_eq
  function: AddressFamily.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# socket.SocketKind.__name__.__len__()==10 — standalone
#
# socket.SocketKind.__name__.__len__() is 10. 'SocketKind' is 10 chars.
# SocketKind is the shorter of the two socket enum class names (SocketKind=10
# vs AddressFamily=13). SocketKind contains the SOCK_* constants (SOCK_STREAM,
# SOCK_DGRAM, SOCK_RAW, etc.) as IntEnum members. No prior socket spec anchors
# SocketKind.__name__.__len__()==10 as a standalone under sockdoc142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra142.SocketKind_name_len_10:
  description: "socket.SocketKind.__name__.__len__() == 10 — 'SocketKind' (10 chars); shorter of the two socket enum class names (SocketKind=10 < AddressFamily=13); contains all SOCK_* IntEnum members; inherits from IntEnum; no prior socket spec anchors this as a standalone; first standalone under sockdoc142"
  category: identity
  kind: python_call_eq
  function: SocketKind.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# socket.error.__name__.__len__()==7 — standalone
#
# socket.error.__name__.__len__() is 7. 'OSError' is 7 chars. socket.error is
# simply the builtin OSError re-exported from the socket module. Its __name__
# is 'OSError' rather than 'error' because it is the actual OSError class, not
# a subclass or alias with a different name. The __module__ is 'builtins'
# confirming it is defined in the Python builtin namespace. No prior socket spec
# anchors socket.error.__name__.__len__()==7 as a standalone under sockdoc142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra142.error_name_len_7:
  description: "socket.error.__name__.__len__() == 7 — 'OSError' (7 chars); socket.error is the builtin OSError re-exported; __name__ is 'OSError' not 'error'; __module__ is 'builtins'; no prior socket spec anchors this as a standalone; first standalone under sockdoc142"
  category: identity
  kind: python_call_eq
  function: error.__name__.__len__
  args: []
  expected: 7
