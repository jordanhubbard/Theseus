spec: decimal_extra324
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal comparison operator invariants
# All test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0.
#
# Decimal('1').__eq__(Decimal('1')) == True
# Decimal('NaN').__eq__(Decimal('NaN')) == False  — NaN is never equal to anything
# Decimal('Infinity').__gt__(Decimal('1000000')) == True
# Decimal('-Infinity').__lt__(Decimal('-1000000')) == True
# Decimal('1').__ne__(Decimal('2')) == True
# Decimal('1.0').__eq__(Decimal('1')) == True    — same numeric value, different precision
# Decimal('0.10').__eq__(Decimal('0.1')) == True — trailing zero does not affect equality
# Decimal('1.5').__round__() == 2               — banker's rounding: round half to even
# ---------------------------------------------------------------------------

invariant decimal_extra324.Decimal.eq_self:
  description: "decimal.Decimal('1').__eq__(decimal.Decimal('1')) == True — identical Decimal values compare equal; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('1').__eq__"
  args: ["Decimal('1')"]
  expected: true

invariant decimal_extra324.Decimal.nan_not_eq_nan:
  description: "decimal.Decimal('NaN').__eq__(decimal.Decimal('NaN')) == False — NaN is not equal to itself per IEEE 754; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('NaN').__eq__"
  args: ["Decimal('NaN')"]
  expected: false

invariant decimal_extra324.Decimal.infinity_gt_large:
  description: "decimal.Decimal('Infinity').__gt__(decimal.Decimal('1000000')) == True — Infinity is greater than any finite value; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('Infinity').__gt__"
  args: ["Decimal('1000000')"]
  expected: true

invariant decimal_extra324.Decimal.neg_infinity_lt_large_negative:
  description: "decimal.Decimal('-Infinity').__lt__(decimal.Decimal('-1000000')) == True — -Infinity is less than any finite value; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('-Infinity').__lt__"
  args: ["Decimal('-1000000')"]
  expected: true

invariant decimal_extra324.Decimal.ne_different_values:
  description: "decimal.Decimal('1').__ne__(decimal.Decimal('2')) == True — distinct values are not equal; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('1').__ne__"
  args: ["Decimal('2')"]
  expected: true

invariant decimal_extra324.Decimal.eq_different_precision:
  description: "decimal.Decimal('1.0').__eq__(decimal.Decimal('1')) == True — same numeric value compares equal regardless of trailing zeros; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('1.0').__eq__"
  args: ["Decimal('1')"]
  expected: true

invariant decimal_extra324.Decimal.eq_trailing_zero:
  description: "decimal.Decimal('0.10').__eq__(decimal.Decimal('0.1')) == True — trailing zero in fraction does not affect equality; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('0.10').__eq__"
  args: ["Decimal('0.1')"]
  expected: true

invariant decimal_extra324.Decimal.round_half_to_even:
  description: "decimal.Decimal('1.5').__round__().__eq__(2) == True — banker's rounding: round half to even rounds 1.5 up to 2; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('1.5').__round__().__eq__"
  args: [2]
  expected: true
