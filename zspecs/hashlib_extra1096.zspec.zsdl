spec: hashlib_extra1096
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib.md5/__init__ qualname, hashlib.sha256/__init__ qualname, hashlib.__all__/__file__ class names, HASH __repr__/__init__/__new__ qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1096.constructor_init_qualnames:
  description: "hashlib.md5.__init__ and hashlib.sha256.__init__ qualname identity"
  kind: python_call_eq
  category: constructor_init_qualnames
  id_prefix: hl1096ci
  columns: [id, function, args, expected]
  rows:
    - [hl1096ci001, hashlib.md5.__init__.__qualname__.__eq__,              ["openssl_md5.__init__"],    true]
    - [hl1096ci002, hashlib.sha256.__init__.__qualname__.__eq__,           ["openssl_sha256.__init__"], true]
    - [hl1096ci003, hashlib.md5.__init__.__qualname__.__class__.__name__.__eq__,   ["str"], true]
    - [hl1096ci004, hashlib.sha256.__init__.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [hl1096ci005, hashlib.md5.__init__.__class__.__name__.__eq__,        ["slot_wrapper"], true]
    - [hl1096ci006, hashlib.sha256.__init__.__class__.__name__.__eq__,     ["slot_wrapper"], true]
    - [hl1096ci007, hashlib.md5.__init__.__module__.__eq__,                ["_hashlib"],     true]
    - [hl1096ci008, hashlib.sha256.__init__.__module__.__eq__,             ["_hashlib"],     true]

table hashlib_extra1096.module_collection_class_names:
  description: "hashlib.__all__.__class__.__name__ and hashlib.__file__.__class__.__name__ identity"
  kind: python_call_eq
  category: module_collection_classnames
  id_prefix: hl1096mc
  columns: [id, function, args, expected]
  rows:
    - [hl1096mc001, hashlib.__all__.__class__.__name__.__eq__,              ["list"],  true]
    - [hl1096mc002, hashlib.__file__.__class__.__name__.__eq__,             ["str"],   true]
    - [hl1096mc003, hashlib.__all__.__class__.__module__.__eq__,            ["builtins"], true]
    - [hl1096mc004, hashlib.__file__.__class__.__module__.__eq__,           ["builtins"], true]
    - [hl1096mc005, hashlib.__all__.__class__.__qualname__.__eq__,          ["list"],  true]
    - [hl1096mc006, hashlib.__file__.__class__.__qualname__.__eq__,         ["str"],   true]
    - [hl1096mc007, hashlib.__all__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
    - [hl1096mc008, hashlib.__file__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]

table hashlib_extra1096.hash_repr_init_new_qualnames:
  description: "HASH object __repr__, __init__, __new__ qualname identity via md5 and sha256"
  kind: python_call_eq
  category: hash_repr_init_new_qualnames
  id_prefix: hl1096rn
  columns: [id, function, args, expected]
  rows:
    - [hl1096rn001, hashlib.md5.__repr__.__qualname__.__eq__,              ["HASH.__repr__"], true]
    - [hl1096rn002, hashlib.md5.__new__.__qualname__.__eq__,               ["HASH.__new__"],  true]
    - [hl1096rn003, hashlib.sha256.__repr__.__qualname__.__eq__,           ["HASH.__repr__"], true]
    - [hl1096rn004, hashlib.sha256.__new__.__qualname__.__eq__,            ["HASH.__new__"],  true]
    - [hl1096rn005, hashlib.md5.__repr__.__qualname__.__class__.__name__.__eq__,  ["str"], true]
    - [hl1096rn006, hashlib.md5.__new__.__qualname__.__class__.__name__.__eq__,   ["str"], true]
    - [hl1096rn007, hashlib.sha256.__repr__.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [hl1096rn008, hashlib.md5.__repr__.__class__.__name__.__eq__,        ["slot_wrapper"], true]
    - [hl1096rn009, hashlib.sha256.__repr__.__class__.__name__.__eq__,     ["slot_wrapper"], true]
    - [hl1096rn010, hashlib.md5.__new__.__class__.__name__.__eq__,         ["slot_wrapper"], true]
