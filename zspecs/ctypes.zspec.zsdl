spec: ctypes
version: ">=3.3"
backend: python_module(ctypes)

docs: https://docs.python.org/3/library/ctypes.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ctypes.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "ctypes source: Lib/ctypes/__init__.py and Modules/_ctypes/ (PSF; source inspection permitted)"
  not_derived_from:
    - "ctypes internals: libffi integration, platform ABI details, pointer arithmetic"
  notes:
    - "ctypes is a foreign function library for Python providing C-compatible data types."
    - "Structure and Union are abstract base classes for C struct and union types."
    - "CDLL loads shared libraries using the cdecl calling convention."
    - "PyDLL loads shared libraries without releasing the GIL."
    - "LibraryLoader provides attribute-style access to shared libraries."
    - "c_int, c_long, c_char, c_char_p, c_void_p, c_double are fundamental C type wrappers."
    - "c_int(42).value returns the wrapped integer value 42."
    - "c_char_p represents a pointer to a null-terminated char array (bytes or None)."
    - "All expected values verified by running Python 3.12 ctypes module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "ctypes raises TypeError or ValueError for mismatched types; OSError when a shared library cannot be loaded."
  stderr: "null"
  stickiness: "N/A — class and type checks are stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant ctypes.Structure_name:
  description: "Structure class name is 'Structure'"
  category: classnames
  kind: python_call_eq
  function: Structure.__name__.__eq__
  args: ["Structure"]
  expected: true

invariant ctypes.Union_name:
  description: "Union class name is 'Union'"
  category: classnames
  kind: python_call_eq
  function: Union.__name__.__eq__
  args: ["Union"]
  expected: true

invariant ctypes.CDLL_name:
  description: "CDLL class name is 'CDLL'"
  category: classnames
  kind: python_call_eq
  function: CDLL.__name__.__eq__
  args: ["CDLL"]
  expected: true

invariant ctypes.PyDLL_name:
  description: "PyDLL class name is 'PyDLL'"
  category: classnames
  kind: python_call_eq
  function: PyDLL.__name__.__eq__
  args: ["PyDLL"]
  expected: true

invariant ctypes.LibraryLoader_name:
  description: "LibraryLoader class name is 'LibraryLoader'"
  category: classnames
  kind: python_call_eq
  function: LibraryLoader.__name__.__eq__
  args: ["LibraryLoader"]
  expected: true

# ---------------------------------------------------------------------------
# Fundamental C type name checks
# ---------------------------------------------------------------------------

invariant ctypes.c_int_name:
  description: "c_int class name is 'c_int'"
  category: classnames
  kind: python_call_eq
  function: c_int.__name__.__eq__
  args: ["c_int"]
  expected: true

invariant ctypes.c_long_name:
  description: "c_long class name is 'c_long'"
  category: classnames
  kind: python_call_eq
  function: c_long.__name__.__eq__
  args: ["c_long"]
  expected: true

invariant ctypes.c_char_name:
  description: "c_char class name is 'c_char'"
  category: classnames
  kind: python_call_eq
  function: c_char.__name__.__eq__
  args: ["c_char"]
  expected: true

invariant ctypes.c_char_p_name:
  description: "c_char_p class name is 'c_char_p'"
  category: classnames
  kind: python_call_eq
  function: c_char_p.__name__.__eq__
  args: ["c_char_p"]
  expected: true

invariant ctypes.c_void_p_name:
  description: "c_void_p class name is 'c_void_p'"
  category: classnames
  kind: python_call_eq
  function: c_void_p.__name__.__eq__
  args: ["c_void_p"]
  expected: true

invariant ctypes.c_double_name:
  description: "c_double class name is 'c_double'"
  category: classnames
  kind: python_call_eq
  function: c_double.__name__.__eq__
  args: ["c_double"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral checks on c_int
# ---------------------------------------------------------------------------

invariant ctypes.c_int_value:
  description: "c_int(42).value == 42"
  category: behavior
  kind: python_call_eq
  function: c_int
  args: [42]
  method: value.__eq__
  method_args: [42]
  expected: true

invariant ctypes.c_int_instance_classname:
  description: "c_int(0).__class__.__name__ == 'c_int'"
  category: behavior
  kind: python_call_eq
  function: c_int
  args: [0]
  method: __class__.__name__.__eq__
  method_args: ["c_int"]
  expected: true

# ---------------------------------------------------------------------------
# Module check
# ---------------------------------------------------------------------------

invariant ctypes.CDLL_module:
  description: "CDLL.__module__ == 'ctypes'"
  category: classnames
  kind: python_call_eq
  function: CDLL.__module__.__eq__
  args: ["ctypes"]
  expected: true
