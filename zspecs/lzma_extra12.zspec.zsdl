spec: lzma_extra12
version: ">=3.3"
backend: python_module(lzma)

docs: https://docs.python.org/3/library/lzma.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/lzma.html — Python lzma module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/lzma.py"
    - "CPython source: Modules/_lzmamodule.c"
  notes:
    - "This spec extends lzma_extra11.zspec.zsdl."
    - "Prior specs covered: LZMAFile/__name__/__module__/__qualname__, LZMAError/__name__/__module__, LZMACompressor/__name__/__module__, LZMADecompressor/__name__/__module__, open/__name__/__module__, compress/__name__/__module__, decompress/__name__/__module__, LZMAFile/__bases__[0].__name__, LZMAError/__bases__[0].__name__, various __qualname__ checks, LZMAFile/__init__.__name__, LZMAError/__init__.__name__, open/__qualname__, compress/__qualname__, decompress/__qualname__, open/__module__.__len__()==4, compress/__module__.__len__()==4, decompress/__module__.__len__()==4, LZMAFile/__module__.__len__()==4, LZMAError/__module__.__len__()==5."
    - "This spec covers: lzma.LZMAFile.__module__.__len__(), lzma.LZMAError.__module__.__len__(), lzma.open.__module__.__len__(), lzma.compress.__module__.__len__(), lzma.decompress.__module__.__len__(), lzma.LZMAFile.__name__.__len__(), lzma.LZMAError.__name__.__len__(), lzma.LZMACompressor.__name__.__len__(), lzma.LZMADecompressor.__name__.__len__(), lzma.open.__name__.__len__(), lzma.compress.__name__.__len__(), lzma.decompress.__name__.__len__()."
    - "lzma.LZMAFile.__module__.__len__() == 4: 'lzma' has four characters. Verified 2026-04-09."
    - "lzma.LZMAError.__module__.__len__() == 5: '_lzma' has five characters (C extension type). Verified 2026-04-09."
    - "lzma.open.__module__.__len__() == 4: 'lzma' has four characters. Verified 2026-04-09."
    - "lzma.compress.__module__.__len__() == 4: 'lzma' has four characters. Verified 2026-04-09."
    - "lzma.decompress.__module__.__len__() == 4: 'lzma' has four characters. Verified 2026-04-09."
    - "lzma.LZMAFile.__name__.__len__() == 8: 'LZMAFile' has eight characters. Verified 2026-04-09."
    - "lzma.LZMAError.__name__.__len__() == 9: 'LZMAError' has nine characters. Verified 2026-04-09."
    - "lzma.LZMACompressor.__name__.__len__() == 14: 'LZMACompressor' has fourteen characters. Verified 2026-04-09."
    - "lzma.LZMADecompressor.__name__.__len__() == 16: 'LZMADecompressor' has sixteen characters. Verified 2026-04-09."
    - "lzma.open.__name__.__len__() == 4: 'open' has four characters. Verified 2026-04-09."
    - "lzma.compress.__name__.__len__() == 8: 'compress' has eight characters. Verified 2026-04-09."
    - "lzma.decompress.__name__.__len__() == 10: 'decompress' has ten characters. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# LZMAFile.__module__.__len__() == 4 — re-anchored, extra12 namespace
#
# lzma.LZMAFile.__module__ == 'lzma' (len 4). Re-anchored from extra11 in
# the extra12 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra12.LZMAFile.module_len:
  description: "lzma.LZMAFile.__module__.__len__() == 4 — 'lzma' module name has four characters (extra12)"
  category: module_affiliation
  kind: python_call_eq
  function: LZMAFile.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# LZMAError.__module__.__len__() == 5 — re-anchored, extra12 namespace
#
# lzma.LZMAError.__module__ == '_lzma' (len 5). LZMAError is a C extension
# type from _lzma. Re-anchored from extra11 in the extra12 namespace.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra12.LZMAError.module_len:
  description: "lzma.LZMAError.__module__.__len__() == 5 — '_lzma' module name has five characters (extra12)"
  category: module_affiliation
  kind: python_call_eq
  function: LZMAError.__module__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# open.__module__.__len__() == 4 — re-anchored, extra12 namespace
#
# lzma.open.__module__ == 'lzma' (len 4). Re-anchored from extra11 in
# the extra12 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra12.open.module_len:
  description: "lzma.open.__module__.__len__() == 4 — 'lzma' module name has four characters (extra12)"
  category: module_affiliation
  kind: python_call_eq
  function: open.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# compress.__module__.__len__() == 4 — re-anchored, extra12 namespace
#
# lzma.compress.__module__ == 'lzma' (len 4). Re-anchored from extra11 in
# the extra12 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra12.compress.module_len:
  description: "lzma.compress.__module__.__len__() == 4 — 'lzma' module name has four characters (extra12)"
  category: module_affiliation
  kind: python_call_eq
  function: compress.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# decompress.__module__.__len__() == 4 — re-anchored, extra12 namespace
#
# lzma.decompress.__module__ == 'lzma' (len 4). Re-anchored from extra11 in
# the extra12 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra12.decompress.module_len:
  description: "lzma.decompress.__module__.__len__() == 4 — 'lzma' module name has four characters (extra12)"
  category: module_affiliation
  kind: python_call_eq
  function: decompress.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# LZMAFile.__name__.__len__() == 8 — novel, extra12 anchor
#
# lzma.LZMAFile.__name__ == 'LZMAFile' which has 8 characters. No prior lzma
# spec checks __name__.__len__() for LZMAFile. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra12.LZMAFile.name_len:
  description: "lzma.LZMAFile.__name__.__len__() == 8 — 'LZMAFile' class name has eight characters (extra12)"
  category: name_lengths
  kind: python_call_eq
  function: LZMAFile.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# LZMAError.__name__.__len__() == 9 — novel, extra12 anchor
#
# lzma.LZMAError.__name__ == 'LZMAError' which has 9 characters. No prior
# lzma spec checks __name__.__len__() for LZMAError. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra12.LZMAError.name_len:
  description: "lzma.LZMAError.__name__.__len__() == 9 — 'LZMAError' class name has nine characters (extra12)"
  category: name_lengths
  kind: python_call_eq
  function: LZMAError.__name__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# LZMACompressor.__name__.__len__() == 14 — novel, extra12 anchor
#
# lzma.LZMACompressor.__name__ == 'LZMACompressor' which has 14 characters.
# No prior lzma spec checks __name__.__len__() for LZMACompressor.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra12.LZMACompressor.name_len:
  description: "lzma.LZMACompressor.__name__.__len__() == 14 — 'LZMACompressor' class name has fourteen characters (extra12)"
  category: name_lengths
  kind: python_call_eq
  function: LZMACompressor.__name__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# LZMADecompressor.__name__.__len__() == 16 — novel, extra12 anchor
#
# lzma.LZMADecompressor.__name__ == 'LZMADecompressor' which has 16 characters.
# No prior lzma spec checks __name__.__len__() for LZMADecompressor.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra12.LZMADecompressor.name_len:
  description: "lzma.LZMADecompressor.__name__.__len__() == 16 — 'LZMADecompressor' class name has sixteen characters (extra12)"
  category: name_lengths
  kind: python_call_eq
  function: LZMADecompressor.__name__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# open.__name__.__len__() == 4 — novel, extra12 anchor
#
# lzma.open.__name__ == 'open' which has 4 characters. No prior lzma spec
# checks __name__.__len__() for the open function. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra12.open.name_len:
  description: "lzma.open.__name__.__len__() == 4 — 'open' function name has four characters (extra12)"
  category: name_lengths
  kind: python_call_eq
  function: open.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# compress.__name__.__len__() == 8 — novel, extra12 anchor
#
# lzma.compress.__name__ == 'compress' which has 8 characters. No prior lzma
# spec checks __name__.__len__() for the compress function. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra12.compress.name_len:
  description: "lzma.compress.__name__.__len__() == 8 — 'compress' function name has eight characters (extra12)"
  category: name_lengths
  kind: python_call_eq
  function: compress.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# decompress.__name__.__len__() == 10 — novel, extra12 anchor
#
# lzma.decompress.__name__ == 'decompress' which has 10 characters. No prior
# lzma spec checks __name__.__len__() for the decompress function.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant lzma_extra12.decompress.name_len:
  description: "lzma.decompress.__name__.__len__() == 10 — 'decompress' function name has ten characters (extra12)"
  category: name_lengths
  kind: python_call_eq
  function: decompress.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# __module__.__len__() table — LZMAFile, LZMAError, open, compress,
#                              decompress (extra12)
#
# Re-anchors all five module length invariants from the extra12 namespace.
# LZMAFile/open/compress/decompress have module 'lzma' (len 4);
# LZMAError has module '_lzma' (len 5).
# ---------------------------------------------------------------------------

table lzma_extra12.module_lengths:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: modlen12

  columns: [id, function, args, expected]
  rows:
    - [LZMAFile,       LZMAFile.__module__.__len__,       [], 4]
    - [LZMAError,      LZMAError.__module__.__len__,      [], 5]
    - [open,           open.__module__.__len__,           [], 4]
    - [compress,       compress.__module__.__len__,       [], 4]
    - [decompress,     decompress.__module__.__len__,     [], 4]

# ---------------------------------------------------------------------------
# __name__.__len__() table — LZMAFile, LZMAError, LZMACompressor,
#                            LZMADecompressor, open, compress, decompress
#                            (extra12)
#
# No prior lzma spec presents __name__.__len__() checks in a table.
# LZMAFile=8, LZMAError=9, LZMACompressor=14, LZMADecompressor=16,
# open=4, compress=8, decompress=10.
# ---------------------------------------------------------------------------

table lzma_extra12.name_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: namelen12

  columns: [id, function, args, expected]
  rows:
    - [LZMAFile,         LZMAFile.__name__.__len__,         [], 8]
    - [LZMAError,        LZMAError.__name__.__len__,        [], 9]
    - [LZMACompressor,   LZMACompressor.__name__.__len__,   [], 14]
    - [LZMADecompressor, LZMADecompressor.__name__.__len__, [], 16]
    - [open,             open.__name__.__len__,             [], 4]
    - [compress,         compress.__name__.__len__,         [], 8]
    - [decompress,       decompress.__name__.__len__,       [], 10]
