spec: html_parser_extra2
version: ">=3.4"
backend: python_module(html.parser)

docs: https://docs.python.org/3/library/html.parser.html

provenance:
  derived_from:
    - "Python html.parser documentation — https://docs.python.org/3/library/html.parser.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/html/parser.py"
    - "html_parser.zspec.zsdl — covers HTMLParser.__name__, __module__, convert_charrefs default, getpos(), method names (feed/reset/close/getpos/handle_starttag/handle_endtag/handle_data/handle_comment/handle_charref/handle_entityref), reset/close return None"
    - "html_extra5.zspec.zsdl — covers HTMLParser.__qualname__, method __qualname__ for feed/reset/close/getpos/handle_starttag/handle_endtag/handle_data/handle_comment, HTMLParser.__class__.__name__, HTMLParser.__bases__[0].__name__"
  notes:
    - "This spec covers axes not yet in html_parser.zspec.zsdl or html_extra5.zspec.zsdl."
    - "HTMLParser has additional overrideable callbacks not yet spec'd: handle_decl, handle_pi, unknown_decl."
    - "handle_decl.__name__ == 'handle_decl' — called for DOCTYPE declarations."
    - "handle_pi.__name__ == 'handle_pi' — called for processing instructions."
    - "unknown_decl.__name__ == 'unknown_decl' — called for unrecognized markup declarations."
    - "handle_decl.__qualname__ == 'HTMLParser.handle_decl'."
    - "handle_pi.__qualname__ == 'HTMLParser.handle_pi'."
    - "unknown_decl.__qualname__ == 'HTMLParser.unknown_decl'."
    - "CDATA_CONTENT_ELEMENTS is a tuple of element names whose content is treated as raw text."
    - "'script' is in CDATA_CONTENT_ELEMENTS — script element content is not parsed as markup."
    - "'style' is in CDATA_CONTENT_ELEMENTS — style element content is not parsed as markup."
    - "HTMLParser(convert_charrefs=False).convert_charrefs == False — the argument is respected."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Method name checks — handle_decl, handle_pi, unknown_decl
# (html_parser.zspec.zsdl covers the 10 methods listed in its table;
#  these three additional callbacks are not covered there)
# ---------------------------------------------------------------------------

table html_parser_extra2.extra_method_names:
  kind: python_call_eq
  category: functions
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [handle_decl,  HTMLParser.handle_decl.__name__.__eq__,  ["handle_decl"],  true]
    - [handle_pi,    HTMLParser.handle_pi.__name__.__eq__,    ["handle_pi"],    true]
    - [unknown_decl, HTMLParser.unknown_decl.__name__.__eq__, ["unknown_decl"], true]

# ---------------------------------------------------------------------------
# Method __qualname__ — handle_decl, handle_pi, unknown_decl
# (html_extra5.zspec.zsdl covers __qualname__ for 8 methods; these 3 are new)
# ---------------------------------------------------------------------------

table html_parser_extra2.extra_method_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: mqname

  columns: [id, function, args, expected]
  rows:
    - [handle_decl,  HTMLParser.handle_decl.__qualname__.__eq__,  ["HTMLParser.handle_decl"],  true]
    - [handle_pi,    HTMLParser.handle_pi.__qualname__.__eq__,    ["HTMLParser.handle_pi"],    true]
    - [unknown_decl, HTMLParser.unknown_decl.__qualname__.__eq__, ["HTMLParser.unknown_decl"], true]

# ---------------------------------------------------------------------------
# CDATA_CONTENT_ELEMENTS — type is tuple
#
# html_extra3.zspec.zsdl (via html backend) reports __class__.__name__ == 'frozenset'
# but on Python 3.14 it is a tuple. This spec records the actual value via the
# html.parser backend (the authoritative source).
# ---------------------------------------------------------------------------

invariant html_parser_extra2.CDATA_CONTENT_ELEMENTS.type:
  description: "HTMLParser.CDATA_CONTENT_ELEMENTS.__class__.__name__ == 'tuple' (Python 3.14)"
  category: attributes
  kind: python_call_eq
  function: HTMLParser.CDATA_CONTENT_ELEMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# CDATA_CONTENT_ELEMENTS — 'script' membership
# (not in any prior spec; verifies a specific known member)
# ---------------------------------------------------------------------------

invariant html_parser_extra2.CDATA_CONTENT_ELEMENTS.contains_script:
  description: "'script' in HTMLParser.CDATA_CONTENT_ELEMENTS == True"
  category: attributes
  kind: python_call_eq
  function: HTMLParser.CDATA_CONTENT_ELEMENTS.__contains__
  args: ["script"]
  expected: true

# ---------------------------------------------------------------------------
# CDATA_CONTENT_ELEMENTS — 'style' membership
# ---------------------------------------------------------------------------

invariant html_parser_extra2.CDATA_CONTENT_ELEMENTS.contains_style:
  description: "'style' in HTMLParser.CDATA_CONTENT_ELEMENTS == True"
  category: attributes
  kind: python_call_eq
  function: HTMLParser.CDATA_CONTENT_ELEMENTS.__contains__
  args: ["style"]
  expected: true

# ---------------------------------------------------------------------------
# convert_charrefs=False — the constructor argument is respected
# (html_parser.zspec.zsdl covers the True default only)
# ---------------------------------------------------------------------------

invariant html_parser_extra2.convert_charrefs_false:
  description: "HTMLParser(convert_charrefs=False).convert_charrefs == False"
  category: behavior
  kind: python_call_eq
  function: HTMLParser
  kwargs: {convert_charrefs: false}
  method: convert_charrefs
  method_args: []
  expected: false

# ---------------------------------------------------------------------------
# handle_charref and handle_entityref qualname
# (html_parser.zspec.zsdl covers their __name__; __qualname__ is new here)
# ---------------------------------------------------------------------------

table html_parser_extra2.legacy_method_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: legmqname

  columns: [id, function, args, expected]
  rows:
    - [handle_charref,   HTMLParser.handle_charref.__qualname__.__eq__,   ["HTMLParser.handle_charref"],   true]
    - [handle_entityref, HTMLParser.handle_entityref.__qualname__.__eq__, ["HTMLParser.handle_entityref"], true]
