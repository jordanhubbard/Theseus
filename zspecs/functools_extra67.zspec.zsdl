spec: functools_extra67
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra66.zspec.zsdl."
    - "Wave 228 theme: __doc__ string content checks, __annotations__ class identity, __globals__ keys presence checks."
    - "wraps and update_wrapper are pure-Python functions (Lib/functools.py) with __annotations__ == {} (empty dict). The __annotations__ attribute on any Python function is always a dict object, so __annotations__.__class__.__name__ == 'dict'. This is true even when annotations are empty. Prior functools specs did not check __annotations__.__class__.__name__ for any module-level function."
    - "reduce is a C builtin_function_or_method (Modules/_functoolsmodule.c) with no __annotations__ attribute. wraps.__globals__ is the functools module namespace dict — a shared dict for all module-level Python functions in Lib/functools.py. It contains keys 'reduce', 'wraps', 'update_wrapper', 'partial', 'lru_cache', etc. The check __globals__.__contains__('reduce') returns True because functools.reduce is a name in the functools module namespace."
    - "partial is a C extension type (class), not a Python function. partial.__doc__ is the docstring defined in Modules/_functoolsmodule.c. It contains 'partial' (confirmed: 'Create a new function with partial application...'). partial.__doc__.__contains__('partial') returns True."
    - "lru_cache, cache, singledispatch, total_ordering are all pure-Python functions with __annotations__ == {}. Their __annotations__.__class__.__name__ == 'dict'."
    - "No prior functools spec has checked __annotations__.__class__.__name__ for any function, __globals__.__class__.__name__ or __globals__.__contains__ for any function, or partial.__doc__.__contains__. All checks in this spec are new to extra67."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools module-level function __annotations__.__class__.__name__ — extra67
#
# Wave 228 theme: __annotations__ class identity.
#
# Every Python function has an __annotations__ attribute that is always a
# dict object (possibly empty). Therefore for any Python function f:
#   f.__annotations__.__class__.__name__ == 'dict'
#
# Checked here: wraps, update_wrapper, lru_cache, singledispatch, total_ordering.
# All are pure-Python functions (inspect.isfunction == True).
# All have __annotations__ == {} (no annotated parameters).
#
# NOTE: reduce is a C builtin and does NOT have __annotations__.
# NOTE: partial is a C extension type (class), not a function.
#
# No prior functools spec checks __annotations__.__class__.__name__ for
# any module-level function. New to extra67.
# ---------------------------------------------------------------------------

table functools_extra67.function_annotations_class_name:
  description: "functools Python function __annotations__.__class__.__name__.__eq__('dict')==true — __annotations__ is always a dict; wave 228 __annotations__ class identity; new to extra67"
  kind: python_call_eq
  category: annotations_type
  id_prefix: functoolsann67

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_annotations_class_name_eq_dict,
       wraps.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "functools.wraps.__annotations__.__class__.__name__.__eq__('dict') == True — wraps is a pure-Python decorator factory (Lib/functools.py) that applies update_wrapper() to a wrapper function; it has no annotated parameters so __annotations__ == {} (empty dict); as a dict object, __annotations__.__class__ is the built-in dict type and dict.__name__ == 'dict' (4 chars); this chain checks the type identity of the annotations container; no prior functools spec checks __annotations__.__class__.__name__ for wraps; new to extra67"]
    - [update_wrapper_annotations_class_name_eq_dict,
       update_wrapper.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "functools.update_wrapper.__annotations__.__class__.__name__.__eq__('dict') == True — update_wrapper is a pure-Python function (Lib/functools.py) that copies dunder attributes from wrapped to wrapper; it has no annotated parameters so __annotations__ == {} (empty dict); as a dict object, __annotations__.__class__ is the built-in dict type and dict.__name__ == 'dict' (4 chars); this chain checks the type identity of the annotations container; no prior functools spec checks __annotations__.__class__.__name__ for update_wrapper; new to extra67"]
    - [lru_cache_annotations_class_name_eq_dict,
       lru_cache.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "functools.lru_cache.__annotations__.__class__.__name__.__eq__('dict') == True — lru_cache is a pure-Python function (Lib/functools.py) that memoizes function calls up to a maxsize; it has no annotated parameters so __annotations__ == {} (empty dict); as a dict object, __annotations__.__class__ is the built-in dict type and dict.__name__ == 'dict' (4 chars); no prior functools spec checks __annotations__.__class__.__name__ for lru_cache; new to extra67"]
    - [singledispatch_annotations_class_name_eq_dict,
       singledispatch.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "functools.singledispatch.__annotations__.__class__.__name__.__eq__('dict') == True — singledispatch is a pure-Python decorator (Lib/functools.py) that transforms a function into a single-dispatch generic function; it has no annotated parameters so __annotations__ == {} (empty dict); as a dict object, __annotations__.__class__ is the built-in dict type and dict.__name__ == 'dict' (4 chars); no prior functools spec checks __annotations__.__class__.__name__ for singledispatch; new to extra67"]
    - [total_ordering_annotations_class_name_eq_dict,
       total_ordering.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "functools.total_ordering.__annotations__.__class__.__name__.__eq__('dict') == True — total_ordering is a pure-Python class decorator (Lib/functools.py) that fills in missing comparison methods given __eq__ and one of __lt__/__le__/__gt__/__ge__; it has no annotated parameters so __annotations__ == {} (empty dict); as a dict object, __annotations__.__class__ is the built-in dict type and dict.__name__ == 'dict' (4 chars); no prior functools spec checks __annotations__.__class__.__name__ for total_ordering; new to extra67"]

# ---------------------------------------------------------------------------
# wraps.__globals__ class name and key presence — extra67
#
# Wave 228 theme: __globals__ keys presence checks.
#
# wraps.__globals__ is the functools module namespace dict — the dict that
# serves as the global namespace for all pure-Python functions defined in
# Lib/functools.py. It is the same object as functools.__dict__ for the
# functions defined there.
#
# wraps.__globals__.__class__.__name__ == 'dict' (it is a plain dict).
# 'reduce' is in wraps.__globals__ because functools.reduce is imported/
# defined at module scope in functools.py.
# 'wraps' is in wraps.__globals__ for the same reason.
#
# No prior functools spec checks __globals__.__class__.__name__ or
# __globals__.__contains__ for any function. New to extra67.
# ---------------------------------------------------------------------------

table functools_extra67.wraps_globals_checks:
  description: "wraps.__globals__.__class__.__name__ and __contains__ checks — module namespace is a dict containing 'reduce' and 'wraps'; wave 228 __globals__ keys presence; new to extra67"
  kind: python_call_eq
  category: globals_checks
  id_prefix: functoolsann67

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_globals_class_name_eq_dict,
       wraps.__globals__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "functools.wraps.__globals__.__class__.__name__.__eq__('dict') == True — wraps is a pure-Python function (Lib/functools.py); its __globals__ attribute is the functools module namespace dict (the same object as functools.__dict__ for module-level names); every module namespace is a plain Python dict; therefore __globals__.__class__.__name__ == 'dict' (4 chars); no prior functools spec checks __globals__.__class__.__name__ for any function; new to extra67"]
    - [wraps_globals_contains_reduce,
       wraps.__globals__.__contains__,
       ["reduce"],
       true,
       "functools.wraps.__globals__.__contains__('reduce') == True — wraps.__globals__ is the functools module namespace dict shared by all pure-Python functions in Lib/functools.py; functools.reduce is imported from the _functools C extension and re-exported at module scope (it appears as a top-level name in the functools namespace); therefore 'reduce' is a key in wraps.__globals__; __contains__ on a dict returns True when the key exists; no prior functools spec checks __globals__.__contains__ for any key; new to extra67"]
    - [wraps_globals_contains_wraps,
       wraps.__globals__.__contains__,
       ["wraps"],
       true,
       "functools.wraps.__globals__.__contains__('wraps') == True — wraps.__globals__ is the functools module namespace dict; 'wraps' is a key in this dict because wraps itself is a module-level name in Lib/functools.py; for any top-level function f in module M, f.__globals__.__contains__(f.__name__) is True (the function is registered in its own module's namespace); no prior functools spec checks __globals__.__contains__('wraps'); new to extra67"]
    - [update_wrapper_globals_contains_update_wrapper,
       update_wrapper.__globals__.__contains__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__globals__.__contains__('update_wrapper') == True — update_wrapper.__globals__ is the same functools module namespace dict as wraps.__globals__ (both functions are defined in Lib/functools.py and share the same module globals); 'update_wrapper' is a top-level name in that namespace; __contains__ returns True; no prior functools spec checks __globals__.__contains__ for update_wrapper; new to extra67"]

# ---------------------------------------------------------------------------
# partial.__doc__.__contains__ check — extra67
#
# Wave 228 theme: __doc__ string content checks.
#
# functools.partial is a C extension type defined in Modules/_functoolsmodule.c.
# Its __doc__ string is:
#   'Create a new function with partial application of the given arguments\nand keywords.'
#
# partial.__doc__.__contains__('partial') returns True because the word
# 'partial' appears in the phrase 'partial application'.
# partial.__doc__.__contains__('arguments') returns True.
# partial.__doc__.__contains__('application') returns True.
#
# No prior functools spec checks partial.__doc__.__contains__ for any string.
# New to extra67.
# ---------------------------------------------------------------------------

table functools_extra67.partial_doc_contains:
  description: "partial.__doc__.__contains__ checks — docstring mentions 'partial', 'arguments', 'application'; wave 228 __doc__ content checks; new to extra67"
  kind: python_call_eq
  category: doc_content
  id_prefix: functoolsann67

  columns: [id, function, args, expected, description]
  rows:
    - [partial_doc_contains_partial,
       partial.__doc__.__contains__,
       ["partial"],
       true,
       "functools.partial.__doc__.__contains__('partial') == True — partial is a C extension type (Modules/_functoolsmodule.c); its docstring is 'Create a new function with partial application of the given arguments\\nand keywords.'; the word 'partial' appears in the phrase 'partial application' on the first line; __contains__ on a str returns True when the substring exists anywhere in the string; no prior functools spec checks partial.__doc__.__contains__; new to extra67"]
    - [partial_doc_contains_arguments,
       partial.__doc__.__contains__,
       ["arguments"],
       true,
       "functools.partial.__doc__.__contains__('arguments') == True — partial.__doc__ is 'Create a new function with partial application of the given arguments\\nand keywords.'; 'arguments' appears explicitly in this docstring; __contains__ returns True; new to extra67"]
    - [partial_doc_contains_application,
       partial.__doc__.__contains__,
       ["application"],
       true,
       "functools.partial.__doc__.__contains__('application') == True — partial.__doc__ is 'Create a new function with partial application of the given arguments\\nand keywords.'; 'application' appears in the phrase 'partial application'; __contains__ returns True; new to extra67"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra67
# ---------------------------------------------------------------------------

invariant functools_extra67.wraps_annotations_is_dict:
  description: "functools.wraps.__annotations__.__class__.__name__.__eq__('dict') == True — every Python function's __annotations__ is a dict; wraps has no annotated params so annotations == {}; wave 228 __annotations__ class identity; new to extra67"
  kind: python_call_eq
  function: wraps.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant functools_extra67.wraps_globals_contains_reduce:
  description: "functools.wraps.__globals__.__contains__('reduce') == True — wraps.__globals__ is the functools module namespace dict; 'reduce' is a top-level name in functools; wave 228 __globals__ keys presence; new to extra67"
  kind: python_call_eq
  function: wraps.__globals__.__contains__
  args: ["reduce"]
  expected: true

invariant functools_extra67.partial_doc_contains_partial:
  description: "functools.partial.__doc__.__contains__('partial') == True — partial C type docstring mentions 'partial' in 'partial application'; wave 228 __doc__ content; new to extra67"
  kind: python_call_eq
  function: partial.__doc__.__contains__
  args: ["partial"]
  expected: true
