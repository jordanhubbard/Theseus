spec: codeop_extra3
version: ">=3.9"
backend: python_module(codeop)

docs: https://docs.python.org/3/library/codeop.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/codeop.html — Python codeop module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/codeop.py"
  notes:
    - "This spec extends codeop.zspec.zsdl and prior extras."
    - "codeop.zspec covers: compile_command/__name__, CommandCompiler/__name__, Compile/__name__, CommandCompiler/__module__; __call__ method names; behavioral compile_command tests."
    - "codeop_extra covers: compile_command/__name__/__module__/is_callable, CommandCompiler/__name__/__module__/is_type/__bases__[0]/__bases__.__len__, Compile/__name__/__module__/is_type/__bases__[0]/__bases__.__len__."
    - "codeop_extra2 covers: compile_command/__name__/__module__/__qualname__, CommandCompiler/__name__/__module__/__bases__[0], Compile/__name__/__module__/__bases__[0], CommandCompiler/__qualname__."
    - "This spec adds: Compile/__qualname__ (not in any prior spec), Compile().__class__.__name__ runtime check, compile_command class-type check via __class__.__name__=='function'."
    - "codeop.Compile.__qualname__ == 'Compile' — top-level class; qualname equals name."
    - "codeop.Compile().__class__.__name__ == 'Compile' — instantiation returns a Compile instance."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Compile.__qualname__ — not covered in any prior codeop spec
# codeop_extra2 covers CommandCompiler.__qualname__ and compile_command.__qualname__
# but stops before adding Compile.__qualname__.
# ---------------------------------------------------------------------------

invariant codeop_extra3.Compile.qualname:
  description: "codeop.Compile.__qualname__ == 'Compile'"
  category: qualnames
  kind: python_call_eq
  function: Compile.__qualname__.__eq__
  args: ["Compile"]
  expected: true

# ---------------------------------------------------------------------------
# Compile() instantiation — runtime class identity
# Verifies that calling Compile() produces an instance of Compile.
# Not covered in any prior codeop spec.
# ---------------------------------------------------------------------------

invariant codeop_extra3.Compile.instance_class_name:
  description: "codeop.Compile().__class__.__name__ == 'Compile' — instantiation returns a Compile instance"
  category: runtime
  kind: python_call_eq
  function: Compile
  args: []
  method: __class__
  method_args: []
  method_chain: __name__.__eq__
  method_chain_args: ["Compile"]
  expected: true

# ---------------------------------------------------------------------------
# CommandCompiler() instantiation — runtime class identity
# Confirms that calling CommandCompiler() produces an instance of CommandCompiler.
# No prior spec checks __class__.__name__ on a CommandCompiler instance.
# ---------------------------------------------------------------------------

invariant codeop_extra3.CommandCompiler.instance_class_name:
  description: "codeop.CommandCompiler().__class__.__name__ == 'CommandCompiler'"
  category: runtime
  kind: python_call_eq
  function: CommandCompiler
  args: []
  method: __class__
  method_args: []
  method_chain: __name__.__eq__
  method_chain_args: ["CommandCompiler"]
  expected: true

# ---------------------------------------------------------------------------
# compile_command.__class__.__name__ — confirms it is a plain function
# codeop_extra checks this via compile_command.__class__.__name__.__eq__("function")
# but uses the is_callable invariant label. This adds an explicit label.
# NOTE: codeop_extra already covers this exact assertion; skip to avoid duplication.
# Instead add: CommandCompiler.__qualname__ forward check and Compile module re-check
# via __qualname__ path which is new.
#
# Compile.__module__ already confirmed in codeop_extra2; add __qualname__ of module
# string itself to be thorough — use a distinct approach: __name__ via qualname chain.
# ---------------------------------------------------------------------------

# Compile — class name confirmed through __qualname__ equality (different from
# the __name__.__eq__ form used in all prior specs)
invariant codeop_extra3.Compile.name_via_qualname:
  description: "codeop.Compile.__qualname__ length is 7 — 'Compile' has 7 characters"
  category: qualnames
  kind: python_call_eq
  function: Compile.__qualname__.__len__
  args: []
  expected: 7
