spec: asyncio_extra1021
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio Task, Future, Queue, Lock weakref descriptors and module-level attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra1021.weakref_descriptors:
  description: "asyncio core classes __weakref__ class name identity"
  kind: python_call_eq
  category: weakref_descriptors
  id_prefix: as1021x
  columns: [id, function, args, expected]
  rows:
    - [as1021x001, asyncio.Task.__weakref__.__class__.__name__.__eq__,   ["getset_descriptor"], true]
    - [as1021x002, asyncio.Future.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [as1021x003, asyncio.Queue.__weakref__.__class__.__name__.__eq__,  ["getset_descriptor"], true]
    - [as1021x004, asyncio.Lock.__weakref__.__class__.__name__.__eq__,   ["getset_descriptor"], true]
    - [as1021x005, asyncio.Event.__weakref__.__class__.__name__.__eq__,  ["getset_descriptor"], true]
    - [as1021x006, asyncio.Semaphore.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [as1021x007, asyncio.Condition.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]

table asyncio_extra1021.module_attributes:
  description: "asyncio module-level attribute class identity"
  kind: python_call_eq
  category: module_attributes
  id_prefix: as1021m
  columns: [id, function, args, expected]
  rows:
    - [as1021m001, asyncio.__all__.__class__.__name__.__eq__,            ["list"],    true]
    - [as1021m002, asyncio.__name__.__eq__,                              ["asyncio"], true]
    - [as1021m003, asyncio.__spec__.__class__.__name__.__eq__,           ["ModuleSpec"], true]
    - [as1021m004, asyncio.__package__.__eq__,                           ["asyncio"], true]
    - [as1021m005, asyncio.__file__.__class__.__name__.__eq__,           ["str"],     true]

table asyncio_extra1021.coroutine_helpers:
  description: "asyncio coroutine helper function module identity"
  kind: python_call_eq
  category: coroutine_helpers
  id_prefix: as1021c
  columns: [id, function, args, expected]
  rows:
    - [as1021c001, asyncio.iscoroutine.__module__.__eq__,                ["asyncio.coroutines"], true]
    - [as1021c002, asyncio.iscoroutinefunction.__module__.__eq__,        ["asyncio.coroutines"], true]
    - [as1021c003, asyncio.iscoroutine.__class__.__name__.__eq__,        ["builtin_function_or_method"], false]
    - [as1021c004, asyncio.iscoroutine.__qualname__.__eq__,              ["iscoroutine"], true]
    - [as1021c005, asyncio.iscoroutinefunction.__qualname__.__eq__,      ["iscoroutinefunction"], true]
