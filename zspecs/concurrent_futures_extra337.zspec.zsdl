spec: concurrent_futures_extra337
version: ">=3.2"
backend: python_module(concurrent.futures.thread)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "concurrent.futures.thread is the implementation module for ThreadPoolExecutor."
    - "BrokenThreadPool inherits from BrokenExecutor (not BrokenException) on Python 3.14."
    - "_WorkItem is a private helper class for the thread pool implementation."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.thread module identity
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra337.module.name:
  description: "concurrent.futures.thread.__name__ == 'concurrent.futures.thread'"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra337.module.package:
  description: "concurrent.futures.thread.__package__ == 'concurrent.futures'"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["concurrent.futures"]
  expected: true

# ---------------------------------------------------------------------------
# ThreadPoolExecutor class introspection
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra337.thread_pool_executor.class_name:
  description: "ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'"
  category: thread_pool_executor
  kind: python_call_eq
  function: ThreadPoolExecutor.__name__.__eq__
  args: ["ThreadPoolExecutor"]
  expected: true

invariant concurrent_futures_extra337.thread_pool_executor.module:
  description: "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'"
  category: thread_pool_executor
  kind: python_call_eq
  function: ThreadPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra337.thread_pool_executor.base_class:
  description: "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'"
  category: thread_pool_executor
  kind: python_call_eq
  function: ThreadPoolExecutor.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Executor"]
  expected: true

# ---------------------------------------------------------------------------
# _WorkItem private helper class
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra337.work_item.class_name:
  description: "_WorkItem.__name__ == '_WorkItem'"
  category: work_item
  kind: python_call_eq
  function: _WorkItem.__name__.__eq__
  args: ["_WorkItem"]
  expected: true

# ---------------------------------------------------------------------------
# BrokenThreadPool exception class
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra337.broken_thread_pool.class_name:
  description: "BrokenThreadPool.__name__ == 'BrokenThreadPool'"
  category: broken_thread_pool
  kind: python_call_eq
  function: BrokenThreadPool.__name__.__eq__
  args: ["BrokenThreadPool"]
  expected: true

invariant concurrent_futures_extra337.broken_thread_pool.module:
  description: "BrokenThreadPool.__module__ == 'concurrent.futures.thread'"
  category: broken_thread_pool
  kind: python_call_eq
  function: BrokenThreadPool.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra337.broken_thread_pool.base_class:
  description: "BrokenThreadPool.__bases__[0].__name__ == 'BrokenExecutor'"
  category: broken_thread_pool
  kind: python_call_eq
  function: BrokenThreadPool.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["BrokenExecutor"]
  expected: true
