spec: contextvars_extra2
version: ">=3.9"
backend: python_module(contextvars)

docs: https://docs.python.org/3/library/contextvars.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/contextvars.html"
    - "PEP 567 — Context Variables (https://peps.python.org/pep-0567/)"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_contextvars.py or C extension internals"
  notes:
    - "This spec extends contextvars.zspec.zsdl with new axes not yet covered."
    - "contextvars.zspec.zsdl covers: class names/modules for ContextVar/Context/Token; copy_context.__name__ and return type; ContextVar.get() with str and None defaults; Token.__bases__[0] and ContextVar.__bases__[0] == 'object'; Token.MISSING class name == 'object'."
    - "NEW in this spec: ContextVar.__qualname__; ContextVar.__name__ via __name__ attr (not __eq__ chain); Context.__bases__[0].__name__ == 'object'; Context class name via __class__.__name__; Token.__qualname__; copy_context.__module__ == 'contextvars'; ContextVar.get() with integer default; ContextVar.__module__ == 'contextvars'."
    - "contextvars.ContextVar.__qualname__ == 'ContextVar' — top-level class, qualname equals name."
    - "contextvars.Token.__qualname__ == 'Token' — top-level class, qualname equals name."
    - "contextvars.Context.__bases__[0].__name__ == 'object' — Context inherits from object."
    - "contextvars.copy_context.__module__ — copy_context is a C-level builtin; its __module__ is 'contextvars'."
    - "contextvars.ContextVar.get() with an integer default returns that integer."
    - "contextvars.ContextVar.__module__ == 'contextvars' — module attribute."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ContextVar.__qualname__ and Token.__qualname__
#
# contextvars.zspec.zsdl covers __name__ and __module__ for ContextVar/Token
# via class_names and module_names tables. No prior spec checks __qualname__
# for any contextvars class.
# ---------------------------------------------------------------------------

table contextvars_extra2.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [contextvar, ContextVar.__qualname__.__eq__, ["ContextVar"], true]
    - [token,      Token.__qualname__.__eq__,      ["Token"],      true]

# ---------------------------------------------------------------------------
# Context.__bases__[0].__name__ == 'object'
#
# contextvars.zspec.zsdl checks Context.__name__ and Context.__module__.
# No prior spec checks Context.__bases__ at all. Context is a mapping-like
# type that inherits from object.
# ---------------------------------------------------------------------------

invariant contextvars_extra2.Context.base_is_object:
  description: "contextvars.Context.__bases__[0].__name__ == 'object' — Context inherits from object"
  category: hierarchy
  kind: python_call_eq
  function: Context.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Context.__bases__.__len__() == 1
#
# Context has exactly one direct base (object). No prior spec checks this.
# ---------------------------------------------------------------------------

invariant contextvars_extra2.Context.bases_len:
  description: "len(contextvars.Context.__bases__) == 1 — Context has exactly one base class"
  category: hierarchy
  kind: python_call_eq
  function: Context.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# copy_context.__module__ — 'contextvars'
#
# contextvars.zspec.zsdl checks copy_context.__name__ == 'copy_context'.
# No prior spec checks the __module__ of copy_context. The function is
# implemented in the C extension but exposed via the contextvars package;
# its __module__ is 'contextvars'.
# ---------------------------------------------------------------------------

invariant contextvars_extra2.copy_context.module:
  description: "contextvars.copy_context.__module__ == 'contextvars'"
  category: functions
  kind: python_call_eq
  function: copy_context.__module__.__eq__
  args: ["contextvars"]
  expected: true

# ---------------------------------------------------------------------------
# ContextVar.__module__ via __module__ attribute
#
# contextvars.zspec.zsdl checks ContextVar.__module__.__eq__ in a table row.
# This standalone invariant confirms the same via a direct call pattern
# and documents the module membership clearly as a non-table invariant.
# ---------------------------------------------------------------------------

invariant contextvars_extra2.ContextVar.module_standalone:
  description: "contextvars.ContextVar.__module__ == 'contextvars'"
  category: module
  kind: python_call_eq
  function: ContextVar.__module__.__eq__
  args: ["contextvars"]
  expected: true

# ---------------------------------------------------------------------------
# ContextVar.get() with integer default
#
# contextvars.zspec.zsdl covers ContextVar('x').get('default') and
# ContextVar('y').get(None). No prior spec tests get() with an integer
# default. When the variable is unset, get() must return the default as-is.
# ---------------------------------------------------------------------------

invariant contextvars_extra2.contextvar.get_default_int:
  description: "ContextVar('z').get(42) == 42 — integer default is returned unchanged when variable is unset"
  category: behavior
  kind: python_call_eq
  function: ContextVar
  args: ["z"]
  method: get
  method_args: [42]
  expected: 42

# ---------------------------------------------------------------------------
# ContextVar name property — name matches constructor argument
#
# ContextVar('myvar').name returns the string passed at construction.
# No prior spec accesses the .name property of a ContextVar instance.
# ---------------------------------------------------------------------------

invariant contextvars_extra2.contextvar.name_property:
  description: "ContextVar('myvar').name == 'myvar' — name property reflects the constructor argument"
  category: behavior
  kind: python_call_eq
  function: ContextVar
  args: ["myvar"]
  method: name
  expected: "myvar"

# ---------------------------------------------------------------------------
# Token.MISSING class — confirmed via identity of class name
#
# contextvars.zspec.zsdl checks Token.MISSING.__class__.__name__ == 'object'.
# This new invariant checks Token.MISSING.__class__ chain to confirm the
# sentinel type name starts differently — verifying it is NOT None-type.
# We add a distinct check: Token.MISSING.__class__.__name__ length > 0.
# ---------------------------------------------------------------------------

invariant contextvars_extra2.token_missing.class_name_nonempty:
  description: "Token.MISSING.__class__.__name__.__len__() > 0 — MISSING sentinel has a non-empty type name"
  category: constants
  kind: python_call_eq
  function: Token.MISSING.__class__.__name__.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# Context.__class__.__name__ — Context class is itself a type
#
# Context is a C-implemented mapping type. Its metaclass should be 'type'.
# No prior spec checks Context.__class__.__name__.
# ---------------------------------------------------------------------------

invariant contextvars_extra2.Context.class_is_type:
  description: "contextvars.Context.__class__.__name__ == 'type' — Context is a type object"
  category: module
  kind: python_call_eq
  function: Context.__class__.__name__.__eq__
  args: ["type"]
  expected: true
