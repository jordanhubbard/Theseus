spec: asyncio_extra191
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — Python asyncio.Queue documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "asyncio.Queue.__name__ == 'Queue' (len=5: Q(1)u(2)e(3)u(4)e(5)); Queue is the pure-Python FIFO queue class for coroutine producer-consumer patterns."
    - "asyncio.Queue.__module__ == 'asyncio.queues' (len=14: 'asyncio'=7+'.'=1+'queues'=6=14); not '_asyncio' — Queue is not C-accelerated unlike asyncio.Task and asyncio.Future."
    - "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin' (len=15: '_'=1+'Loop'=4+'Bound'=5+'Mixin'=5=15); Queue inherits from the private _LoopBoundMixin mixin rather than directly from object."
    - "asyncio.Queue.__init__.__qualname__ == 'Queue.__init__' (len=14: 'Queue'=5+'.'=1+'__init__'=8=14)."
    - "asyncio.Queue.put.__qualname__ == 'Queue.put' (len=9: 'Queue'=5+'.'=1+'put'=3=9); put is a coroutine."
    - "asyncio.Queue.get.__qualname__ == 'Queue.get' (len=9: same as put); get is a coroutine."
    - "asyncio.Queue.put_nowait.__qualname__ == 'Queue.put_nowait' (len=16: 'Queue'=5+'.'=1+'put_nowait'=10=16); non-blocking variant of put."
    - "asyncio.Queue.get_nowait.__qualname__ == 'Queue.get_nowait' (len=16: same as put_nowait); non-blocking variant of get."
    - "Length ordering: put==get (9) < __init__ (14) < put_nowait==get_nowait (16); nowait variants (10 chars each) are the longest method names."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Queue class identity — __name__, __module__, __bases__[0].__name__
#
# Queue.__name__ == 'Queue' (len=5)
# Queue.__module__ == 'asyncio.queues' (len=14)
# Queue.__bases__[0].__name__ == '_LoopBoundMixin' (len=15)
# ---------------------------------------------------------------------------

table asyncio_extra191.asyncio_queue_class_identity:
  description: "asyncio.Queue class identity checks in asyncioqueue191 namespace — Queue.__name__=='Queue' (len=5: pure-Python FIFO coroutine-safe queue); Queue.__module__=='asyncio.queues' (len=14: 'asyncio'=7+'.'=1+'queues'=6=14; pure Python — unlike asyncio.Future/__module__=='_asyncio'); Queue.__bases__[0].__name__=='_LoopBoundMixin' (len=15: '_'=1+'Loop'=4+'Bound'=5+'Mixin'=5=15; private mixin that ties the queue to the running event loop and raises RuntimeError if used outside a running loop); Queue.__name__.__len__()==5 ('Queue'=5; compare PriorityQueue=13, LifoQueue=9); Queue.__module__.__len__()==14 ('asyncio.queues'=14; compare 'asyncio.locks'=13 — queues is 1 char longer); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioqueue191

  columns: [id, function, args, expected, description]
  rows:
    - [queue_name_eq,    asyncio.Queue.__name__.__eq__,    ["Queue"],           true, "asyncio.Queue.__name__ == 'Queue' (len=5: FIFO coroutine-safe queue class); verified Python 3.14.3"]
    - [queue_name_len,   asyncio.Queue.__name__.__len__,   [],                  5,    "asyncio.Queue.__name__.__len__() == 5 ('Queue'=5); put==get qualname (9) > name (5) by 4; verified Python 3.14.3"]
    - [queue_module_eq,  asyncio.Queue.__module__.__eq__,  ["asyncio.queues"],  true, "asyncio.Queue.__module__ == 'asyncio.queues' (len=14; pure Python, not '_asyncio'); verified Python 3.14.3"]
    - [queue_module_len, asyncio.Queue.__module__.__len__, [],                  14,   "asyncio.Queue.__module__.__len__() == 14 ('asyncio.queues'=14; 'asyncio.locks'=13 — queues is 1 longer); verified Python 3.14.3"]
    - ["queue_base_eq",  "asyncio.Queue.__bases__[0].__name__.__eq__",          ["_LoopBoundMixin"], true, "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin' (len=15; Queue inherits from private _LoopBoundMixin mixin); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.Queue.__init__ and put/get qualname identity
#
# Queue.__init__.__qualname__ == 'Queue.__init__' (len=14)
# Queue.put.__qualname__ == 'Queue.put' (len=9)
# Queue.get.__qualname__ == 'Queue.get' (len=9)
# ---------------------------------------------------------------------------

table asyncio_extra191.asyncio_queue_init_put_get_qualnames:
  description: "asyncio.Queue __init__, put, get qualname identity in asyncioqueue191 namespace — Queue.__init__.__qualname__=='Queue.__init__' (len=14: 'Queue'=5+'.'=1+'__init__'=8=14; initializes _queue deque, _maxsize, _getters, _putters waiter sets); Queue.put.__qualname__=='Queue.put' (len=9: 'Queue'=5+'.'=1+'put'=3=9; coroutine: blocks when full until a consumer calls get()); Queue.get.__qualname__=='Queue.get' (len=9: same length as put; coroutine: blocks when empty until a producer calls put()); put==get at length 9; __init__ (14) > put==get (9) by 5; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioqueue191

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname_eq,  "asyncio.Queue.__init__.__qualname__.__eq__", ["Queue.__init__"], true, "asyncio.Queue.__init__.__qualname__ == 'Queue.__init__' (len=14); initializes internal deque, maxsize, waiter sets; verified Python 3.14.3"]
    - [init_qualname_len, "asyncio.Queue.__init__.__qualname__.__len__", [],               14,   "asyncio.Queue.__init__.__qualname__.__len__() == 14 ('Queue.__init__'=14: 'Queue'=5+'.'=1+'__init__'=8=14); verified Python 3.14.3"]
    - [put_qualname_eq,   asyncio.Queue.put.__qualname__.__eq__,        ["Queue.put"],     true, "asyncio.Queue.put.__qualname__ == 'Queue.put' (len=9; coroutine that blocks when queue is full); verified Python 3.14.3"]
    - [put_qualname_len,  asyncio.Queue.put.__qualname__.__len__,       [],               9,    "asyncio.Queue.put.__qualname__.__len__() == 9 ('Queue.put'=9: 'Queue'=5+'.'=1+'put'=3=9; put==get at 9); verified Python 3.14.3"]
    - [get_qualname_eq,   asyncio.Queue.get.__qualname__.__eq__,        ["Queue.get"],     true, "asyncio.Queue.get.__qualname__ == 'Queue.get' (len=9; coroutine that blocks when queue is empty); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Queue put_nowait and get_nowait qualname identity
#
# Queue.put_nowait.__qualname__ == 'Queue.put_nowait' (len=16)
# Queue.get_nowait.__qualname__ == 'Queue.get_nowait' (len=16)
# ---------------------------------------------------------------------------

table asyncio_extra191.asyncio_queue_nowait_qualnames:
  description: "asyncio.Queue put_nowait and get_nowait qualname identity in asyncioqueue191 namespace — Queue.put_nowait.__qualname__=='Queue.put_nowait' (len=16: 'Queue'=5+'.'=1+'put_nowait'=10=16; raises asyncio.QueueFull immediately when the queue is full, unlike put() which suspends); Queue.get_nowait.__qualname__=='Queue.get_nowait' (len=16: same length as put_nowait; raises asyncio.QueueEmpty immediately when empty, unlike get() which suspends); put_nowait==get_nowait at length 16; length ordering: put==get (9) < __init__ (14) < put_nowait==get_nowait (16); nowait variants (10-char method portion) are the longest method names in this spec; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioqueue191

  columns: [id, function, args, expected, description]
  rows:
    - [put_nowait_eq,   asyncio.Queue.put_nowait.__qualname__.__eq__,  ["Queue.put_nowait"], true, "asyncio.Queue.put_nowait.__qualname__ == 'Queue.put_nowait' (len=16; raises QueueFull immediately if full); verified Python 3.14.3"]
    - [put_nowait_len,  asyncio.Queue.put_nowait.__qualname__.__len__, [],                  16,   "asyncio.Queue.put_nowait.__qualname__.__len__() == 16 ('Queue.put_nowait'=16; put_nowait==get_nowait at 16); verified Python 3.14.3"]
    - [get_nowait_eq,   asyncio.Queue.get_nowait.__qualname__.__eq__,  ["Queue.get_nowait"], true, "asyncio.Queue.get_nowait.__qualname__ == 'Queue.get_nowait' (len=16; raises QueueEmpty immediately if empty); verified Python 3.14.3"]
    - [get_nowait_len,  asyncio.Queue.get_nowait.__qualname__.__len__, [],                  16,   "asyncio.Queue.get_nowait.__qualname__.__len__() == 16 ('Queue.get_nowait'=16; same as put_nowait; longest in spec); verified Python 3.14.3"]
    - [put_eq_get_len,  asyncio.Queue.put.__qualname__.__len__,        [],                  9,    "asyncio.Queue.put.__qualname__.__len__() == 9 confirms put==get (9) < __init__ (14) < nowait pair (16); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra191
# ---------------------------------------------------------------------------

invariant asyncio_extra191.asyncio_Queue_name_eq:
  description: "asyncio.Queue.__name__.__eq__('Queue') returns True — asyncio.Queue is the pure-Python FIFO coroutine-safe queue for producer-consumer asyncio patterns; Queue.__name__=='Queue' (len=5: Q(1)u(2)e(3)u(4)e(5)); Queue is distinct from asyncio.PriorityQueue (len=13) and asyncio.LifoQueue (len=9) which subclass it; Queue.__module__=='asyncio.queues' (pure Python) distinguishes it from asyncio.Future and asyncio.Task which are C-accelerated with __module__=='_asyncio'; NEW in extra191: first standalone Queue.__name__.__eq__ invariant in asyncioqueue191 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

invariant asyncio_extra191.asyncio_Queue_module_eq:
  description: "asyncio.Queue.__module__.__eq__('asyncio.queues') returns True — asyncio.Queue is defined in Lib/asyncio/queues.py; Queue.__module__=='asyncio.queues' (len=14: 'asyncio'=7+'.'=1+'queues'=6=14); this distinguishes Queue (pure Python) from asyncio.Future and asyncio.Task which have __module__=='_asyncio' (len=8; C extension); length ordering for asyncio submodule paths: '_asyncio'=8 < 'asyncio.tasks'=13 == 'asyncio.locks'=13 < 'asyncio.queues'=14 < 'asyncio.futures'=15; NEW in extra191: standalone Queue.__module__ invariant confirming pure-Python identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra191.asyncio_Queue_base_is_LoopBoundMixin:
  description: "asyncio.Queue.__bases__[0].__name__.__eq__('_LoopBoundMixin') returns True — asyncio.Queue inherits from _LoopBoundMixin (a private mixin class in Lib/asyncio/queues.py); __bases__[0].__name__=='_LoopBoundMixin' (len=15: '_'=1+'Loop'=4+'Bound'=5+'Mixin'=5=15); _LoopBoundMixin binds the queue to the running event loop and raises RuntimeError if a queue method is called outside a running loop; this differs from asyncio.Lock, Event, Semaphore, Condition which inherit from _ContextManagerMixin; Queue does NOT support 'async with' — it uses 'await put()/get()' instead; compare: asyncio.PriorityQueue.__bases__[0].__name__=='Queue', asyncio.LifoQueue.__bases__[0].__name__=='Queue' — the subqueue classes inherit from Queue not from _LoopBoundMixin directly; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Queue.__bases__[0].__name__.__eq__"
  args: ["_LoopBoundMixin"]
  expected: true

invariant asyncio_extra191.asyncio_Queue_init_qualname_eq:
  description: "asyncio.Queue.__init__.__qualname__.__eq__('Queue.__init__') returns True — Queue.__init__.__qualname__=='Queue.__init__' (len=14: 'Queue'=5+'.'=1+'__init__'=8=14); Queue.__init__ initializes the internal collections.deque (_queue), maxsize limit, and two sets of asyncio.Future waiters (_getters for blocked get() callers, _putters for blocked put() callers); the maxsize=0 default means the queue is unbounded; __init__ (14) is longer than put==get (9) by 5 and shorter than put_nowait==get_nowait (16) by 2; NEW in extra191: first standalone Queue.__init__.__qualname__ invariant in asyncioqueue191 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Queue.__init__.__qualname__.__eq__"
  args: ["Queue.__init__"]
  expected: true

invariant asyncio_extra191.asyncio_Queue_put_qualname_eq:
  description: "asyncio.Queue.put.__qualname__.__eq__('Queue.put') returns True — Queue.put.__qualname__=='Queue.put' (len=9: 'Queue'=5+'.'=1+'put'=3=9); Queue.put is a coroutine that suspends the caller when the queue is at capacity (maxsize > 0 and qsize() >= maxsize) until a consumer calls get() and wakes a putter; put() resolves waiters in FIFO order; put==get at qualname length 9 (both 3-char method names yield the same qualified length); 'put' (3 chars) < 'get' (3 chars): both are the same; compare nowait variants: put_nowait (10 chars) produces qualname length 16 — 7 more than put; NEW in extra191: standalone Queue.put.__qualname__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.put.__qualname__.__eq__
  args: ["Queue.put"]
  expected: true

invariant asyncio_extra191.asyncio_Queue_get_qualname_eq:
  description: "asyncio.Queue.get.__qualname__.__eq__('Queue.get') returns True — Queue.get.__qualname__=='Queue.get' (len=9: 'Queue'=5+'.'=1+'get'=3=9); Queue.get is a coroutine that suspends the caller when the queue is empty until a producer calls put() and wakes a getter; get() is the consumer side of the asyncio producer-consumer pattern; get==put at qualname length 9 (symmetric); 'get' and 'put' are both 3-char method names yielding identical qualname lengths; compare: get_nowait (10 chars) produces qualname length 16; NEW in extra191: standalone Queue.get.__qualname__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.get.__qualname__.__eq__
  args: ["Queue.get"]
  expected: true

invariant asyncio_extra191.asyncio_Queue_put_nowait_qualname_eq:
  description: "asyncio.Queue.put_nowait.__qualname__.__eq__('Queue.put_nowait') returns True — Queue.put_nowait.__qualname__=='Queue.put_nowait' (len=16: 'Queue'=5+'.'=1+'put_nowait'=10=16); put_nowait is the non-blocking variant: it raises asyncio.QueueFull immediately (synchronously) when the queue is at capacity rather than suspending; put_nowait is useful in synchronous code that interacts with an asyncio queue (e.g., a synchronous callback that needs to enqueue items); length ordering: put==get (9) < __init__ (14) < put_nowait==get_nowait (16); put_nowait (16) is 2 chars longer than __init__ (14) and 7 chars longer than put (9); NEW in extra191: standalone Queue.put_nowait.__qualname__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.put_nowait.__qualname__.__eq__
  args: ["Queue.put_nowait"]
  expected: true

invariant asyncio_extra191.asyncio_Queue_get_nowait_qualname_eq:
  description: "asyncio.Queue.get_nowait.__qualname__.__eq__('Queue.get_nowait') returns True — Queue.get_nowait.__qualname__=='Queue.get_nowait' (len=16: 'Queue'=5+'.'=1+'get_nowait'=10=16); get_nowait is the non-blocking variant: it raises asyncio.QueueEmpty immediately (synchronously) when the queue has no items rather than suspending; get_nowait==put_nowait at qualname length 16 — the nowait pair forms a 2-way tie at the maximum length in this spec; get_nowait (16) > __init__ (14) > put==get (9); NEW in extra191: standalone Queue.get_nowait.__qualname__ invariant completing the 8-invariant qualname coverage for asyncio.Queue; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.get_nowait.__qualname__.__eq__
  args: ["Queue.get_nowait"]
  expected: true
