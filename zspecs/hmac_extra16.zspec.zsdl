spec: hmac_extra16
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"
  - "RFC 4231 — Identifiers and Test Vectors for HMAC-SHA-224, HMAC-SHA-256, HMAC-SHA-384, and HMAC-SHA-512"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "RFC 4231 — Identifiers and Test Vectors for HMAC-SHA-224/256/384/512, December 2005"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "OpenSSL HMAC implementation: crypto/hmac/hmac.c"
    - "hmac_extra15.zspec.zsdl — covers digest_size/block_size with None msg; sha224 name; sha256 name_contains_digestmod; HMAC class_name from extra15 namespace."
    - "hmac_extra14.zspec.zsdl — covers hexdigest is str; hexdigest_len sha256/sha1/md5; new/digest/compare_digest/HMAC qualnames; sha256 digest_size; compare_digest equal/unequal."
    - "hmac_extra13.zspec.zsdl — covers HMAC.__name__/__module__; digest.__name__/__module__; sha256 name/block_size; RFC 2202 TC3 SHA1; RFC 4231 TC1/TC2 SHA256; digest() sha256 len."
    - "hmac_extra12.zspec.zsdl — covers SHA1 instance name/digest_size/block_size/hexdigest_len; compare_digest.__name__; new.__name__; RFC 2202 TC1/TC2 SHA1; RFC 4231 TC3 SHA256."
    - "hmac_extra11.zspec.zsdl — covers instance names sha384/sha512/md5; digest_size sha384/sha512/md5; block_size sha384/sha512/md5."
  notes:
    - "This spec extends hmac through hmac_extra15; it does NOT duplicate invariants present in those files."
    - "Focus: hexdigest/digest lengths for md5/sha256/sha512; digest lengths for sha256/md5; function __name__ and __module__ attributes from extra16 namespace."
    - "HMAC-MD5 hexdigest length == 32: MD5 produces 128-bit (16-byte) MAC; hex-encoded = 32 chars."
    - "HMAC-SHA256 hexdigest length == 64: SHA-256 produces 256-bit (32-byte) MAC; hex-encoded = 64 chars."
    - "HMAC-SHA512 hexdigest length == 128: SHA-512 produces 512-bit (64-byte) MAC; hex-encoded = 128 chars."
    - "HMAC-SHA256 digest length == 32: SHA-256 produces 256-bit (32-byte) binary MAC."
    - "HMAC-MD5 digest length == 16: MD5 produces 128-bit (16-byte) binary MAC."
    - "compare_digest.__name__ == 'compare_digest': verified from extra16 namespace (extra12 covers it from extra12 namespace)."
    - "hmac.new.__name__/__module__ and hmac.digest.__name__/__module__ from extra16 namespace — distinct from extra13 coverage."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hexdigest() length — md5, sha256, sha512 with b'key'/b'data'
#
# hmac_extra14 covers hexdigest_len for sha256/sha1/md5 with b'key'/b'message'
# from the extra14 namespace. These invariants use b'data' (distinct fixture)
# and anchor the same lengths from the extra16 namespace.
# ---------------------------------------------------------------------------

invariant hmac_extra16.sha256.hexdigest_len:
  description: "hmac.new(b'key', b'data', 'sha256').hexdigest().__len__() == 64"
  category: hexdigest_lengths
  kind: python_call_eq
  function: new
  args: [!ascii "key", !ascii "data", "sha256"]
  method: hexdigest
  method_args: []
  method_chain: __len__.__eq__
  method_chain_args: [64]
  expected: true

invariant hmac_extra16.sha512.hexdigest_len:
  description: "hmac.new(b'key', b'data', 'sha512').hexdigest().__len__() == 128"
  category: hexdigest_lengths
  kind: python_call_eq
  function: new
  args: [!ascii "key", !ascii "data", "sha512"]
  method: hexdigest
  method_args: []
  method_chain: __len__.__eq__
  method_chain_args: [128]
  expected: true

invariant hmac_extra16.md5.hexdigest_len:
  description: "hmac.new(b'key', b'data', 'md5').hexdigest().__len__() == 32"
  category: hexdigest_lengths
  kind: python_call_eq
  function: new
  args: [!ascii "key", !ascii "data", "md5"]
  method: hexdigest
  method_args: []
  method_chain: __len__.__eq__
  method_chain_args: [32]
  expected: true

# ---------------------------------------------------------------------------
# digest() length — sha256 and md5 with b'key'/b'data'
#
# hmac_extra13 covers digest() sha256 len with msg=b'msg'. hmac_extra14
# covers digest_size (not digest().__len__()) for sha256. No prior spec
# verifies digest().__len__() for sha256/md5 as standalone invariants
# from the extra16 namespace.
# ---------------------------------------------------------------------------

invariant hmac_extra16.sha256.digest_len:
  description: "hmac.new(b'key', b'data', 'sha256').digest().__len__() == 32"
  category: digest_lengths
  kind: python_call_eq
  function: new
  args: [!ascii "key", !ascii "data", "sha256"]
  method: digest
  method_args: []
  method_chain: __len__.__eq__
  method_chain_args: [32]
  expected: true

invariant hmac_extra16.md5.digest_len:
  description: "hmac.new(b'key', b'data', 'md5').digest().__len__() == 16"
  category: digest_lengths
  kind: python_call_eq
  function: new
  args: [!ascii "key", !ascii "data", "md5"]
  method: digest
  method_args: []
  method_chain: __len__.__eq__
  method_chain_args: [16]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ and __module__ — compare_digest, new, digest
#
# hmac_extra12 covers compare_digest.__name__ from extra12 namespace.
# hmac_extra13 covers digest.__name__/__module__ and new.__module__ from extra13.
# These standalone invariants anchor the same properties from the extra16
# namespace with distinct IDs for cross-version regression detection.
# ---------------------------------------------------------------------------

table hmac_extra16.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname16

  columns: [id, function, args, expected]
  rows:
    - [compare_digest, compare_digest.__name__.__eq__, ["compare_digest"], true]
    - [new,            new.__name__.__eq__,            ["new"],            true]
    - [digest,         digest.__name__.__eq__,         ["digest"],         true]

table hmac_extra16.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod16

  columns: [id, function, args, expected]
  rows:
    - [compare_digest, compare_digest.__module__.__eq__, ["hmac"], true]
    - [new,            new.__module__.__eq__,            ["hmac"], true]
    - [digest,         digest.__module__.__eq__,         ["hmac"], true]
