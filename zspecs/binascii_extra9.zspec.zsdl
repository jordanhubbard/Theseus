spec: binascii_extra9
version: ">=3.9"
backend: python_module(binascii)

docs: https://docs.python.org/3/library/binascii.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/binascii.html — Python binascii documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/binascii.c"
    - "binascii_extra8.zspec.zsdl — covers crc32(b'')==0; a2b_hex/b2a_hex hello/world round-trips; a2b_hex/__name__ and b2a_hex/__name__ standalone; crc32(b'abc')."
    - "binascii_extra7.zspec.zsdl — covers hexlify/unhexlify/b2a_base64/a2b_base64/crc32/crc_hqx __name__ standalone; __module__ table; hexlify(b'hi')/unhexlify(b'6869') values."
    - "binascii_extra6.zspec.zsdl — covers b2a_base64/a2b_base64 vectors; crc32/crc_hqx values; hexlify separator; unhexlify raises."
    - "binascii_extra4.zspec.zsdl — covers __module__ for unhexlify/b2a_hex/a2b_hex/crc_hqx/b2a_base64/a2b_base64; Error/Incomplete __module__; __qualname__ table."
    - "binascii_extra3.zspec.zsdl — covers hexlify(b'hello')/unhexlify(b'68656c6c6f'); crc32(b'hello')==907060870; a2b_base64(b'aGVsbG8=')==b'hello'; Error class."
    - "binascii_extra2.zspec.zsdl — covers crc_hqx(b'',0)==0; __name__ table for hexlify/unhexlify/crc32/crc_hqx; __module__ table."
  notes:
    - "This spec extends binascii through binascii_extra8 with Error/Incomplete class hierarchy and function __module__ attributes."
    - "binascii.Error.__bases__[0].__name__ == 'ValueError': binascii.Error derives from ValueError, not Exception."
    - "binascii.Incomplete.__bases__[0].__name__ == 'Exception': Incomplete derives directly from Exception."
    - "binascii.hexlify.__module__ == 'binascii': C extension function; module is the module name, not '_binascii'."
    - "binascii.unhexlify.__module__ == 'binascii': same as hexlify."
    - "binascii.crc32.__module__ == 'binascii': C builtin; __module__ reports 'binascii'."
    - "binascii.crc_hqx.__module__ == 'binascii': C builtin; __module__ reports 'binascii'."
    - "binascii.Error.__name__ == 'Error' and __module__ == 'binascii'."
    - "binascii.Incomplete.__name__ == 'Incomplete' and __module__ == 'binascii'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Error.__bases__[0].__name__ == 'ValueError' (extra9 namespace)
#
# binascii.Error is unusual: it derives from ValueError rather than Exception
# directly, meaning callers can catch it as a ValueError.
# binascii_extra3 covers Error as a class but not its __bases__.
# No prior spec covers Error.__bases__[0].__name__.
# Verified: binascii.Error.__bases__[0].__name__ == 'ValueError'.
# ---------------------------------------------------------------------------

invariant binascii_extra9.Error.bases0.name:
  description: "binascii.Error.__bases__[0].__name__ == 'ValueError' — Error derives from ValueError, not Exception"
  category: class_hierarchy
  kind: python_call_eq
  function: "Error.__bases__[0].__name__.__eq__"
  args: ["ValueError"]
  expected: true

# ---------------------------------------------------------------------------
# Incomplete.__bases__[0].__name__ == 'Exception' (extra9 namespace)
#
# binascii.Incomplete derives directly from Exception. No prior spec covers
# Incomplete.__bases__[0].__name__.
# Verified: binascii.Incomplete.__bases__[0].__name__ == 'Exception'.
# ---------------------------------------------------------------------------

invariant binascii_extra9.Incomplete.bases0.name:
  description: "binascii.Incomplete.__bases__[0].__name__ == 'Exception' — Incomplete derives from Exception"
  category: class_hierarchy
  kind: python_call_eq
  function: "Incomplete.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# Error and Incomplete — __name__ attributes (extra9 namespace)
#
# binascii_extra3 anchors Error as a class; no prior spec covers
# Error.__name__ or Incomplete.__name__ as standalone invariants.
# Verified: binascii.Error.__name__ == 'Error'
#           binascii.Incomplete.__name__ == 'Incomplete'
# ---------------------------------------------------------------------------

invariant binascii_extra9.Error.name:
  description: "binascii.Error.__name__ == 'Error' — class name attribute in extra9 namespace"
  category: class_attrs
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant binascii_extra9.Incomplete.name:
  description: "binascii.Incomplete.__name__ == 'Incomplete' — class name attribute in extra9 namespace"
  category: class_attrs
  kind: python_call_eq
  function: Incomplete.__name__.__eq__
  args: ["Incomplete"]
  expected: true

# ---------------------------------------------------------------------------
# crc_hqx.__module__ (extra9 namespace)
#
# binascii_extra2 covers crc_hqx in a __module__ table from the extra2
# namespace. No prior spec covers crc_hqx.__module__ as a standalone
# invariant from the extra9 namespace.
# Verified: binascii.crc_hqx.__module__ == 'binascii'.
# ---------------------------------------------------------------------------

invariant binascii_extra9.crc_hqx.module:
  description: "binascii.crc_hqx.__module__ == 'binascii' — extra9 namespace anchor"
  category: module_identity
  kind: python_call_eq
  function: crc_hqx.__module__.__eq__
  args: ["binascii"]
  expected: true

# ---------------------------------------------------------------------------
# Table: __module__ for hexlify, unhexlify, crc32, crc_hqx, a2b_hex, b2a_hex
#        (extra9 namespace)
#
# binascii_extra2 covers __module__ for hexlify/unhexlify/crc32/crc_hqx in a
# table from the extra2 namespace. binascii_extra4 covers __module__ for
# unhexlify/b2a_hex/a2b_hex/crc_hqx/b2a_base64/a2b_base64 in a table.
# This table re-anchors the six core functions under the extra9 namespace
# and adds a2b_hex/b2a_hex alongside the other four, which were not grouped
# together in a single table in any prior spec from this namespace.
# ---------------------------------------------------------------------------

table binascii_extra9.function_modules:
  description: "binascii core C functions all report __module__ == 'binascii'"
  kind: python_call_eq
  category: module_identity

  columns: [id, function, args, expected]
  rows:
    - [hexlify,   hexlify.__module__.__eq__,   ["binascii"], true]
    - [unhexlify, unhexlify.__module__.__eq__,  ["binascii"], true]
    - [crc32,     crc32.__module__.__eq__,      ["binascii"], true]
    - [crc_hqx,   crc_hqx.__module__.__eq__,   ["binascii"], true]
    - [a2b_hex,   a2b_hex.__module__.__eq__,   ["binascii"], true]
    - [b2a_hex,   b2a_hex.__module__.__eq__,   ["binascii"], true]
