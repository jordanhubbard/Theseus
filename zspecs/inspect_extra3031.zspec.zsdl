spec: in3031
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 649 (in3031): __missing__, __init_subclass__, __class_getitem__ dict-presence checks for inspect types."
    - "None of the inspect types define __missing__, __init_subclass__, or __class_getitem__ in their own __dict__."
    - "inspect.Parameter, inspect.Signature, inspect.BoundArguments are pure Python introspection classes."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec are namedtuple subclasses."
    - "inspect.Attribute is a namedtuple subclass used by getmembers_static."
    - "inspect.ClassFoundException and inspect.EndOfBlock are internal exception/sentinel classes."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3031.missing:
  description: "inspect types __missing__ dict-presence checks; wave 649"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in3031
  columns: [id, function, args, expected]
  rows:
    - ["in3031001", operator.contains, [inspect.Parameter.__dict__,          "__missing__"], false]
    - ["in3031002", operator.contains, [inspect.Signature.__dict__,          "__missing__"], false]
    - ["in3031003", operator.contains, [inspect.BoundArguments.__dict__,     "__missing__"], false]
    - ["in3031004", operator.contains, [inspect.FrameInfo.__dict__,          "__missing__"], false]
    - ["in3031005", operator.contains, [inspect.ArgInfo.__dict__,            "__missing__"], false]
    - ["in3031006", operator.contains, [inspect.FullArgSpec.__dict__,        "__missing__"], false]
    - ["in3031007", operator.contains, [inspect.Attribute.__dict__,          "__missing__"], false]
    - ["in3031008", operator.contains, [inspect.ClassFoundException.__dict__, "__missing__"], false]
    - ["in3031009", operator.contains, [inspect.EndOfBlock.__dict__,         "__missing__"], false]

