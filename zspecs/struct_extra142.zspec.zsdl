  description: "struct.__all__.__class__.__name__.__eq__('list') == True — 'list' (4 chars); struct uses a list (not a tuple like hashlib); list ordering: struct(8) < hashlib(19) << socket(238) entries; no prior struct spec anchors this as a standalone; first standalone under structall142"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

