# ---------------------------------------------------------------------------
# struct.__spec__.name.__eq__('struct') — standalone
#
# struct.__spec__.name is 'struct' (6 chars). The ModuleSpec.name attribute
# identifies the public module in the import system. 'struct' (6 chars) ties in
# length with 'socket' (6 chars) — both are 6-char stdlib module names. For
# comparison: 'uuid' is 4 chars, 'struct' and 'socket' are both 6 chars,
# 'hashlib' is 7 chars. Note that struct.__spec__.name is 'struct' (without
# underscore) rather than '_struct' — the private C extension name uses the
# underscore prefix but the ModuleSpec reports the public name. extra97 anchors
# __spec__ lengths; no prior struct spec anchors __spec__.name.__eq__('struct')
# as a standalone under structall142. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra142.spec_name_eq_struct:
  description: "struct.__spec__.name.__eq__('struct') == True — 'struct' (6 chars; public module name without underscore); ties in length with 'socket' (also 6 chars); length ordering: uuid(4) < struct(6) == socket(6) < hashlib(7); extra97 anchors __spec__ length; no prior struct spec anchors this as a standalone; first standalone under structall142"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["struct"]
  expected: true

