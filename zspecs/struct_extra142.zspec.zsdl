# ---------------------------------------------------------------------------
# struct.Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__') — standalone
#
# struct.Struct.__sizeof__.__qualname__ is 'Struct.__sizeof__' (17 chars). The
# qualname follows the 'Struct.<method>' pattern with the 7-char 'Struct.' prefix
# plus the 10-char '__sizeof__'. At 17 chars it is 2 chars longer than
# Struct.__init__ and Struct.__repr__ (both 15 chars = 7 + 8) because '__sizeof__'
# (10 chars) is 2 chars longer than '__init__' and '__repr__' (8 chars each).
# Struct.__sizeof__ is a method_descriptor, while __init__ and __repr__ are
# wrapper_descriptor. No prior struct spec anchors Struct.__sizeof__ qualname as
# a standalone under structall142. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra142.Struct_sizeof_qualname_eq:
  description: "struct.Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__') == True — 'Struct.__sizeof__' (17 chars = 7-char 'Struct.' prefix + 10-char '__sizeof__'); 2 chars longer than __init__/__repr__ (both 15); method_descriptor (not wrapper_descriptor like __init__/__repr__); no prior struct spec anchors this as a standalone; first standalone under structall142"
  category: qualname_identity
  kind: python_call_eq
  function: Struct.__sizeof__.__qualname__.__eq__
  args: ["Struct.__sizeof__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__sizeof__.__qualname__.__len__()==17 — standalone
#
# struct.Struct.__sizeof__.__qualname__.__len__() is 17. The qualname
# 'Struct.__sizeof__' has length 17 (7-char prefix + 10-char '__sizeof__').
# This makes it the longest dunder method qualname on the Struct class among those
# examined: __repr__/__init__ (both 15 chars) < __sizeof__ (17 chars). The
# '__sizeof__' dunder is typically inherited from object and used by sys.getsizeof()
# to measure the memory footprint of a Struct object. For Struct this is a
# method_descriptor (C-level method). No prior struct spec anchors
# Struct.__sizeof__.__qualname__.__len__()==17 as a standalone under structall142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra142.Struct_sizeof_qualname_len_17:
  description: "struct.Struct.__sizeof__.__qualname__.__len__() == 17 — 'Struct.__sizeof__' (17 chars = 7 + 10); longest dunder method qualname on Struct: __repr__/__init__ (both 15) < __sizeof__ (17); used by sys.getsizeof(); method_descriptor (C-level); no prior struct spec anchors this as a standalone; first standalone under structall142"
  category: qualname_lengths
  kind: python_call_eq
  function: Struct.__sizeof__.__qualname__.__len__
  args: []
  expected: 17

