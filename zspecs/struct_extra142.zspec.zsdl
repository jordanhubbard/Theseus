# for pack/calcsize or __spec__.name equality string as a table under structall142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra142.all_function_membership_and_spec:
  description: "struct.__all__.__contains__('pack')==True / __contains__('calcsize')==True / __spec__.name.__eq__('struct')==True / __spec__.name.__len__()==6 — pack and calcsize are among the 6 module-level functions in __all__; __spec__.name 'struct' (6 chars) is the public module name (contrast with _struct C extension, 7 chars); extra97 anchors __spec__ length broadly; first structall142 anchor for __all__ pack/calcsize membership and spec name equality"
  kind: python_call_eq
  category: identity
  id_prefix: structall142

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_pack,      __all__.__contains__,  ["pack"],    true, "struct.__all__.__contains__('pack') == True (4-char name; packs values into bytes per format string)"]
    - [all_contains_calcsize,  __all__.__contains__,  ["calcsize"], true, "struct.__all__.__contains__('calcsize') == True (8-char name; returns byte size for a format string)"]
    - [spec_name_eq_struct,    __spec__.name.__eq__,  ["struct"],   true, "struct.__spec__.name == 'struct' (6 chars; public module name without underscore prefix)"]
    - [spec_name_len_6,        __spec__.name.__len__, [],           6,    "struct.__spec__.name.__len__() is 6 ('struct' = 6 chars; ties with socket.__spec__.name length)"]

# ---------------------------------------------------------------------------
# struct.__loader__.__class__.__name__.__eq__('SourceFileLoader')
# struct.__loader__.__class__.__name__.__len__()==16
# struct.Struct.__init__.__qualname__.__eq__('Struct.__init__')
# struct.Struct.__init__.__qualname__.__len__()==15
#
# Wave 314 theme: struct module loader class and Struct.__init__ qualname.
#
# struct is a pure-Python wrapper (Lib/struct.py), so its loader is SourceFileLoader
# (16 chars). Struct.__init__ has qualname 'Struct.__init__' (15 chars) and is a
# wrapper_descriptor (C-level slot wrapper). extra97 anchors __loader__ length;
# no prior struct spec anchors __loader__.__class__.__name__ equality string or
# Struct.__init__ qualname as a table under structall142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra142.loader_and_init_qualname:
  description: "struct.__loader__/__class__.__name__.__eq__('SourceFileLoader')==True / __class__.__name__.__len__()==16 / Struct.__init__/__qualname__.__eq__('Struct.__init__')==True / __qualname__.__len__()==15 — SourceFileLoader (16 chars) loads Lib/struct.py (pure-Python wrapper around _struct C extension); Struct.__init__ qualname 'Struct.__init__' (15 chars = 7-char prefix + 8-char '__init__'); extra97 anchors __loader__ length; first structall142 anchor for loader class equality and init qualname"
  kind: python_call_eq
  category: identity
  id_prefix: structall142

  columns: [id, function, args, expected, description]
  rows:
    - [loader_SourceFileLoader, __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "struct.__loader__.__class__.__name__ == 'SourceFileLoader' (16 chars; pure-Python source module loader)"]
    - [loader_class_len_16,     __loader__.__class__.__name__.__len__, [],                  16,   "struct.__loader__.__class__.__name__.__len__() is 16 ('SourceFileLoader' = 16 chars)"]
    - [init_qualname_eq,        Struct.__init__.__qualname__.__eq__,  ["Struct.__init__"],  true, "struct.Struct.__init__.__qualname__ == 'Struct.__init__' (15 chars = 7-char 'Struct.' + 8-char '__init__')"]
    - [init_qualname_len,       Struct.__init__.__qualname__.__len__, [],                   15,   "struct.Struct.__init__.__qualname__.__len__() is 15 (7-char 'Struct.' prefix + 8-char '__init__')"]

# ---------------------------------------------------------------------------
# struct.__all__.__class__.__name__.__eq__('list') — standalone
#
# struct.__all__.__class__.__name__ is 'list'. Among the stdlib modules covered
# by this spec series: hashlib.__all__ is a tuple (19 entries), struct.__all__
# is a list (8 entries), socket.__all__ is a list (238 entries). struct and socket
# both use lists, while hashlib uses a tuple. The 8-entry struct list is the smallest
# __all__ of the three. No prior struct spec anchors __all__.__class__.__name__
# == 'list' as a standalone under structall142. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

