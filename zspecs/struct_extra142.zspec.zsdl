spec: struct_extra142
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra141.zspec.zsdl — covers struct.Struct.__module__.__eq__('_struct') / Struct.__qualname__.__eq__('Struct') and __len__()==6 / Struct.__bases__[0].__name__.__eq__('object') / Struct.__mro__.__len__()==2 / Struct.__doc__.__len__()==40 / Struct.__dict__.__class__.__name__.__eq__('mappingproxy') / error.__qualname__.__eq__('error') and __len__()==5 (table + invariants)."
    - "struct_extra140.zspec.zsdl — covers struct.Struct.format/__class__.__name__.__eq__('getset_descriptor') / Struct.size/__class__.__name__.__eq__('getset_descriptor') / Struct.format/__qualname__.__eq__('Struct.format') and __len__()==13 / Struct.size/__qualname__.__eq__('Struct.size') and __len__()==11 / struct.__doc__.__len__()==1278 / struct.error/__doc__ is None (table + invariants)."
    - "struct_extra139.zspec.zsdl — covers struct module-level function __qualname__ string equality (pack/unpack/calcsize/pack_into/unpack_from/iter_unpack) / all six + Struct/__module__.__eq__('_struct') / full __doc__ length ordering (table + invariants)."
    - "struct_extra138.zspec.zsdl — covers Struct method __qualname__ string equality (pack/unpack/pack_into/unpack_from/iter_unpack) / __qualname__ length ordering / error.__name__/__qualname__/__bases__[0].__name__/__bases__[0].__name__.__len__() (table + invariants)."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra141."
    - "Wave 314 theme: struct.__all__ — __all__.__class__.__name__.__eq__('list') / __all__.__len__()==8 / __all__.__contains__('Struct')==True / __all__.__contains__('error')==True / __all__.__contains__('pack')==True / __all__.__contains__('calcsize')==True / struct.__spec__.name.__eq__('struct') (len 6) / struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') (len 16) / Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__') (len 17)."
    - "struct.__all__.__class__.__name__ == 'list' (8 entries). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(struct.__all__) == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'Struct' in struct.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'error' in struct.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'pack' in struct.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'calcsize' in struct.__all__ == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.name == 'struct' (len 6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__loader__.__class__.__name__ == 'SourceFileLoader' (len 16). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__qualname__ == 'Struct.__init__' (len 15). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__repr__.__qualname__ == 'Struct.__repr__' (len 15). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__qualname__ == 'Struct.__sizeof__' (len 17). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__repr__.__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.__all__ is a list (8 entries), unlike hashlib.__all__ which is a tuple. The 8 entries are: calcsize, pack, pack_into, unpack, unpack_from, iter_unpack, Struct, error. The list includes both the 6 module-level functions, the Struct class, and the error exception class."
    - "Note: struct.__spec__.name is 'struct' (6 chars). This is the public module name in the import system. The private C extension _struct (7 chars, with underscore) is not exposed in __spec__.name; the public name 'struct' (without underscore) is always returned."
    - "Note: struct.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars). struct is implemented as a pure-Python wrapper (Lib/struct.py) around the _struct C extension. The Python wrapper is what gets loaded; the C extension is imported within the Python wrapper. This is why the loader is SourceFileLoader rather than ExtensionFileLoader."
    - "Note: struct.Struct.__sizeof__ has qualname 'Struct.__sizeof__' (17 chars = 7-char 'Struct.' prefix + 10-char '__sizeof__'). It is 2 chars longer than Struct.__init__ and Struct.__repr__ (both 15 chars) because '__sizeof__' (10 chars) is 2 chars longer than '__init__' and '__repr__' (8 chars each). Struct.__sizeof__ is a method_descriptor (C-level), while __init__ and __repr__ are wrapper_descriptor (C-level slot wrappers)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__all__.__class__.__name__.__eq__('list')
# struct.__all__.__len__()==8
# struct.__all__.__contains__('Struct')
# struct.__all__.__contains__('error')
#
# Wave 314 theme: struct.__all__ is a list with 8 entries.
#
# struct.__all__ is a list (not a tuple like hashlib.__all__) with 8 entries:
# calcsize, pack, pack_into, unpack, unpack_from, iter_unpack, Struct, error.
# extra97 anchors __spec__/__loader__ attribute lengths; no prior struct spec
# anchors __all__ class name or __contains__ checks as a table under structall142.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra142.all_class_and_membership:
  description: "struct.__all__/__class__.__name__.__eq__('list')==True / __all__.__len__()==8 / __all__.__contains__('Struct')==True / __all__.__contains__('error')==True — __all__ is a list (unlike hashlib's tuple); 8 entries cover 6 module-level functions + Struct class + error exception; extra97 anchors __spec__/__loader__ lengths; first structall142 anchor for __all__ class name, length, and membership"
  kind: python_call_eq
  category: identity
  id_prefix: structall142

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_list,     __all__.__class__.__name__.__eq__, ["list"],   true, "struct.__all__.__class__.__name__ == 'list' (unlike hashlib.__all__ which is a tuple)"]
    - [all_len_8,          __all__.__len__,                   [],         8,    "struct.__all__.__len__() is 8 (6 module-level functions + Struct class + error exception)"]
    - [all_contains_Struct, __all__.__contains__,             ["Struct"], true, "struct.__all__.__contains__('Struct') == True (the compiled struct class)"]
    - [all_contains_error,  __all__.__contains__,             ["error"],  true, "struct.__all__.__contains__('error') == True (the exception class for struct errors)"]

