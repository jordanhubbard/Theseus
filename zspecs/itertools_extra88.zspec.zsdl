table itertools_extra88.names_group3:
  description: "filterfalse/takewhile/dropwhile/count __name__ strings; all C types in itertoolsmodule.c; wave 250; new to extra88"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsnames88

  columns: [id, function, args, expected, description]
  rows:
    - [filterfalse_name_eq_filterfalse,
       filterfalse.__name__.__eq__,
       ["filterfalse"],
       true,
       "itertools.filterfalse.__name__.__eq__('filterfalse') == True — filterfalse is a C extension type in Modules/itertoolsmodule.c that makes an iterator returning elements of an iterable for which a predicate is false; __name__ is 'filterfalse' (11 chars); str.__eq__('filterfalse') returns True; no prior itertools spec checks filterfalse.__name__ via itertoolsnames88; new to extra88"]
    - [takewhile_name_eq_takewhile,
       takewhile.__name__.__eq__,
       ["takewhile"],
       true,
       "itertools.takewhile.__name__.__eq__('takewhile') == True — takewhile is a C extension type in Modules/itertoolsmodule.c that makes an iterator that returns elements from an iterable as long as the predicate is true; __name__ is 'takewhile' (9 chars); str.__eq__('takewhile') returns True; no prior itertools spec checks takewhile.__name__ via itertoolsnames88; new to extra88"]
    - [dropwhile_name_eq_dropwhile,
       dropwhile.__name__.__eq__,
       ["dropwhile"],
       true,
       "itertools.dropwhile.__name__.__eq__('dropwhile') == True — dropwhile is a C extension type in Modules/itertoolsmodule.c that makes an iterator that drops elements from an iterable as long as the predicate is true; __name__ is 'dropwhile' (9 chars); str.__eq__('dropwhile') returns True; no prior itertools spec checks dropwhile.__name__ via itertoolsnames88; new to extra88"]
    - [count_name_eq_count,
       count.__name__.__eq__,
       ["count"],
       true,
       "itertools.count.__name__.__eq__('count') == True — count is a C extension type in Modules/itertoolsmodule.c that makes an iterator that returns evenly spaced values starting with number start; __name__ is 'count' (5 chars); str.__eq__('count') returns True; no prior itertools spec checks count.__name__ via itertoolsnames88; new to extra88"]

