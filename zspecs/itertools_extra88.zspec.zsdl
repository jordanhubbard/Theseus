spec: itertools_extra88
version: ">=3.9"
backend: python_module(itertools)
extends: itertools_extra87

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra87.zspec.zsdl."
    - "This spec covers: itertools C-type __name__ string equality for all iterator types (Wave 250)."
    - "itertools.chain.__name__ == 'chain' — C type in itertoolsmodule.c; __name__ is 'chain'. Verified with Python 3.14.3."
    - "itertools.product.__name__ == 'product' — C type; __name__ is 'product'. Verified with Python 3.14.3."
    - "itertools.combinations.__name__ == 'combinations' — C type; __name__ is 'combinations'. Verified with Python 3.14.3."
    - "itertools.permutations.__name__ == 'permutations' — C type; __name__ is 'permutations'. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' — C type; __name__ is 'combinations_with_replacement'. Verified with Python 3.14.3."
    - "itertools.accumulate.__name__ == 'accumulate' — C type; __name__ is 'accumulate'. Verified with Python 3.14.3."
    - "itertools.groupby.__name__ == 'groupby' — C type; __name__ is 'groupby'. Verified with Python 3.14.3."
    - "itertools.islice.__name__ == 'islice' — C type; __name__ is 'islice'. Verified with Python 3.14.3."
    - "itertools.starmap.__name__ == 'starmap' — C type; __name__ is 'starmap'. Verified with Python 3.14.3."
    - "itertools.filterfalse.__name__ == 'filterfalse' — C type; __name__ is 'filterfalse'. Verified with Python 3.14.3."
    - "itertools.takewhile.__name__ == 'takewhile' — C type; __name__ is 'takewhile'. Verified with Python 3.14.3."
    - "itertools.dropwhile.__name__ == 'dropwhile' — C type; __name__ is 'dropwhile'. Verified with Python 3.14.3."
    - "itertools.count.__name__ == 'count' — C type; __name__ is 'count'. Verified with Python 3.14.3."
    - "itertools.repeat.__name__ == 'repeat' — C type; __name__ is 'repeat'. Verified with Python 3.14.3."
    - "itertools.cycle.__name__ == 'cycle' — C type; __name__ is 'cycle'. Verified with Python 3.14.3."
    - "itertools.zip_longest.__name__ == 'zip_longest' — C type; __name__ is 'zip_longest'. Verified with Python 3.14.3."
    - "For C types, __qualname__ == __name__ (no containing class); chain.__qualname__ == 'chain'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: chain, product, combinations, permutations __name__ strings
#
# Wave 250 theme: itertools C-type __name__ string equality — group 1.
#
# itertools.chain.__name__.__eq__('chain')             == True
# itertools.product.__name__.__eq__('product')         == True
# itertools.combinations.__name__.__eq__('combinations') == True
# itertools.permutations.__name__.__eq__('permutations') == True
#
# Prior spec extra87 checked __mro__.__len__() and __bases__[0].__name__. This spec (extra88) checks __name__. New to extra88.
# ---------------------------------------------------------------------------

table itertools_extra88.names_group1:
  description: "chain/product/combinations/permutations __name__ strings; all C types in itertoolsmodule.c; wave 250; new to extra88"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsnames88

  columns: [id, function, args, expected, description]
  rows:
    - [chain_name_eq_chain,
       chain.__name__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__name__.__eq__('chain') == True — chain is a C extension type in Modules/itertoolsmodule.c that chains multiple iterables together; __name__ is the unqualified type name 'chain' (5 chars); str.__eq__('chain') returns True; prior spec extra87 checked chain.__mro__.__len__() and chain.__bases__[0].__name__; this spec (extra88) checks __name__; new to extra88"]
    - [product_name_eq_product,
       product.__name__.__eq__,
       ["product"],
       true,
       "itertools.product.__name__.__eq__('product') == True — product is a C extension type in Modules/itertoolsmodule.c that computes the Cartesian product of input iterables; __name__ is 'product' (7 chars); str.__eq__('product') returns True; prior spec extra87 checked product.__mro__.__len__(); this spec (extra88) checks __name__; new to extra88"]
    - [combinations_name_eq_combinations,
       combinations.__name__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — combinations is a C extension type in Modules/itertoolsmodule.c that returns r-length subsequences of elements; __name__ is 'combinations' (12 chars); str.__eq__('combinations') returns True; prior spec extra87 checked combinations.__mro__.__len__(); this spec (extra88) checks __name__; new to extra88"]
    - [permutations_name_eq_permutations,
       permutations.__name__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__name__.__eq__('permutations') == True — permutations is a C extension type in Modules/itertoolsmodule.c that returns successive r-length permutations; __name__ is 'permutations' (12 chars); str.__eq__('permutations') returns True; prior spec extra87 checked permutations.__mro__.__len__(); this spec (extra88) checks __name__; new to extra88"]

