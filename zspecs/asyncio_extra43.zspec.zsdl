spec: asyncio_extra43
version: ">=3.11"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio event loop interface"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio coroutines and tasks"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py"
    - "CPython source: Lib/asyncio/runners.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec extends asyncio_extra42.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, QueueFull/__name__.__len__()==9, QueueEmpty/QueueFull __qualname__.__len__(), Runner method __name__/__qualname__.__len__() tables, various function and class lengths, MRO depths for all queue/lock/sync classes, AbstractEventLoop/__name__/__len__() tables, BaseEventLoop/Handle/TimerHandle/Protocol/StreamReader lengths, Event method __qualname__ string values and lengths (extra39), Semaphore acquire/release __qualname__ string values and lengths (extra39/extra40), BoundedSemaphore/__name__/__module__/inherited acquire qualname (extra40), Condition/__name__/__module__/wait qualname (extra40), TaskGroup/__name__/__module__/__bases__[0].__name__, Runner/__name__/__module__, shield/ensure_future/create_task __name__/__module__ (extra41), get_event_loop/__name__/__module__, get_running_loop/__name__/__module__, new_event_loop/__name__/__module__, run/__name__/__module__, iscoroutine/__name__/__module__, iscoroutinefunction/__name__/__module__ (extra42)."
    - "This spec covers: get_event_loop/__qualname__=='get_event_loop' (14 chars); get_running_loop/__qualname__=='get_running_loop' (16 chars); run/__qualname__=='run' (3 chars); sleep/__qualname__=='sleep' (5 chars); gather/__qualname__=='gather' (6 chars); wait/__qualname__=='wait' (4 chars); Queue/__qualname__=='Queue' (5 chars); Lock/__qualname__=='Lock' (4 chars); Event/__qualname__=='Event' (5 chars)."
    - "asyncio.get_event_loop.__qualname__ == 'get_event_loop' (14 chars). For C-extension functions in _asyncio, __qualname__ equals __name__ since there is no class scope; both are 'get_event_loop'. Prior specs in extra42 captured __name__ and __module__; extra43 captures __qualname__."
    - "asyncio.get_running_loop.__qualname__ == 'get_running_loop' (16 chars). Like get_event_loop, this is a C-extension function in _asyncio; its __qualname__ equals __name__. len('get_running_loop') == 16."
    - "asyncio.run.__qualname__ == 'run' (3 chars). asyncio.run is a module-level function in asyncio.runners; its __qualname__ equals __name__ == 'run'. len('run') == 3."
    - "asyncio.sleep.__qualname__ == 'sleep' (5 chars). asyncio.sleep is a coroutine function (async def) defined at module level in asyncio.tasks; its __qualname__ equals its __name__. len('sleep') == 5."
    - "asyncio.gather.__qualname__ == 'gather' (6 chars). asyncio.gather is a coroutine function defined at module level in asyncio.tasks; its __qualname__ equals its __name__. len('gather') == 6."
    - "asyncio.wait.__qualname__ == 'wait' (4 chars). asyncio.wait is a coroutine function defined at module level in asyncio.tasks; its __qualname__ equals its __name__. len('wait') == 4."
    - "asyncio.Queue.__qualname__ == 'Queue' (5 chars). Queue is a top-level class in asyncio.queues; __qualname__ equals __name__ for top-level classes. len('Queue') == 5."
    - "asyncio.Lock.__qualname__ == 'Lock' (4 chars). Lock is a top-level class in asyncio.locks; __qualname__ equals __name__ for top-level classes. len('Lock') == 4."
    - "asyncio.Event.__qualname__ == 'Event' (5 chars). Event is a top-level class in asyncio.locks; __qualname__ equals __name__ for top-level classes. len('Event') == 5."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio event loop function __qualname__ — extra43 namespace
#
# For module-level functions (both C-extension and pure-Python), __qualname__
# equals __name__ since there is no enclosing class scope:
#   get_event_loop.__qualname__ == 'get_event_loop'   (14 chars)
#   get_running_loop.__qualname__ == 'get_running_loop' (16 chars)
#   run.__qualname__             == 'run'              ( 3 chars)
# Prior specs in extra42 captured __name__ and __module__ for these functions.
# Extra43 captures their __qualname__ values for completeness.
# ---------------------------------------------------------------------------

table asyncio_extra43.event_loop_func_qualnames:
  description: "asyncio event loop function __qualname__ string equality in extra43 namespace — get_event_loop, get_running_loop, run"
  kind: python_call_eq
  category: function_names
  id_prefix: asyncelfuncqn43

  columns: [id, function, args, expected, description]
  rows:
    - [get_event_loop,   get_event_loop.__qualname__.__eq__,   ["get_event_loop"],   true, "get_event_loop.__qualname__ == 'get_event_loop' — C-extension; qualname equals name (14 chars)"]
    - [get_running_loop, get_running_loop.__qualname__.__eq__,  ["get_running_loop"], true, "get_running_loop.__qualname__ == 'get_running_loop' — C-extension; qualname equals name (16 chars)"]
    - [run,              run.__qualname__.__eq__,               ["run"],              true, "run.__qualname__ == 'run' — pure-Python module-level function in asyncio.runners (3 chars)"]

# ---------------------------------------------------------------------------
# asyncio coroutine function __qualname__ — extra43 namespace
#
# Three coroutine functions (async def) defined at module level in asyncio.tasks:
#   sleep.__qualname__  == 'sleep'  (5 chars)
#   gather.__qualname__ == 'gather' (6 chars)
#   wait.__qualname__   == 'wait'   (4 chars)
# For module-level async functions, __qualname__ equals __name__. These three
# functions are the primary concurrency primitives in asyncio for coroutine
# scheduling and event coordination.
# ---------------------------------------------------------------------------

table asyncio_extra43.coroutine_func_qualnames:
  description: "asyncio coroutine function __qualname__ string equality in extra43 namespace — sleep, gather, wait"
  kind: python_call_eq
  category: function_names
  id_prefix: asynccorfuncqn43

  columns: [id, function, args, expected, description]
  rows:
    - [sleep,  sleep.__qualname__.__eq__,  ["sleep"],  true, "sleep.__qualname__ == 'sleep' — async def at module level; qualname equals name (5 chars)"]
    - [gather, gather.__qualname__.__eq__, ["gather"], true, "gather.__qualname__ == 'gather' — async def at module level; qualname equals name (6 chars)"]
    - [wait,   wait.__qualname__.__eq__,   ["wait"],   true, "wait.__qualname__ == 'wait' — async def at module level; qualname equals name (4 chars)"]

# ---------------------------------------------------------------------------
# asyncio synchronization class __qualname__ — extra43 namespace
#
# Three synchronization primitive classes defined at module level:
#   Queue.__qualname__ == 'Queue'  (5 chars)
#   Lock.__qualname__  == 'Lock'   (4 chars)
#   Event.__qualname__ == 'Event'  (5 chars)
# For top-level classes, __qualname__ equals __name__. Queue is in asyncio.queues;
# Lock and Event are in asyncio.locks. All three are commonly used for
# coordinating concurrent coroutines within a single event loop.
# ---------------------------------------------------------------------------

table asyncio_extra43.sync_class_qualnames:
  description: "asyncio synchronization class __qualname__ string equality in extra43 namespace — Queue, Lock, Event"
  kind: python_call_eq
  category: class_names
  id_prefix: asyncsyncclsqn43

  columns: [id, function, args, expected, description]
  rows:
    - [Queue, Queue.__qualname__.__eq__, ["Queue"], true, "Queue.__qualname__ == 'Queue' — top-level class in asyncio.queues; qualname equals name (5 chars)"]
    - [Lock,  Lock.__qualname__.__eq__,  ["Lock"],  true, "Lock.__qualname__ == 'Lock' — top-level class in asyncio.locks; qualname equals name (4 chars)"]
    - [Event, Event.__qualname__.__eq__, ["Event"], true, "Event.__qualname__ == 'Event' — top-level class in asyncio.locks; qualname equals name (5 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra43
# ---------------------------------------------------------------------------

invariant asyncio_extra43.get_event_loop_qualname_eq:
  description: "asyncio.get_event_loop.__qualname__ == 'get_event_loop' — C-extension function in _asyncio; qualname equals name for module-level functions (14 chars)"
  category: function_names
  kind: python_call_eq
  function: get_event_loop.__qualname__.__eq__
  args: ["get_event_loop"]
  expected: true

invariant asyncio_extra43.get_running_loop_qualname_eq:
  description: "asyncio.get_running_loop.__qualname__ == 'get_running_loop' — C-extension function in _asyncio; qualname equals name for module-level functions (16 chars)"
  category: function_names
  kind: python_call_eq
  function: get_running_loop.__qualname__.__eq__
  args: ["get_running_loop"]
  expected: true

invariant asyncio_extra43.run_qualname_eq:
  description: "asyncio.run.__qualname__ == 'run' — pure-Python module-level function in asyncio.runners; qualname equals name (3 chars)"
  category: function_names
  kind: python_call_eq
  function: run.__qualname__.__eq__
  args: ["run"]
  expected: true

invariant asyncio_extra43.sleep_qualname_eq:
  description: "asyncio.sleep.__qualname__ == 'sleep' — async def at module level in asyncio.tasks; qualname equals name (5 chars)"
  category: function_names
  kind: python_call_eq
  function: sleep.__qualname__.__eq__
  args: ["sleep"]
  expected: true

invariant asyncio_extra43.gather_qualname_eq:
  description: "asyncio.gather.__qualname__ == 'gather' — async def at module level in asyncio.tasks; qualname equals name (6 chars)"
  category: function_names
  kind: python_call_eq
  function: gather.__qualname__.__eq__
  args: ["gather"]
  expected: true

invariant asyncio_extra43.wait_qualname_eq:
  description: "asyncio.wait.__qualname__ == 'wait' — async def at module level in asyncio.tasks; qualname equals name (4 chars)"
  category: function_names
  kind: python_call_eq
  function: wait.__qualname__.__eq__
  args: ["wait"]
  expected: true

invariant asyncio_extra43.Queue_qualname_eq:
  description: "asyncio.Queue.__qualname__ == 'Queue' — top-level class in asyncio.queues; qualname equals name for top-level classes (5 chars)"
  category: class_names
  kind: python_call_eq
  function: Queue.__qualname__.__eq__
  args: ["Queue"]
  expected: true

invariant asyncio_extra43.Lock_qualname_eq:
  description: "asyncio.Lock.__qualname__ == 'Lock' — top-level class in asyncio.locks; qualname equals name for top-level classes (4 chars)"
  category: class_names
  kind: python_call_eq
  function: Lock.__qualname__.__eq__
  args: ["Lock"]
  expected: true

invariant asyncio_extra43.Event_qualname_eq:
  description: "asyncio.Event.__qualname__ == 'Event' — top-level class in asyncio.locks; qualname equals name for top-level classes (5 chars)"
  category: class_names
  kind: python_call_eq
  function: Event.__qualname__.__eq__
  args: ["Event"]
  expected: true
