spec: abc_extra2176
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Theme: iterator/sequence protocol dict-presence — checks for __iter__, __next__, __aiter__, __anext__, __await__, __length_hint__, __reversed__, __missing__ in class __dict__."
    - "abc.ABCMeta does not define any iterator/sequence protocol methods in its own __dict__."
    - "abc.ABC does not define any iterator/sequence protocol methods in its own __dict__."
    - "abc.abstractmethod does not define any iterator/sequence protocol methods in its own __dict__; it is a plain Python function with an empty __dict__."
    - "Despite abc.ABCMeta being a metaclass that can impose abstract method requirements for __iter__ etc., it does not itself own any iterator protocol method in its __dict__."
    - "abc.ABC is a simple helper class using ABCMeta as its metaclass; it owns no iterator or sequence protocol methods."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

