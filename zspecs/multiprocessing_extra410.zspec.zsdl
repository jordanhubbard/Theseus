spec: multiprocessing_extra410
version: ">=3.9"
backend: python_module(multiprocessing.managers)
docs: https://docs.python.org/3/library/multiprocessing.html#managers
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#managers — multiprocessing managers documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "multiprocessing.managers.SyncManager.dict.__name__ == 'dict'"
    - "multiprocessing.managers.SyncManager.list.__name__ == 'list'"
    - "multiprocessing.managers.SyncManager.Lock.__name__ == 'Lock'"
    - "multiprocessing.managers.SyncManager.Event.__name__ == 'Event'"
    - "multiprocessing.managers.SyncManager.Queue.__name__ == 'Queue'"
    - "SyncManager managed type methods are auto-generated and carry the original type name as __name__"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra410.sync_manager_method_names:
  description: "Verify __name__ attribute of multiprocessing.managers.SyncManager managed-type methods"
  kind: python_call_eq
  category: identity
  id_prefix: mp410sm

  columns: [id, function, args, expected]
  rows:
    - [mp410sm001, multiprocessing.managers.SyncManager.dict.__name__.__eq__, ["dict"], true]
    - [mp410sm002, multiprocessing.managers.SyncManager.list.__name__.__eq__, ["list"], true]
    - [mp410sm003, multiprocessing.managers.SyncManager.Lock.__name__.__eq__, ["Lock"], true]
    - [mp410sm004, multiprocessing.managers.SyncManager.Event.__name__.__eq__, ["Event"], true]
    - [mp410sm005, multiprocessing.managers.SyncManager.Queue.__name__.__eq__, ["Queue"], true]
