spec: errno_extra8
version: ">=3.9"
backend: python_module(errno)

docs: https://docs.python.org/3/library/errno.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/errno.html — Python errno module documentation"
    - "POSIX.1-2017 — IEEE Std 1003.1, errno.h error codes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/errnomodule.c"
  notes:
    - "This spec extends errno.zspec.zsdl through errno_extra7.zspec.zsdl."
    - "errno.zspec covers: EPERM=1, ENOENT=2, ESRCH=3, EINTR=4, EIO=5, EBADF=9, ENOMEM=12, EACCES=13, EINVAL=22 values; errorcode type/lookups 1/2/22."
    - "errno_extra through errno_extra7 cover: ENXIO=6, ECHILD=10, EFAULT=14, ENOTDIR=20, EISDIR=21, ENOSPC=28, EPIPE=32, ERANGE=34, EMFILE, ENFILE, EAGAIN=35, EWOULDBLOCK=35, EADDRINUSE, ECONNRESET, ECONNREFUSED=61, ETIMEDOUT=60, EHOSTUNREACH=65, ENETUNREACH=51."
    - "No prior spec verifies EDEADLK=11, ENODEV=19, ENOTTY=25, ESPIPE=29, EROFS=30, ENAMETOOLONG=63, ELOOP=62 as standalone value invariants."
    - "No prior spec verifies errorcode[11]=='EDEADLK', errorcode[19]=='ENODEV', errorcode[25]=='ENOTTY', errorcode[29]=='ESPIPE', errorcode[30]=='EROFS' as standalone invariants."
    - "No prior spec verifies 1 in errno.errorcode or errorcode[1]=='EPERM' as standalone invariants."
    - "errno.EDEADLK == 11 on macOS/Darwin (resource deadlock avoided)."
    - "errno.ENODEV == 19 on macOS/Darwin (operation not supported by device)."
    - "errno.ENOTTY == 25 on macOS/Darwin (inappropriate ioctl for device)."
    - "errno.ESPIPE == 29 on macOS/Darwin (illegal seek)."
    - "errno.EROFS == 30 on macOS/Darwin (read-only file system)."
    - "errno.ENAMETOOLONG == 63 on macOS/Darwin (file name too long)."
    - "errno.ELOOP == 62 on macOS/Darwin (too many levels of symbolic links)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Constant values — EDEADLK, ENODEV, ENOTTY, ESPIPE, EROFS
#
# No prior spec verifies these five constants' integer values as standalone
# invariants. All are POSIX-defined; numeric values below are for macOS/Darwin.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra8.EDEADLK.value:
  description: "errno.EDEADLK == 11 on macOS/Darwin (resource deadlock avoided)"
  category: constants
  kind: python_call_eq
  function: EDEADLK.__eq__
  args: [11]
  expected: true

invariant errno_extra8.ENODEV.value:
  description: "errno.ENODEV == 19 on macOS/Darwin (operation not supported by device)"
  category: constants
  kind: python_call_eq
  function: ENODEV.__eq__
  args: [19]
  expected: true

invariant errno_extra8.ENOTTY.value:
  description: "errno.ENOTTY == 25 on macOS/Darwin (inappropriate ioctl for device)"
  category: constants
  kind: python_call_eq
  function: ENOTTY.__eq__
  args: [25]
  expected: true

invariant errno_extra8.ESPIPE.value:
  description: "errno.ESPIPE == 29 on macOS/Darwin (illegal seek)"
  category: constants
  kind: python_call_eq
  function: ESPIPE.__eq__
  args: [29]
  expected: true

invariant errno_extra8.EROFS.value:
  description: "errno.EROFS == 30 on macOS/Darwin (read-only file system)"
  category: constants
  kind: python_call_eq
  function: EROFS.__eq__
  args: [30]
  expected: true

# ---------------------------------------------------------------------------
# Constant values — ENAMETOOLONG and ELOOP
#
# No prior spec verifies these two constants as standalone invariants.
# Values are for macOS/Darwin 25.4.0. Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra8.ENAMETOOLONG.value:
  description: "errno.ENAMETOOLONG == 63 on macOS/Darwin (file name too long)"
  category: constants
  kind: python_call_eq
  function: ENAMETOOLONG.__eq__
  args: [63]
  expected: true

invariant errno_extra8.ELOOP.value:
  description: "errno.ELOOP == 62 on macOS/Darwin (too many levels of symbolic links)"
  category: constants
  kind: python_call_eq
  function: ELOOP.__eq__
  args: [62]
  expected: true

# ---------------------------------------------------------------------------
# errorcode — reverse-lookup for key 1 (EPERM)
#
# errno.zspec covers errorcode lookups for keys 2 and 22. No prior spec anchors
# errorcode[1]=='EPERM' as a standalone invariant. Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra8.errorcode.eperm_lookup:
  description: "errno.errorcode[1] == 'EPERM' — reverse-lookup of errno 1 on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [1]
  expected: "EPERM"

# ---------------------------------------------------------------------------
# errorcode — reverse-lookups for EDEADLK, ENODEV, ENOTTY, ESPIPE, EROFS
#
# No prior spec verifies errorcode reverse-lookups for keys 11, 19, 25, 29, 30.
# All verified at runtime on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant errno_extra8.errorcode.edeadlk_lookup:
  description: "errno.errorcode[11] == 'EDEADLK' — reverse-lookup of errno 11 on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [11]
  expected: "EDEADLK"

invariant errno_extra8.errorcode.enodev_lookup:
  description: "errno.errorcode[19] == 'ENODEV' — reverse-lookup of errno 19 on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [19]
  expected: "ENODEV"

invariant errno_extra8.errorcode.enotty_lookup:
  description: "errno.errorcode[25] == 'ENOTTY' — reverse-lookup of errno 25 on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [25]
  expected: "ENOTTY"

invariant errno_extra8.errorcode.espipe_lookup:
  description: "errno.errorcode[29] == 'ESPIPE' — reverse-lookup of errno 29 on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [29]
  expected: "ESPIPE"

invariant errno_extra8.errorcode.erofs_lookup:
  description: "errno.errorcode[30] == 'EROFS' — reverse-lookup of errno 30 on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [30]
  expected: "EROFS"

# ---------------------------------------------------------------------------
# errorcode — __contains__ for keys 1, 11, 19, 25, 29, 30
#
# No prior spec anchors 1 in errorcode as a standalone invariant.
# No prior spec verifies __contains__ for keys 11/19/25/29/30.
# All verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra8.errorcode.contains_eperm_key:
  description: "1 in errno.errorcode — EPERM key is present on all POSIX platforms"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# Table: new constant integer values
#
# Groups all seven new constant-value checks in one indexed table.
# No prior table covers EDEADLK/ENODEV/ENOTTY/ESPIPE/EROFS/ENAMETOOLONG/ELOOP.
# All verified at runtime on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table errno_extra8.constant_values:
  description: "EDEADLK, ENODEV, ENOTTY, ESPIPE, EROFS, ENAMETOOLONG, ELOOP integer values on macOS/Darwin"
  kind: python_call_eq
  category: constants
  id_prefix: e8cv

  columns: [id, function, args, expected]
  rows:
    - [EDEADLK,     EDEADLK.__eq__,     [11], true]
    - [ENODEV,      ENODEV.__eq__,      [19], true]
    - [ENOTTY,      ENOTTY.__eq__,      [25], true]
    - [ESPIPE,      ESPIPE.__eq__,      [29], true]
    - [EROFS,       EROFS.__eq__,       [30], true]
    - [ENAMETOOLONG, ENAMETOOLONG.__eq__, [63], true]
    - [ELOOP,       ELOOP.__eq__,       [62], true]

# ---------------------------------------------------------------------------
# Table: errorcode reverse-lookups for new keys
#
# Groups the five new errorcode reverse-lookup checks in one indexed table.
# No prior table covers errorcode[11/19/25/29/30] lookups.
# ---------------------------------------------------------------------------

table errno_extra8.errorcode_lookups:
  description: "errno.errorcode reverse-lookups for EDEADLK/ENODEV/ENOTTY/ESPIPE/EROFS"
  kind: python_call_eq
  category: errorcode
  id_prefix: e8el

  columns: [id, function, args, expected]
  rows:
    - [edeadlk, errorcode.__getitem__, [11], "EDEADLK"]
    - [enodev,  errorcode.__getitem__, [19], "ENODEV"]
    - [enotty,  errorcode.__getitem__, [25], "ENOTTY"]
    - [espipe,  errorcode.__getitem__, [29], "ESPIPE"]
    - [erofs,   errorcode.__getitem__, [30], "EROFS"]
