spec: decimal_extra241
version: ">=3.7"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic Specification, Version 1.72"
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "IBM General Decimal Arithmetic Specification 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal.zspec.zsdl — covers Decimal.__str__, is_finite/is_infinite/is_nan/is_zero/is_signed/is_normal predicates"
    - "decimal_extra.zspec.zsdl — covers to_eng_string, Context classes, rounding mode constants"
  notes:
    - "This spec focuses on is_nan, is_infinite, is_finite, is_zero behavioral contracts not yet in other specs."
    - "Decimal('NaN').is_nan() == True; Decimal('1').is_nan() == False."
    - "Decimal('Inf').is_infinite() == True; Decimal('-Inf').is_infinite() == True; Decimal('1').is_infinite() == False."
    - "Decimal('1').is_finite() == True; Decimal('NaN').is_finite() == False; Decimal('Inf').is_finite() == False."
    - "Decimal('0').is_zero() == True; Decimal('1').is_zero() == False."
    - "is_snan() returns True only for signaling NaN (Decimal('sNaN')), not for quiet NaN."
    - "Method names verified: Decimal.is_nan.__name__ == 'is_nan', __qualname__ == 'Decimal.is_nan'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Method identity — is_nan, is_infinite, is_finite, is_zero
# ---------------------------------------------------------------------------

table decimal_extra241.method_names:
  description: "Decimal test method __name__ identity"
  kind: python_call_eq
  category: method_identity
  id_prefix: dectest241

  columns: [id, function, args, expected]
  rows:
    - [is_nan_name,       Decimal.is_nan.__name__.__eq__,       ["is_nan"],       true]
    - [is_infinite_name,  Decimal.is_infinite.__name__.__eq__,  ["is_infinite"],  true]
    - [is_finite_name,    Decimal.is_finite.__name__.__eq__,    ["is_finite"],    true]
    - [is_zero_name,      Decimal.is_zero.__name__.__eq__,      ["is_zero"],      true]

table decimal_extra241.method_qualnames:
  description: "Decimal test method __qualname__ identity"
  kind: python_call_eq
  category: method_identity
  id_prefix: dectest241

  columns: [id, function, args, expected]
  rows:
    - [is_nan_qualname,       Decimal.is_nan.__qualname__.__eq__,       ["Decimal.is_nan"],       true]
    - [is_infinite_qualname,  Decimal.is_infinite.__qualname__.__eq__,  ["Decimal.is_infinite"],  true]
    - [is_finite_qualname,    Decimal.is_finite.__qualname__.__eq__,    ["Decimal.is_finite"],    true]
    - [is_zero_qualname,      Decimal.is_zero.__qualname__.__eq__,      ["Decimal.is_zero"],      true]

# ---------------------------------------------------------------------------
# is_nan() behavioral contracts
# ---------------------------------------------------------------------------

invariant decimal_extra241.is_nan.nan_true:
  description: "Decimal('NaN').is_nan() == True"
  category: is_nan
  kind: python_call_eq
  function: Decimal
  args: ["NaN"]
  method: is_nan
  expected: true

invariant decimal_extra241.is_nan.finite_false:
  description: "Decimal('1').is_nan() == False — a regular number is not NaN"
  category: is_nan
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: is_nan
  expected: false

invariant decimal_extra241.is_nan.neg_one_false:
  description: "Decimal('-1').is_nan() == False"
  category: is_nan
  kind: python_call_eq
  function: Decimal
  args: ["-1"]
  method: is_nan
  expected: false

invariant decimal_extra241.is_nan.inf_false:
  description: "Decimal('Inf').is_nan() == False — infinity is not NaN"
  category: is_nan
  kind: python_call_eq
  function: Decimal
  args: ["Inf"]
  method: is_nan
  expected: false

invariant decimal_extra241.is_nan.zero_false:
  description: "Decimal('0').is_nan() == False"
  category: is_nan
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: is_nan
  expected: false

# ---------------------------------------------------------------------------
# is_infinite() behavioral contracts
# ---------------------------------------------------------------------------

invariant decimal_extra241.is_infinite.pos_inf_true:
  description: "Decimal('Inf').is_infinite() == True"
  category: is_infinite
  kind: python_call_eq
  function: Decimal
  args: ["Inf"]
  method: is_infinite
  expected: true

invariant decimal_extra241.is_infinite.neg_inf_true:
  description: "Decimal('-Inf').is_infinite() == True — negative infinity is infinite"
  category: is_infinite
  kind: python_call_eq
  function: Decimal
  args: ["-Inf"]
  method: is_infinite
  expected: true

invariant decimal_extra241.is_infinite.finite_false:
  description: "Decimal('1').is_infinite() == False"
  category: is_infinite
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: is_infinite
  expected: false

invariant decimal_extra241.is_infinite.zero_false:
  description: "Decimal('0').is_infinite() == False"
  category: is_infinite
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: is_infinite
  expected: false

invariant decimal_extra241.is_infinite.nan_false:
  description: "Decimal('NaN').is_infinite() == False — NaN is not infinite"
  category: is_infinite
  kind: python_call_eq
  function: Decimal
  args: ["NaN"]
  method: is_infinite
  expected: false

# ---------------------------------------------------------------------------
# is_finite() behavioral contracts
# ---------------------------------------------------------------------------

invariant decimal_extra241.is_finite.one_true:
  description: "Decimal('1').is_finite() == True — a regular number is finite"
  category: is_finite
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: is_finite
  expected: true

invariant decimal_extra241.is_finite.zero_true:
  description: "Decimal('0').is_finite() == True — zero is finite"
  category: is_finite
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: is_finite
  expected: true

invariant decimal_extra241.is_finite.inf_false:
  description: "Decimal('Inf').is_finite() == False — infinity is not finite"
  category: is_finite
  kind: python_call_eq
  function: Decimal
  args: ["Inf"]
  method: is_finite
  expected: false

invariant decimal_extra241.is_finite.nan_false:
  description: "Decimal('NaN').is_finite() == False — NaN is not finite"
  category: is_finite
  kind: python_call_eq
  function: Decimal
  args: ["NaN"]
  method: is_finite
  expected: false

# ---------------------------------------------------------------------------
# is_zero() behavioral contracts
# ---------------------------------------------------------------------------

invariant decimal_extra241.is_zero.zero_true:
  description: "Decimal('0').is_zero() == True"
  category: is_zero
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: is_zero
  expected: true

invariant decimal_extra241.is_zero.one_false:
  description: "Decimal('1').is_zero() == False"
  category: is_zero
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: is_zero
  expected: false

invariant decimal_extra241.is_zero.nan_false:
  description: "Decimal('NaN').is_zero() == False — NaN is not zero"
  category: is_zero
  kind: python_call_eq
  function: Decimal
  args: ["NaN"]
  method: is_zero
  expected: false

invariant decimal_extra241.is_zero.inf_false:
  description: "Decimal('Inf').is_zero() == False — infinity is not zero"
  category: is_zero
  kind: python_call_eq
  function: Decimal
  args: ["Inf"]
  method: is_zero
  expected: false
