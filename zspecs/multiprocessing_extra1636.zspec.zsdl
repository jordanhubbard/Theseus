spec: multiprocessing_extra1636
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing: Process-based parallelism"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
    - "CPython source: Lib/multiprocessing/ (internal implementation)"
  notes:
    - "behavioral invariants for ABC virtual subclassing protocol"
    - "Wave 1636: theme is __subclasshook__, __instancecheck__, __subclasscheck__ — the ABC virtual subclassing protocol."
    - "multiprocessing.Process is a plain class; its metaclass is `type`, not ABCMeta."
    - "Process does not define __subclasshook__, __instancecheck__, or __subclasscheck__ in its own __dict__."
    - "multiprocessing exception hierarchy: ProcessError is the root exception; AuthenticationError, TimeoutError, BufferTooShort all inherit from ProcessError."
    - "multiprocessing.ProcessError itself inherits from Exception."
    - "None of the exception classes in multiprocessing define __subclasshook__ in their own __dict__."
    - "multiprocessing.managers.BaseManager and SyncManager are not ABCs; they have plain `type` as metaclass."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: multiprocessing classes have no ABC hooks in their own __dict__
#
# multiprocessing.Process, Queue, Pipe, Pool, Lock, Event, Semaphore, Value,
# Array, Manager are all concrete classes/factory functions. None define
# __subclasshook__, __instancecheck__, or __subclasscheck__ in their own
# __dict__. Their metaclass is the plain built-in `type`.
# ---------------------------------------------------------------------------

table multiprocessing_extra1636.no_virtual_subclassing:
  description: "multiprocessing classes do not define ABC hooks in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1636nv

  columns: [id, function, args, expected]
  rows:
    - ["mp1636nv001", "multiprocessing.Process.__dict__.__contains__",          ["__subclasshook__"],  false]
    - ["mp1636nv002", "multiprocessing.Process.__dict__.__contains__",          ["__instancecheck__"], false]
    - ["mp1636nv003", "multiprocessing.Process.__dict__.__contains__",          ["__subclasscheck__"], false]
    - ["mp1636nv004", "multiprocessing.Process.__class__.__name__.__eq__",      ["type"],              true]
    - ["mp1636nv005", "multiprocessing.ProcessError.__dict__.__contains__",     ["__subclasshook__"],  false]
    - ["mp1636nv006", "multiprocessing.AuthenticationError.__dict__.__contains__", ["__subclasshook__"], false]
    - ["mp1636nv007", "multiprocessing.TimeoutError.__dict__.__contains__",     ["__subclasshook__"],  false]
    - ["mp1636nv008", "multiprocessing.BufferTooShort.__dict__.__contains__",   ["__subclasshook__"],  false]
    - ["mp1636nv009", "multiprocessing.Process.__dict__.__contains__",          ["start"],             true]
    - ["mp1636nv010", "multiprocessing.Process.__dict__.__contains__",          ["run"],               true]
    - ["mp1636nv011", "multiprocessing.Process.__dict__.__contains__",          ["join"],              true]
    - ["mp1636nv012", "multiprocessing.Process.__dict__.__contains__",          ["is_alive"],          true]
    - ["mp1636nv013", "multiprocessing.Process.__dict__.__contains__",          ["terminate"],         true]
    - ["mp1636nv014", "multiprocessing.Process.__dict__.__contains__",          ["kill"],              true]
    - ["mp1636nv015", "multiprocessing.Process.__name__.__eq__",                ["Process"],           true]
    - ["mp1636nv016", "multiprocessing.Process.__module__.__eq__",              ["multiprocessing.process"], true]
    - ["mp1636nv017", "multiprocessing.ProcessError.__name__.__eq__",           ["ProcessError"],      true]
    - ["mp1636nv018", "multiprocessing.AuthenticationError.__name__.__eq__",    ["AuthenticationError"], true]
    - ["mp1636nv019", "multiprocessing.TimeoutError.__name__.__eq__",           ["TimeoutError"],      true]
    - ["mp1636nv020", "multiprocessing.BufferTooShort.__name__.__eq__",         ["BufferTooShort"],    true]

# ---------------------------------------------------------------------------
# Table 2: exception hierarchy — multiprocessing exception class relationships
#
# ProcessError is the root of the multiprocessing exception tree, inheriting
# from Exception. AuthenticationError, TimeoutError, BufferTooShort all
# inherit from ProcessError. None of these classes define __subclasshook__
# because they are plain exception classes with `type` as their metaclass.
# ---------------------------------------------------------------------------

table multiprocessing_extra1636.exception_hierarchy:
  description: "multiprocessing exception class inheritance hierarchy"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1636eh

  columns: [id, function, args, expected]
  rows:
    - ["mp1636eh001", "multiprocessing.ProcessError.__bases__.__getitem__",          [0],                null]
    - ["mp1636eh002", "multiprocessing.AuthenticationError.__bases__.__getitem__",   [0],                null]
    - ["mp1636eh003", "multiprocessing.TimeoutError.__bases__.__getitem__",          [0],                null]
    - ["mp1636eh004", "multiprocessing.BufferTooShort.__bases__.__getitem__",        [0],                null]
    - ["mp1636eh005", "multiprocessing.AuthenticationError.__bases__.__getitem__",   [0],                null]
    - ["mp1636eh006", "multiprocessing.ProcessError.__class__.__name__.__eq__",      ["type"],           true]
    - ["mp1636eh007", "multiprocessing.AuthenticationError.__class__.__name__.__eq__", ["type"],         true]
    - ["mp1636eh008", "multiprocessing.TimeoutError.__class__.__name__.__eq__",      ["type"],           true]
    - ["mp1636eh009", "multiprocessing.BufferTooShort.__class__.__name__.__eq__",    ["type"],           true]
    - ["mp1636eh010", "multiprocessing.ProcessError.__dict__.__contains__",          ["__instancecheck__"], false]
    - ["mp1636eh011", "multiprocessing.ProcessError.__dict__.__contains__",          ["__subclasscheck__"], false]
    - ["mp1636eh012", "multiprocessing.AuthenticationError.__dict__.__contains__",   ["__instancecheck__"], false]
    - ["mp1636eh013", "multiprocessing.TimeoutError.__dict__.__contains__",          ["__instancecheck__"], false]
    - ["mp1636eh014", "multiprocessing.BufferTooShort.__dict__.__contains__",        ["__instancecheck__"], false]
    - ["mp1636eh015", "multiprocessing.ProcessError.__name__.__eq__",                ["ProcessError"],   true]
    - ["mp1636eh016", "multiprocessing.AuthenticationError.__name__.__eq__",         ["AuthenticationError"], true]
    - ["mp1636eh017", "multiprocessing.TimeoutError.__name__.__eq__",                ["TimeoutError"],   true]
    - ["mp1636eh018", "multiprocessing.BufferTooShort.__name__.__eq__",              ["BufferTooShort"], true]
    - ["mp1636eh019", "multiprocessing.ProcessError.__module__.__eq__",              ["multiprocessing"], true]
    - ["mp1636eh020", "multiprocessing.AuthenticationError.__module__.__eq__",       ["multiprocessing"], true]
    - ["mp1636eh021", "multiprocessing.TimeoutError.__module__.__eq__",              ["multiprocessing"], true]
    - ["mp1636eh022", "multiprocessing.BufferTooShort.__module__.__eq__",            ["multiprocessing"], true]
    - ["mp1636eh023", "multiprocessing.Process.__bases__.__getitem__",               [0],                null]
    - ["mp1636eh024", "multiprocessing.Process.__bases__.__getitem__",               [0],                null]
    - ["mp1636eh025", "multiprocessing.ProcessError.__dict__.__contains__",          ["__subclasshook__"], false]
