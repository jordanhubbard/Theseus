spec: re_extra721
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from: []
  not_derived_from: []
  notes: "Qualname identity checks for re.Pattern and re.Match method descriptors"
  created_at: "2026-04-12"

docs:
  summary: "Covers re.Pattern method qualnames (match, search, fullmatch, findall, finditer, sub, subn, split) and re.Match method qualnames (group, groups, groupdict, span)."

table re_extra721.method_qualnames:
  description: "re.Pattern and re.Match method qualname identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: re721mq
  columns: [id, function, args, expected]
  rows:
    - [re721mq001, re.Pattern.match.__qualname__.__eq__, ["Pattern.match"], true]
    - [re721mq002, re.Pattern.search.__qualname__.__eq__, ["Pattern.search"], true]
    - [re721mq003, re.Pattern.fullmatch.__qualname__.__eq__, ["Pattern.fullmatch"], true]
    - [re721mq004, re.Pattern.findall.__qualname__.__eq__, ["Pattern.findall"], true]
    - [re721mq005, re.Pattern.finditer.__qualname__.__eq__, ["Pattern.finditer"], true]
    - [re721mq006, re.Pattern.sub.__qualname__.__eq__, ["Pattern.sub"], true]
    - [re721mq007, re.Pattern.subn.__qualname__.__eq__, ["Pattern.subn"], true]
    - [re721mq008, re.Pattern.split.__qualname__.__eq__, ["Pattern.split"], true]
    - [re721mq009, re.Match.group.__qualname__.__eq__, ["Match.group"], true]
    - [re721mq010, re.Match.groups.__qualname__.__eq__, ["Match.groups"], true]
    - [re721mq011, re.Match.groupdict.__qualname__.__eq__, ["Match.groupdict"], true]
    - [re721mq012, re.Match.span.__qualname__.__eq__, ["Match.span"], true]
