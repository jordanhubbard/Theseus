spec: inspect_extra2101
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2101 (_extra2101): __class_getitem__, __init_subclass__, __subclasshook__, __mro_entries__ dict-presence checks for inspect module types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "inspect.ForwardRef defines __init_subclass__ in its own __dict__ (True) — ForwardRef is a typing helper that overrides __init_subclass__ to control subclassing behavior."
    - "inspect.Parameter does NOT define __class_getitem__ in its own __dict__ (False) — Parameter is a plain Python class that does not support subscript generic syntax."
    - "inspect.Signature does NOT define __class_getitem__ in its own __dict__ (False) — Signature is a plain Python class without generic alias support."
    - "inspect.BoundArguments does NOT define __class_getitem__ in its own __dict__ (False)."
    - "Named-tuple subclasses FullArgSpec, ArgInfo, Arguments, ClosureVars, Traceback do not define any of the four dunders in their own __dict__."
    - "inspect.Parameter, Signature, BoundArguments, BufferFlags, Format, _ParameterKind all have False for __class_getitem__, __init_subclass__, __subclasshook__, __mro_entries__ in their own __dict__."
    - "None of the inspect types define __subclasshook__ in their own __dict__ — none use ABCMeta virtual subclass hooks."
    - "None of the inspect types define __mro_entries__ in their own __dict__ — none are used as generic alias proxies in class base tuples."
    - "inspect.ForwardRef.__init_subclass__ True reflects its role as a typing bridge class, not a general pattern for inspect classes."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __class_getitem__ dict-presence for inspect types
#
# All inspect public types: False
# None of Parameter, Signature, BoundArguments, BufferFlags, Format,
# FullArgSpec, ArgInfo, Arguments, ClosureVars, Traceback, ForwardRef,
# _ParameterKind define __class_getitem__ in their own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra2101.class_getitem_protocol:
  description: "inspect types __class_getitem__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2101

  columns: [id, function, args, expected]
  rows:
    - ["in2101001", "inspect.Parameter.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in2101002", "inspect.Signature.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in2101003", "inspect.BoundArguments.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in2101004", "inspect.BufferFlags.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in2101005", "inspect.Format.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in2101006", "inspect.FullArgSpec.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in2101007", "inspect.ArgInfo.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in2101008", "inspect.Arguments.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in2101009", "inspect.ClosureVars.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in2101010", "inspect.Traceback.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in2101011", "inspect.ForwardRef.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in2101012", "inspect._ParameterKind.__dict__.__contains__", ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Table 2: __init_subclass__ dict-presence for inspect types
#
# inspect.ForwardRef: True — ForwardRef overrides __init_subclass__
# All others: False — plain Python or namedtuple classes that rely on
# the default object.__init_subclass__ classmethod.
# ---------------------------------------------------------------------------

table inspect_extra2101.init_subclass_protocol:
  description: "inspect types __init_subclass__ dict-presence checks — ForwardRef True, all others False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2101

  columns: [id, function, args, expected]
  rows:
    - ["in2101013", "inspect.Parameter.__dict__.__contains__", ["__init_subclass__"], false]
    - ["in2101014", "inspect.Signature.__dict__.__contains__", ["__init_subclass__"], false]
    - ["in2101015", "inspect.BoundArguments.__dict__.__contains__", ["__init_subclass__"], false]
    - ["in2101016", "inspect.BufferFlags.__dict__.__contains__", ["__init_subclass__"], false]
    - ["in2101017", "inspect.Format.__dict__.__contains__", ["__init_subclass__"], false]
    - ["in2101018", "inspect.FullArgSpec.__dict__.__contains__", ["__init_subclass__"], false]
    - ["in2101019", "inspect.ArgInfo.__dict__.__contains__", ["__init_subclass__"], false]
    - ["in2101020", "inspect.Arguments.__dict__.__contains__", ["__init_subclass__"], false]
    - ["in2101021", "inspect.ClosureVars.__dict__.__contains__", ["__init_subclass__"], false]
    - ["in2101022", "inspect.Traceback.__dict__.__contains__", ["__init_subclass__"], false]
    - ["in2101023", "inspect.ForwardRef.__dict__.__contains__", ["__init_subclass__"], true]
    - ["in2101024", "inspect._ParameterKind.__dict__.__contains__", ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Table 3: __subclasshook__ dict-presence for inspect types
#
# None of the inspect types define __subclasshook__ in their own __dict__.
# inspect classes are not registered as ABCs and do not implement the
# virtual subclass hook protocol.
# ---------------------------------------------------------------------------

table inspect_extra2101.subclasshook_protocol:
  description: "inspect types __subclasshook__ dict-presence checks — all False (no ABC virtual subclass hooks)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2101

  columns: [id, function, args, expected]
  rows:
    - ["in2101025", "inspect.Parameter.__dict__.__contains__", ["__subclasshook__"], false]
    - ["in2101026", "inspect.Signature.__dict__.__contains__", ["__subclasshook__"], false]
    - ["in2101027", "inspect.BoundArguments.__dict__.__contains__", ["__subclasshook__"], false]
    - ["in2101028", "inspect.BufferFlags.__dict__.__contains__", ["__subclasshook__"], false]
    - ["in2101029", "inspect.Format.__dict__.__contains__", ["__subclasshook__"], false]
    - ["in2101030", "inspect.FullArgSpec.__dict__.__contains__", ["__subclasshook__"], false]
    - ["in2101031", "inspect.ArgInfo.__dict__.__contains__", ["__subclasshook__"], false]
    - ["in2101032", "inspect.Arguments.__dict__.__contains__", ["__subclasshook__"], false]
    - ["in2101033", "inspect.ForwardRef.__dict__.__contains__", ["__subclasshook__"], false]
    - ["in2101034", "inspect._ParameterKind.__dict__.__contains__", ["__subclasshook__"], false]

# ---------------------------------------------------------------------------
# Table 4: __mro_entries__ dict-presence for inspect types
#
# __mro_entries__ is a protocol for objects used as class bases that need to
# expand to a tuple of actual base classes (e.g. Generic[T]). None of the
# inspect types define it in their own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra2101.mro_entries_protocol:
  description: "inspect types __mro_entries__ dict-presence checks — all False (not MRO-entry proxy types)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2101

  columns: [id, function, args, expected]
  rows:
    - ["in2101035", "inspect.Parameter.__dict__.__contains__", ["__mro_entries__"], false]
    - ["in2101036", "inspect.Signature.__dict__.__contains__", ["__mro_entries__"], false]
    - ["in2101037", "inspect.BoundArguments.__dict__.__contains__", ["__mro_entries__"], false]
    - ["in2101038", "inspect.BufferFlags.__dict__.__contains__", ["__mro_entries__"], false]
    - ["in2101039", "inspect.Format.__dict__.__contains__", ["__mro_entries__"], false]
    - ["in2101040", "inspect.FullArgSpec.__dict__.__contains__", ["__mro_entries__"], false]
    - ["in2101041", "inspect.ArgInfo.__dict__.__contains__", ["__mro_entries__"], false]
    - ["in2101042", "inspect.Arguments.__dict__.__contains__", ["__mro_entries__"], false]
    - ["in2101043", "inspect.ForwardRef.__dict__.__contains__", ["__mro_entries__"], false]
    - ["in2101044", "inspect._ParameterKind.__dict__.__contains__", ["__mro_entries__"], false]
    - ["in2101045", "inspect.ClosureVars.__dict__.__contains__", ["__mro_entries__"], false]
    - ["in2101046", "inspect.Traceback.__dict__.__contains__", ["__mro_entries__"], false]
