spec: pathlib_extra1066
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module PurePath and Path method documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks PurePath manipulation method __qualname__ values, Path classmethod __qualname__ via __func__, and Path I/O method qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1066.purepath_manipulation_qualnames:
  description: "pathlib.PurePath path manipulation method __qualname__ checks"
  kind: python_call_eq
  category: purepath_manipulation_qualnames
  id_prefix: pl1066pm
  columns: [id, function, args, expected]
  rows:
    - [pl1066pm001, pathlib.PurePath.with_name.__qualname__.__eq__,      ["PurePath.with_name"],      true]
    - [pl1066pm002, pathlib.PurePath.with_stem.__qualname__.__eq__,      ["PurePath.with_stem"],      true]
    - [pl1066pm003, pathlib.PurePath.with_suffix.__qualname__.__eq__,    ["PurePath.with_suffix"],    true]
    - [pl1066pm004, pathlib.PurePath.relative_to.__qualname__.__eq__,    ["PurePath.relative_to"],    true]
    - [pl1066pm005, pathlib.PurePath.is_relative_to.__qualname__.__eq__, ["PurePath.is_relative_to"], true]
    - [pl1066pm006, pathlib.PurePath.joinpath.__qualname__.__eq__,       ["PurePath.joinpath"],       true]
    - [pl1066pm007, pathlib.PurePath.with_name.__module__.__eq__,        ["pathlib"],                 true]
    - [pl1066pm008, pathlib.PurePath.joinpath.__module__.__eq__,         ["pathlib"],                 true]

table pathlib_extra1066.path_classmethod_qualnames:
  description: "pathlib.Path classmethod __qualname__ checks via __func__"
  kind: python_call_eq
  category: path_classmethod_qualnames
  id_prefix: pl1066cm
  columns: [id, function, args, expected]
  rows:
    - [pl1066cm001, pathlib.Path.cwd.__func__.__qualname__.__eq__,  ["Path.cwd"],  true]
    - [pl1066cm002, pathlib.Path.home.__func__.__qualname__.__eq__, ["Path.home"], true]
    - [pl1066cm003, pathlib.Path.cwd.__class__.__name__.__eq__,     ["method"],    true]
    - [pl1066cm004, pathlib.Path.home.__class__.__name__.__eq__,    ["method"],    true]
    - [pl1066cm005, pathlib.Path.cwd.__func__.__module__.__eq__,    ["pathlib"],   true]
    - [pl1066cm006, pathlib.Path.home.__func__.__module__.__eq__,   ["pathlib"],   true]

table pathlib_extra1066.path_io_method_qualnames:
  description: "pathlib.Path I/O method __qualname__ checks"
  kind: python_call_eq
  category: path_io_method_qualnames
  id_prefix: pl1066io
  columns: [id, function, args, expected]
  rows:
    - [pl1066io001, pathlib.Path.read_text.__qualname__.__eq__,   ["Path.read_text"],   true]
    - [pl1066io002, pathlib.Path.read_bytes.__qualname__.__eq__,  ["Path.read_bytes"],  true]
    - [pl1066io003, pathlib.Path.write_text.__qualname__.__eq__,  ["Path.write_text"],  true]
    - [pl1066io004, pathlib.Path.write_bytes.__qualname__.__eq__, ["Path.write_bytes"], true]
    - [pl1066io005, pathlib.Path.open.__qualname__.__eq__,        ["Path.open"],        true]
    - [pl1066io006, pathlib.Path.resolve.__qualname__.__eq__,     ["Path.resolve"],     true]
    - [pl1066io007, pathlib.Path.expanduser.__qualname__.__eq__,  ["Path.expanduser"],  true]
    - [pl1066io008, pathlib.Path.read_text.__module__.__eq__,     ["pathlib"],          true]
