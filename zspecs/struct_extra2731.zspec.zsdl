spec: struct_extra2731
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/struct.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 629 theme: __trunc__, __floor__, and __ceil__ dict-presence checks (numeric rounding protocol)."
    - "struct.Struct is a compiled struct object class; it does not implement numeric rounding protocols."
    - "struct.error is an exception subclass (inherits from Exception); it does not define __trunc__, __floor__, or __ceil__ in its own __dict__."
    - "None of the struct public classes define __trunc__, __floor__, or __ceil__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — absent from all struct classes
# ---------------------------------------------------------------------------

table struct_extra2731.trunc_protocol:
  description: "__trunc__ is absent from all struct class __dict__s — none implement numeric truncation"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2731

  columns: [id, function, args, expected]
  rows:
    - ["st2731001", "struct.Struct.__dict__.__contains__", ["__trunc__"], false]
    - ["st2731002", "struct.error.__dict__.__contains__",  ["__trunc__"], false]

# ---------------------------------------------------------------------------
# __floor__ dict-presence — absent from all struct classes
# ---------------------------------------------------------------------------

table struct_extra2731.floor_protocol:
  description: "__floor__ is absent from all struct class __dict__s — none implement floor rounding"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2731

  columns: [id, function, args, expected]
  rows:
    - ["st2731003", "struct.Struct.__dict__.__contains__", ["__floor__"], false]
    - ["st2731004", "struct.error.__dict__.__contains__",  ["__floor__"], false]

# ---------------------------------------------------------------------------
# __ceil__ dict-presence — absent from all struct classes
# ---------------------------------------------------------------------------

table struct_extra2731.ceil_protocol:
  description: "__ceil__ is absent from all struct class __dict__s — none implement ceiling rounding"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2731

  columns: [id, function, args, expected]
  rows:
    - ["st2731005", "struct.Struct.__dict__.__contains__", ["__ceil__"], false]
    - ["st2731006", "struct.error.__dict__.__contains__",  ["__ceil__"], false]

# ---------------------------------------------------------------------------
# Combined view — Struct and error vs. all three rounding protocols
# ---------------------------------------------------------------------------

table struct_extra2731.struct_rounding_combined:
  description: "struct.Struct and struct.error define none of __trunc__, __floor__, __ceil__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2731

  columns: [id, function, args, expected]
  rows:
    - ["st2731007", "struct.Struct.__dict__.__contains__", ["__trunc__"], false]
    - ["st2731008", "struct.Struct.__dict__.__contains__", ["__floor__"], false]
    - ["st2731009", "struct.Struct.__dict__.__contains__", ["__ceil__"],  false]
    - ["st2731010", "struct.error.__dict__.__contains__",  ["__trunc__"], false]
    - ["st2731011", "struct.error.__dict__.__contains__",  ["__floor__"], false]
    - ["st2731012", "struct.error.__dict__.__contains__",  ["__ceil__"],  false]
