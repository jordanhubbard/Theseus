spec: hashlib_extra1726
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 562 (_extra1726): comparison/ordering protocol dict-presence checks."
    - "hashlib hash objects do not define comparison operators in their own __dict__."
    - "hashlib._hashlib.HASH.__dict__.__contains__('__lt__') is False — HASH is a C extension type with no ordering semantics."
    - "Hash objects are opaque digest accumulators; equality by value is undefined, so __eq__ is also absent."
    - "None of __lt__, __le__, __gt__, __ge__, __ne__, __eq__, or __hash__ appear in HASH's own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra1726.comparison_protocol:
  description: "hashlib._hashlib.HASH comparison/ordering dict-presence checks — __lt__, __le__, __gt__, __ge__, __ne__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1726

  columns: [id, function, args, expected]
  rows:
    - ["hl1726001", "hashlib._hashlib.HASH.__dict__.__contains__", ["__lt__"], false]
    - ["hl1726002", "hashlib._hashlib.HASH.__dict__.__contains__", ["__le__"], false]
    - ["hl1726003", "hashlib._hashlib.HASH.__dict__.__contains__", ["__gt__"], false]
    - ["hl1726004", "hashlib._hashlib.HASH.__dict__.__contains__", ["__ge__"], false]
    - ["hl1726005", "hashlib._hashlib.HASH.__dict__.__contains__", ["__ne__"], false]

table hashlib_extra1726.eq_hash_protocol:
  description: "hashlib._hashlib.HASH __eq__ and __hash__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1726

  columns: [id, function, args, expected]
  rows:
    - ["hl1726006", "hashlib._hashlib.HASH.__dict__.__contains__", ["__eq__"], false]
    - ["hl1726007", "hashlib._hashlib.HASH.__dict__.__contains__", ["__hash__"], false]
