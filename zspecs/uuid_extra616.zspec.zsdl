spec: uuid_extra616
version: ">=3.9"
backend: python_module(uuid)
docs: "https://docs.python.org/3/library/uuid.html"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers SafeUUID enum values and UUID int representation, plus doc string class checks"
  created_at: "2026-04-12T00:00:00Z"

table uuid_extra616.safeuuid_class:
  description: "Class identity checks for uuid.SafeUUID enum members"
  kind: python_call_eq
  category: enum_identity
  id_prefix: uu616sv
  columns: [id, function, args, expected]
  rows:
    - [uu616sv001, uuid.SafeUUID.safe.__class__.__name__.__eq__, ["SafeUUID"], true]
    - [uu616sv002, uuid.SafeUUID.unsafe.__class__.__name__.__eq__, ["SafeUUID"], true]
    - [uu616sv003, uuid.SafeUUID.safe.value.__class__.__name__.__eq__, ["int"], true]
    - [uu616sv004, uuid.SafeUUID.unsafe.value.__class__.__name__.__eq__, ["int"], true]
    - [uu616sv005, uuid.SafeUUID.safe.name.__eq__, ["safe"], true]
    - [uu616sv006, uuid.SafeUUID.unsafe.name.__eq__, ["unsafe"], true]

table uuid_extra616.uuid_doc_types:
  description: "Doc string class checks for uuid.UUID and uuid generation functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: uu616dc
  columns: [id, function, args, expected]
  rows:
    - [uu616dc001, uuid.UUID.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu616dc002, uuid.uuid1.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu616dc003, uuid.uuid3.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu616dc004, uuid.uuid4.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu616dc005, uuid.uuid5.__doc__.__class__.__name__.__eq__, ["str"], true]
