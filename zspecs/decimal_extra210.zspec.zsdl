spec: decimal_extra210
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra209.zspec.zsdl — covers decimal class __doc__ contains checks (different words)"
  notes:
    - "decimal.Decimal.__doc__ starts with 'Construct a new Decimal object.'; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__doc__.__contains__('string') == True; value can be a string; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__doc__.__contains__('integer') == True; value can be an integer; confirmed Python 3.14.3 macOS."
    - "decimal.Decimal.__doc__.__contains__('tuple') == True; value can be a tuple; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__doc__.__contains__('rounding') == True; Context controls rounding; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__doc__.__contains__('trap') == True; Context mentions trap; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__doc__.__contains__('operations') == True; doc says 'affects almost all operations'; confirmed Python 3.14.3 macOS."
    - "decimal.getcontext.__doc__ == 'Get the current default context.'; confirmed Python 3.14.3 macOS."
    - "decimal.setcontext.__doc__ == 'Set a new default context.'; confirmed Python 3.14.3 macOS."
    - "decimal.localcontext.__doc__ describes context manager for restoring context; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __doc__ contains checks for decimal.Decimal (new words)
# decimal.Decimal __doc__ string substring membership — different words
# ---------------------------------------------------------------------------

table decimal_extra210.decimal_class_doc_contains:
  description: "decimal.Decimal __doc__ string contains expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: decimaldoccontains210a

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_doc_contains_Construct,   decimal.Decimal.__doc__.__contains__, ["Construct"],  true, "decimal.Decimal.__doc__.__contains__('Construct') == True; doc starts with 'Construct a new Decimal object'; confirmed Python 3.14.3 macOS"]
    - [decimal_doc_contains_object,      decimal.Decimal.__doc__.__contains__, ["object"],     true, "decimal.Decimal.__doc__.__contains__('object') == True; doc says 'Construct a new Decimal object'; confirmed Python 3.14.3 macOS"]
    - [decimal_doc_contains_integer,     decimal.Decimal.__doc__.__contains__, ["integer"],    true, "decimal.Decimal.__doc__.__contains__('integer') == True; doc says value can be an integer; confirmed Python 3.14.3 macOS"]
    - [decimal_doc_contains_string,      decimal.Decimal.__doc__.__contains__, ["string"],     true, "decimal.Decimal.__doc__.__contains__('string') == True; doc says value can be a string; confirmed Python 3.14.3 macOS"]
    - [decimal_doc_contains_tuple,       decimal.Decimal.__doc__.__contains__, ["tuple"],      true, "decimal.Decimal.__doc__.__contains__('tuple') == True; doc says value can be a tuple; confirmed Python 3.14.3 macOS"]
    - [decimal_doc_contains_value,       decimal.Decimal.__doc__.__contains__, ["value"],      true, "decimal.Decimal.__doc__.__contains__('value') == True; doc says 'value can be an integer, string, tuple'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: __doc__ contains checks for decimal.Context (new words)
# decimal.Context __doc__ string substring membership — different words
# ---------------------------------------------------------------------------

table decimal_extra210.context_class_doc_contains:
  description: "decimal.Context __doc__ string contains expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: decimaldoccontains210b

  columns: [id, function, args, expected, description]
  rows:
    - [context_doc_contains_affects,     decimal.Context.__doc__.__contains__, ["affects"],     true, "decimal.Context.__doc__.__contains__('affects') == True; doc says 'affects almost all operations'; confirmed Python 3.14.3 macOS"]
    - [context_doc_contains_rounding,    decimal.Context.__doc__.__contains__, ["rounding"],    true, "decimal.Context.__doc__.__contains__('rounding') == True; Context controls rounding; confirmed Python 3.14.3 macOS"]
    - [context_doc_contains_trap,        decimal.Context.__doc__.__contains__, ["trap"],        true, "decimal.Context.__doc__.__contains__('trap') == True; Context doc mentions trap; confirmed Python 3.14.3 macOS"]
    - [context_doc_contains_operations,  decimal.Context.__doc__.__contains__, ["operations"],  true, "decimal.Context.__doc__.__contains__('operations') == True; doc says 'affects almost all operations'; confirmed Python 3.14.3 macOS"]
    - [context_doc_contains_exceptions,  decimal.Context.__doc__.__contains__, ["exceptions"],  true, "decimal.Context.__doc__.__contains__('exceptions') == True; Context controls raising of exceptions; confirmed Python 3.14.3 macOS"]
    - [context_doc_contains_prec,        decimal.Context.__doc__.__contains__, ["prec"],        true, "decimal.Context.__doc__.__contains__('prec') == True; doc shows 'Context(prec=28, ...)' example; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: __doc__ contains checks for decimal context functions (new words)
# decimal.getcontext, setcontext, localcontext __doc__ string substring membership
# ---------------------------------------------------------------------------

table decimal_extra210.context_func_doc_contains:
  description: "decimal.getcontext, setcontext, and localcontext __doc__ string contains expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: decimaldoccontains210c

  columns: [id, function, args, expected, description]
  rows:
    - [getcontext_doc_contains_Get,      decimal.getcontext.__doc__.__contains__,   ["Get"],      true, "decimal.getcontext.__doc__.__contains__('Get') == True; doc starts with 'Get the current default context'; confirmed Python 3.14.3 macOS"]
    - [getcontext_doc_contains_default,  decimal.getcontext.__doc__.__contains__,   ["default"],  true, "decimal.getcontext.__doc__.__contains__('default') == True; doc says 'current default context'; confirmed Python 3.14.3 macOS"]
    - [getcontext_doc_contains_context,  decimal.getcontext.__doc__.__contains__,   ["context"],  true, "decimal.getcontext.__doc__.__contains__('context') == True; doc mentions context; confirmed Python 3.14.3 macOS"]
    - [setcontext_doc_contains_Set,      decimal.setcontext.__doc__.__contains__,   ["Set"],      true, "decimal.setcontext.__doc__.__contains__('Set') == True; doc starts with 'Set a new default context'; confirmed Python 3.14.3 macOS"]
    - [setcontext_doc_contains_new,      decimal.setcontext.__doc__.__contains__,   ["new"],      true, "decimal.setcontext.__doc__.__contains__('new') == True; doc says 'Set a new default context'; confirmed Python 3.14.3 macOS"]
    - [localcontext_doc_contains_copy,   decimal.localcontext.__doc__.__contains__,  ["copy"],    true, "decimal.localcontext.__doc__.__contains__('copy') == True; doc says 'set the default context to a copy of ctx'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra210.decimal_doc_contains_Construct:
  description: "decimal.Decimal.__doc__.__contains__('Construct') == True — Decimal doc starts with 'Construct a new Decimal object'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__doc__.__contains__
  args: ["Construct"]
  expected: true

invariant decimal_extra210.decimal_doc_contains_integer:
  description: "decimal.Decimal.__doc__.__contains__('integer') == True — Decimal doc says value can be an integer; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__doc__.__contains__
  args: ["integer"]
  expected: true

invariant decimal_extra210.decimal_doc_contains_tuple:
  description: "decimal.Decimal.__doc__.__contains__('tuple') == True — Decimal doc says value can be a tuple; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__doc__.__contains__
  args: ["tuple"]
  expected: true

invariant decimal_extra210.context_doc_contains_rounding:
  description: "decimal.Context.__doc__.__contains__('rounding') == True — Context doc says it controls rounding; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__doc__.__contains__
  args: ["rounding"]
  expected: true

invariant decimal_extra210.context_doc_contains_exceptions:
  description: "decimal.Context.__doc__.__contains__('exceptions') == True — Context doc says it controls raising of exceptions; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__doc__.__contains__
  args: ["exceptions"]
  expected: true

invariant decimal_extra210.getcontext_doc_contains_default:
  description: "decimal.getcontext.__doc__.__contains__('default') == True — getcontext doc says 'Get the current default context'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.getcontext.__doc__.__contains__
  args: ["default"]
  expected: true

invariant decimal_extra210.localcontext_doc_contains_copy:
  description: "decimal.localcontext.__doc__.__contains__('copy') == True — localcontext doc says 'set the default context to a copy of ctx'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.localcontext.__doc__.__contains__
  args: ["copy"]
  expected: true

