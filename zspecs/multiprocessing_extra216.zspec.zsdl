spec: multiprocessing_extra216
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
  notes:
    - "multiprocessing.Process.__name__ == 'Process' — startswith('Process') is True; len is 7; verified with Python 3.14.3."
    - "multiprocessing.Process.__module__ == 'multiprocessing.context' — startswith('multiprocessing') is True; verified with Python 3.14.3."
    - "multiprocessing.AuthenticationError.__name__ == 'AuthenticationError' — startswith('Authentication') and endswith('Error') both True; verified with Python 3.14.3."
    - "multiprocessing.ProcessError.__name__ == 'ProcessError' — startswith('Process') and endswith('Error') both True; verified with Python 3.14.3."
    - "multiprocessing.TimeoutError.__name__ == 'TimeoutError' — endswith('Error') is True; verified with Python 3.14.3."
    - "multiprocessing.BufferTooShort.__name__ == 'BufferTooShort' — endswith('Short') is True; verified with Python 3.14.3."
    - "multiprocessing.Process.__name__.__len__() == 7 — 'Process' has 7 characters; verified with Python 3.14.3."
    - "multiprocessing.cpu_count().__class__.__name__ == 'int' — cpu_count() returns an int on POSIX/macOS platforms; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing class name string contracts — extra216 namespace
#
# Process, AuthenticationError, ProcessError, TimeoutError, BufferTooShort name checks.
# ---------------------------------------------------------------------------

table multiprocessing_extra216.name_string_checks:
  description: "multiprocessing class __name__ startswith/endswith string contracts in mp216ns namespace"
  kind: python_call_eq
  category: string_comparison
  id_prefix: mp216ns

  columns: [id, function, args, expected, description]
  rows:
    - [Process_sw_Process,                Process.__name__.__startswith__,             ["Process"],        true, "multiprocessing.Process.__name__.__startswith__('Process') == True — verified with Python 3.14.3"]
    - [AuthenticationError_sw_Auth,       AuthenticationError.__name__.__startswith__, ["Authentication"], true, "multiprocessing.AuthenticationError.__name__.__startswith__('Authentication') == True — verified with Python 3.14.3"]
    - [ProcessError_sw_Process,           ProcessError.__name__.__startswith__,        ["Process"],        true, "multiprocessing.ProcessError.__name__.__startswith__('Process') == True — verified with Python 3.14.3"]
    - [AuthenticationError_ew_Error,      AuthenticationError.__name__.__endswith__,   ["Error"],          true, "multiprocessing.AuthenticationError.__name__.__endswith__('Error') == True — verified with Python 3.14.3"]
    - [ProcessError_ew_Error,             ProcessError.__name__.__endswith__,          ["Error"],          true, "multiprocessing.ProcessError.__name__.__endswith__('Error') == True — verified with Python 3.14.3"]
    - [TimeoutError_ew_Error,             TimeoutError.__name__.__endswith__,          ["Error"],          true, "multiprocessing.TimeoutError.__name__.__endswith__('Error') == True — verified with Python 3.14.3"]
    - [BufferTooShort_ew_Short,           BufferTooShort.__name__.__endswith__,        ["Short"],          true, "multiprocessing.BufferTooShort.__name__.__endswith__('Short') == True — verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing class __module__ startswith contracts — extra216 namespace
#
# Process.__module__ is 'multiprocessing.context'; verified Python 3.14.3.
# ---------------------------------------------------------------------------

table multiprocessing_extra216.module_checks:
  description: "multiprocessing class __module__ startswith contracts in mp216mod namespace"
  kind: python_call_eq
  category: module_identity
  id_prefix: mp216mod

  columns: [id, function, args, expected, description]
  rows:
    - [Process_module_sw_multiprocessing, Process.__module__.__startswith__, ["multiprocessing"], true, "multiprocessing.Process.__module__.__startswith__('multiprocessing') == True — module is 'multiprocessing.context'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process.__name__ length — extra216 namespace
#
# 'Process' has 7 chars; verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra216.process_name_len_7:
  description: "multiprocessing.Process.__name__.__len__() == 7 — 'Process' has 7 characters; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: string_comparison
  kind: python_call_eq
  function: Process.__name__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# multiprocessing cpu_count() return type — extra216 namespace
#
# cpu_count() returns int on POSIX/macOS platforms; verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra216.cpu_count_class_name:
  description: "multiprocessing.cpu_count().__class__.__name__ == 'int' — cpu_count() returns an integer on POSIX platforms; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: type_identity
  kind: python_call_eq
  function: cpu_count()
  args: []
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true

