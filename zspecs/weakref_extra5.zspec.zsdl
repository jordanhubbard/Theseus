spec: weakref_extra5
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
  notes:
    - "This spec extends weakref.zspec.zsdl, weakref_extra.zspec.zsdl, weakref_extra2.zspec.zsdl, weakref_extra4.zspec.zsdl."
    - "Focus: __qualname__ checks for weakref classes; ref.__module__ and finalize.__module__."
    - "weakref.ref.__qualname__ == 'weakref' — the C-level type has qualname 'weakref', not 'ref'."
    - "weakref.WeakValueDictionary.__qualname__ == 'WeakValueDictionary'."
    - "weakref.WeakKeyDictionary.__qualname__ == 'WeakKeyDictionary'."
    - "weakref.WeakSet.__qualname__ == 'WeakSet'."
    - "weakref.finalize.__qualname__ == 'finalize'."
    - "weakref.proxy.__qualname__ == 'proxy' — proxy() is a C-level builtin."
    - "weakref.ref.__module__ == 'builtins' is NOT the case; weakref.ref is from _weakref (C ext), its __module__ == 'builtins' under some implementations. In CPython 3.9-3.12 weakref.ref.__module__ == 'builtins'."
    - "weakref.WeakValueDictionary.__module__ == 'weakref' — pure-Python class."
    - "weakref.WeakKeyDictionary.__module__ == 'weakref' — pure-Python class."
    - "weakref.WeakSet.__module__ == 'weakref' — pure-Python class."
    - "weakref.finalize.__module__ == '_weakref' — implemented in C; __module__ reflects the C extension."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for weakref classes (table)
# ---------------------------------------------------------------------------

table weakref_extra5.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [WeakValueDictionary, WeakValueDictionary.__qualname__.__eq__, ["WeakValueDictionary"], true]
    - [WeakKeyDictionary,   WeakKeyDictionary.__qualname__.__eq__,   ["WeakKeyDictionary"],   true]
    - [WeakSet,             WeakSet.__qualname__.__eq__,             ["WeakSet"],             true]
    - [finalize,            finalize.__qualname__.__eq__,            ["finalize"],            true]

# ---------------------------------------------------------------------------
# weakref.ref.__qualname__ — C-level type has qualname 'weakref'
# ---------------------------------------------------------------------------

invariant weakref_extra5.ref.qualname:
  description: "weakref.ref.__qualname__ == 'weakref' — the C-level ref type has qualname 'weakref'"
  category: qualnames
  kind: python_call_eq
  function: ref.__qualname__.__eq__
  args: ["weakref"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.proxy.__qualname__ — C-level callable
# ---------------------------------------------------------------------------

invariant weakref_extra5.proxy.qualname:
  description: "weakref.proxy.__qualname__ == 'proxy'"
  category: qualnames
  kind: python_call_eq
  function: proxy.__qualname__.__eq__
  args: ["proxy"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ checks not yet covered in prior specs
# ---------------------------------------------------------------------------

invariant weakref_extra5.finalize.module:
  description: "weakref.finalize.__module__ == '_weakref' — finalize is implemented in the C extension"
  category: module
  kind: python_call_eq
  function: finalize.__module__.__eq__
  args: ["_weakref"]
  expected: true
