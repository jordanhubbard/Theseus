spec: sys_extra29
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
    - "sys_extra28.zspec.zsdl — covers __qualname__ for getdefaultencoding/getfilesystemencoding/getsizeof/intern/exc_info/exit/getrecursionlimit/setrecursionlimit and __module__ for getdefaultencoding/getfilesystemencoding/getsizeof/exit; NOT __len__() on any __module__ or __name__ strings."
  notes:
    - "This spec extends sys.zspec.zsdl through sys_extra28.zspec.zsdl."
    - "Prior specs covered: sys.__name__/__package__, various attribute class names, getrecursionlimit()==1000, getdefaultencoding/getfilesystemencoding/getsizeof/intern/exc_info/exit/getrecursionlimit/setrecursionlimit __name__/__module__/__qualname__, stdin/stdout/stderr class names, version_info class name."
    - "This spec covers: __module__.__len__() for getdefaultencoding/getfilesystemencoding/getsizeof/exit (all 3, for 'sys'); __name__.__len__() for getdefaultencoding/getfilesystemencoding/getsizeof/exit/intern/exc_info/getrecursionlimit/setrecursionlimit."
    - "All __module__ strings for these sys built-in functions are 'sys' (len 3). __name__ lengths: getdefaultencoding=18, getfilesystemencoding=21, getsizeof=9, exit=4, intern=6, exc_info=8, getrecursionlimit=17, setrecursionlimit=17."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sys built-in function __module__ string lengths
#
# sys_extra28 covers __module__ values for getdefaultencoding, getfilesystemencoding,
# getsizeof, and exit (all == 'sys'). No prior sys spec checks the __len__() of
# these __module__ strings. 'sys' has 3 characters.
# ---------------------------------------------------------------------------

table sys_extra29.builtin_function_module_lengths:
  description: "__module__.__len__() == 3 for sys built-in functions (all 'sys')"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fnmodlen29

  columns: [id, function, args, expected]
  rows:
    - [getdefaultencoding,    getdefaultencoding.__module__.__len__,    [], 3]
    - [getfilesystemencoding, getfilesystemencoding.__module__.__len__, [], 3]
    - [getsizeof,             getsizeof.__module__.__len__,             [], 3]
    - [exit,                  exit.__module__.__len__,                  [], 3]

# ---------------------------------------------------------------------------
# sys built-in function __name__ string lengths
#
# Prior specs confirm the __name__ values for all these functions. No prior
# sys spec checks __len__() on the __name__ strings. Lengths:
#   getdefaultencoding    == 18
#   getfilesystemencoding == 21
#   getsizeof             == 9
#   exit                  == 4
#   intern                == 6
#   exc_info              == 8
#   getrecursionlimit     == 17
#   setrecursionlimit     == 17
# ---------------------------------------------------------------------------

table sys_extra29.builtin_function_name_lengths:
  description: "__name__.__len__() for sys built-in functions"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fnnlen29

  columns: [id, function, args, expected]
  rows:
    - [getdefaultencoding,    getdefaultencoding.__name__.__len__,    [], 18]
    - [getfilesystemencoding, getfilesystemencoding.__name__.__len__, [], 21]
    - [getsizeof,             getsizeof.__name__.__len__,             [], 9]
    - [exit,                  exit.__name__.__len__,                  [], 4]
    - [intern,                intern.__name__.__len__,                [], 6]
    - [exc_info,              exc_info.__name__.__len__,              [], 8]
    - [getrecursionlimit,     getrecursionlimit.__name__.__len__,     [], 17]
    - [setrecursionlimit,     setrecursionlimit.__name__.__len__,     [], 17]

# ---------------------------------------------------------------------------
# Standalone invariants — __module__ string lengths
# ---------------------------------------------------------------------------

invariant sys_extra29.getdefaultencoding.module_len:
  description: "sys.getdefaultencoding.__module__.__len__() == 3 — 'sys' has 3 characters"
  category: function_attrs
  kind: python_call_eq
  function: getdefaultencoding.__module__.__len__
  args: []
  expected: 3

invariant sys_extra29.getfilesystemencoding.module_len:
  description: "sys.getfilesystemencoding.__module__.__len__() == 3 — 'sys' has 3 characters"
  category: function_attrs
  kind: python_call_eq
  function: getfilesystemencoding.__module__.__len__
  args: []
  expected: 3

invariant sys_extra29.getsizeof.module_len:
  description: "sys.getsizeof.__module__.__len__() == 3 — 'sys' has 3 characters"
  category: function_attrs
  kind: python_call_eq
  function: getsizeof.__module__.__len__
  args: []
  expected: 3

invariant sys_extra29.exit.module_len:
  description: "sys.exit.__module__.__len__() == 3 — 'sys' has 3 characters"
  category: function_attrs
  kind: python_call_eq
  function: exit.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Standalone invariants — __name__ string lengths
# ---------------------------------------------------------------------------

invariant sys_extra29.getdefaultencoding.name_len:
  description: "sys.getdefaultencoding.__name__.__len__() == 18 — 'getdefaultencoding' has 18 characters"
  category: function_attrs
  kind: python_call_eq
  function: getdefaultencoding.__name__.__len__
  args: []
  expected: 18

invariant sys_extra29.getfilesystemencoding.name_len:
  description: "sys.getfilesystemencoding.__name__.__len__() == 21 — 'getfilesystemencoding' has 21 characters"
  category: function_attrs
  kind: python_call_eq
  function: getfilesystemencoding.__name__.__len__
  args: []
  expected: 21

invariant sys_extra29.getsizeof.name_len:
  description: "sys.getsizeof.__name__.__len__() == 9 — 'getsizeof' has 9 characters"
  category: function_attrs
