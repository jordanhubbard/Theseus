spec: hashlib_extra156
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra155.zspec.zsdl — covers hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method') / sha256.__module__.__eq__('_hashlib') / sha256.__name__.__eq__('openssl_sha256') / md5.__name__.__eq__('openssl_md5') / sha1.__name__.__eq__('openssl_sha1') / sha512.__name__.__eq__('openssl_sha512') / pbkdf2_hmac.__module__.__eq__('_hashlib') / name length checks (table + invariants)."
    - "hashlib_extra154.zspec.zsdl — covers hashlib.algorithms_guaranteed/__class__.__name__.__eq__('set') / algorithms_available/__class__.__name__.__eq__('set') / algorithms_guaranteed.__len__()==14 / algorithms_guaranteed.__contains__('sha256'/'md5'/'sha1'/'sha512'/'blake2b'/'sha3_256'/'shake_128') (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ equality / algorithms_guaranteed.__len__()==14."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra155."
    - "Wave 335 theme: hashlib hash constructor __qualname__ and blake2b/__name__ identity — sha256.__qualname__.__eq__('openssl_sha256') / sha256.__qualname__.__len__()==14 / md5.__qualname__.__eq__('openssl_md5') / sha512.__qualname__.__eq__('openssl_sha512') / blake2b.__name__.__eq__('blake2b') / blake2b.__qualname__.__eq__('blake2b') / sha3_256.__name__.__eq__('openssl_sha3_256')."
    - "hashlib.sha256.__qualname__ == 'openssl_sha256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__qualname__ == 'openssl_md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__qualname__ == 'openssl_sha512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__name__ == 'blake2b'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__qualname__ == 'blake2b'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__name__ == 'openssl_sha3_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__qualname__ == 'openssl_sha3_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: For the OpenSSL-backed constructors (sha256, md5, sha1, sha512, sha3_256), __qualname__ equals __name__ — both are the 'openssl_' prefixed forms. The __qualname__ is not 'sha256' or any module-qualified path; it is the bare C function name as exposed by the _hashlib extension. This is because builtin_function_or_method objects have __qualname__ set to the same value as __name__ at the C level."
    - "Note: hashlib.blake2b is NOT an OpenSSL-backed builtin_function_or_method like sha256. blake2b is a class (implemented in _hashlib as a type). Its __name__ and __qualname__ are both 'blake2b' (7 chars, no 'openssl_' prefix). This distinguishes it from sha256 (builtin_function_or_method, __name__='openssl_sha256') and from sha3_256 (__name__='openssl_sha3_256', 16 chars)."
    - "Note: hashlib.sha3_256.__name__ == 'openssl_sha3_256' (16 chars). This is 2 chars longer than 'openssl_sha256' (14 chars). The SHA-3 family (Keccak-based) constructors also receive the 'openssl_' prefix, matching the SHA-2 pattern. sha3_256 produces a 32-byte digest (same output size as SHA-256) but uses a different algorithm (Keccak sponge construction vs. Merkle-Damgard)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha256.__qualname__.__eq__('openssl_sha256')
# hashlib.md5.__qualname__.__eq__('openssl_md5')
# hashlib.sha512.__qualname__.__eq__('openssl_sha512')
# hashlib.sha256.__qualname__.__len__()==14
#
# Wave 335 theme: hash constructor __qualname__ values match __name__ values.
#
# For builtin_function_or_method objects from _hashlib, __qualname__ == __name__.
# sha256.__qualname__ == 'openssl_sha256' (14 chars), md5.__qualname__ == 'openssl_md5'
# (11 chars), sha512.__qualname__ == 'openssl_sha512' (14 chars). extra155 anchors
# __name__ for all three; no prior hashlib spec anchors __qualname__ as a table under
# hashhq156. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra156.sha256_md5_sha512_qualnames:
  description: "hashlib.sha256.__qualname__.__eq__('openssl_sha256')==True / md5.__qualname__.__eq__('openssl_md5')==True / sha512.__qualname__.__eq__('openssl_sha512')==True / sha256.__qualname__.__len__()==14 — for builtin_function_or_method objects __qualname__==__name__ (same 'openssl_' prefixed value); sha256 and sha512 both 14 chars; md5 is 11 chars; no prior hashlib spec anchors __qualname__ for these constructors; first hashhq156 anchor for sha256/md5/sha512 qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: hashhq156

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_qualname_openssl,  "sha256.__qualname__.__eq__",    ["openssl_sha256"],  true, "hashlib.sha256.__qualname__ == 'openssl_sha256' (14 chars; __qualname__==__name__ for builtin_function_or_method)"]
    - [md5_qualname_openssl,     "md5.__qualname__.__eq__",       ["openssl_md5"],     true, "hashlib.md5.__qualname__ == 'openssl_md5' (11 chars; __qualname__==__name__; 'openssl_'=8 + 'md5'=3)"]
    - [sha512_qualname_openssl,  "sha512.__qualname__.__eq__",    ["openssl_sha512"],  true, "hashlib.sha512.__qualname__ == 'openssl_sha512' (14 chars; same length as sha256 qualname)"]
    - [sha256_qualname_len_14,   "sha256.__qualname__.__len__",   [],                  14,   "hashlib.sha256.__qualname__.__len__() is 14 ('openssl_sha256' = 14 chars; equals sha256.__name__.__len__())"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__name__.__eq__('blake2b')
# hashlib.blake2b.__qualname__.__eq__('blake2b')
# hashlib.sha3_256.__name__.__eq__('openssl_sha3_256')
# hashlib.sha3_256.__qualname__.__len__()==16
#
# Wave 335 theme: blake2b (class) vs sha3_256 (openssl-prefixed builtin_function_or_method).
#
# blake2b is a class (not a builtin_function_or_method), so its __name__ is 'blake2b'
# (7 chars, no 'openssl_' prefix). sha3_256 IS an openssl-backed constructor with
# __name__=='openssl_sha3_256' (16 chars). No prior hashlib spec anchors blake2b.__name__
# or sha3_256.__name__ as a table under hashhq156. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra156.blake2b_and_sha3_256_identity:
  description: "hashlib.blake2b.__name__.__eq__('blake2b')==True / blake2b.__qualname__.__eq__('blake2b')==True / sha3_256.__name__.__eq__('openssl_sha3_256')==True / sha3_256.__qualname__.__len__()==16 — blake2b is a class (7 chars, no 'openssl_' prefix; __name__==__qualname__=='blake2b'); sha3_256 is openssl-backed (16 chars: 'openssl_'=8 + 'sha3_256'=8); sha3_256.__qualname__.__len__() > sha256.__qualname__.__len__() by 2 (16 vs 14); first hashhq156 anchor for blake2b/__name__/__qualname__ and sha3_256/__name__"
  kind: python_call_eq
  category: identity
  id_prefix: hashhq156

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_name_blake2b,      "blake2b.__name__.__eq__",        ["blake2b"],          true, "hashlib.blake2b.__name__ == 'blake2b' (7 chars; class type, not builtin_function_or_method; no 'openssl_' prefix)"]
    - [blake2b_qualname_blake2b,  "blake2b.__qualname__.__eq__",    ["blake2b"],          true, "hashlib.blake2b.__qualname__ == 'blake2b' (7 chars; class __qualname__ equals __name__; no 'openssl_' prefix)"]
    - [sha3_256_name_openssl,     "sha3_256.__name__.__eq__",       ["openssl_sha3_256"], true, "hashlib.sha3_256.__name__ == 'openssl_sha3_256' (16 chars; 'openssl_'=8 + 'sha3_256'=8; SHA-3 Keccak-based)"]
    - [sha3_256_qualname_len_16,  "sha3_256.__qualname__.__len__",  [],                   16,   "hashlib.sha3_256.__qualname__.__len__() is 16 ('openssl_sha3_256' = 16 chars; 2 more than sha256's 14)"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.__name__.__len__()==7
# hashlib.sha3_256.__qualname__.__eq__('openssl_sha3_256')
# hashlib.sha256.__qualname__.__eq__('openssl_sha256') / md5.__qualname__.__len__()==11
#
# Wave 335 theme: qualname and name length comparisons across hash constructors.
#
# blake2b.__name__.__len__() == 7; sha3_256.__qualname__ == 'openssl_sha3_256' (16 chars).
# Length ordering: blake2b(7) < md5(11) < sha1(12) < sha256==sha512(14) < sha3_256(16).
# No prior hashlib spec anchors these lengths or sha3_256.__qualname__ as a table under
# hashhq156. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra156.qualname_length_ordering:
  description: "hashlib.blake2b.__name__.__len__()==7 / sha3_256.__qualname__.__eq__('openssl_sha3_256')==True / md5.__qualname__.__len__()==11 / sha3_256.__name__.__len__()==16 — length ordering: blake2b(7) < md5(11) < sha1(12) < sha256==sha512(14) < sha3_256(16); blake2b has no 'openssl_' prefix (7 chars); sha3_256 is 16 chars ('openssl_'=8 + 'sha3_256'=8); first hashhq156 anchor for these length values"
  kind: python_call_eq
  category: identity
  id_prefix: hashhq156

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_name_len_7,        "blake2b.__name__.__len__",       [],                   7,    "hashlib.blake2b.__name__.__len__() is 7 ('blake2b' = 7 chars; shortest named constructor __name__; no prefix)"]
    - [sha3_256_qualname_eq,      "sha3_256.__qualname__.__eq__",   ["openssl_sha3_256"], true, "hashlib.sha3_256.__qualname__ == 'openssl_sha3_256' (16 chars; qualname==name for this builtin_function_or_method)"]
    - [md5_qualname_len_11,       "md5.__qualname__.__len__",       [],                   11,   "hashlib.md5.__qualname__.__len__() is 11 ('openssl_md5' = 11 chars; equals md5.__name__.__len__())"]
    - [sha3_256_name_len_16,      "sha3_256.__name__.__len__",      [],                   16,   "hashlib.sha3_256.__name__.__len__() is 16 ('openssl_sha3_256' = 16 chars; longest of the named constructors)"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__qualname__.__eq__('openssl_sha256') — standalone
#
# hashlib.sha256.__qualname__ is 'openssl_sha256' (14 chars). For builtin_function_or_method
# objects from _hashlib, __qualname__ equals __name__. This means sha256.__qualname__ is
# 'openssl_sha256', not 'sha256', not '_hashlib.openssl_sha256', and not any module-qualified
# path. The __qualname__ of a C extension callable is set at the C level to the same value
# as its __name__. extra155 anchors sha256.__name__.__eq__('openssl_sha256') as a table
# and standalone; no prior hashlib spec anchors sha256.__qualname__ as a standalone under
# hashhq156. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra156.sha256_qualname_eq_openssl_sha256:
  description: "hashlib.sha256.__qualname__.__eq__('openssl_sha256') == True — 14 chars; for builtin_function_or_method __qualname__==__name__; not 'sha256' or '_hashlib.sha256'; C extension sets __qualname__=__name__ at the C level; extra155 anchors sha256.__name__=='openssl_sha256'; no prior hashlib spec anchors sha256.__qualname__ as a standalone; first standalone under hashhq156"
  category: identity
  kind: python_call_eq
  function: sha256.__qualname__.__eq__
  args: ["openssl_sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__name__.__eq__('blake2b') — standalone
#
# hashlib.blake2b.__name__ is 'blake2b' (7 chars). Unlike sha256, md5, sha1, sha512, and
# sha3_256 — which are builtin_function_or_method objects with 'openssl_' prefixed __name__
# values — blake2b is a class (a C extension type). As a class, its __name__ is the bare
# class name 'blake2b' (7 chars), with no 'openssl_' prefix. This is because blake2b in
# CPython is implemented directly (not via OpenSSL) as _hashlib.BLAKE2b. No prior hashlib
# spec anchors blake2b.__name__.__eq__('blake2b') as a standalone under hashhq156.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra156.blake2b_name_eq_blake2b:
  description: "hashlib.blake2b.__name__.__eq__('blake2b') == True — 7 chars; blake2b is a class (not builtin_function_or_method); no 'openssl_' prefix unlike sha256/md5/sha1/sha512/sha3_256; implemented directly as _hashlib.BLAKE2b (not via OpenSSL); __name__==__qualname__=='blake2b'; no prior hashlib spec anchors this as a standalone; first standalone under hashhq156"
  category: identity
  kind: python_call_eq
  function: blake2b.__name__.__eq__
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__name__.__eq__('openssl_sha3_256') — standalone
#
# hashlib.sha3_256.__name__ is 'openssl_sha3_256' (16 chars). The SHA-3 family
# constructors (sha3_256, sha3_224, sha3_384, sha3_512) also receive the 'openssl_'
# prefix in CPython 3.14.3 on macOS, indicating they are backed by OpenSSL's Keccak
# implementation. sha3_256 produces a 32-byte (256-bit) digest using the Keccak sponge
# construction, which is algorithmically different from SHA-256 (Merkle-Damgard). The
# name 'openssl_sha3_256' (16 chars) is 2 chars longer than 'openssl_sha256' (14 chars)
# because 'sha3_256' (8 chars) is 2 chars longer than 'sha256' (6 chars). No prior
# hashlib spec anchors sha3_256.__name__ as a standalone under hashhq156.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra156.sha3_256_name_eq_openssl_sha3_256:
  description: "hashlib.sha3_256.__name__.__eq__('openssl_sha3_256') == True — 16 chars (longest named constructor __name__); 'openssl_'=8 + 'sha3_256'=8; SHA-3 Keccak sponge (different from SHA-2 Merkle-Damgard); 32-byte/256-bit digest (same output size as SHA-256 but different algorithm); 'openssl_sha3_256' is 2 chars longer than 'openssl_sha256' (14 chars); no prior hashlib spec anchors this as a standalone; first standalone under hashhq156"
  category: identity
  kind: python_call_eq
  function: sha3_256.__name__.__eq__
  args: ["openssl_sha3_256"]
  expected: true

