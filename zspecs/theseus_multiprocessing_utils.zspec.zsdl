spec: theseus_multiprocessing_utils
version: ">=3.9"
backend: python_cleanroom(theseus_multiprocessing_utils)
blocks: multiprocessing

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
  notes:
    - "Clean-room multiprocessing primitives (inter-process coordination only). Do NOT import multiprocessing."
    - "Provide Pipe-like message passing, Queue-like FIFO, shared state via value objects."
    - "Queue: FIFO queue with put/get; empty() when no items; qsize() returns item count."
    - "Pipe-equivalent: SimpleChannel with send/recv."
    - "Value(typecode, val): holds a sharable typed value with .value attribute."
    - "multiprocessing_queue_put_get(): Queue().put(42); get() == 42."
    - "multiprocessing_queue_empty(): empty Queue is empty."
    - "multiprocessing_value(): Value('i', 7).value == 7."
    - "Export: Queue, SimpleChannel, Value classes."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_multiprocessing_utils.queue_put_get:
  description: "Queue().put(42); get() == 42"
  category: queue
  kind: python_call_eq
  function: multiprocessing_queue_put_get
  args: []
  expected: 42

invariant theseus_multiprocessing_utils.queue_empty:
  description: "new Queue() is empty"
  category: queue
  kind: python_call_eq
  function: multiprocessing_queue_empty
  args: []
  expected: true

invariant theseus_multiprocessing_utils.value:
  description: "Value('i', 7).value == 7"
  category: value
  kind: python_call_eq
  function: multiprocessing_value
  args: []
  expected: 7
