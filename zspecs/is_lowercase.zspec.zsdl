spec: is_lowercase
version: ">=1.0.0"
backend: node(is-lowercase)

docs: https://www.npmjs.com/package/is-lowercase

provenance:
  derived_from:
    - "is-lowercase README — https://www.npmjs.com/package/is-lowercase"
    - "Test vectors verified with is-lowercase via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-lowercase source"
  notes:
    - "is-lowercase is an npm package. Install: npm install is-lowercase"
    - "Returns true if every character in the string is lowercase."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_lowercase.isLowercase:
  kind: node_module_call_eq
  function: ~
  category: predicate
  id_prefix: islo

  columns: [id, args, expected]
  rows:
    - [all_lower,  ["hello"],  true]
    - [all_upper,  ["HELLO"],  false]
    - [mixed,      ["Hello"],  false]

