spec: time_extra7
version: ">=3.9"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html — Python time module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
    - "time.zspec.zsdl — covers gmtime/strptime/strftime/mktime/sleep __name__ (table), struct_time.__name__, epoch vectors, strptime vectors"
    - "time_extra.zspec.zsdl — covers struct_time.__module__, time/monotonic/perf_counter/process_time return float, gmtime/localtime return struct_time, timezone/altzone int type"
    - "time_extra2.zspec.zsdl — covers struct_time.__name__/__module__, timezone/altzone/daylight int class names, gmtime(0) epoch fields, time/__name__, sleep/__name__"
    - "time_extra3.zspec.zsdl — covers struct_time._fields, altzone/daylight/timezone/tzname class names, gmtime/localtime/mktime/strftime/strptime __name__ table"
    - "time_extra4.zspec.zsdl — covers __qualname__ for all core time functions and struct_time"
    - "time_extra5.zspec.zsdl — covers __module__ for all core time functions and struct_time"
    - "time_extra6.zspec.zsdl — covers CLOCK_* constants and struct_time n_fields/n_sequence_fields/n_unnamed_fields; get_clock_info __name__/__module__/behavioral"
  notes:
    - "This spec extends the time chain and does NOT duplicate invariants already present in any prior spec."
    - "Focus: nanosecond-resolution clock functions (time_ns, monotonic_ns, perf_counter_ns) and thread_time — none covered in any prior spec."
    - "time.time_ns() returns int (nanoseconds since epoch); time_extra covers time() returning float."
    - "time.monotonic_ns() returns int (monotonic nanoseconds); time_extra covers monotonic() returning float."
    - "time.perf_counter_ns() returns int (perf counter nanoseconds); time_extra covers perf_counter() returning float."
    - "time.thread_time() returns float — CPU time for the current thread; not in any prior spec."
    - "time.time_ns.__name__ == 'time_ns', time.monotonic_ns.__name__ == 'monotonic_ns', time.perf_counter_ns.__name__ == 'perf_counter_ns', time.thread_time.__name__ == 'thread_time'."
    - "time.time_ns.__qualname__ == 'time_ns' — flat qualname for C builtin."
    - "time.thread_time.__qualname__ == 'thread_time' — flat qualname for C builtin."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Nanosecond clock return types — time_ns, monotonic_ns, perf_counter_ns
#
# time_extra covers time(), monotonic(), perf_counter(), process_time() which
# all return float. The nanosecond variants return int (not float) and are
# entirely uncovered by any prior spec.
# ---------------------------------------------------------------------------

invariant time_extra7.time_ns.return_type:
  description: "time.time_ns().__class__.__name__ == 'int' — nanosecond timestamp is an integer"
  category: return_types
  kind: python_call_eq
  function: time_ns
  args: []
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true

invariant time_extra7.monotonic_ns.return_type:
  description: "time.monotonic_ns().__class__.__name__ == 'int' — nanosecond monotonic clock is an integer"
  category: return_types
  kind: python_call_eq
  function: monotonic_ns
  args: []
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true

invariant time_extra7.perf_counter_ns.return_type:
  description: "time.perf_counter_ns().__class__.__name__ == 'int' — nanosecond perf counter is an integer"
  category: return_types
  kind: python_call_eq
  function: perf_counter_ns
  args: []
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# thread_time return type
#
# time.thread_time() measures CPU time consumed by the current thread; it
# returns float. Not covered in any prior spec (only process_time is covered
# in time_extra as a float-returning function).
# ---------------------------------------------------------------------------

invariant time_extra7.thread_time.return_type:
  description: "time.thread_time().__class__.__name__ == 'float' — thread CPU time is a float"
  category: return_types
  kind: python_call_eq
  function: thread_time
  args: []
  method: __class__.__name__.__eq__
  method_args: ["float"]
  expected: true

# ---------------------------------------------------------------------------
# Nanosecond function __name__ attributes
#
# time.zspec.zsdl covers gmtime/strptime/strftime/mktime/sleep __name__.
# time_extra2 and time_extra3 cover sleep, time, localtime, mktime, strftime,
# strptime __name__. The nanosecond variants are entirely new.
# ---------------------------------------------------------------------------

table time_extra7.ns_function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: nsname

  columns: [id, function, args, expected]
  rows:
    - [time_ns,        time_ns.__name__.__eq__,        ["time_ns"],        true]
    - [monotonic_ns,   monotonic_ns.__name__.__eq__,   ["monotonic_ns"],   true]
    - [perf_counter_ns, perf_counter_ns.__name__.__eq__, ["perf_counter_ns"], true]
    - [thread_time,    thread_time.__name__.__eq__,    ["thread_time"],    true]

# ---------------------------------------------------------------------------
# Nanosecond function __qualname__ attributes
#
# time_extra4 covers __qualname__ for time/sleep/monotonic/perf_counter/
# process_time/gmtime/localtime/mktime/strftime/strptime. The nanosecond
# variants and thread_time are not covered.
# ---------------------------------------------------------------------------

invariant time_extra7.time_ns.qualname:
  description: "time.time_ns.__qualname__ == 'time_ns' — flat qualname for C builtin"
  category: qualnames
  kind: python_call_eq
  function: time_ns.__qualname__.__eq__
  args: ["time_ns"]
  expected: true

invariant time_extra7.monotonic_ns.qualname:
  description: "time.monotonic_ns.__qualname__ == 'monotonic_ns' — flat qualname for C builtin"
  category: qualnames
  kind: python_call_eq
  function: monotonic_ns.__qualname__.__eq__
  args: ["monotonic_ns"]
  expected: true

invariant time_extra7.perf_counter_ns.qualname:
  description: "time.perf_counter_ns.__qualname__ == 'perf_counter_ns' — flat qualname for C builtin"
  category: qualnames
  kind: python_call_eq
  function: perf_counter_ns.__qualname__.__eq__
  args: ["perf_counter_ns"]
  expected: true

invariant time_extra7.thread_time.qualname:
  description: "time.thread_time.__qualname__ == 'thread_time' — flat qualname for C builtin"
  category: qualnames
  kind: python_call_eq
  function: thread_time.__qualname__.__eq__
  args: ["thread_time"]
  expected: true

# ---------------------------------------------------------------------------
# Nanosecond function __module__ attributes
#
# time_extra5 covers __module__ for all core time functions but does not
# include the nanosecond variants or thread_time.
# ---------------------------------------------------------------------------

invariant time_extra7.time_ns.module:
  description: "time.time_ns.__module__ == 'time'"
  category: modules
  kind: python_call_eq
  function: time_ns.__module__.__eq__
  args: ["time"]
  expected: true

invariant time_extra7.thread_time.module:
  description: "time.thread_time.__module__ == 'time'"
  category: modules
  kind: python_call_eq
  function: thread_time.__module__.__eq__
  args: ["time"]
  expected: true
