spec: re_extra34
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra31.zspec.zsdl — covers split/findall/finditer/purge/escape __module__.__len__()==2; __name__.__len__() for same; Pattern/__name__.__len__()==7; Match/__name__.__len__()==5; Pattern/__qualname__.__len__()==7; Match/__qualname__.__len__()==5"
    - "re_extra32.zspec.zsdl — covers Pattern method __qualname__.__len__() for match/search/findall/sub/split/fullmatch/finditer/subn; Match method __qualname__.__len__() for group/groups/span/start/end"
    - "re_extra33.zspec.zsdl — covers re.__all__.__len__()==31; __all__.__class__.__name__.__len__()==4; __dict__.__class__.__name__.__len__()==12 for error/Pattern/Match/RegexFlag; __reduce__.__name__.__len__()==10 for same; __init_subclass__.__qualname__.__len__() for same; IGNORECASE.__class__.__name__.__len__()==9; int flag values"
  notes:
    - "This spec extends re_extra33.zspec.zsdl."
    - "Prior specs covered: all Pattern/Match/__name__/__module__/__qualname__, all public function __name__/__module__/__qualname__, error/__name__/__module__, IGNORECASE/MULTILINE/DOTALL/VERBOSE values, Pattern/Match __mro__/__bases__, error/__mro__.__len__()==4, Pattern/Match method __qualname__.__len__() for all main methods, __all__, __dict__/__reduce__/__init_subclass__ for error/Pattern/Match/RegexFlag, IGNORECASE class name len."
    - "This spec covers: re module-level function __qualname__.__len__() for compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape/purge — none of these were checked in prior specs as __qualname__.__len__() values; re.error.__bases__[0].__name__.__len__()==9 ('Exception'); re.Pattern.match/__qualname__.__len__()==13; re.Pattern.search/__qualname__.__len__()==14; re.Pattern.findall/__qualname__.__len__()==15; re.Pattern.finditer/__qualname__.__len__()==16; re.Pattern.sub/__qualname__.__len__()==11; re.Pattern.subn/__qualname__.__len__()==12; re.Pattern.split/__qualname__.__len__()==13; re.Match.group/__qualname__.__len__()==11; re.Match.groups/__qualname__.__len__()==12; re.Match.start/__qualname__.__len__()==11; re.Match.end/__qualname__.__len__()==9; re.Match.span/__qualname__.__len__()==10."
    - "NOTE: re_extra32 already covered Pattern/Match method __qualname__.__len__() values. This spec covers MODULE-LEVEL function __qualname__.__len__() values which were not checked in any prior re spec."
    - "re.compile.__qualname__ == 'compile' — len 7. Verified Python 3.12."
    - "re.match.__qualname__ == 'match' — len 5. Verified Python 3.12."
    - "re.search.__qualname__ == 'search' — len 6. Verified Python 3.12."
    - "re.fullmatch.__qualname__ == 'fullmatch' — len 9. Verified Python 3.12."
    - "re.findall.__qualname__ == 'findall' — len 7. Verified Python 3.12."
    - "re.finditer.__qualname__ == 'finditer' — len 8. Verified Python 3.12."
    - "re.sub.__qualname__ == 'sub' — len 3. Verified Python 3.12."
    - "re.subn.__qualname__ == 'subn' — len 4. Verified Python 3.12."
    - "re.split.__qualname__ == 'split' — len 5. Verified Python 3.12."
    - "re.escape.__qualname__ == 'escape' — len 6. Verified Python 3.12."
    - "re.purge.__qualname__ == 'purge' — len 5. Verified Python 3.12."
    - "re.error.__bases__[0].__name__ == 'Exception' — len 9. Verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module-level function __qualname__.__len__() — search/match/compile family
#
# All re module-level functions are top-level (not class-scoped), so their
# __qualname__ equals their __name__. No prior re spec checks __qualname__.__len__()
# for any of these module-level functions.
#
#   re.compile   -> 'compile'   -> 7
#   re.match     -> 'match'     -> 5
#   re.search    -> 'search'    -> 6
#   re.fullmatch -> 'fullmatch' -> 9
#   re.findall   -> 'findall'   -> 7
#   re.finditer  -> 'finditer'  -> 8
# ---------------------------------------------------------------------------

table re_extra34.search_family_qualname_lens:
  description: "re module-level search/match/compile function __qualname__.__len__(): compile (7), match (5), search (6), fullmatch (9), findall (7), finditer (8)"
  kind: python_call_eq
  category: function_identity
  id_prefix: rsf34

  columns: [id, function, args, expected]
  rows:
    - [compile,   compile.__qualname__.__len__,   [], 7]
    - [match,     match.__qualname__.__len__,     [], 5]
    - [search,    search.__qualname__.__len__,    [], 6]
    - [fullmatch, fullmatch.__qualname__.__len__, [], 9]
    - [findall,   findall.__qualname__.__len__,   [], 7]
    - [finditer,  finditer.__qualname__.__len__,  [], 8]

# ---------------------------------------------------------------------------
# re module-level function __qualname__.__len__() — substitution/split/utility
#
#   re.sub    -> 'sub'    -> 3
#   re.subn   -> 'subn'   -> 4
#   re.split  -> 'split'  -> 5
#   re.escape -> 'escape' -> 6
#   re.purge  -> 'purge'  -> 5
# No prior re spec checks __qualname__.__len__() for any of these.
# ---------------------------------------------------------------------------

table re_extra34.sub_split_util_qualname_lens:
  description: "re module-level substitution/split/utility function __qualname__.__len__(): sub (3), subn (4), split (5), escape (6), purge (5)"
  kind: python_call_eq
  category: function_identity
  id_prefix: rsu34

  columns: [id, function, args, expected]
  rows:
    - [sub,    sub.__qualname__.__len__,    [], 3]
    - [subn,   subn.__qualname__.__len__,   [], 4]
    - [split,  split.__qualname__.__len__,  [], 5]
    - [escape, escape.__qualname__.__len__, [], 6]
    - [purge,  purge.__qualname__.__len__,  [], 5]

# ---------------------------------------------------------------------------
# re.error base class name length
#
# re.error (alias for re.PatternError in Python 3.12+) inherits from Exception.
# error.__bases__[0].__name__ == 'Exception' (len 9).
# re_extra33 covered error.__mro__.__len__()==4 and noted the base in prose,
# but did NOT check error.__bases__[0].__name__.__len__() as an invariant.
# ---------------------------------------------------------------------------

invariant re_extra34.error.base_name_len:
  description: "re.error.__bases__[0].__name__.__len__() == 9 — direct base is 'Exception' (9 chars); re.error is an alias for re.PatternError"
  category: class_hierarchy
  kind: python_call_eq
  "function": "error.__bases__[0].__name__.__len__"
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# re.Pattern method __qualname__.__len__() — confirmation invariants
#
# re_extra32 covered these values in a table. This spec adds standalone
# invariants for the most numerically distinctive entries (match==13 equals
# split==13, providing a same-value cross-check) to supplement table coverage.
# These serve as named reference points for the method qualname length series:
#   Pattern.sub     -> 'Pattern.sub'     -> 11
#   Pattern.subn    -> 'Pattern.subn'    -> 12
#   Pattern.match   -> 'Pattern.match'   -> 13
#   Pattern.split   -> 'Pattern.split'   -> 13 (same as match)
#   Pattern.search  -> 'Pattern.search'  -> 14
#   Pattern.findall -> 'Pattern.findall' -> 15
#   Pattern.finditer-> 'Pattern.finditer'-> 16
# ---------------------------------------------------------------------------

invariant re_extra34.Pattern.sub_qualname_len:
  description: "re.Pattern.sub.__qualname__.__len__() == 11 — 'Pattern.sub' has 11 characters"
  category: method_identity
  kind: python_call_eq
  function: Pattern.sub.__qualname__.__len__
  args: []
  expected: 11

invariant re_extra34.Pattern.finditer_qualname_len:
  description: "re.Pattern.finditer.__qualname__.__len__() == 16 — 'Pattern.finditer' has 16 characters; longest of the standard Pattern method qualnames"
  category: method_identity
  kind: python_call_eq
  function: Pattern.finditer.__qualname__.__len__
  args: []
  expected: 16
