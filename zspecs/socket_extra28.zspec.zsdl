spec: socket_extra28
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra27.zspec.zsdl — covers __module__.__len__() for socket.socket/error/timeout/herror/gaierror; __name__.__len__() for socket.socket/error; __qualname__ for gethostname/getfqdn/inet_aton/inet_ntoa; gethostname.__module__.__len__()."
    - "socket_extra26.zspec.zsdl — covers socket.timeout/__bases__[0].__name__, socket.herror/__bases__[0].__name__, socket.gaierror/__bases__[0].__name__, socket.socket.__init__.__name__, socket.inet_aton/__name__/__module__, socket.inet_ntoa/__name__."
    - "socket_extra25.zspec.zsdl — covers socket.error/__module__, socket.timeout/__module__, socket.gaierror/__module__, socket.herror/__module__, socket.gethostname/__qualname__/__module__, socket.getfqdn/__qualname__/__module__, socket.getaddrinfo/__qualname__/__module__, socket.create_connection/__qualname__/__module__."
  notes:
    - "This spec extends socket_extra27.zspec.zsdl."
    - "Prior specs covered: socket.__name__/__package__, socket.socket/__name__/__module__/__qualname__/__bases__[0].__name__/__init__.__name__, error/timeout/herror/gaierror __name__/__module__/__bases__[0].__name__, AF_INET/AF_INET6/AF_UNIX values, SOCK_STREAM/SOCK_DGRAM values, IPPROTO_TCP/IPPROTO_UDP, gethostname/getfqdn/__name__/__module__/__qualname__, inet_aton/inet_ntoa/__name__/__module__/__qualname__, getaddrinfo/__name__/__module__/__qualname__, setdefaulttimeout/__name__/__module__, __module__.__len__() for socket.socket/error/timeout/herror/gaierror/gethostname, __name__.__len__() for socket.socket/error."
    - "This spec covers: socket.socket.bind/__qualname__ and __name__/__qualname__.__len__(); socket.socket.connect/__name__/__qualname__/__len__(); socket.socket.listen/__name__/__qualname__/__len__(); socket.socket.accept/__name__/__qualname__/__len__(); socket.socket.send/__name__/__qualname__/__len__(); socket.socket.recv/__name__/__qualname__/__len__(); socket.getaddrinfo.__qualname__.__len__(); socket.setdefaulttimeout.__qualname__.__len__(); socket.setdefaulttimeout.__module__.__len__()."
    - "socket.socket.bind.__qualname__ == 'socket.bind' — len 11. method_descriptor objects have __qualname__ and __name__ but not __module__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__qualname__ == 'socket.connect' — len 14. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__qualname__ == 'socket.listen' — len 13. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__qualname__ == 'socket.accept' — len 13. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.send.__qualname__ == 'socket.send' — len 11. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__qualname__ == 'socket.recv' — len 11. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__name__ == 'bind' — len 4. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__name__ == 'connect' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__name__ == 'listen' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__name__ == 'accept' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.send.__name__ == 'send' — len 4. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__name__ == 'recv' — len 4. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__qualname__ == 'getaddrinfo' — len 11; module-level function in socket package wrapping _socket. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__qualname__ == 'setdefaulttimeout' — len 17; C-extension function from _socket. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__module__ == '_socket' — len 7; C-extension function. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket method __qualname__ values
#
# socket_extra27 covers __qualname__ for gethostname/getfqdn/inet_aton/inet_ntoa
# (module-level functions). No prior spec checks __qualname__ for socket.socket
# instance methods (bind, connect, listen, accept, send, recv).
# These are method_descriptor objects whose __qualname__ takes the form
# 'socket.<methodname>' because the class is also named 'socket'.
# ---------------------------------------------------------------------------

table socket_extra28.socket_method_qualnames:
  description: "socket.socket method __qualname__ values — bind/connect/listen/accept/send/recv"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: smq28

  columns: [id, function, args, expected, description]
  rows:
    - [bind,    "socket.bind.__qualname__.__eq__",    ["socket.bind"],    true, "socket.socket.bind.__qualname__ == 'socket.bind'"]
    - [connect, "socket.connect.__qualname__.__eq__", ["socket.connect"], true, "socket.socket.connect.__qualname__ == 'socket.connect'"]
    - [listen,  "socket.listen.__qualname__.__eq__",  ["socket.listen"],  true, "socket.socket.listen.__qualname__ == 'socket.listen'"]
    - [accept,  "socket.accept.__qualname__.__eq__",  ["socket.accept"],  true, "socket.socket.accept.__qualname__ == 'socket.accept'"]
    - [send,    "socket.send.__qualname__.__eq__",    ["socket.send"],    true, "socket.socket.send.__qualname__ == 'socket.send'"]
    - [recv,    "socket.recv.__qualname__.__eq__",    ["socket.recv"],    true, "socket.socket.recv.__qualname__ == 'socket.recv'"]

# ---------------------------------------------------------------------------
# socket.socket method __qualname__.__len__() values
#
# No prior spec checks __qualname__.__len__() for socket.socket instance methods.
# bind.__qualname__ == 'socket.bind' (len 11); connect == 'socket.connect' (len 14);
# listen == 'socket.listen' (len 13); accept == 'socket.accept' (len 13);
# send == 'socket.send' (len 11); recv == 'socket.recv' (len 11).
# ---------------------------------------------------------------------------

table socket_extra28.socket_method_qualname_lengths:
  description: "socket.socket method __qualname__.__len__() — bind/connect/listen/accept/send/recv"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: smql28

  columns: [id, function, args, expected, description]
  rows:
    - [bind,    "socket.bind.__qualname__.__len__",    [], 11, "len('socket.bind') == 11"]
    - [connect, "socket.connect.__qualname__.__len__", [], 14, "len('socket.connect') == 14"]
    - [listen,  "socket.listen.__qualname__.__len__",  [], 13, "len('socket.listen') == 13"]
    - [accept,  "socket.accept.__qualname__.__len__",  [], 13, "len('socket.accept') == 13"]
    - [send,    "socket.send.__qualname__.__len__",    [], 11, "len('socket.send') == 11"]
    - [recv,    "socket.recv.__qualname__.__len__",    [], 11, "len('socket.recv') == 11"]

# ---------------------------------------------------------------------------
# socket.socket method __name__ values
#
# No prior spec checks __name__ for socket.socket instance methods bind/connect/
# listen/accept/send/recv. These method_descriptor objects have simple __name__
# values equal to the bare method name.
# ---------------------------------------------------------------------------

invariant socket_extra28.socket_method.bind_name_len:
  description: "len(socket.socket.bind.__name__) == 4 — len('bind') == 4"
  category: function_names
  kind: python_call_eq
  function: "socket.bind.__name__.__len__"
  args: []
  expected: 4

invariant socket_extra28.socket_method.connect_name_len:
  description: "len(socket.socket.connect.__name__) == 7 — len('connect') == 7"
  category: function_names
  kind: python_call_eq
  function: "socket.connect.__name__.__len__"
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__qualname__.__len__() and
# socket.setdefaulttimeout __qualname__/__module__ lengths
#
# socket_extra27 covers __qualname__.__eq__ for getaddrinfo (table row), and
# __module__.__eq__ for setdefaulttimeout == '_socket' (extra25).
# No prior spec checks __qualname__.__len__() for getaddrinfo or
# setdefaulttimeout, or __module__.__len__() for setdefaulttimeout.
# ---------------------------------------------------------------------------

invariant socket_extra28.getaddrinfo.qualname_len:
  description: "len(socket.getaddrinfo.__qualname__) == 11 — len('getaddrinfo') == 11"
  category: function_qualnames
  kind: python_call_eq
  function: getaddrinfo.__qualname__.__len__
  args: []
  expected: 11

invariant socket_extra28.setdefaulttimeout.qualname_len:
  description: "len(socket.setdefaulttimeout.__qualname__) == 17 — len('setdefaulttimeout') == 17"
  category: function_qualnames
  kind: python_call_eq
  function: setdefaulttimeout.__qualname__.__len__
  args: []
  expected: 17

invariant socket_extra28.setdefaulttimeout.module_len:
  description: "len(socket.setdefaulttimeout.__module__) == 7 — len('_socket') == 7; C-extension module"
  category: function_module
  kind: python_call_eq
  function: setdefaulttimeout.__module__.__len__
  args: []
  expected: 7
