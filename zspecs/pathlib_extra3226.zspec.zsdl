spec: pp3226
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 662 (pp3226): __radd__, __rsub__, __rmul__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __radd__, __rsub__, __rmul__ dict-presence (reflected arithmetic)."
    - "No pathlib class defines __radd__ in its own __dict__: path objects represent filesystem paths, not numeric types, and do not implement reflected addition."
    - "No pathlib class defines __rsub__ in its own __dict__: path objects do not implement reflected subtraction."
    - "No pathlib class defines __rmul__ in its own __dict__: path objects do not implement reflected multiplication."
    - "In wave 659, pathlib.PurePath.__truediv__ was True (path joining via /); no reflected arithmetic operators are defined on PurePath or any subclass."
    - "pathlib defines __truediv__ (wave 659) but NOT __radd__, __rsub__, or __rmul__."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "Key finding: decimal.Decimal defines all 3 reflected operators (complete numeric type supporting right-hand arithmetic); all other classes in this wave are False."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __radd__ dict-presence — operator.contains(Cls.__dict__, '__radd__')
#
# No pathlib class defines __radd__ in its own __dict__; all false.
# pathlib types represent immutable filesystem paths, not numeric operands.
# Contrast with __truediv__ (wave 659) which PurePath does define.
# ---------------------------------------------------------------------------

table pp3226.radd:
  description: "pathlib types __radd__ dict-presence checks; wave 662"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3226

  columns: [id, function, args, expected]
  rows:
    - ["pp3226001", operator.contains, [pathlib.PurePath.__dict__,         "__radd__"], false]
    - ["pp3226002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__radd__"], false]
    - ["pp3226003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__radd__"], false]
    - ["pp3226004", operator.contains, [pathlib.Path.__dict__,             "__radd__"], false]
    - ["pp3226005", operator.contains, [pathlib.PosixPath.__dict__,        "__radd__"], false]

