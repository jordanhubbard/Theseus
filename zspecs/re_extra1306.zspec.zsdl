spec: re_extra1306
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_sre.c, Lib/re/__init__.py"
  notes:
    - "Wave 534 (_extra1306): focuses on exception-raising behavior for invalid patterns and wrong argument types."
    - "re.compile(42) raises TypeError: first argument must be string or compiled pattern."
    - "re.compile('(') raises re.PatternError (alias of re.error): unterminated subpattern."
    - "re.compile('[') raises re.PatternError: unterminated character set."
    - "re.compile('x', 99999) raises ValueError: unknown flag."
    - "re.match(42, 'test') raises TypeError: first argument must be string or compiled pattern."
    - "re.sub(42, 'r', 's') raises TypeError: first argument must be string or compiled pattern."
    - "re.PatternError is an alias of re.error; isinstance check confirmed Python 3.14.4."
    - "All exceptions verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table re_extra1306.compile_type_errors:
  description: "re.compile raises TypeError when the pattern argument is not a string or compiled pattern"
  kind: python_call_raises
  category: type_errors
  id_prefix: re1306ct
  columns: [id, function, args, exception]
  rows:
    - [re1306ct001, re.compile,  [42],          "TypeError"]
    - [re1306ct002, re.compile,  [null],         "TypeError"]
    - [re1306ct003, re.compile,  [3.14],         "TypeError"]
    - [re1306ct004, re.compile,  [[]],           "TypeError"]
    - [re1306ct005, re.compile,  [{}],           "TypeError"]
    - [re1306ct006, re.compile,  [true],         "TypeError"]

table re_extra1306.compile_pattern_errors:
  description: "re.compile raises re.error (PatternError) on syntactically invalid regex patterns, and ValueError on bad flags"
  kind: python_call_raises
  category: pattern_errors
  id_prefix: re1306pe
  columns: [id, function, args, exception]
  rows:
    - [re1306pe001, re.compile,  ["("],          "PatternError"]
    - [re1306pe002, re.compile,  ["["],          "PatternError"]
    - [re1306pe003, re.compile,  ["(?P<>x)"],    "PatternError"]
    - [re1306pe004, re.compile,  ["(?P<1>x)"],   "PatternError"]
    - [re1306pe005, re.compile,  ["*"],          "PatternError"]
    - [re1306pe006, re.compile,  ["x", 99999],   "ValueError"]

table re_extra1306.match_sub_type_errors:
  description: "re.match, re.search, re.sub, re.split, re.findall raise TypeError when pattern is not a string"
  kind: python_call_raises
  category: type_errors
  id_prefix: re1306ms
  columns: [id, function, args, exception]
  rows:
    - [re1306ms001, re.match,   [42, "test"],    "TypeError"]
    - [re1306ms002, re.search,  [null, "test"],  "TypeError"]
    - [re1306ms003, re.sub,     [42, "r", "s"],  "TypeError"]
    - [re1306ms004, re.split,   [42, "test"],    "TypeError"]
    - [re1306ms005, re.findall, [42, "test"],    "TypeError"]
    - [re1306ms006, re.fullmatch, [null, "x"],   "TypeError"]
