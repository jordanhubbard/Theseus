# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra182.cwd_name_is_cwd:
  description: "pathlib.Path.cwd.__name__ == 'cwd' — 'cwd' has 3 characters; cwd (3) is the minimum method name length in this spec; cwd (3) < glob=home (4) < rglob (5) < exists=is_dir (6) < iterdir=is_file (7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.cwd.__name__.__eq__
  args: ["cwd"]
  expected: true

invariant pathlib_extra182.home_name_is_home:
  description: "pathlib.Path.home.__name__ == 'home' — 'home' has 4 characters; home (4) == glob (4): a two-way tie at 4; home (4) > cwd (3) by 1; home (4) < rglob (5) by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.home.__name__.__eq__
  args: ["home"]
  expected: true

invariant pathlib_extra182.glob_name_len_4:
  description: "pathlib.Path.glob.__name__.__len__() == 4 — 'glob' has 4 characters; glob (4) == home (4): a two-way tie at 4; glob (4) < rglob (5) by 1: rglob is glob with a leading 'r'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.glob.__name__.__len__
  args: []
  expected: 4

invariant pathlib_extra182.rglob_name_len_5:
  description: "pathlib.Path.rglob.__name__.__len__() == 5 — 'rglob' has 5 characters: 'r' (1) + 'glob' (4) = 5; rglob (5) > glob (4) by 1; rglob (5) < exists=is_dir (6) by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.rglob.__name__.__len__
  args: []
  expected: 5

invariant pathlib_extra182.exists_name_len_6:
  description: "pathlib.Path.exists.__name__.__len__() == 6 — 'exists' has 6 characters; exists (6) == is_dir (6): a two-way tie at 6; exists (6) > rglob (5) by 1; exists (6) < iterdir=is_file (7) by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.exists.__name__.__len__
  args: []
  expected: 6

invariant pathlib_extra182.is_file_name_len_7:
  description: "pathlib.Path.is_file.__name__.__len__() == 7 — 'is_file' has 7 characters: 'is' (2) + '_' (1) + 'file' (4) = 7; is_file (7) == iterdir (7): the two co-maximum method name lengths in this spec; is_file (7) > is_dir (6) by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.is_file.__name__.__len__
  args: []
  expected: 7

invariant pathlib_extra182.is_dir_name_len_6:
  description: "pathlib.Path.is_dir.__name__.__len__() == 6 — 'is_dir' has 6 characters: 'is' (2) + '_' (1) + 'dir' (3) = 6; is_dir (6) == exists (6): a two-way tie at 6; is_dir (6) < is_file (7) by 1 because 'dir' (3) < 'file' (4) by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.is_dir.__name__.__len__
  args: []
  expected: 6

