spec: pathlib_extra182
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers: pathlib.Path class method identity — __name__ values and lengths for cwd, home, iterdir, glob, rglob, exists, is_file, is_dir."
    - "pathlib.Path.cwd.__name__ == 'cwd' (len=3; class method returning the current working directory)."
    - "pathlib.Path.home.__name__ == 'home' (len=4; class method returning the user home directory)."
    - "pathlib.Path.iterdir.__name__ == 'iterdir' (len=7)."
    - "pathlib.Path.glob.__name__ == 'glob' (len=4; same len as home: 'glob' (4) == 'home' (4))."
    - "pathlib.Path.rglob.__name__ == 'rglob' (len=5)."
    - "pathlib.Path.exists.__name__ == 'exists' (len=6)."
    - "pathlib.Path.is_file.__name__ == 'is_file' (len=7; same len as iterdir: 'is_file' (7) == 'iterdir' (7))."
    - "pathlib.Path.is_dir.__name__ == 'is_dir' (len=6; same len as exists: 'is_dir' (6) == 'exists' (6))."
    - "Name length ordering: cwd (3) < glob=home (4) < rglob (5) < exists=is_dir (6) < iterdir=is_file (7)."
    - "cwd (3) is the minimum; iterdir=is_file (7) are co-maximum."
    - "glob (4) == home (4): two-way tie at 4."
    - "exists (6) == is_dir (6): two-way tie at 6."
    - "iterdir (7) == is_file (7): two-way tie at 7 (co-maximum)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path class methods — cwd (3), home (4), glob (4)
# cwd.__name__ == 'cwd' (len=3; minimum in spec)
# home.__name__ == 'home' (len=4; ties glob)
# glob.__name__ == 'glob' (len=4; ties home)
# ---------------------------------------------------------------------------

table pathlib_extra182.short_class_method_names:
  description: "Short Path method names: cwd (len=3; minimum), home (len=4), glob (len=4); cwd (3) < glob=home (4) by 1; home (4) == glob (4): a two-way tie at 4"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibcls182

  columns: [id, function, args, expected, description]
  rows:
    - [cwd_name,      Path.cwd.__name__.__eq__,   ["cwd"],  true, "pathlib.Path.cwd.__name__ == 'cwd' — 'cwd' has 3 characters; cwd (3) is the minimum method name length in this spec; cwd (3) < glob=home (4) by 1; cwd (3) < iterdir=is_file (7) by 4; Path.cwd() is a class method returning the current working directory as a new Path object; confirmed Python 3.14.3 macOS"]
    - [cwd_name_len,  Path.cwd.__name__.__len__,  [],       3,    "pathlib.Path.cwd.__name__.__len__() == 3 — 'cwd' has 3 characters; cwd (3) is the global minimum in the name-length ordering: cwd (3) < glob=home (4) < rglob (5) < exists=is_dir (6) < iterdir=is_file (7); cwd (3) < rglob (5) by 2; cwd (3) < iterdir (7) by 4; confirmed Python 3.14.3 macOS"]
    - [home_name,     Path.home.__name__.__eq__,  ["home"], true, "pathlib.Path.home.__name__ == 'home' — 'home' has 4 characters; home (4) == glob (4): a two-way tie at 4; home (4) > cwd (3) by 1; home (4) < rglob (5) by 1; Path.home() is a class method returning the current user's home directory as a new Path object; confirmed Python 3.14.3 macOS"]
    - [home_name_len, Path.home.__name__.__len__, [],       4,    "pathlib.Path.home.__name__.__len__() == 4 — 'home' has 4 characters; home (4) == glob (4): the two 4-character method names in this spec; home (4) > cwd (3) by 1; home (4) < rglob (5) by 1; home (4) < exists=is_dir (6) by 2; home (4) < iterdir=is_file (7) by 3; confirmed Python 3.14.3 macOS"]
    - [glob_name,     Path.glob.__name__.__eq__,  ["glob"], true, "pathlib.Path.glob.__name__ == 'glob' — 'glob' has 4 characters; glob (4) == home (4): a two-way tie at 4; glob (4) > cwd (3) by 1; glob (4) < rglob (5) by 1: rglob is glob with a leading 'r' for recursive; Path.glob() iterates over all matching files in the directory tree; confirmed Python 3.14.3 macOS"]
    - [glob_name_len, Path.glob.__name__.__len__, [],       4,    "pathlib.Path.glob.__name__.__len__() == 4 — 'glob' has 4 characters; glob (4) == home (4): both are 4-character method names; glob (4) < rglob (5) by 1; glob (4) < exists=is_dir (6) by 2; glob (4) < iterdir=is_file (7) by 3; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.Path methods — rglob (5), exists (6), is_dir (6)
# rglob.__name__ == 'rglob' (len=5)
# exists.__name__ == 'exists' (len=6; ties is_dir)
# is_dir.__name__ == 'is_dir' (len=6; ties exists)
# ---------------------------------------------------------------------------

table pathlib_extra182.medium_method_names:
  description: "Medium-length Path method names: rglob (len=5), exists (len=6), is_dir (len=6); rglob (5) < exists=is_dir (6) by 1; exists (6) == is_dir (6): a two-way tie at 6"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibcls182

  columns: [id, function, args, expected, description]
  rows:
    - [rglob_name,      Path.rglob.__name__.__eq__,   ["rglob"],  true, "pathlib.Path.rglob.__name__ == 'rglob' — 'rglob' has 5 characters: 'r' (1) + 'glob' (4) = 5; rglob (5) > glob=home (4) by 1: rglob is a recursive variant of glob prefixed with 'r'; rglob (5) > cwd (3) by 2; rglob (5) < exists=is_dir (6) by 1; Path.rglob() recursively globs for matching paths; confirmed Python 3.14.3 macOS"]
    - [rglob_name_len,  Path.rglob.__name__.__len__,  [],         5,    "pathlib.Path.rglob.__name__.__len__() == 5 — 'rglob' has 5 characters; rglob (5) is between glob=home (4) and exists=is_dir (6) in the name-length ordering; rglob (5) > cwd (3) by 2; rglob (5) < iterdir=is_file (7) by 2; confirmed Python 3.14.3 macOS"]
    - [exists_name,     Path.exists.__name__.__eq__,  ["exists"], true, "pathlib.Path.exists.__name__ == 'exists' — 'exists' has 6 characters; exists (6) == is_dir (6): a two-way tie at 6; exists (6) > rglob (5) by 1; exists (6) < iterdir=is_file (7) by 1; Path.exists() returns True if the path points to an existing file or directory; confirmed Python 3.14.3 macOS"]
    - [exists_name_len, Path.exists.__name__.__len__, [],         6,    "pathlib.Path.exists.__name__.__len__() == 6 — 'exists' has 6 characters; exists (6) == is_dir (6): the two 6-character method names in this spec; exists (6) > rglob (5) by 1; exists (6) < iterdir=is_file (7) by 1; confirmed Python 3.14.3 macOS"]
    - [is_dir_name,     Path.is_dir.__name__.__eq__,  ["is_dir"], true, "pathlib.Path.is_dir.__name__ == 'is_dir' — 'is_dir' has 6 characters: 'is' (2) + '_' (1) + 'dir' (3) = 6; is_dir (6) == exists (6): a two-way tie at 6; is_dir (6) > rglob (5) by 1; is_dir (6) < is_file=iterdir (7) by 1; Path.is_dir() returns True if the path points to a directory; confirmed Python 3.14.3 macOS"]
    - [is_dir_name_len, Path.is_dir.__name__.__len__, [],         6,    "pathlib.Path.is_dir.__name__.__len__() == 6 — 'is_dir' has 6 characters; is_dir (6) == exists (6): both are 6-character method names; is_dir (6) < is_file (7) by 1: is_dir (6) is 1 character shorter than is_file (7) because 'dir' (3) < 'file' (4) by 1; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.Path methods — iterdir (7), is_file (7)
# iterdir.__name__ == 'iterdir' (len=7; co-maximum, ties is_file)
# is_file.__name__ == 'is_file' (len=7; co-maximum, ties iterdir)
# ---------------------------------------------------------------------------

table pathlib_extra182.long_method_names:
  description: "Longest Path method names: iterdir (len=7; co-maximum), is_file (len=7; co-maximum); iterdir (7) == is_file (7): the two maximum-length method names in this spec; both exceed exists=is_dir (6) by 1"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibcls182

  columns: [id, function, args, expected, description]
  rows:
    - [iterdir_name,      Path.iterdir.__name__.__eq__,  ["iterdir"], true, "pathlib.Path.iterdir.__name__ == 'iterdir' — 'iterdir' has 7 characters: 'iter' (4) + 'dir' (3) = 7; iterdir (7) == is_file (7): a two-way tie at the maximum name length in this spec; iterdir (7) > exists=is_dir (6) by 1; iterdir (7) > cwd (3) by 4; Path.iterdir() yields Path objects for the directory contents; confirmed Python 3.14.3 macOS"]
    - [iterdir_name_len,  Path.iterdir.__name__.__len__, [],          7,    "pathlib.Path.iterdir.__name__.__len__() == 7 — 'iterdir' has 7 characters; iterdir (7) == is_file (7): both are the maximum-length method names in the name-length ordering: cwd (3) < glob=home (4) < rglob (5) < exists=is_dir (6) < iterdir=is_file (7); iterdir (7) > exists (6) by 1; iterdir (7) > cwd (3) by 4; confirmed Python 3.14.3 macOS"]
    - [is_file_name,      Path.is_file.__name__.__eq__,  ["is_file"], true, "pathlib.Path.is_file.__name__ == 'is_file' — 'is_file' has 7 characters: 'is' (2) + '_' (1) + 'file' (4) = 7; is_file (7) == iterdir (7): a two-way tie at the co-maximum name length; is_file (7) > is_dir (6) by 1: 'file' (4) > 'dir' (3) by 1; is_file (7) > rglob (5) by 2; Path.is_file() returns True if the path points to a regular file; confirmed Python 3.14.3 macOS"]
    - [is_file_name_len,  Path.is_file.__name__.__len__, [],          7,    "pathlib.Path.is_file.__name__.__len__() == 7 — 'is_file' has 7 characters; is_file (7) == iterdir (7): both are co-maximum in the name-length ordering; is_file (7) > is_dir (6) by 1: 'file' (4) is 1 longer than 'dir' (3); is_file (7) > exists (6) by 1; is_file (7) > cwd (3) by 4; confirmed Python 3.14.3 macOS"]

