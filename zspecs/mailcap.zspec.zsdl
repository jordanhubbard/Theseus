spec: mailcap
version: ">=3.3,<3.13"
backend: python_module(mailcap)

docs: https://docs.python.org/3/library/mailcap.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/mailcap.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "mailcap source: Lib/mailcap.py (PSF; source inspection permitted)"
  not_derived_from:
    - "mailcap internal details"
  notes:
    - "Deprecated since Python 3.11; removed in Python 3.13."
    - "mailcap provides support for finding and interpreting mailcap files (RFC 1524)."
    - "mailcap.getcaps() reads all mailcap files and returns a dict mapping MIME types to lists of entries."
    - "mailcap.findmatch(caps, mimetype) searches the caps dict for a matching entry."
    - "mailcap.lookup(caps, mimetype, key) looks up a specific key in the caps for the given MIME type."
    - "getcaps() returns a dict — keys are MIME type strings, values are lists of dicts."
    - "All expected values verified by running Python 3.12 mailcap module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant mailcap.getcaps_name:
  description: "mailcap.getcaps.__name__ == 'getcaps'"
  category: functions
  kind: python_call_eq
  function: getcaps.__name__.__eq__
  args: ["getcaps"]
  expected: true

invariant mailcap.getcaps_module:
  description: "mailcap.getcaps.__module__ == 'mailcap'"
  category: functions
  kind: python_call_eq
  function: getcaps.__module__.__eq__
  args: ["mailcap"]
  expected: true

invariant mailcap.findmatch_name:
  description: "mailcap.findmatch.__name__ == 'findmatch'"
  category: functions
  kind: python_call_eq
  function: findmatch.__name__.__eq__
  args: ["findmatch"]
  expected: true

invariant mailcap.findmatch_module:
  description: "mailcap.findmatch.__module__ == 'mailcap'"
  category: functions
  kind: python_call_eq
  function: findmatch.__module__.__eq__
  args: ["mailcap"]
  expected: true

invariant mailcap.lookup_name:
  description: "mailcap.lookup.__name__ == 'lookup'"
  category: functions
  kind: python_call_eq
  function: lookup.__name__.__eq__
  args: ["lookup"]
  expected: true

invariant mailcap.lookup_module:
  description: "mailcap.lookup.__module__ == 'mailcap'"
  category: functions
  kind: python_call_eq
  function: lookup.__module__.__eq__
  args: ["mailcap"]
  expected: true

# ---------------------------------------------------------------------------
# getcaps() return type checks
# ---------------------------------------------------------------------------

invariant mailcap.getcaps_returns_dict:
  description: "getcaps().__class__.__name__ == 'dict'"
  category: getcaps
  kind: python_call_eq
  function: getcaps
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["dict"]
  expected: true

invariant mailcap.getcaps_is_mapping:
  description: "isinstance(getcaps(), dict) — getcaps() returns a plain dict"
  category: getcaps
  kind: python_call_eq
  function: getcaps
  args: []
  method: __class__.__name__.__eq__
  method_args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# findmatch return type check
# ---------------------------------------------------------------------------

invariant mailcap.findmatch_returns_tuple:
  description: "findmatch({}, 'text/plain') returns a 2-tuple (None, {})"
  category: findmatch
  kind: python_call_eq
  function: findmatch
  args: [{}, "text/plain"]
  method: __class__.__name__.__eq__
  method_args: ["tuple"]
  expected: true
