spec: ensurepip
version: ">=3.4"
backend: python_module(ensurepip)

docs: https://docs.python.org/3/library/ensurepip.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ensurepip.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "ensurepip source: Lib/ensurepip/__init__.py (PSF; source inspection permitted)"
  not_derived_from:
    - "ensurepip source: bundled pip wheel internals"
  notes:
    - "ensurepip bootstraps the pip installer into a Python environment."
    - "version() returns a string like '24.0' representing the bundled pip version."
    - "version().__class__.__name__ == 'str' — the return value is always a string."
    - "version().__contains__('.') is True — pip version strings always contain a dot separator."
    - "bootstrap() installs pip; it is side-effecting and not tested here."
    - "ensurepip.__name__ == 'ensurepip'."
    - "All expected values verified by running Python 3.12 ensurepip module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "ensurepip.bootstrap() raises RuntimeError if called in a virtual environment where pip installation is forbidden. version() is always safe to call."
  stderr: "null"
  stickiness: "N/A — version() is stateless; bootstrap() modifies the environment."
  codes: {}

# ---------------------------------------------------------------------------
# module name
# ---------------------------------------------------------------------------

invariant ensurepip.module_name:
  description: "ensurepip.__name__ == 'ensurepip'"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["ensurepip"]
  expected: true

# ---------------------------------------------------------------------------
# function names
# ---------------------------------------------------------------------------

table ensurepip.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: function_name

  columns: [id, function, args, expected]
  rows:
    - [version,   version.__name__.__eq__,   ["version"],   true]
    - [bootstrap, bootstrap.__name__.__eq__, ["bootstrap"], true]

# ---------------------------------------------------------------------------
# version() — return type and structure
# ---------------------------------------------------------------------------

invariant ensurepip.version.returns_str:
  description: "version().__class__.__name__ == 'str' — version() always returns a string"
  category: version
  kind: python_call_eq
  function: version
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

invariant ensurepip.version.nonempty:
  description: "version().__gt__('') — version string is non-empty"
  category: version
  kind: python_call_eq
  function: version
  args: []
  method: __gt__
  method_args: [""]
  expected: true

invariant ensurepip.version.contains_dot:
  description: "version().__contains__('.') == True — pip version strings always contain a dot"
  category: version
  kind: python_call_eq
  function: version
  args: []
  method: __contains__
  method_args: ["."]
  expected: true

invariant ensurepip.version.is_str_type:
  description: "isinstance(version(), str) — version() return value is an instance of str"
  category: version
  kind: python_call_eq
  function: version
  args: []
  method: __class__
  method_chain: __name__
  expected: "str"

