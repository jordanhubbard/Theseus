  model: claude-cli
  attempted_at: 2026-04-15T02:07:26Z
  iterations: 3
  pass_count: 5
  fail_count: 2
  total_invariants: 7
  notes: "Partial synthesis after 3 iteration(s): 5 passing, 2 failing."
  infeasible_reason: null
  invariant_annotations:
    ensurepip.version.returns_str:
      status: failed
      reason: "Result '' has no attribute '__name__.__eq__'"
    ensurepip.version.is_str_type:
      status: failed
      reason: "Result '' has no attribute '__name__'"
