spec: smtpd
version: ">=3.3,<3.12"
backend: python_module(smtpd)

docs: https://docs.python.org/3.11/library/smtpd.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3.11/library/smtpd.html"
    - "Test vectors verified with Python 3.11 on macOS/Darwin 25.4.0, 2026-04-09"
    - "smtpd source: Lib/smtpd.py (PSF; structural inspection only)"
  not_derived_from:
    - "smtpd source: SMTP protocol state machine internals"
    - "smtpd source: actual network socket handling"
  notes:
    - "smtpd was deprecated in Python 3.6 and removed in Python 3.12."
    - "smtpd.SMTPServer is the base SMTP server class; it inherits from asyncore.dispatcher."
    - "smtpd.DebuggingServer extends SMTPServer, printing messages to stdout."
    - "smtpd.PureProxy extends SMTPServer to forward mail to another host."
    - "smtpd.SMTPChannel handles a single client connection; it inherits from asynchat.async_chat."
    - "SMTPServer.__bases__[0].__name__ == 'dispatcher' — inherits from asyncore.dispatcher."
    - "SMTPChannel.__bases__[0].__name__ == 'async_chat' — inherits from asynchat.async_chat."
    - "DebuggingServer.__bases__[0].__name__ == 'SMTPServer'."
    - "PureProxy.__bases__[0].__name__ == 'SMTPServer'."
    - "All expected values verified by running Python 3.11 smtpd module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "smtpd raises no module-specific exception class; network errors propagate from asyncore."
  stderr: "null"
  stickiness: "N/A — class-level structural checks only."
  codes: {}

# ---------------------------------------------------------------------------
# SMTPServer class — name, module, base
# ---------------------------------------------------------------------------

invariant smtpd.SMTPServer_name:
  description: "SMTPServer.__name__ == 'SMTPServer'"
  category: classnames
  kind: python_call_eq
  function: SMTPServer.__name__.__eq__
  args: ["SMTPServer"]
  expected: true

invariant smtpd.SMTPServer_module:
  description: "SMTPServer.__module__ == 'smtpd'"
  category: classnames
  kind: python_call_eq
  function: SMTPServer.__module__.__eq__
  args: ["smtpd"]
  expected: true

invariant smtpd.SMTPServer_base:
  description: "SMTPServer.__bases__[0].__name__ == 'dispatcher' — inherits from asyncore.dispatcher"
  category: classnames
  kind: python_call_eq
  function: SMTPServer.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "dispatcher"

