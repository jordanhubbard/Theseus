# ---------------------------------------------------------------------------
# Cross-module summary — all 18 itertools types, __isub__ only
#
# Confirms that the absence of __isub__ is uniform across the full
# itertools namespace. The same result holds for __imul__ and __itruediv__
# (covered per-group in the tables above).
# ---------------------------------------------------------------------------

table itertools_extra2776.all_types_isub_summary:
  description: "All 18 itertools types — '__isub__' not in __dict__ for any of them; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: it2776as

  columns: [id, function, args, expected]
  rows:
    - ["it2776as_ch",  chain.__dict__.__contains__,                       ["__isub__"], false]
    - ["it2776as_ct",  count.__dict__.__contains__,                       ["__isub__"], false]
    - ["it2776as_rp",  repeat.__dict__.__contains__,                      ["__isub__"], false]
    - ["it2776as_cy",  cycle.__dict__.__contains__,                       ["__isub__"], false]
    - ["it2776as_is",  islice.__dict__.__contains__,                      ["__isub__"], false]
    - ["it2776as_co",  compress.__dict__.__contains__,                    ["__isub__"], false]
    - ["it2776as_dw",  dropwhile.__dict__.__contains__,                   ["__isub__"], false]
    - ["it2776as_tw",  takewhile.__dict__.__contains__,                   ["__isub__"], false]
    - ["it2776as_sm",  starmap.__dict__.__contains__,                     ["__isub__"], false]
    - ["it2776as_gb",  groupby.__dict__.__contains__,                     ["__isub__"], false]
    - ["it2776as_ff",  filterfalse.__dict__.__contains__,                 ["__isub__"], false]
    - ["it2776as_ac",  accumulate.__dict__.__contains__,                  ["__isub__"], false]
    - ["it2776as_zl",  zip_longest.__dict__.__contains__,                 ["__isub__"], false]
    - ["it2776as_pw",  pairwise.__dict__.__contains__,                    ["__isub__"], false]
    - ["it2776as_pr",  product.__dict__.__contains__,                     ["__isub__"], false]
    - ["it2776as_pe",  permutations.__dict__.__contains__,                ["__isub__"], false]
    - ["it2776as_cm",  combinations.__dict__.__contains__,                ["__isub__"], false]
    - ["it2776as_cr",  combinations_with_replacement.__dict__.__contains__, ["__isub__"], false]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra2776
# ---------------------------------------------------------------------------

invariant itertools_extra2776.chain_no_isub:
  description: "'__isub__' not in itertools.chain.__dict__ — chain is an iterator type with no -= operator support"
  category: behavior
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__isub__"]
  expected: false

invariant itertools_extra2776.chain_no_imul:
  description: "'__imul__' not in itertools.chain.__dict__ — chain does not implement the *= operator"
  category: behavior
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__imul__"]
  expected: false

invariant itertools_extra2776.chain_no_itruediv:
  description: "'__itruediv__' not in itertools.chain.__dict__ — chain does not implement the /= operator"
  category: behavior
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__itruediv__"]
  expected: false

invariant itertools_extra2776.product_no_isub:
  description: "'__isub__' not in itertools.product.__dict__ — product is a combinatoric iterator with no -= operator support"
  category: behavior
  kind: python_call_eq
  function: product.__dict__.__contains__
  args: ["__isub__"]
  expected: false

invariant itertools_extra2776.accumulate_no_imul:
  description: "'__imul__' not in itertools.accumulate.__dict__ — despite its name, accumulate does not implement the *= operator"
  category: behavior
  kind: python_call_eq
  function: accumulate.__dict__.__contains__
  args: ["__imul__"]
  expected: false

invariant itertools_extra2776.combinations_with_replacement_no_itruediv:
  description: "'__itruediv__' not in itertools.combinations_with_replacement.__dict__ — combinations_with_replacement does not implement the /= operator"
  category: behavior
  kind: python_call_eq
  function: combinations_with_replacement.__dict__.__contains__
  args: ["__itruediv__"]
  expected: false
