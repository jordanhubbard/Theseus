spec: itertools_extra2776
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave 632 theme: __isub__, __imul__, and __itruediv__ dict-presence checks (in-place subtraction -=, in-place multiplication *=, in-place true division /=)."
    - "All 18 itertools C-level iterator types are checked: chain, count, repeat, cycle, islice, compress, dropwhile, takewhile, starmap, groupby, filterfalse, accumulate, zip_longest, pairwise, product, permutations, combinations, combinations_with_replacement."
    - "None of the itertools types define __isub__, __imul__, or __itruediv__ in their __dict__."
    - "itertools types are C-level types (Modules/itertoolsmodule.c); they expose iteration protocol only."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools basic iterator types — __isub__/__imul__/__itruediv__ dict-presence
#
# chain, count, repeat, cycle, islice, compress, dropwhile, takewhile, starmap
# are C-level types. None defines in-place operator dunders for -=, *=, or /=.
# All nine checks per operator (27 total) return False.
# ---------------------------------------------------------------------------

table itertools_extra2776.basic_iterators_operator_dict:
  description: "itertools chain/count/repeat/cycle/islice/compress/dropwhile/takewhile/starmap — __isub__, __imul__, __itruediv__ dict-presence all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: it2776bi

  columns: [id, function, args, expected]
  rows:
    - ["it2776bi_ch_is",  chain.__dict__.__contains__,     ["__isub__"],      false]
    - ["it2776bi_ch_im",  chain.__dict__.__contains__,     ["__imul__"],      false]
    - ["it2776bi_ch_it",  chain.__dict__.__contains__,     ["__itruediv__"],  false]
    - ["it2776bi_ct_is",  count.__dict__.__contains__,     ["__isub__"],      false]
    - ["it2776bi_ct_im",  count.__dict__.__contains__,     ["__imul__"],      false]
    - ["it2776bi_ct_it",  count.__dict__.__contains__,     ["__itruediv__"],  false]
    - ["it2776bi_rp_is",  repeat.__dict__.__contains__,    ["__isub__"],      false]
    - ["it2776bi_rp_im",  repeat.__dict__.__contains__,    ["__imul__"],      false]
    - ["it2776bi_rp_it",  repeat.__dict__.__contains__,    ["__itruediv__"],  false]
    - ["it2776bi_cy_is",  cycle.__dict__.__contains__,     ["__isub__"],      false]
    - ["it2776bi_cy_im",  cycle.__dict__.__contains__,     ["__imul__"],      false]
    - ["it2776bi_cy_it",  cycle.__dict__.__contains__,     ["__itruediv__"],  false]
    - ["it2776bi_is_is",  islice.__dict__.__contains__,    ["__isub__"],      false]
    - ["it2776bi_is_im",  islice.__dict__.__contains__,    ["__imul__"],      false]
    - ["it2776bi_is_it",  islice.__dict__.__contains__,    ["__itruediv__"],  false]
    - ["it2776bi_co_is",  compress.__dict__.__contains__,  ["__isub__"],      false]
    - ["it2776bi_co_im",  compress.__dict__.__contains__,  ["__imul__"],      false]
    - ["it2776bi_co_it",  compress.__dict__.__contains__,  ["__itruediv__"],  false]
    - ["it2776bi_dw_is",  dropwhile.__dict__.__contains__, ["__isub__"],      false]
    - ["it2776bi_dw_im",  dropwhile.__dict__.__contains__, ["__imul__"],      false]
    - ["it2776bi_dw_it",  dropwhile.__dict__.__contains__, ["__itruediv__"],  false]
    - ["it2776bi_tw_is",  takewhile.__dict__.__contains__, ["__isub__"],      false]
    - ["it2776bi_tw_im",  takewhile.__dict__.__contains__, ["__imul__"],      false]
    - ["it2776bi_tw_it",  takewhile.__dict__.__contains__, ["__itruediv__"],  false]
    - ["it2776bi_sm_is",  starmap.__dict__.__contains__,   ["__isub__"],      false]
    - ["it2776bi_sm_im",  starmap.__dict__.__contains__,   ["__imul__"],      false]
    - ["it2776bi_sm_it",  starmap.__dict__.__contains__,   ["__itruediv__"],  false]

