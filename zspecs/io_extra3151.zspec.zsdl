spec: io3151
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 657 (io3151): __setitem__, __delitem__, __contains__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper, io.IOBase."
    - "No io class defines __setitem__ in its own __dict__: io stream classes do not support item assignment."
    - "No io class defines __delitem__ in its own __dict__: io stream classes do not support item deletion."
    - "No io class defines __contains__ in its own __dict__: io stream classes do not implement membership testing."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __setitem__ dict-presence — operator.contains(Cls.__dict__, '__setitem__')
#
# No io class defines __setitem__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions, not mutable mappings or sequences.
# ---------------------------------------------------------------------------

