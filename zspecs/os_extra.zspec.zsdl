spec: os_extra
version: ">=3.2"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "Python 3 os module documentation — https://docs.python.org/3/library/os.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "os.path — covered separately in os_path.zspec.zsdl"
    - "os.environ — covered separately in os_environ.zspec.zsdl"
    - "os.stat — covered separately in os_stat.zspec.zsdl"
  notes:
    - "This spec extends os.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "os.zspec.zsdl covers: extsep/curdir/pardir values, sep/pathsep lengths, name=='posix', O_RDONLY/O_WRONLY/O_RDWR values, function name table, getenv, getpid() > 0, urandom (len and type), strerror, getcwd() type."
    - "os.sep is '/' on POSIX (macOS/Linux/FreeBSD); this spec checks its class name only."
    - "os.linesep is '\\n' on POSIX; this spec checks its class name only (value is OS-dependent)."
    - "os.pathsep is ':' on POSIX; this spec checks its class name only (value is OS-dependent)."
    - "os.name is 'posix' on macOS/Linux/FreeBSD; checked in os.zspec.zsdl. This spec checks its class name."
    - "os.getcwd() returns a str; type check already in os.zspec.zsdl via method chain. This spec uses class name check."
    - "os.getpid() returns an int > 0; positive check already in os.zspec.zsdl. This spec checks class name."
    - "os.cpu_count() returns an int on all tested platforms, but may return None on some platforms — this spec checks the common case."
    - "os.urandom(8).__class__.__name__ == 'bytes' and len == 8 tested here; type/len checks are in os.zspec.zsdl too, kept here per task spec."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "os functions raise OSError (and subclasses) for filesystem/system call errors; TypeError/ValueError for bad arguments."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Path separator constants — class name checks
# (values already in os.zspec.zsdl; class names are new here)
# ---------------------------------------------------------------------------

invariant os_extra.sep.class_name:
  description: "os.sep.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: sep.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_extra.linesep.class_name:
  description: "os.linesep.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: linesep.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_extra.pathsep.class_name:
  description: "os.pathsep.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: pathsep.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# curdir and pardir — value checks (also in os.zspec.zsdl; repeated per task spec)
# ---------------------------------------------------------------------------

invariant os_extra.curdir.value:
  description: "os.curdir == '.' — current directory symbol on all platforms"
  category: constants
  kind: python_call_eq
  function: curdir.__eq__
  args: ["."]
  expected: true

invariant os_extra.pardir.value:
  description: "os.pardir == '..' — parent directory symbol on all platforms"
  category: constants
  kind: python_call_eq
  function: pardir.__eq__
  args: [".."]
  expected: true

invariant os_extra.extsep.value:
  description: "os.extsep == '.' — file extension separator on all platforms"
  category: constants
  kind: python_call_eq
  function: extsep.__eq__
  args: ["."]
  expected: true

# ---------------------------------------------------------------------------
# os.name — class name check
# ---------------------------------------------------------------------------

invariant os_extra.name.class_name:
  description: "os.name.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: name.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# os.getcwd() — returns a str (class name check)
# ---------------------------------------------------------------------------

invariant os_extra.getcwd.class_name:
  description: "os.getcwd().__class__.__name__ == 'str'"
  category: getcwd
  kind: python_call_eq
  function: getcwd()
  args: []
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# os.getpid() — class name and positivity checks
# ---------------------------------------------------------------------------

invariant os_extra.getpid.class_name:
  description: "os.getpid().__class__.__name__ == 'int'"
  category: process
  kind: python_call_eq
  function: getpid()
  args: []
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true

invariant os_extra.getpid.positive:
  description: "os.getpid() > 0 — process ID is always a positive integer"
  category: process
  kind: python_call_eq
  function: getpid()
  args: []
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# os.cpu_count() — returns int on all tested platforms
# (may return None on some exotic platforms, but always int on POSIX/macOS)
# ---------------------------------------------------------------------------

invariant os_extra.cpu_count.class_name:
  description: "os.cpu_count().__class__.__name__ == 'int' on POSIX platforms"
  category: process
  kind: python_call_eq
  function: cpu_count()
  args: []
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# os.urandom() — random bytes
# ---------------------------------------------------------------------------

invariant os_extra.urandom.class_name:
  description: "os.urandom(8).__class__.__name__ == 'bytes'"
  category: urandom
  kind: python_call_eq
  function: urandom
  args: [8]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant os_extra.urandom.length:
  description: "len(os.urandom(8)) == 8 — returns exactly the requested number of bytes"
  category: urandom
  kind: python_call_eq
  function: urandom
  args: [8]
  method: __len__
  method_args: []
  expected: 8
