spec: abc_extra77
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra76.zspec.zsdl."
    - "This spec covers: wave 245 theme — abc ABCMeta method __qualname__ lengths. NEW in extra77: ABCMeta.register.__qualname__=='ABCMeta.register'; ABCMeta.register.__qualname__.__len__()==16 (len('ABCMeta.register')==16); ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__'; ABCMeta.__instancecheck__.__qualname__.__len__()==25 (len('ABCMeta.__instancecheck__')==25); ABCMeta.__subclasscheck__.__qualname__.__len__()==25 (len('ABCMeta.__subclasscheck__')==25); ABCMeta.__new__.__qualname__.__len__()==15 (ABCMeta.__new__.__qualname__=='ABCMeta.__new__', len==15); ABCMeta._dump_registry.__qualname__.__len__()==22 (len('ABCMeta._dump_registry')==22); ABCMeta.__subclasshook__.__qualname__.__len__()==24 (len('ABCMeta.__subclasshook__')==24); ABCMeta.__init__.__qualname__.__len__()==13 (ABCMeta.__init__.__qualname__=='type.__init__', len==13); ABCMeta.__getattribute__.__qualname__.__len__()==21 (ABCMeta.__getattribute__.__qualname__=='type.__getattribute__', len==21); abstractmethod.__qualname__.__len__()==14; abstractproperty.__qualname__.__len__()==16; update_abstractmethods.__qualname__.__len__()==22. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register'. Dotted qualname for a method. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__qualname__.__len__() == 16. len('ABCMeta.register') == 16. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'. Dotted qualname including dunder. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25. len('ABCMeta.__instancecheck__') == 25. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__qualname__.__len__() == 25. len('ABCMeta.__subclasscheck__') == 25. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__'. len == 15. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta._dump_registry.__qualname__.__len__() == 22. len('ABCMeta._dump_registry') == 22. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasshook__.__qualname__.__len__() == 24. len('ABCMeta.__subclasshook__') == 24. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__init__.__qualname__ == 'type.__init__'. ABCMeta inherits __init__ from type; the qualname reflects the defining class. len('type.__init__') == 13. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__getattribute__.__qualname__ == 'type.__getattribute__'. ABCMeta inherits __getattribute__ from type. len('type.__getattribute__') == 21. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__qualname__.__len__() == 14. len('abstractmethod') == 14. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__qualname__.__len__() == 16. len('abstractproperty') == 16. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__qualname__.__len__() == 22. len('update_abstractmethods') == 22. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc ABCMeta.register and __instancecheck__ qualname checks — extra77
#
# Wave 245 theme: ABCMeta method __qualname__ lengths.
#
# ABCMeta.register.__qualname__ == 'ABCMeta.register'
# ABCMeta.register.__qualname__.__len__() == 16
# ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'
# ABCMeta.__instancecheck__.__qualname__.__len__() == 25
# ABCMeta.__subclasscheck__.__qualname__.__len__() == 25
# ---------------------------------------------------------------------------

table abc_extra77.ABCMeta_register_and_instancecheck_qualnames:
  description: "abc ABCMeta.register and __instancecheck__ qualname checks in abcextra77 namespace — wave 245 theme: ABCMeta method __qualname__ lengths; ABCMeta.register.__qualname__=='ABCMeta.register'; ABCMeta.register.__qualname__.__len__()==16 (len('ABCMeta.register')==16); ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__'; ABCMeta.__instancecheck__.__qualname__.__len__()==25 (len('ABCMeta.__instancecheck__')==25); ABCMeta.__subclasscheck__.__qualname__.__len__()==25; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra77

  columns: [id, function, args, expected, description]
  rows:
    - [register_qualname,       ABCMeta.register.__qualname__.__eq__,              ["ABCMeta.register"],          true, "ABCMeta.register.__qualname__ == 'ABCMeta.register' — dotted qualname for method; verified with Python 3.14.3"]
    - [register_qualname_len,   ABCMeta.register.__qualname__.__len__,             [],                            16,  "ABCMeta.register.__qualname__.__len__() == 16 — len('ABCMeta.register') == 16; verified with Python 3.14.3"]
    - [ic_qualname,             ABCMeta.__instancecheck__.__qualname__.__eq__,     ["ABCMeta.__instancecheck__"], true, "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' — dotted qualname with dunder; verified with Python 3.14.3"]
    - [ic_qualname_len,         ABCMeta.__instancecheck__.__qualname__.__len__,    [],                            25,  "ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — len('ABCMeta.__instancecheck__') == 25; verified with Python 3.14.3"]
    - [sc_qualname_len,         ABCMeta.__subclasscheck__.__qualname__.__len__,    [],                            25,  "ABCMeta.__subclasscheck__.__qualname__.__len__() == 25 — len('ABCMeta.__subclasscheck__') == 25; verified with Python 3.14.3"]

