  description: "abc ABCMeta.__init__ and __getattribute__ inherited qualname checks in abcextra77 namespace — wave 245 theme: inherited method qualnames reflect defining class; ABCMeta.__init__.__qualname__=='type.__init__' (ABCMeta inherits __init__ from type, qualname reflects defining class); ABCMeta.__init__.__qualname__.__len__()==13 (len('type.__init__')==13); ABCMeta.__getattribute__.__qualname__=='type.__getattribute__'; ABCMeta.__getattribute__.__qualname__.__len__()==21 (len('type.__getattribute__')==21); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra77b

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname,            ABCMeta.__init__.__qualname__.__eq__,          ["type.__init__"],          true, "ABCMeta.__init__.__qualname__ == 'type.__init__' — inherited from type; qualname reflects defining class; verified with Python 3.14.3"]
    - [init_qualname_len,        ABCMeta.__init__.__qualname__.__len__,         [],                         13,  "ABCMeta.__init__.__qualname__.__len__() == 13 — len('type.__init__') == 13; verified with Python 3.14.3"]
    - [getattr_qualname,         ABCMeta.__getattribute__.__qualname__.__eq__,  ["type.__getattribute__"],  true, "ABCMeta.__getattribute__.__qualname__ == 'type.__getattribute__' — inherited from type; verified with Python 3.14.3"]
    - [getattr_qualname_len,     ABCMeta.__getattribute__.__qualname__.__len__, [],                         21,  "ABCMeta.__getattribute__.__qualname__.__len__() == 21 — len('type.__getattribute__') == 21; verified with Python 3.14.3"]

