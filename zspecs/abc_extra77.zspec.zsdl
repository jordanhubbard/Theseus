    - [dump_reg_qualname_len,   ABCMeta._dump_registry.__qualname__.__len__,       [], 22, "ABCMeta._dump_registry.__qualname__.__len__() == 22 — len('ABCMeta._dump_registry') == 22; verified with Python 3.14.3"]
    - [subhook_qualname_len,    ABCMeta.__subclasshook__.__qualname__.__len__,     [], 24, "ABCMeta.__subclasshook__.__qualname__.__len__() == 24 — len('ABCMeta.__subclasshook__') == 24; verified with Python 3.14.3"]

