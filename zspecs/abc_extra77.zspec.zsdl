# ---------------------------------------------------------------------------
# Standalone invariants — extra77
# ---------------------------------------------------------------------------

invariant abc_extra77.ABCMeta_register_qualname:
  description: "abc.ABCMeta.register.__qualname__.__eq__('ABCMeta.register') returns True — register is defined directly on ABCMeta so its qualname uses the dotted form 'ABCMeta.register'; NEW in extra77: first standalone __qualname__ invariant for ABCMeta.register in abcextra77 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.register.__qualname__.__eq__
  args: ["ABCMeta.register"]
  expected: true

invariant abc_extra77.ABCMeta_register_qualname_len:
  description: "abc.ABCMeta.register.__qualname__.__len__() == 16 — len('ABCMeta.register') == 16; NEW in extra77: first standalone __qualname__.__len__ invariant for ABCMeta.register in abcextra77 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.register.__qualname__.__len__
  args: []
  expected: 16

invariant abc_extra77.ABCMeta_instancecheck_qualname_len:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — len('ABCMeta.__instancecheck__') == 25; __instancecheck__ is defined on ABCMeta to support isinstance() checks with abstract classes; NEW in extra77: first standalone __qualname__.__len__ invariant for ABCMeta.__instancecheck__ in abcextra77 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__qualname__.__len__
  args: []
  expected: 25

invariant abc_extra77.ABCMeta_new_qualname_len:
  description: "abc.ABCMeta.__new__.__qualname__.__len__() == 15 — len('ABCMeta.__new__') == 15; ABCMeta.__new__ is defined on ABCMeta to set up the abc machinery; NEW in extra77: first standalone __qualname__.__len__ invariant for ABCMeta.__new__ in abcextra77 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__new__.__qualname__.__len__
  args: []
  expected: 15

invariant abc_extra77.abstractmethod_qualname_len:
  description: "abc.abstractmethod.__qualname__.__len__() == 14 — len('abstractmethod') == 14; abstractmethod is a top-level class/decorator in abc.py; NEW in extra77: first standalone __qualname__.__len__ invariant for abstractmethod in abcextra77 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__qualname__.__len__
  args: []
  expected: 14
